/* ============================================================================
 * ast_accessors port -- batch 2: call args/callee + single-child expr/stmt/arg.
 * ast_kind_child(ast,node,want_kind,off) = the common shape: get node, verify
 * kind, return the u32 field at byte offset.  want_kind/off copied to locals
 * before the iii_ast_get call (param-spill guard, verified).  Offsets from
 * gen_ast_offsets (note stmt_let bool-padding: let_.value_expr@24).
 * ============================================================================ */

fn ast_kind_child(ast: u64, node: u32, want_kind: u32, off: u64) -> u32 {
    let wk: u32 = want_kind
    let o: u64 = off
    if ast == 0u64 { return 0u32 }
    if node == 0u32 { return 0u32 }
    let n: u64 = iii_ast_get(ast, node)
    if n == 0u64 { return 0u32 }
    if iii_lex_read_u32_c(n, 0u64) != wk { return 0u32 }
    return iii_lex_read_u32_c(n, o)
}

fn iii_ast_call_arg_count(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_EXPR_CALL, 16u64) }
fn iii_ast_call_callee(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_EXPR_CALL, 8u64) }
fn iii_ast_let_value(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_STMT_LET, 24u64) }
fn iii_ast_expr_stmt_expr(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_STMT_EXPR, 8u64) }
fn iii_ast_return_value(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_STMT_RETURN, 8u64) }
fn iii_ast_assign_lvalue(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_STMT_ASSIGN, 8u64) }
fn iii_ast_assign_value(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_STMT_ASSIGN, 12u64) }
fn iii_ast_field_object(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_EXPR_FIELD, 8u64) }
fn iii_ast_index_object(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_EXPR_INDEX, 8u64) }
fn iii_ast_index_index(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_EXPR_INDEX, 12u64) }
fn iii_ast_binary_lhs(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_EXPR_BINARY, 12u64) }
fn iii_ast_binary_rhs(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_EXPR_BINARY, 16u64) }
fn iii_ast_unary_operand(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_EXPR_UNARY, 12u64) }
fn iii_ast_paren_inner(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_EXPR_PAREN, 8u64) }
fn iii_ast_arg_value(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_ARG, 16u64) }
fn iii_ast_arg_name_off(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_ARG, 8u64) }
fn iii_ast_arg_name_len(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_ARG, 12u64) }

fn iii_ast_call_arg_at(ast: u64, node: u32, i: u32) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    if node == 0u32 { return 0u32 }
    let n: u64 = iii_ast_get(ast, node)
    if n == 0u64 { return 0u32 }
    if iii_lex_read_u32_c(n, 0u64) != III_AST_EXPR_CALL { return 0u32 }
    let lp: u64 = iii_lex_read_u64_c(n, 12u64)
    let idx: u32 = i
    return iii_ast_list_at(ast, lp, idx)
}

/* ============================================================================
 * ast_accessors port -- batch 3: cycle_decl + modifier + type_ref/type_decl.
 * ast_kind_list_at(ast,node,want_kind,list_off,i) = kind-checked packed-list
 * element read (the list companion to ast_kind_child; all reg params spill-guarded).
 * ============================================================================ */

fn ast_kind_list_at(ast: u64, node: u32, want_kind: u32, list_off: u64, i: u32) -> u32 {
    let wk: u32 = want_kind
    let lo: u64 = list_off
    let idx: u32 = i
    if ast == 0u64 { return 0u32 }
    if node == 0u32 { return 0u32 }
    let n: u64 = iii_ast_get(ast, node)
    if n == 0u64 { return 0u32 }
    if iii_lex_read_u32_c(n, 0u64) != wk { return 0u32 }
    let lp: u64 = iii_lex_read_u64_c(n, lo)
    return iii_ast_list_at(ast, lp, idx)
}

fn iii_ast_cycle_modifier_count(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_CYCLE_DECL, 32u64) }
fn iii_ast_cycle_modifier_at(ast: u64, node: u32, i: u32) -> u32 @export { return ast_kind_list_at(ast, node, III_AST_CYCLE_DECL, 28u64, i) }
fn iii_ast_cycle_forward_block(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_CYCLE_DECL, 36u64) }
fn iii_ast_cycle_compromise_block(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_CYCLE_DECL, 40u64) }
fn iii_ast_modifier_name_offset(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_MODIFIER, 8u64) }
fn iii_ast_modifier_name_length(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_MODIFIER, 12u64) }
fn iii_ast_type_ref_modifier_count(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_TYPE_REF, 28u64) }
fn iii_ast_type_ref_modifier_at(ast: u64, node: u32, i: u32) -> u32 @export { return ast_kind_list_at(ast, node, III_AST_TYPE_REF, 24u64, i) }
fn iii_ast_type_decl_modifier_count(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_TYPE_DECL, 32u64) }
fn iii_ast_type_decl_modifier_at(ast: u64, node: u32, i: u32) -> u32 @export { return ast_kind_list_at(ast, node, III_AST_TYPE_DECL, 28u64, i) }
fn iii_ast_type_decl_rhs_type(ast: u64, node: u32) -> u32 @export { return ast_kind_child(ast, node, III_AST_TYPE_DECL, 24u64) }

/* ============================================================================
 * ast_accessors port -- batch 4: raw-memory pokes (native deref) + source-buffer
 * slice + type_decl_for_name (decl-loop + iii_lex_memcmp_c).  The non-kind_child
 * shapes.  source_buf/source_len/root_module already @export above.
 * ============================================================================ */

fn iii_ast_load_u8(ptr: u64) -> u32 @export {
    if ptr == 0u64 { return 0u32 }
    let p: *u8 = ptr as *u8
    return p[0] as u32
}
fn iii_ast_store_u8(ptr: u64, v: u32) -> u32 @export {
    if ptr == 0u64 { return 0u32 }
    let p: *u8 = ptr as *u8
    p[0] = (v & 0xFFu32) as u8
    return 0u32
}
fn iii_ast_store_u32(ptr: u64, v: u32) -> u32 @export {
    if ptr == 0u64 { return 0u32 }
    let p: *u32 = ptr as *u32
    p[0] = v
    return 0u32
}

fn iii_ast_source_slice(ast: u64, offset: u32, length: u32) -> u64 @export {
    let off: u32 = offset
    let len: u32 = length
    if ast == 0u64 { return 0u64 }
    let src: u64 = iii_ast_source_buf(ast)
    if src == 0u64 { return 0u64 }
    let slen: u64 = iii_ast_source_len(ast)
    if (off as u64) + (len as u64) > slen { return 0u64 }
    return src + (off as u64)
}

fn iii_ast_type_decl_for_name(ast: u64, name_offset: u32, name_length: u32) -> u32 @export {
    let no: u32 = name_offset
    let nl: u32 = name_length
    if ast == 0u64 { return 0u32 }
    if nl == 0u32 { return 0u32 }
    let src: u64 = iii_ast_source_buf(ast)
    if src == 0u64 { return 0u32 }
    let root: u32 = iii_ast_root_module(ast)
    let modn: u64 = iii_ast_get(ast, root)
    if modn == 0u64 { return 0u32 }
    if iii_lex_read_u32_c(modn, 0u64) != III_AST_MODULE { return 0u32 }
    let noff: u64 = src + (no as u64)
    let dcount: u32 = iii_lex_read_u32_c(modn, 36u64)
    let dlist: u64 = iii_lex_read_u64_c(modn, 32u64)
    let mut i: u32 = 0u32
    while i < dcount {
        let did: u32 = iii_ast_list_at(ast, dlist, i)
        let d: u64 = iii_ast_get(ast, did)
        if d != 0u64 {
            if iii_lex_read_u32_c(d, 0u64) == III_AST_TYPE_DECL {
                if iii_lex_read_u32_c(d, 12u64) == nl {
                    let doff: u64 = src + (iii_lex_read_u32_c(d, 8u64) as u64)
                    if iii_lex_memcmp_c(doff, noff, nl as u64) == 0i32 {
                        return did
                    }
                }
            }
        }
        i = i + 1u32
    }
    return 0u32
}

/* Distinct node count (sum of pool counts minus the 4 NULL sentinels). */
fn iii_ast_node_count(ast: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    let s: u64 = iii_lex_read_u32_c(ast, AST_OFF_SMALL_COUNT) as u64
    let m: u64 = iii_lex_read_u32_c(ast, AST_OFF_MEDIUM_COUNT) as u64
    let l: u64 = iii_lex_read_u32_c(ast, AST_OFF_LARGE_COUNT) as u64
    let u: u64 = iii_lex_read_u32_c(ast, AST_OFF_USER_COUNT) as u64
    return (s + m + l + u) - 4u64
}

fn iii_ast_pool_count(ast: u64, pool: u32) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    let mut ok: u32 = 0u32
    if pool == III_AST_POOL_SMALL { ok = 1u32 }
    if pool == III_AST_POOL_MEDIUM { ok = 1u32 }
    if pool == III_AST_POOL_LARGE { ok = 1u32 }
    if pool == III_AST_POOL_USER { ok = 1u32 }
    if ok == 0u32 { return 0u64 }
    let c: u32 = iii_lex_read_u32_c(ast, ast_off_count(pool))
    if c == 0u32 { return 0u64 }
    return (c - 1u32) as u64
}

fn iii_ast_recompute_root_mhash(ast: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    let rm: u32 = iii_lex_read_u32_c(ast, AST_OFF_ROOT_MODULE)
    if rm == 0u32 {
        iii_lex_memset_c(ast + AST_OFF_ROOT_MODULE_MHASH, 0u32, 32u64)
        return 0u32
    }
    let mh: u64 = iii_ast_node_mhash(ast, rm)
    if mh != 0u64 { iii_lex_memcpy_c(ast + AST_OFF_ROOT_MODULE_MHASH, mh, 32u64) }
    if mh == 0u64 { iii_lex_memset_c(ast + AST_OFF_ROOT_MODULE_MHASH, 0u32, 32u64) }
    return 0u32
}

fn iii_ast_set_root_module(ast: u64, node_index: u32) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    iii_lex_write_u32_c(ast, AST_OFF_ROOT_MODULE, node_index)
    iii_ast_recompute_root_mhash(ast)
    return 0u32
}

/* ============================================================================
 * RITCHIE Stage 2.2.16 -- binder-id (M1) + doc-comment (G1) side-tables.
 * Mirrors ast.c alloc_binder_id/node_binder_id/set_binder_id (1574-1603) +
 * leading_doc_comment/set_leading_doc_comment (1605-1629).  All use the raw
 * per-pool count (incl the slot-0 sentinel).
 * ============================================================================ */

fn iii_ast_alloc_binder_id(ast: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    let id: u32 = iii_lex_read_u32_c(ast, AST_OFF_NEXT_BINDER_ID)
    iii_lex_write_u32_c(ast, AST_OFF_NEXT_BINDER_ID, id + 1u32)
    return id
}
fn iii_ast_node_binder_id(ast: u64, node_index: u32) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    if node_index == 0u32 { return 0u32 }
    let pool: u32 = ast_node_pool(node_index)
    let slot: u64 = ast_node_slot(node_index)
    let cnt: u32 = iii_lex_read_u32_c(ast, ast_off_count(pool))
    if slot >= (cnt as u64) { return 0u32 }
    let base: u64 = iii_lex_read_u64_c(ast, ast_off_binder(pool))
    return iii_lex_read_u32_c(base + slot * 4u64, 0u64)
}
fn iii_ast_set_binder_id(ast: u64, node_index: u32, binder_id: u32) -> i32 @export {
    if ast == 0u64 { return 0i32 }
    if node_index == 0u32 { return 0i32 }
    let pool: u32 = ast_node_pool(node_index)
    let slot: u64 = ast_node_slot(node_index)
    let cnt: u32 = iii_lex_read_u32_c(ast, ast_off_count(pool))
    if slot >= (cnt as u64) { return 0i32 }
    let base: u64 = iii_lex_read_u64_c(ast, ast_off_binder(pool))
    iii_lex_write_u32_c(base + slot * 4u64, 0u64, binder_id)
    return 1i32
}
fn iii_ast_leading_doc_comment(ast: u64, node_index: u32) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    if node_index == 0u32 { return 0u32 }
    let pool: u32 = ast_node_pool(node_index)
    let slot: u64 = ast_node_slot(node_index)
    let cnt: u32 = iii_lex_read_u32_c(ast, ast_off_count(pool))
    if slot >= (cnt as u64) { return 0u32 }
    let base: u64 = iii_lex_read_u64_c(ast, ast_off_doc(pool))
    return iii_lex_read_u32_c(base + slot * 4u64, 0u64)
}
fn iii_ast_set_leading_doc_comment(ast: u64, node_index: u32, doc_comment_node: u32) -> i32 @export {
    if ast == 0u64 { return 0i32 }
    if node_index == 0u32 { return 0i32 }
    let pool: u32 = ast_node_pool(node_index)
    let slot: u64 = ast_node_slot(node_index)
    let cnt: u32 = iii_lex_read_u32_c(ast, ast_off_count(pool))
    if slot >= (cnt as u64) { return 0i32 }
    let base: u64 = iii_lex_read_u64_c(ast, ast_off_doc(pool))
    iii_lex_write_u32_c(base + slot * 4u64, 0u64, doc_comment_node)
    return 1i32
}

/* ============================================================================
 * RITCHIE Stage 2.2.15b -- kind_name (79-name NUL-pool).  Mirrors ast.c
 * III_AST_KIND_NAMES + iii_ast_kind_name (1395-1483).  iiis-0 literals are not
 * NUL-terminated, so each name is copied + NUL'd into AKN_POOL once; kind_name
 * returns a stable pool offset (or "<bad-kind>" for out-of-range).  Lengths
 * strlen-measured.  Names match ast.c exactly (e.g. MOBIUS_CANDIDATE, not
 * ..._DECL).
 * ============================================================================ */
var AKN_POOL : [u8; 1024]
var AKN_OFF  : [u32; 80]
var AKN_BAD  : u32 = 0u32
var AKN_NEXT : u64 = 0u64
var AKN_INIT : u8 = 0u8

fn akn_add(kind: u32, lit: u64, litlen: u64) -> u32 {
    let base: u64 = (&AKN_POOL as u64) + AKN_NEXT
    iii_lex_memcpy_c(base, lit, litlen)
    iii_lex_write_u8_at_c(base + litlen, 0u64, 0u32)
    iii_lex_write_u32_c(&AKN_OFF as u64, (kind as u64) * 4u64, AKN_NEXT as u32)
    AKN_NEXT = AKN_NEXT + litlen + 1u64
    return 0u32
}
fn akn_init() -> u32 {
    if AKN_INIT == 1u8 { return 0u32 }
    akn_add(III_AST_NULL, "NULL" as u64, 4u64)
    akn_add(III_AST_MODULE, "MODULE" as u64, 6u64)
    akn_add(III_AST_USE, "USE" as u64, 3u64)
    akn_add(III_AST_CYCLE_DECL, "CYCLE_DECL" as u64, 10u64)
    akn_add(III_AST_FN_DECL, "FN_DECL" as u64, 7u64)
    akn_add(III_AST_TYPE_DECL, "TYPE_DECL" as u64, 9u64)
    akn_add(III_AST_CONST_DECL, "CONST_DECL" as u64, 10u64)
    akn_add(III_AST_EXTERN_DECL, "EXTERN_DECL" as u64, 11u64)
    akn_add(III_AST_MOBIUS_CANDIDATE_DECL, "MOBIUS_CANDIDATE" as u64, 16u64)
    akn_add(III_AST_SCHEMA_DECL, "SCHEMA_DECL" as u64, 11u64)
    akn_add(III_AST_SCHEMA_FIELD, "SCHEMA_FIELD" as u64, 12u64)
    akn_add(III_AST_SEALED_CALL_METHOD_DECL, "SEALED_CALL_METHOD" as u64, 18u64)
    akn_add(III_AST_PARAM, "PARAM" as u64, 5u64)
    akn_add(III_AST_TYPE_PARAM, "TYPE_PARAM" as u64, 10u64)
    akn_add(III_AST_MODIFIER, "MODIFIER" as u64, 8u64)
    akn_add(III_AST_TYPE_REF, "TYPE_REF" as u64, 8u64)
    akn_add(III_AST_TYPE_PTR, "TYPE_PTR" as u64, 8u64)
    akn_add(III_AST_TYPE_ARRAY, "TYPE_ARRAY" as u64, 10u64)
    akn_add(III_AST_TYPE_TUPLE, "TYPE_TUPLE" as u64, 10u64)
    akn_add(III_AST_TYPE_FN, "TYPE_FN" as u64, 7u64)
    akn_add(III_AST_STMT_LET, "STMT_LET" as u64, 8u64)
    akn_add(III_AST_STMT_WAVEFRONT, "STMT_WAVEFRONT" as u64, 14u64)
    akn_add(III_AST_STMT_SANCTUM_ENTER, "STMT_SANCTUM_ENTER" as u64, 18u64)
    akn_add(III_AST_STMT_METAL, "STMT_METAL" as u64, 10u64)
    akn_add(III_AST_STMT_FOR, "STMT_FOR" as u64, 8u64)
    akn_add(III_AST_STMT_MATCH, "STMT_MATCH" as u64, 10u64)
    akn_add(III_AST_STMT_RETURN, "STMT_RETURN" as u64, 11u64)
    akn_add(III_AST_STMT_ASSIGN, "STMT_ASSIGN" as u64, 11u64)
    akn_add(III_AST_STMT_EXPR, "STMT_EXPR" as u64, 9u64)
    akn_add(III_AST_FORWARD_BLOCK, "FORWARD_BLOCK" as u64, 13u64)
    akn_add(III_AST_COMPROMISE_BLOCK, "COMPROMISE_BLOCK" as u64, 16u64)
    akn_add(III_AST_MATCH_ARM, "MATCH_ARM" as u64, 9u64)
    akn_add(III_AST_PAT_LITERAL, "PAT_LITERAL" as u64, 11u64)
    akn_add(III_AST_PAT_IDENT, "PAT_IDENT" as u64, 9u64)
    akn_add(III_AST_PAT_HEXAD, "PAT_HEXAD" as u64, 9u64)
    akn_add(III_AST_PAT_WILDCARD, "PAT_WILDCARD" as u64, 12u64)
    akn_add(III_AST_PAT_TUPLE, "PAT_TUPLE" as u64, 9u64)
    akn_add(III_AST_EXPR_INT, "EXPR_INT" as u64, 8u64)
    akn_add(III_AST_EXPR_HEX, "EXPR_HEX" as u64, 8u64)
    akn_add(III_AST_EXPR_MHASH, "EXPR_MHASH" as u64, 10u64)
    akn_add(III_AST_EXPR_STR, "EXPR_STR" as u64, 8u64)
    akn_add(III_AST_EXPR_BOOL, "EXPR_BOOL" as u64, 9u64)
    akn_add(III_AST_EXPR_TRIT, "EXPR_TRIT" as u64, 9u64)
    akn_add(III_AST_EXPR_HEXAD, "EXPR_HEXAD" as u64, 10u64)
    akn_add(III_AST_EXPR_UNIT, "EXPR_UNIT" as u64, 9u64)
    akn_add(III_AST_EXPR_IDENT, "EXPR_IDENT" as u64, 10u64)
    akn_add(III_AST_EXPR_CALL, "EXPR_CALL" as u64, 9u64)
    akn_add(III_AST_EXPR_FIELD, "EXPR_FIELD" as u64, 10u64)
    akn_add(III_AST_EXPR_INDEX, "EXPR_INDEX" as u64, 10u64)
    akn_add(III_AST_EXPR_BINARY, "EXPR_BINARY" as u64, 11u64)
    akn_add(III_AST_EXPR_UNARY, "EXPR_UNARY" as u64, 10u64)
    akn_add(III_AST_EXPR_BLOCK, "EXPR_BLOCK" as u64, 10u64)
    akn_add(III_AST_EXPR_MATCH, "EXPR_MATCH" as u64, 10u64)
    akn_add(III_AST_EXPR_PAREN, "EXPR_PAREN" as u64, 10u64)
    akn_add(III_AST_EXPR_RAW_ASM, "EXPR_RAW_ASM" as u64, 12u64)
    akn_add(III_AST_RING_SET, "RING_SET" as u64, 8u64)
    akn_add(III_AST_HEXAD_NAME, "HEXAD_NAME" as u64, 10u64)
    akn_add(III_AST_ARG, "ARG" as u64, 3u64)
    akn_add(III_AST_EXPR_TYPE, "EXPR_TYPE" as u64, 9u64)
    akn_add(III_AST_TYPE_OF, "TYPE_OF" as u64, 7u64)
    akn_add(III_AST_EXPR_HOLE, "EXPR_HOLE" as u64, 9u64)
    akn_add(III_AST_EXPR_PARALLEL, "EXPR_PARALLEL" as u64, 13u64)
    akn_add(III_AST_ERROR_NODE, "ERROR_NODE" as u64, 10u64)
    akn_add(III_AST_ADR_DECL, "ADR_DECL" as u64, 8u64)
    akn_add(III_AST_CONFORMANCE_CLAIM_DECL, "CONFORMANCE_CLAIM" as u64, 17u64)
    akn_add(III_AST_TEST_CASE_DECL, "TEST_CASE" as u64, 9u64)
    akn_add(III_AST_RATIONALE_DECL, "RATIONALE" as u64, 9u64)
    akn_add(III_AST_OPERATOR_INTENT, "OPERATOR_INTENT" as u64, 15u64)
    akn_add(III_AST_USER_NODE, "USER_NODE" as u64, 9u64)
    akn_add(III_AST_STMT_IF, "STMT_IF" as u64, 7u64)
    akn_add(III_AST_STMT_WHILE, "STMT_WHILE" as u64, 10u64)
    akn_add(III_AST_EXPR_RANGE, "EXPR_RANGE" as u64, 10u64)
    akn_add(III_AST_EXPR_CAST, "EXPR_CAST" as u64, 9u64)
    akn_add(III_AST_EXPR_SIZEOF, "EXPR_SIZEOF" as u64, 11u64)
    akn_add(III_AST_VAR_DECL, "VAR_DECL" as u64, 8u64)
    akn_add(III_AST_STRUCT_DECL, "STRUCT_DECL" as u64, 11u64)
    akn_add(III_AST_STMT_LOOP, "STMT_LOOP" as u64, 9u64)
    akn_add(III_AST_STMT_BREAK, "STMT_BREAK" as u64, 10u64)
    akn_add(III_AST_STMT_CONTINUE, "STMT_CONTINUE" as u64, 13u64)
    /* out-of-range fallback */
    AKN_BAD = AKN_NEXT as u32
    let bb: u64 = (&AKN_POOL as u64) + AKN_NEXT
    iii_lex_memcpy_c(bb, "<bad-kind>" as u64, 10u64)
    iii_lex_write_u8_at_c(bb + 10u64, 0u64, 0u32)
    AKN_NEXT = AKN_NEXT + 11u64
    AKN_INIT = 1u8
    return 0u32
}
fn iii_ast_kind_name(k: u32) -> u64 @export {
    akn_init()
    if k >= III_AST_KIND_COUNT { return (&AKN_POOL as u64) + (AKN_BAD as u64) }
    let off: u32 = iii_lex_read_u32_c(&AKN_OFF as u64, (k as u64) * 4u64)
    return (&AKN_POOL as u64) + (off as u64)
}

/* ============================================================================
 * RITCHIE Stage 2.2.17 -- checkpoint / rollback (E1).  Mirrors ast.c
 * iii_ast_checkpoint (1633-1649) + iii_ast_rollback (1651-1689).  The 44-byte
 * iii_ast_checkpoint_t {11 u32 @ 0,4,..,40} exceeds 8 bytes, so Win64 returns
 * it via a hidden sret pointer (rcx) and passes it by value via a pointer
 * (rdx).  So checkpoint(out_ptr, ast) writes the 11 fields to *out and returns
 * out; rollback(ast, cp_ptr) reads them from *cp_ptr.  Rollback truncates
 * hash-cons entries whose node-index slot is now beyond the boundary, then
 * restores the 10 restored counts (hashcons_count is decremented in place).
 * ============================================================================ */

const CP_SMALL: u64 = 0u64
const CP_MEDIUM: u64 = 4u64
const CP_LARGE: u64 = 8u64
const CP_USER: u64 = 12u64
const CP_LIST_USED: u64 = 16u64
const CP_STRP: u64 = 20u64
const CP_POS: u64 = 24u64
const CP_ANN: u64 = 28u64
const CP_ANNBLOB: u64 = 32u64
const CP_HC: u64 = 36u64
const CP_NBID: u64 = 40u64

fn iii_ast_checkpoint(out: u64, ast: u64) -> u64 @export {
    if out == 0u64 { return out }
    if ast == 0u64 { iii_lex_memset_c(out, 0u32, 44u64) ; return out }
    iii_lex_write_u32_c(out, CP_SMALL, iii_lex_read_u32_c(ast, AST_OFF_SMALL_COUNT))
    iii_lex_write_u32_c(out, CP_MEDIUM, iii_lex_read_u32_c(ast, AST_OFF_MEDIUM_COUNT))
    iii_lex_write_u32_c(out, CP_LARGE, iii_lex_read_u32_c(ast, AST_OFF_LARGE_COUNT))
    iii_lex_write_u32_c(out, CP_USER, iii_lex_read_u32_c(ast, AST_OFF_USER_COUNT))
    iii_lex_write_u32_c(out, CP_LIST_USED, iii_lex_read_u32_c(ast, AST_OFF_LIST_USED))
    iii_lex_write_u32_c(out, CP_STRP, iii_lex_read_u32_c(ast, AST_OFF_STRING_PAYLOAD_COUNT))
    iii_lex_write_u32_c(out, CP_POS, iii_lex_read_u32_c(ast, AST_OFF_POSITION_COUNT))
    iii_lex_write_u32_c(out, CP_ANN, iii_lex_read_u32_c(ast, AST_OFF_ANNOTATION_COUNT))
    iii_lex_write_u32_c(out, CP_ANNBLOB, iii_lex_read_u32_c(ast, AST_OFF_ANNOTATION_BLOB_USED))
    iii_lex_write_u32_c(out, CP_HC, iii_lex_read_u32_c(ast, AST_OFF_HASHCONS_COUNT))
    iii_lex_write_u32_c(out, CP_NBID, iii_lex_read_u32_c(ast, AST_OFF_NEXT_BINDER_ID))
    return out
}

fn iii_ast_rollback(ast: u64, cp_ptr: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    if cp_ptr == 0u64 { return 0u32 }
    let cs: u32 = iii_lex_read_u32_c(cp_ptr, CP_SMALL)
    let cm: u32 = iii_lex_read_u32_c(cp_ptr, CP_MEDIUM)
    let cl: u32 = iii_lex_read_u32_c(cp_ptr, CP_LARGE)
    let cu: u32 = iii_lex_read_u32_c(cp_ptr, CP_USER)
    /* Truncate hash-cons entries whose node now lies beyond the boundary. */
    let cap: u32 = iii_lex_read_u32_c(ast, AST_OFF_HASHCONS_CAP)
    let base: u64 = iii_lex_read_u64_c(ast, AST_OFF_HASHCONS)
    let mut i: u32 = 0u32
    while i != cap {
        let saddr: u64 = base + (i as u64) * HASHCONS_SLOT_BYTES
        let ni: u32 = iii_lex_read_u32_c(saddr, HC_OFF_NODE_INDEX)
        if ni != 0u32 {
            let p: u32 = ast_node_pool(ni)
            let s: u64 = ast_node_slot(ni)
            let mut drop: u32 = 0u32
            if p == III_AST_POOL_SMALL  { if s >= (cs as u64) { drop = 1u32 } }
            if p == III_AST_POOL_MEDIUM { if s >= (cm as u64) { drop = 1u32 } }
            if p == III_AST_POOL_LARGE  { if s >= (cl as u64) { drop = 1u32 } }
            if p == III_AST_POOL_USER   { if s >= (cu as u64) { drop = 1u32 } }
            if drop == 1u32 {
                iii_lex_memset_c(saddr, 0u32, HASHCONS_SLOT_BYTES)
                let hc: u32 = iii_lex_read_u32_c(ast, AST_OFF_HASHCONS_COUNT)
                if hc > 0u32 { iii_lex_write_u32_c(ast, AST_OFF_HASHCONS_COUNT, hc - 1u32) }
            }
        }
        i = i + 1u32
    }
    iii_lex_write_u32_c(ast, AST_OFF_SMALL_COUNT, cs)
    iii_lex_write_u32_c(ast, AST_OFF_MEDIUM_COUNT, cm)
    iii_lex_write_u32_c(ast, AST_OFF_LARGE_COUNT, cl)
    iii_lex_write_u32_c(ast, AST_OFF_USER_COUNT, cu)
    iii_lex_write_u32_c(ast, AST_OFF_LIST_USED, iii_lex_read_u32_c(cp_ptr, CP_LIST_USED))
    iii_lex_write_u32_c(ast, AST_OFF_STRING_PAYLOAD_COUNT, iii_lex_read_u32_c(cp_ptr, CP_STRP))
    iii_lex_write_u32_c(ast, AST_OFF_POSITION_COUNT, iii_lex_read_u32_c(cp_ptr, CP_POS))
    iii_lex_write_u32_c(ast, AST_OFF_ANNOTATION_COUNT, iii_lex_read_u32_c(cp_ptr, CP_ANN))
    iii_lex_write_u32_c(ast, AST_OFF_ANNOTATION_BLOB_USED, iii_lex_read_u32_c(cp_ptr, CP_ANNBLOB))
    iii_lex_write_u32_c(ast, AST_OFF_NEXT_BINDER_ID, iii_lex_read_u32_c(cp_ptr, CP_NBID))
    return 0u32
}

/* ============================================================================
 * RITCHIE Stage 2.2.18a -- iterate_children (callback child enumeration).
 * Mirrors ast.c iii_ast_iterate_children (1693-1928).  The callback fn-pointer
 * is invoked via iiis-0's indirect-call form `fnp(a,b,c,d,e)` (5-arg, proven).
 * Each child slot carries a NUL-terminated slot-kind string from SLOT_POOL.
 * CRITICAL: ast.c's switch has NO arms for the 10 Phase-B kinds (STMT_IF/
 * WHILE/LOOP/BREAK/CONTINUE/RANGE/CAST/SIZEOF/VAR_DECL/STRUCT_DECL) -- they hit
 * default and enumerate no children.  This port mirrors that exactly (byte-
 * equivalence; NOT a "fix").
 * ============================================================================ */

var SLOT_POOL : [u8; 512]
var SLOT_OFF  : [u32; 48]
var SLOT_INIT : u8 = 0u8
var SLOT_NEXT : u64 = 0u64

fn slot_add(id: u32, lit: u64, litlen: u64) -> u32 {
    let base: u64 = (&SLOT_POOL as u64) + SLOT_NEXT
    iii_lex_memcpy_c(base, lit, litlen)
    iii_lex_write_u8_at_c(base + litlen, 0u64, 0u32)
    iii_lex_write_u32_c(&SLOT_OFF as u64, (id as u64) * 4u64, SLOT_NEXT as u32)
    SLOT_NEXT = SLOT_NEXT + litlen + 1u64
    return 0u32
}
fn slot_init() -> u32 {
    if SLOT_INIT == 1u8 { return 0u32 }
    slot_add(0u32, "modifiers" as u64, 9u64)
    slot_add(1u32, "uses" as u64, 4u64)
    slot_add(2u32, "decls" as u64, 5u64)
    slot_add(3u32, "closure" as u64, 7u64)
    slot_add(4u32, "params" as u64, 6u64)
    slot_add(5u32, "return_type" as u64, 11u64)
    slot_add(6u32, "forward" as u64, 7u64)
    slot_add(7u32, "compromise" as u64, 10u64)
    slot_add(8u32, "body" as u64, 4u64)
    slot_add(9u32, "type_params" as u64, 11u64)
    slot_add(10u32, "rhs" as u64, 3u64)
    slot_add(11u32, "type" as u64, 4u64)
    slot_add(12u32, "value" as u64, 5u64)
    slot_add(13u32, "in_type" as u64, 7u64)
    slot_add(14u32, "out_type" as u64, 8u64)
    slot_add(15u32, "fields" as u64, 6u64)
    slot_add(16u32, "args" as u64, 4u64)
    slot_add(17u32, "expr" as u64, 4u64)
    slot_add(18u32, "hexad" as u64, 5u64)
    slot_add(19u32, "type_args" as u64, 9u64)
    slot_add(20u32, "inner" as u64, 5u64)
    slot_add(21u32, "components" as u64, 10u64)
    slot_add(22u32, "nodes" as u64, 5u64)
    slot_add(23u32, "on_rollback" as u64, 11u64)
    slot_add(24u32, "iter" as u64, 4u64)
    slot_add(25u32, "where" as u64, 5u64)
    slot_add(26u32, "scrutinee" as u64, 9u64)
    slot_add(27u32, "arms" as u64, 4u64)
    slot_add(28u32, "lvalue" as u64, 6u64)
    slot_add(29u32, "stmts" as u64, 5u64)
    slot_add(30u32, "pattern" as u64, 7u64)
    slot_add(31u32, "guard" as u64, 5u64)
    slot_add(32u32, "literal" as u64, 7u64)
    slot_add(33u32, "payload_pats" as u64, 12u64)
    slot_add(34u32, "callee" as u64, 6u64)
    slot_add(35u32, "object" as u64, 6u64)
    slot_add(36u32, "index" as u64, 5u64)
    slot_add(37u32, "lhs" as u64, 3u64)
    slot_add(38u32, "operand" as u64, 7u64)
    slot_add(39u32, "branches" as u64, 8u64)
    slot_add(40u32, "proof" as u64, 5u64)
    slot_add(41u32, "precondition" as u64, 12u64)
    slot_add(42u32, "action" as u64, 6u64)
    slot_add(43u32, "postcondition" as u64, 13u64)
    slot_add(44u32, "term" as u64, 4u64)
    slot_add(45u32, "type_hint" as u64, 9u64)
    slot_add(46u32, "witness" as u64, 7u64)
    slot_add(47u32, "children" as u64, 8u64)
    SLOT_INIT = 1u8
    return 0u32
}
fn slot_str(id: u32) -> u64 {
    slot_init()
    let off: u32 = iii_lex_read_u32_c(&SLOT_OFF as u64, (id as u64) * 4u64)
    return (&SLOT_POOL as u64) + (off as u64)
}

/* iter-ctx buffer: {fn@0, ctx@8, ast@16, node@24(u32), err@28(i32)} = 32B. */
const IC_FN: u64 = 0u64
const IC_CTX: u64 = 8u64
const IC_AST: u64 = 16u64
const IC_NODE: u64 = 24u64
const IC_ERR: u64 = 28u64

fn ast_iter_child(ic: u64, child: u32, slot_id: u32) -> i32 {
    let err: u32 = iii_lex_read_u32_c(ic, IC_ERR)
    if err != 0u32 { return err as i32 }
    if child == 0u32 { return 0i32 }
    let fnp: u64 = iii_lex_read_u64_c(ic, IC_FN)
    let ctx: u64 = iii_lex_read_u64_c(ic, IC_CTX)
    let ast: u64 = iii_lex_read_u64_c(ic, IC_AST)
    let parent: u32 = iii_lex_read_u32_c(ic, IC_NODE)
    let slotp: u64 = slot_str(slot_id)
    let r: u32 = fnp(ast, parent, child, slotp, ctx)
    if r != 0u32 { iii_lex_write_u32_c(ic, IC_ERR, r) }
    return r as i32
}
fn ast_iter_list(ic: u64, list_addr: u64, slot_id: u32) -> i32 {
    let off: u32 = iii_lex_read_u32_c(list_addr, LIST_OFF_OFFSET)
    let cnt: u32 = iii_lex_read_u32_c(list_addr, LIST_OFF_COUNT)
    let ast: u64 = iii_lex_read_u64_c(ic, IC_AST)
    let la: u64 = iii_lex_read_u64_c(ast, AST_OFF_LIST_ARENA)
    let mut i: u32 = 0u32
    let mut res: i32 = 0i32
    let mut done: u32 = 0u32
    while done == 0u32 {
        if i == cnt { done = 1u32 }
        if done == 0u32 {
            let child: u32 = iii_lex_read_u32_c(la + ((off as u64) + (i as u64)) * 4u64, 0u64)
            res = ast_iter_child(ic, child, slot_id)
            if res != 0i32 { done = 1u32 }
            i = i + 1u32
        }
    }
    return res
}

/* Per-kind child enumeration (early return per arm; leaves + the 10 Phase-B
 * kinds fall through to the trailing return 0 -- mirrors ast.c default). */
fn ast_iter_dispatch(ic: u64, np: u64, kind: u32) -> i32 {
    if kind == III_AST_MODULE {
        ast_iter_list(ic, np + 16u64, 0u32)
        ast_iter_list(ic, np + 24u64, 1u32)
        ast_iter_list(ic, np + 32u64, 2u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_USE {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 16u64), 3u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_CYCLE_DECL {
        ast_iter_list(ic, np + 16u64, 4u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 24u64), 5u32)
        ast_iter_list(ic, np + 28u64, 0u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 36u64), 6u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 40u64), 7u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_FN_DECL {
        ast_iter_list(ic, np + 16u64, 4u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 24u64), 5u32)
        ast_iter_list(ic, np + 28u64, 0u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 36u64), 8u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_TYPE_DECL {
        ast_iter_list(ic, np + 16u64, 9u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 24u64), 10u32)
        ast_iter_list(ic, np + 28u64, 0u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_CONST_DECL {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 16u64), 11u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 20u64), 12u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_EXTERN_DECL {
        ast_iter_list(ic, np + 20u64, 4u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 28u64), 5u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_MOBIUS_CANDIDATE_DECL {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 16u64), 13u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 20u64), 14u32)
        ast_iter_list(ic, np + 24u64, 0u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 32u64), 6u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_SCHEMA_DECL {
        ast_iter_list(ic, np + 16u64, 15u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_SCHEMA_FIELD {
        ast_iter_list(ic, np + 20u64, 16u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 28u64), 17u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_SEALED_CALL_METHOD_DECL {
        ast_iter_list(ic, np + 16u64, 4u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 24u64), 5u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 32u64), 8u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_PARAM {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 16u64), 11u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_MODIFIER {
        ast_iter_list(ic, np + 16u64, 16u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 28u64), 18u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_TYPE_REF {
        ast_iter_list(ic, np + 16u64, 19u32)
        ast_iter_list(ic, np + 24u64, 0u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_TYPE_PTR {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 20u32)
        ast_iter_list(ic, np + 12u64, 0u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_TYPE_ARRAY {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 20u32)
        ast_iter_list(ic, np + 24u64, 0u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_TYPE_TUPLE {
        ast_iter_list(ic, np + 8u64, 21u32)
