        ast_iter_child(ic, iii_lex_read_u32_c(np, 16u64), 8u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_PAT_LITERAL {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 32u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_PAT_IDENT {
        ast_iter_list(ic, np + 16u64, 33u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_PAT_TUPLE {
        ast_iter_list(ic, np + 8u64, 21u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_EXPR_CALL {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 34u32)
