    }
    if kind == III_AST_EXPR_PARALLEL {
        ast_iter_list(ic, np + 8u64, 39u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_ADR_DECL {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 24u64), 8u32)
        ast_iter_list(ic, np + 28u64, 0u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_CONFORMANCE_CLAIM_DECL {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 24u64), 40u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_TEST_CASE_DECL {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 16u64), 41u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 20u64), 42u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 24u64), 43u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_OPERATOR_INTENT {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 44u64), 46u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_USER_NODE {
        ast_iter_list(ic, np + 12u64, 47u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    return 0i32
}

fn iii_ast_iterate_children(ast: u64, node: u32, fn_ptr: u64, ctx: u64) -> i32 @export {
    if ast == 0u64 { return 0i32 - 1i32 }
    if fn_ptr == 0u64 { return 0i32 - 1i32 }
    let np: u64 = iii_ast_get(ast, node)
    if np == 0u64 { return 0i32 - 1i32 }
    let kind: u32 = iii_lex_read_u32_c(np, NODE_OFF_KIND)
    let ic: u64 = iii_lex_malloc_c(32u64)
    if ic == 0u64 { return 0i32 - 1i32 }
    iii_lex_write_u64_c(ic, IC_FN, fn_ptr)
    iii_lex_write_u64_c(ic, IC_CTX, ctx)
    iii_lex_write_u64_c(ic, IC_AST, ast)
    iii_lex_write_u32_c(ic, IC_NODE, node)
    iii_lex_write_u32_c(ic, IC_ERR, 0u32)
    let r: i32 = ast_iter_dispatch(ic, np, kind)
    iii_lex_free_c(ic)
    return r
}

/* ============================================================================
 * RITCHIE Stage 2.2.18b -- walk_pre / walk_post (callback recursion).  Mirrors
 * ast.c iii_walk_child_visit + iii_ast_walk_pre/walk_post (1940-1976).  Uses
 * iiis-0 forward-reference support (proven): the walk inners forward-ref
 * `ast_walk_child_visit as u64` and pass it to iterate_children, which invokes
 * it; it recurses back into the inners.  visit_fn is fn(ast,node,depth,ctx);
 * depth is always 0 (mirrors ast.c, where each walk_pre/post resets depth -- a
 * latent ast.c quirk replicated for byte-equivalence).  walk_ctx =
 * {fn@0,ctx@8,err@16(i32),post@20(u8)}=32B.
 * ============================================================================ */

const WC_BYTES: u64 = 32u64
const WC_FN: u64 = 0u64
const WC_CTX: u64 = 8u64
const WC_ERR: u64 = 16u64
const WC_POST: u64 = 20u64

fn ast_walk_pre_inner(ast: u64, root: u32, fnp: u64, ctx: u64) -> i32 {
    if ast == 0u64 { return 0i32 }
    if fnp == 0u64 { return 0i32 }
    if root == 0u32 { return 0i32 }
    let r0: u32 = fnp(ast, root, 0u32, ctx)
    if r0 != 0u32 { return r0 as i32 }
    let w: u64 = iii_lex_malloc_c(WC_BYTES)
    if w == 0u64 { return 0i32 }
    iii_lex_memset_c(w, 0u32, WC_BYTES)
    iii_lex_write_u64_c(w, WC_FN, fnp)
    iii_lex_write_u64_c(w, WC_CTX, ctx)
    iii_lex_write_u8_at_c(w, WC_POST, 0u32)
    let r: i32 = iii_ast_iterate_children(ast, root, ast_walk_child_visit as u64, w)
    iii_lex_free_c(w)
    return r
}

fn ast_walk_post_inner(ast: u64, root: u32, fnp: u64, ctx: u64) -> i32 {
    if ast == 0u64 { return 0i32 }
    if fnp == 0u64 { return 0i32 }
    if root == 0u32 { return 0i32 }
    let w: u64 = iii_lex_malloc_c(WC_BYTES)
    if w == 0u64 { return 0i32 }
    iii_lex_memset_c(w, 0u32, WC_BYTES)
    iii_lex_write_u64_c(w, WC_FN, fnp)
    iii_lex_write_u64_c(w, WC_CTX, ctx)
    iii_lex_write_u8_at_c(w, WC_POST, 1u32)
    let r: i32 = iii_ast_iterate_children(ast, root, ast_walk_child_visit as u64, w)
    iii_lex_free_c(w)
    if r != 0i32 { return r }
    let r2: u32 = fnp(ast, root, 0u32, ctx)
    return r2 as i32
}

fn ast_walk_child_visit(ast: u64, parent: u32, child: u32, slot_kind: u64, ctx: u64) -> i32 {
    let w: u64 = ctx
    let err: u32 = iii_lex_read_u32_c(w, WC_ERR)
    if err != 0u32 { return err as i32 }
    let fnp: u64 = iii_lex_read_u64_c(w, WC_FN)
    let wctx: u64 = iii_lex_read_u64_c(w, WC_CTX)
    let post: u32 = iii_lex_read_u8_at_c(w, WC_POST)
    let mut r: i32 = 0i32
    if post == 1u32 { r = ast_walk_post_inner(ast, child, fnp, wctx) }
    if post == 0u32 { r = ast_walk_pre_inner(ast, child, fnp, wctx) }
    if r != 0i32 { iii_lex_write_u32_c(w, WC_ERR, r as u32) }
    return r
}

fn iii_ast_walk_pre(ast: u64, root: u32, fn_ptr: u64, ctx: u64) -> i32 @export {
    return ast_walk_pre_inner(ast, root, fn_ptr, ctx)
}
fn iii_ast_walk_post(ast: u64, root: u32, fn_ptr: u64, ctx: u64) -> i32 @export {
    return ast_walk_post_inner(ast, root, fn_ptr, ctx)
}

/* ============================================================================
 * RITCHIE Stage 2.2.19 -- zipper (I1).  Mirrors ast.c iii_ast_zipper_*
 * (1994-2059).  The zipper struct is opaque (callers hold the ptr only), so
 * the layout is self-chosen: {ast@0, cur@8(u32), depth@12(u32), stack@16}.
 * Each frame = {parent_node@0(u32), child_index@4(u32)} = 8B; stack[1024].
 * descend/sibling collect the current/parent's children via iterate_children +
 * a collect callback into a {count@0, children@4(u32[1024])} = 4100B scratch.
 * sibling's signed delta is handled via the high-bit (avoids the iiis-0
 * signed-ordering-compare trap).
 * ============================================================================ */

const ZIP_BYTES: u64 = 8208u64
const ZIP_AST: u64 = 0u64
const ZIP_CUR: u64 = 8u64
const ZIP_DEPTH: u64 = 12u64
const ZIP_STACK: u64 = 16u64
const ZCOLLECT_BYTES: u64 = 4100u64

fn ast_zipper_collect_child(ast: u64, parent: u32, child: u32, slot_kind: u64, ctx: u64) -> i32 {
    let count: u32 = iii_lex_read_u32_c(ctx, 0u64)
    if count < 1024u32 {
        iii_lex_write_u32_c(ctx, 4u64 + (count as u64) * 4u64, child)
        iii_lex_write_u32_c(ctx, 0u64, count + 1u32)
    }
    return 0i32
}

fn iii_ast_zipper_at(ast: u64, node_index: u32) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    let z: u64 = iii_lex_malloc_c(ZIP_BYTES)
    if z == 0u64 { return 0u64 }
    iii_lex_memset_c(z, 0u32, ZIP_BYTES)
    iii_lex_write_u64_c(z, ZIP_AST, ast)
    iii_lex_write_u32_c(z, ZIP_CUR, node_index)
    iii_lex_write_u32_c(z, ZIP_DEPTH, 0u32)
    return z
}
fn iii_ast_zipper_destroy(z: u64) -> u32 @export {
    if z != 0u64 { iii_lex_free_c(z) }
    return 0u32
}
fn iii_ast_zipper_node(z: u64) -> u32 @export {
    if z == 0u64 { return 0u32 }
    return iii_lex_read_u32_c(z, ZIP_CUR)
}
fn iii_ast_zipper_depth(z: u64) -> u64 @export {
    if z == 0u64 { return 0u64 }
    return iii_lex_read_u32_c(z, ZIP_DEPTH) as u64
}

fn iii_ast_zipper_descend(z: u64, child_index: u32) -> i32 @export {
    if z == 0u64 { return 0i32 }
    let depth: u32 = iii_lex_read_u32_c(z, ZIP_DEPTH)
    if depth >= 1024u32 { return 0i32 }
    let ast: u64 = iii_lex_read_u64_c(z, ZIP_AST)
    let cur: u32 = iii_lex_read_u32_c(z, ZIP_CUR)
    let c: u64 = iii_lex_malloc_c(ZCOLLECT_BYTES)
    if c == 0u64 { return 0i32 }
    iii_lex_write_u32_c(c, 0u64, 0u32)
    let rc: i32 = iii_ast_iterate_children(ast, cur, ast_zipper_collect_child as u64, c)
    if rc != 0i32 { iii_lex_free_c(c) ; return 0i32 }
    let count: u32 = iii_lex_read_u32_c(c, 0u64)
    if child_index >= count { iii_lex_free_c(c) ; return 0i32 }
    let frame: u64 = z + ZIP_STACK + (depth as u64) * 8u64
    iii_lex_write_u32_c(frame, 0u64, cur)
    iii_lex_write_u32_c(frame, 4u64, child_index)
    iii_lex_write_u32_c(z, ZIP_DEPTH, depth + 1u32)
    iii_lex_write_u32_c(z, ZIP_CUR, iii_lex_read_u32_c(c, 4u64 + (child_index as u64) * 4u64))
    iii_lex_free_c(c)
    return 1i32
}

fn iii_ast_zipper_ascend(z: u64) -> i32 @export {
    if z == 0u64 { return 0i32 }
    let depth: u32 = iii_lex_read_u32_c(z, ZIP_DEPTH)
    if depth == 0u32 { return 0i32 }
    let nd: u32 = depth - 1u32
    iii_lex_write_u32_c(z, ZIP_DEPTH, nd)
    let frame: u64 = z + ZIP_STACK + (nd as u64) * 8u64
    iii_lex_write_u32_c(z, ZIP_CUR, iii_lex_read_u32_c(frame, 0u64))
    return 1i32
}

fn iii_ast_zipper_sibling(z: u64, delta: i32) -> i32 @export {
    if z == 0u64 { return 0i32 }
    let depth: u32 = iii_lex_read_u32_c(z, ZIP_DEPTH)
    if depth == 0u32 { return 0i32 }
    let frame: u64 = z + ZIP_STACK + ((depth - 1u32) as u64) * 8u64
    let parent: u32 = iii_lex_read_u32_c(frame, 0u64)
    let cidx: u32 = iii_lex_read_u32_c(frame, 4u64)
    let ast: u64 = iii_lex_read_u64_c(z, ZIP_AST)
    let c: u64 = iii_lex_malloc_c(ZCOLLECT_BYTES)
    if c == 0u64 { return 0i32 }
    iii_lex_write_u32_c(c, 0u64, 0u32)
    let rc: i32 = iii_ast_iterate_children(ast, parent, ast_zipper_collect_child as u64, c)
    if rc != 0i32 { iii_lex_free_c(c) ; return 0i32 }
    let count: u32 = iii_lex_read_u32_c(c, 0u64)
    let du: u32 = delta as u32
    let mut new_idx: u32 = 0u32
    let mut ok: u32 = 0u32
    if (du & 2147483648u32) == 0u32 {
        new_idx = cidx + du
        if new_idx < count { ok = 1u32 }
    }
    if (du & 2147483648u32) != 0u32 {
        let mag: u32 = 0u32 - du
        if mag <= cidx {
            new_idx = cidx - mag
            ok = 1u32
        }
    }
    if ok == 0u32 { iii_lex_free_c(c) ; return 0i32 }
    iii_lex_write_u32_c(frame, 4u64, new_idx)
    iii_lex_write_u32_c(z, ZIP_CUR, iii_lex_read_u32_c(c, 4u64 + (new_idx as u64) * 4u64))
    iii_lex_free_c(c)
    return 1i32
}

/* ============================================================================
 * RITCHIE Stage 2.2.20a -- walk-state (V1) step-based iterator.  Mirrors ast.c
 * iii_ast_walk_state_create/destroy/step/done (2085-2179).  Opaque ws =
 * {ast@0, stack@8(heap ptr), depth@16(u32), cap@20(u32), post@24(u8),
 * done@25(u8)}=32B.  Heap frame = {node@0,depth@4,next_child@8,child_count@12,
 * children@16(u32[1024])}=4112B.  CRITICAL: ast.c's pre-order step has a
 * documented bug -- after emitting a node it sets next_child=1 (an "emitted"
 * sentinel that conflates with "child[0] consumed"), so PRE-ORDER SKIPS
 * child[0] of every node.  Post-order is correct.  This port mirrors the bug
 * exactly (byte-equivalence; the comment at ast.c:2131-2136 acknowledges it).
 * ============================================================================ */

const WS_BYTES: u64 = 32u64
const WS_AST: u64 = 0u64
const WS_STACK: u64 = 8u64
const WS_DEPTH: u64 = 16u64
const WS_CAP: u64 = 20u64
const WS_POST: u64 = 24u64
const WS_DONE: u64 = 25u64
const WF_BYTES: u64 = 4112u64
const WF_NODE: u64 = 0u64
const WF_DEPTH: u64 = 4u64
const WF_NEXT: u64 = 8u64
const WF_CCOUNT: u64 = 12u64
const WF_CHILDREN: u64 = 16u64

/* Collect node's children into frame.children + frame.child_count. */
fn ast_ws_collect_into(ast: u64, node: u32, frame: u64) -> u32 {
    iii_lex_write_u32_c(frame, WF_CCOUNT, 0u32)
    let c: u64 = iii_lex_malloc_c(ZCOLLECT_BYTES)
    if c == 0u64 { return 0u32 }
    iii_lex_write_u32_c(c, 0u64, 0u32)
    iii_ast_iterate_children(ast, node, ast_zipper_collect_child as u64, c)
    let cnt: u32 = iii_lex_read_u32_c(c, 0u64)
    iii_lex_write_u32_c(frame, WF_CCOUNT, cnt)
    if cnt != 0u32 { iii_lex_memcpy_c(frame + WF_CHILDREN, c + 4u64, (cnt as u64) * 4u64) }
    iii_lex_free_c(c)
    return 0u32
}

fn iii_ast_walk_state_create(ast: u64, root: u32, post_order: u32) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    if root == 0u32 { return 0u64 }
    let ws: u64 = iii_lex_malloc_c(WS_BYTES)
    if ws == 0u64 { return 0u64 }
    iii_lex_memset_c(ws, 0u32, WS_BYTES)
    iii_lex_write_u64_c(ws, WS_AST, ast)
    let cap: u32 = 64u32
    let stack: u64 = iii_lex_malloc_c((cap as u64) * WF_BYTES)
    if stack == 0u64 { iii_lex_free_c(ws) ; return 0u64 }
    iii_lex_memset_c(stack, 0u32, (cap as u64) * WF_BYTES)
    iii_lex_write_u64_c(ws, WS_STACK, stack)
    iii_lex_write_u32_c(ws, WS_CAP, cap)
    let mut pv: u32 = 0u32
    if post_order != 0u32 { pv = 1u32 }
    iii_lex_write_u8_at_c(ws, WS_POST, pv)
    iii_lex_write_u8_at_c(ws, WS_DONE, 0u32)
    iii_lex_write_u32_c(stack, WF_NODE, root)
    iii_lex_write_u32_c(stack, WF_DEPTH, 0u32)
    ast_ws_collect_into(ast, root, stack)
    iii_lex_write_u32_c(stack, WF_NEXT, 0u32)
    iii_lex_write_u32_c(ws, WS_DEPTH, 1u32)
    return ws
}

fn iii_ast_walk_state_destroy(ws: u64) -> u32 @export {
    if ws == 0u64 { return 0u32 }
    let stack: u64 = iii_lex_read_u64_c(ws, WS_STACK)
    if stack != 0u64 { iii_lex_free_c(stack) }
    iii_lex_free_c(ws)
    return 0u32
}

fn iii_ast_walk_state_done(ws: u64) -> i32 @export {
    if ws == 0u64 { return 1i32 }
    if iii_lex_read_u8_at_c(ws, WS_DONE) != 0u32 { return 1i32 }
    return 0i32
}

fn iii_ast_walk_state_step(ws: u64, out_node: u64, out_depth: u64) -> i32 @export {
    if ws == 0u64 { return 0i32 }
    if iii_lex_read_u8_at_c(ws, WS_DONE) != 0u32 { return 0i32 }
    let ast: u64 = iii_lex_read_u64_c(ws, WS_AST)
    let post: u32 = iii_lex_read_u8_at_c(ws, WS_POST)
    let mut result: i32 = 0i32
    let mut loop_done: u32 = 0u32
    while loop_done == 0u32 {
        let depth: u32 = iii_lex_read_u32_c(ws, WS_DEPTH)
        let mut step: u32 = 0u32
        if depth == 0u32 {
            iii_lex_write_u8_at_c(ws, WS_DONE, 1u32)
            result = 0i32
            loop_done = 1u32
            step = 1u32
        }
        if step == 0u32 {
            let stack: u64 = iii_lex_read_u64_c(ws, WS_STACK)
            let top: u64 = stack + ((depth - 1u32) as u64) * WF_BYTES
            let nc: u32 = iii_lex_read_u32_c(top, WF_NEXT)
            let cc: u32 = iii_lex_read_u32_c(top, WF_CCOUNT)
            if post == 0u32 {
                if nc == 0u32 {
                    if out_node != 0u64 { iii_lex_write_u32_c(out_node, 0u64, iii_lex_read_u32_c(top, WF_NODE)) }
                    if out_depth != 0u64 { iii_lex_write_u32_c(out_depth, 0u64, iii_lex_read_u32_c(top, WF_DEPTH)) }
                    iii_lex_write_u32_c(top, WF_NEXT, 1u32)
                    result = 1i32
                    loop_done = 1u32
                    step = 1u32
                }
            }
            if step == 0u32 {
                if nc < cc {
                    let child: u32 = iii_lex_read_u32_c(top + WF_CHILDREN, (nc as u64) * 4u64)
                    iii_lex_write_u32_c(top, WF_NEXT, nc + 1u32)
                    let cap: u32 = iii_lex_read_u32_c(ws, WS_CAP)
                    let mut grow_ok: u32 = 1u32
                    if depth >= cap {
                        let ncap: u32 = cap * 2u32
                        let old: u64 = iii_lex_read_u64_c(ws, WS_STACK)
                        let np: u64 = iii_lex_malloc_c((ncap as u64) * WF_BYTES)
                        if np == 0u64 {
                            iii_lex_write_u8_at_c(ws, WS_DONE, 1u32)
                            result = 0i32
                            loop_done = 1u32
                            grow_ok = 0u32
                        }
                        if grow_ok == 1u32 {
                            iii_lex_memcpy_c(np, old, (cap as u64) * WF_BYTES)
                            iii_lex_free_c(old)
                            iii_lex_write_u64_c(ws, WS_STACK, np)
                            iii_lex_write_u32_c(ws, WS_CAP, ncap)
                        }
                    }
                    if grow_ok == 1u32 {
                        let stack2: u64 = iii_lex_read_u64_c(ws, WS_STACK)
                        let top2: u64 = stack2 + ((depth - 1u32) as u64) * WF_BYTES
                        let td: u32 = iii_lex_read_u32_c(top2, WF_DEPTH)
                        let nf: u64 = stack2 + (depth as u64) * WF_BYTES
                        iii_lex_memset_c(nf, 0u32, WF_BYTES)
                        iii_lex_write_u32_c(nf, WF_NODE, child)
                        iii_lex_write_u32_c(nf, WF_DEPTH, td + 1u32)
                        ast_ws_collect_into(ast, child, nf)
                        iii_lex_write_u32_c(nf, WF_NEXT, 0u32)
                        iii_lex_write_u32_c(ws, WS_DEPTH, depth + 1u32)
                    }
                    step = 1u32
                }
            }
            if step == 0u32 {
                if post != 0u32 {
                    if out_node != 0u64 { iii_lex_write_u32_c(out_node, 0u64, iii_lex_read_u32_c(top, WF_NODE)) }
                    if out_depth != 0u64 { iii_lex_write_u32_c(out_depth, 0u64, iii_lex_read_u32_c(top, WF_DEPTH)) }
                    iii_lex_write_u32_c(ws, WS_DEPTH, depth - 1u32)
                    result = 1i32
                    loop_done = 1u32
                }
                if post == 0u32 {
                    iii_lex_write_u32_c(ws, WS_DEPTH, depth - 1u32)
                }
                step = 1u32
            }
        }
    }
    return result
}

/* ============================================================================
 * RITCHIE Stage 2.2.20b -- walk-state serialize / deserialize.  Mirrors ast.c
 * (2181-2280).  Format: "IIIWLKST"(8) ver(u32=1) post(u8) done(u8) depth(u64)
 * cap(u64), then `depth` frames {node,depth,next_child,child_count(u32 each),
 * children[child_count](u32)}, then a SHA-256 trailer over everything prior.
 * Deserialize trusts its input (skips the SHA verify, per ast.c:2275-2278).
 * ============================================================================ */

fn ast_ws_ser_need(ws: u64) -> u64 {
    let depth: u32 = iii_lex_read_u32_c(ws, WS_DEPTH)
    let stack: u64 = iii_lex_read_u64_c(ws, WS_STACK)
    let mut need: u64 = 30u64
    let mut i: u32 = 0u32
    while i != depth {
        let cc: u32 = iii_lex_read_u32_c(stack + (i as u64) * WF_BYTES, WF_CCOUNT)
        need = need + 16u64 + (cc as u64) * 4u64
        i = i + 1u32
    }
    return need + 32u64
}

fn iii_ast_walk_state_serialize(ws: u64, out: u64, cap: u64) -> u64 @export {
    if ws == 0u64 { return 0u64 }
    let need: u64 = ast_ws_ser_need(ws)
    if out == 0u64 { return need }
    if cap < need { return need }
    let h: u64 = iii_lex_malloc_c(III_AST_SHA256_STATE_BYTES)
    if h == 0u64 { return 0u64 }
    iii_sha256_init(h)
    let mut off: u64 = 0u64
    iii_lex_memcpy_c(out + off, "IIIWLKST" as u64, 8u64) ; off = off + 8u64
    iii_sha256_update(h, "IIIWLKST" as u64, 8u64)
    iii_lex_write_u32_c(out, off, 1u32) ; off = off + 4u64
    iii_sha256_update_u32(h, 1u32)
    let post: u32 = iii_lex_read_u8_at_c(ws, WS_POST)
    iii_lex_write_u8_at_c(out, off, post) ; off = off + 1u64
    iii_sha256_update_u8(h, post)
    let done: u32 = iii_lex_read_u8_at_c(ws, WS_DONE)
    iii_lex_write_u8_at_c(out, off, done) ; off = off + 1u64
    iii_sha256_update_u8(h, done)
    let depth: u32 = iii_lex_read_u32_c(ws, WS_DEPTH)
    iii_lex_write_u64_c(out, off, depth as u64) ; off = off + 8u64
    iii_sha256_update_u64(h, depth as u64)
    let capf: u32 = iii_lex_read_u32_c(ws, WS_CAP)
    iii_lex_write_u64_c(out, off, capf as u64) ; off = off + 8u64
    iii_sha256_update_u64(h, capf as u64)
    let stack: u64 = iii_lex_read_u64_c(ws, WS_STACK)
    let mut i: u32 = 0u32
    while i != depth {
        let f: u64 = stack + (i as u64) * WF_BYTES
        let nd: u32 = iii_lex_read_u32_c(f, WF_NODE)
        iii_lex_write_u32_c(out, off, nd) ; off = off + 4u64 ; iii_sha256_update_u32(h, nd)
        let dp: u32 = iii_lex_read_u32_c(f, WF_DEPTH)
        iii_lex_write_u32_c(out, off, dp) ; off = off + 4u64 ; iii_sha256_update_u32(h, dp)
        let ncx: u32 = iii_lex_read_u32_c(f, WF_NEXT)
        iii_lex_write_u32_c(out, off, ncx) ; off = off + 4u64 ; iii_sha256_update_u32(h, ncx)
        let cc: u32 = iii_lex_read_u32_c(f, WF_CCOUNT)
        iii_lex_write_u32_c(out, off, cc) ; off = off + 4u64 ; iii_sha256_update_u32(h, cc)
        let mut j: u32 = 0u32
        while j != cc {
            let cv: u32 = iii_lex_read_u32_c(f + WF_CHILDREN, (j as u64) * 4u64)
            iii_lex_write_u32_c(out, off, cv) ; off = off + 4u64 ; iii_sha256_update_u32(h, cv)
            j = j + 1u32
        }
        i = i + 1u32
    }
    iii_sha256_final(h, out + off)
    off = off + 32u64
    iii_lex_free_c(h)
    return off
}

fn iii_ast_walk_state_deserialize(ast: u64, bytes: u64, len: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    if bytes == 0u64 { return 0u64 }
    if len < 62u64 { return 0u64 }
    if iii_lex_memcmp_c(bytes, "IIIWLKST" as u64, 8u64) != 0i32 { return 0u64 }
    let ver: u32 = iii_lex_read_u32_c(bytes, 8u64)
    if ver != 1u32 { return 0u64 }
    let post: u32 = iii_lex_read_u8_at_c(bytes, 12u64)
    let done: u32 = iii_lex_read_u8_at_c(bytes, 13u64)
    let d: u64 = iii_lex_read_u64_c(bytes, 14u64)
    let c: u64 = iii_lex_read_u64_c(bytes, 22u64)
    let mut off: u64 = 30u64
    let ws: u64 = iii_lex_malloc_c(WS_BYTES)
    if ws == 0u64 { return 0u64 }
    iii_lex_memset_c(ws, 0u32, WS_BYTES)
    iii_lex_write_u64_c(ws, WS_AST, ast)
    iii_lex_write_u8_at_c(ws, WS_POST, post)
    iii_lex_write_u8_at_c(ws, WS_DONE, done)
    iii_lex_write_u32_c(ws, WS_DEPTH, d as u32)
    let mut capf: u64 = c
    if c == 0u64 { capf = d + 16u64 }
    if c < d { capf = d + 16u64 }
    iii_lex_write_u32_c(ws, WS_CAP, capf as u32)
    let stack: u64 = iii_lex_malloc_c(capf * WF_BYTES)
    if stack == 0u64 { iii_lex_free_c(ws) ; return 0u64 }
    iii_lex_memset_c(stack, 0u32, capf * WF_BYTES)
    iii_lex_write_u64_c(ws, WS_STACK, stack)
    let dd: u32 = d as u32
    let mut i: u32 = 0u32
    let mut fail: u32 = 0u32
    while i != dd {
        if fail == 0u32 {
            if (off + 16u64) > len { fail = 1u32 }
            if fail == 0u32 {
                let f: u64 = stack + (i as u64) * WF_BYTES
                iii_lex_write_u32_c(f, WF_NODE, iii_lex_read_u32_c(bytes, off)) ; off = off + 4u64
                iii_lex_write_u32_c(f, WF_DEPTH, iii_lex_read_u32_c(bytes, off)) ; off = off + 4u64
                iii_lex_write_u32_c(f, WF_NEXT, iii_lex_read_u32_c(bytes, off)) ; off = off + 4u64
                let cc: u32 = iii_lex_read_u32_c(bytes, off) ; off = off + 4u64
                iii_lex_write_u32_c(f, WF_CCOUNT, cc)
                let mut j: u32 = 0u32
                while j != cc {
                    if fail == 0u32 {
                        if (off + 4u64) > len { fail = 1u32 }
                        if fail == 0u32 {
                            iii_lex_write_u32_c(f + WF_CHILDREN, (j as u64) * 4u64, iii_lex_read_u32_c(bytes, off))
                            off = off + 4u64
                        }
                    }
                    j = j + 1u32
                }
            }
        }
        i = i + 1u32
    }
    if fail == 1u32 { iii_ast_walk_state_destroy(ws) ; return 0u64 }
    return ws
}

/* ============================================================================
 * RITCHIE Stage 2.2.21 -- diff (J1).  Mirrors ast.c iii_diff_recurse +
 * iii_ast_diff (2290-2333).  Lockstep mhash compare: equal mhash => identical
 * subtree (prune); else record the (old_node,new_node) pair and, if same kind,
 * recurse pairwise over min(child counts) children (collected via
 * iterate_children).  dc = {out@0,cap@8(u64),produced@16(u64)}=24B; diff_pair =
 * {old_node@0,new_node@4}=8B.  All params assigned to locals (spill-trap dodge).
 * ============================================================================ */

fn ast_diff_recurse(old_ast: u64, old_node: u32, new_ast: u64, new_node: u32, dc: u64) -> u32 {
    let oa: u64 = old_ast
    let na: u64 = new_ast
    let on: u32 = old_node
    let nn: u32 = new_node
    let d: u64 = dc
    let omh: u64 = iii_ast_node_mhash(oa, on)
    let nmh: u64 = iii_ast_node_mhash(na, nn)
    if omh != 0u64 {
        if nmh != 0u64 {
            if iii_lex_memcmp_c(omh, nmh, 32u64) == 0i32 { return 0u32 }
        }
    }
    let produced: u64 = iii_lex_read_u64_c(d, 16u64)
    let cap: u64 = iii_lex_read_u64_c(d, 8u64)
    let out: u64 = iii_lex_read_u64_c(d, 0u64)
    if produced < cap {
        if out != 0u64 {
            iii_lex_write_u32_c(out + produced * 8u64, 0u64, on)
            iii_lex_write_u32_c(out + produced * 8u64, 4u64, nn)
        }
    }
    iii_lex_write_u64_c(d, 16u64, produced + 1u64)
    let onp: u64 = iii_ast_get(oa, on)
    let nnp: u64 = iii_ast_get(na, nn)
    if onp == 0u64 { return 0u32 }
    if nnp == 0u64 { return 0u32 }
    if iii_lex_read_u32_c(onp, NODE_OFF_KIND) != iii_lex_read_u32_c(nnp, NODE_OFF_KIND) { return 0u32 }
    let oc: u64 = iii_lex_malloc_c(ZCOLLECT_BYTES)
    if oc == 0u64 { return 0u32 }
    let nc: u64 = iii_lex_malloc_c(ZCOLLECT_BYTES)
    if nc == 0u64 { iii_lex_free_c(oc) ; return 0u32 }
    iii_lex_write_u32_c(oc, 0u64, 0u32)
    iii_lex_write_u32_c(nc, 0u64, 0u32)
    iii_ast_iterate_children(oa, on, ast_zipper_collect_child as u64, oc)
    iii_ast_iterate_children(na, nn, ast_zipper_collect_child as u64, nc)
    let ocount: u32 = iii_lex_read_u32_c(oc, 0u64)
    let ncount: u32 = iii_lex_read_u32_c(nc, 0u64)
    let mut common: u32 = ocount
    if ncount < ocount { common = ncount }
    let mut i: u32 = 0u32
    while i != common {
        let och: u32 = iii_lex_read_u32_c(oc + 4u64, (i as u64) * 4u64)
        let nch: u32 = iii_lex_read_u32_c(nc + 4u64, (i as u64) * 4u64)
        ast_diff_recurse(oa, och, na, nch, d)
        i = i + 1u32
    }
    iii_lex_free_c(oc)
    iii_lex_free_c(nc)
    return 0u32
}

fn iii_ast_diff(old_ast: u64, old_root: u32, new_ast: u64, new_root: u32, out: u64, cap: u64) -> u64 @export {
    let oa: u64 = old_ast
    let orr: u32 = old_root
    let nia: u64 = new_ast
    let nrr: u32 = new_root
    let o: u64 = out
    let cp: u64 = cap
    let d: u64 = iii_lex_malloc_c(24u64)
    if d == 0u64 { return 0u64 }
    iii_lex_write_u64_c(d, 0u64, o)
    iii_lex_write_u64_c(d, 8u64, cp)
    iii_lex_write_u64_c(d, 16u64, 0u64)
    ast_diff_recurse(oa, orr, nia, nrr, d)
    let produced: u64 = iii_lex_read_u64_c(d, 16u64)
    iii_lex_free_c(d)
    return produced
}

/* ============================================================================
 * RITCHIE Stage 2.2.22 -- annotations (L1).  LOAD-BEARING (proof.iii + sid.iii
 * call iii_ast_annotate).  Mirrors ast.c iii_phase_hash/intern_phase/
 * annotation_grow/iii_ast_annotate/get_annotation/annotation_count
 * (2337-2482).  Phase strings are NUL-terminated C strings (NIH strlen/str_eq).
 * key = FNV-1a(phase) folded with node_index; phase interned (ptr-equality
 * match); open-addressed slots {key@0,node@8,boff@12,blen@16,phase@24,used@32}
 * =40B; separate blob arena.
 * ============================================================================ */

const ASLOT_BYTES: u64 = 40u64
const ASLOT_KEY: u64 = 0u64
const ASLOT_NODE: u64 = 8u64
const ASLOT_BOFF: u64 = 12u64
const ASLOT_BLEN: u64 = 16u64
const ASLOT_PHASE: u64 = 24u64
const ASLOT_USED: u64 = 32u64
const UK_BYTES: u64 = 16u64
const UK_ID: u64 = 0u64
const UK_NAME: u64 = 8u64

fn ast_strlen(s: u64) -> u64 {
    let mut i: u64 = 0u64
    let mut done: u32 = 0u32
    while done == 0u32 {
        if iii_lex_read_u8_at_c(s, i) == 0u32 { done = 1u32 }
        if done == 0u32 { i = i + 1u64 }
    }
    return i
}
fn ast_str_eq(a: u64, b: u64) -> u32 {
    let mut i: u64 = 0u64
    let mut res: u32 = 2u32
    while res == 2u32 {
        let ca: u32 = iii_lex_read_u8_at_c(a, i)
        let cb: u32 = iii_lex_read_u8_at_c(b, i)
        if ca != cb { res = 0u32 }
        if res == 2u32 {
            if ca == 0u32 { res = 1u32 }
            if res == 2u32 { i = i + 1u64 }
        }
    }
    return res
}
fn ast_phase_hash(phase: u64, node_index: u32) -> u64 {
    let mut h: u64 = 0xCBF29CE484222325
    if phase != 0u64 {
        let mut i: u64 = 0u64
        let mut done: u32 = 0u32
        while done == 0u32 {
            let b: u32 = iii_lex_read_u8_at_c(phase, i)
            if b == 0u32 { done = 1u32 }
            if done == 0u32 {
                h = h ^ (b as u64)
                h = h * 0x100000001B3
                i = i + 1u64
            }
        }
    }
    h = h ^ (node_index as u64)
    h = h * 0x100000001B3
    return h
}
fn ast_intern_phase(ast: u64, phase: u64) -> u64 {
    if phase == 0u64 { return 0u64 }
    let arena0: u64 = iii_lex_read_u64_c(ast, AST_OFF_PHASE_ARENA)
    let used0: u64 = iii_lex_read_u32_c(ast, AST_OFF_PHASE_ARENA_USED) as u64
    let mut off: u64 = 0u64
    let mut found: u64 = 0u64
    let mut scanning: u32 = 1u32
    while scanning == 1u32 {
        if off >= used0 { scanning = 0u32 }
        if scanning == 1u32 {
            let cand: u64 = arena0 + off
            if ast_str_eq(cand, phase) == 1u32 { found = cand ; scanning = 0u32 }
            if scanning == 1u32 { off = off + ast_strlen(cand) + 1u64 }
        }
    }
    if found != 0u64 { return found }
    let len: u64 = ast_strlen(phase) + 1u64
    let cap: u64 = iii_lex_read_u32_c(ast, AST_OFF_PHASE_ARENA_CAP) as u64
    if used0 + len > cap {
        let mut ncap: u64 = 256u64
        if cap != 0u64 { ncap = cap * 2u64 }
        let mut g: u32 = 0u32
        while g == 0u32 {
            if ncap >= used0 + len { g = 1u32 }
            if g == 0u32 { ncap = ncap * 2u64 }
        }
        let np: u64 = iii_lex_malloc_c(ncap)
        if np == 0u64 { return 0u64 }
        iii_lex_memset_c(np, 0u32, ncap)
        if arena0 != 0u64 {
            if used0 != 0u64 { iii_lex_memcpy_c(np, arena0, used0) }
            iii_lex_free_c(arena0)
        }
        iii_lex_write_u64_c(ast, AST_OFF_PHASE_ARENA, np)
        iii_lex_write_u32_c(ast, AST_OFF_PHASE_ARENA_CAP, ncap as u32)
    }
    let arena: u64 = iii_lex_read_u64_c(ast, AST_OFF_PHASE_ARENA)
    let dst: u64 = arena + used0
    iii_lex_memcpy_c(dst, phase, len)
    iii_lex_write_u32_c(ast, AST_OFF_PHASE_ARENA_USED, (used0 + len) as u32)
    return dst
}
fn ast_annotation_grow(ast: u64, need: u32) -> u32 {
    let cap: u32 = iii_lex_read_u32_c(ast, AST_OFF_ANNOTATION_CAP)
    if (need as u64) * 2u64 <= (cap as u64) { return 1u32 }
    let mut ncap: u32 = 64u32
    if cap != 0u32 { ncap = cap * 2u32 }
    let mut g: u32 = 0u32
    while g == 0u32 {
        if (ncap as u64) >= (need as u64) * 2u64 { g = 1u32 }
        if g == 0u32 { ncap = ncap * 2u32 }
    }
    let np: u64 = iii_lex_malloc_c((ncap as u64) * ASLOT_BYTES)
    if np == 0u64 { return 0u32 }
    iii_lex_memset_c(np, 0u32, (ncap as u64) * ASLOT_BYTES)
    let old: u64 = iii_lex_read_u64_c(ast, AST_OFF_ANNOTATIONS)
    let mask: u32 = ncap - 1u32
    let mut i: u32 = 0u32
    while i != cap {
        let os: u64 = old + (i as u64) * ASLOT_BYTES
        if iii_lex_read_u8_at_c(os, ASLOT_USED) != 0u32 {
            let kh: u64 = iii_lex_read_u64_c(os, ASLOT_KEY)
            let mut pos: u32 = (kh & (mask as u64)) as u32
            let mut placed: u32 = 0u32
            while placed == 0u32 {
                let ns: u64 = np + (pos as u64) * ASLOT_BYTES
                if iii_lex_read_u8_at_c(ns, ASLOT_USED) == 0u32 {
                    iii_lex_memcpy_c(ns, os, ASLOT_BYTES)
                    placed = 1u32
                }
                if placed == 0u32 { pos = (pos + 1u32) & mask }
            }
        }
        i = i + 1u32
    }
    if old != 0u64 { iii_lex_free_c(old) }
    iii_lex_write_u64_c(ast, AST_OFF_ANNOTATIONS, np)
    iii_lex_write_u32_c(ast, AST_OFF_ANNOTATION_CAP, ncap)
    return 1u32
}

fn iii_ast_annotate(ast: u64, phase: u64, node_index: u32, blob: u64, blob_len: u64) -> i32 @export {
    let a: u64 = ast
    let ph: u64 = phase
    let ni: u32 = node_index
    let bl: u64 = blob
    let blen: u64 = blob_len
    if a == 0u64 { return 0i32 }
    if ph == 0u64 { return 0i32 }
    let cnt: u32 = iii_lex_read_u32_c(a, AST_OFF_ANNOTATION_COUNT)
    if ast_annotation_grow(a, cnt + 1u32) == 0u32 { return 0i32 }
    let iphase: u64 = ast_intern_phase(a, ph)
    if iphase == 0u64 { return 0i32 }
    let key: u64 = ast_phase_hash(iphase, ni)
    let bused: u32 = iii_lex_read_u32_c(a, AST_OFF_ANNOTATION_BLOB_USED)
    let bcap: u32 = iii_lex_read_u32_c(a, AST_OFF_ANNOTATION_BLOB_CAP)
    if (bused as u64) + blen > (bcap as u64) {
        let mut ncb: u64 = 256u64
        if bcap != 0u32 { ncb = (bcap as u64) * 2u64 }
        let mut g2: u32 = 0u32
        while g2 == 0u32 {
            if ncb >= (bused as u64) + blen { g2 = 1u32 }
            if g2 == 0u32 { ncb = ncb * 2u64 }
        }
        let oldb: u64 = iii_lex_read_u64_c(a, AST_OFF_ANNOTATION_BLOBS)
        let npb: u64 = iii_lex_malloc_c(ncb)
        if npb == 0u64 { return 0i32 }
        if oldb != 0u64 {
            if bused != 0u32 { iii_lex_memcpy_c(npb, oldb, bused as u64) }
            iii_lex_free_c(oldb)
        }
        iii_lex_write_u64_c(a, AST_OFF_ANNOTATION_BLOBS, npb)
        iii_lex_write_u32_c(a, AST_OFF_ANNOTATION_BLOB_CAP, ncb as u32)
    }
    let blob_off: u32 = bused
    let blobs: u64 = iii_lex_read_u64_c(a, AST_OFF_ANNOTATION_BLOBS)
    if bl != 0u64 {
        if blen != 0u64 { iii_lex_memcpy_c(blobs + (blob_off as u64), bl, blen) }
    }
    iii_lex_write_u32_c(a, AST_OFF_ANNOTATION_BLOB_USED, bused + (blen as u32))
    let cap: u32 = iii_lex_read_u32_c(a, AST_OFF_ANNOTATION_CAP)
    let base: u64 = iii_lex_read_u64_c(a, AST_OFF_ANNOTATIONS)
    let mask: u32 = cap - 1u32
    let mut pos: u32 = (key & (mask as u64)) as u32
    let mut done: u32 = 0u32
    let mut result: i32 = 0i32
    while done == 0u32 {
        let slot: u64 = base + (pos as u64) * ASLOT_BYTES
        if iii_lex_read_u8_at_c(slot, ASLOT_USED) == 0u32 {
            iii_lex_write_u64_c(slot, ASLOT_KEY, key)
            iii_lex_write_u32_c(slot, ASLOT_NODE, ni)
            iii_lex_write_u64_c(slot, ASLOT_PHASE, iphase)
            iii_lex_write_u32_c(slot, ASLOT_BOFF, blob_off)
            iii_lex_write_u32_c(slot, ASLOT_BLEN, blen as u32)
            iii_lex_write_u8_at_c(slot, ASLOT_USED, 1u32)
            iii_lex_write_u32_c(a, AST_OFF_ANNOTATION_COUNT, cnt + 1u32)
            result = 1i32
            done = 1u32
        }
        if done == 0u32 {
            let mut matched: u32 = 0u32
            if iii_lex_read_u64_c(slot, ASLOT_KEY) == key {
                if iii_lex_read_u32_c(slot, ASLOT_NODE) == ni {
                    if iii_lex_read_u64_c(slot, ASLOT_PHASE) == iphase { matched = 1u32 }
                }
            }
            if matched == 1u32 {
                iii_lex_write_u32_c(slot, ASLOT_BOFF, blob_off)
                iii_lex_write_u32_c(slot, ASLOT_BLEN, blen as u32)
                result = 1i32
                done = 1u32
            }
            if done == 0u32 { pos = (pos + 1u32) & mask }
        }
    }
    return result
}

fn iii_ast_get_annotation(ast: u64, phase: u64, node_index: u32, out_blob: u64, out_blob_len: u64) -> i32 @export {
    let a: u64 = ast
    let ph: u64 = phase
    let ni: u32 = node_index
    let ob: u64 = out_blob
    let obl: u64 = out_blob_len
    if a == 0u64 { return 0i32 }
    if ph == 0u64 { return 0i32 }
    if ob == 0u64 { return 0i32 }
    if obl == 0u64 { return 0i32 }
    let cap: u32 = iii_lex_read_u32_c(a, AST_OFF_ANNOTATION_CAP)
    if cap == 0u32 { return 0i32 }
    let arena: u64 = iii_lex_read_u64_c(a, AST_OFF_PHASE_ARENA)
    let used: u64 = iii_lex_read_u32_c(a, AST_OFF_PHASE_ARENA_USED) as u64
    let mut off: u64 = 0u64
    let mut iphase: u64 = 0u64
    let mut scanning: u32 = 1u32
    while scanning == 1u32 {
        if off >= used { scanning = 0u32 }
        if scanning == 1u32 {
            let cand: u64 = arena + off
            if ast_str_eq(cand, ph) == 1u32 { iphase = cand ; scanning = 0u32 }
            if scanning == 1u32 { off = off + ast_strlen(cand) + 1u64 }
        }
    }
    if iphase == 0u64 { return 0i32 }
    let key: u64 = ast_phase_hash(iphase, ni)
    let base: u64 = iii_lex_read_u64_c(a, AST_OFF_ANNOTATIONS)
    let mask: u32 = cap - 1u32
    let mut pos: u32 = (key & (mask as u64)) as u32
    let mut done: u32 = 0u32
    let mut result: i32 = 0i32
    while done == 0u32 {
        let slot: u64 = base + (pos as u64) * ASLOT_BYTES
        if iii_lex_read_u8_at_c(slot, ASLOT_USED) == 0u32 { done = 1u32 }
        if done == 0u32 {
            let mut matched: u32 = 0u32
            if iii_lex_read_u64_c(slot, ASLOT_KEY) == key {
                if iii_lex_read_u32_c(slot, ASLOT_NODE) == ni {
                    if iii_lex_read_u64_c(slot, ASLOT_PHASE) == iphase { matched = 1u32 }
                }
            }
            if matched == 1u32 {
                let blobs: u64 = iii_lex_read_u64_c(a, AST_OFF_ANNOTATION_BLOBS)
                let boff: u32 = iii_lex_read_u32_c(slot, ASLOT_BOFF)
                iii_lex_write_u64_c(ob, 0u64, blobs + (boff as u64))
                iii_lex_write_u64_c(obl, 0u64, iii_lex_read_u32_c(slot, ASLOT_BLEN) as u64)
                result = 1i32
                done = 1u32
            }
            if done == 0u32 { pos = (pos + 1u32) & mask }
        }
    }
    return result
}

fn iii_ast_annotation_count(ast: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    return iii_lex_read_u32_c(ast, AST_OFF_ANNOTATION_COUNT) as u64
}

/* ============================================================================
 * RITCHIE Stage 2.2.23 -- user-kind registry (C1).  Mirrors ast.c
 * iii_ast_register_user_kind/user_kind_name/user_kind_count (2486-2516).  Names
 * are interned in the shared phase arena.  user_kinds[] entries = {id@0,name@8}
 * =16B.
 * ============================================================================ */

fn iii_ast_register_user_kind(ast: u64, name: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    if name == 0u64 { return 0u32 }
    let cnt: u32 = iii_lex_read_u32_c(ast, AST_OFF_USER_KIND_COUNT)
    let cap: u32 = iii_lex_read_u32_c(ast, AST_OFF_USER_KIND_CAP)
    if cnt == cap {
        let mut ncap: u32 = 16u32
        if cap != 0u32 { ncap = cap * 2u32 }
        let old: u64 = iii_lex_read_u64_c(ast, AST_OFF_USER_KINDS)
        let np: u64 = ast_grow_one(old, cap as u64, ncap as u64, UK_BYTES)
        if np == 0u64 { return 0u32 }
        iii_lex_write_u64_c(ast, AST_OFF_USER_KINDS, np)
        iii_lex_write_u32_c(ast, AST_OFF_USER_KIND_CAP, ncap)
    }
    let iname: u64 = ast_intern_phase(ast, name)
    if iname == 0u64 { return 0u32 }
    let id: u32 = cnt + 1u32
    let base: u64 = iii_lex_read_u64_c(ast, AST_OFF_USER_KINDS)
    let slot: u64 = base + (cnt as u64) * UK_BYTES
    iii_lex_write_u32_c(slot, UK_ID, id)
    iii_lex_write_u64_c(slot, UK_NAME, iname)
    iii_lex_write_u32_c(ast, AST_OFF_USER_KIND_COUNT, cnt + 1u32)
    return id
}
fn iii_ast_user_kind_name(ast: u64, user_kind_id: u32) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    if user_kind_id == 0u32 { return 0u64 }
    let cnt: u32 = iii_lex_read_u32_c(ast, AST_OFF_USER_KIND_COUNT)
    if user_kind_id > cnt { return 0u64 }
    let base: u64 = iii_lex_read_u64_c(ast, AST_OFF_USER_KINDS)
    let slot: u64 = base + ((user_kind_id - 1u32) as u64) * UK_BYTES
    return iii_lex_read_u64_c(slot, UK_NAME)
}
fn iii_ast_user_kind_count(ast: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    return iii_lex_read_u32_c(ast, AST_OFF_USER_KIND_COUNT) as u64
}

/* ============================================================================
 * RITCHIE Stage 2.2.24a -- serialize (Q1).  Mirrors ast.c iii_ast_serialize +
 * iii_ast_serialize_buf (2548-2651).  Format "IIIASTBN"+ver+reserved + 5
 * witness mhashes + root/binder/hole ids + 4 pool counts + per-pool
 * {nodes,mhash,pos_first,binder,doc} bulk arrays + positions + list arena +
 * string_payload_count + annotations(phase_arena+blobs+used slots) + user-kinds
 * + SHA-256 trailer.  FILE* carried as u64; raw stream via lex_runtime helpers.
 * ============================================================================ */

var AST_IO_SCRATCH : [u8; 8]

fn ast_emit_bytes(file: u64, h: u64, ptr: u64, n: u64) -> u32 {
    if n != 0u64 { iii_lex_fwrite_c(ptr, n, file) }
    iii_sha256_update(h, ptr, n)
    return 0u32
}
fn ast_emit_u32(file: u64, h: u64, v: u32) -> u32 {
    iii_lex_write_u32_c(&AST_IO_SCRATCH as u64, 0u64, v)
    iii_lex_fwrite_c(&AST_IO_SCRATCH as u64, 4u64, file)
    iii_sha256_update_u32(h, v)
    return 0u32
}
fn ast_emit_pool(out: u64, h: u64, ast: u64, pool: u32, count: u32) -> u32 {
    let c: u64 = count as u64
    ast_emit_bytes(out, h, iii_lex_read_u64_c(ast, ast_off_nodes(pool)), c * NODE_BYTES)
    ast_emit_bytes(out, h, iii_lex_read_u64_c(ast, ast_off_mhash(pool)), c * 32u64)
    ast_emit_bytes(out, h, iii_lex_read_u64_c(ast, ast_off_pos_first(pool)), c * 4u64)
    ast_emit_bytes(out, h, iii_lex_read_u64_c(ast, ast_off_binder(pool)), c * 4u64)
    ast_emit_bytes(out, h, iii_lex_read_u64_c(ast, ast_off_doc(pool)), c * 4u64)
    return 0u32
}

fn iii_ast_serialize(ast: u64, out: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    if out == 0u64 { return 0u64 }
    let h: u64 = iii_lex_malloc_c(III_AST_SHA256_STATE_BYTES)
    if h == 0u64 { return 0u64 }
    iii_sha256_init(h)
    ast_emit_bytes(out, h, "IIIASTBN" as u64, 8u64)
    ast_emit_u32(out, h, 1u32)
    ast_emit_u32(out, h, 0u32)
    ast_emit_bytes(out, h, ast + AST_OFF_PARSER_VERSION_MHASH, 32u64)
    ast_emit_bytes(out, h, ast + AST_OFF_TOKEN_STREAM_MHASH, 32u64)
    ast_emit_bytes(out, h, ast + AST_OFF_SOURCE_MHASH, 32u64)
    ast_emit_bytes(out, h, ast + AST_OFF_GRAMMAR_MHASH, 32u64)
    ast_emit_bytes(out, h, ast + AST_OFF_ROOT_MODULE_MHASH, 32u64)
    ast_emit_u32(out, h, iii_lex_read_u32_c(ast, AST_OFF_ROOT_MODULE))
    ast_emit_u32(out, h, iii_lex_read_u32_c(ast, AST_OFF_NEXT_BINDER_ID))
    ast_emit_u32(out, h, iii_lex_read_u32_c(ast, AST_OFF_NEXT_HOLE_ID))
    let sc: u32 = iii_lex_read_u32_c(ast, AST_OFF_SMALL_COUNT)
    let mc: u32 = iii_lex_read_u32_c(ast, AST_OFF_MEDIUM_COUNT)
    let lc: u32 = iii_lex_read_u32_c(ast, AST_OFF_LARGE_COUNT)
    let uc: u32 = iii_lex_read_u32_c(ast, AST_OFF_USER_COUNT)
    ast_emit_u32(out, h, sc)
    ast_emit_u32(out, h, mc)
    ast_emit_u32(out, h, lc)
    ast_emit_u32(out, h, uc)
    ast_emit_pool(out, h, ast, III_AST_POOL_SMALL, sc)
    ast_emit_pool(out, h, ast, III_AST_POOL_MEDIUM, mc)
    ast_emit_pool(out, h, ast, III_AST_POOL_LARGE, lc)
    ast_emit_pool(out, h, ast, III_AST_POOL_USER, uc)
    let pc: u32 = iii_lex_read_u32_c(ast, AST_OFF_POSITION_COUNT)
    ast_emit_u32(out, h, pc)
    ast_emit_bytes(out, h, iii_lex_read_u64_c(ast, AST_OFF_POSITIONS), (pc as u64) * POSITION_RECORD_BYTES)
    let lu: u32 = iii_lex_read_u32_c(ast, AST_OFF_LIST_USED)
    ast_emit_u32(out, h, lu)
    ast_emit_bytes(out, h, iii_lex_read_u64_c(ast, AST_OFF_LIST_ARENA), (lu as u64) * 4u64)
    ast_emit_u32(out, h, iii_lex_read_u32_c(ast, AST_OFF_STRING_PAYLOAD_COUNT))
    let acnt: u32 = iii_lex_read_u32_c(ast, AST_OFF_ANNOTATION_COUNT)
    let ablob: u32 = iii_lex_read_u32_c(ast, AST_OFF_ANNOTATION_BLOB_USED)
    let pau: u32 = iii_lex_read_u32_c(ast, AST_OFF_PHASE_ARENA_USED)
    ast_emit_u32(out, h, acnt)
    ast_emit_u32(out, h, ablob)
    ast_emit_u32(out, h, pau)
    ast_emit_bytes(out, h, iii_lex_read_u64_c(ast, AST_OFF_PHASE_ARENA), pau as u64)
    ast_emit_bytes(out, h, iii_lex_read_u64_c(ast, AST_OFF_ANNOTATION_BLOBS), ablob as u64)
    let acap: u32 = iii_lex_read_u32_c(ast, AST_OFF_ANNOTATION_CAP)
    let abase: u64 = iii_lex_read_u64_c(ast, AST_OFF_ANNOTATIONS)
    let parena: u64 = iii_lex_read_u64_c(ast, AST_OFF_PHASE_ARENA)
    let mut i: u32 = 0u32
    while i != acap {
        let slot: u64 = abase + (i as u64) * ASLOT_BYTES
        if iii_lex_read_u8_at_c(slot, ASLOT_USED) != 0u32 {
            ast_emit_u32(out, h, (iii_lex_read_u64_c(slot, ASLOT_PHASE) - parena) as u32)
            ast_emit_u32(out, h, iii_lex_read_u32_c(slot, ASLOT_NODE))
            ast_emit_u32(out, h, iii_lex_read_u32_c(slot, ASLOT_BOFF))
            ast_emit_u32(out, h, iii_lex_read_u32_c(slot, ASLOT_BLEN))
        }
        i = i + 1u32
    }
    let ukc: u32 = iii_lex_read_u32_c(ast, AST_OFF_USER_KIND_COUNT)
    ast_emit_u32(out, h, ukc)
    let ukbase: u64 = iii_lex_read_u64_c(ast, AST_OFF_USER_KINDS)
    let mut j: u32 = 0u32
    while j != ukc {
        let uk: u64 = ukbase + (j as u64) * UK_BYTES
        ast_emit_u32(out, h, iii_lex_read_u32_c(uk, UK_ID))
        ast_emit_u32(out, h, (iii_lex_read_u64_c(uk, UK_NAME) - parena) as u32)
        j = j + 1u32
    }
    let mhb: u64 = iii_lex_malloc_c(32u64)
    if mhb == 0u64 { iii_lex_free_c(h) ; return 0u64 }
    iii_sha256_final(h, mhb)
    iii_lex_fwrite_c(mhb, 32u64, out)
    iii_lex_free_c(mhb)
    iii_lex_free_c(h)
    return 0u64
}

fn iii_ast_serialize_buf(ast: u64, out: u64, cap: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    let t: u64 = iii_lex_tmpfile_c()
    if t == 0u64 { return 0u64 }
    iii_ast_serialize(ast, t)
    let sz: i64 = iii_lex_ftell_c(t)
    if ((sz as u64) & 0x8000000000000000) != 0u64 { iii_lex_fclose_c(t) ; return 0u64 }
    let szu: u64 = sz as u64
    if out == 0u64 { iii_lex_fclose_c(t) ; return szu }
    if cap < szu { iii_lex_fclose_c(t) ; return szu }
    iii_lex_rewind_c(t)
    let got: u64 = iii_lex_fread_c(out, szu, t)
    iii_lex_fclose_c(t)
    return got
}

/* ============================================================================
 * RITCHIE Stage 2.2.24b -- deserialize (Q1).  Mirrors ast.c iii_ast_deserialize
 * + iii_ast_deserialize_buf (2656-2804).  Symmetric to serialize: validate
 * magic+version, create, read witnesses + counts, grow + bulk-read each pool +
 * side-tables, positions, list arena, string count, annotations (phase arena +
 * blobs + slots replayed via iii_ast_annotate), user-kinds.  SHA trailer not
 * verified (per ast.c).  fread-ok gated by a fail flag (mirrors goto fail).
 * ============================================================================ */

fn ast_fread_ok(file: u64, ptr: u64, n: u64) -> u32 {
    if iii_lex_fread_c(ptr, n, file) == n { return 1u32 }
    return 0u32
}
/* read a u32: returns (value | (ok<<32)); 0 if the 4-byte read fell short. */
fn ast_fread_u32v(file: u64) -> u64 {
    if iii_lex_fread_c(&AST_IO_SCRATCH as u64, 4u64, file) != 4u64 { return 0u64 }
    return (iii_lex_read_u32_c(&AST_IO_SCRATCH as u64, 0u64) as u64) | 0x100000000u64
}
fn ast_read_pool(file: u64, ast: u64, pool: u32, count: u32) -> u32 {
    let c: u64 = count as u64
    let mut ok: u32 = ast_fread_ok(file, iii_lex_read_u64_c(ast, ast_off_nodes(pool)), c * NODE_BYTES)
    if ok == 1u32 { ok = ast_fread_ok(file, iii_lex_read_u64_c(ast, ast_off_mhash(pool)), c * 32u64) }
    if ok == 1u32 { ok = ast_fread_ok(file, iii_lex_read_u64_c(ast, ast_off_pos_first(pool)), c * 4u64) }
    if ok == 1u32 { ok = ast_fread_ok(file, iii_lex_read_u64_c(ast, ast_off_binder(pool)), c * 4u64) }
    if ok == 1u32 { ok = ast_fread_ok(file, iii_lex_read_u64_c(ast, ast_off_doc(pool)), c * 4u64) }
    return ok
}

fn iii_ast_deserialize(in_file: u64) -> u64 @export {
    if in_file == 0u64 { return 0u64 }
    if ast_fread_ok(in_file, &AST_IO_SCRATCH as u64, 8u64) == 0u32 { return 0u64 }
    if iii_lex_memcmp_c(&AST_IO_SCRATCH as u64, "IIIASTBN" as u64, 8u64) != 0i32 { return 0u64 }
    let rv: u64 = ast_fread_u32v(in_file)
    if (rv >> 32u64) == 0u64 { return 0u64 }
    if ast_fread_u32v(in_file) == 0u64 { return 0u64 }
    if (rv & 0xFFFFFFFFu64) != 1u64 { return 0u64 }
    let ast: u64 = iii_ast_create(0u64, 0u64, 0u64)
    if ast == 0u64 { return 0u64 }
    let mut fail: u32 = 0u32
    if fail == 0u32 { if ast_fread_ok(in_file, ast + AST_OFF_PARSER_VERSION_MHASH, 32u64) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_fread_ok(in_file, ast + AST_OFF_TOKEN_STREAM_MHASH, 32u64) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_fread_ok(in_file, ast + AST_OFF_SOURCE_MHASH, 32u64) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_fread_ok(in_file, ast + AST_OFF_GRAMMAR_MHASH, 32u64) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_fread_ok(in_file, ast + AST_OFF_ROOT_MODULE_MHASH, 32u64) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_fread_ok(in_file, ast + AST_OFF_ROOT_MODULE, 4u64) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_fread_ok(in_file, ast + AST_OFF_NEXT_BINDER_ID, 4u64) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_fread_ok(in_file, ast + AST_OFF_NEXT_HOLE_ID, 4u64) == 0u32 { fail = 1u32 } }
    let mut sc: u32 = 0u32
    let mut mc: u32 = 0u32
    let mut lc: u32 = 0u32
    let mut uc: u32 = 0u32
    if fail == 0u32 { let r: u64 = ast_fread_u32v(in_file) ; if (r >> 32u64) == 0u64 { fail = 1u32 } ; sc = (r & 0xFFFFFFFFu64) as u32 }
    if fail == 0u32 { let r: u64 = ast_fread_u32v(in_file) ; if (r >> 32u64) == 0u64 { fail = 1u32 } ; mc = (r & 0xFFFFFFFFu64) as u32 }
    if fail == 0u32 { let r: u64 = ast_fread_u32v(in_file) ; if (r >> 32u64) == 0u64 { fail = 1u32 } ; lc = (r & 0xFFFFFFFFu64) as u32 }
    if fail == 0u32 { let r: u64 = ast_fread_u32v(in_file) ; if (r >> 32u64) == 0u64 { fail = 1u32 } ; uc = (r & 0xFFFFFFFFu64) as u32 }
    if fail == 0u32 { if ast_pool_grow(ast, III_AST_POOL_SMALL, sc) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_pool_grow(ast, III_AST_POOL_MEDIUM, mc) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_pool_grow(ast, III_AST_POOL_LARGE, lc) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_pool_grow(ast, III_AST_POOL_USER, uc) == 0u32 { fail = 1u32 } }
    if fail == 0u32 {
        iii_lex_write_u32_c(ast, AST_OFF_SMALL_COUNT, sc)
        iii_lex_write_u32_c(ast, AST_OFF_MEDIUM_COUNT, mc)
        iii_lex_write_u32_c(ast, AST_OFF_LARGE_COUNT, lc)
        iii_lex_write_u32_c(ast, AST_OFF_USER_COUNT, uc)
    }
    if fail == 0u32 { if ast_read_pool(in_file, ast, III_AST_POOL_SMALL, sc) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_read_pool(in_file, ast, III_AST_POOL_MEDIUM, mc) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_read_pool(in_file, ast, III_AST_POOL_LARGE, lc) == 0u32 { fail = 1u32 } }
    if fail == 0u32 { if ast_read_pool(in_file, ast, III_AST_POOL_USER, uc) == 0u32 { fail = 1u32 } }
    /* positions */
    let mut pc: u32 = 0u32
    if fail == 0u32 { let r: u64 = ast_fread_u32v(in_file) ; if (r >> 32u64) == 0u64 { fail = 1u32 } ; pc = (r & 0xFFFFFFFFu64) as u32 }
    if fail == 0u32 {
        if pc != 0u32 {
            if iii_position_arena_grow(ast, pc) == 0u32 { fail = 1u32 }
            if fail == 0u32 { if ast_fread_ok(in_file, iii_lex_read_u64_c(ast, AST_OFF_POSITIONS), (pc as u64) * POSITION_RECORD_BYTES) == 0u32 { fail = 1u32 } }
            if fail == 0u32 { iii_lex_write_u32_c(ast, AST_OFF_POSITION_COUNT, pc) }
        }
    }
    /* list arena */
    let mut lu: u32 = 0u32
    if fail == 0u32 { let r: u64 = ast_fread_u32v(in_file) ; if (r >> 32u64) == 0u64 { fail = 1u32 } ; lu = (r & 0xFFFFFFFFu64) as u32 }
    if fail == 0u32 {
        let lcap: u32 = iii_lex_read_u32_c(ast, AST_OFF_LIST_CAP)
        if lu > lcap {
            let ncap: u32 = ast_grow_cap(lcap, lu)
            if ncap == 0u32 { fail = 1u32 }
            if fail == 0u32 {
                let np: u64 = ast_grow_one(iii_lex_read_u64_c(ast, AST_OFF_LIST_ARENA), lcap as u64, ncap as u64, 4u64)
                if np == 0u64 { fail = 1u32 }
                if fail == 0u32 { iii_lex_write_u64_c(ast, AST_OFF_LIST_ARENA, np) ; iii_lex_write_u32_c(ast, AST_OFF_LIST_CAP, ncap) }
            }
        }
    }
    if fail == 0u32 {
        if lu != 0u32 { if ast_fread_ok(in_file, iii_lex_read_u64_c(ast, AST_OFF_LIST_ARENA), (lu as u64) * 4u64) == 0u32 { fail = 1u32 } }
    }
    if fail == 0u32 { iii_lex_write_u32_c(ast, AST_OFF_LIST_USED, lu) }
    /* string payload count */
    if fail == 0u32 { let r: u64 = ast_fread_u32v(in_file) ; if (r >> 32u64) == 0u64 { fail = 1u32 } ; iii_lex_write_u32_c(ast, AST_OFF_STRING_PAYLOAD_COUNT, (r & 0xFFFFFFFFu64) as u32) }
    /* annotations */
    let mut ac: u32 = 0u32
    let mut ablob: u32 = 0u32
    let mut pau: u32 = 0u32
    if fail == 0u32 { let r: u64 = ast_fread_u32v(in_file) ; if (r >> 32u64) == 0u64 { fail = 1u32 } ; ac = (r & 0xFFFFFFFFu64) as u32 }
    if fail == 0u32 { let r: u64 = ast_fread_u32v(in_file) ; if (r >> 32u64) == 0u64 { fail = 1u32 } ; ablob = (r & 0xFFFFFFFFu64) as u32 }
    if fail == 0u32 { let r: u64 = ast_fread_u32v(in_file) ; if (r >> 32u64) == 0u64 { fail = 1u32 } ; pau = (r & 0xFFFFFFFFu64) as u32 }
    if fail == 0u32 {
        if pau != 0u32 {
            let pcap: u32 = iii_lex_read_u32_c(ast, AST_OFF_PHASE_ARENA_CAP)
            if pau > pcap {
                let np: u64 = ast_grow_one(iii_lex_read_u64_c(ast, AST_OFF_PHASE_ARENA), pcap as u64, pau as u64, 1u64)
                if np == 0u64 { fail = 1u32 }
                if fail == 0u32 { iii_lex_write_u64_c(ast, AST_OFF_PHASE_ARENA, np) ; iii_lex_write_u32_c(ast, AST_OFF_PHASE_ARENA_CAP, pau) }
            }
            if fail == 0u32 { if ast_fread_ok(in_file, iii_lex_read_u64_c(ast, AST_OFF_PHASE_ARENA), pau as u64) == 0u32 { fail = 1u32 } }
            if fail == 0u32 { iii_lex_write_u32_c(ast, AST_OFF_PHASE_ARENA_USED, pau) }
        }
    }
    if fail == 0u32 {
        if ablob != 0u32 {
            let bcap: u32 = iii_lex_read_u32_c(ast, AST_OFF_ANNOTATION_BLOB_CAP)
            let np: u64 = ast_grow_one(iii_lex_read_u64_c(ast, AST_OFF_ANNOTATION_BLOBS), bcap as u64, ablob as u64, 1u64)
            if np == 0u64 { fail = 1u32 }
            if fail == 0u32 {
                iii_lex_write_u64_c(ast, AST_OFF_ANNOTATION_BLOBS, np)
                iii_lex_write_u32_c(ast, AST_OFF_ANNOTATION_BLOB_CAP, ablob)
                if ast_fread_ok(in_file, np, ablob as u64) == 0u32 { fail = 1u32 }
                if fail == 0u32 { iii_lex_write_u32_c(ast, AST_OFF_ANNOTATION_BLOB_USED, ablob) }
            }
        }
    }
    if fail == 0u32 {
        let mut i: u32 = 0u32
        while i != ac {
            if fail == 0u32 {
                let r1: u64 = ast_fread_u32v(in_file)
                let r2: u64 = ast_fread_u32v(in_file)
                let r3: u64 = ast_fread_u32v(in_file)
                let r4: u64 = ast_fread_u32v(in_file)
                if (r1 >> 32u64) == 0u64 { fail = 1u32 }
                if (r2 >> 32u64) == 0u64 { fail = 1u32 }
                if (r3 >> 32u64) == 0u64 { fail = 1u32 }
                if (r4 >> 32u64) == 0u64 { fail = 1u32 }
                if fail == 0u32 {
                    let phase_off: u32 = (r1 & 0xFFFFFFFFu64) as u32
                    let pa_used: u32 = iii_lex_read_u32_c(ast, AST_OFF_PHASE_ARENA_USED)
                    if phase_off >= pa_used { fail = 1u32 }
                    if fail == 0u32 {
                        let phase: u64 = iii_lex_read_u64_c(ast, AST_OFF_PHASE_ARENA) + (phase_off as u64)
                        let blobs: u64 = iii_lex_read_u64_c(ast, AST_OFF_ANNOTATION_BLOBS)
                        let blen: u64 = r4 & 0xFFFFFFFFu64
                        /* Copy the blob to a stable temp first: iii_ast_annotate
                         * grows (malloc+memcpy+free) the blob arena, which would
                         * dangle a `blobs+off` pointer mid-call (ast.c gets away
                         * with this via realloc; we must not). */
                        let tmp: u64 = iii_lex_malloc_c(blen + 1u64)
                        if tmp == 0u64 { fail = 1u32 }
                        if fail == 0u32 {
                            if blen != 0u64 { iii_lex_memcpy_c(tmp, blobs + (r3 & 0xFFFFFFFFu64), blen) }
                            iii_ast_annotate(ast, phase, (r2 & 0xFFFFFFFFu64) as u32, tmp, blen)
                            iii_lex_free_c(tmp)
                        }
                    }
                }
            }
            i = i + 1u32
        }
    }
    /* user kinds */
    let mut ukc: u32 = 0u32
    if fail == 0u32 { let r: u64 = ast_fread_u32v(in_file) ; if (r >> 32u64) == 0u64 { fail = 1u32 } ; ukc = (r & 0xFFFFFFFFu64) as u32 }
    if fail == 0u32 {
        let mut i: u32 = 0u32
        while i != ukc {
            if fail == 0u32 {
                let r1: u64 = ast_fread_u32v(in_file)
                let r2: u64 = ast_fread_u32v(in_file)
                if (r1 >> 32u64) == 0u64 { fail = 1u32 }
                if (r2 >> 32u64) == 0u64 { fail = 1u32 }
                if fail == 0u32 {
                    let name_off: u32 = (r2 & 0xFFFFFFFFu64) as u32
                    let pa_used: u32 = iii_lex_read_u32_c(ast, AST_OFF_PHASE_ARENA_USED)
                    if name_off >= pa_used { fail = 1u32 }
                    if fail == 0u32 {
                        let cnt: u32 = iii_lex_read_u32_c(ast, AST_OFF_USER_KIND_COUNT)
                        let cap: u32 = iii_lex_read_u32_c(ast, AST_OFF_USER_KIND_CAP)
                        if cnt == cap {
                            let mut nc: u32 = 16u32
                            if cap != 0u32 { nc = cap * 2u32 }
                            let np: u64 = ast_grow_one(iii_lex_read_u64_c(ast, AST_OFF_USER_KINDS), cap as u64, nc as u64, UK_BYTES)
                            if np == 0u64 { fail = 1u32 }
                            if fail == 0u32 { iii_lex_write_u64_c(ast, AST_OFF_USER_KINDS, np) ; iii_lex_write_u32_c(ast, AST_OFF_USER_KIND_CAP, nc) }
                        }
                        if fail == 0u32 {
                            let base: u64 = iii_lex_read_u64_c(ast, AST_OFF_USER_KINDS)
                            let slot: u64 = base + (cnt as u64) * UK_BYTES
                            iii_lex_write_u32_c(slot, UK_ID, (r1 & 0xFFFFFFFFu64) as u32)
                            iii_lex_write_u64_c(slot, UK_NAME, iii_lex_read_u64_c(ast, AST_OFF_PHASE_ARENA) + (name_off as u64))
                            iii_lex_write_u32_c(ast, AST_OFF_USER_KIND_COUNT, cnt + 1u32)
                        }
                    }
                }
            }
            i = i + 1u32
        }
    }
    if fail == 1u32 { iii_ast_destroy(ast) ; return 0u64 }
    return ast
}

fn iii_ast_deserialize_buf(bytes: u64, len: u64) -> u64 @export {
    if bytes == 0u64 { return 0u64 }
    if len == 0u64 { return 0u64 }
    let t: u64 = iii_lex_tmpfile_c()
    if t == 0u64 { return 0u64 }
    if iii_lex_fwrite_c(bytes, len, t) != len { iii_lex_fclose_c(t) ; return 0u64 }
    iii_lex_rewind_c(t)
    let ast: u64 = iii_ast_deserialize(t)
    iii_lex_fclose_c(t)
    return ast
}

/* ============================================================================
 * RITCHIE Stage 2.2.24c -- debug_dump.  Mirrors ast.c iii_dump_pre +
 * iii_ast_debug_dump (2806-2849).  walk_pre over root; per node print
 * "[<hex8>] <kind>" + optional position + " mhash=<hex16>" + newline.  fprintf
 * is replaced by manual hex8/hex2/dec emit; fixed punctuation written via
 * fwrite-with-length (iiis-0 string literals are not NUL-terminated, so fputs
 * of a literal would overrun -- only kind_name (from the NUL-pool) uses fputs).
 * ============================================================================ */

var DUMP_SCRATCH : [u8; 16]

fn ast_dump_hex8(out: u64, v: u32) -> u32 {
    let mut i: u32 = 0u32
    while i != 8u32 {
        let nib: u32 = (v >> ((7u32 - i) * 4u32)) & 15u32
        let mut ch: u32 = 48u32 + nib
        if nib >= 10u32 { ch = 87u32 + nib }
        iii_lex_fputc_c(ch, out)
        i = i + 1u32
    }
    return 0u32
}
fn ast_dump_hex2(out: u64, v: u32) -> u32 {
    let hi: u32 = (v >> 4u32) & 15u32
    let lo: u32 = v & 15u32
    let mut c1: u32 = 48u32 + hi
    if hi >= 10u32 { c1 = 87u32 + hi }
    let mut c2: u32 = 48u32 + lo
    if lo >= 10u32 { c2 = 87u32 + lo }
    iii_lex_fputc_c(c1, out)
    iii_lex_fputc_c(c2, out)
    return 0u32
}
fn ast_dump_dec(out: u64, v: u32) -> u32 {
    if v == 0u32 { iii_lex_fputc_c(48u32, out) ; return 0u32 }
    let mut n: u32 = v
    let mut len: u32 = 0u32
    while n != 0u32 {
        iii_lex_write_u8_at_c(&DUMP_SCRATCH as u64, len as u64, 48u32 + (n % 10u32))
        n = n / 10u32
        len = len + 1u32
    }
    let mut i: u32 = len
    while i != 0u32 {
        i = i - 1u32
        iii_lex_fputc_c(iii_lex_read_u8_at_c(&DUMP_SCRATCH as u64, i as u64), out)
    }
    return 0u32
}

fn ast_dump_pre(ast: u64, node_index: u32, depth: u32, ctx: u64) -> i32 {
    let out: u64 = ctx
    let np: u64 = iii_ast_get(ast, node_index)
    if np == 0u64 { return 0i32 }
    let mut i: u32 = 0u32
    while i != depth {
        iii_lex_fwrite_c("  " as u64, 2u64, out)
        i = i + 1u32
    }
    iii_lex_fwrite_c("[" as u64, 1u64, out)
    ast_dump_hex8(out, node_index)
    iii_lex_fwrite_c("] " as u64, 2u64, out)
    iii_lex_fputs_c(iii_ast_kind_name(iii_lex_read_u32_c(np, NODE_OFF_KIND)), out)
    let posbuf: u64 = iii_lex_malloc_c(POSITION_T_BYTES)
    if posbuf != 0u64 {
        if ast_position_at_inner(ast, node_index, 0u64, posbuf) == 1i32 {
            let pk: u32 = iii_lex_read_u32_c(posbuf, POS_OFF_KIND)
            if pk == III_POS_PHYSICAL {
                iii_lex_fwrite_c(" @ " as u64, 3u64, out)
                ast_dump_dec(out, iii_lex_read_u32_c(posbuf, POS_PHYS_LINE))
                iii_lex_fwrite_c(":" as u64, 1u64, out)
                ast_dump_dec(out, iii_lex_read_u32_c(posbuf, POS_PHYS_COL))
                iii_lex_fwrite_c(".." as u64, 2u64, out)
                let eb: u32 = iii_lex_read_u32_c(posbuf, POS_PHYS_END)
                let sb: u32 = iii_lex_read_u32_c(posbuf, POS_PHYS_START)
                let cl: u32 = iii_lex_read_u32_c(posbuf, POS_PHYS_COL)
                ast_dump_dec(out, eb - sb + cl)
            }
            if pk == III_POS_SYNTHETIC {
                iii_lex_fwrite_c(" @ synthetic from " as u64, 18u64, out)
                ast_dump_hex8(out, iii_lex_read_u32_c(posbuf, POS_SYN_SRC))
            }
        }
        iii_lex_free_c(posbuf)
    }
    let mh: u64 = iii_ast_node_mhash(ast, node_index)
    if mh != 0u64 {
        iii_lex_fwrite_c(" mhash=" as u64, 7u64, out)
        let mut j: u32 = 0u32
        while j != 8u32 {
            ast_dump_hex2(out, iii_lex_read_u8_at_c(mh, j as u64))
            j = j + 1u32
        }
    }
    iii_lex_fputc_c(10u32, out)
    return 0i32
}

fn iii_ast_debug_dump(ast: u64, root: u32, out: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    if out == 0u64 { return 0u32 }
    iii_ast_walk_pre(ast, root, ast_dump_pre as u64, out)
    return 0u32
}

