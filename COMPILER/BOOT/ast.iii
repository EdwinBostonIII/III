    }
    if kind == III_AST_EXPR_INDEX {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 35u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 12u64), 36u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_EXPR_BINARY {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 12u64), 37u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 16u64), 10u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_EXPR_UNARY {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 12u64), 38u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_EXPR_BLOCK {
        ast_iter_list(ic, np + 8u64, 29u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_EXPR_MATCH {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 26u32)
        ast_iter_list(ic, np + 12u64, 27u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_EXPR_PAREN {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 20u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_ARG {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 16u64), 12u32)
