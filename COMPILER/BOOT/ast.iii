/* ============================================================================
 * RITCHIE Stage 2.2.2 -- lifecycle.  Mirrors ast.c iii_grow_cap (155-163),
 * the per-pool array accessors + iii_pool_grow (275-399), iii_pool_node
 * (401-421), iii_ast_create (425-491), iii_ast_destroy (493-525).  Per-pool
 * field offsets via small if-cascade helpers (pool is 1..4).  Growth is
 * malloc+memcpy+free (no realloc extern), lockstep across the 5 parallel
 * arrays {nodes(48B), mhash(32B), pos_first(i32, init -1), binder(u32,0),
 * doc(u32,0)}; unsigned compares done in u64 to avoid any u32-ordering doubt.
 * ============================================================================ */

/* iii_grow_cap: 16, then double until >= need; 0 on u32 overflow. */
fn ast_grow_cap(cap: u32, need: u32) -> u32 {
    let mut nc: u32 = 16u32
    if cap != 0u32 { nc = cap }
    let mut done: u32 = 0u32
    while done == 0u32 {
        if (nc as u64) >= (need as u64) { done = 1u32 }
        if done == 0u32 {
            if (nc as u64) > 2147483647u64 { return 0u32 }
            nc = nc * 2u32
        }
    }
    return nc
}

/* Per-pool container-field offsets (pool in 1..4). */
fn ast_off_nodes(pool: u32) -> u64 {
    if pool == III_AST_POOL_SMALL { return AST_OFF_SMALL_NODES }
    if pool == III_AST_POOL_MEDIUM { return AST_OFF_MEDIUM_NODES }
    if pool == III_AST_POOL_LARGE { return AST_OFF_LARGE_NODES }
    return AST_OFF_USER_NODES
}
fn ast_off_count(pool: u32) -> u64 {
    if pool == III_AST_POOL_SMALL { return AST_OFF_SMALL_COUNT }
    if pool == III_AST_POOL_MEDIUM { return AST_OFF_MEDIUM_COUNT }
    if pool == III_AST_POOL_LARGE { return AST_OFF_LARGE_COUNT }
    return AST_OFF_USER_COUNT
}
fn ast_off_cap(pool: u32) -> u64 {
    if pool == III_AST_POOL_SMALL { return AST_OFF_SMALL_CAP }
    if pool == III_AST_POOL_MEDIUM { return AST_OFF_MEDIUM_CAP }
    if pool == III_AST_POOL_LARGE { return AST_OFF_LARGE_CAP }
    return AST_OFF_USER_CAP
}
fn ast_off_mhash(pool: u32) -> u64 {
    if pool == III_AST_POOL_SMALL { return AST_OFF_SMALL_MHASH }
    if pool == III_AST_POOL_MEDIUM { return AST_OFF_MEDIUM_MHASH }
    if pool == III_AST_POOL_LARGE { return AST_OFF_LARGE_MHASH }
    return AST_OFF_USER_MHASH
}
fn ast_off_pos_first(pool: u32) -> u64 {
    if pool == III_AST_POOL_SMALL { return AST_OFF_SMALL_POS_FIRST }
    if pool == III_AST_POOL_MEDIUM { return AST_OFF_MEDIUM_POS_FIRST }
    if pool == III_AST_POOL_LARGE { return AST_OFF_LARGE_POS_FIRST }
    return AST_OFF_USER_POS_FIRST
}
fn ast_off_binder(pool: u32) -> u64 {
    if pool == III_AST_POOL_SMALL { return AST_OFF_SMALL_BINDER }
    if pool == III_AST_POOL_MEDIUM { return AST_OFF_MEDIUM_BINDER }
    if pool == III_AST_POOL_LARGE { return AST_OFF_LARGE_BINDER }
    return AST_OFF_USER_BINDER
}
fn ast_off_doc(pool: u32) -> u64 {
    if pool == III_AST_POOL_SMALL { return AST_OFF_SMALL_DOC }
    if pool == III_AST_POOL_MEDIUM { return AST_OFF_MEDIUM_DOC }
    if pool == III_AST_POOL_LARGE { return AST_OFF_LARGE_DOC }
    return AST_OFF_USER_DOC
}

/* Grow one parallel array: malloc newcap*elem, copy oldcap*elem, free old,
 * zero the new tail.  Returns new base, or 0 on OOM. */
fn ast_grow_one(old: u64, oldcap: u64, newcap: u64, elem: u64) -> u64 {
    let np: u64 = iii_lex_malloc_c(newcap * elem)
    if np == 0u64 { return 0u64 }
    if old != 0u64 {
        iii_lex_memcpy_c(np, old, oldcap * elem)
        iii_lex_free_c(old)
    }
    iii_lex_memset_c(np + oldcap * elem, 0u32, (newcap - oldcap) * elem)
    return np
}

/* Grow a pool's 5 parallel arrays in lockstep to >= need_slots. */
fn ast_pool_grow(ast: u64, pool: u32, need_slots: u32) -> u32 {
    let cap_off: u64 = ast_off_cap(pool)
    let cur_cap: u32 = iii_lex_read_u32_c(ast, cap_off)
    if (need_slots as u64) <= (cur_cap as u64) { return 1u32 }
    let new_cap: u32 = ast_grow_cap(cur_cap, need_slots)
    if new_cap == 0u32 { return 0u32 }
    let oc: u64 = cur_cap as u64
    let ncp: u64 = new_cap as u64

    let nodes_off: u64 = ast_off_nodes(pool)
    let nn: u64 = ast_grow_one(iii_lex_read_u64_c(ast, nodes_off), oc, ncp, NODE_BYTES)
    if nn == 0u64 { return 0u32 }
    iii_lex_write_u64_c(ast, nodes_off, nn)

    let mh_off: u64 = ast_off_mhash(pool)
    let nm: u64 = ast_grow_one(iii_lex_read_u64_c(ast, mh_off), oc, ncp, 32u64)
    if nm == 0u64 { return 0u32 }
    iii_lex_write_u64_c(ast, mh_off, nm)

    /* pos_first: i32 array; new tail must be -1 (0xFFFFFFFF), not 0. */
    let pf_off: u64 = ast_off_pos_first(pool)
    let oldpf: u64 = iii_lex_read_u64_c(ast, pf_off)
    let npf: u64 = iii_lex_malloc_c(ncp * 4u64)
    if npf == 0u64 { return 0u32 }
    if oldpf != 0u64 {
        iii_lex_memcpy_c(npf, oldpf, oc * 4u64)
        iii_lex_free_c(oldpf)
    }
    iii_lex_memset_c(npf + oc * 4u64, 255u32, (ncp - oc) * 4u64)
    iii_lex_write_u64_c(ast, pf_off, npf)

    let bd_off: u64 = ast_off_binder(pool)
    let nb: u64 = ast_grow_one(iii_lex_read_u64_c(ast, bd_off), oc, ncp, 4u64)
    if nb == 0u64 { return 0u32 }
    iii_lex_write_u64_c(ast, bd_off, nb)

    let dc_off: u64 = ast_off_doc(pool)
    let nd: u64 = ast_grow_one(iii_lex_read_u64_c(ast, dc_off), oc, ncp, 4u64)
    if nd == 0u64 { return 0u32 }
    iii_lex_write_u64_c(ast, dc_off, nd)

    iii_lex_write_u32_c(ast, cap_off, new_cap)
    return 1u32
}

/* Address of node `slot` in `pool` (or 0 if slot >= count). */
fn ast_pool_node(ast: u64, pool: u32, slot: u64) -> u64 {
    let cnt: u32 = iii_lex_read_u32_c(ast, ast_off_count(pool))
    if slot >= (cnt as u64) { return 0u64 }
    let base: u64 = iii_lex_read_u64_c(ast, ast_off_nodes(pool))
    return base + slot * NODE_BYTES
}

/* Public: create an AST container.  Reserves slot 0 of each pool as the
 * III_AST_NULL sentinel; inits the list / string-payload / hashcons arenas. */
fn iii_ast_create(source_buf: u64, source_len: u64, source_path: u64) -> u64 @export {
    let ast: u64 = iii_lex_malloc_c(AST_BYTES)
    if ast == 0u64 { return 0u64 }
    iii_lex_memset_c(ast, 0u32, AST_BYTES)
    iii_lex_write_u64_c(ast, AST_OFF_SOURCE_BUF, source_buf)
    iii_lex_write_u64_c(ast, AST_OFF_SOURCE_LEN, source_len)
    iii_lex_write_u64_c(ast, AST_OFF_SOURCE_PATH, source_path)

    /* Reserve slot 0 (NULL sentinel) in all four pools. */
    if ast_pool_grow(ast, III_AST_POOL_SMALL, 1u32) == 0u32 { iii_lex_free_c(ast) ; return 0u64 }
    if ast_pool_grow(ast, III_AST_POOL_MEDIUM, 1u32) == 0u32 { iii_lex_free_c(ast) ; return 0u64 }
    if ast_pool_grow(ast, III_AST_POOL_LARGE, 1u32) == 0u32 { iii_lex_free_c(ast) ; return 0u64 }
    if ast_pool_grow(ast, III_AST_POOL_USER, 1u32) == 0u32 { iii_lex_free_c(ast) ; return 0u64 }
    /* slot 0 node.kind = III_AST_NULL (0); memset already zeroed it. */
    iii_lex_write_u32_c(ast, AST_OFF_SMALL_COUNT, 1u32)
    iii_lex_write_u32_c(ast, AST_OFF_MEDIUM_COUNT, 1u32)
    iii_lex_write_u32_c(ast, AST_OFF_LARGE_COUNT, 1u32)
    iii_lex_write_u32_c(ast, AST_OFF_USER_COUNT, 1u32)

    let la: u64 = iii_lex_malloc_c(64u64 * 4u64)
    if la == 0u64 { iii_lex_free_c(ast) ; return 0u64 }
    iii_lex_memset_c(la, 0u32, 64u64 * 4u64)
    iii_lex_write_u64_c(ast, AST_OFF_LIST_ARENA, la)
    iii_lex_write_u32_c(ast, AST_OFF_LIST_CAP, 64u32)
    iii_lex_write_u32_c(ast, AST_OFF_LIST_USED, 0u32)

    let sp: u64 = iii_lex_malloc_c(16u64 * 8u64)
    if sp == 0u64 { iii_lex_free_c(ast) ; return 0u64 }
    iii_lex_memset_c(sp, 0u32, 16u64 * 8u64)
    iii_lex_write_u64_c(ast, AST_OFF_STRING_PAYLOADS, sp)
    iii_lex_write_u32_c(ast, AST_OFF_STRING_PAYLOAD_CAP, 16u32)
    iii_lex_write_u32_c(ast, AST_OFF_STRING_PAYLOAD_COUNT, 0u32)

    let hc: u64 = iii_lex_malloc_c(256u64 * HASHCONS_SLOT_BYTES)
    if hc == 0u64 { iii_lex_free_c(ast) ; return 0u64 }
    iii_lex_memset_c(hc, 0u32, 256u64 * HASHCONS_SLOT_BYTES)
    iii_lex_write_u64_c(ast, AST_OFF_HASHCONS, hc)
    iii_lex_write_u32_c(ast, AST_OFF_HASHCONS_CAP, 256u32)
    iii_lex_write_u32_c(ast, AST_OFF_HASHCONS_COUNT, 0u32)

    iii_lex_write_u32_c(ast, AST_OFF_NEXT_BINDER_ID, 1u32)
    iii_lex_write_u32_c(ast, AST_OFF_NEXT_HOLE_ID, 1u32)
    iii_lex_write_u32_c(ast, AST_OFF_ROOT_MODULE, 0u32)
    return ast
}

/* Free one heap pointer stored at container offset `off` (if non-NULL). */
fn ast_free_at(ast: u64, off: u64) -> u32 {
    let p: u64 = iii_lex_read_u64_c(ast, off)
    if p != 0u64 { iii_lex_free_c(p) }
    return 0u32
}

fn iii_ast_destroy(ast: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    ast_free_at(ast, AST_OFF_SMALL_NODES)
    ast_free_at(ast, AST_OFF_MEDIUM_NODES)
    ast_free_at(ast, AST_OFF_LARGE_NODES)
    ast_free_at(ast, AST_OFF_USER_NODES)
    ast_free_at(ast, AST_OFF_SMALL_MHASH)
    ast_free_at(ast, AST_OFF_MEDIUM_MHASH)
    ast_free_at(ast, AST_OFF_LARGE_MHASH)
    ast_free_at(ast, AST_OFF_USER_MHASH)
    ast_free_at(ast, AST_OFF_SMALL_POS_FIRST)
    ast_free_at(ast, AST_OFF_MEDIUM_POS_FIRST)
    ast_free_at(ast, AST_OFF_LARGE_POS_FIRST)
    ast_free_at(ast, AST_OFF_USER_POS_FIRST)
    ast_free_at(ast, AST_OFF_SMALL_BINDER)
    ast_free_at(ast, AST_OFF_MEDIUM_BINDER)
    ast_free_at(ast, AST_OFF_LARGE_BINDER)
    ast_free_at(ast, AST_OFF_USER_BINDER)
    ast_free_at(ast, AST_OFF_SMALL_DOC)
    ast_free_at(ast, AST_OFF_MEDIUM_DOC)
    ast_free_at(ast, AST_OFF_LARGE_DOC)
    ast_free_at(ast, AST_OFF_USER_DOC)
    ast_free_at(ast, AST_OFF_POSITIONS)
    ast_free_at(ast, AST_OFF_LIST_ARENA)
    ast_free_at(ast, AST_OFF_STRING_PAYLOADS)
    ast_free_at(ast, AST_OFF_HASHCONS)
    ast_free_at(ast, AST_OFF_ANNOTATIONS)
    ast_free_at(ast, AST_OFF_ANNOTATION_BLOBS)
    ast_free_at(ast, AST_OFF_PHASE_ARENA)
    ast_free_at(ast, AST_OFF_USER_KINDS)
    iii_lex_free_c(ast)
    return 0u32
}

/* ============================================================================
 * RITCHIE Stage 2.2.3 -- witness setters/accessors + source accessors + root
 * getter.  Mirrors ast.c iii_ast_set_parser_version/token_stream/source/grammar
 * + get_witnesses + root_module_mhash + source_buf/len/path + root_module
 * (527-574).  recompute_root_mhash + set_root_module depend on node_mhash
 * (canonical-bytes, ported §2.2.6-12) -> done in §2.2.15.
 * ============================================================================ */

fn iii_ast_set_parser_version(ast: u64, mhash: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    if mhash == 0u64 { return 0u32 }
    iii_lex_memcpy_c(ast + AST_OFF_PARSER_VERSION_MHASH, mhash, 32u64)
    return 0u32
}
fn iii_ast_set_token_stream_mhash(ast: u64, mhash: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    if mhash == 0u64 { return 0u32 }
    iii_lex_memcpy_c(ast + AST_OFF_TOKEN_STREAM_MHASH, mhash, 32u64)
    return 0u32
}
fn iii_ast_set_source_mhash(ast: u64, mhash: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    if mhash == 0u64 { return 0u32 }
    iii_lex_memcpy_c(ast + AST_OFF_SOURCE_MHASH, mhash, 32u64)
    return 0u32
}
fn iii_ast_set_grammar_mhash(ast: u64, mhash: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    if mhash == 0u64 { return 0u32 }
    iii_lex_memcpy_c(ast + AST_OFF_GRAMMAR_MHASH, mhash, 32u64)
    return 0u32
}

/* 5-arg API: params assigned to locals first (defeats the single-use spill
 * trap) before each conditional memcpy. */
fn iii_ast_get_witnesses(ast: u64, out_pv: u64, out_ts: u64, out_src: u64, out_gram: u64) -> u32 @export {
    let a: u64 = ast
    let pv: u64 = out_pv
    let ts: u64 = out_ts
    let sr: u64 = out_src
    let gr: u64 = out_gram
    if a == 0u64 { return 0u32 }
    if pv != 0u64 { iii_lex_memcpy_c(pv, a + AST_OFF_PARSER_VERSION_MHASH, 32u64) }
    if ts != 0u64 { iii_lex_memcpy_c(ts, a + AST_OFF_TOKEN_STREAM_MHASH, 32u64) }
    if sr != 0u64 { iii_lex_memcpy_c(sr, a + AST_OFF_SOURCE_MHASH, 32u64) }
    if gr != 0u64 { iii_lex_memcpy_c(gr, a + AST_OFF_GRAMMAR_MHASH, 32u64) }
    return 0u32
}

/* Pointer to the 32-byte root-module mhash field (NULL if ast NULL). */
fn iii_ast_root_module_mhash(ast: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    return ast + AST_OFF_ROOT_MODULE_MHASH
}

fn iii_ast_source_buf(ast: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    return iii_lex_read_u64_c(ast, AST_OFF_SOURCE_BUF)
}
fn iii_ast_source_len(ast: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    return iii_lex_read_u64_c(ast, AST_OFF_SOURCE_LEN)
}
fn iii_ast_source_path(ast: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    return iii_lex_read_u64_c(ast, AST_OFF_SOURCE_PATH)
}
fn iii_ast_root_module(ast: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    return iii_lex_read_u32_c(ast, AST_OFF_ROOT_MODULE)
}

/* ============================================================================
 * RITCHIE Stage 2.2.4 -- pool dispatch + position arena + alloc_node +
 * position accessors.  Mirrors ast.c iii_pool_for_kind (172-258),
 * iii_position_arena_grow (585-596), iii_position_chain_prepend (598-607),
 * iii_ast_alloc_node (611-653), iii_pool_pos_first_read +
 * iii_ast_position_count/at/first/add/add_synthetic (1503-1570).
 * Position chain sentinel is -1 stored as i32; walked as u32 != 0xFFFFFFFF
 * (never a signed `>=`, which is the iiis-0 ordering-compare trap).
 * ============================================================================ */

/* Position-record sub-offsets (iii_ast_position_t = 44B; record = 48B). */
const POSITION_T_BYTES: u64 = 44u64
const POS_OFF_KIND: u64 = 0u64
const POS_PHYS_START: u64 = 4u64
const POS_PHYS_END: u64 = 8u64
const POS_PHYS_LINE: u64 = 12u64
const POS_PHYS_COL: u64 = 16u64
const POS_SYN_SRC: u64 = 4u64
const POS_SYN_MHASH: u64 = 8u64
const POS_SYN_RAT: u64 = 40u64
/* iii_src_pos_t (alloc_node `pos` arg) = 16B. */
const SRCPOS_START: u64 = 0u64
const SRCPOS_END: u64 = 4u64
const SRCPOS_LINE: u64 = 8u64
const SRCPOS_COL: u64 = 12u64
const POS_SENTINEL: u32 = 4294967295u32       /* -1 as u32 */

/* kind -> pool table (default LARGE; explicit SMALL/MEDIUM/USER overrides),
 * mirroring ast.c iii_pool_for_kind's switch + default. */
var KIND_POOL : [u8; 80]
var KIND_POOL_INIT : u8 = 0u8

fn kp_set(k: u32, p: u32) -> u32 {
    iii_lex_write_u8_at_c(&KIND_POOL as u64, k as u64, p)
    return 0u32
}
fn kind_pool_init() -> u32 {
    if KIND_POOL_INIT == 1u8 { return 0u32 }
    iii_lex_memset_c(&KIND_POOL as u64, III_AST_POOL_LARGE, 80u64)   /* default LARGE=3 */
    kp_set(III_AST_NULL, III_AST_POOL_NULL)
    /* SMALL (14) */
    kp_set(III_AST_EXPR_BOOL, III_AST_POOL_SMALL)
    kp_set(III_AST_EXPR_TRIT, III_AST_POOL_SMALL)
    kp_set(III_AST_EXPR_UNIT, III_AST_POOL_SMALL)
    kp_set(III_AST_PAT_WILDCARD, III_AST_POOL_SMALL)
    kp_set(III_AST_RING_SET, III_AST_POOL_SMALL)
    kp_set(III_AST_HEXAD_NAME, III_AST_POOL_SMALL)
    kp_set(III_AST_COMPROMISE_BLOCK, III_AST_POOL_SMALL)
    kp_set(III_AST_PAT_LITERAL, III_AST_POOL_SMALL)
    kp_set(III_AST_STMT_RETURN, III_AST_POOL_SMALL)
    kp_set(III_AST_STMT_EXPR, III_AST_POOL_SMALL)
    kp_set(III_AST_EXPR_PAREN, III_AST_POOL_SMALL)
    kp_set(III_AST_EXPR_TYPE, III_AST_POOL_SMALL)
    kp_set(III_AST_TYPE_OF, III_AST_POOL_SMALL)
    kp_set(III_AST_EXPR_HOLE, III_AST_POOL_SMALL)
    /* MEDIUM (31) */
    kp_set(III_AST_EXPR_INT, III_AST_POOL_MEDIUM)
    kp_set(III_AST_EXPR_HEX, III_AST_POOL_MEDIUM)
    kp_set(III_AST_EXPR_IDENT, III_AST_POOL_MEDIUM)
    kp_set(III_AST_EXPR_FIELD, III_AST_POOL_MEDIUM)
    kp_set(III_AST_EXPR_INDEX, III_AST_POOL_MEDIUM)
    kp_set(III_AST_EXPR_UNARY, III_AST_POOL_MEDIUM)
    kp_set(III_AST_EXPR_BINARY, III_AST_POOL_MEDIUM)
    kp_set(III_AST_EXPR_STR, III_AST_POOL_MEDIUM)
    kp_set(III_AST_PAT_HEXAD, III_AST_POOL_MEDIUM)
    kp_set(III_AST_EXPR_HEXAD, III_AST_POOL_MEDIUM)
    kp_set(III_AST_PAT_IDENT, III_AST_POOL_MEDIUM)
    kp_set(III_AST_PAT_TUPLE, III_AST_POOL_MEDIUM)
    kp_set(III_AST_MATCH_ARM, III_AST_POOL_MEDIUM)
    kp_set(III_AST_PARAM, III_AST_POOL_MEDIUM)
    kp_set(III_AST_TYPE_PARAM, III_AST_POOL_MEDIUM)
    kp_set(III_AST_CONST_DECL, III_AST_POOL_MEDIUM)
    kp_set(III_AST_USE, III_AST_POOL_MEDIUM)
    kp_set(III_AST_STMT_LET, III_AST_POOL_MEDIUM)
    kp_set(III_AST_STMT_ASSIGN, III_AST_POOL_MEDIUM)
    kp_set(III_AST_TYPE_PTR, III_AST_POOL_MEDIUM)
    kp_set(III_AST_TYPE_ARRAY, III_AST_POOL_MEDIUM)
    kp_set(III_AST_TYPE_TUPLE, III_AST_POOL_MEDIUM)
    kp_set(III_AST_TYPE_FN, III_AST_POOL_MEDIUM)
    kp_set(III_AST_STMT_SANCTUM_ENTER, III_AST_POOL_MEDIUM)
    kp_set(III_AST_STMT_METAL, III_AST_POOL_MEDIUM)
    kp_set(III_AST_STMT_FOR, III_AST_POOL_MEDIUM)
    kp_set(III_AST_STMT_MATCH, III_AST_POOL_MEDIUM)
    kp_set(III_AST_EXPR_MATCH, III_AST_POOL_MEDIUM)
    kp_set(III_AST_EXPR_PARALLEL, III_AST_POOL_MEDIUM)
    kp_set(III_AST_ARG, III_AST_POOL_MEDIUM)
    kp_set(III_AST_RATIONALE_DECL, III_AST_POOL_MEDIUM)
    /* USER (1) */
    kp_set(III_AST_USER_NODE, III_AST_POOL_USER)
    KIND_POOL_INIT = 1u8
    return 0u32
}
fn iii_pool_for_kind(kind: u32) -> u32 {
    kind_pool_init()
    if kind >= 80u32 { return III_AST_POOL_LARGE }
    return iii_lex_read_u8_at_c(&KIND_POOL as u64, kind as u64)
}

/* Grow the position arena to >= need records (48B each). */
fn iii_position_arena_grow(ast: u64, need: u32) -> u32 {
    let cap: u32 = iii_lex_read_u32_c(ast, AST_OFF_POSITION_CAP)
    if (need as u64) <= (cap as u64) { return 1u32 }
    let new_cap: u32 = ast_grow_cap(cap, need)
    if new_cap == 0u32 { return 0u32 }
    let old: u64 = iii_lex_read_u64_c(ast, AST_OFF_POSITIONS)
    let np: u64 = ast_grow_one(old, cap as u64, new_cap as u64, POSITION_RECORD_BYTES)
    if np == 0u64 { return 0u32 }
    iii_lex_write_u64_c(ast, AST_OFF_POSITIONS, np)
    iii_lex_write_u32_c(ast, AST_OFF_POSITION_CAP, new_cap)
    return 1u32
}

/* Prepend a position record (pos_ptr -> 44B) to the chain headed at first_addr
 * (the address of a pos_first[slot] i32 entry). */
fn iii_position_chain_prepend(ast: u64, first_addr: u64, pos_ptr: u64) -> u32 {
    let cnt: u32 = iii_lex_read_u32_c(ast, AST_OFF_POSITION_COUNT)
    if iii_position_arena_grow(ast, cnt + 1u32) == 0u32 { return 0u32 }
    let base: u64 = iii_lex_read_u64_c(ast, AST_OFF_POSITIONS)
    let rec: u64 = base + (cnt as u64) * POSITION_RECORD_BYTES
    iii_lex_memcpy_c(rec, pos_ptr, POSITION_T_BYTES)
    let old_head: u32 = iii_lex_read_u32_c(first_addr, 0u64)
    iii_lex_write_u32_c(rec, POSREC_OFF_NEXT, old_head)
    iii_lex_write_u32_c(first_addr, 0u64, cnt)
    iii_lex_write_u32_c(ast, AST_OFF_POSITION_COUNT, cnt + 1u32)
    return 1u32
}

/* Scratch position struct (consumed synchronously by chain_prepend). */
var POS_SCRATCH : [u8; 48]

/* Allocate a freshly-typed node in its kind's pool; record physical position. */
fn iii_ast_alloc_node(ast: u64, kind: u32, pos: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    if kind >= III_AST_KIND_COUNT { return 0u32 }
    let pool: u32 = iii_pool_for_kind(kind)
    if pool == III_AST_POOL_NULL { return 0u32 }
    let cnt_off: u64 = ast_off_count(pool)
    let cur: u32 = iii_lex_read_u32_c(ast, cnt_off)
    if ast_pool_grow(ast, pool, cur + 1u32) == 0u32 { return 0u32 }
    let slot: u64 = cur as u64
    iii_lex_write_u32_c(ast, cnt_off, cur + 1u32)
    let nodes: u64 = iii_lex_read_u64_c(ast, ast_off_nodes(pool))
    let node: u64 = nodes + slot * NODE_BYTES
    iii_lex_memset_c(node, 0u32, NODE_BYTES)
    iii_lex_write_u32_c(node, NODE_OFF_KIND, kind)
    /* side-tables: mhash=0, pos_first=-1, binder=0, doc=0 */
    let mhb: u64 = iii_lex_read_u64_c(ast, ast_off_mhash(pool))
    iii_lex_memset_c(mhb + slot * 32u64, 0u32, 32u64)
    let pfb: u64 = iii_lex_read_u64_c(ast, ast_off_pos_first(pool))
    iii_lex_write_u32_c(pfb + slot * 4u64, 0u64, POS_SENTINEL)
    let bdb: u64 = iii_lex_read_u64_c(ast, ast_off_binder(pool))
    iii_lex_write_u32_c(bdb + slot * 4u64, 0u64, 0u32)
    let dcb: u64 = iii_lex_read_u64_c(ast, ast_off_doc(pool))
    iii_lex_write_u32_c(dcb + slot * 4u64, 0u64, 0u32)
    /* record physical position if provided */
    if pos != 0u64 {
        iii_lex_memset_c(&POS_SCRATCH as u64, 0u32, 48u64)
        iii_lex_write_u32_c(&POS_SCRATCH as u64, POS_OFF_KIND, III_POS_PHYSICAL)
        iii_lex_write_u32_c(&POS_SCRATCH as u64, POS_PHYS_START, iii_lex_read_u32_c(pos, SRCPOS_START))
        iii_lex_write_u32_c(&POS_SCRATCH as u64, POS_PHYS_END, iii_lex_read_u32_c(pos, SRCPOS_END))
        iii_lex_write_u32_c(&POS_SCRATCH as u64, POS_PHYS_LINE, iii_lex_read_u32_c(pos, SRCPOS_LINE))
        iii_lex_write_u32_c(&POS_SCRATCH as u64, POS_PHYS_COL, iii_lex_read_u32_c(pos, SRCPOS_COL))
        iii_position_chain_prepend(ast, pfb + slot * 4u64, &POS_SCRATCH as u64)
    }
    return ast_node_make(pool, slot)
}

/* Read pos_first[slot] (sentinel 0xFFFFFFFF if slot out of range). */
fn iii_pool_pos_first_read(ast: u64, pool: u32, slot: u64) -> u32 {
    let cnt: u32 = iii_lex_read_u32_c(ast, ast_off_count(pool))
    if slot >= (cnt as u64) { return POS_SENTINEL }
    let pfb: u64 = iii_lex_read_u64_c(ast, ast_off_pos_first(pool))
    return iii_lex_read_u32_c(pfb + slot * 4u64, 0u64)
}

fn iii_ast_position_count(ast: u64, node_index: u32) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    if node_index == 0u32 { return 0u64 }
    let pool: u32 = ast_node_pool(node_index)
    let slot: u64 = ast_node_slot(node_index)
    let base: u64 = iii_lex_read_u64_c(ast, AST_OFF_POSITIONS)
    let mut cur: u32 = iii_pool_pos_first_read(ast, pool, slot)
    let mut n: u64 = 0u64
    let mut done: u32 = 0u32
    while done == 0u32 {
        if cur == POS_SENTINEL { done = 1u32 }
        if done == 0u32 {
            n = n + 1u64
            cur = iii_lex_read_u32_c(base + (cur as u64) * POSITION_RECORD_BYTES, POSREC_OFF_NEXT)
        }
    }
    return n
}

fn ast_position_at_inner(ast: u64, node_index: u32, i: u64, out: u64) -> i32 {
    if ast == 0u64 { return 0i32 }
    if out == 0u64 { return 0i32 }
    if node_index == 0u32 { return 0i32 }
    let pool: u32 = ast_node_pool(node_index)
    let slot: u64 = ast_node_slot(node_index)
    let base: u64 = iii_lex_read_u64_c(ast, AST_OFF_POSITIONS)
    let mut cur: u32 = iii_pool_pos_first_read(ast, pool, slot)
    let mut k: u64 = 0u64
    let mut done: u32 = 0u32
    let mut found: i32 = 0i32
    while done == 0u32 {
        if cur == POS_SENTINEL { done = 1u32 }
        if done == 0u32 {
            if k == i {
                iii_lex_memcpy_c(out, base + (cur as u64) * POSITION_RECORD_BYTES, POSITION_T_BYTES)
                found = 1i32
                done = 1u32
            }
            if done == 0u32 {
                k = k + 1u64
                cur = iii_lex_read_u32_c(base + (cur as u64) * POSITION_RECORD_BYTES, POSREC_OFF_NEXT)
            }
        }
    }
    return found
}

fn iii_ast_position_at(ast: u64, node_index: u32, i: u64, out: u64) -> i32 @export {
    return ast_position_at_inner(ast, node_index, i, out)
}

fn iii_ast_position_first(ast: u64, node_index: u32, out: u64) -> i32 @export {
    return ast_position_at_inner(ast, node_index, 0u64, out)
}

fn iii_ast_position_add(ast: u64, node_index: u32, pos: u64) -> i32 @export {
    if ast == 0u64 { return 0i32 }
    if pos == 0u64 { return 0i32 }
    if node_index == 0u32 { return 0i32 }
    let pool: u32 = ast_node_pool(node_index)
    let slot: u64 = ast_node_slot(node_index)
    let cnt: u32 = iii_lex_read_u32_c(ast, ast_off_count(pool))
    if slot >= (cnt as u64) { return 0i32 }
    let pfb: u64 = iii_lex_read_u64_c(ast, ast_off_pos_first(pool))
    if iii_position_chain_prepend(ast, pfb + slot * 4u64, pos) == 1u32 { return 1i32 }
    return 0i32
}

fn iii_ast_position_add_synthetic(ast: u64, node_index: u32, src: u32, mhash: u64, rat: u32) -> i32 @export {
    let a: u64 = ast
    let ni: u32 = node_index
    let sn: u32 = src
    let mh: u64 = mhash
    let rt: u32 = rat
    iii_lex_memset_c(&POS_SCRATCH as u64, 0u32, 48u64)
    iii_lex_write_u32_c(&POS_SCRATCH as u64, POS_OFF_KIND, III_POS_SYNTHETIC)
    iii_lex_write_u32_c(&POS_SCRATCH as u64, POS_SYN_SRC, sn)
    if mh != 0u64 { iii_lex_memcpy_c((&POS_SCRATCH as u64) + POS_SYN_MHASH, mh, 32u64) }
    iii_lex_write_u32_c(&POS_SCRATCH as u64, POS_SYN_RAT, rt)
    return iii_ast_position_add(a, ni, &POS_SCRATCH as u64)
}

/* ============================================================================
 * RITCHIE Stage 2.2.6-12 -- per-node mhash + canonical-bytes serializer (A1,
 * the Merkle-DAG core).  Mirrors ast.c iii_ast_node_mhash (1487-1499) +
 * iii_canonical_src_text/list/child (768-805) + iii_canonical_node_bytes
 * (807-1186).  Field addresses are node + NODE_OFF_U(8) + payload-offset
 * (offsetof-measured, CONVERGENCE-AUDIT §2.2.6-prep).  list/src_text are
 * {offset@0, count|length@4}.  Zero-mhash for absent children fed as 32 zero
 * bytes (8x update_u32(0), identical SHA input to update(zero,32)).
 * ============================================================================ */

const LIST_OFF_OFFSET: u64 = 0u64
const LIST_OFF_COUNT: u64 = 4u64
const SRCTEXT_OFF_OFFSET: u64 = 0u64
const SRCTEXT_OFF_LENGTH: u64 = 4u64

/* Pointer to a node's stored 32-byte mhash (0 if absent / out of range). */
fn iii_ast_node_mhash(ast: u64, node_index: u32) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    if node_index == 0u32 { return 0u64 }
    let pool: u32 = ast_node_pool(node_index)
    let slot: u64 = ast_node_slot(node_index)
    let cnt: u32 = iii_lex_read_u32_c(ast, ast_off_count(pool))
    if slot >= (cnt as u64) { return 0u64 }
    let mhb: u64 = iii_lex_read_u64_c(ast, ast_off_mhash(pool))
    return mhb + slot * 32u64
}

fn ast_update_zero32(h: u64) -> u32 {
    let mut i: u32 = 0u32
    while i != 8u32 {
        iii_sha256_update_u32(h, 0u32)
        i = i + 1u32
    }
    return 0u32
}

/* Hash a src_text handle (t_addr -> {offset@0,length@4}): length then bytes. */
fn ast_canon_src_text(h: u64, ast: u64, t_addr: u64) -> u32 {
    let off: u32 = iii_lex_read_u32_c(t_addr, SRCTEXT_OFF_OFFSET)
    let len: u32 = iii_lex_read_u32_c(t_addr, SRCTEXT_OFF_LENGTH)
    iii_sha256_update_u32(h, len)
    if len != 0u32 {
        let src: u64 = iii_lex_read_u64_c(ast, AST_OFF_SOURCE_BUF)
        let slen: u64 = iii_lex_read_u64_c(ast, AST_OFF_SOURCE_LEN)
        if src != 0u64 {
            if (off as u64) + (len as u64) <= slen {
                iii_sha256_update(h, src + (off as u64), len as u64)
            }
        }
    }
    return 0u32
}

/* Feed a child node-index's mhash (or 32 zeros if 0 / unhashed). */
fn ast_canon_child(h: u64, ast: u64, child: u32) -> u32 {
    if child == 0u32 { ast_update_zero32(h) ; return 0u32 }
    let mh: u64 = iii_ast_node_mhash(ast, child)
    if mh == 0u64 { ast_update_zero32(h) ; return 0u32 }
    iii_sha256_update(h, mh, 32u64)
    return 0u32
}

/* Hash a list handle (list_addr -> {offset@0,count@4}): count then child mhashes. */
fn ast_canon_list(h: u64, ast: u64, list_addr: u64) -> u32 {
    let off: u32 = iii_lex_read_u32_c(list_addr, LIST_OFF_OFFSET)
    let cnt: u32 = iii_lex_read_u32_c(list_addr, LIST_OFF_COUNT)
    iii_sha256_update_u32(h, cnt)
    let la: u64 = iii_lex_read_u64_c(ast, AST_OFF_LIST_ARENA)
    let mut i: u32 = 0u32
    while i != cnt {
        let child: u32 = iii_lex_read_u32_c(la, ((off as u64) + (i as u64)) * 4u64)
        ast_canon_child(h, ast, child)
        i = i + 1u32
    }
    return 0u32
}

/* Hash the 6-trit hexad payload at node+8 (6 u32 read as low-byte each). */
fn ast_canon_hexad6(h: u64, node: u64) -> u32 {
    let mut i: u64 = 0u64
    while i != 6u64 {
        iii_sha256_update_u8(h, iii_lex_read_u32_c(node, 8u64 + i * 4u64))
        i = i + 1u64
    }
    return 0u32
}

/* Canonical byte serialisation of a node (kind, flags, then per-kind payload).
 * Per-kind cascade with early return; payload-less kinds (NULL/UNIT/WILDCARD/
 * BREAK/CONTINUE/unknown) fall through to the trailing return after kind+flags. */
fn ast_canonical_node_bytes(h: u64, ast: u64, node: u64) -> u32 {
    let kind: u32 = iii_lex_read_u32_c(node, NODE_OFF_KIND)
    iii_sha256_update_u32(h, kind)
    iii_sha256_update_u16(h, iii_lex_read_u32_c(node, NODE_OFF_FLAGS) & 65535u32)

    if kind == III_AST_MODULE {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        ast_canon_list(h, ast, node + 24u64)
        ast_canon_list(h, ast, node + 32u64)
        return 0u32
    }
    if kind == III_AST_USE {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        ast_canon_src_text(h, ast, node + 20u64)
        return 0u32
    }
    if kind == III_AST_CYCLE_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 24u64))
        ast_canon_list(h, ast, node + 28u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 36u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 40u64))
        return 0u32
    }
    if kind == III_AST_FN_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 24u64))
        ast_canon_list(h, ast, node + 28u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 36u64))
        /* Stage 7.1: hash generic type-params (node+40) only when present, so
         * ordinary fns keep a byte-identical canonical mhash. count @ node+44. */
        let tpc: u32 = iii_lex_read_u32_c(node, 44u64)
        if tpc > 0u32 { ast_canon_list(h, ast, node + 40u64) }
        return 0u32
    }
    if kind == III_AST_TYPE_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 24u64))
        ast_canon_list(h, ast, node + 28u64)
        return 0u32
    }
    if kind == III_AST_CONST_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 20u64))
        return 0u32
    }
    if kind == III_AST_EXTERN_DECL {
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 8u64))
        ast_canon_src_text(h, ast, node + 12u64)
        ast_canon_list(h, ast, node + 20u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 28u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 32u64))
        return 0u32
    }
    if kind == III_AST_MOBIUS_CANDIDATE_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 20u64))
        ast_canon_list(h, ast, node + 24u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 32u64))
        return 0u32
    }
    if kind == III_AST_SCHEMA_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        return 0u32
    }
    if kind == III_AST_SCHEMA_FIELD {
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 8u64))
        ast_canon_src_text(h, ast, node + 12u64)
        ast_canon_list(h, ast, node + 20u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 28u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 32u64))
        return 0u32
    }
    if kind == III_AST_SEALED_CALL_METHOD_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 24u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 28u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 32u64))
        return 0u32
    }
    if kind == III_AST_PARAM {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        return 0u32
    }
    if kind == III_AST_TYPE_PARAM {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_src_text(h, ast, node + 16u64)
        return 0u32
    }
    if kind == III_AST_MODIFIER {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 24u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 28u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 32u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 36u64))
        return 0u32
    }
    if kind == III_AST_TYPE_REF {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        ast_canon_list(h, ast, node + 24u64)
        return 0u32
    }
    if kind == III_AST_TYPE_PTR {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_list(h, ast, node + 12u64)
        return 0u32
    }
    if kind == III_AST_TYPE_ARRAY {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        iii_sha256_update_u64(h, iii_lex_read_u64_c(node, 16u64))
        ast_canon_list(h, ast, node + 24u64)
        return 0u32
    }
    if kind == III_AST_TYPE_TUPLE {
        ast_canon_list(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        return 0u32
    }
    if kind == III_AST_TYPE_FN {
        ast_canon_list(h, ast, node + 8u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        ast_canon_list(h, ast, node + 20u64)
        return 0u32
    }
    if kind == III_AST_STMT_LET {
        iii_sha256_update_u8(h, iii_lex_read_u8_at_c(node, 8u64))
        ast_canon_src_text(h, ast, node + 12u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 20u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 24u64))
        return 0u32
    }
    if kind == III_AST_STMT_WAVEFRONT {
        ast_canon_list(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 24u64))
        return 0u32
    }
    if kind == III_AST_STMT_SANCTUM_ENTER {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        return 0u32
    }
    if kind == III_AST_STMT_METAL {
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 8u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 12u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 16u64))
        return 0u32
    }
    if kind == III_AST_STMT_FOR {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 20u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 24u64))
        return 0u32
    }
    if kind == III_AST_STMT_MATCH {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_list(h, ast, node + 12u64)
        return 0u32
    }
    if kind == III_AST_STMT_RETURN {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_STMT_ASSIGN {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 12u64))
        return 0u32
    }
    if kind == III_AST_STMT_EXPR {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_FORWARD_BLOCK {
        ast_canon_list(h, ast, node + 8u64)
        return 0u32
    }
    if kind == III_AST_COMPROMISE_BLOCK {
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_MATCH_ARM {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 12u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        return 0u32
    }
    if kind == III_AST_PAT_LITERAL {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_PAT_IDENT {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        return 0u32
    }
    if kind == III_AST_PAT_HEXAD {
        ast_canon_hexad6(h, node)
        return 0u32
    }
    if kind == III_AST_PAT_TUPLE {
        ast_canon_list(h, ast, node + 8u64)
        return 0u32
    }
    if kind == III_AST_EXPR_INT {
        iii_sha256_update_u64(h, iii_lex_read_u64_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_EXPR_HEX {
        iii_sha256_update_u64(h, iii_lex_read_u64_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_EXPR_MHASH {
        iii_sha256_update(h, node + 8u64, 32u64)
        return 0u32
    }
    if kind == III_AST_EXPR_STR {
        let spi: u32 = iii_lex_read_u32_c(node, 8u64)
        let sl: u32 = iii_lex_read_u32_c(node, 12u64)
        iii_sha256_update_u32(h, spi)
        iii_sha256_update_u32(h, sl)
        let spc: u32 = iii_lex_read_u32_c(ast, AST_OFF_STRING_PAYLOAD_COUNT)
        if spi < spc {
            let spb: u64 = iii_lex_read_u64_c(ast, AST_OFF_STRING_PAYLOADS)
            let payload: u64 = iii_lex_read_u64_c(spb + (spi as u64) * 8u64, 0u64)
            if payload != 0u64 {
                if sl != 0u32 { iii_sha256_update(h, payload, sl as u64) }
            }
        }
        return 0u32
    }
    if kind == III_AST_EXPR_BOOL {
        iii_sha256_update_u8(h, iii_lex_read_u8_at_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_EXPR_TRIT {
        iii_sha256_update_u8(h, iii_lex_read_u32_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_EXPR_HEXAD {
        ast_canon_hexad6(h, node)
        return 0u32
    }
    if kind == III_AST_EXPR_IDENT {
        ast_canon_src_text(h, ast, node + 8u64)
        return 0u32
    }
    if kind == III_AST_EXPR_CALL {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_list(h, ast, node + 12u64)
        return 0u32
    }
    if kind == III_AST_EXPR_FIELD {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_src_text(h, ast, node + 12u64)
        return 0u32
    }
    if kind == III_AST_EXPR_INDEX {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 12u64))
        return 0u32
    }
    if kind == III_AST_EXPR_BINARY {
        iii_sha256_update_u8(h, iii_lex_read_u32_c(node, 8u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 12u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        return 0u32
    }
    if kind == III_AST_EXPR_UNARY {
        iii_sha256_update_u8(h, iii_lex_read_u32_c(node, 8u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 12u64))
        return 0u32
    }
    if kind == III_AST_EXPR_BLOCK {
        ast_canon_list(h, ast, node + 8u64)
        return 0u32
    }
    if kind == III_AST_EXPR_MATCH {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_list(h, ast, node + 12u64)
        return 0u32
    }
    if kind == III_AST_EXPR_PAREN {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_EXPR_RAW_ASM {
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 8u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 12u64))
        return 0u32
    }
    if kind == III_AST_RING_SET {
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_HEXAD_NAME {
        ast_canon_src_text(h, ast, node + 8u64)
        return 0u32
    }
    if kind == III_AST_ARG {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        return 0u32
    }
    if kind == III_AST_EXPR_TYPE {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_TYPE_OF {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_EXPR_HOLE {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 12u64))
        return 0u32
    }
    if kind == III_AST_EXPR_PARALLEL {
        ast_canon_list(h, ast, node + 8u64)
        return 0u32
    }
    if kind == III_AST_ERROR_NODE {
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 8u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 12u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 16u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 20u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 24u64))
        return 0u32
    }
    if kind == III_AST_ADR_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_src_text(h, ast, node + 16u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 24u64))
        ast_canon_list(h, ast, node + 28u64)
        return 0u32
    }
    if kind == III_AST_CONFORMANCE_CLAIM_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_src_text(h, ast, node + 16u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 24u64))
        return 0u32
    }
    if kind == III_AST_TEST_CASE_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 20u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 24u64))
        return 0u32
    }
    if kind == III_AST_RATIONALE_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 16u64))
        return 0u32
    }
    if kind == III_AST_OPERATOR_INTENT {
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 8u64))
        iii_sha256_update(h, node + 12u64, 32u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 44u64))
        return 0u32
    }
    if kind == III_AST_USER_NODE {
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 8u64))
        ast_canon_list(h, ast, node + 12u64)
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 20u64))
        iii_sha256_update_u32(h, iii_lex_read_u32_c(node, 24u64))
        return 0u32
    }
    if kind == III_AST_STMT_IF {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 12u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        return 0u32
    }
    if kind == III_AST_STMT_WHILE {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 12u64))
        return 0u32
    }
    if kind == III_AST_STMT_LOOP {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        return 0u32
    }
    if kind == III_AST_EXPR_RANGE {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 12u64))
        return 0u32
    }
    if kind == III_AST_EXPR_CAST {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 12u64))
        return 0u32
    }
    if kind == III_AST_EXPR_SIZEOF {
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 8u64))
        iii_sha256_update_u64(h, iii_lex_read_u64_c(node, 16u64))
        return 0u32
    }
    if kind == III_AST_STRUCT_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_list(h, ast, node + 16u64)
        return 0u32
    }
    if kind == III_AST_VAR_DECL {
        ast_canon_src_text(h, ast, node + 8u64)
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 16u64))
        ast_canon_child(h, ast, iii_lex_read_u32_c(node, 20u64))
        return 0u32
    }
    return 0u32
}

/* ============================================================================
 * RITCHIE Stage 2.2.5 -- open-addressed hash-cons (A2) + intern_node.  Mirrors
 * ast.c iii_hashcons_grow/lookup/insert (657-711) + iii_ast_intern_node
 * (713-764).  Slot = 36B {mhash[32]@0, node_index u32@32}; probe key =
 * mhash[0..3] little-endian & (cap-1); cap is a power of two.  intern computes
 * the node's canonical mhash, stores it in the side-table, and either dedups
 * (drop fresh slot + migrate its position chain to the existing node) or
 * inserts (set INTERNED + add to the table).
 * ============================================================================ */

/* Probe key from the first 4 mhash bytes (little-endian). */
fn ast_hc_hash(mh_addr: u64) -> u32 {
    let b0: u32 = iii_lex_read_u8_at_c(mh_addr, 0u64)
    let b1: u32 = iii_lex_read_u8_at_c(mh_addr, 1u64)
    let b2: u32 = iii_lex_read_u8_at_c(mh_addr, 2u64)
    let b3: u32 = iii_lex_read_u8_at_c(mh_addr, 3u64)
    return b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32)
}

/* Grow the hash-cons table to keep load < 50% (need*2 <= cap), rehashing. */
fn ast_hashcons_grow(ast: u64, need: u32) -> u32 {
    let cap: u32 = iii_lex_read_u32_c(ast, AST_OFF_HASHCONS_CAP)
    if (need as u64) * 2u64 <= (cap as u64) { return 1u32 }
    let mut nc: u32 = 256u32
    if cap != 0u32 { nc = cap * 2u32 }
    let mut grown: u32 = 0u32
    while grown == 0u32 {
        if (nc as u64) >= (need as u64) * 2u64 { grown = 1u32 }
        if grown == 0u32 {
            if (nc as u64) > 2147483647u64 { return 0u32 }
            nc = nc * 2u32
        }
    }
    let np: u64 = iii_lex_malloc_c((nc as u64) * HASHCONS_SLOT_BYTES)
    if np == 0u64 { return 0u32 }
    iii_lex_memset_c(np, 0u32, (nc as u64) * HASHCONS_SLOT_BYTES)
    let old: u64 = iii_lex_read_u64_c(ast, AST_OFF_HASHCONS)
    let mask: u32 = nc - 1u32
    let mut i: u32 = 0u32
    while i != cap {
        let oslot: u64 = old + (i as u64) * HASHCONS_SLOT_BYTES
        let oni: u32 = iii_lex_read_u32_c(oslot, HC_OFF_NODE_INDEX)
        if oni != 0u32 {
            let mut pos: u32 = ast_hc_hash(oslot) & mask
            let mut placed: u32 = 0u32
            while placed == 0u32 {
                let nslot: u64 = np + (pos as u64) * HASHCONS_SLOT_BYTES
                if iii_lex_read_u32_c(nslot, HC_OFF_NODE_INDEX) == 0u32 {
                    iii_lex_memcpy_c(nslot, oslot, HASHCONS_SLOT_BYTES)
                    placed = 1u32
                }
                if placed == 0u32 { pos = (pos + 1u32) & mask }
            }
        }
        i = i + 1u32
    }
    if old != 0u64 { iii_lex_free_c(old) }
    iii_lex_write_u64_c(ast, AST_OFF_HASHCONS, np)
    iii_lex_write_u32_c(ast, AST_OFF_HASHCONS_CAP, nc)
    return 1u32
}

/* Look up node-index by mhash (0 if absent). */
fn ast_hashcons_lookup(ast: u64, mh_addr: u64) -> u32 {
    let cap: u32 = iii_lex_read_u32_c(ast, AST_OFF_HASHCONS_CAP)
    if cap == 0u32 { return 0u32 }
    let base: u64 = iii_lex_read_u64_c(ast, AST_OFF_HASHCONS)
    let mask: u32 = cap - 1u32
    let mut pos: u32 = ast_hc_hash(mh_addr) & mask
    let mut result: u32 = 0u32
    let mut done: u32 = 0u32
    while done == 0u32 {
        let slot: u64 = base + (pos as u64) * HASHCONS_SLOT_BYTES
        let ni: u32 = iii_lex_read_u32_c(slot, HC_OFF_NODE_INDEX)
        if ni == 0u32 { done = 1u32 }
        if done == 0u32 {
            if iii_lex_memcmp_c(slot, mh_addr, 32u64) == 0i32 {
                result = ni
                done = 1u32
            }
            if done == 0u32 { pos = (pos + 1u32) & mask }
        }
    }
    return result
}

/* Insert (mhash, node_index) (grows first). */
fn ast_hashcons_insert(ast: u64, mh_addr: u64, node_index: u32) -> u32 {
    let cnt: u32 = iii_lex_read_u32_c(ast, AST_OFF_HASHCONS_COUNT)
    if ast_hashcons_grow(ast, cnt + 1u32) == 0u32 { return 0u32 }
    let cap: u32 = iii_lex_read_u32_c(ast, AST_OFF_HASHCONS_CAP)
    let base: u64 = iii_lex_read_u64_c(ast, AST_OFF_HASHCONS)
    let mask: u32 = cap - 1u32
    let mut pos: u32 = ast_hc_hash(mh_addr) & mask
    let mut done: u32 = 0u32
    while done == 0u32 {
        let slot: u64 = base + (pos as u64) * HASHCONS_SLOT_BYTES
        if iii_lex_read_u32_c(slot, HC_OFF_NODE_INDEX) == 0u32 {
            iii_lex_memcpy_c(slot, mh_addr, 32u64)
            iii_lex_write_u32_c(slot, HC_OFF_NODE_INDEX, node_index)
            done = 1u32
        }
        if done == 0u32 { pos = (pos + 1u32) & mask }
    }
    iii_lex_write_u32_c(ast, AST_OFF_HASHCONS_COUNT, cnt + 1u32)
    return 1u32
}

/* Migrate the fresh slot's position chain onto the existing node (dedup). */
fn ast_intern_migrate_pos(ast: u64, fresh: u32, existing: u32) -> u32 {
    let fpool: u32 = ast_node_pool(fresh)
    let fslot: u64 = ast_node_slot(fresh)
    let epool: u32 = ast_node_pool(existing)
    let eslot: u64 = ast_node_slot(existing)
    let ecnt: u32 = iii_lex_read_u32_c(ast, ast_off_count(epool))
    if (eslot as u64) >= (ecnt as u64) { return 0u32 }
    let new_head: u64 = iii_lex_read_u64_c(ast, ast_off_pos_first(fpool)) + fslot * 4u64
    let old_head: u64 = iii_lex_read_u64_c(ast, ast_off_pos_first(epool)) + eslot * 4u64
    let positions: u64 = iii_lex_read_u64_c(ast, AST_OFF_POSITIONS)
    let mut cur: u32 = iii_lex_read_u32_c(new_head, 0u64)
    let mut done: u32 = 0u32
    while done == 0u32 {
        if cur == POS_SENTINEL { done = 1u32 }
        if done == 0u32 {
            let rec: u64 = positions + (cur as u64) * POSITION_RECORD_BYTES
            let nxt: u32 = iii_lex_read_u32_c(rec, POSREC_OFF_NEXT)
            iii_lex_write_u32_c(rec, POSREC_OFF_NEXT, iii_lex_read_u32_c(old_head, 0u64))
            iii_lex_write_u32_c(old_head, 0u64, cur)
            cur = nxt
        }
    }
    iii_lex_write_u32_c(new_head, 0u64, POS_SENTINEL)
    return 0u32
}

/* Intern a freshly-allocated node: compute its canonical mhash, dedup or insert. */
fn iii_ast_intern_node(ast: u64, freshly: u32) -> u32 @export {
    if ast == 0u64 { return freshly }
    if freshly == 0u32 { return freshly }
    let pool: u32 = ast_node_pool(freshly)
    let slot: u64 = ast_node_slot(freshly)
    let node: u64 = ast_pool_node(ast, pool, slot)
    if node == 0u64 { return freshly }
    let mhb: u64 = iii_lex_read_u64_c(ast, ast_off_mhash(pool)) + slot * 32u64
    let h: u64 = iii_lex_malloc_c(III_AST_SHA256_STATE_BYTES)
    if h == 0u64 { return freshly }
    iii_sha256_init(h)
    ast_canonical_node_bytes(h, ast, node)
    iii_sha256_final(h, mhb)
    iii_lex_free_c(h)
    let existing: u32 = ast_hashcons_lookup(ast, mhb)
    if existing != 0u32 {
        let cnt: u32 = iii_lex_read_u32_c(ast, ast_off_count(pool))
        if cnt == (slot as u32) + 1u32 { iii_lex_write_u32_c(ast, ast_off_count(pool), cnt - 1u32) }
        ast_intern_migrate_pos(ast, freshly, existing)
        return existing
    }
    let fl: u32 = iii_lex_read_u32_c(node, NODE_OFF_FLAGS)
    iii_lex_write_u32_c(node, NODE_OFF_FLAGS, fl | III_AST_FLAG_INTERNED)
    ast_hashcons_insert(ast, mhb, freshly)
    return freshly
}

/* ============================================================================
 * RITCHIE Stage 2.2.13 + 2.2.14 -- string interning + list arena.  Mirrors
 * ast.c iii_ast_intern_string/string_payload_count/get (1313-1343),
 * iii_ast_list_begin/push/commit/extend (1190-1242), open-list create/push/
 * commit/destroy (1253-1309), iii_ast_list_at (1385-1391).  iii_ast_list_t is
 * 8B {offset@0,count@4}: returned packed in rax (offset=low32,count=high32),
 * passed-by-value in one register.  The open-list is opaque (parser holds the
 * ptr only) so its 24B layout {ast@0,items@8,count@16,cap@20} is self-chosen.
 * ============================================================================ */

const OL_BYTES: u64 = 24u64
const OL_OFF_AST: u64 = 0u64
const OL_OFF_ITEMS: u64 = 8u64
const OL_OFF_COUNT: u64 = 16u64
const OL_OFF_CAP: u64 = 20u64

fn iii_ast_intern_string(ast: u64, payload: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    let cnt: u32 = iii_lex_read_u32_c(ast, AST_OFF_STRING_PAYLOAD_COUNT)
    let cap: u32 = iii_lex_read_u32_c(ast, AST_OFF_STRING_PAYLOAD_CAP)
    if cnt == cap {
        let nc: u32 = ast_grow_cap(cap, cap + 1u32)
        if nc == 0u32 { return 0u32 }
        let old: u64 = iii_lex_read_u64_c(ast, AST_OFF_STRING_PAYLOADS)
        let np: u64 = ast_grow_one(old, cap as u64, nc as u64, 8u64)
        if np == 0u64 { return 0u32 }
        iii_lex_write_u64_c(ast, AST_OFF_STRING_PAYLOADS, np)
        iii_lex_write_u32_c(ast, AST_OFF_STRING_PAYLOAD_CAP, nc)
    }
    let base: u64 = iii_lex_read_u64_c(ast, AST_OFF_STRING_PAYLOADS)
    iii_lex_write_u64_c(base + (cnt as u64) * 8u64, 0u64, payload)
    iii_lex_write_u32_c(ast, AST_OFF_STRING_PAYLOAD_COUNT, cnt + 1u32)
    return cnt
}
fn iii_ast_string_payload_count(ast: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    return iii_lex_read_u32_c(ast, AST_OFF_STRING_PAYLOAD_COUNT)
}
fn iii_ast_string_payload_get(ast: u64, idx: u32) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    let cnt: u32 = iii_lex_read_u32_c(ast, AST_OFF_STRING_PAYLOAD_COUNT)
    if idx >= cnt { return 0u64 }
    let base: u64 = iii_lex_read_u64_c(ast, AST_OFF_STRING_PAYLOADS)
    return iii_lex_read_u64_c(base + (idx as u64) * 8u64, 0u64)
}

fn iii_ast_list_begin(ast: u64) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    return iii_lex_read_u32_c(ast, AST_OFF_LIST_USED)
}

/* push node_index onto the master list arena (list_start is ignored, LIFO). */
fn iii_ast_list_push(ast: u64, list_start: u32, node_index: u32) -> i32 @export {
    if ast == 0u64 { return 0i32 }
    let used: u32 = iii_lex_read_u32_c(ast, AST_OFF_LIST_USED)
    let cap: u32 = iii_lex_read_u32_c(ast, AST_OFF_LIST_CAP)
    if used == cap {
        let nc: u32 = ast_grow_cap(cap, cap + 1u32)
        if nc == 0u32 { return 0i32 }
        let old: u64 = iii_lex_read_u64_c(ast, AST_OFF_LIST_ARENA)
        let np: u64 = ast_grow_one(old, cap as u64, nc as u64, 4u64)
        if np == 0u64 { return 0i32 }
        iii_lex_write_u64_c(ast, AST_OFF_LIST_ARENA, np)
        iii_lex_write_u32_c(ast, AST_OFF_LIST_CAP, nc)
    }
    let la: u64 = iii_lex_read_u64_c(ast, AST_OFF_LIST_ARENA)
    iii_lex_write_u32_c(la + (used as u64) * 4u64, 0u64, node_index)
    iii_lex_write_u32_c(ast, AST_OFF_LIST_USED, used + 1u32)
    return 1i32
}

/* commit -> packed iii_ast_list_t (offset=list_start, count=used-list_start). */
fn iii_ast_list_commit(ast: u64, list_start: u32) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    let used: u32 = iii_lex_read_u32_c(ast, AST_OFF_LIST_USED)
    let count: u32 = used - list_start
    return (list_start as u64) | ((count as u64) << 32u64)
}

fn iii_ast_list_extend(ast: u64, existing: u64, node_index: u32) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    let mut ex_off: u32 = 0u32
    let mut ex_cnt: u32 = 0u32
    if existing != 0u64 {
        ex_off = iii_lex_read_u32_c(existing, LIST_OFF_OFFSET)
        ex_cnt = iii_lex_read_u32_c(existing, LIST_OFF_COUNT)
    }
    if ex_cnt == 0u32 {
        let s: u32 = iii_ast_list_begin(ast)
        if iii_ast_list_push(ast, s, node_index) == 0i32 { return 0u64 }
        return iii_ast_list_commit(ast, s)
    }
    let used: u32 = iii_lex_read_u32_c(ast, AST_OFF_LIST_USED)
    if (ex_off + ex_cnt) != used { return 0u64 }
    if iii_ast_list_push(ast, ex_off, node_index) == 0i32 { return 0u64 }
    return (ex_off as u64) | (((ex_cnt + 1u32) as u64) << 32u64)
}

fn iii_ast_open_list_create(ast: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    let ol: u64 = iii_lex_malloc_c(OL_BYTES)
    if ol == 0u64 { return 0u64 }
    iii_lex_memset_c(ol, 0u32, OL_BYTES)
    iii_lex_write_u64_c(ol, OL_OFF_AST, ast)
    return ol
}
fn iii_ast_open_list_push(ol: u64, node_index: u32) -> i32 @export {
    if ol == 0u64 { return 0i32 }
    let cnt: u32 = iii_lex_read_u32_c(ol, OL_OFF_COUNT)
    let cap: u32 = iii_lex_read_u32_c(ol, OL_OFF_CAP)
    if cnt == cap {
        let mut nc: u32 = 8u32
        if cap != 0u32 { nc = cap * 2u32 }
        let old: u64 = iii_lex_read_u64_c(ol, OL_OFF_ITEMS)
        let np: u64 = ast_grow_one(old, cap as u64, nc as u64, 4u64)
        if np == 0u64 { return 0i32 }
        iii_lex_write_u64_c(ol, OL_OFF_ITEMS, np)
        iii_lex_write_u32_c(ol, OL_OFF_CAP, nc)
    }
    let items: u64 = iii_lex_read_u64_c(ol, OL_OFF_ITEMS)
    iii_lex_write_u32_c(items + (cnt as u64) * 4u64, 0u64, node_index)
    iii_lex_write_u32_c(ol, OL_OFF_COUNT, cnt + 1u32)
    return 1i32
}
fn iii_ast_open_list_destroy(ol: u64) -> u32 @export {
    if ol == 0u64 { return 0u32 }
    let items: u64 = iii_lex_read_u64_c(ol, OL_OFF_ITEMS)
    if items != 0u64 { iii_lex_free_c(items) }
    iii_lex_free_c(ol)
    return 0u32
}
fn iii_ast_open_list_commit(ast: u64, ol: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    if ol == 0u64 { return 0u64 }
    let used: u32 = iii_lex_read_u32_c(ast, AST_OFF_LIST_USED)
    let olcnt: u32 = iii_lex_read_u32_c(ol, OL_OFF_COUNT)
    if olcnt != 0u32 {
        let need: u32 = used + olcnt
        let cap: u32 = iii_lex_read_u32_c(ast, AST_OFF_LIST_CAP)
        if need > cap {
            let nc: u32 = ast_grow_cap(cap, need)
            if nc == 0u32 { iii_ast_open_list_destroy(ol) ; return 0u64 }
            let old: u64 = iii_lex_read_u64_c(ast, AST_OFF_LIST_ARENA)
            let np: u64 = ast_grow_one(old, cap as u64, nc as u64, 4u64)
            if np == 0u64 { iii_ast_open_list_destroy(ol) ; return 0u64 }
            iii_lex_write_u64_c(ast, AST_OFF_LIST_ARENA, np)
            iii_lex_write_u32_c(ast, AST_OFF_LIST_CAP, nc)
        }
        let la: u64 = iii_lex_read_u64_c(ast, AST_OFF_LIST_ARENA)
        let items: u64 = iii_lex_read_u64_c(ol, OL_OFF_ITEMS)
        iii_lex_memcpy_c(la + (used as u64) * 4u64, items, (olcnt as u64) * 4u64)
        iii_lex_write_u32_c(ast, AST_OFF_LIST_USED, used + olcnt)
    }
    iii_ast_open_list_destroy(ol)
    return (used as u64) | ((olcnt as u64) << 32u64)
}

/* list_at: list passed packed (offset=low32, count=high32). */
fn iii_ast_list_at(ast: u64, list_packed: u64, i: u32) -> u32 @export {
    if ast == 0u64 { return 0u32 }
    let off: u32 = (list_packed & 4294967295u64) as u32
    let cnt: u32 = (list_packed >> 32u64) as u32
    if i >= cnt { return 0u32 }
    let used: u32 = iii_lex_read_u32_c(ast, AST_OFF_LIST_USED)
    if (off + i) >= used { return 0u32 }
    let la: u64 = iii_lex_read_u64_c(ast, AST_OFF_LIST_ARENA)
    return iii_lex_read_u32_c(la + ((off + i) as u64) * 4u64, 0u64)
}

/* ============================================================================
 * RITCHIE Stage 2.2.15a -- read accessors + root recompute.  Mirrors ast.c
 * iii_ast_get/get_mut (1347-1363), node_count (1365-1371), pool_count
 * (1373-1383), recompute_root_mhash (559-569), set_root_module (576-581).
 * (kind_name NUL-pool ships in §2.2.15b.)
 * ============================================================================ */

fn iii_ast_get(ast: u64, node_index: u32) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    if node_index == 0u32 { return iii_lex_read_u64_c(ast, AST_OFF_SMALL_NODES) }
    return ast_pool_node(ast, ast_node_pool(node_index), ast_node_slot(node_index))
}
fn iii_ast_get_mut(ast: u64, node_index: u32) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    if node_index == 0u32 { return iii_lex_read_u64_c(ast, AST_OFF_SMALL_NODES) }
    return ast_pool_node(ast, ast_node_pool(node_index), ast_node_slot(node_index))
}

/* ============================================================================
 * ast_accessors port -- batch 1: node basics + decl-name + module/block lists.
 * Moved here from ast_accessors.c (DELETED there).  Field reads use this file's
 * own iii_lex_read_u32_c / iii_lex_read_u64_c at C-authoritative byte offsets
 * (extracted via offsetof, gen_ast_offsets).  Node header: kind@0 flags@4,
 * union@8 (sizeof 48).  iii_src_text_t{offset@0,length@4}=8B; iii_ast_list_t
 * {offset@0,count@4}=8B read packed as a u64 for iii_ast_list_at.
 * ============================================================================ */

/* decl `name` field byte-offset by kind: 12 for extern_decl (4-byte abi prefix),
 * 8 for the other seven decl kinds, 0 = not a named decl. */
fn ast_decl_name_field_off(k: u32) -> u64 {
    if k == III_AST_EXTERN_DECL { return 12u64 }
    if k == III_AST_CYCLE_DECL { return 8u64 }
    if k == III_AST_FN_DECL { return 8u64 }
    if k == III_AST_TYPE_DECL { return 8u64 }
    if k == III_AST_CONST_DECL { return 8u64 }
    if k == III_AST_MOBIUS_CANDIDATE_DECL { return 8u64 }
    if k == III_AST_SCHEMA_DECL { return 8u64 }
    if k == III_AST_SEALED_CALL_METHOD_DECL { return 8u64 }
    return 0u64
}

fn iii_ast_node_kind(ast: u64, node: u32) -> u32 @export {
