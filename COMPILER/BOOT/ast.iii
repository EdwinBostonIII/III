        ast_iter_list(ic, np + 8u64, 0u32)
        ast_iter_list(ic, np + 16u64, 22u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 24u64), 23u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_STMT_SANCTUM_ENTER {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 16u64), 8u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_STMT_FOR {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 16u64), 24u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 20u64), 25u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 24u64), 8u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_STMT_MATCH {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 26u32)
        ast_iter_list(ic, np + 12u64, 27u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_STMT_RETURN {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 12u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_STMT_ASSIGN {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 28u32)
        ast_iter_child(ic, iii_lex_read_u32_c(np, 12u64), 12u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_STMT_EXPR {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 17u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_FORWARD_BLOCK {
        ast_iter_list(ic, np + 8u64, 29u32)
        return iii_lex_read_u32_c(ic, IC_ERR) as i32
    }
    if kind == III_AST_MATCH_ARM {
        ast_iter_child(ic, iii_lex_read_u32_c(np, 8u64), 30u32)
