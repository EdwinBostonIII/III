/* --- Pool encoding (ast.h:312-330): node_index = (pool<<28)|slot --------- */
const III_AST_POOL_SHIFT: u64 = 28u64
const III_AST_SLOT_MASK: u64 = 268435455u64       /* 0x0FFFFFFF */
const III_AST_POOL_NULL: u32 = 0u32
const III_AST_POOL_SMALL: u32 = 1u32
const III_AST_POOL_MEDIUM: u32 = 2u32
const III_AST_POOL_LARGE: u32 = 3u32
const III_AST_POOL_USER: u32 = 4u32

/* node handle <-> (pool, slot) */
fn ast_node_make(pool: u32, slot: u64) -> u32 {
    return (((pool as u64) << III_AST_POOL_SHIFT) | (slot & III_AST_SLOT_MASK)) as u32
}
fn ast_node_pool(idx: u32) -> u32 {
    return (((idx as u64) >> III_AST_POOL_SHIFT) & 15u64) as u32
}
fn ast_node_slot(idx: u32) -> u64 {
    return (idx as u64) & III_AST_SLOT_MASK
}

