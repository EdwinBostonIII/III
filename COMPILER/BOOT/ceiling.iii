/* C:\Users\Edwin Boston\OneDrive\Desktop\III\COMPILER\BOOT\ceiling.iii
 *
 * III Stage-0 Ceiling Membership Ledger — .iii port of ceiling.c.
 *
 * Mirrors ceiling.h ABI exactly so this object file is link-compatible
 * with the C iiis-0 build (replaces ceiling.o).  All seven public
 * symbols are @export'd (unmangled).  SHA-256 is hand-rolled inline.
 *
 * Limitations of iii Stage-0 codegen at port time forced a few
 * structural simplifications versus ceiling.c:
 *   - No struct-pointer arguments (cg_r3 lacks (*p).field lvalue).
 *     SHA-256 working state lives in module-scope globals; the SHA
 *     used here is single-shot inside iii_ceil_bitmap_mhash so the
 *     globals are not reentrant — acceptable for this single call.
 *   - cl_K[64] is initialised by an explicit one-shot function rather
 *     than a const array literal, because const-array layout in
 *     iiis-0's cg_r3 emits .quad slots (8 bytes) which would corrupt
 *     a u32 stride.
 *   - No "for i in A..B" with mutable B; loop bounds are integer
 *     literals (matches what iiis-0 supports).
 */

module ceiling

/* ─── Public ABI: error codes (must match ceiling.h) ───────────────── */

const III_CEIL_OK         : u32 = 0u32
const III_CEIL_E_SEALED   : u32 = 1u32
const III_CEIL_BYTES      : u32 = 8192u32

/* ─── Ledger state ─────────────────────────────────────────────────── */

var BM      : [u8; 8192]
var INITED  : u8 = 0u8
var SEALED  : u8 = 0u8

/* ─── SHA-256 working state (single-shot; not reentrant) ───────────── */

var CL_K       : [u32; 64]
var CL_K_INIT  : u8 = 0u8
var CL_W       : [u32; 64]
var CL_H       : [u32; 8]
var CL_BUF     : [u8; 64]
var CL_BUFLEN  : u32 = 0u32
var CL_BITS    : u64 = 0u64

/* ─── Helpers ──────────────────────────────────────────────────────── */

fn cl_rotr(x: u32, n: u32) -> u32 {
    return (x >> n) | (x << (32u32 - n))
}

fn cl_init_k_once() -> u32 {
    if CL_K_INIT == 1u8 { return 0u32 }
    CL_K[0]  = 0x428a2f98u32; CL_K[1]  = 0x71374491u32
    CL_K[2]  = 0xb5c0fbcfu32; CL_K[3]  = 0xe9b5dba5u32
    CL_K[4]  = 0x3956c25bu32; CL_K[5]  = 0x59f111f1u32
    CL_K[6]  = 0x923f82a4u32; CL_K[7]  = 0xab1c5ed5u32
    CL_K[8]  = 0xd807aa98u32; CL_K[9]  = 0x12835b01u32
    CL_K[10] = 0x243185beu32; CL_K[11] = 0x550c7dc3u32
    CL_K[12] = 0x72be5d74u32; CL_K[13] = 0x80deb1feu32
    CL_K[14] = 0x9bdc06a7u32; CL_K[15] = 0xc19bf174u32
    CL_K[16] = 0xe49b69c1u32; CL_K[17] = 0xefbe4786u32
    CL_K[18] = 0x0fc19dc6u32; CL_K[19] = 0x240ca1ccu32
    CL_K[20] = 0x2de92c6fu32; CL_K[21] = 0x4a7484aau32
    CL_K[22] = 0x5cb0a9dcu32; CL_K[23] = 0x76f988dau32
    CL_K[24] = 0x983e5152u32; CL_K[25] = 0xa831c66du32
    CL_K[26] = 0xb00327c8u32; CL_K[27] = 0xbf597fc7u32
    CL_K[28] = 0xc6e00bf3u32; CL_K[29] = 0xd5a79147u32
    CL_K[30] = 0x06ca6351u32; CL_K[31] = 0x14292967u32
    CL_K[32] = 0x27b70a85u32; CL_K[33] = 0x2e1b2138u32
    CL_K[34] = 0x4d2c6dfcu32; CL_K[35] = 0x53380d13u32
    CL_K[36] = 0x650a7354u32; CL_K[37] = 0x766a0abbu32
    CL_K[38] = 0x81c2c92eu32; CL_K[39] = 0x92722c85u32
    CL_K[40] = 0xa2bfe8a1u32; CL_K[41] = 0xa81a664bu32
    CL_K[42] = 0xc24b8b70u32; CL_K[43] = 0xc76c51a3u32
    CL_K[44] = 0xd192e819u32; CL_K[45] = 0xd6990624u32
    CL_K[46] = 0xf40e3585u32; CL_K[47] = 0x106aa070u32
    CL_K[48] = 0x19a4c116u32; CL_K[49] = 0x1e376c08u32
    CL_K[50] = 0x2748774cu32; CL_K[51] = 0x34b0bcb5u32
    CL_K[52] = 0x391c0cb3u32; CL_K[53] = 0x4ed8aa4au32
    CL_K[54] = 0x5b9cca4fu32; CL_K[55] = 0x682e6ff3u32
    CL_K[56] = 0x748f82eeu32; CL_K[57] = 0x78a5636fu32
    CL_K[58] = 0x84c87814u32; CL_K[59] = 0x8cc70208u32
    CL_K[60] = 0x90befffau32; CL_K[61] = 0xa4506cebu32
    CL_K[62] = 0xbef9a3f7u32; CL_K[63] = 0xc67178f2u32
    CL_K_INIT = 1u8
    return 0u32
}

fn cl_sha_init() -> u32 {
    CL_H[0] = 0x6a09e667u32; CL_H[1] = 0xbb67ae85u32
    CL_H[2] = 0x3c6ef372u32; CL_H[3] = 0xa54ff53au32
    CL_H[4] = 0x510e527fu32; CL_H[5] = 0x9b05688cu32
    CL_H[6] = 0x1f83d9abu32; CL_H[7] = 0x5be0cd19u32
    CL_BITS = 0u64
    CL_BUFLEN = 0u32
    return 0u32
}

/* Process one 64-byte block from CL_BUF into CL_H. */
fn cl_sha_block() -> u32 {
    for i in 0..16 {
        let i4: u32 = (i as u32) * 4u32
        let b0: u32 = CL_BUF[i4 + 0u32] as u32
        let b1: u32 = CL_BUF[i4 + 1u32] as u32
        let b2: u32 = CL_BUF[i4 + 2u32] as u32
        let b3: u32 = CL_BUF[i4 + 3u32] as u32
        CL_W[i] = (b0 << 24u32) | (b1 << 16u32) | (b2 << 8u32) | b3
    }
    for j in 16..64 {
        let w15: u32 = CL_W[j - 15]
        let w2:  u32 = CL_W[j - 2]
        let s0: u32 = cl_rotr(w15, 7u32) ^ cl_rotr(w15, 18u32) ^ (w15 >> 3u32)
        let s1: u32 = cl_rotr(w2, 17u32) ^ cl_rotr(w2, 19u32) ^ (w2 >> 10u32)
        CL_W[j] = CL_W[j - 16] + s0 + CL_W[j - 7] + s1
    }
    let mut a: u32 = CL_H[0]
    let mut b: u32 = CL_H[1]
    let mut c: u32 = CL_H[2]
    let mut d: u32 = CL_H[3]
    let mut e: u32 = CL_H[4]
    let mut f: u32 = CL_H[5]
    let mut g: u32 = CL_H[6]
    let mut h: u32 = CL_H[7]
    for i in 0..64 {
        let S1: u32 = cl_rotr(e, 6u32) ^ cl_rotr(e, 11u32) ^ cl_rotr(e, 25u32)
        let ch: u32 = (e & f) ^ ((~e) & g)
        let t1: u32 = h + S1 + ch + CL_K[i] + CL_W[i]
        let S0: u32 = cl_rotr(a, 2u32) ^ cl_rotr(a, 13u32) ^ cl_rotr(a, 22u32)
        let mj: u32 = (a & b) ^ (a & c) ^ (b & c)
        let t2: u32 = S0 + mj
        h = g; g = f; f = e
        e = d + t1
        d = c; c = b; b = a
        a = t1 + t2
    }
    CL_H[0] = CL_H[0] + a
    CL_H[1] = CL_H[1] + b
    CL_H[2] = CL_H[2] + c
    CL_H[3] = CL_H[3] + d
    CL_H[4] = CL_H[4] + e
    CL_H[5] = CL_H[5] + f
    CL_H[6] = CL_H[6] + g
    CL_H[7] = CL_H[7] + h
    return 0u32
}

/* Feed `len` bytes from `data` into the running hash. */
fn cl_sha_update(data: *u8, len: u64) -> u32 {
    CL_BITS = CL_BITS + (len * 8u64)
    let mut off: u64 = 0u64
    let mut rem: u64 = len
    while rem > 0u64 {
        let mut take: u64 = 64u64 - (CL_BUFLEN as u64)
        if take > rem { take = rem }
        for k in 0..64 {
            if (k as u64) < take {
                CL_BUF[CL_BUFLEN + (k as u32)] = data[off + (k as u64)]
            }
        }
        CL_BUFLEN = CL_BUFLEN + (take as u32)
        off = off + take
        rem = rem - take
        if CL_BUFLEN == 64u32 {
            cl_sha_block()
            CL_BUFLEN = 0u32
        }
    }
    return 0u32
}

/* Single-byte update (used for padding). */
fn cl_sha_update_byte(b: u8) -> u32 {
    CL_BITS = CL_BITS + 8u64
    CL_BUF[CL_BUFLEN] = b
    CL_BUFLEN = CL_BUFLEN + 1u32
    if CL_BUFLEN == 64u32 {
        cl_sha_block()
        CL_BUFLEN = 0u32
    }
    return 0u32
}

fn cl_sha_final(out: *u8) -> u32 {
    let final_bits: u64 = CL_BITS
    cl_sha_update_byte(0x80u8)
    while CL_BUFLEN != 56u32 {
        cl_sha_update_byte(0u8)
    }
    /* Append 64-bit big-endian length (was bits BEFORE padding). */
    cl_sha_update_byte(((final_bits >> 56u64) & 0xffu64) as u8)
    cl_sha_update_byte(((final_bits >> 48u64) & 0xffu64) as u8)
    cl_sha_update_byte(((final_bits >> 40u64) & 0xffu64) as u8)
    cl_sha_update_byte(((final_bits >> 32u64) & 0xffu64) as u8)
    cl_sha_update_byte(((final_bits >> 24u64) & 0xffu64) as u8)
    cl_sha_update_byte(((final_bits >> 16u64) & 0xffu64) as u8)
    cl_sha_update_byte(((final_bits >>  8u64) & 0xffu64) as u8)
    cl_sha_update_byte(( final_bits         & 0xffu64) as u8)
    /* Cancel out the bits we counted for the padding. */
    /* Note: counting padding into CL_BITS is harmless because we only
     * ever consult final_bits, captured before the padding bytes. */
    for i in 0..8 {
        let hi: u32 = CL_H[i]
        let i4: u32 = (i as u32) * 4u32
        out[i4 + 0u32] = ((hi >> 24u32) & 0xffu32) as u8
        out[i4 + 1u32] = ((hi >> 16u32) & 0xffu32) as u8
        out[i4 + 2u32] = ((hi >>  8u32) & 0xffu32) as u8
        out[i4 + 3u32] = ( hi          & 0xffu32) as u8
    }
    return 0u32
}

/* ─── Public ABI: lifecycle ────────────────────────────────────────── */

fn iii_ceil_init_denied() -> u32 @export {
    for i in 0..8192 {
        BM[i] = 0u8
    }
    INITED = 1u8
    SEALED = 0u8
    return 0u32
}

fn iii_ceil_admit_kind(cycle_kind: u16) -> u32 @export {
    if SEALED == 1u8 { return III_CEIL_E_SEALED }
    INITED = 1u8
    let idx: u32 = (cycle_kind / 8u16) as u32
    let bit: u32 = (cycle_kind % 8u16) as u32
    let m32: u32 = 1u32 << bit
    let mask: u8 = m32 as u8
    BM[idx] = BM[idx] | mask
    return III_CEIL_OK
}

fn iii_ceil_deny_kind(cycle_kind: u16) -> u32 @export {
    if SEALED == 1u8 { return III_CEIL_E_SEALED }
    INITED = 1u8
    let idx: u32 = (cycle_kind / 8u16) as u32
    let bit: u32 = (cycle_kind % 8u16) as u32
    let m32: u32 = 1u32 << bit
    let mu8: u8 = m32 as u8
    let mask: u8 = ~mu8
    BM[idx] = BM[idx] & mask
    return III_CEIL_OK
}

fn iii_ceil_admitted_kind(cycle_kind: u16) -> u32 @export {
    if INITED == 0u8 { return 0u32 }
    let idx: u32 = (cycle_kind / 8u16) as u32
    let bit: u32 = (cycle_kind % 8u16) as u32
    let v: u32 = (BM[idx] as u32) >> bit
    return v & 1u32
}

fn iii_ceil_seal() -> u32 @export {
    SEALED = 1u8
    return III_CEIL_OK
}

fn iii_ceil_is_sealed() -> u32 @export {
    return SEALED as u32
}

fn iii_ceil_canonical_bytes(out: *u8) -> u32 @export {
    if INITED == 0u8 {
        for i in 0..8192 {
            out[i] = 0u8
        }
        return 0u32
    }
    for i in 0..8192 {
        out[i] = BM[i]
    }
    return 0u32
}

fn iii_ceil_bitmap_mhash(out: *u8) -> u32 @export {
    cl_init_k_once()
    cl_sha_init()
    if INITED == 0u8 {
        /* Hash 8192 zero bytes deterministically by seeding BM. */
        for i in 0..8192 {
            BM[i] = 0u8
        }
        INITED = 1u8
    }
    cl_sha_update(&BM[0], 8192u64)
    cl_sha_final(out)
    return 0u32
}

fn iii_ceil_count_admitted() -> u32 @export {
    if INITED == 0u8 { return 0u32 }
    let mut n: u32 = 0u32
    for i in 0..8192 {
        let mut b: u8 = BM[i]
        while b != 0u8 {
            n = n + ((b as u32) & 1u32)
            b = b >> 1u8
        }
    }
    return n
}
