/* COMPILER/BOOT/cg_opt_rules.iii -- Path C: the SINGLE SOURCE of cg_r3's strength-reduction EMISSION law,
 * factored out of r3_mul_pow2_k so the very admit/shift functions that DRIVE codegen are the ones the
 * STDLIB certifier (forcefield/cg_opt_cert.iii) kernel-PROVES sound (x*2^k == x<<k mod 2^64, via the CIC
 * BV64 kernel) over the full emittable range k=1..63.  Before this, r3_mul_pow2_k computed k inline and the
 * proof lived in a sandbox that never inspected the emitter -- the F6 "no proof->emit binding" gap.  Now
 * cg_r3 is TABLE-DRIVEN: it delegates the (admit, shift) decision here, and the certifier proves THIS code.
 *
 * Zero deps (integer-only, no externs) so iiis-0 compiles it standalone and it links into iiis-2.  The logic
 * is IDENTICAL to cg_r3.c's inline mul_pow2_k, so iiis-0 (C, inline) and iiis-2 (.iii, delegating here) emit
 * byte-for-byte the same assembly -- mechanically gated by build_iiis2.sh --check-corpus.  K: 1.00. */
module boot_cg_opt_rules

/* admit: is `x * v` a WIDTH-FAITHFUL strength reduction (mul -> shift)?  1 iff v is an exact power of two
 * >= 2 (then x*v == x<<log2(v) mod 2^64 for signed + unsigned).  A non-pow2 / overflowing factor is REJECTED
 * -- the soundness boundary the CIC kernel proof and this admit share. */
fn cgopt_mul_admit(v: u64) -> u32 @export {
    if v < 2u64 { return 0u32 }
    if (v & (v - 1u64)) != 0u64 { return 0u32 }
    return 1u32
}

/* shift_k: the shift amount k such that v == 2^k.  Caller guarantees cgopt_mul_admit(v)==1, so v is an
 * exact power of two in 2^1..2^63 and this returns 1..63. */
fn cgopt_mul_shift_k(v: u64) -> u32 @export {
    let mut k: u32 = 0u32
    let mut t: u64 = v
    while t > 1u64 { t = t >> 1u64; k = k + 1u32 }
    return k
}

/* div_admit: is UNSIGNED `x / v` a width-faithful pow2 strength reduction (div -> shr)?  1 iff v is an exact
 * power of two >= 2 (then x/v == x>>log2(v) for unsigned: floor division IS the logical shift).  Signed div is
 * NOT reduced here (signed x/2^k rounds toward zero, != arithmetic shift) -- cg_r3 gates the emission on
 * unsignedness.  cg_r3 had NO division strength reduction at all (it emitted divq even for x/8); this is the
 * optimization the synthesizer found that the compiler lacked. */
fn cgopt_div_admit(v: u64) -> u32 @export {
    if v < 2u64 { return 0u32 }
    if (v & (v - 1u64)) != 0u64 { return 0u32 }
    return 1u32
}
/* shift_k for the div reduction: k such that v == 2^k.  Caller guarantees cgopt_div_admit(v)==1, so v is an
 * exact power of two in 2^1..2^63 and this returns 1..63 (identical to cgopt_mul_shift_k). */
fn cgopt_div_shift_k(v: u64) -> u32 @export {
    let mut k: u32 = 0u32
    let mut t: u64 = v
    while t > 1u64 { t = t >> 1u64; k = k + 1u32 }
    return k
}

/* sdiv_admit: is SIGNED `x / v` (v the raw u64 word of the constant divisor literal) a width-faithful
 * pow2 BIAS-SHIFT reduction (idiv -> sar+and+add+sar)?  1 iff v == 2^k for k in 1..62 (v >= 2, exact
 * power of two, HIGH BIT CLEAR: v = 2^63 as a u64 literal reads as the NEGATIVE divisor -2^63 under
 * i64 -- excluded, it keeps idivq).  Then for ALL i64 x:
 *     trunc(x / 2^k) == (x + ((x >>arith 63) & (2^k - 1))) >>arith k
 * (x >= 0: bias 0, arithmetic shift = floor = trunc; x < 0: trunc = ceil = floor((x + 2^k - 1)/2^k),
 * and the bias add of a POSITIVE < 2^63 to a NEGATIVE x cannot overflow).  No trap case exists (the
 * divisor is 2^k >= 2, never -1, so INT_MIN/-1 never routes here).  Certified in
 * forcefield/cg_opt_rules.iii (complete width-8/16 sweeps against the hardware divider + boot
 * agreement); the fold fires only on a CONSTANT pow2 divisor, absent from stage1_corpus, so
 * iiis-0 == iiis-2 on stage1 holds (byte-safe, like magic-div and the umod fold). */
fn cgopt_sdiv_admit(v: u64) -> u32 @export {
    if v < 2u64 { return 0u32 }
    if (v >> 63u64) != 0u64 { return 0u32 }
    if (v & (v - 1u64)) != 0u64 { return 0u32 }
    return 1u32
}
/* sdiv_k: the shift amount k such that v == 2^k.  Caller guarantees cgopt_sdiv_admit(v)==1, so v is an
 * exact power of two in 2^1..2^62 and this returns 1..62. */
fn cgopt_sdiv_k(v: u64) -> u32 @export {
    let mut k: u32 = 0u32
    let mut t: u64 = v
    while t > 1u64 { t = t >> 1u64; k = k + 1u32 }
    return k
}
/* sdiv_mask: the bias mask 2^k - 1 (>= 1).  Caller guarantees cgopt_sdiv_admit(v)==1. */
fn cgopt_sdiv_mask(v: u64) -> u64 @export {
    return v - 1u64
}

/* mod_admit: is UNSIGNED `x % v` a width-faithful pow2 strength reduction (umod -> AND mask)?  1 iff v is an exact
 * power of two >= 2 (then x % v == x & (v-1) for unsigned: the remainder mod 2^k IS the low k bits).  Signed % is NOT
 * reduced here (signed remainder rounds toward zero, != the low bits) -- cg_r3 gates emission on unsignedness.  The
 * SYMMETRIC PARTNER of cgopt_div_admit; cg_r3 had NO modulo strength reduction at all (it emitted divumod for x%8). */
fn cgopt_mod_admit(v: u64) -> u32 @export {
    if v < 2u64 { return 0u32 }
    if (v & (v - 1u64)) != 0u64 { return 0u32 }
    return 1u32
}
/* mod_mask for the umod reduction: the AND mask v-1 = 2^k-1 (the low k bits).  Caller guarantees
 * cgopt_mod_admit(v)==1, so v is a power of two in 2^1..2^63 and v-1 is the k-bit low mask (>= 1). */
fn cgopt_mod_mask(v: u64) -> u64 @export {
    return v - 1u64
}

/* shladd_admit: is `x * v` a WIDTH-FAITHFUL shift-and-add strength reduction (mul -> shl+add)?  1 iff
 * v == 2^k + 1 for k in 1..63, i.e. v >= 3 and (v-1) is an exact power of two.  Then
 * x*v == x*(2^k+1) == (x<<k) + x mod 2^64 (proven over bv_ring: (2^k+1)x = 2^k x + x).  Disjoint from
 * cgopt_mul_admit (2^k+1 is always odd, never a power of two), so cg_r3 tries the pow2 shift first, then
 * this shl+add for the non-pow2 (2^k+1) factors it would otherwise emit as a full imul.  This replaces an
 * imul with one shl + one add -- strictly cheaper on the metal, and cg_r3 did not have it before. */
fn cgopt_mul_shladd_admit(v: u64) -> u32 @export {
    if v < 3u64 { return 0u32 }
    let m: u64 = v - 1u64
    if (m & (m - 1u64)) != 0u64 { return 0u32 }
    return 1u32
}

/* shladd_k: the shift amount k such that v == 2^k + 1.  Caller guarantees cgopt_mul_shladd_admit(v)==1,
 * so v-1 is an exact power of two in 2^1..2^63 and this returns 1..63 (= log2(v-1)). */
fn cgopt_mul_shladd_k(v: u64) -> u32 @export {
    let mut k: u32 = 0u32
    let mut t: u64 = v - 1u64
    while t > 1u64 { t = t >> 1u64; k = k + 1u32 }
    return k
}

/* [EMITTED by seraphyte_emit_rule.sh from descriptor NAME=subk FLOOR=7 SHAPE=2^k-1 OP=subq]
 * is `x * v` a width-faithful shl-sub strength reduction?  1 iff v == 2^k-1 for k in 3..63 (v >= 7
 * and v+1 an exact power of two).  Then x*v == subk: (x<<k) - x mod 2^64.  v=3 (=2^2-1) is excluded
 * (floor 7): 3 is also 2^1+1 (shladd's by dispatch).  Replaces an imul with one shl + one subq. */
fn cgopt_mul_subk_admit(v: u64) -> u32 @export {
    if v < 7u64 { return 0u32 }
    if (v >> 63u64) != 0u64 { return 0u32 }   /* v >= 2^63: outside k<=63; also guards the v+1 overflow */
    let p: u64 = v + 1u64                       /* v < 2^63, so v+1 does not overflow */
    if (p & v) != 0u64 { return 0u32 }          /* v+1 must be an exact power of two: v == 2^k - 1 */
    return 1u32
}
fn cgopt_mul_subk_k(v: u64) -> u32 @export {
    let mut k: u32 = 0u32
    let mut t: u64 = v + 1u64
    while t > 1u64 { t = t >> 1u64; k = k + 1u32 }
    return k
}

/* [EMITTED by seraphyte_emit_2shift.sh] is `x * v` a width-faithful TWO-SHIFT strength reduction?  1 iff
 * v == 2^j + 2^m with j > m >= 1 (popcount 2 and EVEN -- disjoint from pow2/shladd/subk).  Then
 * x*v == (x<<j) + (x<<m) mod 2^64.  Replaces a full imul with two shifts + one add. */
fn cgopt_mul_2sh_admit(v: u64) -> u32 @export {
    if (v & 1u64) != 0u64 { return 0u32 }              /* must be EVEN (low bit m >= 1) */
    let mut c: u32 = 0u32
    let mut t: u64 = v
    while t != 0u64 {
        if (t & 1u64) != 0u64 { c = c + 1u32 }
        t = t >> 1u64
    }
    if c != 2u32 { return 0u32 }                       /* exactly two set bits */
    return 1u32
}
/* the HIGH set-bit position j (caller guarantees cgopt_mul_2sh_admit(v)==1). */
fn cgopt_mul_2sh_j(v: u64) -> u32 @export {
    let mut k: u32 = 0u32
    let mut hi: u32 = 0u32
    let mut t: u64 = v
    while t != 0u64 {
        if (t & 1u64) != 0u64 { hi = k }
        k = k + 1u32
        t = t >> 1u64
    }
    return hi
}
/* the LOW set-bit position m (caller guarantees cgopt_mul_2sh_admit(v)==1). */
fn cgopt_mul_2sh_m(v: u64) -> u32 @export {
    let mut k: u32 = 0u32
    let mut t: u64 = v
    while (t & 1u64) == 0u64 {
        k = k + 1u32
        t = t >> 1u64
    }
    return k
}

/* [EMITTED by seraphyte_emit_2sub.sh] is `x * v` a width-faithful 2-shift-SUBTRACT strength reduction?  1 iff
 * v == 2^j - 2^m with j > m >= 1 and j-m >= 3 -- i.e. v is a CONTIGUOUS run of >= 3 one-bits NOT starting at
 * bit 0 (even, popcount >= 3, the run test).  Then x*v == (x<<j) - (x<<m) mod 2^64.  Disjoint from
 * pow2/shladd/2-shift-add (popcount<=2) and subk (run from bit 0).  Replaces a full imul with two shl + one sub. */
fn cgopt_mul_2ss_admit(v: u64) -> u32 @export {
    if (v & 1u64) != 0u64 { return 0u32 }              /* even: the run starts at bit m >= 1 */
    let mut c: u32 = 0u32
    let mut t: u64 = v
    while t != 0u64 {
        if (t & 1u64) != 0u64 { c = c + 1u32 }
        t = t >> 1u64
    }
    if c < 3u32 { return 0u32 }                         /* popcount >= 3 (disjoint from the popcount-2 rules) */
    let mut s: u64 = v
    while (s & 1u64) == 0u64 { s = s >> 1u64 }          /* strip trailing zeros -> the run, low bit set */
    if ((s + 1u64) & s) != 0u64 { return 0u32 }         /* the run must be all ones: s == 2^(j-m) - 1 */
    return 1u32
}
/* the LOW shift m = number of trailing zeros (caller guarantees admit). */
fn cgopt_mul_2ss_m(v: u64) -> u32 @export {
    let mut k: u32 = 0u32
    let mut t: u64 = v
    while (t & 1u64) == 0u64 {
        k = k + 1u32
        t = t >> 1u64
    }
    return k
}
/* the HIGH shift j = m + popcount (the run spans bits m .. j-1) (caller guarantees admit). */
fn cgopt_mul_2ss_j(v: u64) -> u32 @export {
    let mut c: u32 = 0u32
    let mut t: u64 = v
    while t != 0u64 {
        if (t & 1u64) != 0u64 { c = c + 1u32 }
        t = t >> 1u64
    }
    let mut m: u32 = 0u32
    let mut s: u64 = v
    while (s & 1u64) == 0u64 {
        m = m + 1u32
        s = s >> 1u64
    }
    return m + c
}
