extern @abi(c-msvc-x64) fn cgsha_snapshot(ctx: u64, out: u64) -> u32 from "cg_sha.iii"
var R0_SHA : [u64; 14]
fn iii_cg_r0_sha_init_c() -> u32 { cgsha_init(&R0_SHA as u64); return 0u32 }
fn iii_cg_r0_sha_update_c(addr: u64, n: u64) -> u32 { cgsha_update(&R0_SHA as u64, addr, n); return 0u32 }
fn iii_cg_r0_sha_snapshot_c(out32: u64) -> u32 { cgsha_snapshot(&R0_SHA as u64, out32); return 0u32 }

