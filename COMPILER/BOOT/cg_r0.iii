        let callee: u32 = iii_ast_call_callee(R0_G_AST, node)
        let argc: u32 = iii_ast_call_arg_count(R0_G_AST, node)
        let mut i: u32 = 0u32
        while i < argc { let a: u32 = iii_ast_call_arg_at(R0_G_AST, node, i); let ae: u32 = r0_emit_expr(iii_ast_arg_value(R0_G_AST, a)); if ae != R0_OK { return ae }; i = i + 1u32 }
        if argc >= 4u32 { r0_emit_arr(&R0_STR_POPR9_NL as u64, R0_STR_POPR9_NL_LEN); R0_G_STACK_DEPTH = R0_G_STACK_DEPTH - 1u32 }
        if argc >= 3u32 { r0_emit_arr(&R0_STR_POPR8_NL as u64, R0_STR_POPR8_NL_LEN); R0_G_STACK_DEPTH = R0_G_STACK_DEPTH - 1u32 }
        if argc >= 2u32 { r0_pop_rdx() }
        if argc >= 1u32 { r0_pop_rcx() }
        r0_emit_arr(&R0_STR_SUB32_RSP as u64, R0_STR_SUB32_RSP_LEN)
        let ck: u32 = iii_ast_node_kind(R0_G_AST, callee)
        if ck == R0_K_EXPR_IDENT {
            let kapi_off: u32 = iii_ast_ident_name_offset(R0_G_AST, callee)
            let kapi_len: u32 = iii_ast_ident_name_length(R0_G_AST, callee)
            r0_emit_arr(&R0_STR_CALLQ as u64, R0_STR_CALLQ_LEN)
            if r0_callee_is_kernel_import(callee, kapi_off) == 1u32 { r0_emit_sym_run(kapi_off, kapi_len) } else { r0_emit_decl_label(kapi_off, kapi_len) }
            r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
        } else { let cee: u32 = r0_emit_expr(callee); if cee != R0_OK { return cee }; r0_pop_rax(); r0_emit_arr(&R0_STR_CALL_INDIR as u64, R0_STR_CALL_INDIR_LEN) }
        r0_emit_arr(&R0_STR_ADD32_RSP as u64, R0_STR_ADD32_RSP_LEN)
        r0_push_rax(); return R0_OK
    }
    if k == R0_K_EXPR_MATCH {
        let scrut: u32 = iii_ast_match_expr_scrutinee(R0_G_AST, node)
        let armc: u32 = iii_ast_match_expr_arm_count(R0_G_AST, node)
        let endid: u32 = R0_G_LABEL_COUNTER; R0_G_LABEL_COUNTER = R0_G_LABEL_COUNTER + 1u32
        let se2: u32 = r0_emit_expr(scrut); if se2 != R0_OK { return se2 }; r0_pop_rax()
        let mut i: u32 = 0u32
        while i < armc { let arm: u32 = iii_ast_match_expr_arm_at(R0_G_AST, node, i); let pat: u32 = iii_ast_match_arm_pattern(R0_G_AST, arm); r0_emit_pattern_compare(pat, endid); let body: u32 = iii_ast_match_arm_body(R0_G_AST, arm); let be: u32 = r0_emit_expr(body); if be != R0_OK { return be }; r0_pop_rax(); r0_emit_arr(&R0_STR_JMP as u64, R0_STR_JMP_LEN); r0_emit_arr(&R0_PFX_MATCHEND as u64, R0_PFX_MATCHEND_LEN); r0_emit_dec(endid as u64); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN); i = i + 1u32 }
        r0_emit_arr(&R0_PFX_MATCHEND as u64, R0_PFX_MATCHEND_LEN); r0_emit_dec(endid as u64); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
        r0_push_rax(); return R0_OK
    }
    if k == R0_K_EXPR_RAW_ASM {
        let idx: u32 = iii_ast_raw_asm_str_idx(R0_G_AST, node)
        let addr: u64 = iii_ast_string_payload_addr_c(R0_G_AST, idx)
        let len: u32 = iii_ast_raw_asm_len(R0_G_AST, node)
        r0_emit_bytes(addr, len as u64)
        r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
        r0_emit_arr(&R0_STR_XORRAX as u64, R0_STR_XORRAX_LEN)
        r0_push_rax(); return R0_OK
    }
    R0_G_LAST_ERROR = R0_E_UNSUPPORTED; return R0_E_UNSUPPORTED
}

/* ─────────────── emit_stmt ─────────────── */
fn r0_emit_stmt(node: u32) -> u32 {
    if node == 0u32 { return R0_OK }
    let k: u32 = iii_ast_node_kind(R0_G_AST, node)
    if k == R0_K_STMT_LET {
        let v: u32 = iii_ast_let_value(R0_G_AST, node)
        let off: u32 = iii_ast_let_name_off(R0_G_AST, node)
        let len: u32 = iii_ast_let_name_len(R0_G_AST, node)
        let mut s: i32 = r0_local_lookup(off, len)
        if s < 0i32 { s = r0_local_add(off, len) }
        if v != 0u32 { let ve: u32 = r0_emit_expr(v); if ve != R0_OK { return ve }; r0_pop_rax(); if s >= 0i32 { r0_emit_store_rax_slot(s as u32) } }
        return R0_OK
    }
    if k == R0_K_STMT_EXPR { let xe: u32 = r0_emit_expr(iii_ast_expr_stmt_expr(R0_G_AST, node)); if xe != R0_OK { return xe }; r0_pop_rax(); return R0_OK }
    if k == R0_K_STMT_RETURN {
        let v: u32 = iii_ast_return_value(R0_G_AST, node)
        if v != 0u32 { let rve: u32 = r0_emit_expr(v); if rve != R0_OK { return rve }; r0_pop_rax() } else { r0_emit_arr(&R0_STR_MOVABS0 as u64, R0_STR_MOVABS0_LEN) }
        if R0_G_CUR_SECMEM != 0u32 { r0_emit_arr(&R0_CMT_D14_SEC_EXIT as u64, R0_CMT_D14_SEC_EXIT_LEN) }
        /* BUG-2 fix: save %rax (return value) with TWO pushes so %rsp stays 16-byte aligned
           across the witness EXIT call (MS x64 wants rsp%16==8 at the callee entry). */
        r0_emit_arr(&R0_STR_WIT_PUSHRAX as u64, R0_STR_WIT_PUSHRAX_LEN)
        r0_emit_arr(&R0_STR_WIT_PUSHRAX as u64, R0_STR_WIT_PUSHRAX_LEN)
        r0_emit_arr(&R0_STR_WIT_RCX_EXT as u64, R0_STR_WIT_RCX_EXT_LEN)
        r0_emit_arr(&R0_STR_WIT_SUB32 as u64, R0_STR_WIT_SUB32_LEN)
        r0_emit_arr(&R0_STR_WIT_CALL as u64, R0_STR_WIT_CALL_LEN)
        r0_emit_arr(&R0_STR_WIT_ADD32 as u64, R0_STR_WIT_ADD32_LEN)
        r0_emit_arr(&R0_STR_WIT_POPRAX as u64, R0_STR_WIT_POPRAX_LEN)
        r0_emit_arr(&R0_STR_WIT_POPRAX as u64, R0_STR_WIT_POPRAX_LEN)
        r0_emit_arr(&R0_STR_EPILOGUE as u64, R0_STR_EPILOGUE_LEN)
        R0_G_EMITTED_RETURN = 1u32
        return R0_OK
    }
    if k == R0_K_STMT_ASSIGN {
        let lv: u32 = iii_ast_assign_lvalue(R0_G_AST, node)
        let val: u32 = iii_ast_assign_value(R0_G_AST, node)
        let vae: u32 = r0_emit_expr(val); if vae != R0_OK { return vae }; r0_pop_rax()
        let lk: u32 = iii_ast_node_kind(R0_G_AST, lv)
        if lk == R0_K_EXPR_IDENT {
            let off: u32 = iii_ast_ident_name_offset(R0_G_AST, lv)
            let len: u32 = iii_ast_ident_name_length(R0_G_AST, lv)
            let s: i32 = r0_local_lookup(off, len)
            if s >= 0i32 { r0_emit_store_rax_slot(s as u32); return R0_OK }
            r0_emit_arr(&R0_STR_MOVQ_RAX_C as u64, R0_STR_MOVQ_RAX_C_LEN)
            r0_emit_decl_label(off, len)
            r0_emit_arr(&R0_STR_RIP_PAREN as u64, R0_STR_RIP_PAREN_LEN)
            return R0_OK
        }
        if lk == R0_K_EXPR_INDEX {
            let obj: u32 = iii_ast_index_object(R0_G_AST, lv)
            let idx: u32 = iii_ast_index_index(R0_G_AST, lv)
            /* BUG-3 fix: value is already in %rax (pre-emitted above). Push it, then
               evaluate obj and idx onto the operand stack and pop idx->rcx, obj->rax,
               val->rdx so the store `movq %rdx,(%rax,%rcx,8)` writes val to [obj+idx*8].
               The old code saved val into -8(%rbp) -- which ALIASES local slot 0 -- then
               reloaded it over obj and stored an unset %rdx. */
            r0_push_rax()
            let aoe: u32 = r0_emit_expr(obj); if aoe != R0_OK { return aoe }; let aie: u32 = r0_emit_expr(idx); if aie != R0_OK { return aie }
            r0_pop_rcx(); r0_pop_rax(); r0_pop_rdx()
            if R0_G_CUR_SECMEM != 0u32 { r0_emit_arr(&R0_STR_INDEX_NTI as u64, R0_STR_INDEX_NTI_LEN) } else { r0_emit_arr(&R0_STR_INDEX_ST as u64, R0_STR_INDEX_ST_LEN) }
            return R0_OK
        }
        return R0_OK
    }
    if k == R0_K_STMT_IF {
        let lbl_else: u32 = R0_G_LABEL_COUNTER; R0_G_LABEL_COUNTER = R0_G_LABEL_COUNTER + 1u32
        let lbl_end: u32 = R0_G_LABEL_COUNTER; R0_G_LABEL_COUNTER = R0_G_LABEL_COUNTER + 1u32
        let cond: u32 = iii_ast_if_cond(R0_G_AST, node)
        let then_b: u32 = iii_ast_if_then(R0_G_AST, node)
        let else_b: u32 = iii_ast_if_else(R0_G_AST, node)
        let ce2: u32 = r0_emit_expr(cond); if ce2 != R0_OK { return ce2 }; r0_pop_rax()
        r0_emit_arr(&R0_STR_TESTRRAX as u64, R0_STR_TESTRRAX_LEN)
        r0_emit_arr(&R0_STR_JZ as u64, R0_STR_JZ_LEN)
        if else_b != 0u32 { r0_emit_arr(&R0_PFX_LIFELSE as u64, R0_PFX_LIFELSE_LEN); r0_emit_dec(lbl_else as u64) } else { r0_emit_arr(&R0_PFX_LIFEND as u64, R0_PFX_LIFEND_LEN); r0_emit_dec(lbl_end as u64) }
        r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
        let te: u32 = r0_emit_block(then_b); if te != R0_OK { return te }
        if else_b != 0u32 {
            r0_emit_arr(&R0_STR_JMP as u64, R0_STR_JMP_LEN); r0_emit_arr(&R0_PFX_LIFEND as u64, R0_PFX_LIFEND_LEN); r0_emit_dec(lbl_end as u64); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
            r0_emit_arr(&R0_PFX_LIFELSE as u64, R0_PFX_LIFELSE_LEN); r0_emit_dec(lbl_else as u64); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
            let ek: u32 = iii_ast_node_kind(R0_G_AST, else_b)
            if ek == R0_K_STMT_IF { let ee: u32 = r0_emit_stmt(else_b); if ee != R0_OK { return ee } } else { let eb: u32 = r0_emit_block(else_b); if eb != R0_OK { return eb } }
        }
        r0_emit_arr(&R0_PFX_LIFEND as u64, R0_PFX_LIFEND_LEN); r0_emit_dec(lbl_end as u64); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
        return R0_OK
    }
    if k == R0_K_STMT_WHILE {
        let lbl_top: u32 = R0_G_LABEL_COUNTER; R0_G_LABEL_COUNTER = R0_G_LABEL_COUNTER + 1u32
        let lbl_end: u32 = R0_G_LABEL_COUNTER; R0_G_LABEL_COUNTER = R0_G_LABEL_COUNTER + 1u32
        let wcond: u32 = iii_ast_while_cond(R0_G_AST, node)
        let wbody: u32 = iii_ast_while_body(R0_G_AST, node)
        r0_emit_arr(&R0_PFX_FORTOP as u64, R0_PFX_FORTOP_LEN); r0_emit_dec(lbl_top as u64); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
        let wce: u32 = r0_emit_expr(wcond); if wce != R0_OK { return wce }; r0_pop_rax()
        r0_emit_arr(&R0_STR_TESTRRAX as u64, R0_STR_TESTRRAX_LEN)
        r0_emit_arr(&R0_STR_JZ as u64, R0_STR_JZ_LEN); r0_emit_arr(&R0_PFX_FOREND as u64, R0_PFX_FOREND_LEN); r0_emit_dec(lbl_end as u64); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
        let we: u32 = r0_emit_block(wbody); if we != R0_OK { return we }
        r0_emit_arr(&R0_STR_JMP as u64, R0_STR_JMP_LEN); r0_emit_arr(&R0_PFX_FORTOP as u64, R0_PFX_FORTOP_LEN); r0_emit_dec(lbl_top as u64); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
        r0_emit_arr(&R0_PFX_FOREND as u64, R0_PFX_FOREND_LEN); r0_emit_dec(lbl_end as u64); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
        return R0_OK
    }
    if k == R0_K_STMT_FOR {
        let iter: u32 = iii_ast_for_iter(R0_G_AST, node)
        let body: u32 = iii_ast_for_body(R0_G_AST, node)
        let off: u32 = iii_ast_for_var_off(R0_G_AST, node)
        let len: u32 = iii_ast_for_var_len(R0_G_AST, node)
        let mut s: i32 = r0_local_lookup(off, len)
        if s < 0i32 { s = r0_local_add(off, len) }
        let topid: u32 = R0_G_LABEL_COUNTER; R0_G_LABEL_COUNTER = R0_G_LABEL_COUNTER + 1u32
        let fie: u32 = r0_emit_expr(iter); if fie != R0_OK { return fie }; r0_pop_rax(); if s >= 0i32 { r0_emit_store_rax_slot(s as u32) }
        r0_emit_arr(&R0_PFX_FORTOP as u64, R0_PFX_FORTOP_LEN); r0_emit_dec(topid as u64); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
        if s >= 0i32 { r0_emit_load_slot(s as u32) }
        r0_emit_arr(&R0_STR_TESTRRAX as u64, R0_STR_TESTRRAX_LEN)
        r0_emit_arr(&R0_STR_JZ as u64, R0_STR_JZ_LEN)
        r0_emit_arr(&R0_PFX_FOREND as u64, R0_PFX_FOREND_LEN); r0_emit_dec(topid as u64); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
        let fbe: u32 = r0_emit_block(body); if fbe != R0_OK { return fbe }
        if s >= 0i32 { r0_emit_load_slot(s as u32); r0_emit_arr(&R0_STR_ADD1RAX as u64, R0_STR_ADD1RAX_LEN); r0_emit_store_rax_slot(s as u32) }
        r0_emit_arr(&R0_STR_JMP as u64, R0_STR_JMP_LEN); r0_emit_arr(&R0_PFX_FORTOP as u64, R0_PFX_FORTOP_LEN); r0_emit_dec(topid as u64); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
        r0_emit_arr(&R0_PFX_FOREND as u64, R0_PFX_FOREND_LEN); r0_emit_dec(topid as u64); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
        return R0_OK
    }
    if k == R0_K_STMT_MATCH {
        let scrut: u32 = iii_ast_match_stmt_scrutinee(R0_G_AST, node)
        let armc: u32 = iii_ast_match_stmt_arm_count(R0_G_AST, node)
        let endid: u32 = R0_G_LABEL_COUNTER; R0_G_LABEL_COUNTER = R0_G_LABEL_COUNTER + 1u32
        let se2: u32 = r0_emit_expr(scrut); if se2 != R0_OK { return se2 }; r0_pop_rax()
        let mut i: u32 = 0u32
        while i < armc { let arm: u32 = iii_ast_match_stmt_arm_at(R0_G_AST, node, i); let pat: u32 = iii_ast_match_arm_pattern(R0_G_AST, arm); r0_emit_pattern_compare(pat, endid); let body: u32 = iii_ast_match_arm_body(R0_G_AST, arm); let be: u32 = r0_emit_expr(body); if be != R0_OK { return be }; r0_pop_rax(); r0_emit_arr(&R0_STR_JMP as u64, R0_STR_JMP_LEN); r0_emit_arr(&R0_PFX_MATCHEND as u64, R0_PFX_MATCHEND_LEN); r0_emit_dec(endid as u64); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN); i = i + 1u32 }
        r0_emit_arr(&R0_PFX_MATCHEND as u64, R0_PFX_MATCHEND_LEN); r0_emit_dec(endid as u64); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
        return R0_OK
    }
    if k == R0_K_STMT_WAVEFRONT {
        let nc: u32 = iii_ast_wavefront_node_count(R0_G_AST, node)
        let mut i: u32 = 0u32
        while i < nc { let we2: u32 = r0_emit_stmt(iii_ast_wavefront_node_at(R0_G_AST, node, i)); if we2 != R0_OK { return we2 }; i = i + 1u32 }
        return R0_OK
    }
    if k == R0_K_STMT_SANCTUM_ENTER { R0_G_LAST_ERROR = R0_E_UNSUPPORTED; return R0_E_UNSUPPORTED }
    if k == R0_K_STMT_METAL {
        let idx: u32 = iii_ast_metal_asm_str_idx(R0_G_AST, node)
        let addr: u64 = iii_ast_string_payload_addr_c(R0_G_AST, idx)
        let len: u32 = iii_ast_metal_asm_len(R0_G_AST, node)
        r0_emit_bytes(addr, len as u64); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
        return R0_OK
    }
    return r0_emit_expr(node)
}

fn r0_emit_block(node: u32) -> u32 { if node == 0u32 { return R0_OK }; let k: u32 = iii_ast_node_kind(R0_G_AST, node); if k == R0_K_FORWARD_BLOCK { let n: u32 = iii_ast_forward_block_stmt_count(R0_G_AST, node); let mut i: u32 = 0u32; while i < n { let se: u32 = r0_emit_stmt(iii_ast_forward_block_stmt_at(R0_G_AST, node, i)); if se != R0_OK { return se }; i = i + 1u32 }; return R0_OK }; if k == R0_K_EXPR_BLOCK { let n: u32 = iii_ast_block_stmt_count(R0_G_AST, node); let mut i: u32 = 0u32; while i < n { let se: u32 = r0_emit_stmt(iii_ast_block_stmt_at(R0_G_AST, node, i)); if se != R0_OK { return se }; i = i + 1u32 }; return R0_OK }; return r0_emit_stmt(node) }


/* ─────────────── compute_function_attributes / select_section ─────────────── */
fn r0_compute_attrs(node: u32, kind: u32) -> u32 {
    R0_G_CUR_MAX_IRQL = 2u32; R0_G_CUR_PAGED = 0u32; R0_G_CUR_SECMEM = 0u32; R0_G_CUR_RETURNS_NTSTATUS = 1u32
    let m_paged: u32 = r0_mod_find(node, kind, &R0_MOD_PAGED as u64, R0_MOD_PAGED_LEN); if m_paged != 0u32 { R0_G_CUR_PAGED = 1u32 }
    let m_sec: u32 = r0_mod_find(node, kind, &R0_MOD_SECMEM as u64, R0_MOD_SECMEM_LEN); if m_sec != 0u32 { R0_G_CUR_SECMEM = 1u32 }
    let m_irql: u32 = r0_mod_find(node, kind, &R0_MOD_IRQL_MAX as u64, R0_MOD_IRQL_MAX_LEN); if m_irql != 0u32 { let v: u64 = r0_mod_first_int(m_irql); R0_G_CUR_MAX_IRQL = (v & 0xffu64) as u32 }
    return R0_OK
}

fn r0_emit_section_for(node: u32, kind: u32) -> u32 {
    r0_emit_arr(&R0_SEC_OPEN as u64, R0_SEC_OPEN_LEN)
    let m_entry: u32 = r0_mod_find(node, kind, &R0_MOD_ENTRY as u64, R0_MOD_ENTRY_LEN)
    if m_entry != 0u32 { r0_emit_arr(&R0_SEC_INIT as u64, R0_SEC_INIT_LEN) } else { if R0_G_CUR_PAGED != 0u32 { r0_emit_arr(&R0_SEC_PAGE as u64, R0_SEC_PAGE_LEN) } else { r0_emit_arr(&R0_SEC_DOTTEXT as u64, R0_SEC_DOTTEXT_LEN) } }
    r0_emit_arr(&R0_SEC_TAIL as u64, R0_SEC_TAIL_LEN)
    return R0_OK
}

fn r0_emit_param_sal(p: u32) -> u32 {
    let t: u32 = iii_ast_param_type(R0_G_AST, p)
    if t == 0u32 { return R0_OK }
    let mc: u32 = iii_ast_type_modifier_count(R0_G_AST, t)
    let mut i: u32 = 0u32
    while i < mc {
        let m: u32 = iii_ast_type_modifier_at(R0_G_AST, t, i)
        let no: u32 = iii_ast_modifier_name_offset(R0_G_AST, m)
        let nl: u32 = iii_ast_modifier_name_length(R0_G_AST, m)
        if r0_name_eq_lit(no, nl, &R0_MOD_SAL as u64, R0_MOD_SAL_LEN) == 1u32 {
            r0_emit_arr(&R0_CMT_SAL_OPEN as u64, R0_CMT_SAL_OPEN_LEN)
            let ac: u32 = iii_ast_modifier_arg_count(R0_G_AST, m)
            let mut j: u32 = 0u32
            while j < ac { let a: u32 = iii_ast_modifier_arg_at(R0_G_AST, m, j); let v: u32 = iii_ast_arg_value(R0_G_AST, a); let vk: u32 = iii_ast_node_kind(R0_G_AST, v); if vk == R0_K_EXPR_STR { let idx: u32 = iii_ast_str_payload_idx(R0_G_AST, v); let addr: u64 = iii_ast_string_payload_addr_c(R0_G_AST, idx); let mut k: u64 = 0u64; while iii_emit_buf_read_u8_c(addr, k) != 0u32 { k = k + 1u64 }; r0_emit_bytes(addr, k) }; j = j + 1u32; if j < ac { r0_emit_arr(&R0_STR_COMMA_SP as u64, R0_STR_COMMA_SP_LEN) } }
            r0_emit_arr(&R0_CMT_SAL_CLOSE as u64, R0_CMT_SAL_CLOSE_LEN)
        }
        i = i + 1u32
    }
    return R0_OK
}

fn r0_get_name_off(node: u32, kind: u32) -> u32 { if kind == R0_K_CYCLE_DECL { return iii_ast_cycle_name_off(R0_G_AST, node) }; if kind == R0_K_SEALED { return iii_ast_sealed_call_name_off(R0_G_AST, node) }; return iii_ast_fn_name_off(R0_G_AST, node) }
fn r0_get_name_len(node: u32, kind: u32) -> u32 { if kind == R0_K_CYCLE_DECL { return iii_ast_cycle_name_len(R0_G_AST, node) }; if kind == R0_K_SEALED { return iii_ast_sealed_call_name_len(R0_G_AST, node) }; return iii_ast_fn_name_len(R0_G_AST, node) }
fn r0_get_param_count(node: u32, kind: u32) -> u32 { if kind == R0_K_CYCLE_DECL { return iii_ast_cycle_param_count(R0_G_AST, node) }; if kind == R0_K_SEALED { return iii_ast_sealed_param_count(R0_G_AST, node) }; return iii_ast_fn_param_count(R0_G_AST, node) }
fn r0_get_param_at(node: u32, kind: u32, i: u32) -> u32 { if kind == R0_K_CYCLE_DECL { return iii_ast_cycle_param_at(R0_G_AST, node, i) }; if kind == R0_K_SEALED { return iii_ast_sealed_param_at(R0_G_AST, node, i) }; return iii_ast_fn_param_at(R0_G_AST, node, i) }
fn r0_get_body(node: u32, kind: u32) -> u32 { if kind == R0_K_CYCLE_DECL { return iii_ast_cycle_forward_block(R0_G_AST, node) }; if kind == R0_K_SEALED { return iii_ast_sealed_body(R0_G_AST, node) }; return iii_ast_fn_body(R0_G_AST, node) }

/* ─────────────── emit_function ─────────────── */
fn r0_emit_function(node: u32, kind: u32) -> u32 {
    R0_G_LOCAL_COUNT = 0u32; R0_G_STACK_DEPTH = 0u32; R0_G_FRAME_BYTES = 1024u32; R0_G_EMITTED_RETURN = 0u32
    /* NOTE: R0_G_LABEL_COUNTER is module-global (monotonic across functions), NOT reset here.
       Resetting per-function made every function restart at L_if_end_0/L_for_top_0 etc., so
       once functions contained if/while/match/for the labels collided (duplicate symbol at
       assemble). Mirrors cg_r3, which resets the counter once in create. */
    r0_compute_attrs(node, kind)
    let name_off: u32 = r0_get_name_off(node, kind)
    let name_len: u32 = r0_get_name_len(node, kind)
    let pc: u32 = r0_get_param_count(node, kind)
    let body: u32 = r0_get_body(node, kind)
    let m_entry: u32 = r0_mod_find(node, kind, &R0_MOD_ENTRY as u64, R0_MOD_ENTRY_LEN)
    let mut is_driver_entry: u32 = 0u32
    if m_entry != 0u32 { is_driver_entry = 1u32 } else { is_driver_entry = r0_name_eq_lit(name_off, name_len, &R0_NAME_DRIVER_ENTRY as u64, R0_NAME_DRIVER_ENTRY_LEN) }
    if is_driver_entry == 1u32 { R0_G_HAS_DRIVER_ENTRY = 1u32 }
    if is_driver_entry == 1u32 { if pc != 2u32 { r0_emit_arr(&R0_STR_SIG_MISMATCH as u64, R0_STR_SIG_MISMATCH_LEN); R0_G_LAST_ERROR = R0_E_SIG_MISMATCH; return R0_E_SIG_MISMATCH } }
    r0_emit_section_for(node, kind)
    r0_emit_arr(&R0_CMT_IRQL_OPEN as u64, R0_CMT_IRQL_OPEN_LEN); r0_emit_dec(R0_G_CUR_MAX_IRQL as u64); r0_emit_arr(&R0_CMT_IRQL_CLOSE as u64, R0_CMT_IRQL_CLOSE_LEN)
    let mut pi: u32 = 0u32
    while pi < pc { let p: u32 = r0_get_param_at(node, kind, pi); r0_emit_param_sal(p); pi = pi + 1u32 }
    r0_emit_arr(&R0_STR_GLOBAL as u64, R0_STR_GLOBAL_LEN); r0_emit_decl_label(name_off, name_len); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
    if is_driver_entry == 1u32 { r0_emit_arr(&R0_STR_GLOBAL as u64, R0_STR_GLOBAL_LEN); r0_emit_arr(&R0_STR_DRIVER_NL as u64, R0_STR_DRIVER_NL_LEN) }
    r0_emit_decl_label(name_off, name_len); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
    if is_driver_entry == 1u32 { r0_emit_arr(&R0_STR_DRIVER_COL as u64, R0_STR_DRIVER_COL_LEN) }
    r0_emit_arr(&R0_STR_SEH_PROC as u64, R0_STR_SEH_PROC_LEN); r0_emit_decl_label(name_off, name_len); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
    r0_emit_arr(&R0_STR_PUSHRBP as u64, R0_STR_PUSHRBP_LEN)
    r0_emit_arr(&R0_STR_SEH_PUSHRBP as u64, R0_STR_SEH_PUSHRBP_LEN)
    r0_emit_arr(&R0_STR_MOVRSPRBP as u64, R0_STR_MOVRSPRBP_LEN)
    r0_emit_arr(&R0_STR_SUBRSP as u64, R0_STR_SUBRSP_LEN); r0_emit_dec(R0_G_FRAME_BYTES as u64); r0_emit_arr(&R0_STR_RSP_NL as u64, R0_STR_RSP_NL_LEN)
    r0_emit_arr(&R0_STR_SEH_STKALLOC as u64, R0_STR_SEH_STKALLOC_LEN)
    r0_emit_arr(&R0_STR_SEH_ENDPRO as u64, R0_STR_SEH_ENDPRO_LEN)
    if R0_G_CUR_SECMEM != 0u32 { r0_emit_arr(&R0_CMT_D14_SEC_ENT as u64, R0_CMT_D14_SEC_ENT_LEN) }
    /* BUG-1 fix: spill MS x64 first 4 params to slots BEFORE the witness ENTER call.
       The witness ENTER sets %rcx = IIIW_ENTER and the call may clobber volatiles, so
       rcx/rdx/r8/r9 (the parameters) MUST be saved to their frame slots first. */
    let mut spi: u32 = 0u32
    let mut pmax: u32 = pc
    if pc > 4u32 { pmax = 4u32 }
    while spi < pmax {
        let p: u32 = r0_get_param_at(node, kind, spi)
        let off: u32 = iii_ast_param_name_off(R0_G_AST, p)
        let len: u32 = iii_ast_param_name_len(R0_G_AST, p)
        let s: i32 = r0_local_add(off, len)
        if s >= 0i32 {
            r0_emit_arr(&R0_STR_MOVQ_PCT as u64, R0_STR_MOVQ_PCT_LEN)
            if spi == 0u32 { r0_emit_arr(&R0_REG_RCX as u64, R0_REG_RCX_LEN) }
            if spi == 1u32 { r0_emit_arr(&R0_REG_RDX as u64, R0_REG_RDX_LEN) }
            if spi == 2u32 { r0_emit_arr(&R0_REG_R8 as u64, R0_REG_R8_LEN) }
            if spi == 3u32 { r0_emit_arr(&R0_REG_R9 as u64, R0_REG_R9_LEN) }
            r0_emit_arr(&R0_STR_COMMA_DASH as u64, R0_STR_COMMA_DASH_LEN)
            r0_emit_dec((((s as u32)+1u32)*8u32) as u64)
            r0_emit_arr(&R0_STR_RBP_NL as u64, R0_STR_RBP_NL_LEN)
        }
        spi = spi + 1u32
    }
    r0_emit_arr(&R0_CMT_WIT_ENTER as u64, R0_CMT_WIT_ENTER_LEN)
    r0_emit_arr(&R0_STR_WIT_RCX_ENT as u64, R0_STR_WIT_RCX_ENT_LEN)
    r0_emit_arr(&R0_STR_WIT_SUB32 as u64, R0_STR_WIT_SUB32_LEN)
    r0_emit_arr(&R0_STR_WIT_CALL as u64, R0_STR_WIT_CALL_LEN)
    r0_emit_arr(&R0_STR_WIT_ADD32 as u64, R0_STR_WIT_ADD32_LEN)
    let body_e: u32 = r0_emit_block(body)
    if body_e != R0_OK { R0_G_LAST_ERROR = body_e; return body_e }
    if R0_G_EMITTED_RETURN == 0u32 {
        r0_emit_arr(&R0_CMT_D7_FALL as u64, R0_CMT_D7_FALL_LEN)
        r0_emit_arr(&R0_STR_MOVABS0 as u64, R0_STR_MOVABS0_LEN)
        if R0_G_CUR_SECMEM != 0u32 { r0_emit_arr(&R0_CMT_D14_SEC_EXIT as u64, R0_CMT_D14_SEC_EXIT_LEN) }
        /* BUG-2 fix: TWO pushes keep %rsp 16-byte aligned across the witness EXIT call. */
        r0_emit_arr(&R0_STR_WIT_PUSHRAX as u64, R0_STR_WIT_PUSHRAX_LEN)
        r0_emit_arr(&R0_STR_WIT_PUSHRAX as u64, R0_STR_WIT_PUSHRAX_LEN)
        r0_emit_arr(&R0_STR_WIT_RCX_EXT as u64, R0_STR_WIT_RCX_EXT_LEN)
        r0_emit_arr(&R0_STR_WIT_SUB32 as u64, R0_STR_WIT_SUB32_LEN)
        r0_emit_arr(&R0_STR_WIT_CALL as u64, R0_STR_WIT_CALL_LEN)
        r0_emit_arr(&R0_STR_WIT_ADD32 as u64, R0_STR_WIT_ADD32_LEN)
        r0_emit_arr(&R0_STR_WIT_POPRAX as u64, R0_STR_WIT_POPRAX_LEN)
        r0_emit_arr(&R0_STR_WIT_POPRAX as u64, R0_STR_WIT_POPRAX_LEN)
        r0_emit_arr(&R0_STR_EPILOGUE as u64, R0_STR_EPILOGUE_LEN)
    }
    r0_emit_arr(&R0_STR_SEH_ENDPROC as u64, R0_STR_SEH_ENDPROC_LEN)
    return R0_OK
}

/* ─────────────── IRP dispatch table ─────────────── */
fn r0_record_irp_handler(node: u32, kind: u32) -> u32 {
    let m: u32 = r0_mod_find(node, kind, &R0_MOD_IRP_HANDLER as u64, R0_MOD_IRP_HANDLER_LEN)
    if m == 0u32 { return R0_OK }
    let mj: i32 = r0_mod_first_ident_irp(m)
    if mj < 0i32 { return R0_OK }
    if (mj as u32) >= R0_MAX_IRP { return R0_OK }
    let idx: u32 = mj as u32
    if R0_IRP_HANDLER_VALID[idx] != 0u32 { R0_G_LAST_ERROR = R0_E_IRP_DUP; return R0_E_IRP_DUP }
    R0_IRP_HANDLER_NODE[idx] = node
    R0_IRP_HANDLER_DECL_OFF[idx] = r0_get_name_off(node, kind)
    R0_IRP_HANDLER_DECL_LEN[idx] = r0_get_name_len(node, kind)
    R0_IRP_HANDLER_VALID[idx] = 1u32
    return R0_OK
}

fn r0_emit_irp_dispatch_table() -> u32 {
    r0_emit_arr(&R0_SEC_IRP_DR as u64, R0_SEC_IRP_DR_LEN)
    r0_emit_arr(&R0_STR_GLOBAL as u64, R0_STR_GLOBAL_LEN); r0_emit_arr(&R0_SYM_IRPTBL as u64, R0_SYM_IRPTBL_LEN); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
    r0_emit_arr(&R0_SYM_IRPTBL_LBL as u64, R0_SYM_IRPTBL_LBL_LEN)
    let mut i: u32 = 0u32
    while i < R0_MAX_IRP {
        if R0_IRP_HANDLER_VALID[i] != 0u32 {
            r0_emit_arr(&R0_STR_QUAD as u64, R0_STR_QUAD_LEN)
            r0_emit_decl_label(R0_IRP_HANDLER_DECL_OFF[i], R0_IRP_HANDLER_DECL_LEN[i])
            r0_emit_arr(&R0_STR_IRP_TAIL_OPEN as u64, R0_STR_IRP_TAIL_OPEN_LEN)
            r0_emit_hex(i as u64)
            r0_emit_arr(&R0_STR_IRP_TAIL as u64, R0_STR_IRP_TAIL_LEN)
        } else {
            r0_emit_arr(&R0_STR_QUAD_NOIMP as u64, R0_STR_QUAD_NOIMP_LEN)
            r0_emit_hex(i as u64)
            r0_emit_arr(&R0_STR_IRP_TAIL as u64, R0_STR_IRP_TAIL_LEN)
        }
        i = i + 1u32
    }
    r0_emit_arr(&R0_SEC_TEXT as u64, R0_SEC_TEXT_LEN)
    r0_emit_arr(&R0_SYM_IRP_NOIMP_WD as u64, R0_SYM_IRP_NOIMP_WD_LEN)
    r0_emit_arr(&R0_SYM_IRP_NOIMP_LBL as u64, R0_SYM_IRP_NOIMP_LBL_LEN)
    r0_emit_arr(&R0_STR_NOIMP_BODY as u64, R0_STR_NOIMP_BODY_LEN)
    return R0_OK
}

/* ─────────────── string pool emission (pass over all string payloads) ─────────────── */
fn r0_emit_string_pool() -> u32 {
    let n: u32 = iii_ast_string_payload_count_c(R0_G_AST)
    if n == 0u32 { return R0_OK }
    r0_emit_arr(&R0_SEC_RDATA_DR as u64, R0_SEC_RDATA_DR_LEN)
    let mut i: u32 = 0u32
    while i < n {
        let addr: u64 = iii_ast_string_payload_addr_c(R0_G_AST, i)
        if addr != 0u64 {
            r0_emit_str_label(i); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
            r0_emit_arr(&R0_STR_ASCII_OPEN as u64, R0_STR_ASCII_OPEN_LEN)
            let mut k: u64 = 0u64
            while iii_emit_buf_read_u8_c(addr, k) != 0u32 {
                let b: u32 = iii_emit_buf_read_u8_c(addr, k)
                if b == 34u32 { r0_emit_arr(&R0_STR_BACKSLASH as u64, R0_STR_BACKSLASH_LEN); r0_emit_ch(34u32) } else { if b == 92u32 { r0_emit_arr(&R0_STR_BACKSLASH as u64, R0_STR_BACKSLASH_LEN); r0_emit_ch(92u32) } else { if b == 10u32 { r0_emit_arr(&R0_STR_BACKSLASH_N as u64, R0_STR_BACKSLASH_N_LEN) } else { r0_emit_ch(b) } } }
                k = k + 1u64
            }
            r0_emit_arr(&R0_STR_ASCII_CLOSE as u64, R0_STR_ASCII_CLOSE_LEN)
        }
        i = i + 1u32
    }
    return R0_OK
}

/* ─────────────── public exports ─────────────── */
fn iii_cg_r0_create(ast: u64, sema: u64, sid: u64, walloc: u64) -> u64 @export { if ast == 0u64 { return 0u64 }; R0_G_AST = ast; R0_G_SEMA = sema; R0_G_SID = sid; R0_G_WALLOC = walloc; R0_G_OUT = 0u64; R0_G_SEALED = 0u32; R0_G_LAST_ERROR = R0_OK; R0_G_LOCAL_COUNT = 0u32; R0_G_STACK_DEPTH = 0u32; R0_G_LABEL_COUNTER = 0u32; let mut i: u32 = 0u32; while i < R0_MAX_IRP { R0_IRP_HANDLER_VALID[i] = 0u32; R0_IRP_HANDLER_NODE[i] = 0u32; R0_IRP_HANDLER_DECL_OFF[i] = 0u32; R0_IRP_HANDLER_DECL_LEN[i] = 0u32; i = i + 1u32 }; iii_cg_r0_sha_init_c(); return &R0_SENTINEL as u64 }

fn iii_cg_r0_destroy(cg: u64) @export { R0_G_AST = 0u64; R0_G_SEMA = 0u64; R0_G_SID = 0u64; R0_G_WALLOC = 0u64; R0_G_OUT = 0u64; R0_G_SEALED = 0u32; return }

/* Tier-2 Inc-1: module-level data emission (GAP-5; mirrors cg_r3 r3_emit_data_decls).
   cg_r0 is 8-byte-uniform (indexing is *8, BSS reserves count*8), so all data is
   emitted as .quad (8-byte slots) / .zero count*8 -- NOT width-packed like cg_r3. */
fn r0_lit_u64_compute(node: u32) -> u32 {
    R0_LIT_VALUE = 0u64
    if node == 0u32 { return 0u32 }
    let k: u32 = iii_ast_node_kind(R0_G_AST, node)
    if k == R0_K_EXPR_INT { R0_LIT_VALUE = iii_ast_expr_int_u64(R0_G_AST, node); return 1u32 }
    if k == R0_K_EXPR_HEX { let lo: u64 = iii_ast_hex_value_lo(R0_G_AST, node) as u64; let hi: u64 = iii_ast_hex_value_hi(R0_G_AST, node) as u64; R0_LIT_VALUE = lo | (hi << 32u64); return 1u32 }
    if k == R0_K_EXPR_UNARY {
        let op: u32 = iii_ast_unary_op(R0_G_AST, node)
        if op == 1u32 {
            let inner: u32 = iii_ast_unary_operand(R0_G_AST, node)
            let ik: u32 = iii_ast_node_kind(R0_G_AST, inner)
            if ik == R0_K_EXPR_INT { let b: u64 = iii_ast_expr_int_u64(R0_G_AST, inner); R0_LIT_VALUE = 0u64 - b; return 1u32 }
            if ik == R0_K_EXPR_HEX { let lo2: u64 = iii_ast_hex_value_lo(R0_G_AST, inner) as u64; let hi2: u64 = iii_ast_hex_value_hi(R0_G_AST, inner) as u64; let bb: u64 = lo2 | (hi2 << 32u64); R0_LIT_VALUE = 0u64 - bb; return 1u32 }
        }
    }
    return 0u32
}
fn r0_emit_global_decl_label(off: u32, len: u32) -> u32 {
    r0_emit_arr(&R0_STR_GLOBAL as u64, R0_STR_GLOBAL_LEN); r0_emit_decl_label(off, len); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
    r0_emit_decl_label(off, len); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
    return R0_OK
}
fn r0_emit_local_decl_label(off: u32, len: u32) -> u32 {
    r0_emit_decl_label(off, len); r0_emit_arr(&R0_STR_COLONNL as u64, R0_STR_COLONNL_LEN)
    return R0_OK
}
fn r0_emit_data_decls() -> u32 {
    let root: u32 = iii_ast_root_module(R0_G_AST); if root == 0u32 { return R0_OK }
    let dc: u32 = iii_ast_module_decl_count(R0_G_AST, root)
    let mut current_section: u32 = 0u32
    let mut i: u32 = 0u32
    while i < dc {
        let d: u32 = iii_ast_module_decl_at(R0_G_AST, root, i)
        let dk: u32 = iii_ast_node_kind(R0_G_AST, d)
        if dk == R0_K_CONST_DECL {
            let v: u32 = iii_ast_const_decl_value(R0_G_AST, d)
            let vk: u32 = iii_ast_node_kind(R0_G_AST, v)
            let no: u32 = iii_ast_const_decl_name_off(R0_G_AST, d)
            let nl: u32 = iii_ast_const_decl_name_len(R0_G_AST, d)
            if vk == R0_K_EXPR_PARALLEL {
                if current_section != 1u32 { r0_emit_arr(&R0_SEC_RODATA as u64, R0_SEC_RODATA_LEN); current_section = 1u32 }
                r0_emit_local_decl_label(no, nl)
                let bc: u32 = iii_ast_parallel_branch_count(R0_G_AST, v)
                let mut k: u32 = 0u32
                while k < bc { let eid: u32 = iii_ast_parallel_branch_at(R0_G_AST, v, k); r0_lit_u64_compute(eid); r0_emit_arr(&R0_STR_QUAD0X as u64, R0_STR_QUAD0X_LEN); r0_emit_hex(R0_LIT_VALUE); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN); k = k + 1u32 }
            } else {
                let okv: u32 = r0_lit_u64_compute(v)
                if okv == 1u32 {
                    if current_section != 1u32 { r0_emit_arr(&R0_SEC_RODATA as u64, R0_SEC_RODATA_LEN); current_section = 1u32 }
                    r0_emit_local_decl_label(no, nl)
                    r0_emit_arr(&R0_STR_QUAD0X as u64, R0_STR_QUAD0X_LEN); r0_emit_hex(R0_LIT_VALUE); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
                }
            }
        }
        if dk == R0_K_VAR_DECL {
            let vno: u32 = iii_ast_var_decl_name_off(R0_G_AST, d)
            let vnl: u32 = iii_ast_var_decl_name_len(R0_G_AST, d)
            let init: u32 = iii_ast_var_decl_init(R0_G_AST, d)
            let vt: u32 = iii_ast_var_decl_type(R0_G_AST, d)
            let mut handled: u32 = 0u32
            if init != 0u32 {
                let ik: u32 = iii_ast_node_kind(R0_G_AST, init)
                if ik == R0_K_EXPR_PARALLEL {
                    if current_section != 2u32 { r0_emit_arr(&R0_SEC_DATA as u64, R0_SEC_DATA_LEN); current_section = 2u32 }
                    r0_emit_global_decl_label(vno, vnl)
                    let bc2: u32 = iii_ast_parallel_branch_count(R0_G_AST, init)
                    let mut k2: u32 = 0u32
                    while k2 < bc2 { let eid2: u32 = iii_ast_parallel_branch_at(R0_G_AST, init, k2); r0_lit_u64_compute(eid2); r0_emit_arr(&R0_STR_QUAD0X as u64, R0_STR_QUAD0X_LEN); r0_emit_hex(R0_LIT_VALUE); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN); k2 = k2 + 1u32 }
                    handled = 1u32
                } else {
                    let okv2: u32 = r0_lit_u64_compute(init)
                    if okv2 == 1u32 {
                        if current_section != 2u32 { r0_emit_arr(&R0_SEC_DATA as u64, R0_SEC_DATA_LEN); current_section = 2u32 }
                        r0_emit_global_decl_label(vno, vnl)
                        r0_emit_arr(&R0_STR_QUAD0X as u64, R0_STR_QUAD0X_LEN); r0_emit_hex(R0_LIT_VALUE); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
                        handled = 1u32
                    }
                }
            }
            if handled == 0u32 {
                let mut bs: u64 = 8u64
                if vt != 0u32 { let tk: u32 = iii_ast_node_kind(R0_G_AST, vt); if tk == R0_K_TYPE_ARR { bs = iii_ast_type_array_count(R0_G_AST, vt) * 8u64 } }
                if current_section != 3u32 { r0_emit_arr(&R0_SEC_BSS as u64, R0_SEC_BSS_LEN); current_section = 3u32 }
                r0_emit_global_decl_label(vno, vnl)
                r0_emit_arr(&R0_STR_ZERO_PFX as u64, R0_STR_ZERO_PFX_LEN); r0_emit_dec(bs); r0_emit_arr(&R0_STR_NL as u64, R0_STR_NL_LEN)
            }
        }
        i = i + 1u32
    }
    return R0_OK
}

/* Tier-2 Inc-2: emit the IRP dispatch table only for a real driver module (one with
   @irp_handler cycles). A pure logic module must NOT emit it -- otherwise every linked
   cg_r0 .o defines `_iii_IrpDispatchTable` and the link fails (multiple definition). */
fn r0_any_irp_handler() -> u32 { let mut i: u32 = 0u32; while i < R0_MAX_IRP { if R0_IRP_HANDLER_VALID[i] != 0u32 { return 1u32 }; i = i + 1u32 }; return 0u32 }

fn iii_cg_r0_emit_module(cg: u64, out: u64) -> u32 @export {
    if cg == 0u64 { return R0_E_NULL_ARG }
    if out == 0u64 { R0_G_LAST_ERROR = R0_E_NULL_ARG; return R0_E_NULL_ARG }
    if R0_G_SEALED != 0u32 { R0_G_LAST_ERROR = R0_E_SEALED; return R0_E_SEALED }
    R0_G_OUT = out
    R0_G_HAS_DRIVER_ENTRY = 0u32
    R0_G_LABEL_COUNTER = 0u32
    r0_emit_arr(&R0_STR_HDR1 as u64, R0_STR_HDR1_LEN)
    r0_emit_arr(&R0_STR_HDR2 as u64, R0_STR_HDR2_LEN)
    r0_emit_arr(&R0_STR_ATTSYNTAX as u64, R0_STR_ATTSYNTAX_LEN)
    r0_emit_string_pool()
    r0_emit_data_decls()
    let root: u32 = iii_ast_root_module(R0_G_AST)
    if root == 0u32 { R0_G_LAST_ERROR = R0_E_INTERNAL; return R0_E_INTERNAL }
    let dc: u32 = iii_ast_module_decl_count(R0_G_AST, root)
    /* pass 1: harvest IRP handlers */
    let mut i: u32 = 0u32
    while i < dc {
        let d: u32 = iii_ast_module_decl_at(R0_G_AST, root, i)
        let dk: u32 = iii_ast_node_kind(R0_G_AST, d)
        if dk == R0_K_FN_DECL { r0_record_irp_handler(d, dk) }
        if dk == R0_K_CYCLE_DECL { r0_record_irp_handler(d, dk) }
        i = i + 1u32
    }
    /* pass 2: emit functions (R0-eligible only) */
    let mut j: u32 = 0u32
    while j < dc {
        let d: u32 = iii_ast_module_decl_at(R0_G_AST, root, j)
        let dk: u32 = iii_ast_node_kind(R0_G_AST, d)
        if dk == R0_K_FN_DECL { if r0_ring_ok(d, dk) == 1u32 { let e: u32 = r0_emit_function(d, dk); if e != R0_OK { return e } } }
        if dk == R0_K_CYCLE_DECL { if r0_ring_ok(d, dk) == 1u32 { let e2: u32 = r0_emit_function(d, dk); if e2 != R0_OK { return e2 } } }
        if dk == R0_K_SEALED { if r0_ring_ok(d, dk) == 1u32 { let e3: u32 = r0_emit_function(d, dk); if e3 != R0_OK { return e3 } } }
        j = j + 1u32
    }
    /* Emit the IRP dispatch table for a real driver module (driver_entry present) OR a
       module with @irp_handler cycles. The driver's table (.quad symbol refs) also gives
       the .sys its base relocations (.reloc), making it a standard relocatable kernel image.
       Pure logic modules emit no table -> no duplicate _iii_IrpDispatchTable at link. */
    if R0_G_HAS_DRIVER_ENTRY == 1u32 { r0_emit_irp_dispatch_table() }
    if R0_G_HAS_DRIVER_ENTRY == 0u32 { if r0_any_irp_handler() == 1u32 { r0_emit_irp_dispatch_table() } }
    iii_cg_r0_sha_snapshot_c(&R0_MHASH_CACHE as u64)
    return R0_OK
}

fn iii_cg_r0_get_witness(cg: u64, out32: u64) -> u32 @export { if cg == 0u64 { return R0_E_NULL_ARG }; if out32 == 0u64 { return R0_E_NULL_ARG }; iii_emit_memcpy_c(out32, &R0_MHASH_CACHE as u64, 32u64); return R0_OK }

fn iii_cg_r0_last_error(cg: u64) -> u32 @export { if cg == 0u64 { return R0_E_NULL_ARG }; return R0_G_LAST_ERROR }

fn iii_cg_r0_error_name(code: u32) -> u64 @export {
    if code == R0_OK { return &R0_ENAME_OK as u64 }
    if code == R0_E_NULL_ARG { return &R0_ENAME_NULL_ARG as u64 }
    if code == R0_E_IO { return &R0_ENAME_IO as u64 }
    if code == R0_E_UNSUPPORTED { return &R0_ENAME_UNSUPPORTED as u64 }
    if code == R0_E_SIG_MISMATCH { return &R0_ENAME_SIG_MISMATCH as u64 }
    if code == R0_E_IRP_DUP { return &R0_ENAME_IRP_DUP as u64 }
    if code == R0_E_IRQL_VIOLATION { return &R0_ENAME_IRQL_VIOLATION as u64 }
    if code == R0_E_RING_WALL { return &R0_ENAME_RING_WALL as u64 }
    if code == R0_E_RETURN_DISCIPLINE { return &R0_ENAME_RETURN_DISCIPLINE as u64 }
    if code == R0_E_STACK_OVER { return &R0_ENAME_STACK_OVER as u64 }
    if code == R0_E_INTERNAL { return &R0_ENAME_INTERNAL as u64 }
    return &R0_ENAME_UNKNOWN as u64
}
