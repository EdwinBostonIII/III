module rmain
extern @abi(c-msvc-x64) fn sha256_oneshot(msg: *u8, len: u64, out: *u8) -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn r0_sha_w0(len: u64) -> u32 from "rprobe.iii"
var MBUF : [u8; 140]
var MOUT : [u8; 32]
var LENS : [u64; 12] = [0u64, 1u64, 3u64, 55u64, 56u64, 63u64, 64u64, 65u64, 100u64, 119u64, 128u64, 135u64]
fn sw_w0(len: u64) -> u32 {
    let mut i : u64 = 0u64
    while i < len { MBUF[i] = ((i * 131u64 + 7u64) & 0xFFu64) as u8  i = i + 1u64 }
    sha256_oneshot((&MBUF as u64) as *u8, len, (&MOUT as u64) as *u8)
    return ((MOUT[0u64] as u32) << 24u32) | ((MOUT[1u64] as u32) << 16u32) | ((MOUT[2u64] as u32) << 8u32) | (MOUT[3u64] as u32)
}
fn main() -> u64 {
    let mut t : u64 = 0u64
    while t < 12u64 {
        let len : u64 = LENS[t]
        let sw : u32 = sw_w0(len)
        let r0 : u32 = r0_sha_w0(len)
        if sw != r0 { return 100u64 + len }
        t = t + 1u64
    }
    return 99u64
}
