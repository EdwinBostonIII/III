const R3_STR_CALLQ_KCHAIN_CUR_LEN : u64 = 25u64

/* ── Instruction fragments ── */
var R3_STR_MOVQ_RAX_RCX : [u8; 20] = [32u8, 32u8, 32u8, 32u8, 109u8, 111u8, 118u8, 113u8, 32u8, 37u8, 114u8, 97u8, 120u8, 44u8, 32u8, 37u8, 114u8, 99u8, 120u8, 10u8]
const R3_STR_MOVQ_RAX_RCX_LEN : u64 = 20u64

var R3_STR_TESTB_AL_AL : [u8; 19] = [32u8, 32u8, 32u8, 32u8, 116u8, 101u8, 115u8, 116u8, 98u8, 32u8, 37u8, 97u8, 108u8, 44u8, 32u8, 37u8, 97u8, 108u8, 10u8]
const R3_STR_TESTB_AL_AL_LEN : u64 = 19u64

var R3_STR_MOVZBQ_AL_RCX : [u8; 21] = [32u8, 32u8, 32u8, 32u8, 109u8, 111u8, 118u8, 122u8, 98u8, 113u8, 32u8, 37u8, 97u8, 108u8, 44u8, 32u8, 37u8, 114u8, 99u8, 120u8, 10u8]
const R3_STR_MOVZBQ_AL_RCX_LEN : u64 = 21u64

var R3_STR_MOVQ_SENTINEL_RAX : [u8; 35] = [32u8, 32u8, 32u8, 32u8, 109u8, 111u8, 118u8, 113u8, 32u8, 36u8, 48u8, 120u8, 70u8, 70u8, 70u8, 70u8, 70u8, 70u8, 70u8, 70u8, 70u8, 70u8, 70u8, 70u8, 70u8, 70u8, 70u8, 70u8, 44u8, 32u8, 37u8, 114u8, 97u8, 120u8, 10u8]
const R3_STR_MOVQ_SENTINEL_RAX_LEN : u64 = 35u64

