extern @abi(c-msvc-x64) fn iii_ast_const_decl_name_off(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_const_decl_name_len(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_const_decl_type(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_const_decl_value(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_var_decl_name_off(ast: u64, node: u32) -> u32 from "sema_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_var_decl_name_len(ast: u64, node: u32) -> u32 from "sema_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_sizeof_target_type(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_sizeof_resolved(ast: u64, node: u32) -> u64 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_cast_value(ast: u64, node: u32) -> u32 from "sema_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_cast_target_type(ast: u64, node: u32) -> u32 from "sema_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_var_decl_type(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_var_decl_init(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_parallel_branch_count(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_parallel_branch_at(ast: u64, node: u32, i: u32) -> u32 from "ast_accessors.c"

fn r3_get_name_off(node: u32, kind: u32) -> u32 { if kind == R3_K_CYCLE_DECL { return iii_ast_cycle_name_off(R3_G_AST, node) }; return iii_ast_fn_name_off(R3_G_AST, node) }
fn r3_get_name_len(node: u32, kind: u32) -> u32 { if kind == R3_K_CYCLE_DECL { return iii_ast_cycle_name_len(R3_G_AST, node) }; return iii_ast_fn_name_len(R3_G_AST, node) }
fn r3_get_param_count(node: u32, kind: u32) -> u32 { if kind == R3_K_CYCLE_DECL { return iii_ast_cycle_param_count(R3_G_AST, node) }; return iii_ast_fn_param_count(R3_G_AST, node) }
fn r3_get_param_at(node: u32, kind: u32, i: u32) -> u32 { if kind == R3_K_CYCLE_DECL { return iii_ast_cycle_param_at(R3_G_AST, node, i) }; return iii_ast_fn_param_at(R3_G_AST, node, i) }
fn r3_get_body(node: u32, kind: u32) -> u32 { if kind == R3_K_CYCLE_DECL { return iii_ast_cycle_forward_block(R3_G_AST, node) }; return iii_ast_fn_body(R3_G_AST, node) }

fn r3_emit_expr(node: u32) -> u32 {
    if node == 0u32 { return R3_OK }
    let k: u32 = iii_ast_node_kind(R3_G_AST, node)
    if k == R3_K_EXPR_INT { r3_emit_movabs_rax(iii_ast_expr_int_u64(R3_G_AST, node)); r3_push_rax(); return R3_OK }
    if k == R3_K_EXPR_HEX { let lo: u64 = iii_ast_hex_value_lo(R3_G_AST, node) as u64; let hi: u64 = iii_ast_hex_value_hi(R3_G_AST, node) as u64; r3_emit_movabs_rax(lo | (hi << 32u64)); r3_push_rax(); return R3_OK }
    if k == R3_K_EXPR_BOOL { if iii_ast_bool_value(R3_G_AST, node) != 0u32 { r3_emit_arr(&R3_STR_DOL1RAX as u64, R3_STR_DOL1RAX_LEN) } else { r3_emit_arr(&R3_STR_DOL0RAX as u64, R3_STR_DOL0RAX_LEN) }; r3_push_rax(); return R3_OK }
    if k == R3_K_EXPR_TRIT { r3_emit_arr(&R3_STR_MOVQ_PFX as u64, R3_STR_MOVQ_PFX_LEN); r3_emit_ch(36u32); r3_emit_dec(iii_ast_expr_trit_value(R3_G_AST, node) as u64); r3_emit_arr(&R3_STR_COMMA_RAX_NL as u64, R3_STR_COMMA_RAX_NL_LEN); r3_push_rax(); return R3_OK }
    if k == R3_K_EXPR_UNIT { r3_emit_arr(&R3_STR_DOL0RAX as u64, R3_STR_DOL0RAX_LEN); r3_push_rax(); return R3_OK }
    if k == R3_K_EXPR_HEXAD { r3_emit_movabs_rax(r3_pack_hexad_expr(node)); r3_push_rax(); return R3_OK }
    if k == R3_K_EXPR_STR { let idx: u32 = iii_ast_str_payload_idx(R3_G_AST, node); r3_emit_arr(&R3_STR_LEAQ as u64, R3_STR_LEAQ_LEN); r3_emit_str_label(idx); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN); r3_push_rax(); return R3_OK }
    if k == R3_K_EXPR_MHASH { r3_emit_arr(&R3_STR_LEAQ as u64, R3_STR_LEAQ_LEN); r3_emit_mhash_label(node); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN); r3_push_rax(); return R3_OK }
    if k == R3_K_EXPR_PAREN { return r3_emit_expr(iii_ast_paren_inner(R3_G_AST, node)) }
    if k == R3_K_EXPR_BLOCK { return r3_emit_block(node) }
    if k == R3_K_EXPR_IDENT {
        let off: u32 = iii_ast_ident_name_offset(R3_G_AST, node)
        let len: u32 = iii_ast_ident_name_length(R3_G_AST, node)
        let s: u32 = r3_local_lookup(off, len)
        if s != 4294967295u32 {
            r3_emit_local_load_width_aware(node, s)
            r3_push_rax()
            return R3_OK
        }
        return r3_emit_global_ident(node, off, len)
    }
    if k == R3_K_EXPR_UNARY {
        let op: u32 = iii_ast_unary_op(R3_G_AST, node)
        let inner: u32 = iii_ast_unary_operand(R3_G_AST, node)
        if op == 5u32 {
            /* op==5 (ADDR): mirror cg_r3.c:1305-1402 special-case dispatch. */
            let ik2: u32 = iii_ast_node_kind(R3_G_AST, inner)
            if ik2 == R3_K_EXPR_IDENT {
                let aoff: u32 = iii_ast_ident_name_offset(R3_G_AST, inner)
                let alen: u32 = iii_ast_ident_name_length(R3_G_AST, inner)
                let aslot: u32 = r3_local_lookup(aoff, alen)
                if aslot != 4294967295u32 {
                    /* ADDR-of-IDENT-local: leaq -N(%rbp), %rax + push. */
                    r3_emit_arr(&R3_STR_LEAQ_DASH as u64, R3_STR_LEAQ_DASH_LEN); r3_emit_dec(((aslot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN)
                    r3_push_rax(); return R3_OK
                }
                /* ADDR-of-IDENT-global: leaq <sym>(%rip), %rax + push.
                 * Symbol form depends on binder kind: raw for EXTERN_DECL
                 * or @export FN_DECL, otherwise L_ prefixed.  Mirrors
                 * cg_r3.c:1319-1331. */
                let raw: u32 = r3_addr_is_raw_sym(inner)
                r3_emit_arr(&R3_STR_LEAQ as u64, R3_STR_LEAQ_LEN)
                if raw == 1u32 { r3_emit_sym_run(aoff, alen) } else { r3_emit_decl_label(aoff, alen) }
                r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN)
                r3_push_rax(); return R3_OK
            }
            /* ADDR-of-INDEX (`&arr[i]`): compute base+scaled index, leave
             * address on TOS.  Mirrors cg_r3.c:1341-1395 byte_index-aware
             * leaq path.  Only scales 1 (byte) and 8 (default) emitted. */
            if ik2 == R3_K_EXPR_INDEX {
                let iobj: u32 = iii_ast_index_object(R3_G_AST, inner)
                let iidx: u32 = iii_ast_index_index(R3_G_AST, inner)
                let bb: u32 = r3_index_obj_is_byte(iobj)
                let iok: u32 = iii_ast_node_kind(R3_G_AST, iobj)
                if iok == R3_K_EXPR_IDENT {
                    let ioff: u32 = iii_ast_ident_name_offset(R3_G_AST, iobj)
                    let ilen: u32 = iii_ast_ident_name_length(R3_G_AST, iobj)
                    let islot: u32 = r3_local_lookup(ioff, ilen)
                    if islot != 4294967295u32 {
                        r3_emit_arr(&R3_STR_LEAQ_DASH as u64, R3_STR_LEAQ_DASH_LEN); r3_emit_dec(((islot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN)
                        r3_push_rax()
                    } else {
                        r3_emit_arr(&R3_STR_LEAQ as u64, R3_STR_LEAQ_LEN); r3_emit_decl_label(ioff, ilen); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN)
                        r3_push_rax()
                    }
                } else {
                    r3_emit_expr(iobj)
                }
                r3_emit_expr(iidx)
                r3_pop_rcx(); r3_pop_rax()
                if bb == 1u32 { r3_emit_arr(&R3_STR_LEAQ_RCX1 as u64, R3_STR_LEAQ_RCX1_LEN) }
                else { r3_emit_arr(&R3_STR_LEAQ_RCX8 as u64, R3_STR_LEAQ_RCX8_LEN) }
                r3_push_rax()
                return R3_OK
            }
            /* ADDR-of-other fallthrough (PAREN, FIELD, etc.): emit inner
             * as rvalue pointer.  cg_r3.c uses "TOS-is-pointer" pattern. */
            r3_emit_expr(inner); return R3_OK
        }
        /* op != 5 (NEG/NOT/BNOT/DEREF) */
        r3_emit_expr(inner); r3_pop_rax()
        if op == 1u32 { r3_emit_arr(&R3_STR_NEGQ as u64, R3_STR_NEGQ_LEN) }
        if op == 2u32 { r3_emit_arr(&R3_STR_TESTRSTE as u64, R3_STR_TESTRSTE_LEN) }
        if op == 3u32 { r3_emit_arr(&R3_STR_NOTQ as u64, R3_STR_NOTQ_LEN) }
        if op == 4u32 { r3_emit_arr(&R3_STR_DEREF_RAX as u64, R3_STR_DEREF_RAX_LEN) }
        r3_push_rax(); return R3_OK
    }
    if k == R3_K_EXPR_SIZEOF {
        let mut sv: u64 = iii_ast_sizeof_resolved(R3_G_AST, node)
        if sv == 0u64 {
            sv = 8u64
            let tt: u32 = iii_ast_sizeof_target_type(R3_G_AST, node)
            let tts: u32 = r3_type_ref_byte_size(tt)
            if tts != 0u32 { sv = tts as u64 }
        }
        r3_emit_movabs_rax(sv)
        r3_push_rax(); return R3_OK
    }
    if k == R3_K_EXPR_CAST {
        let cv: u32 = iii_ast_cast_value(R3_G_AST, node)
        let ct: u32 = iii_ast_cast_target_type(R3_G_AST, node)
        r3_emit_expr(cv); r3_pop_rax()
        /* iiis-1 bit-identity: EXPR_CAST is UNSIGNED-UNIFORM in cg_r3.c
         * (treats i8/u8 same as movzbq, i16/u16 same as movzwq, i32/u32
         * same as movl).  Use r3_emit_cast_extend (not _return_extend
         * which IS signed-aware for callee return widening). */
        r3_emit_cast_extend(ct)
        r3_push_rax(); return R3_OK
    }
    if k == R3_K_EXPR_BINARY {
        let lhs: u32 = iii_ast_binary_lhs(R3_G_AST, node); let rhs: u32 = iii_ast_binary_rhs(R3_G_AST, node); let op: u32 = iii_ast_binary_op(R3_G_AST, node)
        let signed: u32 = r3_either_is_signed(lhs, rhs)
        r3_emit_expr(lhs); r3_emit_expr(rhs); r3_pop_rcx(); r3_pop_rax()
        if op == 1u32 { r3_emit_arr(&R3_STR_ADDQ as u64, R3_STR_ADDQ_LEN); if r3_expr_is_u32(lhs) == 1u32 { r3_emit_arr(&R3_STR_MOVL_EE as u64, R3_STR_MOVL_EE_LEN) } }
        if op == 2u32 { r3_emit_arr(&R3_STR_SUBQ as u64, R3_STR_SUBQ_LEN); if r3_expr_is_u32(lhs) == 1u32 { r3_emit_arr(&R3_STR_MOVL_EE as u64, R3_STR_MOVL_EE_LEN) } }
        if op == 3u32 { r3_emit_arr(&R3_STR_IMULQ as u64, R3_STR_IMULQ_LEN); if r3_expr_is_u32(lhs) == 1u32 { r3_emit_arr(&R3_STR_MOVL_EE as u64, R3_STR_MOVL_EE_LEN) } }
        if op == 4u32 { r3_emit_arr(&R3_STR_IDIV as u64, R3_STR_IDIV_LEN) }
        if op == 5u32 { r3_emit_arr(&R3_STR_IDIVMOD as u64, R3_STR_IDIVMOD_LEN) }
        if op == 6u32 { r3_emit_arr(&R3_STR_ANDQ as u64, R3_STR_ANDQ_LEN) }
        if op == 7u32 { r3_emit_arr(&R3_STR_ORQ as u64, R3_STR_ORQ_LEN) }
        if op == 8u32 { r3_emit_arr(&R3_STR_XORQ as u64, R3_STR_XORQ_LEN) }
        if op == 9u32 { r3_emit_arr(&R3_STR_SHLQ as u64, R3_STR_SHLQ_LEN) }
        if op == 9u32 { if r3_expr_is_u32(lhs) == 1u32 { r3_emit_arr(&R3_STR_MOVL_EE as u64, R3_STR_MOVL_EE_LEN) } }
        if op == 10u32 { r3_emit_arr(&R3_STR_SHRQ as u64, R3_STR_SHRQ_LEN) }
        if op == 11u32 { r3_emit_arr(&R3_STR_CMP_RCX_RAX as u64, R3_STR_CMP_RCX_RAX_LEN); r3_emit_arr(&R3_STR_SETE as u64, R3_STR_SETE_LEN) }
        if op == 12u32 { r3_emit_arr(&R3_STR_CMP_RCX_RAX as u64, R3_STR_CMP_RCX_RAX_LEN); r3_emit_arr(&R3_STR_SETNE as u64, R3_STR_SETNE_LEN) }
        if op == 13u32 { r3_emit_arr(&R3_STR_CMP_RCX_RAX as u64, R3_STR_CMP_RCX_RAX_LEN); r3_emit_setcc_lt(signed) }
        if op == 14u32 { r3_emit_arr(&R3_STR_CMP_RCX_RAX as u64, R3_STR_CMP_RCX_RAX_LEN); r3_emit_setcc_le(signed) }
        if op == 15u32 { r3_emit_arr(&R3_STR_CMP_RCX_RAX as u64, R3_STR_CMP_RCX_RAX_LEN); r3_emit_setcc_gt(signed) }
        if op == 16u32 { r3_emit_arr(&R3_STR_CMP_RCX_RAX as u64, R3_STR_CMP_RCX_RAX_LEN); r3_emit_setcc_ge(signed) }
        if op == 17u32 { r3_emit_arr(&R3_STR_TESTRRAX as u64, R3_STR_TESTRRAX_LEN); r3_emit_arr(&R3_STR_SETNE as u64, R3_STR_SETNE_LEN) }
        if op == 18u32 { r3_emit_arr(&R3_STR_ORQ as u64, R3_STR_ORQ_LEN); r3_emit_arr(&R3_STR_TESTRRAX as u64, R3_STR_TESTRRAX_LEN); r3_emit_arr(&R3_STR_SETNE as u64, R3_STR_SETNE_LEN) }
        r3_push_rax(); return R3_OK
    }
    if k == R3_K_EXPR_FIELD {
        let obj: u32 = iii_ast_field_object(R3_G_AST, node)
        let fnoff: u32 = iii_ast_field_name_offset(R3_G_AST, node)
        let fnlen: u32 = iii_ast_field_name_length(R3_G_AST, node)
        let fs: u32 = r3_struct_field_slot(obj, fnoff, fnlen)
        if fs != 4294967295u32 { r3_emit_load_slot(fs); r3_push_rax(); return R3_OK }
        r3_emit_expr(obj); r3_pop_rax()
        r3_emit_arr(&R3_STR_LEAQ as u64, R3_STR_LEAQ_LEN); r3_emit_field_label(fnoff, fnlen); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RCX as u64, R3_REG_RCX_LEN)
        r3_emit_arr(&R3_STR_ADDQ as u64, R3_STR_ADDQ_LEN); r3_emit_arr(&R3_STR_DEREF_RAX as u64, R3_STR_DEREF_RAX_LEN)
        r3_push_rax(); return R3_OK
    }
    if k == R3_K_EXPR_INDEX {
        let obj: u32 = iii_ast_index_object(R3_G_AST, node); let idx: u32 = iii_ast_index_index(R3_G_AST, node)
        let ek: u32 = r3_index_obj_elem_kind(obj)
        r3_emit_expr(obj); r3_emit_expr(idx); r3_pop_rcx(); r3_pop_rax()
        r3_emit_indexed_load(ek)
        r3_push_rax(); return R3_OK
    }
    if k == R3_K_EXPR_CALL {
        let callee: u32 = iii_ast_call_callee(R3_G_AST, node); let argc: u32 = iii_ast_call_arg_count(R3_G_AST, node)
        /* iiis-1 static type-system checks at every call site.
         * Each check is local: the EXPR_CALL handler runs for every
         * call (including nested calls), so checks compose
         * automatically via tree recursion.
         *
         * (1) @cap_required cap-flow: caller_mask covers callee_mask.
         * (2) @k_max K-floor: caller_floor >= callee_floor.
         * (3) @hexad_kind param-kind: for each typed arg (let/param
         *     binding with @hexad_kind OR a direct CALL with
         *     @returns_hexad), match against param's @hexad_kind.
         * All gated on both decls being FN_DECL.  Mandate 7 clean:
         * pure integer comparisons over declared metadata. */
        /* iiis-1 static checks dispatched via helper to keep the
         * EXPR_CALL body shallow.  All branching happens inside the
         * helper. */
        let chk_rc: u32 = r3_chk_call_site(node, callee, argc)
        if chk_rc != R3_OK { return chk_rc }
        /* iiis-1 Phase C.6 single-stmt PE narrowing: if this is
         * resolve(set, intent, ctx) and intent classifies as static,
         * replace the whole call with `leaq <fn>(%rip), %rax + push`.
         * Mirrors cg_r3.c:1644-1657. */
        let pe_rc: u32 = r3_try_pe_resolve(node, callee, argc)
        if pe_rc == 1u32 { return R3_OK }
        /* iiis-1 Phase C.6 multi-stmt narrowing: if the callee is a
         * local IDENT whose slot was recorded via STMT_LET PE, emit a
         * direct callq instead of indirect-through-slot.  Handled INLINE
         * in the callq-selection below (pe_hit branch), mirroring
         * cg_r3.c's single-flow 3-way callq branch (cg_r3.c:1718-1779) --
         * must be after arg-eval+shadow, not an early return. */
        let mut reg_args: u32 = argc
        if reg_args > 4u32 { reg_args = 4u32 }
        let mut stack_args: u32 = 0u32
        if argc > 4u32 { stack_args = argc - 4u32 }
        let mut align_pad: u32 = 0u32
        if ((R3_G_STACK_DEPTH + stack_args) & 1u32) != 0u32 { align_pad = 1u32 }
        if align_pad != 0u32 { r3_emit_arr(&R3_STR_ALIGN8 as u64, R3_STR_ALIGN8_LEN); R3_G_STACK_DEPTH = R3_G_STACK_DEPTH + 1u32 }
        let mut ai: u32 = argc
        while ai > 0u32 { ai = ai - 1u32; let a: u32 = iii_ast_call_arg_at(R3_G_AST, node, ai); r3_emit_expr(iii_ast_arg_value(R3_G_AST, a)) }
        if reg_args >= 1u32 { r3_pop_rcx() }
        if reg_args >= 2u32 { r3_pop_rdx() }
        if reg_args >= 3u32 { r3_emit_arr(&R3_STR_POPR8_NL as u64, R3_STR_POPR8_NL_LEN); R3_G_STACK_DEPTH = R3_G_STACK_DEPTH - 1u32 }
        if reg_args >= 4u32 { r3_emit_arr(&R3_STR_POPR9_NL as u64, R3_STR_POPR9_NL_LEN); R3_G_STACK_DEPTH = R3_G_STACK_DEPTH - 1u32 }
        r3_emit_arr(&R3_STR_SUB32_RSP as u64, R3_STR_SUB32_RSP_LEN)
        R3_G_STACK_DEPTH = R3_G_STACK_DEPTH + 4u32
        /* iiis-1 bit-identity: ABI-OK comment removed (was dynamic
         * in cg_r3.c, static in cg_r3.iii — now skipped in both). */
        let ck: u32 = iii_ast_node_kind(R3_G_AST, callee)
        let mut do_indir: u32 = 0u32
        let mut cof: u32 = 0u32
        let mut cln: u32 = 0u32
        let mut is_extern: u32 = 0u32
        let mut callee_rt: u32 = 0u32
        let mut pe_hit: u32 = 0u32
        let mut pe_addr: u64 = 0u64
        let mut pe_len: u32 = 0u32
        if ck == R3_K_EXPR_IDENT {
            cof = iii_ast_ident_name_offset(R3_G_AST, callee)
            cln = iii_ast_ident_name_length(R3_G_AST, callee)
            let cslot: u32 = r3_local_lookup(cof, cln)
            if cslot != 4294967295u32 {
                let pe_nm: u64 = r3_pe_get_static_fp(cslot)
                if pe_nm != 0u64 { pe_hit = 1u32; pe_addr = pe_nm; pe_len = R3_G_PE_NAME_LEN } else { do_indir = 1u32 }
            }
            if do_indir == 0u32 {
                if pe_hit == 0u32 {
                let bid: u32 = iii_ast_node_binder_id(R3_G_AST, callee)
                if bid != 0u32 { let bk: u32 = iii_ast_node_kind(R3_G_AST, bid); if bk == R3_K_EXTERN_DECL { is_extern = 1u32; callee_rt = iii_ast_extern_return_type(R3_G_AST, bid) }; if bk == R3_K_FN_DECL { callee_rt = iii_ast_fn_return_type(R3_G_AST, bid); if r3_decl_is_exported(bid, bk) == 1u32 { is_extern = 1u32 } } }
                }
            }
        }
        if ck != R3_K_EXPR_IDENT { do_indir = 1u32 }
        if pe_hit == 1u32 {
            r3_emit_arr(&R3_CMT_PE_DIRECT_CALL as u64, R3_CMT_PE_DIRECT_CALL_LEN)
            r3_emit_c_str(pe_addr, pe_len)
            r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
            r3_emit_arr(&R3_STR_CALLQ as u64, R3_STR_CALLQ_LEN)
            r3_emit_c_str(pe_addr, pe_len)
            r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        } else { if do_indir == 0u32 {
            r3_emit_arr(&R3_STR_CALLQ as u64, R3_STR_CALLQ_LEN)
            if is_extern == 1u32 { r3_emit_sym_run(cof, cln) } else { r3_emit_decl_label(cof, cln) }
            r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        } else { r3_emit_expr(callee); r3_pop_rax(); r3_emit_arr(&R3_STR_CALL_INDIR as u64, R3_STR_CALL_INDIR_LEN) } }
        r3_emit_arr(&R3_STR_ADD32_RSP as u64, R3_STR_ADD32_RSP_LEN)
        R3_G_STACK_DEPTH = R3_G_STACK_DEPTH - 4u32
        if align_pad != 0u32 { r3_emit_arr(&R3_STR_UNALIGN8 as u64, R3_STR_UNALIGN8_LEN); R3_G_STACK_DEPTH = R3_G_STACK_DEPTH - 1u32 }
        /* iiis-1 bit-identity: post-call stack-args discard.  Matches
         * cg_r3.c which emits `addq $<stack_args*8>, %rsp` after
         * unshadow + unalign.  Required when argc > 4 (extra args
         * pushed onto stack before the call). */
        if stack_args > 0u32 {
            r3_emit_arr(&R3_STR_ADDQ_DOLR as u64, R3_STR_ADDQ_DOLR_LEN)
            r3_emit_dec((stack_args * 8u32) as u64)
            r3_emit_arr(&R3_K_RSPLOCALS as u64, R3_K_RSPLOCALS_LEN)
            R3_G_STACK_DEPTH = R3_G_STACK_DEPTH - stack_args
        }
        r3_emit_return_extend(callee_rt)
        r3_push_rax(); return R3_OK
    }
    if k == R3_K_EXPR_MATCH {
        let scrut: u32 = iii_ast_match_expr_scrutinee(R3_G_AST, node); let armc: u32 = iii_ast_match_expr_arm_count(R3_G_AST, node)
        let endid: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
        r3_emit_expr(scrut); r3_pop_rax()
        let scrut_slot: u32 = R3_G_LOCAL_COUNT; R3_G_LOCAL_COUNT = R3_G_LOCAL_COUNT + 1u32
        r3_emit_store_rax_slot(scrut_slot)
        let mut i: u32 = 0u32
        while i < armc {
            let arm: u32 = iii_ast_match_expr_arm_at(R3_G_AST, node, i)
            let pat: u32 = iii_ast_match_arm_pattern(R3_G_AST, arm)
            let skip_lbl: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
            r3_emit_load_slot(scrut_slot)
            r3_emit_pattern_compare(pat, skip_lbl)
            r3_emit_arr(&R3_STR_JNE as u64, R3_STR_JNE_LEN); r3_emit_arr(&R3_PFX_LSKIP as u64, R3_PFX_LSKIP_LEN); r3_emit_dec(skip_lbl as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
            r3_emit_pattern_bind(pat)
            let body: u32 = iii_ast_match_arm_body(R3_G_AST, arm)
            r3_emit_expr(body)
            r3_emit_arr(&R3_STR_JMP as u64, R3_STR_JMP_LEN); r3_emit_arr(&R3_PFX_LMATCHEND as u64, R3_PFX_LMATCHEND_LEN); r3_emit_dec(endid as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
            r3_emit_arr(&R3_PFX_LSKIP as u64, R3_PFX_LSKIP_LEN); r3_emit_dec(skip_lbl as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
            i = i + 1u32
        }
        r3_emit_arr(&R3_STR_MOVQ_DOL0_RAX as u64, R3_STR_MOVQ_DOL0_RAX_LEN)
        r3_push_rax()
        r3_emit_arr(&R3_PFX_LMATCHEND as u64, R3_PFX_LMATCHEND_LEN); r3_emit_dec(endid as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
        return R3_OK
    }
    if k == R3_K_EXPR_RAW_ASM {
        let idx: u32 = iii_ast_raw_asm_str_idx(R3_G_AST, node)
        let addr: u64 = iii_ast_string_payload_addr_c(R3_G_AST, idx)
        let len: u32 = iii_ast_raw_asm_len(R3_G_AST, node)
        r3_emit_bytes(addr, len as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        r3_emit_arr(&R3_STR_XORRAX as u64, R3_STR_XORRAX_LEN); r3_push_rax(); return R3_OK
    }
    R3_G_LAST_ERROR = R3_E_UNSUPPORTED; return R3_E_UNSUPPORTED
}

fn r3_emit_stmt(node: u32) -> u32 {
    if node == 0u32 { return R3_OK }
    let k: u32 = iii_ast_node_kind(R3_G_AST, node)
    if k == R3_K_STMT_LET {
        let v: u32 = iii_ast_let_value(R3_G_AST, node)
        let off: u32 = iii_ast_let_name_off(R3_G_AST, node)
        let len: u32 = iii_ast_let_name_len(R3_G_AST, node)
        /* iiis-1 STATIC return-kind check: extracted to helper to
         * keep r3_emit_stmt below iiis-0's parser recursion limit. */
        if v != 0u32 {
            let rk_rc: u32 = r3_chk_let_return_kind(node, v)
            if rk_rc != R3_OK { return rk_rc }
        }
        /* iiis-1 bit-identity: when the let's declared type is a
         * TYPE_ARRAY [T; N], reserve ceil(N*sizeof(T)/8) slots so
         * subsequent locals get the same stack offset cg_r3.c
         * computes.  Mirrors Phase 3 Step 1 trap fix #10. */
        let r3_let_t: u32 = iii_ast_let_type(R3_G_AST, node)
        if r3_let_t != 0u32 {
            let r3_let_tk: u32 = iii_ast_node_kind(R3_G_AST, r3_let_t)
            if r3_let_tk == R3_K_TYPE_ARR {
                let r3_elem_count: u64 = iii_ast_type_array_count(R3_G_AST, r3_let_t)
                let r3_elem_width: u32 = r3_array_elem_byte_size(r3_let_t)
                let r3_total_bytes: u64 = r3_elem_count * (r3_elem_width as u64)
                let mut r3_total_slots: u32 = ((r3_total_bytes + 7u64) / 8u64) as u32
                if r3_total_slots == 0u32 { r3_total_slots = 1u32 }
                r3_local_add(off, len)
                let mut r3_extra: u32 = 1u32
                while r3_extra < r3_total_slots {
                    R3_G_LOCAL_COUNT = R3_G_LOCAL_COUNT + 1u32
                    r3_extra = r3_extra + 1u32
                }
                if v != 0u32 {
                    r3_emit_expr(v)
                    r3_pop_rax()
                }
                return R3_OK
            }
            /* iiis-1 bit-identity: when the let's type is a TYPE_REF
             * whose name resolves to a STRUCT_DECL, reserve N slots.
             * Extracted to helper r3_try_struct_slots to keep parse
             * recursion depth low. */
            if r3_let_tk == R3_K_TYPE_REF {
                let r3_st_rc: u32 = r3_try_struct_slots(r3_let_t, off, len, v)
                if r3_st_rc == 1u32 { return R3_OK }
            }
        }
        /* iiis-1 bit-identity: match cg_r3.c STMT_LET ordering exactly.
         * C emits expr FIRST (RHS reads outer scope if name shadows), THEN
         * calls local_add (always creates new slot — never reuses), THEN
         * stores rax to the new slot.  iii previously did lookup-first /
         * reuse-on-hit, which produced wrong slot offsets for repeated
         * `let _ = expr` patterns (slot accounting drift) and wrong
         * shadow semantics for `let x = x + 1`. */
        if v != 0u32 {
            r3_emit_expr(v)
            r3_pop_rax()
        }
        r3_local_add(off, len)
        let slot: u32 = R3_G_LOCAL_COUNT - 1u32
        if v != 0u32 {
            r3_emit_store_rax_slot(slot)
        }
        /* iiis-1 Phase C.6 PE multi-stmt narrowing: record the slot →
         * fn_name mapping when the initializer was a static resolve()
         * call.  Mirrors cg_r3.c:2237-2243 — emits the PE_RECORD marker
         * AND stashes the mapping for later direct-call elision. */
        if v != 0u32 {
            let pe_fn: u64 = r3_pe_classify_let_value(v)
            if pe_fn != 0u64 {
                let pe_nlen: u32 = iii_cg_pe_name_len(pe_fn)
                r3_pe_record_static_fp(slot, pe_fn, pe_nlen)
                r3_emit_arr(&R3_CMT_PE_RECORD as u64, R3_CMT_PE_RECORD_LEN)
                r3_emit_dec(slot as u64)
                r3_emit_arr(&R3_STR_ARROW as u64, R3_STR_ARROW_LEN)
                r3_emit_c_str(pe_fn, pe_nlen)
                r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
            }
        }
        return R3_OK
    }
    if k == R3_K_STMT_EXPR { r3_emit_expr(iii_ast_expr_stmt_expr(R3_G_AST, node)); r3_pop_rax(); return R3_OK }
    if k == R3_K_STMT_RETURN {
        let v: u32 = iii_ast_return_value(R3_G_AST, node)
        if v != 0u32 { r3_emit_expr(v); r3_pop_rax() } else { r3_emit_arr(&R3_STR_DOL0RAX as u64, R3_STR_DOL0RAX_LEN) }
        if R3_G_CUR_IS_CYCLE != 0u32 { r3_emit_arr(&R3_CMT_WIT_EXIT as u64, R3_CMT_WIT_EXIT_LEN) }
        r3_emit_arr(&R3_STR_LEAVE_RET as u64, R3_STR_LEAVE_RET_LEN)
        return R3_OK
    }
    if k == R3_K_STMT_ASSIGN {
        let lv: u32 = iii_ast_assign_lvalue(R3_G_AST, node)
        let val: u32 = iii_ast_assign_value(R3_G_AST, node)
        let lk: u32 = iii_ast_node_kind(R3_G_AST, lv)
        if lk == R3_K_EXPR_UNARY {
            let lop: u32 = iii_ast_unary_op(R3_G_AST, lv)
            if lop == 4u32 {
                let inner: u32 = iii_ast_unary_operand(R3_G_AST, lv)
                r3_emit_expr(inner)
                r3_emit_expr(val)
                r3_pop_rdx(); r3_pop_rax()
                r3_emit_arr(&R3_STR_DEREF_STORE as u64, R3_STR_DEREF_STORE_LEN)
                return R3_OK
            }
        }
        if lk == R3_K_EXPR_INDEX {
            let obj: u32 = iii_ast_index_object(R3_G_AST, lv); let idx: u32 = iii_ast_index_index(R3_G_AST, lv)
            let ek: u32 = r3_index_obj_elem_kind(obj)
            r3_emit_expr(obj); r3_emit_expr(idx); r3_emit_expr(val)
            r3_pop_rdx(); r3_pop_rcx(); r3_pop_rax()
            r3_emit_indexed_store(ek)
            return R3_OK
        }
        r3_emit_expr(val); r3_pop_rax()
        if lk == R3_K_EXPR_IDENT {
            let off: u32 = iii_ast_ident_name_offset(R3_G_AST, lv)
            let len: u32 = iii_ast_ident_name_length(R3_G_AST, lv)
            let s: u32 = r3_local_lookup(off, len)
            if s != 4294967295u32 { r3_emit_store_rax_slot(s); return R3_OK }
            /* iiis-1 width-aware global store: probe binder type and
             * dispatch to movb/movw/movl/movq matching cg_r3.c:2306-2323.
             * Previously emitted movq unconditionally — wrote 7 bytes of
             * garbage past u8 globals, root-cause of multiple latent
             * codegen bugs in the self-host sources. */
            return r3_emit_global_ident_store(lv, off, len)
        }
        if lk == R3_K_EXPR_FIELD {
            let fobj: u32 = iii_ast_field_object(R3_G_AST, lv)
            let fnoff: u32 = iii_ast_field_name_offset(R3_G_AST, lv)
            let fnlen: u32 = iii_ast_field_name_length(R3_G_AST, lv)
            let fs: u32 = r3_struct_field_slot(fobj, fnoff, fnlen)
            if fs != 4294967295u32 { r3_emit_store_rax_slot(fs); return R3_OK }
            r3_emit_arr(&R3_STR_MOVQ_RAX_C as u64, R3_STR_MOVQ_RAX_C_LEN); r3_emit_field_label(fnoff, fnlen); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
        }
        return R3_OK
    }
    if k == R3_K_STMT_FOR {
        let topid: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
        let endid: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
        let iter: u32 = iii_ast_for_iter(R3_G_AST, node)
        let body: u32 = iii_ast_for_body(R3_G_AST, node)
        let where_e: u32 = iii_ast_for_where(R3_G_AST, node)
        let off: u32 = iii_ast_for_var_off(R3_G_AST, node)
        let len: u32 = iii_ast_for_var_len(R3_G_AST, node)
        let ik: u32 = iii_ast_node_kind(R3_G_AST, iter)
        let mut count_slot: u32 = 0u32
        let mut var_slot: u32 = 0u32
        if ik == R3_K_EXPR_RANGE {
            r3_emit_expr(iii_ast_range_hi(R3_G_AST, iter)); r3_pop_rax()
            count_slot = R3_G_LOCAL_COUNT; R3_G_LOCAL_COUNT = R3_G_LOCAL_COUNT + 1u32
            r3_emit_store_rax_slot(count_slot)
            r3_emit_expr(iii_ast_range_lo(R3_G_AST, iter)); r3_pop_rax()
            r3_local_add(off, len); var_slot = R3_G_LOCAL_COUNT - 1u32
            r3_emit_store_rax_slot(var_slot)
        } else {
            r3_emit_expr(iter); r3_pop_rax()
            count_slot = R3_G_LOCAL_COUNT; R3_G_LOCAL_COUNT = R3_G_LOCAL_COUNT + 1u32
            r3_emit_store_rax_slot(count_slot)
            r3_local_add(off, len); var_slot = R3_G_LOCAL_COUNT - 1u32
            r3_emit_arr(&R3_STR_MOVQ_RAX_C as u64, R3_STR_MOVQ_RAX_C_LEN)
            r3_emit_arr(&R3_STR_MOVABSQ_OPEN as u64, R3_STR_MOVABSQ_OPEN_LEN)
            r3_emit_hex(0u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
            r3_emit_store_rax_slot(var_slot)
        }
        r3_emit_arr(&R3_PFX_LFORTOP as u64, R3_PFX_LFORTOP_LEN); r3_emit_dec(topid as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
        r3_emit_load_slot(var_slot)
        r3_emit_arr(&R3_STR_DASH_OPEN as u64, R3_STR_DASH_OPEN_LEN); r3_emit_dec(((count_slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RCX as u64, R3_STR_BPCMA_RCX_LEN)
        r3_emit_arr(&R3_STR_CMP_RCX_RAX as u64, R3_STR_CMP_RCX_RAX_LEN)
        r3_emit_arr(&R3_STR_JGE as u64, R3_STR_JGE_LEN); r3_emit_arr(&R3_PFX_LFOREND as u64, R3_PFX_LFOREND_LEN); r3_emit_dec(endid as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        if where_e != 0u32 {
            r3_emit_expr(where_e); r3_pop_rax()
            r3_emit_arr(&R3_STR_TESTRRAX as u64, R3_STR_TESTRRAX_LEN)
            r3_emit_arr(&R3_STR_JZ as u64, R3_STR_JZ_LEN); r3_emit_arr(&R3_PFX_LFORCONT as u64, R3_PFX_LFORCONT_LEN); r3_emit_dec(topid as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        }
        r3_emit_block(body); r3_pop_rax()
        if where_e != 0u32 { r3_emit_arr(&R3_PFX_LFORCONT as u64, R3_PFX_LFORCONT_LEN); r3_emit_dec(topid as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN) }
        r3_emit_load_slot(var_slot)
        r3_emit_arr(&R3_STR_ADDQ1RAX as u64, R3_STR_ADDQ1RAX_LEN)
        r3_emit_store_rax_slot(var_slot)
        r3_emit_arr(&R3_STR_JMP as u64, R3_STR_JMP_LEN); r3_emit_arr(&R3_PFX_LFORTOP as u64, R3_PFX_LFORTOP_LEN); r3_emit_dec(topid as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        r3_emit_arr(&R3_PFX_LFOREND as u64, R3_PFX_LFOREND_LEN); r3_emit_dec(endid as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
        return R3_OK
    }
    if k == R3_K_STMT_IF {
        let lbl_else: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
        let lbl_end: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
        let cond: u32 = iii_ast_if_cond(R3_G_AST, node)
        let then_b: u32 = iii_ast_if_then(R3_G_AST, node)
        let else_b: u32 = iii_ast_if_else(R3_G_AST, node)
        r3_emit_expr(cond); r3_pop_rax()
        r3_emit_arr(&R3_STR_TESTRRAX as u64, R3_STR_TESTRRAX_LEN)
        r3_emit_arr(&R3_STR_JZ as u64, R3_STR_JZ_LEN)
        if else_b != 0u32 { r3_emit_arr(&R3_PFX_LIFELSE as u64, R3_PFX_LIFELSE_LEN); r3_emit_dec(lbl_else as u64) } else { r3_emit_arr(&R3_PFX_LIFEND as u64, R3_PFX_LIFEND_LEN); r3_emit_dec(lbl_end as u64) }
        r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        r3_emit_block(then_b); r3_pop_rax()
        if else_b != 0u32 {
            r3_emit_arr(&R3_STR_JMP as u64, R3_STR_JMP_LEN); r3_emit_arr(&R3_PFX_LIFEND as u64, R3_PFX_LIFEND_LEN); r3_emit_dec(lbl_end as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
            r3_emit_arr(&R3_PFX_LIFELSE as u64, R3_PFX_LIFELSE_LEN); r3_emit_dec(lbl_else as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
            let ek: u32 = iii_ast_node_kind(R3_G_AST, else_b)
            if ek == R3_K_STMT_IF { r3_emit_stmt(else_b) } else { r3_emit_block(else_b); r3_pop_rax() }
        }
        r3_emit_arr(&R3_PFX_LIFEND as u64, R3_PFX_LIFEND_LEN); r3_emit_dec(lbl_end as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
        return R3_OK
    }
    if k == R3_K_STMT_WHILE {
        /* iiis-2 unified labels: STMT_WHILE emits L_loop_top_<id> /
         * L_loop_end_<id> (same scheme as STMT_LOOP) so STMT_BREAK and
         * STMT_CONTINUE inside the body resolve uniformly.  The label
         * uniqueness comes from R3_G_LABEL_COUNTER. */
        let lbl_top: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
        let lbl_end: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
        if R3_G_LOOP_DEPTH >= 16u32 {
            R3_G_LAST_ERROR = R3_E_INTERNAL; R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32
            return R3_E_INTERNAL
        }
        R3_G_LOOP_TOP_STK[R3_G_LOOP_DEPTH] = lbl_top
        R3_G_LOOP_END_STK[R3_G_LOOP_DEPTH] = lbl_end
        R3_G_LOOP_DEPTH = R3_G_LOOP_DEPTH + 1u32
        let wcond: u32 = iii_ast_while_cond(R3_G_AST, node)
        let wbody: u32 = iii_ast_while_body(R3_G_AST, node)
        r3_emit_arr(&R3_PFX_LLOOPTOP as u64, R3_PFX_LLOOPTOP_LEN); r3_emit_dec(lbl_top as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
        r3_emit_expr(wcond); r3_pop_rax()
        r3_emit_arr(&R3_STR_TESTRRAX as u64, R3_STR_TESTRRAX_LEN)
        r3_emit_arr(&R3_STR_JZ as u64, R3_STR_JZ_LEN); r3_emit_arr(&R3_PFX_LLOOPEND as u64, R3_PFX_LLOOPEND_LEN); r3_emit_dec(lbl_end as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        r3_emit_block(wbody); r3_pop_rax()
        r3_emit_arr(&R3_STR_JMP as u64, R3_STR_JMP_LEN); r3_emit_arr(&R3_PFX_LLOOPTOP as u64, R3_PFX_LLOOPTOP_LEN); r3_emit_dec(lbl_top as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        r3_emit_arr(&R3_PFX_LLOOPEND as u64, R3_PFX_LLOOPEND_LEN); r3_emit_dec(lbl_end as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
        R3_G_LOOP_DEPTH = R3_G_LOOP_DEPTH - 1u32
        return R3_OK
    }
    if k == R3_K_STMT_LOOP {
        /* iiis-2 — unconditional loop.  Same label scheme as WHILE
         * minus the condition + jz; break/continue inside resolve to
         * lbl_end/lbl_top respectively. */
        let lbl_top: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
        let lbl_end: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
        if R3_G_LOOP_DEPTH >= 16u32 {
            R3_G_LAST_ERROR = R3_E_INTERNAL; R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32
            return R3_E_INTERNAL
        }
        R3_G_LOOP_TOP_STK[R3_G_LOOP_DEPTH] = lbl_top
        R3_G_LOOP_END_STK[R3_G_LOOP_DEPTH] = lbl_end
        R3_G_LOOP_DEPTH = R3_G_LOOP_DEPTH + 1u32
        let lbody: u32 = iii_ast_loop_body(R3_G_AST, node)
        r3_emit_arr(&R3_PFX_LLOOPTOP as u64, R3_PFX_LLOOPTOP_LEN); r3_emit_dec(lbl_top as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
        r3_emit_block(lbody); r3_pop_rax()
        r3_emit_arr(&R3_STR_JMP as u64, R3_STR_JMP_LEN); r3_emit_arr(&R3_PFX_LLOOPTOP as u64, R3_PFX_LLOOPTOP_LEN); r3_emit_dec(lbl_top as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        r3_emit_arr(&R3_PFX_LLOOPEND as u64, R3_PFX_LLOOPEND_LEN); r3_emit_dec(lbl_end as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
        R3_G_LOOP_DEPTH = R3_G_LOOP_DEPTH - 1u32
        return R3_OK
    }
    if k == R3_K_STMT_BREAK {
        /* iiis-2 — `break` outside any loop is a codegen error. */
        if R3_G_LOOP_DEPTH == 0u32 {
            R3_G_LAST_ERROR = R3_E_INTERNAL; R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32
            return R3_E_INTERNAL
        }
        let target: u32 = R3_G_LOOP_END_STK[R3_G_LOOP_DEPTH - 1u32]
        r3_emit_arr(&R3_STR_JMP as u64, R3_STR_JMP_LEN); r3_emit_arr(&R3_PFX_LLOOPEND as u64, R3_PFX_LLOOPEND_LEN); r3_emit_dec(target as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        return R3_OK
    }
    if k == R3_K_STMT_CONTINUE {
        if R3_G_LOOP_DEPTH == 0u32 {
            R3_G_LAST_ERROR = R3_E_INTERNAL; R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32
            return R3_E_INTERNAL
        }
        let target: u32 = R3_G_LOOP_TOP_STK[R3_G_LOOP_DEPTH - 1u32]
        r3_emit_arr(&R3_STR_JMP as u64, R3_STR_JMP_LEN); r3_emit_arr(&R3_PFX_LLOOPTOP as u64, R3_PFX_LLOOPTOP_LEN); r3_emit_dec(target as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        return R3_OK
    }
    if k == R3_K_STMT_MATCH {
        let scrut: u32 = iii_ast_match_stmt_scrutinee(R3_G_AST, node); let armc: u32 = iii_ast_match_stmt_arm_count(R3_G_AST, node)
        let endid: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
        r3_emit_expr(scrut); r3_pop_rax()
        let scrut_slot: u32 = R3_G_LOCAL_COUNT; R3_G_LOCAL_COUNT = R3_G_LOCAL_COUNT + 1u32
        r3_emit_store_rax_slot(scrut_slot)
        let mut i: u32 = 0u32
        while i < armc {
            let arm: u32 = iii_ast_match_stmt_arm_at(R3_G_AST, node, i)
            let pat: u32 = iii_ast_match_arm_pattern(R3_G_AST, arm)
            let skip_lbl: u32 = R3_G_LABEL_COUNTER; R3_G_LABEL_COUNTER = R3_G_LABEL_COUNTER + 1u32
            r3_emit_load_slot(scrut_slot)
            r3_emit_pattern_compare(pat, skip_lbl)
            r3_emit_arr(&R3_STR_JNE as u64, R3_STR_JNE_LEN); r3_emit_arr(&R3_PFX_LSKIP as u64, R3_PFX_LSKIP_LEN); r3_emit_dec(skip_lbl as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
            r3_emit_pattern_bind(pat)
            let body: u32 = iii_ast_match_arm_body(R3_G_AST, arm)
            r3_emit_expr(body); r3_pop_rax()
            r3_emit_arr(&R3_STR_JMP as u64, R3_STR_JMP_LEN); r3_emit_arr(&R3_PFX_LMATCHEND as u64, R3_PFX_LMATCHEND_LEN); r3_emit_dec(endid as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
            r3_emit_arr(&R3_PFX_LSKIP as u64, R3_PFX_LSKIP_LEN); r3_emit_dec(skip_lbl as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
            i = i + 1u32
        }
        r3_emit_arr(&R3_PFX_LMATCHEND as u64, R3_PFX_LMATCHEND_LEN); r3_emit_dec(endid as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
        return R3_OK
    }
    if k == R3_K_STMT_WAVEFRONT {
        let nc: u32 = iii_ast_wavefront_node_count(R3_G_AST, node)
        let mut i: u32 = 0u32; while i < nc { r3_emit_stmt(iii_ast_wavefront_node_at(R3_G_AST, node, i)); i = i + 1u32 }
        return R3_OK
    }
    if k == R3_K_STMT_SANCTUM_ENTER { R3_G_LAST_ERROR = R3_E_UNSUPPORTED; return R3_E_UNSUPPORTED }
    if k == R3_K_STMT_METAL {
        /* metal{} raw_asm_str_idx is a SOURCE-BUFFER OFFSET (not a string-
         * payload index), byte-mirroring cg_r3.c:2718-2722: emit the raw
         * source bytes [off, off+len) verbatim, bounds-checked. */
        let off: u32 = iii_ast_metal_asm_str_idx(R3_G_AST, node)
        let len: u32 = iii_ast_metal_asm_len(R3_G_AST, node)
        if ((off as u64) + (len as u64)) <= (iii_ast_source_len_u32(R3_G_AST) as u64) {
            let addr: u64 = iii_ast_source_buf(R3_G_AST) + (off as u64)
            r3_emit_bytes(addr, len as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        }
        return R3_OK
    }
    return r3_emit_expr(node)
}

/* iiis-1 bit-identity: emit_block now SAVES R3_G_LOCAL_COUNT at block
 * entry and RESTORES it at block exit, matching cg_r3.c.  This pops
 * block-scoped locals so subsequent statements see the same slot
 * offsets the C compiler would compute. */
fn r3_emit_block(node: u32) -> u32 {
    if node == 0u32 { return R3_OK }
    let k: u32 = iii_ast_node_kind(R3_G_AST, node)
    if k == R3_K_FORWARD_BLOCK {
        let saved_locals: u32 = R3_G_LOCAL_COUNT
        let n: u32 = iii_ast_forward_block_stmt_count(R3_G_AST, node)
        let mut i: u32 = 0u32
        while i < n { r3_emit_stmt(iii_ast_forward_block_stmt_at(R3_G_AST, node, i)); i = i + 1u32 }
        R3_G_LOCAL_COUNT = saved_locals
        r3_emit_arr(&R3_STR_DOL0RAX as u64, R3_STR_DOL0RAX_LEN); r3_push_rax(); return R3_OK
    }
    if k == R3_K_EXPR_BLOCK {
        let saved_locals: u32 = R3_G_LOCAL_COUNT
        let n: u32 = iii_ast_block_stmt_count(R3_G_AST, node)
        let mut i: u32 = 0u32
        while i < n { r3_emit_stmt(iii_ast_block_stmt_at(R3_G_AST, node, i)); i = i + 1u32 }
        R3_G_LOCAL_COUNT = saved_locals
        r3_emit_arr(&R3_STR_DOL0RAX as u64, R3_STR_DOL0RAX_LEN); r3_push_rax(); return R3_OK
    }
    return r3_emit_stmt(node)
}

/* iiis-1 Phase 3 Step 3: locate the 0-based param slot named "ctx".
 * Returns slot index (== local slot index after spill) or 0xFFFFFFFF
 * if no ctx param exists.  Mirrors cg_r3.c's linear scan over
 * fn_decl.params for memcmp(name, "ctx", 3). */
fn r3_find_ctx_slot(fn_decl_node: u32) -> u32 {
    let pc: u32 = iii_ast_fn_param_count(R3_G_AST, fn_decl_node)
    let mut i: u32 = 0u32
    while i < pc {
        let pid: u32 = iii_ast_fn_param_at(R3_G_AST, fn_decl_node, i)
        let pno: u32 = iii_ast_param_name_off(R3_G_AST, pid)
        let pnl: u32 = iii_ast_param_name_len(R3_G_AST, pid)
        if r3_name_eq_lit(pno, pnl, &R3_LIT_CTX as u64, R3_LIT_CTX_LEN) == 1u32 { return i }
        i = i + 1u32
    }
    return 4294967295u32
}

/* iiis-1 Phase 3 Step 3: emit @cap_required(MASK) runtime gate.
 * Mirrors cg_r3.c:3057-3075 byte-for-byte.  Loads ctx from local slot,
 * fetches its cap-id via call_context_cap_id, checks against MASK
 * via cap_verify_rights; on fail returns sentinel -1 (full epilogue),
 * on success falls through to L_cap_ok_<DECL_NODE>. */
fn r3_emit_cap_check(off: u64, mask: u64, decl_node: u32) -> u32 {
    r3_emit_arr(&R3_STR_CAP_REQ_BANNER as u64, R3_STR_CAP_REQ_BANNER_LEN)
    r3_emit_arr(&R3_STR_DASH_OPEN as u64, R3_STR_DASH_OPEN_LEN); r3_emit_dec(off); r3_emit_arr(&R3_STR_BPCMA_RCX as u64, R3_STR_BPCMA_RCX_LEN)
    r3_emit_arr(&R3_STR_SUB32_RSP as u64, R3_STR_SUB32_RSP_LEN)
    r3_emit_arr(&R3_STR_CALLQ_CAP_ID as u64, R3_STR_CALLQ_CAP_ID_LEN)
    r3_emit_arr(&R3_STR_ADD32_RSP as u64, R3_STR_ADD32_RSP_LEN)
    r3_emit_arr(&R3_STR_MOVQ_RAX_RCX as u64, R3_STR_MOVQ_RAX_RCX_LEN)
    r3_emit_arr(&R3_STR_MOVABSQ_OPEN as u64, R3_STR_MOVABSQ_OPEN_LEN); r3_emit_hex(mask); r3_emit_arr(&R3_STR_COMMA_RDX_NL as u64, R3_STR_COMMA_RDX_NL_LEN)
    r3_emit_arr(&R3_STR_SUB32_RSP as u64, R3_STR_SUB32_RSP_LEN)
    r3_emit_arr(&R3_STR_CALLQ_CAP_VERIFY as u64, R3_STR_CALLQ_CAP_VERIFY_LEN)
    r3_emit_arr(&R3_STR_ADD32_RSP as u64, R3_STR_ADD32_RSP_LEN)
    r3_emit_arr(&R3_STR_TESTB_AL_AL as u64, R3_STR_TESTB_AL_AL_LEN)
    r3_emit_arr(&R3_STR_JNZ as u64, R3_STR_JNZ_LEN); r3_emit_arr(&R3_PFX_LCAPOK as u64, R3_PFX_LCAPOK_LEN); r3_emit_dec(decl_node as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
    r3_emit_arr(&R3_STR_MOVQ_SENTINEL_RAX as u64, R3_STR_MOVQ_SENTINEL_RAX_LEN)
    r3_emit_arr(&R3_STR_LEAVE_RET as u64, R3_STR_LEAVE_RET_LEN)
    r3_emit_arr(&R3_PFX_LCAPOK as u64, R3_PFX_LCAPOK_LEN); r3_emit_dec(decl_node as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
    return R3_OK
}

/* iiis-1 Phase 3 Step 3: emit @hexad_kind(K) runtime gate.
 * Mirrors cg_r3.c:3082-3098 byte-for-byte.  Fetches ctx's hexad kind
 * via call_context_hexad_kind, zero-extends to u64, compares against
 * K; on mismatch returns sentinel -1, on match falls through. */
fn r3_emit_hexad_check(off: u64, kind_val: u64, decl_node: u32) -> u32 {
    r3_emit_arr(&R3_STR_HEXAD_KIND_BANNER as u64, R3_STR_HEXAD_KIND_BANNER_LEN)
    r3_emit_arr(&R3_STR_DASH_OPEN as u64, R3_STR_DASH_OPEN_LEN); r3_emit_dec(off); r3_emit_arr(&R3_STR_BPCMA_RCX as u64, R3_STR_BPCMA_RCX_LEN)
    r3_emit_arr(&R3_STR_SUB32_RSP as u64, R3_STR_SUB32_RSP_LEN)
    r3_emit_arr(&R3_STR_CALLQ_HEXAD_KIND as u64, R3_STR_CALLQ_HEXAD_KIND_LEN)
    r3_emit_arr(&R3_STR_ADD32_RSP as u64, R3_STR_ADD32_RSP_LEN)
    r3_emit_arr(&R3_STR_MOVZBQ_AL_RAX as u64, R3_STR_MOVZBQ_AL_RAX_LEN)
    r3_emit_arr(&R3_STR_MOVABSQ_OPEN as u64, R3_STR_MOVABSQ_OPEN_LEN); r3_emit_hex(kind_val); r3_emit_arr(&R3_STR_COMMA_RCX_NL as u64, R3_STR_COMMA_RCX_NL_LEN)
    r3_emit_arr(&R3_STR_CMP_RCX_RAX as u64, R3_STR_CMP_RCX_RAX_LEN)
    r3_emit_arr(&R3_STR_JE_PFX as u64, R3_STR_JE_PFX_LEN); r3_emit_arr(&R3_PFX_LHEXADOK as u64, R3_PFX_LHEXADOK_LEN); r3_emit_dec(decl_node as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
    r3_emit_arr(&R3_STR_MOVQ_SENTINEL_RAX as u64, R3_STR_MOVQ_SENTINEL_RAX_LEN)
    r3_emit_arr(&R3_STR_LEAVE_RET as u64, R3_STR_LEAVE_RET_LEN)
    r3_emit_arr(&R3_PFX_LHEXADOK as u64, R3_PFX_LHEXADOK_LEN); r3_emit_dec(decl_node as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
    return R3_OK
}

/* iiis-1 Phase 3 Step 3: emit @k_max(N) runtime gate.
 * Mirrors cg_r3.c:3102-3127 byte-for-byte.  Fetches ctx's K-chain id,
 * looks up its current K via kchain_current, compares against N;
 * on K < N returns sentinel -1, on K >= N falls through.  Comparison
 * is unsigned (jae) since K is a fixed-point u64. */
fn r3_emit_kmax_check(off: u64, kmax_val: u64, decl_node: u32) -> u32 {
    r3_emit_arr(&R3_STR_K_MAX_BANNER as u64, R3_STR_K_MAX_BANNER_LEN)
    r3_emit_arr(&R3_STR_DASH_OPEN as u64, R3_STR_DASH_OPEN_LEN); r3_emit_dec(off); r3_emit_arr(&R3_STR_BPCMA_RCX as u64, R3_STR_BPCMA_RCX_LEN)
    r3_emit_arr(&R3_STR_SUB32_RSP as u64, R3_STR_SUB32_RSP_LEN)
    r3_emit_arr(&R3_STR_CALLQ_KCHAIN_ID as u64, R3_STR_CALLQ_KCHAIN_ID_LEN)
    r3_emit_arr(&R3_STR_ADD32_RSP as u64, R3_STR_ADD32_RSP_LEN)
    r3_emit_arr(&R3_STR_MOVZBQ_AL_RCX as u64, R3_STR_MOVZBQ_AL_RCX_LEN)
    r3_emit_arr(&R3_STR_SUB32_RSP as u64, R3_STR_SUB32_RSP_LEN)
    r3_emit_arr(&R3_STR_CALLQ_KCHAIN_CUR as u64, R3_STR_CALLQ_KCHAIN_CUR_LEN)
    r3_emit_arr(&R3_STR_ADD32_RSP as u64, R3_STR_ADD32_RSP_LEN)
    r3_emit_arr(&R3_STR_MOVABSQ_OPEN as u64, R3_STR_MOVABSQ_OPEN_LEN); r3_emit_hex(kmax_val); r3_emit_arr(&R3_STR_COMMA_RCX_NL as u64, R3_STR_COMMA_RCX_NL_LEN)
    r3_emit_arr(&R3_STR_CMP_RCX_RAX as u64, R3_STR_CMP_RCX_RAX_LEN)
    r3_emit_arr(&R3_STR_JAE as u64, R3_STR_JAE_LEN); r3_emit_arr(&R3_PFX_LKMAXOK as u64, R3_PFX_LKMAXOK_LEN); r3_emit_dec(decl_node as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
    r3_emit_arr(&R3_STR_MOVQ_SENTINEL_RAX as u64, R3_STR_MOVQ_SENTINEL_RAX_LEN)
    r3_emit_arr(&R3_STR_LEAVE_RET as u64, R3_STR_LEAVE_RET_LEN)
    r3_emit_arr(&R3_PFX_LKMAXOK as u64, R3_PFX_LKMAXOK_LEN); r3_emit_dec(decl_node as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
    return R3_OK
}

/* iiis-1 PE narrowing: emit bytes from a C string (e.g.,
 * III_COMPOSITION_TABLE's dispatch_fp_name).  Uses the existing
 * iii_cg_pe_name_byte accessor for each byte. */
fn r3_emit_c_str(name_addr: u64, name_len: u32) -> u32 {
    let mut i: u32 = 0u32
    while i < name_len {
        let b: u32 = iii_cg_pe_name_byte(name_addr, i)
        r3_emit_ch(b)
        i = i + 1u32
    }
    return R3_OK
}

/* iiis-1 PE direct-load emission.  Mirrors cg_r3.c's
 * cg_r3_pe_emit_direct_load byte-for-byte.  Result: TOS = fn address. */
fn r3_pe_emit_direct_load(name_addr: u64, name_len: u32) -> u32 {
    r3_emit_arr(&R3_CMT_PE_DIRECT_LOAD as u64, R3_CMT_PE_DIRECT_LOAD_LEN); r3_emit_c_str(name_addr, name_len); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
    r3_emit_arr(&R3_STR_LEAQ as u64, R3_STR_LEAQ_LEN); r3_emit_c_str(name_addr, name_len); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN)
    r3_push_rax()
    return R3_OK
}

/* iiis-1 PE slot recording: store (slot_idx → fn_name) for later
 * indirect-call elision.  Used when STMT_LET initializer is a
 * statically-resolvable resolve() call. */
fn r3_pe_record_static_fp(slot: u32, name_addr: u64, name_len: u32) -> u32 {
    if R3_PE_COUNT >= 64u32 { return R3_OK }
    R3_PE_SLOT[R3_PE_COUNT] = slot
    R3_PE_NAME_ADDR[R3_PE_COUNT] = name_addr
    R3_PE_NAME_LEN[R3_PE_COUNT] = name_len
    R3_PE_COUNT = R3_PE_COUNT + 1u32
    return R3_OK
}

/* iiis-1 PE slot lookup.  Returns the (recorded) name_addr or 0 if
 * no match.  R3_G_PE_NAME_LEN is set as a side-effect for callers. */
var R3_G_PE_NAME_LEN : u32 = 0u32
fn r3_pe_get_static_fp(slot: u32) -> u64 {
    let mut i: u32 = 0u32
    while i < R3_PE_COUNT {
        if R3_PE_SLOT[i] == slot {
            R3_G_PE_NAME_LEN = R3_PE_NAME_LEN[i]
            return R3_PE_NAME_ADDR[i]
        }
        i = i + 1u32
    }
    R3_G_PE_NAME_LEN = 0u32
    return 0u64
}

/* iiis-1 PE detect: returns 1 if EXPR_CALL is a static-resolvable
 * `resolve(set, intent, ctx)` and emits the direct leaq sequence.
 * Returns 0 if no narrowing applicable. */
fn r3_try_pe_resolve(call_node: u32, callee: u32, argc: u32) -> u32 {
    if argc != 3u32 { return 0u32 }
    let ck: u32 = iii_ast_node_kind(R3_G_AST, callee)
    if ck != R3_K_EXPR_IDENT { return 0u32 }
    let co: u32 = iii_ast_ident_name_offset(R3_G_AST, callee)
    let cl: u32 = iii_ast_ident_name_length(R3_G_AST, callee)
    if r3_name_eq_lit(co, cl, &R3_LIT_RESOLVE as u64, R3_LIT_RESOLVE_LEN) != 1u32 { return 0u32 }
    let intent_arg: u32 = iii_ast_call_arg_at(R3_G_AST, call_node, 1u32)
    let fn_name: u64 = iii_cg_pe_classify_intent(R3_G_AST, intent_arg)
    if fn_name == 0u64 { return 0u32 }
    let nlen: u32 = iii_cg_pe_name_len(fn_name)
    r3_pe_emit_direct_load(fn_name, nlen)
    return 1u32
}

/* iiis-1 PE multi-stmt narrowing: classify a STMT_LET initializer to
 * see if it should be recorded as a static fp.  Returns the fn_name
 * pointer or 0.  Used by STMT_LET after the store. */
fn r3_pe_classify_let_value(value_node: u32) -> u64 {
    if value_node == 0u32 { return 0u64 }
    let vk: u32 = iii_ast_node_kind(R3_G_AST, value_node)
    if vk != R3_K_EXPR_CALL { return 0u64 }
    let v_callee: u32 = iii_ast_call_callee(R3_G_AST, value_node)
    let v_argc: u32 = iii_ast_call_arg_count(R3_G_AST, value_node)
    if v_argc != 3u32 { return 0u64 }
    let ck: u32 = iii_ast_node_kind(R3_G_AST, v_callee)
    if ck != R3_K_EXPR_IDENT { return 0u64 }
    let co: u32 = iii_ast_ident_name_offset(R3_G_AST, v_callee)
    let cl: u32 = iii_ast_ident_name_length(R3_G_AST, v_callee)
    if r3_name_eq_lit(co, cl, &R3_LIT_RESOLVE as u64, R3_LIT_RESOLVE_LEN) != 1u32 { return 0u64 }
    let intent_arg: u32 = iii_ast_call_arg_at(R3_G_AST, value_node, 1u32)
    return iii_cg_pe_classify_intent(R3_G_AST, intent_arg)
}

/* iiis-1 PE direct-call (multi-stmt) is implemented INLINE in the
 * EXPR_CALL callq-selection (pe_hit branch), mirroring cg_r3.c's
 * single-flow 3-way callq branch (cg_r3.c:1718-1779).  The former
 * separate no-op stub was removed: it was structurally wrong (called
 * before arg-eval/shadow, so it could not emit a correct call) and is
 * now superseded by the real inline implementation. */

/* iiis-1 @dynamic ripple decode.  Returns ripple mode encoded as:
 *   0 = unset / @dynamic absent
 *   1 = off
 *   2 = manual
 *   3 = auto (default when @dynamic present without explicit ripple arg)
 * Mirrors cg_r3.c's sema decoding via AST-modifier walk.  No sema-state
 * needed; iii reads modifiers directly from AST. */
fn r3_get_dynamic_mode(fn_decl_node: u32) -> u32 {
    let m: u32 = r3_mod_find(fn_decl_node, R3_K_FN_DECL, &R3_MOD_DYNAMIC as u64, R3_MOD_DYNAMIC_LEN)
    if m == 0u32 { return 0u32 }
    let ac: u32 = iii_ast_modifier_arg_count(R3_G_AST, m)
    let mut j: u32 = 0u32
    while j < ac {
        let arg: u32 = iii_ast_modifier_arg_at(R3_G_AST, m, j)
        let an_off: u32 = iii_ast_arg_name_off(R3_G_AST, arg)
        let an_len: u32 = iii_ast_arg_name_len(R3_G_AST, arg)
        if r3_name_eq_lit(an_off, an_len, &R3_MOD_RIPPLE as u64, R3_MOD_RIPPLE_LEN) == 1u32 {
            let v: u32 = iii_ast_arg_value(R3_G_AST, arg)
            let vk: u32 = iii_ast_node_kind(R3_G_AST, v)
            if vk == R3_K_EXPR_IDENT {
                let id_off: u32 = iii_ast_ident_name_offset(R3_G_AST, v)
                let id_len: u32 = iii_ast_ident_name_length(R3_G_AST, v)
                if r3_name_eq_lit(id_off, id_len, &R3_LIT_AUTO as u64, R3_LIT_AUTO_LEN) == 1u32 { return 3u32 }
                if r3_name_eq_lit(id_off, id_len, &R3_LIT_MANUAL as u64, R3_LIT_MANUAL_LEN) == 1u32 { return 2u32 }
                if r3_name_eq_lit(id_off, id_len, &R3_LIT_OFF as u64, R3_LIT_OFF_LEN) == 1u32 { return 1u32 }
            }
        }
        j = j + 1u32
    }
    /* @dynamic present without explicit ripple — default AUTO. */
    return 3u32
}

/* iiis-1 @dynamic ripple-stub emission.  Mirrors cg_r3.c:2997-3006
 * byte-for-byte.  Emits 4 lines (banner + 3 instr) only when mode
 * is set and not OFF — matching the C SEMA_DYNAMIC_RIPPLE_UNSET/OFF
 * guard.  decl_node is the FN_DECL's AST node id, used as the first
 * argument to ripple_execute_native. */
fn r3_emit_dynamic_stub(decl_node: u32) -> u32 {
    if decl_node == 0u32 { return R3_OK }
    let dk: u32 = iii_ast_node_kind(R3_G_AST, decl_node)
    if dk != R3_K_FN_DECL { return R3_OK }
    let mode: u32 = r3_get_dynamic_mode(decl_node)
    if mode == 0u32 { return R3_OK }
    if mode == 1u32 { return R3_OK }
    r3_emit_arr(&R3_CMT_DYN_STUB as u64, R3_CMT_DYN_STUB_LEN)
    r3_emit_arr(&R3_STR_MOVABSQ_DEC as u64, R3_STR_MOVABSQ_DEC_LEN); r3_emit_dec(decl_node as u64); r3_emit_arr(&R3_STR_COMMA_RCX_NL as u64, R3_STR_COMMA_RCX_NL_LEN)
    r3_emit_arr(&R3_STR_MOVL_DOLR as u64, R3_STR_MOVL_DOLR_LEN); r3_emit_dec(mode as u64); r3_emit_arr(&R3_STR_COMMA_EDX_NL as u64, R3_STR_COMMA_EDX_NL_LEN)
    r3_emit_arr(&R3_STR_CALLQ_RIPPLE as u64, R3_STR_CALLQ_RIPPLE_LEN)
    return R3_OK
}

/* iiis-1 Phase 3 Step 3: dispatch all runtime annotation checks.
 * Called from r3_emit_function after param spill, before body emit.
 * Mirrors cg_r3.c:3008-3131 with explicit C order: cap → hexad → kmax. */
fn r3_emit_runtime_checks(decl_node: u32) -> u32 {
    if decl_node == 0u32 { return R3_OK }
    let dk: u32 = iii_ast_node_kind(R3_G_AST, decl_node)
    if dk != R3_K_FN_DECL { return R3_OK }
    let mask: u64 = r3_fn_mod_extract_u64(decl_node, &R3_MOD_CAP_REQ as u64, R3_MOD_CAP_REQ_LEN)
    let has_cap: u32 = R3_G_MOD_FOUND
    let hex: u64 = r3_fn_mod_extract_u64(decl_node, &R3_MOD_HEXAD_KIND as u64, R3_MOD_HEXAD_KIND_LEN)
    let has_hex: u32 = R3_G_MOD_FOUND
    let kmax: u64 = r3_fn_mod_extract_u64(decl_node, &R3_MOD_K_MAX as u64, R3_MOD_K_MAX_LEN)
    let has_kmx: u32 = R3_G_MOD_FOUND
    if has_cap == 0u32 { if has_hex == 0u32 { if has_kmx == 0u32 { return R3_OK } } }
    let ctx_idx: u32 = r3_find_ctx_slot(decl_node)
    if ctx_idx == 4294967295u32 { return R3_OK }
    let off: u64 = ((ctx_idx + 1u32) * 8u32) as u64
    if has_cap == 1u32 { r3_emit_cap_check(off, mask, decl_node) }
    if has_hex == 1u32 { r3_emit_hexad_check(off, hex, decl_node) }
    if has_kmx == 1u32 { r3_emit_kmax_check(off, kmax, decl_node) }
    return R3_OK
}

fn r3_emit_function(node: u32, kind: u32) -> u32 {
    R3_G_LOCAL_COUNT = 0u32; R3_G_STACK_DEPTH = 0u32; R3_G_MAX_STACK_DEPTH = 0u32; R3_G_DEFINED_LABEL_COUNT = 0u32
    R3_PE_COUNT = 0u32
    R3_G_CUR_DECL_NODE = node
    r3_chk_sovereign(node, kind)
    if kind == R3_K_CYCLE_DECL { R3_G_CUR_IS_CYCLE = 1u32 } else { R3_G_CUR_IS_CYCLE = 0u32 }
    R3_G_CUR_EXPORT = r3_decl_is_exported(node, kind)
    let name_off: u32 = r3_get_name_off(node, kind)
    let name_len: u32 = r3_get_name_len(node, kind)
    let pc: u32 = r3_get_param_count(node, kind)
    let body: u32 = r3_get_body(node, kind)
    /* D9: ring-3 note section + asciz combined (matches C cg_r3.c emit_function exactly) */
    let src: u64 = iii_ast_source_buf(R3_G_AST)
    r3_emit_arr(&R3_K_RING3_ASCIZ as u64, R3_K_RING3_ASCIZ_LEN)
    if R3_SPEC_ACTIVE == 1u32 { r3_emit_spec_symbol(name_off, name_len) } else {
        let mut ni: u32 = 0u32
        while ni < name_len { let b: u32 = iii_emit_buf_read_u8_c(src, (name_off + ni) as u64); if b == 34u32 { r3_emit_ch(95u32) } else { if b == 92u32 { r3_emit_ch(95u32) } else { r3_emit_ch(b) } }; ni = ni + 1u32 }
    }
    r3_emit_arr(&R3_K_DQUOTE_NL as u64, R3_K_DQUOTE_NL_LEN)
    /* .text\n    .global <name>\n */
    r3_emit_arr(&R3_K_TEXT_GLOB as u64, R3_K_TEXT_GLOB_LEN); r3_emit_fn_symbol(name_off, name_len, R3_G_CUR_EXPORT); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
    /*     .seh_proc <name>\n */
    r3_emit_arr(&R3_STR_SEH_PROC as u64, R3_STR_SEH_PROC_LEN); r3_emit_fn_symbol(name_off, name_len, R3_G_CUR_EXPORT); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
    /* <name>:\n */
    r3_emit_fn_symbol(name_off, name_len, R3_G_CUR_EXPORT)
    r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
    r3_audit_sovereign(node, kind)
    /* prologue (C emits in this exact order: pushq, seh_pushreg, movq, seh_setframe, subq, seh_stackalloc, seh_endprologue) */
    r3_emit_arr(&R3_K_PUSHRBP as u64, R3_K_PUSHRBP_LEN)
    r3_emit_arr(&R3_STR_SEH_PUSHRBP as u64, R3_STR_SEH_PUSHRBP_LEN)
    r3_emit_arr(&R3_STR_MOVRSPRBP as u64, R3_STR_MOVRSPRBP_LEN)
    r3_emit_arr(&R3_STR_SEH_SETFRAME as u64, R3_STR_SEH_SETFRAME_LEN)
    r3_emit_arr(&R3_STR_SUBRSP as u64, R3_STR_SUBRSP_LEN); r3_emit_arr(&R3_K_FRAME1024 as u64, R3_K_FRAME1024_LEN); r3_emit_arr(&R3_K_RSPLOCALS as u64, R3_K_RSPLOCALS_LEN)
    r3_emit_arr(&R3_STR_SEH_STKALLOC as u64, R3_STR_SEH_STKALLOC_LEN); r3_emit_arr(&R3_K_FRAME1024 as u64, R3_K_FRAME1024_LEN); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
    r3_emit_arr(&R3_STR_SEH_ENDPRO as u64, R3_STR_SEH_ENDPRO_LEN)
    if R3_G_CUR_IS_CYCLE != 0u32 { r3_emit_arr(&R3_CMT_WIT_ENTER as u64, R3_CMT_WIT_ENTER_LEN) }
    /* Spill MS x64 first 4 params + stack args 4+ */
    let mut spi: u32 = 0u32
    let mut pmax: u32 = pc
    if pc > 4u32 { pmax = 4u32 }
    while spi < pmax {
        let p: u32 = r3_get_param_at(node, kind, spi)
        let off: u32 = iii_ast_param_name_off(R3_G_AST, p)
        let len: u32 = iii_ast_param_name_len(R3_G_AST, p)
        r3_local_add(off, len)
        let s: u32 = R3_G_LOCAL_COUNT - 1u32
        r3_emit_arr(&R3_STR_MOVQ_PCT as u64, R3_STR_MOVQ_PCT_LEN)
        if spi == 0u32 { r3_emit_arr(&R3_REG_RCX as u64, R3_REG_RCX_LEN - 1u64) }
        if spi == 1u32 { r3_emit_arr(&R3_REG_RDX as u64, R3_REG_RDX_LEN - 1u64) }
        if spi == 2u32 { r3_emit_arr(&R3_REG_R8 as u64, R3_REG_R8_LEN - 1u64) }
        if spi == 3u32 { r3_emit_arr(&R3_REG_R9 as u64, R3_REG_R9_LEN - 1u64) }
        r3_emit_arr(&R3_STR_COMMA_DASH as u64, R3_STR_COMMA_DASH_LEN); r3_emit_dec(((s+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_RBP_NL as u64, R3_STR_RBP_NL_LEN)
        spi = spi + 1u32
    }
    let mut spj: u32 = 4u32
    while spj < pc {
        let p2: u32 = r3_get_param_at(node, kind, spj)
        let off2: u32 = iii_ast_param_name_off(R3_G_AST, p2)
        let len2: u32 = iii_ast_param_name_len(R3_G_AST, p2)
        r3_local_add(off2, len2)
        let s2: u32 = R3_G_LOCAL_COUNT - 1u32
        /* iiis-1 bit-identity FIX: stack-args (params 5+) live ABOVE rbp
         * at offset 48 + (i-4)*8 (caller's stack args).  cg_r3.c emits
         * `movq 48(%rbp), %rax` (positive offset).  Use R3_STR_MOVQ_PFX
         * (clean "    movq " with no trailing dash or percent). */
        r3_emit_arr(&R3_STR_MOVQ_PFX as u64, R3_STR_MOVQ_PFX_LEN); r3_emit_dec((48u32 + (spj - 4u32) * 8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN)
        r3_emit_arr(&R3_STR_MOVQ_RAX_C as u64, R3_STR_MOVQ_RAX_C_LEN); r3_emit_ch(45u32); r3_emit_dec(((s2+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_RBP_NL as u64, R3_STR_RBP_NL_LEN)
        spj = spj + 1u32
    }
    /* iiis-1 Phase 3 Step 3: runtime annotation enforcement.
     * Mirrors cg_r3.c:3008-3131 emission order (cap → hexad → kmax).
     * Only fires for FN_DECL with one or more of @cap_required /
     * @hexad_kind / @k_max AND a param named "ctx". */
    r3_emit_runtime_checks(node)
    /* iiis-1 @dynamic ripple-stub: ported via AST-modifier inspection
     * (no sema-state required).  Emits when @dynamic present with
     * ripple mode != UNSET && != OFF.  Mirrors cg_r3.c:2997-3006. */
    r3_emit_dynamic_stub(node)

    /* XII gate (Phase XII-eta).  If this function carries @lattice,
     * dispatch its body to the XII codegen pipeline: canonicalise the
     * AST -> XII term, compute the circumstance encoding, and emit a
     * Lattice placeholder + call-site descriptor that LDIL will fill
     * in.  Otherwise, fall through to the legacy block emitter. */
    let xii_lat : u8 = sema_xii_anno_has_in_ast(R3_G_AST, node, R3_XII_ANNO_LATTICE)
    if xii_lat == 1u8 {
        xii_set_current_sema_state(R3_G_SEMA)
        r3_pe_canonicalise(R3_G_SEMA, node as u64)
        let xii_circ : u32 = r3_compute_circ(R3_G_SEMA, node as u64)
        r3_pe_lattice_emit(R3_G_SEMA, node as u64, xii_circ)
        xii_set_current_sema_state(0u64)
    } else {
        r3_emit_block(body)
    }
    if R3_G_CUR_IS_CYCLE != 0u32 { r3_emit_arr(&R3_CMT_WIT_EXIT as u64, R3_CMT_WIT_EXIT_LEN) }
    /* implicit return + epilogue (C order: implret -> mov rbp,rsp -> popq rbp -> retq -> seh_endproc) */
    r3_emit_arr(&R3_K_IMPLRET as u64, R3_K_IMPLRET_LEN)
    r3_emit_arr(&R3_K_MOVRBPRSP as u64, R3_K_MOVRBPRSP_LEN)
    r3_emit_arr(&R3_K_POPRBP as u64, R3_K_POPRBP_LEN)
    r3_emit_arr(&R3_K_RETQ as u64, R3_K_RETQ_LEN)
    r3_emit_arr(&R3_STR_SEH_ENDPROC as u64, R3_STR_SEH_ENDPROC_LEN)
    return R3_OK
}

fn r3_emit_string_pool() -> u32 {
    let n: u32 = iii_ast_string_payload_count_c(R3_G_AST)
    r3_emit_arr(&R3_K_RODATA as u64, R3_K_RODATA_LEN)
    let mut i: u32 = 0u32
    while i < n {
        r3_emit_str_label(i); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
        let addr: u64 = iii_ast_string_payload_addr_c(R3_G_AST, i)
        if addr != 0u64 {
            r3_emit_arr(&R3_K_ASCII_PRE as u64, R3_K_ASCII_PRE_LEN)
            let mut k: u64 = 0u64
            while iii_emit_buf_read_u8_c(addr, k) != 0u32 {
                let b: u32 = iii_emit_buf_read_u8_c(addr, k)
                if b == 34u32 { r3_emit_arr(&R3_K_ESC_BS as u64, R3_K_ESC_BS_LEN); r3_emit_ch(34u32) }
                if b == 92u32 { r3_emit_arr(&R3_K_ESC_BS as u64, R3_K_ESC_BS_LEN); r3_emit_ch(92u32) }
                if b == 10u32 { r3_emit_arr(&R3_K_ESC_N as u64, R3_K_ESC_N_LEN) }
                if r3_byte_is_plain(b) == 1u32 { r3_emit_ch(b) }
                if r3_byte_needs_octal(b) == 1u32 { r3_emit_arr(&R3_K_ESC_BS as u64, R3_K_ESC_BS_LEN); r3_emit_ch(48u32 + ((b / 64u32) % 8u32)); r3_emit_ch(48u32 + ((b / 8u32) % 8u32)); r3_emit_ch(48u32 + (b % 8u32)) }
                k = k + 1u64
            }
            r3_emit_arr(&R3_K_ASCII_END as u64, R3_K_ASCII_END_LEN)
        }
        i = i + 1u32
    }
    return R3_OK
}

/* helper: emit `.global <label>\n<label>:\n` for a decl name */
fn r3_emit_global_decl_label(off: u32, len: u32) -> u32 {
    r3_emit_arr(&R3_K_GLOBAL_PFX as u64, R3_K_GLOBAL_PFX_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
    r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
    return R3_OK
}

/* Stage 3.18: emit `<label>:\n` only (module-LOCAL symbol, no .global) for a
 * decl name.  Used for module-scope const decls -- a const is private (no
 * @export possible; never cross-referenced), so a local symbol avoids the
 * cross-module L_<name> link collision while intra-module RIP refs resolve. */
fn r3_emit_local_decl_label(off: u32, len: u32) -> u32 {
    r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN)
    return R3_OK
}

/* helper: select byte-exact .<dir> 0x prefix matching gas width */
fn r3_emit_gas_data_hex(width: u32) -> u32 {
    if width == 1u32 { r3_emit_arr(&R3_K_BYTE0X as u64, R3_K_BYTE0X_LEN); return R3_OK }
    if width == 2u32 { r3_emit_arr(&R3_K_SHORT0X as u64, R3_K_SHORT0X_LEN); return R3_OK }
    if width == 4u32 { r3_emit_arr(&R3_K_LONG0X as u64, R3_K_LONG0X_LEN); return R3_OK }
    r3_emit_arr(&R3_K_QUAD0X as u64, R3_K_QUAD0X_LEN); return R3_OK
}

/* helper: returns 1 iff byte must be emitted as 3-digit octal in .ascii payload */
fn r3_byte_needs_octal(b: u32) -> u32 {
    if b == 34u32 { return 0u32 }
    if b == 92u32 { return 0u32 }
    if b == 10u32 { return 0u32 }
    if b < 32u32 { return 1u32 }
    if b >= 127u32 { return 1u32 }
    return 0u32
}

/* helper: returns 1 iff byte is a plain printable that should pass through as itself */
fn r3_byte_is_plain(b: u32) -> u32 {
    if b == 34u32 { return 0u32 }
    if b == 92u32 { return 0u32 }
    if b == 10u32 { return 0u32 }
    if b < 32u32 { return 0u32 }
    if b >= 127u32 { return 0u32 }
    return 1u32
}

/* Extract literal u64 from EXPR_INT, EXPR_HEX, or unary-NEG of those. Returns 1 on success, 0 on fail. */
var R3_LIT_VALUE: u64 = 0u64

fn r3_lit_u64_compute(node: u32) -> u32 {
    R3_LIT_VALUE = 0u64
    if node == 0u32 { return 0u32 }
    let k: u32 = iii_ast_node_kind(R3_G_AST, node)
    if k == R3_K_EXPR_INT { R3_LIT_VALUE = iii_ast_expr_int_u64(R3_G_AST, node); return 1u32 }
    if k == R3_K_EXPR_HEX { let lo: u64 = iii_ast_hex_value_lo(R3_G_AST, node) as u64; let hi: u64 = iii_ast_hex_value_hi(R3_G_AST, node) as u64; R3_LIT_VALUE = lo | (hi << 32u64); return 1u32 }
    if k == R3_K_EXPR_UNARY {
        let op: u32 = iii_ast_unary_op(R3_G_AST, node)
        if op == 1u32 {
            let inner: u32 = iii_ast_unary_operand(R3_G_AST, node)
            let ik: u32 = iii_ast_node_kind(R3_G_AST, inner)
            if ik == R3_K_EXPR_INT { let b: u64 = iii_ast_expr_int_u64(R3_G_AST, inner); R3_LIT_VALUE = 0u64 - b; return 1u32 }
            if ik == R3_K_EXPR_HEX { let lo2: u64 = iii_ast_hex_value_lo(R3_G_AST, inner) as u64; let hi2: u64 = iii_ast_hex_value_hi(R3_G_AST, inner) as u64; let bb: u64 = lo2 | (hi2 << 32u64); R3_LIT_VALUE = 0u64 - bb; return 1u32 }
        }
    }
    return 0u32
}

fn r3_emit_data_decls() -> u32 {
    let root: u32 = iii_ast_root_module(R3_G_AST); if root == 0u32 { return R3_OK }
    let dc: u32 = iii_ast_module_decl_count(R3_G_AST, root)
    /* current_section: 0=none, 1=.rodata, 2=.data, 3=.bss */
    let mut current_section: u32 = 0u32
    let mut i: u32 = 0u32
    while i < dc {
        let d: u32 = iii_ast_module_decl_at(R3_G_AST, root, i)
        let dk: u32 = iii_ast_node_kind(R3_G_AST, d)
        if dk == R3_K_CONST_DECL {
            let v: u32 = iii_ast_const_decl_value(R3_G_AST, d)
            let vk: u32 = iii_ast_node_kind(R3_G_AST, v)
            let no: u32 = iii_ast_const_decl_name_off(R3_G_AST, d)
            let nl: u32 = iii_ast_const_decl_name_len(R3_G_AST, d)
            if vk == R3_K_EXPR_PARALLEL {
                let vt: u32 = iii_ast_const_decl_type(R3_G_AST, d)
                let mut ew: u32 = 8u32
                if vt != 0u32 { let tk: u32 = iii_ast_node_kind(R3_G_AST, vt); if tk == R3_K_TYPE_ARR { ew = r3_array_elem_byte_size(vt) } }
                if current_section != 1u32 { r3_emit_arr(&R3_K_RODATA as u64, R3_K_RODATA_LEN); current_section = 1u32 }
                r3_emit_local_decl_label(no, nl)
                let bc: u32 = iii_ast_parallel_branch_count(R3_G_AST, v)
                let mut k: u32 = 0u32
                while k < bc { let eid: u32 = iii_ast_parallel_branch_at(R3_G_AST, v, k); r3_lit_u64_compute(eid); r3_emit_gas_data_hex(ew); r3_emit_hex(R3_LIT_VALUE); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN); k = k + 1u32 }
            } else {
                let okv: u32 = r3_lit_u64_compute(v)
                if okv == 1u32 {
                    if current_section != 1u32 { r3_emit_arr(&R3_K_RODATA as u64, R3_K_RODATA_LEN); current_section = 1u32 }
                    r3_emit_local_decl_label(no, nl)
                    r3_emit_arr(&R3_K_QUAD0X as u64, R3_K_QUAD0X_LEN); r3_emit_hex(R3_LIT_VALUE); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
                }
            }
        }
        if dk == R3_K_VAR_DECL {
            let vno: u32 = iii_ast_var_decl_name_off(R3_G_AST, d)
            let vnl: u32 = iii_ast_var_decl_name_len(R3_G_AST, d)
            let init: u32 = iii_ast_var_decl_init(R3_G_AST, d)
            let vt: u32 = iii_ast_var_decl_type(R3_G_AST, d)
            let mut handled: u32 = 0u32
            if init != 0u32 {
                let ik: u32 = iii_ast_node_kind(R3_G_AST, init)
                if ik == R3_K_EXPR_PARALLEL {
                    let mut ew: u32 = 8u32
                    if vt != 0u32 { let tk: u32 = iii_ast_node_kind(R3_G_AST, vt); if tk == R3_K_TYPE_ARR { ew = r3_array_elem_byte_size(vt) } }
                    if current_section != 2u32 { r3_emit_arr(&R3_K_DATA as u64, R3_K_DATA_LEN); current_section = 2u32 }
                    r3_emit_global_decl_label(vno, vnl)
                    let bc2: u32 = iii_ast_parallel_branch_count(R3_G_AST, init)
                    let mut k2: u32 = 0u32
                    while k2 < bc2 { let eid2: u32 = iii_ast_parallel_branch_at(R3_G_AST, init, k2); r3_lit_u64_compute(eid2); r3_emit_gas_data_hex(ew); r3_emit_hex(R3_LIT_VALUE); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN); k2 = k2 + 1u32 }
                    handled = 1u32
                } else {
                    let okv2: u32 = r3_lit_u64_compute(init)
                    if okv2 == 1u32 {
                        if current_section != 2u32 { r3_emit_arr(&R3_K_DATA as u64, R3_K_DATA_LEN); current_section = 2u32 }
                        r3_emit_global_decl_label(vno, vnl)
                        r3_emit_arr(&R3_K_QUAD0X as u64, R3_K_QUAD0X_LEN); r3_emit_hex(R3_LIT_VALUE); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
                        handled = 1u32
                    }
                }
            }
            if handled == 0u32 {
                let mut bs: u64 = 8u64
                if vt != 0u32 { let tk: u32 = iii_ast_node_kind(R3_G_AST, vt); if tk == R3_K_TYPE_ARR { bs = (iii_ast_type_array_count(R3_G_AST, vt) as u64) * 8u64 } }
                if current_section != 3u32 { r3_emit_arr(&R3_K_BSS as u64, R3_K_BSS_LEN); current_section = 3u32 }
                r3_emit_global_decl_label(vno, vnl)
                r3_emit_arr(&R3_K_ZERO_PFX as u64, R3_K_ZERO_PFX_LEN); r3_emit_dec(bs); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
            }
        }
        i = i + 1u32
    }
    return R3_OK
}

/* ASCII constants for XII section emission (Phase XII-eta).  Single-line
 * literals per iiis-1 parser requirement.
 *   "\t.section\t" = 0x09 0x2E 0x73 0x65 0x63 0x74 0x69 0x6F 0x6E 0x09  (10 bytes)
 *   "\t.byte 0x"   = 0x09 0x2E 0x62 0x79 0x74 0x65 0x20 0x30 0x78        (9 bytes)
 *   "\t.text\n"    = 0x09 0x2E 0x74 0x65 0x78 0x74 0x0A                  (7 bytes) */
var R3_XII_DOT_SECTION : [u8; 10] = [9u8, 46u8, 115u8, 101u8, 99u8, 116u8, 105u8, 111u8, 110u8, 9u8]
const R3_XII_DOT_SECTION_LEN : u64 = 10u64
var R3_XII_DOT_BYTE_PFX : [u8; 9] = [9u8, 46u8, 98u8, 121u8, 116u8, 101u8, 32u8, 48u8, 120u8]
const R3_XII_DOT_BYTE_PFX_LEN : u64 = 9u64
var R3_XII_DOT_TEXT : [u8; 7] = [9u8, 46u8, 116u8, 101u8, 120u8, 116u8, 10u8]
const R3_XII_DOT_TEXT_LEN : u64 = 7u64

fn _xii_hex_digit(v: u32) -> u32 {
    if v < 10u32 { return 48u32 + v }
    return 87u32 + v
}

/* Emit raw bytes into a named section as a sequence of .byte directives,
 * then return to .text.  Used by the XII gate's emit_section_bytes shim
 * to populate .iii_xii_calls and .iii_xii_ldil_audit.  When R3_G_OUT is
 * not yet bound to an output stream, returns -1 (gate is unreachable in
 * iiis-1 stub path, so this never fires there). */
fn r3_emit_xii_section_bytes(name_ptr: u64, name_len: u64, bytes: u64, bytes_len: u64) -> i32 @export {
    if R3_G_OUT == 0u64 { return -1i32 }
    r3_emit_arr(&R3_XII_DOT_SECTION as u64, R3_XII_DOT_SECTION_LEN)
    r3_emit_bytes(name_ptr, name_len)
    r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
    let mut i : u64 = 0u64
    while i < bytes_len {
        r3_emit_arr(&R3_XII_DOT_BYTE_PFX as u64, R3_XII_DOT_BYTE_PFX_LEN)
        let b : u32 = iii_emit_buf_read_u8_c(bytes, i)
        let hi : u32 = (b >> 4u32) & 0xFu32
        let lo : u32 = b & 0xFu32
        r3_emit_ch(_xii_hex_digit(hi))
        r3_emit_ch(_xii_hex_digit(lo))
        r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        i = i + 1u64
    }
    r3_emit_arr(&R3_XII_DOT_TEXT as u64, R3_XII_DOT_TEXT_LEN)
    return 0i32
}

fn iii_cg_r3_create(ast: u64, sema: u64, sid: u64, walloc: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    R3_G_AST = ast; R3_G_SEMA = sema; R3_G_SID = sid; R3_G_WALLOC = walloc; R3_G_OUT = 0u64
    R3_G_LAST_ERROR = R3_OK; R3_G_ERROR_COUNT = 0u32
    R3_G_LOCAL_COUNT = 0u32; R3_G_STACK_DEPTH = 0u32; R3_G_MAX_STACK_DEPTH = 0u32; R3_G_LABEL_COUNTER = 0u32
    R3_G_DEFINED_LABEL_COUNT = 0u32; R3_DEFINED_LABEL_BUFUSE = 0u32
    R3_G_HAS_EXPECTED_WITNESS = 0u32
    iii_cg_r3_sha_init_c()
    return &R3_SENTINEL as u64
}

fn iii_cg_r3_destroy(cg: u64) -> u32 @export { R3_G_AST = 0u64; R3_G_SEMA = 0u64; R3_G_SID = 0u64; R3_G_WALLOC = 0u64; R3_G_OUT = 0u64; return R3_OK }

fn iii_cg_r3_emit_module(cg: u64, out: u64) -> u32 @export {
    if cg == 0u64 { return R3_E_NULL_ARG }
    if out == 0u64 { R3_G_LAST_ERROR = R3_E_NULL_ARG; return R3_E_NULL_ARG }
    R3_G_OUT = out
    iii_cg_r3_sha_init_c()
    R3_G_LAST_ERROR = R3_OK; R3_G_ERROR_COUNT = 0u32
    r3_emit_arr(&R3_K_HDR1 as u64, R3_K_HDR1_LEN)
    r3_emit_arr(&R3_K_HDR2 as u64, R3_K_HDR2_LEN)
    r3_emit_arr(&R3_K_ATT as u64, R3_K_ATT_LEN)
    r3_emit_arr(&R3_K_FILE as u64, R3_K_FILE_LEN)
    r3_emit_string_pool()
    r3_emit_data_decls()
    let root: u32 = iii_ast_root_module(R3_G_AST)
    if root == 0u32 { R3_G_LAST_ERROR = R3_E_INTERNAL; return R3_E_INTERNAL }
    let dc: u32 = iii_ast_module_decl_count(R3_G_AST, root)
    let mut first_err: u32 = R3_OK
    let mut j: u32 = 0u32
    while j < dc {
        let d: u32 = iii_ast_module_decl_at(R3_G_AST, root, j)
        let dk: u32 = iii_ast_node_kind(R3_G_AST, d)
        if dk == R3_K_FN_DECL { if r3_ring_ok_for_r3(d, dk) == 1u32 { let mut e: u32 = R3_OK; if r3_is_specialize_generic(d) == 1u32 { e = r3_emit_specialized_fn(d) } else { e = r3_emit_function(d, dk) }; if e != R3_OK { if first_err == R3_OK { first_err = e } } } }
        if dk == R3_K_CYCLE_DECL { if r3_ring_ok_for_r3(d, dk) == 1u32 { let e2: u32 = r3_emit_function(d, dk); if e2 != R3_OK { if first_err == R3_OK { first_err = e2 } } } }
        j = j + 1u32
    }
    iii_cg_r3_sha_snapshot_c(&R3_MHASH_CACHE as u64)
    if R3_G_HAS_EXPECTED_WITNESS != 0u32 { let cmp: i32 = iii_emit_memcmp_c(&R3_MHASH_CACHE as u64, &R3_EXPECTED_WITNESS as u64, 32u64); if cmp != 0i32 { R3_G_LAST_ERROR = R3_E_WITNESS_MISMATCH; R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32; if first_err == R3_OK { first_err = R3_E_WITNESS_MISMATCH } } }
    /* iiis-1 static type-system checks set R3_G_ERROR_COUNT but
     * intermediate emit_block/emit_stmt/emit_expr swallow return
     * values.  Propagate the codegen-level error count to the
     * caller so the build pipeline rejects sources that fail any
     * static check.  Mirrors cg_r3.c's cg->error_count semantics. */
    if first_err == R3_OK && R3_G_ERROR_COUNT > 0u32 { first_err = R3_G_LAST_ERROR }
    return first_err
}

fn iii_cg_r3_emit(cg: u64, out: u64) -> u32 @export { return iii_cg_r3_emit_module(cg, out) }