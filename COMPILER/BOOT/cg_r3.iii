fn r3_addr_is_raw_sym(ident_node: u32) -> u32 {
    let bid: u32 = iii_ast_node_binder_id(R3_G_AST, ident_node)
    if bid == 0u32 { return 0u32 }
    let bk: u32 = iii_ast_node_kind(R3_G_AST, bid)
