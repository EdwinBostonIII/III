/* ── Jump instruction prefixes (4 sp + mnemonic + sp) ── */
var R3_STR_JNZ : [u8; 8] = [32u8, 32u8, 32u8, 32u8, 106u8, 110u8, 122u8, 32u8]
const R3_STR_JNZ_LEN : u64 = 8u64

