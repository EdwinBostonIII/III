const R3_STR_CALLQ_CAP_VERIFY_LEN : u64 = 28u64

var R3_STR_CALLQ_HEXAD_KIND : [u8; 34] = [32u8, 32u8, 32u8, 32u8, 99u8, 97u8, 108u8, 108u8, 113u8, 32u8, 99u8, 97u8, 108u8, 108u8, 95u8, 99u8, 111u8, 110u8, 116u8, 101u8, 120u8, 116u8, 95u8, 104u8, 101u8, 120u8, 97u8, 100u8, 95u8, 107u8, 105u8, 110u8, 100u8, 10u8]
const R3_STR_CALLQ_HEXAD_KIND_LEN : u64 = 34u64

var R3_STR_CALLQ_KCHAIN_ID : [u8; 33] = [32u8, 32u8, 32u8, 32u8, 99u8, 97u8, 108u8, 108u8, 113u8, 32u8, 99u8, 97u8, 108u8, 108u8, 95u8, 99u8, 111u8, 110u8, 116u8, 101u8, 120u8, 116u8, 95u8, 107u8, 99u8, 104u8, 97u8, 105u8, 110u8, 95u8, 105u8, 100u8, 10u8]
