/* ─────────────── type sizing ─────────────── */
fn r3_name_eq_str(off: u32, len: u32, lit_addr: u64, lit_len: u64) -> u32 { return r3_name_eq_lit(off, len, lit_addr, lit_len) }
fn r3_type_ref_byte_size(tref: u32) -> u32 { if tref == 0u32 { return 0u32 }; let k: u32 = iii_ast_node_kind(R3_G_AST, tref); if k != R3_K_TYPE_REF { return 0u32 }; let off: u32 = iii_ast_type_ref_name_off(R3_G_AST, tref); let len: u32 = iii_ast_type_ref_name_len(R3_G_AST, tref); if len == 0u32 { return 0u32 }; if R3_SPEC_ACTIVE == 1u32 { if r3_name_eq_lit(off, len, &R3_SPEC_TP_BUF as u64, R3_SPEC_TP_LEN as u64) == 1u32 { return r3_spec_type_byte_size() } }; if len > 4u32 { return 0u32 }; if r3_name_eq_lit(off, len, &R3_TY_U8 as u64, R3_TY_U8_LEN) == 1u32 { return 1u32 }; if r3_name_eq_lit(off, len, &R3_TY_I8 as u64, R3_TY_I8_LEN) == 1u32 { return 1u32 }; if r3_name_eq_lit(off, len, &R3_TY_BOOL as u64, R3_TY_BOOL_LEN) == 1u32 { return 1u32 }; if r3_name_eq_lit(off, len, &R3_TY_U16 as u64, R3_TY_U16_LEN) == 1u32 { return 2u32 }; if r3_name_eq_lit(off, len, &R3_TY_I16 as u64, R3_TY_I16_LEN) == 1u32 { return 2u32 }; if r3_name_eq_lit(off, len, &R3_TY_U32 as u64, R3_TY_U32_LEN) == 1u32 { return 4u32 }; if r3_name_eq_lit(off, len, &R3_TY_I32 as u64, R3_TY_I32_LEN) == 1u32 { return 4u32 }; if r3_name_eq_lit(off, len, &R3_TY_U64 as u64, R3_TY_U64_LEN) == 1u32 { return 8u32 }; if r3_name_eq_lit(off, len, &R3_TY_I64 as u64, R3_TY_I64_LEN) == 1u32 { return 8u32 }; return 0u32 }
fn r3_emit_return_extend(rt: u32) -> u32 {
    if rt == 0u32 { return R3_OK }
    let rk: u32 = iii_ast_node_kind(R3_G_AST, rt)
    if rk != R3_K_TYPE_REF { return R3_OK }
    let off: u32 = iii_ast_type_ref_name_off(R3_G_AST, rt)
    let len: u32 = iii_ast_type_ref_name_len(R3_G_AST, rt)
    if len == 0u32 { return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_U8 as u64, R3_TY_U8_LEN) == 1u32 { r3_emit_arr(&R3_STR_MOVZBQ_AL_RAX as u64, R3_STR_MOVZBQ_AL_RAX_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_BOOL as u64, R3_TY_BOOL_LEN) == 1u32 { r3_emit_arr(&R3_STR_MOVZBQ_AL_RAX as u64, R3_STR_MOVZBQ_AL_RAX_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_I8 as u64, R3_TY_I8_LEN) == 1u32 { r3_emit_arr(&R3_STR_EXT_MOVSBQ as u64, R3_STR_EXT_MOVSBQ_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_U16 as u64, R3_TY_U16_LEN) == 1u32 { r3_emit_arr(&R3_STR_EXT_MOVZWQ as u64, R3_STR_EXT_MOVZWQ_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_I16 as u64, R3_TY_I16_LEN) == 1u32 { r3_emit_arr(&R3_STR_EXT_MOVSWQ as u64, R3_STR_EXT_MOVSWQ_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_U32 as u64, R3_TY_U32_LEN) == 1u32 { r3_emit_arr(&R3_STR_EXT_MOVL as u64, R3_STR_EXT_MOVL_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_I32 as u64, R3_TY_I32_LEN) == 1u32 { r3_emit_arr(&R3_STR_EXT_MOVSLQ as u64, R3_STR_EXT_MOVSLQ_LEN); return R3_OK }
    return R3_OK
}

/* iiis-1 bit-identity: cast-extend mirrors cg_r3.c's EXPR_CAST behavior
 * which is UNSIGNED-UNIFORM (no signed/unsigned distinction): u8/i8/bool
 * → movzbq, u16/i16 → movzwq, u32/i32 → movl %eax, %eax.
 * Differs from return-extend (which IS signed-aware for callee returns). */
fn r3_emit_cast_extend(rt: u32) -> u32 {
    if rt == 0u32 { return R3_OK }
    let rk: u32 = iii_ast_node_kind(R3_G_AST, rt)
    if rk != R3_K_TYPE_REF { return R3_OK }
    let off: u32 = iii_ast_type_ref_name_off(R3_G_AST, rt)
    let len: u32 = iii_ast_type_ref_name_len(R3_G_AST, rt)
    if len == 0u32 { return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_U8 as u64, R3_TY_U8_LEN) == 1u32 { r3_emit_arr(&R3_STR_MOVZBQ_AL_RAX as u64, R3_STR_MOVZBQ_AL_RAX_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_BOOL as u64, R3_TY_BOOL_LEN) == 1u32 { r3_emit_arr(&R3_STR_MOVZBQ_AL_RAX as u64, R3_STR_MOVZBQ_AL_RAX_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_I8 as u64, R3_TY_I8_LEN) == 1u32 { r3_emit_arr(&R3_STR_MOVZBQ_AL_RAX as u64, R3_STR_MOVZBQ_AL_RAX_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_U16 as u64, R3_TY_U16_LEN) == 1u32 { r3_emit_arr(&R3_STR_EXT_MOVZWQ as u64, R3_STR_EXT_MOVZWQ_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_I16 as u64, R3_TY_I16_LEN) == 1u32 { r3_emit_arr(&R3_STR_EXT_MOVZWQ as u64, R3_STR_EXT_MOVZWQ_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_U32 as u64, R3_TY_U32_LEN) == 1u32 { r3_emit_arr(&R3_STR_EXT_MOVL as u64, R3_STR_EXT_MOVL_LEN); return R3_OK }
    if r3_name_eq_lit(off, len, &R3_TY_I32 as u64, R3_TY_I32_LEN) == 1u32 { r3_emit_arr(&R3_STR_EXT_MOVL as u64, R3_STR_EXT_MOVL_LEN); return R3_OK }
    return R3_OK
}
fn r3_array_elem_byte_size(tarr: u32) -> u32 { if tarr == 0u32 { return 8u32 }; let k: u32 = iii_ast_node_kind(R3_G_AST, tarr); if k != R3_K_TYPE_ARR { return 8u32 }; let inner: u32 = iii_ast_type_array_inner(R3_G_AST, tarr); let w: u32 = r3_type_ref_byte_size(inner); if w == 0u32 { return 8u32 }; return w }
fn r3_index_obj_is_byte(obj_node: u32) -> u32 {
    let ek: u32 = r3_index_obj_elem_kind(obj_node)
    if ek == 1u32 { return 1u32 }
    if ek == 2u32 { return 1u32 }
    return 0u32
}

/* iiis-1 width-aware indexed element kind dispatcher.
 * Returns 0-6 to pick the correct movzbq/movsbq/movzwq/movswq/movl/movslq
 * variant for indexed load (and movb/movw/movl/movq scale for store).
 * Mirrors cg_r3.c's pointer_element_width + element_is_signed_int. */
fn r3_index_obj_elem_kind(obj_node: u32) -> u32 {
    if obj_node == 0u32 { return 0u32 }
    let ok: u32 = iii_ast_node_kind(R3_G_AST, obj_node)
    if ok == R3_K_EXPR_STR { return 1u32 }
    if ok != R3_K_EXPR_IDENT { return 0u32 }
    let bid: u32 = iii_ast_node_binder_id(R3_G_AST, obj_node)
    if bid == 0u32 { return 0u32 }
    let bk: u32 = iii_ast_node_kind(R3_G_AST, bid)
    let mut tnode: u32 = 0u32
    if bk == R3_K_STMT_LET { tnode = iii_ast_let_type(R3_G_AST, bid) }
    if bk == R3_K_PARAM { tnode = iii_ast_param_type(R3_G_AST, bid) }
    if bk == R3_K_VAR_DECL { tnode = iii_ast_var_decl_type(R3_G_AST, bid) }
    if tnode == 0u32 { return 0u32 }
    let tk: u32 = iii_ast_node_kind(R3_G_AST, tnode)
    let mut inner: u32 = 0u32
    if tk == R3_K_TYPE_PTR { inner = iii_ast_type_ptr_inner(R3_G_AST, tnode) }
    if tk == R3_K_TYPE_ARR { inner = iii_ast_type_array_inner(R3_G_AST, tnode) }
    if inner == 0u32 { return 0u32 }
    let ik: u32 = iii_ast_node_kind(R3_G_AST, inner)
    if ik != R3_K_TYPE_REF { return 0u32 }
    let no: u32 = iii_ast_type_ref_name_off(R3_G_AST, inner)
    let nl: u32 = iii_ast_type_ref_name_len(R3_G_AST, inner)
    if R3_SPEC_ACTIVE == 1u32 { if r3_name_eq_lit(no, nl, &R3_SPEC_TP_BUF as u64, R3_SPEC_TP_LEN as u64) == 1u32 { return r3_spec_type_elem_kind() } }
    if r3_name_eq_lit(no, nl, &R3_TY_U8 as u64, R3_TY_U8_LEN) == 1u32 { return 1u32 }
    if r3_name_eq_lit(no, nl, &R3_TY_BOOL as u64, R3_TY_BOOL_LEN) == 1u32 { return 1u32 }
    if r3_name_eq_lit(no, nl, &R3_TY_I8 as u64, R3_TY_I8_LEN) == 1u32 { return 2u32 }
    if r3_name_eq_lit(no, nl, &R3_TY_U16 as u64, R3_TY_U16_LEN) == 1u32 { return 3u32 }
    if r3_name_eq_lit(no, nl, &R3_TY_I16 as u64, R3_TY_I16_LEN) == 1u32 { return 4u32 }
    if r3_name_eq_lit(no, nl, &R3_TY_U32 as u64, R3_TY_U32_LEN) == 1u32 { return 5u32 }
    if r3_name_eq_lit(no, nl, &R3_TY_I32 as u64, R3_TY_I32_LEN) == 1u32 { return 6u32 }
    return 0u32
}

/* Emit the indexed load instruction for the given element kind. */
fn r3_emit_indexed_load(ek: u32) -> u32 {
    if ek == 1u32 { r3_emit_arr(&R3_STR_INDEX_LD_B as u64, R3_STR_INDEX_LD_B_LEN); return R3_OK }
    if ek == 2u32 { r3_emit_arr(&R3_STR_INDEX_LD_SB as u64, R3_STR_INDEX_LD_SB_LEN); return R3_OK }
    if ek == 3u32 { r3_emit_arr(&R3_STR_INDEX_LD_W as u64, R3_STR_INDEX_LD_W_LEN); return R3_OK }
    if ek == 4u32 { r3_emit_arr(&R3_STR_INDEX_LD_SW as u64, R3_STR_INDEX_LD_SW_LEN); return R3_OK }
    if ek == 5u32 { r3_emit_arr(&R3_STR_INDEX_LD_L as u64, R3_STR_INDEX_LD_L_LEN); return R3_OK }
    if ek == 6u32 { r3_emit_arr(&R3_STR_INDEX_LD_SL as u64, R3_STR_INDEX_LD_SL_LEN); return R3_OK }
    r3_emit_arr(&R3_STR_INDEX_LD as u64, R3_STR_INDEX_LD_LEN); return R3_OK
}

/* Emit the indexed store instruction for the given element kind.
 * Stores don't distinguish signed-vs-unsigned (just width). */
fn r3_emit_indexed_store(ek: u32) -> u32 {
    if ek == 1u32 { r3_emit_arr(&R3_STR_INDEX_ST_B as u64, R3_STR_INDEX_ST_B_LEN); return R3_OK }
    if ek == 2u32 { r3_emit_arr(&R3_STR_INDEX_ST_B as u64, R3_STR_INDEX_ST_B_LEN); return R3_OK }
    if ek == 3u32 { r3_emit_arr(&R3_STR_INDEX_ST_W as u64, R3_STR_INDEX_ST_W_LEN); return R3_OK }
    if ek == 4u32 { r3_emit_arr(&R3_STR_INDEX_ST_W as u64, R3_STR_INDEX_ST_W_LEN); return R3_OK }
    if ek == 5u32 { r3_emit_arr(&R3_STR_INDEX_ST_L as u64, R3_STR_INDEX_ST_L_LEN); return R3_OK }
    if ek == 6u32 { r3_emit_arr(&R3_STR_INDEX_ST_L as u64, R3_STR_INDEX_ST_L_LEN); return R3_OK }
    r3_emit_arr(&R3_STR_INDEX_ST as u64, R3_STR_INDEX_ST_LEN); return R3_OK
}
fn r3_emit_gas_data(width: u32) -> u32 { if width == 1u32 { r3_emit_arr(&R3_STR_BYTE as u64, R3_STR_BYTE_LEN); return R3_OK }; if width == 2u32 { r3_emit_arr(&R3_STR_SHORT as u64, R3_STR_SHORT_LEN); return R3_OK }; if width == 4u32 { r3_emit_arr(&R3_STR_LONG as u64, R3_STR_LONG_LEN); return R3_OK }; r3_emit_arr(&R3_STR_QUAD as u64, R3_STR_QUAD_LEN); return R3_OK }

extern @abi(c-msvc-x64) fn iii_sema_struct_decl_for_name(s: u64, name: u64) -> u32 from "sema.c"
extern @abi(c-msvc-x64) fn iii_sema_struct_field_slot(s: u64, struct_decl: u32, name: u64) -> i32 from "sema.c"
extern @abi(c-msvc-x64) fn iii_sema_struct_size_slots(s: u64, struct_decl: u32) -> u32 from "sema.c"
/* iii_sema_anno_dynamic_ripple_mode: extern removed; sema.iii doesn't export it. */
var R3_FIELD_TNM : [u8; 64] = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8]
var R3_FIELD_FNM : [u8; 64] = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8]
var R3_ZERO_BYTE : [u8; 1] = [0u8]
fn r3_copy_to_cstr(buf_addr: u64, src_off: u32, len: u32) -> u32 {
    if len >= 64u32 { return 1u32 }
    let src: u64 = iii_ast_source_buf(R3_G_AST)
    iii_emit_memcpy_c(buf_addr, src + (src_off as u64), len as u64)
    iii_emit_memcpy_c(buf_addr + (len as u64), &R3_ZERO_BYTE as u64, 1u64)
    return 0u32
}
fn r3_struct_field_slot(obj_node: u32, fname_off: u32, fname_len: u32) -> u32 {
    if obj_node == 0u32 { return 4294967295u32 }
    if R3_G_SEMA == 0u64 { return 4294967295u32 }
    let ok: u32 = iii_ast_node_kind(R3_G_AST, obj_node)
    if ok != R3_K_EXPR_IDENT { return 4294967295u32 }
    let ioff: u32 = iii_ast_ident_name_offset(R3_G_AST, obj_node)
    let ilen: u32 = iii_ast_ident_name_length(R3_G_AST, obj_node)
    let bs: u32 = r3_local_lookup(ioff, ilen)
    if bs == 4294967295u32 { return 4294967295u32 }
    let bid: u32 = iii_ast_node_binder_id(R3_G_AST, obj_node)
    if bid == 0u32 { return 4294967295u32 }
    let bk: u32 = iii_ast_node_kind(R3_G_AST, bid)
    let mut tnode: u32 = 0u32
    if bk == R3_K_STMT_LET { tnode = iii_ast_let_type(R3_G_AST, bid) }
    if bk == R3_K_PARAM { tnode = iii_ast_param_type(R3_G_AST, bid) }
    if tnode == 0u32 { return 4294967295u32 }
    let tk: u32 = iii_ast_node_kind(R3_G_AST, tnode)
    if tk != R3_K_TYPE_REF { return 4294967295u32 }
    let toff: u32 = iii_ast_type_ref_name_off(R3_G_AST, tnode)
    let tlen: u32 = iii_ast_type_ref_name_len(R3_G_AST, tnode)
    if r3_copy_to_cstr(&R3_FIELD_TNM as u64, toff, tlen) != 0u32 { return 4294967295u32 }
    let sd: u32 = iii_sema_struct_decl_for_name(R3_G_SEMA, &R3_FIELD_TNM as u64)
    if sd == 0u32 { return 4294967295u32 }
    if r3_copy_to_cstr(&R3_FIELD_FNM as u64, fname_off, fname_len) != 0u32 { return 4294967295u32 }
    let foff: i32 = iii_sema_struct_field_slot(R3_G_SEMA, sd, &R3_FIELD_FNM as u64)
    if foff < 0i32 { return 4294967295u32 }
    return bs + (foff as u32)
}

/* ─────────────── ABI alignment (D9 R3 wall) ─────────────── */
fn r3_abi_assert_call_alignment(total_slots: u32) -> u32 { /* MS x64: rsp must be 16-byte aligned BEFORE the CALL.
   Frame: pushed rbp (-8) + locals + pushes => total_slots*8.  Pre-call slots aligned iff total_slots even. */
   if (total_slots & 1u32) == 0u32 { r3_emit_arr(&R3_CMT_ABI_OK as u64, R3_CMT_ABI_OK_LEN); return R3_OK }; r3_emit_arr(&R3_CMT_ABI_BAD as u64, R3_CMT_ABI_BAD_LEN); R3_G_LAST_ERROR = R3_E_ABI_ALIGN; return R3_E_ABI_ALIGN }

/* ─────────────── pattern compare (D6) ─────────────── */
fn r3_emit_pattern_compare(pat: u32, skip_label_id: u32) -> u32 { let _su: u32 = skip_label_id; let pk: u32 = iii_ast_node_kind(R3_G_AST, pat); if pk == R3_K_PAT_WILDCARD { r3_emit_arr(&R3_STR_CMP_RAX_RAX as u64, R3_STR_CMP_RAX_RAX_LEN); return R3_OK }; if pk == R3_K_PAT_IDENT { r3_emit_arr(&R3_STR_CMP_RAX_RAX as u64, R3_STR_CMP_RAX_RAX_LEN); return R3_OK }; if pk == R3_K_PAT_LITERAL { let lit: u32 = iii_ast_pat_literal_node(R3_G_AST, pat); let lk: u32 = iii_ast_node_kind(R3_G_AST, lit); let mut v: u64 = 0u64; if lk == R3_K_EXPR_INT { v = iii_ast_expr_int_u64(R3_G_AST, lit) }; if lk == R3_K_EXPR_HEX { v = (iii_ast_hex_value_lo(R3_G_AST, lit) as u64) | ((iii_ast_hex_value_hi(R3_G_AST, lit) as u64) << 32u64) }; if lk == R3_K_EXPR_BOOL { v = iii_ast_bool_value(R3_G_AST, lit) as u64 }; if lk == R3_K_EXPR_TRIT { v = iii_ast_expr_trit_value(R3_G_AST, lit) as u64 }; r3_emit_arr(&R3_STR_MOVABSQ_OPEN as u64, R3_STR_MOVABSQ_OPEN_LEN); r3_emit_hex(v); r3_emit_arr(&R3_STR_COMMA_RCX_NL as u64, R3_STR_COMMA_RCX_NL_LEN); r3_emit_arr(&R3_STR_CMP_RCX_RAX as u64, R3_STR_CMP_RCX_RAX_LEN); return R3_OK }; if pk == R3_K_PAT_HEXAD { r3_emit_arr(&R3_STR_MOVABSQ_OPEN as u64, R3_STR_MOVABSQ_OPEN_LEN); r3_emit_hex(r3_pack_hexad_pat(pat)); r3_emit_arr(&R3_STR_COMMA_RCX_NL as u64, R3_STR_COMMA_RCX_NL_LEN); r3_emit_arr(&R3_STR_CMP_RCX_RAX as u64, R3_STR_CMP_RCX_RAX_LEN); return R3_OK }; return R3_OK }
fn r3_emit_pattern_bind(pat: u32) -> u32 { let pk: u32 = iii_ast_node_kind(R3_G_AST, pat); if pk == R3_K_PAT_IDENT { let off: u32 = iii_ast_pat_ident_name_off(R3_G_AST, pat); let len: u32 = iii_ast_pat_ident_name_len(R3_G_AST, pat); let s_lk: u32 = r3_local_lookup(off, len); if s_lk != 4294967295u32 { r3_emit_store_rax_slot(s_lk) } else { r3_local_add(off, len); let new_slot: u32 = R3_G_LOCAL_COUNT - 1u32; r3_emit_store_rax_slot(new_slot) } }; return R3_OK }

/* ─────────────── modifier helpers ─────────────── */
fn r3_mod_first_int(m: u32) -> u64 { if m == 0u32 { return 0u64 }; let ac: u32 = iii_ast_modifier_arg_count(R3_G_AST, m); if ac == 0u32 { return 0u64 }; let a: u32 = iii_ast_modifier_arg_at(R3_G_AST, m, 0u32); let v: u32 = iii_ast_arg_value(R3_G_AST, a); let k: u32 = iii_ast_node_kind(R3_G_AST, v); if k == R3_K_EXPR_INT { return iii_ast_expr_int_u64(R3_G_AST, v) }; if k == R3_K_EXPR_HEX { return (iii_ast_hex_value_lo(R3_G_AST, v) as u64) | ((iii_ast_hex_value_hi(R3_G_AST, v) as u64) << 32u64) }; return 0u64 }

/* ─────────────── string-table helpers ─────────────── */
fn r3_emit_raw_symbol(off: u32, len: u32) -> u32 { return r3_emit_sym_run(off, len) }

/* ─────────────── mhash data label emit ─────────────── */
fn r3_emit_mhash_data(node_id: u32) -> u32 { r3_emit_arr(&R3_PFX_LMHASH as u64, R3_PFX_LMHASH_LEN); r3_emit_dec(node_id as u64); r3_emit_arr(&R3_STR_COLONNL as u64, R3_STR_COLONNL_LEN); let mut i: u32 = 0u32; while i < 32u32 { let b: u32 = iii_ast_mhash_byte_at(R3_G_AST, node_id, i); r3_emit_arr(&R3_STR_BYTE as u64, R3_STR_BYTE_LEN); r3_emit_dec(b as u64); r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN); i = i + 1u32 }; return R3_OK }

