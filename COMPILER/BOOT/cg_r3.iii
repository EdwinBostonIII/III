const R3_STR_JE_PFX_LEN : u64 = 7u64

var R3_STR_JAE : [u8; 8] = [32u8, 32u8, 32u8, 32u8, 106u8, 97u8, 101u8, 32u8]
const R3_STR_JAE_LEN : u64 = 8u64

/* ── Label prefixes (no indent, no colon) ── */
var R3_PFX_LCAPOK : [u8; 9] = [76u8, 95u8, 99u8, 97u8, 112u8, 95u8, 111u8, 107u8, 95u8]
const R3_PFX_LCAPOK_LEN : u64 = 9u64

var R3_PFX_LHEXADOK : [u8; 11] = [76u8, 95u8, 104u8, 101u8, 120u8, 97u8, 100u8, 95u8, 111u8, 107u8, 95u8]
const R3_PFX_LHEXADOK_LEN : u64 = 11u64

var R3_PFX_LKMAXOK : [u8; 10] = [76u8, 95u8, 107u8, 109u8, 97u8, 120u8, 95u8, 111u8, 107u8, 95u8]
const R3_PFX_LKMAXOK_LEN : u64 = 10u64

/* ── "ctx" identifier literal for param scan ── */
var R3_LIT_CTX : [u8; 3] = [99u8, 116u8, 120u8]
const R3_LIT_CTX_LEN : u64 = 3u64

/* iiis-1 @dynamic ripple-stub support literals.  Used to decode
 * @dynamic(ripple=auto|manual|off) and select the corresponding
 * mode value for the III_DYNAMIC_RIPPLE_STUB block. */
var R3_MOD_DYNAMIC : [u8; 7] = [100u8, 121u8, 110u8, 97u8, 109u8, 105u8, 99u8]
const R3_MOD_DYNAMIC_LEN : u64 = 7u64
var R3_MOD_RIPPLE : [u8; 6] = [114u8, 105u8, 112u8, 112u8, 108u8, 101u8]
const R3_MOD_RIPPLE_LEN : u64 = 6u64
/* XII (Phase XII-θ) — @lattice / @fusion_budget / @deployment_target.
 * 'l'=108 'a'=97 't'=116 't'=116 'i'=105 'c'=99 'e'=101  → length 7.
 * 'f'=102 'u'=117 's'=115 'i'=105 'o'=111 'n'=110 '_'=95 'b'=98 'u'=117 'd'=100
 * 'g'=103 'e'=101 't'=116 → length 13.
 * 'd'=100 'e'=101 'p'=112 'l'=108 'o'=111 'y'=121 'm'=109 'e'=101 'n'=110 't'=116
 * '_'=95 't'=116 'a'=97 'r'=114 'g'=103 'e'=101 't'=116 → length 17. */
var R3_MOD_LATTICE : [u8; 7] = [108u8, 97u8, 116u8, 116u8, 105u8, 99u8, 101u8]
const R3_MOD_LATTICE_LEN : u64 = 7u64
var R3_MOD_FUSION_BUDGET : [u8; 13] = [102u8, 117u8, 115u8, 105u8, 111u8, 110u8, 95u8, 98u8, 117u8, 100u8, 103u8, 101u8, 116u8]
const R3_MOD_FUSION_BUDGET_LEN : u64 = 13u64
var R3_MOD_DEPLOY_TARGET : [u8; 17] = [100u8, 101u8, 112u8, 108u8, 111u8, 121u8, 109u8, 101u8, 110u8, 116u8, 95u8, 116u8, 97u8, 114u8, 103u8, 101u8, 116u8]
const R3_MOD_DEPLOY_TARGET_LEN : u64 = 17u64
var R3_LIT_AUTO : [u8; 4] = [97u8, 117u8, 116u8, 111u8]
const R3_LIT_AUTO_LEN : u64 = 4u64
var R3_LIT_MANUAL : [u8; 6] = [109u8, 97u8, 110u8, 117u8, 97u8, 108u8]
const R3_LIT_MANUAL_LEN : u64 = 6u64
var R3_LIT_OFF : [u8; 3] = [111u8, 102u8, 102u8]
const R3_LIT_OFF_LEN : u64 = 3u64

/* iiis-1 Phase C.6 PE narrowing constants. */
var R3_LIT_RESOLVE : [u8; 7] = [114u8, 101u8, 115u8, 111u8, 108u8, 118u8, 101u8]
const R3_LIT_RESOLVE_LEN : u64 = 7u64
/* "    # III_PE_DIRECT_LOAD " (25 B, trailing space, no newline) */
var R3_CMT_PE_DIRECT_LOAD : [u8; 25] = [32u8, 32u8, 32u8, 32u8, 35u8, 32u8, 73u8, 73u8, 73u8, 95u8, 80u8, 69u8, 95u8, 68u8, 73u8, 82u8, 69u8, 67u8, 84u8, 95u8, 76u8, 79u8, 65u8, 68u8, 32u8]
const R3_CMT_PE_DIRECT_LOAD_LEN : u64 = 25u64
/* "    # III_PE_DIRECT_CALL " (25 B) for multi-stmt narrowed callsite */
var R3_CMT_PE_DIRECT_CALL : [u8; 25] = [32u8, 32u8, 32u8, 32u8, 35u8, 32u8, 73u8, 73u8, 73u8, 95u8, 80u8, 69u8, 95u8, 68u8, 73u8, 82u8, 69u8, 67u8, 84u8, 95u8, 67u8, 65u8, 76u8, 76u8, 32u8]
const R3_CMT_PE_DIRECT_CALL_LEN : u64 = 25u64
/* "    # III_PE_RECORD slot=" (25 B) for let-binding marker */
var R3_CMT_PE_RECORD : [u8; 25] = [32u8, 32u8, 32u8, 32u8, 35u8, 32u8, 73u8, 73u8, 73u8, 95u8, 80u8, 69u8, 95u8, 82u8, 69u8, 67u8, 79u8, 82u8, 68u8, 32u8, 115u8, 108u8, 111u8, 116u8, 61u8]
const R3_CMT_PE_RECORD_LEN : u64 = 25u64
/* " -> " (4 B) separator in PE_RECORD line */
var R3_STR_ARROW : [u8; 4] = [32u8, 45u8, 62u8, 32u8]
const R3_STR_ARROW_LEN : u64 = 4u64
/* PE slot→fn_name map: parallel arrays. */
var R3_PE_SLOT : [u32; 64]
var R3_PE_NAME_ADDR : [u64; 64]
var R3_PE_NAME_LEN : [u32; 64]
var R3_PE_COUNT : u32 = 0u32

/* Stage 7.1 @specialize monomorphisation binding (set while emitting one
 * specialisation of a generic fn; the width-aware load/store/cast paths
 * resolve a TYPE_REF matching the type-param name to the concrete type). */
var R3_SPEC_ACTIVE   : u32 = 0u32
var R3_SPEC_TP_BUF   : [u8; 64]    /* the type-param name (e.g. "T") */
var R3_SPEC_TP_LEN   : u32 = 0u32
var R3_SPEC_TYPE_BUF : [u8; 16]    /* the concrete type name (e.g. "u32") */
var R3_SPEC_TYPE_LEN : u32 = 0u32
/* "specialize" (modifier name) for r3_mod_find. */
var R3_MOD_SPEC : [u8; 10] = [115u8, 112u8, 101u8, 99u8, 105u8, 97u8, 108u8, 105u8, 122u8, 101u8]
const R3_MOD_SPEC_LEN : u64 = 10u64


/* ─────────────── output sink ─────────────── */
fn r3_emit_bytes(addr: u64, n: u64) -> u32 { if R3_G_OUT == 0u64 { R3_G_LAST_ERROR = R3_E_IO; return R3_E_IO }; let r: i32 = iii_cg_r3_fwrite_c(R3_G_OUT, addr, n); iii_cg_r3_sha_update_c(addr, n); if r != 0i32 { R3_G_LAST_ERROR = R3_E_IO; return R3_E_IO }; return R3_OK }
fn r3_emit_arr(addr: u64, n: u64) -> u32 { return r3_emit_bytes(addr, n) }
fn r3_emit_ch(ch: u32) -> u32 { R3_NUMBUF[0] = ch as u8; return r3_emit_bytes(&R3_NUMBUF as u64, 1u64) }
fn r3_emit_dec(v0: u64) -> u32 { let mut v: u64 = v0; let mut n: u32 = 0u32; if v == 0u64 { R3_NUMBUF[0]=48u8; return r3_emit_bytes(&R3_NUMBUF as u64, 1u64) }; while v > 0u64 { R3_NUMBUF[n] = (48u64 + (v % 10u64)) as u8; n = n + 1u32; v = v / 10u64 }; let mut a: u32 = 0u32; let mut b: u32 = n - 1u32; while a < b { let tmp: u8 = R3_NUMBUF[a]; R3_NUMBUF[a] = R3_NUMBUF[b]; R3_NUMBUF[b] = tmp; a = a + 1u32; b = b - 1u32 }; return r3_emit_bytes(&R3_NUMBUF as u64, n as u64) }
fn r3_emit_hex(v0: u64) -> u32 { let mut v: u64 = v0; let mut n: u32 = 0u32; if v == 0u64 { R3_NUMBUF[0]=48u8; return r3_emit_bytes(&R3_NUMBUF as u64, 1u64) }; while v > 0u64 { let d: u64 = v & 15u64; if d < 10u64 { R3_NUMBUF[n] = (48u64 + d) as u8 } else { R3_NUMBUF[n] = (87u64 + d) as u8 }; n = n + 1u32; v = v >> 4u64 }; let mut a: u32 = 0u32; let mut b: u32 = n - 1u32; while a < b { let tmp: u8 = R3_NUMBUF[a]; R3_NUMBUF[a] = R3_NUMBUF[b]; R3_NUMBUF[b] = tmp; a = a + 1u32; b = b - 1u32 }; return r3_emit_bytes(&R3_NUMBUF as u64, n as u64) }


/* ─────────────── identifier helpers ─────────────── */
fn r3_is_sym_char(b: u32) -> u32 { if b >= 65u32 { if b <= 90u32 { return 1u32 } }; if b >= 97u32 { if b <= 122u32 { return 1u32 } }; if b >= 48u32 { if b <= 57u32 { return 1u32 } }; if b == 95u32 { return 1u32 }; return 0u32 }

fn r3_name_eq_lit(off: u32, len: u32, lit_addr: u64, lit_len: u64) -> u32 { if (len as u64) != lit_len { return 0u32 }; let src: u64 = iii_ast_source_buf(R3_G_AST); if iii_emit_memcmp_c(src + (off as u64), lit_addr, lit_len) == 0i32 { return 1u32 }; return 0u32 }

fn r3_emit_sym_run(off: u32, len: u32) -> u32 { let src: u64 = iii_ast_source_buf(R3_G_AST); let mut i: u32 = 0u32; while i < len { let b: u32 = iii_emit_buf_read_u8_c(src, (off+i) as u64); if r3_is_sym_char(b) == 1u32 { r3_emit_ch(b) } else { r3_emit_ch(95u32) }; i = i + 1u32 }; return R3_OK }

/* Stage 7.1: emit a specialised symbol name: the template name with its first
 * "__" marker expanded to "_<concrete-type>_" (e.g. "option__some" + "u32" ->
 * "option_u32_some"); if no marker, the type is appended ("idfn" -> "idfn_u32").
 * Raw form (matches r3_emit_raw_symbol); callers add any L-prefix/escaping. */
fn r3_emit_spec_symbol(off: u32, len: u32) -> u32 {
    let src: u64 = iii_ast_source_buf(R3_G_AST)
    let mut mark: u32 = len
    let mut i: u32 = 0u32
    while i + 1u32 < len {
        if mark == len {
            let a: u32 = iii_emit_buf_read_u8_c(src, (off + i) as u64)
            let b: u32 = iii_emit_buf_read_u8_c(src, (off + i + 1u32) as u64)
            if a == 95u32 { if b == 95u32 { mark = i } }
        }
        i = i + 1u32
    }
    let mut pend: u32 = mark
    if mark == len { pend = len }
    let mut p: u32 = 0u32
    while p < pend { r3_emit_ch(iii_emit_buf_read_u8_c(src, (off + p) as u64)); p = p + 1u32 }
    r3_emit_ch(95u32)
    r3_emit_bytes(&R3_SPEC_TYPE_BUF as u64, R3_SPEC_TYPE_LEN as u64)
    if mark != len {
        r3_emit_ch(95u32)
        let mut q: u32 = mark + 2u32
        while q < len { r3_emit_ch(iii_emit_buf_read_u8_c(src, (off + q) as u64)); q = q + 1u32 }
    }
    return R3_OK
}

/* Stage 7.1: emit a fn's symbol — specialised (constructed) when active,
 * else the ordinary raw (export) or Lp-prefixed (local) label. */
fn r3_emit_fn_symbol(off: u32, len: u32, export: u32) -> u32 {
    if R3_SPEC_ACTIVE == 1u32 {
        if export == 0u32 { r3_emit_arr(&R3_PFX_LP as u64, R3_PFX_LP_LEN) }
        return r3_emit_spec_symbol(off, len)
    }
    if export == 1u32 { return r3_emit_raw_symbol(off, len) }
    return r3_emit_decl_label(off, len)
}

/* Stage 7.1: emit one specialisation of a generic @specialize fn per type in
 * its @specialize(...) args.  Sets the R3_SPEC binding (type-param name +
 * concrete type name) around each normal r3_emit_function call; the width-aware
 * paths + symbol emitter consult the binding.  Single type-param (containers). */
fn r3_emit_specialized_fn(node: u32) -> u32 {
    let src: u64 = iii_ast_source_buf(R3_G_AST)
    let tp: u32 = iii_ast_fn_type_param_at(R3_G_AST, node, 0u32)
    if tp == 0u32 { return r3_emit_function(node, R3_K_FN_DECL) }
    let tpo: u32 = iii_ast_type_param_name_off(R3_G_AST, tp)
    let tpl: u32 = iii_ast_type_param_name_len(R3_G_AST, tp)
    if tpl == 0u32 { return r3_emit_function(node, R3_K_FN_DECL) }
    if tpl > 64u32 { return r3_emit_function(node, R3_K_FN_DECL) }
    let mut a: u32 = 0u32
    while a < tpl { R3_SPEC_TP_BUF[a] = iii_emit_buf_read_u8_c(src, (tpo + a) as u64) as u8; a = a + 1u32 }
    R3_SPEC_TP_LEN = tpl
    let m: u32 = r3_mod_find(node, R3_K_FN_DECL, &R3_MOD_SPEC as u64, R3_MOD_SPEC_LEN)
    if m == 0u32 { return r3_emit_function(node, R3_K_FN_DECL) }
    let ac: u32 = iii_ast_modifier_arg_count(R3_G_AST, m)
    let mut e: u32 = R3_OK
    let mut k: u32 = 0u32
    while k < ac {
        let arg: u32 = iii_ast_modifier_arg_at(R3_G_AST, m, k)
        let v: u32 = iii_ast_arg_value(R3_G_AST, arg)
        let vo: u32 = iii_ast_ident_name_offset(R3_G_AST, v)
        let vl: u32 = iii_ast_ident_name_length(R3_G_AST, v)
        if vl > 0u32 { if vl <= 16u32 {
            let mut c: u32 = 0u32
            while c < vl { R3_SPEC_TYPE_BUF[c] = iii_emit_buf_read_u8_c(src, (vo + c) as u64) as u8; c = c + 1u32 }
            R3_SPEC_TYPE_LEN = vl
            R3_SPEC_ACTIVE = 1u32
            let ee: u32 = r3_emit_function(node, R3_K_FN_DECL)
            R3_SPEC_ACTIVE = 0u32
            if ee != R3_OK { if e == R3_OK { e = ee } }
        } }
        k = k + 1u32
    }
    return e
}

/* Stage 7.1: true iff `node` is a generic fn carrying @specialize. */
fn r3_is_specialize_generic(node: u32) -> u32 {
    if iii_ast_fn_type_param_count(R3_G_AST, node) == 0u32 { return 0u32 }
    if r3_mod_find(node, R3_K_FN_DECL, &R3_MOD_SPEC as u64, R3_MOD_SPEC_LEN) == 0u32 { return 0u32 }
    return 1u32
}

fn r3_emit_decl_label(off: u32, len: u32) -> u32 { let src: u64 = iii_ast_source_buf(R3_G_AST); if len == 4u32 { if iii_emit_memcmp_c(src + (off as u64), &R3_SYM_MAIN as u64, 4u64) == 0i32 { return r3_emit_sym_run(off, len) } }; r3_emit_arr(&R3_PFX_LP as u64, R3_PFX_LP_LEN); return r3_emit_sym_run(off, len) }

fn r3_emit_field_label(off: u32, len: u32) -> u32 { r3_emit_arr(&R3_PFX_LF as u64, R3_PFX_LF_LEN); return r3_emit_sym_run(off, len) }

fn r3_emit_str_label(idx: u32) -> u32 { let _i: u32 = idx; r3_emit_arr(&R3_PFX_LSTR as u64, R3_PFX_LSTR_LEN); r3_emit_dec(_i as u64); return R3_OK }

fn r3_emit_mhash_label(node: u32) -> u32 { r3_emit_arr(&R3_PFX_LMHASH as u64, R3_PFX_LMHASH_LEN); r3_emit_dec(node as u64); return R3_OK }

/* ─────────────── locals ─────────────── */
fn r3_local_lookup(off: u32, len: u32) -> u32 { let src: u64 = iii_ast_source_buf(R3_G_AST); let mut i: u32 = 0u32; while i < R3_G_LOCAL_COUNT { if R3_LOCAL_LEN[i] == len { if iii_emit_memcmp_c(src + (R3_LOCAL_OFF[i] as u64), src + (off as u64), len as u64) == 0i32 { return i } }; i = i + 1u32 }; return 4294967295u32 }

fn r3_local_add(off: u32, len: u32) -> u32 { if R3_G_LOCAL_COUNT >= R3_MAX_LOCALS { R3_G_LAST_ERROR = R3_E_INTERNAL; return R3_E_INTERNAL }; R3_LOCAL_OFF[R3_G_LOCAL_COUNT] = off; R3_LOCAL_LEN[R3_G_LOCAL_COUNT] = len; R3_G_LOCAL_COUNT = R3_G_LOCAL_COUNT + 1u32; return R3_OK }

/* ─────────────── stack-machine helpers ─────────────── */
fn r3_push_rax() -> u32 { r3_emit_arr(&R3_STR_PUSHRAX as u64, R3_STR_PUSHRAX_LEN); R3_G_STACK_DEPTH = R3_G_STACK_DEPTH + 1u32; if R3_G_STACK_DEPTH > R3_G_MAX_STACK_DEPTH { R3_G_MAX_STACK_DEPTH = R3_G_STACK_DEPTH }; return R3_OK }
fn r3_pop_rax() -> u32 { r3_emit_arr(&R3_STR_POPRAX as u64, R3_STR_POPRAX_LEN); if R3_G_STACK_DEPTH > 0u32 { R3_G_STACK_DEPTH = R3_G_STACK_DEPTH - 1u32 }; return R3_OK }
fn r3_pop_rcx() -> u32 { r3_emit_arr(&R3_STR_POPRCX as u64, R3_STR_POPRCX_LEN); if R3_G_STACK_DEPTH > 0u32 { R3_G_STACK_DEPTH = R3_G_STACK_DEPTH - 1u32 }; return R3_OK }
fn r3_pop_rdx() -> u32 { r3_emit_arr(&R3_STR_POPRDX as u64, R3_STR_POPRDX_LEN); if R3_G_STACK_DEPTH > 0u32 { R3_G_STACK_DEPTH = R3_G_STACK_DEPTH - 1u32 }; return R3_OK }

fn r3_emit_movabs_rax(v: u64) -> u32 { r3_emit_arr(&R3_STR_MOVABSQ_OPEN as u64, R3_STR_MOVABSQ_OPEN_LEN); r3_emit_hex(v); r3_emit_arr(&R3_STR_COMMA_RAX_NL as u64, R3_STR_COMMA_RAX_NL_LEN); return R3_OK }
fn r3_emit_load_slot(slot: u32) -> u32 { let _s: u32 = slot; r3_emit_arr(&R3_STR_DASH_OPEN as u64, R3_STR_DASH_OPEN_LEN); r3_emit_dec(((_s+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN); return R3_OK }

/* iiis-1 width-aware local load — matches cg_r3.c's type-aware load.
 * Uses early-return per type to avoid `let mut emitted` state which
 * iiis-0 may compile incorrectly for deeply-flat-scoped tracking.
 * Each check is independent; first match wins. */
fn r3_emit_local_load_width_aware(ident_node: u32, slot: u32) -> u32 {
    let bid: u32 = iii_ast_node_binder_id(R3_G_AST, ident_node)
    if bid == 0u32 { return r3_emit_local_load_default(slot) }
    let bk: u32 = iii_ast_node_kind(R3_G_AST, bid)
    let mut tnode: u32 = 0u32
    if bk == R3_K_STMT_LET { tnode = iii_ast_let_type(R3_G_AST, bid) }
    if bk == R3_K_PARAM { tnode = iii_ast_param_type(R3_G_AST, bid) }
    if tnode == 0u32 { return r3_emit_local_load_default(slot) }
    let tk: u32 = iii_ast_node_kind(R3_G_AST, tnode)
    /* Local array → address decay: leaq -N(%rbp), %rax (not movq).
     * Mirrors cg_r3.c:1110 EXPR_IDENT TYPE_ARRAY branch. */
    if tk == R3_K_TYPE_ARR {
        r3_emit_arr(&R3_STR_LEAQ_DASH as u64, R3_STR_LEAQ_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN)
        return R3_OK
    }
    if tk != R3_K_TYPE_REF { return r3_emit_local_load_default(slot) }
    let no: u32 = iii_ast_type_ref_name_off(R3_G_AST, tnode)
    let nl: u32 = iii_ast_type_ref_name_len(R3_G_AST, tnode)
    /* Stage 7.1: while emitting a specialisation, a param typed with the
     * type-param name loads as the bound concrete type. */
    if R3_SPEC_ACTIVE == 1u32 { if r3_name_eq_lit(no, nl, &R3_SPEC_TP_BUF as u64, R3_SPEC_TP_LEN as u64) == 1u32 { return r3_spec_emit_local_load(slot) } }
    if r3_name_eq_lit(no, nl, &R3_TY_U32 as u64, R3_TY_U32_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVL_DASH as u64, R3_STR_MOVL_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_EAX as u64, R3_STR_BPCMA_EAX_LEN)
        return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_I32 as u64, R3_TY_I32_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVSLQ_DASH as u64, R3_STR_MOVSLQ_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN)
        return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_U16 as u64, R3_TY_U16_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVZWQ_DASH as u64, R3_STR_MOVZWQ_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN)
        return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_I16 as u64, R3_TY_I16_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVSWQ_DASH as u64, R3_STR_MOVSWQ_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN)
        return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_U8 as u64, R3_TY_U8_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVZBQ_DASH as u64, R3_STR_MOVZBQ_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN)
        return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_I8 as u64, R3_TY_I8_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVSBQ_DASH as u64, R3_STR_MOVSBQ_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN)
        return R3_OK
    }
    return r3_emit_local_load_default(slot)
}

fn r3_emit_local_load_default(slot: u32) -> u32 {
    r3_emit_arr(&R3_STR_DASH_OPEN as u64, R3_STR_DASH_OPEN_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN)
    return R3_OK
}

/* Stage 7.1: compare the bound concrete-type name (R3_SPEC_TYPE_BUF) to a literal. */
fn r3_spec_buf_eq(lit_addr: u64, lit_len: u64) -> u32 {
    if (R3_SPEC_TYPE_LEN as u64) != lit_len { return 0u32 }
    if iii_emit_memcmp_c(&R3_SPEC_TYPE_BUF as u64, lit_addr, lit_len) == 0i32 { return 1u32 }
    return 0u32
}
/* Stage 7.1: width-aware local load for the bound concrete type (mirrors the
 * per-type emission in r3_emit_local_load_width_aware; u64/i64/bool -> default). */
fn r3_spec_emit_local_load(slot: u32) -> u32 {
    if r3_spec_buf_eq(&R3_TY_U32 as u64, R3_TY_U32_LEN) == 1u32 { r3_emit_arr(&R3_STR_MOVL_DASH as u64, R3_STR_MOVL_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_EAX as u64, R3_STR_BPCMA_EAX_LEN); return R3_OK }
    if r3_spec_buf_eq(&R3_TY_I32 as u64, R3_TY_I32_LEN) == 1u32 { r3_emit_arr(&R3_STR_MOVSLQ_DASH as u64, R3_STR_MOVSLQ_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN); return R3_OK }
    if r3_spec_buf_eq(&R3_TY_U16 as u64, R3_TY_U16_LEN) == 1u32 { r3_emit_arr(&R3_STR_MOVZWQ_DASH as u64, R3_STR_MOVZWQ_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN); return R3_OK }
    if r3_spec_buf_eq(&R3_TY_I16 as u64, R3_TY_I16_LEN) == 1u32 { r3_emit_arr(&R3_STR_MOVSWQ_DASH as u64, R3_STR_MOVSWQ_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN); return R3_OK }
    if r3_spec_buf_eq(&R3_TY_U8 as u64, R3_TY_U8_LEN) == 1u32 { r3_emit_arr(&R3_STR_MOVZBQ_DASH as u64, R3_STR_MOVZBQ_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN); return R3_OK }
    if r3_spec_buf_eq(&R3_TY_I8 as u64, R3_TY_I8_LEN) == 1u32 { r3_emit_arr(&R3_STR_MOVSBQ_DASH as u64, R3_STR_MOVSBQ_DASH_LEN); r3_emit_dec(((slot+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_BPCMA_RAX as u64, R3_STR_BPCMA_RAX_LEN); return R3_OK }
    return r3_emit_local_load_default(slot)
}

/* Stage 7.2: byte size of the bound concrete type (T-in-memory: array stride,
 * sizeof, indexed load/store width all derive from r3_type_ref_byte_size). */
fn r3_spec_type_byte_size() -> u32 {
    if r3_spec_buf_eq(&R3_TY_U8 as u64, R3_TY_U8_LEN) == 1u32 { return 1u32 }
    if r3_spec_buf_eq(&R3_TY_I8 as u64, R3_TY_I8_LEN) == 1u32 { return 1u32 }
    if r3_spec_buf_eq(&R3_TY_BOOL as u64, R3_TY_BOOL_LEN) == 1u32 { return 1u32 }
    if r3_spec_buf_eq(&R3_TY_U16 as u64, R3_TY_U16_LEN) == 1u32 { return 2u32 }
    if r3_spec_buf_eq(&R3_TY_I16 as u64, R3_TY_I16_LEN) == 1u32 { return 2u32 }
    if r3_spec_buf_eq(&R3_TY_U32 as u64, R3_TY_U32_LEN) == 1u32 { return 4u32 }
    if r3_spec_buf_eq(&R3_TY_I32 as u64, R3_TY_I32_LEN) == 1u32 { return 4u32 }
    if r3_spec_buf_eq(&R3_TY_U64 as u64, R3_TY_U64_LEN) == 1u32 { return 8u32 }
    if r3_spec_buf_eq(&R3_TY_I64 as u64, R3_TY_I64_LEN) == 1u32 { return 8u32 }
    return 0u32
}
/* Stage 7.2: indexed-element kind (1=byte 2=sbyte 3=word 4=sword 5=long
 * 6=slong, 0=quad) of the bound concrete type.  Mirrors the literal name->kind
 * map in r3_index_obj_elem_kind so that `*T` subscripts in a specialised fn get
 * the right SIB scale + load/store width.  u64/i64 -> 0 (quad) is correct (8B).
 * Without this, `*T` defaulted to ek=0 (movq, scale 8): a u32 element was stored
 * at stride 8 with an 8-byte write, which a stride-4 grow-copy then truncated. */
fn r3_spec_type_elem_kind() -> u32 {
    if r3_spec_buf_eq(&R3_TY_U8 as u64, R3_TY_U8_LEN) == 1u32 { return 1u32 }
    if r3_spec_buf_eq(&R3_TY_BOOL as u64, R3_TY_BOOL_LEN) == 1u32 { return 1u32 }
    if r3_spec_buf_eq(&R3_TY_I8 as u64, R3_TY_I8_LEN) == 1u32 { return 2u32 }
    if r3_spec_buf_eq(&R3_TY_U16 as u64, R3_TY_U16_LEN) == 1u32 { return 3u32 }
    if r3_spec_buf_eq(&R3_TY_I16 as u64, R3_TY_I16_LEN) == 1u32 { return 4u32 }
    if r3_spec_buf_eq(&R3_TY_U32 as u64, R3_TY_U32_LEN) == 1u32 { return 5u32 }
    if r3_spec_buf_eq(&R3_TY_I32 as u64, R3_TY_I32_LEN) == 1u32 { return 6u32 }
    return 0u32
}
fn r3_emit_store_rax_slot(slot: u32) -> u32 { let _s: u32 = slot; r3_emit_arr(&R3_STR_MOVQ_RAX_C as u64, R3_STR_MOVQ_RAX_C_LEN); r3_emit_ch(45u32); r3_emit_dec(((_s+1u32)*8u32) as u64); r3_emit_arr(&R3_STR_RBP_NL as u64, R3_STR_RBP_NL_LEN); return R3_OK }

/* iiis-1 width-aware global IDENT load.  Mirrors cg_r3.c:1160-1201
 * mov_op selection on binder's declared type.  Emits the appropriate
 * width-specific load to %rax (or %eax for u32 which auto-extends).
 * Falls back to full-width movq for unknown types.
 * Pattern: "<MOV_PREFIX>L_<sym>(%rip), %<REG>\n" — DASH_LEN-1 trims
 * the trailing dash from the local-form prefix constants. */
fn r3_emit_global_load_with_type(off: u32, len: u32, type_node: u32) -> u32 {
    if type_node == 0u32 { return r3_emit_global_load_default(off, len) }
    let tk: u32 = iii_ast_node_kind(R3_G_AST, type_node)
    if tk != R3_K_TYPE_REF { return r3_emit_global_load_default(off, len) }
    let no: u32 = iii_ast_type_ref_name_off(R3_G_AST, type_node)
    let nl: u32 = iii_ast_type_ref_name_len(R3_G_AST, type_node)
    if r3_name_eq_lit(no, nl, &R3_TY_U8 as u64, R3_TY_U8_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVZBQ_DASH as u64, R3_STR_MOVZBQ_DASH_LEN - 1u64); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_BOOL as u64, R3_TY_BOOL_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVZBQ_DASH as u64, R3_STR_MOVZBQ_DASH_LEN - 1u64); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_I8 as u64, R3_TY_I8_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVSBQ_DASH as u64, R3_STR_MOVSBQ_DASH_LEN - 1u64); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_U16 as u64, R3_TY_U16_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVZWQ_DASH as u64, R3_STR_MOVZWQ_DASH_LEN - 1u64); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_I16 as u64, R3_TY_I16_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVSWQ_DASH as u64, R3_STR_MOVSWQ_DASH_LEN - 1u64); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_U32 as u64, R3_TY_U32_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVL_DASH as u64, R3_STR_MOVL_DASH_LEN - 1u64); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_EAX as u64, R3_REG_EAX_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_I32 as u64, R3_TY_I32_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVSLQ_DASH as u64, R3_STR_MOVSLQ_DASH_LEN - 1u64); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN); return R3_OK
    }
    return r3_emit_global_load_default(off, len)
}

fn r3_emit_global_load_default(off: u32, len: u32) -> u32 {
    r3_emit_arr(&R3_STR_MOVQ_PFX as u64, R3_STR_MOVQ_PFX_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN); return R3_OK
}

/* iiis-1 width-aware global VAR_DECL store.  Mirrors cg_r3.c:2306-2323
 * mov_op + src_reg selection.  Falls through to movq %rax for unknown
 * types.  Suffix is always `L_<name>(%rip)\n` (RIP_PAREN). */
fn r3_emit_global_store_with_type(off: u32, len: u32, type_node: u32) -> u32 {
    if type_node == 0u32 {
        r3_emit_arr(&R3_STR_MOVQ_RAX_C as u64, R3_STR_MOVQ_RAX_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
    }
    let tk: u32 = iii_ast_node_kind(R3_G_AST, type_node)
    if tk != R3_K_TYPE_REF {
        r3_emit_arr(&R3_STR_MOVQ_RAX_C as u64, R3_STR_MOVQ_RAX_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
    }
    let no: u32 = iii_ast_type_ref_name_off(R3_G_AST, type_node)
    let nl: u32 = iii_ast_type_ref_name_len(R3_G_AST, type_node)
    if r3_name_eq_lit(no, nl, &R3_TY_U8 as u64, R3_TY_U8_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVB_AL_C as u64, R3_STR_MOVB_AL_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_I8 as u64, R3_TY_I8_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVB_AL_C as u64, R3_STR_MOVB_AL_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_BOOL as u64, R3_TY_BOOL_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVB_AL_C as u64, R3_STR_MOVB_AL_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_U16 as u64, R3_TY_U16_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVW_AX_C as u64, R3_STR_MOVW_AX_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_I16 as u64, R3_TY_I16_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVW_AX_C as u64, R3_STR_MOVW_AX_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_U32 as u64, R3_TY_U32_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVL_EAX_C as u64, R3_STR_MOVL_EAX_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
    }
    if r3_name_eq_lit(no, nl, &R3_TY_I32 as u64, R3_TY_I32_LEN) == 1u32 {
        r3_emit_arr(&R3_STR_MOVL_EAX_C as u64, R3_STR_MOVL_EAX_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
    }
    r3_emit_arr(&R3_STR_MOVQ_RAX_C as u64, R3_STR_MOVQ_RAX_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
}

/* iiis-1 global IDENT store dispatcher: probes binder kind to pick
 * width-aware path (VAR_DECL non-array) or fall through to default
 * movq.  Mirrors cg_r3.c:2289-2324. */
fn r3_emit_global_ident_store(ident_node: u32, off: u32, len: u32) -> u32 {
    let bid: u32 = iii_ast_node_binder_id(R3_G_AST, ident_node)
    if bid == 0u32 {
        r3_emit_arr(&R3_STR_MOVQ_RAX_C as u64, R3_STR_MOVQ_RAX_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
    }
    let bk: u32 = iii_ast_node_kind(R3_G_AST, bid)
    if bk == R3_K_VAR_DECL {
        let vt: u32 = iii_ast_var_decl_type(R3_G_AST, bid)
        if vt != 0u32 {
            let tk: u32 = iii_ast_node_kind(R3_G_AST, vt)
            if tk == R3_K_TYPE_REF {
                return r3_emit_global_store_with_type(off, len, vt)
            }
        }
    }
    r3_emit_arr(&R3_STR_MOVQ_RAX_C as u64, R3_STR_MOVQ_RAX_C_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIP_PAREN as u64, R3_STR_RIP_PAREN_LEN); return R3_OK
}

fn r3_emit_global_leaq(off: u32, len: u32) -> u32 {
    r3_emit_arr(&R3_STR_LEAQ as u64, R3_STR_LEAQ_LEN); r3_emit_decl_label(off, len); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN); return R3_OK
}

/* iiis-1 bit-identity: fn-pointer-take of an EXTERN/@export ident must
 * emit the RAW (unmangled) symbol, not L_<name> -- mirrors cg_r3.c
 * 1218-1224 (fn_emit_raw -> emit_raw_symbol).  Without this the leaq
 * targets L_<sym> which the linker leaves UNDEFINED (the @export'd fn
 * has no L_ prefix). */
fn r3_emit_global_leaq_raw(off: u32, len: u32) -> u32 {
    r3_emit_arr(&R3_STR_LEAQ as u64, R3_STR_LEAQ_LEN); r3_emit_sym_run(off, len); r3_emit_arr(&R3_STR_RIPCM_PCT as u64, R3_STR_RIPCM_PCT_LEN); r3_emit_arr(&R3_REG_RAX as u64, R3_REG_RAX_LEN); return R3_OK
}

/* iiis-1 width-aware global IDENT dispatcher.  Mirrors cg_r3.c:1145-1226.
 * CONST_DECL → value load via type dispatch.
 * VAR_DECL non-array → value load via type dispatch.
 * VAR_DECL array → address load (leaq).
 * FN_DECL / EXTERN_DECL / unknown → address load (leaq).
 * Early-return per binder kind: the natural, clean dispatch form.  (The
 * historical iiis-0 `let mut` checkpoint-flag bug this once also dodged is
 * fixed -- every `let mut` local is now memory-backed with store/reload;
 * regression-pinned by corpus 276.  Stage 3.8.) */
fn r3_emit_global_ident(node: u32, off: u32, len: u32) -> u32 {
    let bid: u32 = iii_ast_node_binder_id(R3_G_AST, node)
    if bid == 0u32 {
        r3_emit_global_leaq(off, len); r3_push_rax(); return R3_OK
    }
    let bk: u32 = iii_ast_node_kind(R3_G_AST, bid)
    if bk == R3_K_CONST_DECL {
        r3_emit_global_load_with_type(off, len, iii_ast_const_decl_type(R3_G_AST, bid)); r3_push_rax(); return R3_OK
    }
    if bk == R3_K_VAR_DECL {
        let vt: u32 = iii_ast_var_decl_type(R3_G_AST, bid)
        if vt != 0u32 {
            let tk: u32 = iii_ast_node_kind(R3_G_AST, vt)
            if tk == R3_K_TYPE_ARR {
                r3_emit_global_leaq(off, len); r3_push_rax(); return R3_OK
            }
        }
        r3_emit_global_load_with_type(off, len, vt); r3_push_rax(); return R3_OK
    }
    if r3_addr_is_raw_sym(node) == 1u32 { r3_emit_global_leaq_raw(off, len) } else { r3_emit_global_leaq(off, len) }
    r3_push_rax(); return R3_OK
}

/* ─────────────── hexad packing ─────────────── */
fn r3_pack_hexad_expr(node: u32) -> u64 { let mut v: u32 = 0u32; let mut i: u32 = 0u32; while i < 6u32 { let t: u32 = iii_ast_expr_hexad_trit_at(R3_G_AST, node, i) & 3u32; v = v | (t << (2u32*i)); i = i + 1u32 }; return v as u64 }
fn r3_pack_hexad_pat(node: u32) -> u64 { let mut v: u32 = 0u32; let mut i: u32 = 0u32; while i < 6u32 { let t: u32 = iii_ast_pat_hexad_trit_at(R3_G_AST, node, i) & 3u32; v = v | (t << (2u32*i)); i = i + 1u32 }; return v as u64 }

/* ─────────────── modifier scanning ─────────────── */
fn r3_fn_or_cycle_mod_count(node: u32, kind: u32) -> u32 { if kind == R3_K_CYCLE_DECL { return iii_ast_cycle_modifier_count(R3_G_AST, node) }; return iii_ast_fn_modifier_count(R3_G_AST, node) }
fn r3_fn_or_cycle_mod_at(node: u32, kind: u32, i: u32) -> u32 { if kind == R3_K_CYCLE_DECL { return iii_ast_cycle_modifier_at(R3_G_AST, node, i) }; return iii_ast_fn_modifier_at(R3_G_AST, node, i) }

fn r3_mod_find(node: u32, kind: u32, name_addr: u64, name_len: u64) -> u32 { let mc: u32 = r3_fn_or_cycle_mod_count(node, kind); let mut i: u32 = 0u32; while i < mc { let m: u32 = r3_fn_or_cycle_mod_at(node, kind, i); let no: u32 = iii_ast_modifier_name_offset(R3_G_AST, m); let nl: u32 = iii_ast_modifier_name_length(R3_G_AST, m); if r3_name_eq_lit(no, nl, name_addr, name_len) == 1u32 { return m }; i = i + 1u32 }; return 0u32 }

/* iiis-1 static type-system check helper: extract a modifier's first
 * arg as a u64.  Walks `mod_node`'s arg list, unwraps the first ARG,
 * reads EXPR_INT or EXPR_HEX value.  Sets R3_G_MOD_FOUND=1u32 on hit;
 * returns 0u64 if the modifier has no usable u64 arg.  The caller is
 * responsible for checking R3_G_MOD_FOUND. */
fn r3_mod_extract_u64_value(mod_node: u32) -> u64 {
    if mod_node == 0u32 { return 0u64 }
    let ac: u32 = iii_ast_modifier_arg_count(R3_G_AST, mod_node)
    if ac == 0u32 { return 0u64 }
    let arg_id: u32 = iii_ast_modifier_arg_at(R3_G_AST, mod_node, 0u32)
    let inner: u32 = iii_ast_arg_value(R3_G_AST, arg_id)
    let ik: u32 = iii_ast_node_kind(R3_G_AST, inner)
    if ik == R3_K_EXPR_INT { R3_G_MOD_FOUND = 1u32; return iii_ast_expr_int_u64(R3_G_AST, inner) }
    if ik == R3_K_EXPR_HEX { R3_G_MOD_FOUND = 1u32; return iii_ast_expr_hex_u64(R3_G_AST, inner) }
    return 0u64
}

/* iiis-1 static type-system check: extract a named modifier's u64
 * value from a fn-decl's @-modifier list.  Sets R3_G_MOD_FOUND.  This
 * is the .iii analogue of cg_r3.c's fn_modifier_extract_u64. */
fn r3_fn_mod_extract_u64(fn_decl_node: u32, name_addr: u64, name_len: u64) -> u64 {
    R3_G_MOD_FOUND = 0u32
    let m: u32 = r3_mod_find(fn_decl_node, R3_K_FN_DECL, name_addr, name_len)
    if m == 0u32 { return 0u64 }
    return r3_mod_extract_u64_value(m)
}

/* iiis-1 helper: extract the @hexad_kind of an arg's effective kind.
 * Mirrors cg_r3.c's logic inside the param-hexad check.  Sets
 * R3_G_MOD_FOUND on success; returns the kind value.  Two paths:
 *   - arg is EXPR_IDENT bound to a let/param whose type has @hexad_kind
 *   - arg is direct EXPR_CALL whose callee declares @returns_hexad
 * Extracted to keep r3_emit_expr's EXPR_CALL block below iiis-0's
 * parser recursion limit. */
fn r3_get_arg_kind(arg_value_node: u32) -> u64 {
    R3_G_MOD_FOUND = 0u32
    let avk: u32 = iii_ast_node_kind(R3_G_AST, arg_value_node)
    if avk == R3_K_EXPR_IDENT { return r3_get_ident_arg_kind(arg_value_node) }
    if avk == R3_K_EXPR_CALL { return r3_get_call_arg_kind(arg_value_node) }
    return 0u64
}

fn r3_get_ident_arg_kind(arg_value_node: u32) -> u64 {
    let abid: u32 = iii_ast_node_binder_id(R3_G_AST, arg_value_node)
    if abid == 0u32 { return 0u64 }
    let abk: u32 = iii_ast_node_kind(R3_G_AST, abid)
    let mut at_n: u32 = 0u32
    if abk == R3_K_STMT_LET { at_n = iii_ast_let_type(R3_G_AST, abid) }
    if abk == R3_K_PARAM { at_n = iii_ast_param_type(R3_G_AST, abid) }
    if at_n == 0u32 { return 0u64 }
    return r3_type_node_extract_u64(at_n, &R3_MOD_HEXAD_KIND as u64, R3_MOD_HEXAD_KIND_LEN)
}

fn r3_get_call_arg_kind(arg_value_node: u32) -> u64 {
    let inner_callee: u32 = iii_ast_call_callee(R3_G_AST, arg_value_node)
    let inner_ck: u32 = iii_ast_node_kind(R3_G_AST, inner_callee)
    if inner_ck != R3_K_EXPR_IDENT { return 0u64 }
    let icd: u32 = iii_ast_node_binder_id(R3_G_AST, inner_callee)
    if icd == 0u32 { return 0u64 }
    let icdk: u32 = iii_ast_node_kind(R3_G_AST, icd)
    if icdk != R3_K_FN_DECL { return 0u64 }
    return r3_fn_mod_extract_u64(icd, &R3_MOD_RETURNS_HEXAD as u64, R3_MOD_RETURNS_HEXAD_LEN)
}

/* iiis-1 STATIC cap-flow + K-floor check helper.  Returns R3_OK on
 * no violation, R3_E_INTERNAL on detected violation.  Called from
 * EXPR_CALL handler; uses R3_G_CUR_DECL_NODE for the caller. */
fn r3_chk_cap_and_kfloor(callee_decl: u32) -> u32 {
    if R3_G_CUR_DECL_NODE == 0u32 { return R3_OK }
    let caller_kind: u32 = iii_ast_node_kind(R3_G_AST, R3_G_CUR_DECL_NODE)
    if caller_kind != R3_K_FN_DECL { return R3_OK }
    /* Cap-flow. */
    let callee_mask: u64 = r3_fn_mod_extract_u64(callee_decl, &R3_MOD_CAP_REQ as u64, R3_MOD_CAP_REQ_LEN)
    let callee_cap_has: u32 = R3_G_MOD_FOUND
    let caller_mask: u64 = r3_fn_mod_extract_u64(R3_G_CUR_DECL_NODE, &R3_MOD_CAP_REQ as u64, R3_MOD_CAP_REQ_LEN)
    let caller_cap_has: u32 = R3_G_MOD_FOUND
    if callee_cap_has == 1u32 {
        if caller_cap_has == 1u32 {
            if (caller_mask & callee_mask) != callee_mask {
                r3_emit_arr(&R3_VM_CAPV1 as u64, 44u64) ; r3_emit_hex(caller_mask)
                r3_emit_arr(&R3_VM_CAPV2 as u64, 32u64) ; r3_emit_hex(callee_mask)
                r3_emit_arr(&R3_VM_MISSING as u64, 12u64) ; r3_emit_hex(callee_mask & (caller_mask ^ 18446744073709551615u64))
                r3_emit_arr(&R3_VM_RPNL as u64, 2u64)
                R3_G_LAST_ERROR = R3_E_INTERNAL
                R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32
                return R3_E_INTERNAL
            }
        }
    }
    /* K-floor. */
    let callee_kfloor: u64 = r3_fn_mod_extract_u64(callee_decl, &R3_MOD_K_MAX as u64, R3_MOD_K_MAX_LEN)
    let callee_k_has: u32 = R3_G_MOD_FOUND
    let caller_kfloor: u64 = r3_fn_mod_extract_u64(R3_G_CUR_DECL_NODE, &R3_MOD_K_MAX as u64, R3_MOD_K_MAX_LEN)
    let caller_k_has: u32 = R3_G_MOD_FOUND
    if callee_k_has == 1u32 {
        if caller_k_has == 1u32 {
            if caller_kfloor < callee_kfloor {
                r3_emit_arr(&R3_VM_KFV1 as u64, 42u64) ; r3_emit_dec(caller_kfloor)
                r3_emit_arr(&R3_VM_KFV2 as u64, 20u64) ; r3_emit_dec(callee_kfloor)
                r3_emit_arr(&R3_VM_DEFICIT as u64, 10u64) ; r3_emit_dec(callee_kfloor - caller_kfloor)
                r3_emit_arr(&R3_VM_RPNL as u64, 2u64)
                R3_G_LAST_ERROR = R3_E_INTERNAL
                R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32
                return R3_E_INTERNAL
            }
        }
    }
    return R3_OK
}

/* iiis-1 unified static-check dispatcher for an EXPR_CALL site.
 * Runs cap-flow + K-floor (on caller-callee fn-decls) and param-kind
 * propagation.  Returns R3_OK or R3_E_INTERNAL. */
fn r3_chk_call_site(call_node: u32, callee_ident: u32, argc: u32) -> u32 {
    let ck: u32 = iii_ast_node_kind(R3_G_AST, callee_ident)
    if ck != R3_K_EXPR_IDENT { return R3_OK }
    let callee_decl: u32 = iii_ast_node_binder_id(R3_G_AST, callee_ident)
    if callee_decl == 0u32 { return R3_OK }
    let callee_dk: u32 = iii_ast_node_kind(R3_G_AST, callee_decl)
    if callee_dk != R3_K_FN_DECL { return R3_OK }
    let rc1: u32 = r3_chk_cap_and_kfloor(callee_decl)
    if rc1 != R3_OK { return rc1 }
    let rc2: u32 = r3_chk_param_kinds(call_node, callee_decl, argc)
    if rc2 != R3_OK { return rc2 }
    let rc3: u32 = r3_chk_param_sovereign(call_node, callee_decl, argc)
    if rc3 != R3_OK { return rc3 }
    let rc4: u32 = r3_chk_param_sovereign_out(call_node, callee_decl, argc)
    if rc4 != R3_OK { return rc4 }
    return R3_OK
}

/* iiis-1 bit-identity helper: try reserving struct-decl slots for
 * a let-binding.  Returns 1 if the struct lookup succeeded and
 * slots were reserved (caller should return R3_OK); 0 if the
 * type-ref isn't a known struct (caller should fall through to
 * scalar handling).  Mirrors cg_r3.c's STRUCT_DECL slot reservation. */
fn r3_try_struct_slots(type_node: u32, name_off: u32, name_len: u32, value_expr: u32) -> u32 {
    let st_off: u32 = iii_ast_type_ref_name_off(R3_G_AST, type_node)
    let st_len: u32 = iii_ast_type_ref_name_len(R3_G_AST, type_node)
    if st_len == 0u32 { return 0u32 }
    if r3_copy_to_cstr(&R3_FIELD_TNM as u64, st_off, st_len) != 0u32 { return 0u32 }
    let sd: u32 = iii_sema_struct_decl_for_name(R3_G_SEMA, &R3_FIELD_TNM as u64)
    if sd == 0u32 { return 0u32 }
    let ns: u32 = iii_sema_struct_size_slots(R3_G_SEMA, sd)
    if ns == 0u32 { return 0u32 }
    r3_local_add(name_off, name_len)
    let mut ex: u32 = 1u32
    while ex < ns {
        R3_G_LOCAL_COUNT = R3_G_LOCAL_COUNT + 1u32
        ex = ex + 1u32
    }
    if value_expr != 0u32 {
        r3_emit_expr(value_expr)
        r3_pop_rax()
    }
    return 1u32
}

/* iiis-1 STATIC return-kind check helper.  Called from STMT_LET when
 * the value expression is non-null.  Checks that, if the let's type
 * carries @hexad_kind(K_l) and the value is a direct CALL whose
 * callee declares @returns_hexad(K_r), K_l == K_r.  Returns R3_OK
 * (silent skip when no annotation present) or R3_E_INTERNAL on
 * violation. */
fn r3_chk_let_return_kind(let_node: u32, value_node: u32) -> u32 {
    let lt: u32 = iii_ast_let_type(R3_G_AST, let_node)
    if lt == 0u32 { return R3_OK }
    let lkind: u64 = r3_type_node_extract_u64(lt, &R3_MOD_HEXAD_KIND as u64, R3_MOD_HEXAD_KIND_LEN)
    if R3_G_MOD_FOUND != 1u32 { return R3_OK }
    let vk: u32 = iii_ast_node_kind(R3_G_AST, value_node)
    if vk != R3_K_EXPR_CALL { return R3_OK }
    let v_callee: u32 = iii_ast_call_callee(R3_G_AST, value_node)
    let v_ck: u32 = iii_ast_node_kind(R3_G_AST, v_callee)
    if v_ck != R3_K_EXPR_IDENT { return R3_OK }
    let v_decl: u32 = iii_ast_node_binder_id(R3_G_AST, v_callee)
    if v_decl == 0u32 { return R3_OK }
    let v_dk: u32 = iii_ast_node_kind(R3_G_AST, v_decl)
    if v_dk != R3_K_FN_DECL { return R3_OK }
    let rkind: u64 = r3_fn_mod_extract_u64(v_decl, &R3_MOD_RETURNS_HEXAD as u64, R3_MOD_RETURNS_HEXAD_LEN)
    if R3_G_MOD_FOUND != 1u32 { return R3_OK }
    if lkind != rkind {
        r3_emit_arr(&R3_VM_RKV1 as u64, 44u64) ; r3_emit_hex(lkind)
        r3_emit_arr(&R3_VM_RKV2 as u64, 37u64) ; r3_emit_hex(rkind)
        r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        R3_G_LAST_ERROR = R3_E_INTERNAL
        R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32
        return R3_E_INTERNAL
    }
    return R3_OK
}

/* iiis-1 param-kind check loop.  Iterates the (param, arg) pairs of
 * a CALL; for each pair where param's type has @hexad_kind AND arg
 * has a discoverable effective kind, asserts equality.  Returns
 * R3_OK or R3_E_INTERNAL on violation. */
fn r3_chk_param_kinds(call_node: u32, callee_decl: u32, argc: u32) -> u32 {
    let pcount: u32 = iii_ast_fn_param_count(R3_G_AST, callee_decl)
    let mut cn: u32 = pcount
    if argc < cn { cn = argc }
    let mut i: u32 = 0u32
    while i < cn {
        let pid: u32 = iii_ast_fn_param_at(R3_G_AST, callee_decl, i)
        let ptn: u32 = iii_ast_param_type(R3_G_AST, pid)
        let pkind: u64 = r3_type_node_extract_u64(ptn, &R3_MOD_HEXAD_KIND as u64, R3_MOD_HEXAD_KIND_LEN)
        let p_has: u32 = R3_G_MOD_FOUND
        if p_has == 1u32 {
            let aid: u32 = iii_ast_call_arg_at(R3_G_AST, call_node, i)
            let aval: u32 = iii_ast_arg_value(R3_G_AST, aid)
            let akind: u64 = r3_get_arg_kind(aval)
            let a_has: u32 = R3_G_MOD_FOUND
            if a_has == 1u32 {
                if akind != pkind {
                    r3_emit_arr(&R3_VM_IKV1 as u64, 37u64) ; r3_emit_dec(i as u64)
                    r3_emit_arr(&R3_VM_IKV2 as u64, 8u64) ; r3_emit_hex(akind)
                    r3_emit_arr(&R3_VM_IKV3 as u64, 29u64) ; r3_emit_hex(pkind)
                    r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
                    R3_G_LAST_ERROR = R3_E_INTERNAL
                    R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32
                    return R3_E_INTERNAL
                }
            }
        }
        i = i + 1u32
    }
    return R3_OK
}

/* iiis-2 type-alias resolution: extract a named modifier's u64 value
 * from a type-node.  Tries the type_ref's inline modifier list first,
 * then walks the alias chain to a fixpoint (Stage 3.6 multi-hop): each
 * hop checks the resolved TYPE_DECL's modifiers + its rhs_type's inline
 * modifiers, then descends to the rhs's named type.  Depth-bounded at 8
 * so cyclic aliases terminate.  Mirrors cg_r3.c's type_node_extract_u64. */
fn r3_type_node_extract_u64(type_node: u32, name_addr: u64, name_len: u64) -> u64 {
    R3_G_MOD_FOUND = 0u32
    if type_node == 0u32 { return 0u64 }
    let tk: u32 = iii_ast_node_kind(R3_G_AST, type_node)
    if tk != R3_K_TYPE_REF { return 0u64 }
    /* Pass 1: inline modifiers on the TYPE_REF. */
    let inline_count: u32 = iii_ast_type_ref_modifier_count(R3_G_AST, type_node)
    let mut i: u32 = 0u32
    while i < inline_count {
        let m: u32 = iii_ast_type_ref_modifier_at(R3_G_AST, type_node, i)
        let no: u32 = iii_ast_modifier_name_offset(R3_G_AST, m)
        let nl: u32 = iii_ast_modifier_name_length(R3_G_AST, m)
        if r3_name_eq_lit(no, nl, name_addr, name_len) == 1u32 {
            return r3_mod_extract_u64_value(m)
        }
        i = i + 1u32
    }
    /* Walk the alias chain to a fixpoint (Stage 3.6 multi-hop), depth
     * bounded at 8.  Iteration 0 (cur = type_node) is the old single-hop
     * Pass 2 (alias decl modifiers) + Pass 3 (rhs inline modifiers); each
     * further hop descends to the rhs's named type, so `type C = B`,
     * `type B = A`, `type A = u64 @hexad_kind(K)` flows K through C. */
    let mut cur: u32 = type_node
    let mut depth: u32 = 0u32
    while depth < 8u32 {
        let cur_off: u32 = iii_ast_type_ref_name_off(R3_G_AST, cur)
        let cur_len: u32 = iii_ast_type_ref_name_len(R3_G_AST, cur)
        if cur_len == 0u32 { return 0u64 }
        let alias: u32 = iii_ast_type_decl_for_name(R3_G_AST, cur_off, cur_len)
        if alias == 0u32 { return 0u64 }
        let alias_count: u32 = iii_ast_type_decl_modifier_count(R3_G_AST, alias)
        let mut j: u32 = 0u32
        while j < alias_count {
            let am: u32 = iii_ast_type_decl_modifier_at(R3_G_AST, alias, j)
            let ano: u32 = iii_ast_modifier_name_offset(R3_G_AST, am)
            let anl: u32 = iii_ast_modifier_name_length(R3_G_AST, am)
            if r3_name_eq_lit(ano, anl, name_addr, name_len) == 1u32 {
                return r3_mod_extract_u64_value(am)
            }
            j = j + 1u32
        }
        let rhs: u32 = iii_ast_type_decl_rhs_type(R3_G_AST, alias)
        if rhs == 0u32 { return 0u64 }
        let rk: u32 = iii_ast_node_kind(R3_G_AST, rhs)
        if rk != R3_K_TYPE_REF { return 0u64 }
        let rhs_count: u32 = iii_ast_type_ref_modifier_count(R3_G_AST, rhs)
        let mut h: u32 = 0u32
        while h < rhs_count {
            let rm: u32 = iii_ast_type_ref_modifier_at(R3_G_AST, rhs, h)
            let rno: u32 = iii_ast_modifier_name_offset(R3_G_AST, rm)
            let rnl: u32 = iii_ast_modifier_name_length(R3_G_AST, rm)
            if r3_name_eq_lit(rno, rnl, name_addr, name_len) == 1u32 {
                return r3_mod_extract_u64_value(rm)
            }
            h = h + 1u32
        }
        cur = rhs
        depth = depth + 1u32
    }
    return 0u64
}

/* mig3 (H1 @sovereign): presence-check variant of r3_type_node_extract_u64.
 * Returns 1u32 if `type_node`'s resolved type carries the named modifier
 * (a BARE marker with no u64 arg, e.g. @sovereign_value), else 0u32.  Same
 * resolution as extract_u64: inline TYPE_REF modifiers, then the alias chain
 * (each hop checks the TYPE_DECL's modifiers, where the parser attaches a
 * trailing marker per iiip_parse_type_decl, then the rhs's inline modifiers),
 * depth-bounded at 8.  A pointer-alias like `type SovVal = *u8 @sovereign_value`
 * is detected via the TYPE_DECL-modifier path before the non-TYPE_REF rhs bail. */
fn r3_type_node_has_mod(type_node: u32, name_addr: u64, name_len: u64) -> u32 {
    if type_node == 0u32 { return 0u32 }
    let tk: u32 = iii_ast_node_kind(R3_G_AST, type_node)
    if tk != R3_K_TYPE_REF { return 0u32 }
    let inline_count: u32 = iii_ast_type_ref_modifier_count(R3_G_AST, type_node)
    let mut i: u32 = 0u32
    while i < inline_count {
        let m: u32 = iii_ast_type_ref_modifier_at(R3_G_AST, type_node, i)
        let no: u32 = iii_ast_modifier_name_offset(R3_G_AST, m)
        let nl: u32 = iii_ast_modifier_name_length(R3_G_AST, m)
        if r3_name_eq_lit(no, nl, name_addr, name_len) == 1u32 { return 1u32 }
        i = i + 1u32
    }
    let mut cur: u32 = type_node
    let mut depth: u32 = 0u32
    while depth < 8u32 {
        let cur_off: u32 = iii_ast_type_ref_name_off(R3_G_AST, cur)
        let cur_len: u32 = iii_ast_type_ref_name_len(R3_G_AST, cur)
        if cur_len == 0u32 { return 0u32 }
        let alias: u32 = iii_ast_type_decl_for_name(R3_G_AST, cur_off, cur_len)
        if alias == 0u32 { return 0u32 }
        let alias_count: u32 = iii_ast_type_decl_modifier_count(R3_G_AST, alias)
        let mut j: u32 = 0u32
        while j < alias_count {
            let am: u32 = iii_ast_type_decl_modifier_at(R3_G_AST, alias, j)
            let ano: u32 = iii_ast_modifier_name_offset(R3_G_AST, am)
            let anl: u32 = iii_ast_modifier_name_length(R3_G_AST, am)
            if r3_name_eq_lit(ano, anl, name_addr, name_len) == 1u32 { return 1u32 }
            j = j + 1u32
        }
        let rhs: u32 = iii_ast_type_decl_rhs_type(R3_G_AST, alias)
        if rhs == 0u32 { return 0u32 }
        let rk: u32 = iii_ast_node_kind(R3_G_AST, rhs)
        if rk != R3_K_TYPE_REF { return 0u32 }
        let rhs_count: u32 = iii_ast_type_ref_modifier_count(R3_G_AST, rhs)
        let mut h: u32 = 0u32
        while h < rhs_count {
            let rm: u32 = iii_ast_type_ref_modifier_at(R3_G_AST, rhs, h)
            let rno: u32 = iii_ast_modifier_name_offset(R3_G_AST, rm)
            let rnl: u32 = iii_ast_modifier_name_length(R3_G_AST, rm)
            if r3_name_eq_lit(rno, rnl, name_addr, name_len) == 1u32 { return 1u32 }
            h = h + 1u32
        }
        cur = rhs
        depth = depth + 1u32
    }
    return 0u32
}

/* mig3 (H1 @sovereign): STATIC boundary law.  A function marked @sovereign
 * may accept ONLY @sovereign_value-typed params (the SovVal boundary type).
 * Each non-sovereign param emits III_SOVEREIGN_VIOLATION + bumps the error
 * count, which the top-level driver (r3_emit ... R3_G_ERROR_COUNT) lifts to a
 * non-zero compile result.  Inert for every fn not marked @sovereign, so the
 * self-host fixpoint + corpus are byte-unchanged.  Mirrors the cap-flow check
 * error convention (R3_G_LAST_ERROR/R3_G_ERROR_COUNT). */
fn r3_chk_sovereign(node: u32, kind: u32) -> u32 {
    if kind != R3_K_FN_DECL { return R3_OK }
    let sov_m: u32 = r3_mod_find(node, R3_K_FN_DECL, &R3_MOD_SOVEREIGN as u64, R3_MOD_SOVEREIGN_LEN)
    if sov_m == 0u32 { return R3_OK }
    let pc: u32 = iii_ast_fn_param_count(R3_G_AST, node)
    let mut i: u32 = 0u32
    while i < pc {
        let pid: u32 = iii_ast_fn_param_at(R3_G_AST, node, i)
        let pty: u32 = iii_ast_param_type(R3_G_AST, pid)
        if r3_type_node_has_mod(pty, &R3_MOD_SOVEREIGN_VALUE as u64, R3_MOD_SOVEREIGN_VALUE_LEN) == 0u32 {
            r3_emit_arr(&R3_VM_SOVBND as u64, R3_VM_SOVBND_LEN)
            R3_G_LAST_ERROR = R3_E_INTERNAL
            R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32
        }
        i = i + 1u32
    }
    return R3_OK
}

/* mig3 Part 2 (H1 propagation): is an argument SovVal (external/untrusted)?
 * Mirrors r3_get_arg_kind: an EXPR_IDENT bound to a SovVal-typed let/param, or
 * an EXPR_CALL to a source fn whose RETURN type carries @sovereign_value. */
fn r3_arg_is_sovereign(arg_value_node: u32) -> u32 {
    let avk: u32 = iii_ast_node_kind(R3_G_AST, arg_value_node)
    if avk == R3_K_EXPR_IDENT {
        let abid: u32 = iii_ast_node_binder_id(R3_G_AST, arg_value_node)
        if abid == 0u32 { return 0u32 }
        let abk: u32 = iii_ast_node_kind(R3_G_AST, abid)
        let mut at_n: u32 = 0u32
        if abk == R3_K_STMT_LET { at_n = iii_ast_let_type(R3_G_AST, abid) }
        if abk == R3_K_PARAM { at_n = iii_ast_param_type(R3_G_AST, abid) }
        if at_n == 0u32 { return 0u32 }
        return r3_type_node_has_mod(at_n, &R3_MOD_SOVEREIGN_VALUE as u64, R3_MOD_SOVEREIGN_VALUE_LEN)
    }
    if avk == R3_K_EXPR_CALL {
        let inner_callee: u32 = iii_ast_call_callee(R3_G_AST, arg_value_node)
        let inner_ck: u32 = iii_ast_node_kind(R3_G_AST, inner_callee)
        if inner_ck != R3_K_EXPR_IDENT { return 0u32 }
        let icd: u32 = iii_ast_node_binder_id(R3_G_AST, inner_callee)
        if icd == 0u32 { return 0u32 }
        let icdk: u32 = iii_ast_node_kind(R3_G_AST, icd)
        if icdk != R3_K_FN_DECL { return 0u32 }
        let crt: u32 = iii_ast_fn_return_type(R3_G_AST, icd)
        return r3_type_node_has_mod(crt, &R3_MOD_SOVEREIGN_VALUE as u64, R3_MOD_SOVEREIGN_VALUE_LEN)
    }
    return 0u32
}

/* mig3 Part 2 (H1 propagation): at a CALL, a SovVal arg may flow ONLY into a
 * @sovereign_value-typed param.  A SovVal value reaching a non-sovereign sink
 * (without an explicit sanitiser) is III_SOVEREIGN_FLOW_VIOLATION.  This is how
 * marking the few external-input SOURCES makes the boundary enforced everywhere
 * automatically: the systematic application is the compiler pass, not manual
 * per-fn annotation.  Inert for code with no SovVal sources (fixpoint-safe). */
fn r3_chk_param_sovereign(call_node: u32, callee_decl: u32, argc: u32) -> u32 {
    let pcount: u32 = iii_ast_fn_param_count(R3_G_AST, callee_decl)
    let mut cn: u32 = pcount
    if argc < cn { cn = argc }
    let mut i: u32 = 0u32
    while i < cn {
        let aid: u32 = iii_ast_call_arg_at(R3_G_AST, call_node, i)
        let aval: u32 = iii_ast_arg_value(R3_G_AST, aid)
        if r3_arg_is_sovereign(aval) == 1u32 {
            let pid: u32 = iii_ast_fn_param_at(R3_G_AST, callee_decl, i)
            let ptn: u32 = iii_ast_param_type(R3_G_AST, pid)
            if r3_type_node_has_mod(ptn, &R3_MOD_SOVEREIGN_VALUE as u64, R3_MOD_SOVEREIGN_VALUE_LEN) == 0u32 {
                r3_emit_arr(&R3_VM_SOVFLOW as u64, R3_VM_SOVFLOW_LEN) ; r3_emit_dec(i as u64)
                r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
                R3_G_LAST_ERROR = R3_E_INTERNAL
                R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32
                return R3_E_INTERNAL
            }
        }
        i = i + 1u32
    }
    return R3_OK
}

/* mig3 Part 3 (H1 out-param taint): the DUAL of r3_chk_param_sovereign.  At a
 * CALL, any param whose type carries @sovereign_out is an OUT buffer the callee
 * fills with untrusted external bytes (the recv/read sources, whose taint lives
 * on the buffer, not the return value).  The arg passed there MUST be sovereign
 * (a @sovereign_value buffer) so the taint is captured; a plain buffer loses it
 * and is III_SOVEREIGN_OUT_VIOLATION.  Marking one real source thus forces every
 * caller to hold the taint in the type system, where Part 2 then contains it --
 * the systematic application is this compiler pass.  Inert for any code with no
 * @sovereign_out param (fixpoint-safe). */
fn r3_chk_param_sovereign_out(call_node: u32, callee_decl: u32, argc: u32) -> u32 {
    let pcount: u32 = iii_ast_fn_param_count(R3_G_AST, callee_decl)
    let mut cn: u32 = pcount
    if argc < cn { cn = argc }
    let mut i: u32 = 0u32
    while i < cn {
        let pid: u32 = iii_ast_fn_param_at(R3_G_AST, callee_decl, i)
        let ptn: u32 = iii_ast_param_type(R3_G_AST, pid)
        if r3_type_node_has_mod(ptn, &R3_MOD_SOVEREIGN_OUT as u64, R3_MOD_SOVEREIGN_OUT_LEN) == 1u32 {
            let aid: u32 = iii_ast_call_arg_at(R3_G_AST, call_node, i)
            let aval: u32 = iii_ast_arg_value(R3_G_AST, aid)
            if r3_arg_is_sovereign(aval) == 0u32 {
                r3_emit_arr(&R3_VM_SOVOUT as u64, R3_VM_SOVOUT_LEN) ; r3_emit_dec(i as u64)
                r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
                R3_G_LAST_ERROR = R3_E_INTERNAL
                R3_G_ERROR_COUNT = R3_G_ERROR_COUNT + 1u32
                return R3_E_INTERNAL
            }
        }
        i = i + 1u32
    }
    return R3_OK
}

/* mig3 AUDIT manifest (always-on): emit one machine-readable III_SOVEREIGN_AUDIT
 * record per sovereign-marked declaration the compiler codegens -- SOVFN for a
 * @sovereign fn, SOURCE for a @sovereign_out param (fills an untrusted buffer),
 * SOVVAL for a @sovereign_value-only param (accepts/carries sovereign data).
 * Records go into the .o.s as assembly comments (stripped before .o), so this is
 * fixpoint- and corpus-inert; it fires only where a marker exists, so unmarked
 * code (incl. the compiler's own source) emits nothing.  This is how "III assists
 * in systematically applying the law": the compiler reports its own boundary
 * surface, which audit_sovereign.sh renders.  Called from r3_emit_function. */
fn r3_audit_sovereign(node: u32, kind: u32) -> u32 {
    if kind != R3_K_FN_DECL { return R3_OK }
    let noff: u32 = iii_ast_fn_name_off(R3_G_AST, node)
    let nlen: u32 = iii_ast_fn_name_len(R3_G_AST, node)
    if r3_mod_find(node, R3_K_FN_DECL, &R3_MOD_SOVEREIGN as u64, R3_MOD_SOVEREIGN_LEN) != 0u32 {
        r3_emit_arr(&R3_AUD_SOVFN as u64, R3_AUD_SOVFN_LEN) ; r3_emit_sym_run(noff, nlen) ; r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
    }
    let pc: u32 = iii_ast_fn_param_count(R3_G_AST, node)
    let mut i: u32 = 0u32
    while i < pc {
        let pid: u32 = iii_ast_fn_param_at(R3_G_AST, node, i)
        let pty: u32 = iii_ast_param_type(R3_G_AST, pid)
        let has_out: u32 = r3_type_node_has_mod(pty, &R3_MOD_SOVEREIGN_OUT as u64, R3_MOD_SOVEREIGN_OUT_LEN)
        if has_out == 1u32 {
            r3_emit_arr(&R3_AUD_SOURCE as u64, R3_AUD_SOURCE_LEN) ; r3_emit_sym_run(noff, nlen) ; r3_emit_arr(&R3_AUD_P as u64, R3_AUD_P_LEN) ; r3_emit_dec(i as u64) ; r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
        }
        if has_out == 0u32 {
            let has_val: u32 = r3_type_node_has_mod(pty, &R3_MOD_SOVEREIGN_VALUE as u64, R3_MOD_SOVEREIGN_VALUE_LEN)
            if has_val == 1u32 {
                r3_emit_arr(&R3_AUD_SOVVAL as u64, R3_AUD_SOVVAL_LEN) ; r3_emit_sym_run(noff, nlen) ; r3_emit_arr(&R3_AUD_P as u64, R3_AUD_P_LEN) ; r3_emit_dec(i as u64) ; r3_emit_arr(&R3_STR_NL as u64, R3_STR_NL_LEN)
            }
        }
        i = i + 1u32
    }
    return R3_OK
}

fn r3_decl_is_exported(node: u32, kind: u32) -> u32 { if r3_mod_find(node, kind, &R3_MOD_EXPORT as u64, R3_MOD_EXPORT_LEN) != 0u32 { return 1u32 }; return 0u32 }

/* XII Phase XII-θ: detect @lattice on a FN_DECL or CYCLE_DECL.
 * Returns 1 if the decl carries `@lattice`, 0 otherwise.  When 1,
 * the function body would route through the XII canonicalisation /
 * Lattice-fetched-bytes pipeline (cg_r3_xii.c + xii_ldil.c) instead of
 * the legacy r3_emit_block path.  Pipeline wiring is staged: this
 * detection is the prerequisite, and downstream emission requires the
 * AST→XII-term mapper and sealed-Lattice-cell-store to land first.
 * Until then no source file uses @lattice and this returns 0. */
fn r3_decl_has_lattice(node: u32, kind: u32) -> u32 { if r3_mod_find(node, kind, &R3_MOD_LATTICE as u64, R3_MOD_LATTICE_LEN) != 0u32 { return 1u32 }; return 0u32 }

/* Extract @fusion_budget(N) as u32.  Returns the integer argument of
 * the first @fusion_budget modifier, or 3 (the spec default per
 * DOCS/III-XII.md S15.2) if the modifier is absent or malformed.
 * Follows r3_mod_extract_u64_value's ARG-unwrap pattern. */
fn r3_decl_fusion_budget(node: u32, kind: u32) -> u32 {
    let m: u32 = r3_mod_find(node, kind, &R3_MOD_FUSION_BUDGET as u64, R3_MOD_FUSION_BUDGET_LEN)
    if m == 0u32 { return 3u32 }
    let ac: u32 = iii_ast_modifier_arg_count(R3_G_AST, m)
    if ac == 0u32 { return 3u32 }
    let arg_id: u32 = iii_ast_modifier_arg_at(R3_G_AST, m, 0u32)
    let inner: u32 = iii_ast_arg_value(R3_G_AST, arg_id)
    let k: u32 = iii_ast_node_kind(R3_G_AST, inner)
    if k == R3_K_EXPR_INT { return iii_ast_expr_int_u64(R3_G_AST, inner) as u32 }
    if k == R3_K_EXPR_HEX { return iii_ast_expr_hex_u64(R3_G_AST, inner) as u32 }
    return 3u32
}

/* Extract @deployment_target(T) as u32.  Returns the integer argument
 * of the first @deployment_target modifier, or 0xFFFFFFFF (AUTO,
 * per DOCS/III-XII.md S15.3) if absent or malformed. */
fn r3_decl_deployment_target(node: u32, kind: u32) -> u32 {
    let m: u32 = r3_mod_find(node, kind, &R3_MOD_DEPLOY_TARGET as u64, R3_MOD_DEPLOY_TARGET_LEN)
    if m == 0u32 { return 0xFFFFFFFFu32 }
    let ac: u32 = iii_ast_modifier_arg_count(R3_G_AST, m)
    if ac == 0u32 { return 0xFFFFFFFFu32 }
    let arg_id: u32 = iii_ast_modifier_arg_at(R3_G_AST, m, 0u32)
    let inner: u32 = iii_ast_arg_value(R3_G_AST, arg_id)
    let k: u32 = iii_ast_node_kind(R3_G_AST, inner)
    if k == R3_K_EXPR_INT { return iii_ast_expr_int_u64(R3_G_AST, inner) as u32 }
    if k == R3_K_EXPR_HEX { return iii_ast_expr_hex_u64(R3_G_AST, inner) as u32 }
    return 0xFFFFFFFFu32
}

/* iiis-1 bit-identity helper: returns 1 if the binder of an IDENT
 * should be emitted as a raw symbol (no L_ prefix) — i.e., the binder
 * is an EXTERN_DECL or an @export FN_DECL.  Mirrors cg_r3.c:1202-1224
 * and cg_r3.c:1319-1331 binder-kind dispatch. */
/* iiis-1 signed-type detection.  Returns 1 if the named TYPE_REF is
 * a signed integer (i8/i16/i32/i64), else 0.  Used by signed-aware
 * comparison setcc dispatch. */
fn r3_type_ref_is_signed(type_node: u32) -> u32 {
    if type_node == 0u32 { return 0u32 }
    let tk: u32 = iii_ast_node_kind(R3_G_AST, type_node)
    if tk != R3_K_TYPE_REF { return 0u32 }
    let no: u32 = iii_ast_type_ref_name_off(R3_G_AST, type_node)
    let nl: u32 = iii_ast_type_ref_name_len(R3_G_AST, type_node)
    if r3_name_eq_lit(no, nl, &R3_TY_I8 as u64, R3_TY_I8_LEN) == 1u32 { return 1u32 }
    if r3_name_eq_lit(no, nl, &R3_TY_I16 as u64, R3_TY_I16_LEN) == 1u32 { return 1u32 }
    if r3_name_eq_lit(no, nl, &R3_TY_I32 as u64, R3_TY_I32_LEN) == 1u32 { return 1u32 }
    if r3_name_eq_lit(no, nl, &R3_TY_I64 as u64, R3_TY_I64_LEN) == 1u32 { return 1u32 }
    if r3_name_eq_lit(no, nl, &R3_TY_ISIZE as u64, R3_TY_ISIZE_LEN) == 1u32 { return 1u32 }
    return 0u32
}

/* iiis-1 expr-signedness detection (single expression).  Walks
 * PAREN/CAST/IDENT to find a TYPE_REF for typedness, then dispatches
 * to r3_type_ref_is_signed.  Mirrors cg_r3.c's expr_is_signed.
 * Conservative: returns 0 for anything not clearly signed. */
fn r3_expr_is_signed(node: u32) -> u32 {
    if node == 0u32 { return 0u32 }
    let nk: u32 = iii_ast_node_kind(R3_G_AST, node)
    if nk == R3_K_EXPR_PAREN { return r3_expr_is_signed(iii_ast_paren_inner(R3_G_AST, node)) }
    if nk == R3_K_EXPR_CAST { return r3_type_ref_is_signed(iii_ast_cast_target_type(R3_G_AST, node)) }
    if nk == R3_K_EXPR_BINARY { if r3_expr_is_signed(iii_ast_binary_lhs(R3_G_AST, node)) == 1u32 { return 1u32 } ; return r3_expr_is_signed(iii_ast_binary_rhs(R3_G_AST, node)) }
    if nk == R3_K_EXPR_UNARY { return r3_expr_is_signed(iii_ast_unary_operand(R3_G_AST, node)) }
    if nk != R3_K_EXPR_IDENT { return 0u32 }
    let bid: u32 = iii_ast_node_binder_id(R3_G_AST, node)
    if bid == 0u32 { return 0u32 }
    let bk: u32 = iii_ast_node_kind(R3_G_AST, bid)
    if bk == R3_K_STMT_LET { return r3_type_ref_is_signed(iii_ast_let_type(R3_G_AST, bid)) }
    if bk == R3_K_PARAM { return r3_type_ref_is_signed(iii_ast_param_type(R3_G_AST, bid)) }
    if bk == R3_K_VAR_DECL { return r3_type_ref_is_signed(iii_ast_var_decl_type(R3_G_AST, bid)) }
    if bk == R3_K_CONST_DECL { return r3_type_ref_is_signed(iii_ast_const_decl_type(R3_G_AST, bid)) }
    return 0u32
}

fn r3_either_is_signed(a: u32, b: u32) -> u32 {
    if r3_expr_is_signed(a) == 1u32 { return 1u32 }
    if r3_expr_is_signed(b) == 1u32 { return 1u32 }
    return 0u32
}

/* True iff a type-ref is a 32-bit integer (u32/i32): byte size 4.
 * Mirrors cg_r3.c type_node_is_u32. */
fn r3_tref_is_u32(tn: u32) -> u32 { if r3_type_ref_byte_size(tn) == 4u32 { return 1u32 }; return 0u32 }

/* True iff node's static type is 32-bit (u32/i32).  Byte-exact mirror
 * of cg_r3.c expr_is_u32: PAREN->inner, CAST->type, BINARY->lhs,
 * UNARY->operand, IDENT->binder type; conservative default 0. */
fn r3_expr_is_u32(node: u32) -> u32 {
    if node == 0u32 { return 0u32 }
    let nk: u32 = iii_ast_node_kind(R3_G_AST, node)
    if nk == R3_K_EXPR_PAREN { return r3_expr_is_u32(iii_ast_paren_inner(R3_G_AST, node)) }
    if nk == R3_K_EXPR_CAST { return r3_tref_is_u32(iii_ast_cast_target_type(R3_G_AST, node)) }
    if nk == R3_K_EXPR_BINARY { return r3_expr_is_u32(iii_ast_binary_lhs(R3_G_AST, node)) }
    if nk == R3_K_EXPR_UNARY { return r3_expr_is_u32(iii_ast_unary_operand(R3_G_AST, node)) }
    if nk != R3_K_EXPR_IDENT { return 0u32 }
    let bid: u32 = iii_ast_node_binder_id(R3_G_AST, node)
    if bid == 0u32 { return 0u32 }
    let bk: u32 = iii_ast_node_kind(R3_G_AST, bid)
    if bk == R3_K_STMT_LET { return r3_tref_is_u32(iii_ast_let_type(R3_G_AST, bid)) }
    if bk == R3_K_PARAM { return r3_tref_is_u32(iii_ast_param_type(R3_G_AST, bid)) }
    if bk == R3_K_VAR_DECL { return r3_tref_is_u32(iii_ast_var_decl_type(R3_G_AST, bid)) }
    if bk == R3_K_CONST_DECL { return r3_tref_is_u32(iii_ast_const_decl_type(R3_G_AST, bid)) }
    return 0u32
}

/* Dispatch a signed-aware setcc for the four ordering operators. */
fn r3_emit_setcc_lt(signed: u32) -> u32 { if signed == 1u32 { r3_emit_arr(&R3_STR_SETL_S as u64, R3_STR_SETL_S_LEN); return R3_OK }; r3_emit_arr(&R3_STR_SETL as u64, R3_STR_SETL_LEN); return R3_OK }
fn r3_emit_setcc_le(signed: u32) -> u32 { if signed == 1u32 { r3_emit_arr(&R3_STR_SETLE_S as u64, R3_STR_SETLE_S_LEN); return R3_OK }; r3_emit_arr(&R3_STR_SETLE as u64, R3_STR_SETLE_LEN); return R3_OK }
