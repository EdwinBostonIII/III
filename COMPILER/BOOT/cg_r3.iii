    if bk == R3_K_FN_DECL { if r3_decl_is_exported(bid, R3_K_FN_DECL) == 1u32 { return 1u32 } }
    return 0u32
}

fn r3_ring_ok_for_r3(node: u32, kind: u32) -> u32 { let m: u32 = r3_mod_find(node, kind, &R3_MOD_RING as u64, R3_MOD_RING_LEN); if m == 0u32 { return 1u32 }; let mask: u32 = iii_ast_modifier_ring_mask(R3_G_AST, m); if mask == 0u32 { return 1u32 }; if (mask & R3_RING_MASK_R3) != 0u32 { return 1u32 }; return 0u32 }

/* ─────────────── label dedup (4096-entry, linear scan via byte arena) ─────────────── */
fn r3_label_already_defined(off: u32, len: u32) -> u32 { let src: u64 = iii_ast_source_buf(R3_G_AST); let mut i: u32 = 0u32; while i < R3_G_DEFINED_LABEL_COUNT { if R3_DEFINED_LABEL_LEN[i] == len { if iii_emit_memcmp_c((&R3_DEFINED_LABEL_BUF as u64) + (R3_DEFINED_LABEL_OFF[i] as u64), src + (off as u64), len as u64) == 0i32 { return 1u32 } }; i = i + 1u32 }; return 0u32 }

fn r3_label_record(off: u32, len: u32) -> u32 { if R3_G_DEFINED_LABEL_COUNT >= R3_MAX_LABELS { R3_G_LAST_ERROR = R3_E_INTERNAL; return R3_E_INTERNAL }; if (R3_DEFINED_LABEL_BUFUSE + len) > 65536u32 { R3_G_LAST_ERROR = R3_E_INTERNAL; return R3_E_INTERNAL }; let src: u64 = iii_ast_source_buf(R3_G_AST); iii_emit_memcpy_c((&R3_DEFINED_LABEL_BUF as u64) + (R3_DEFINED_LABEL_BUFUSE as u64), src + (off as u64), len as u64); R3_DEFINED_LABEL_OFF[R3_G_DEFINED_LABEL_COUNT] = R3_DEFINED_LABEL_BUFUSE; R3_DEFINED_LABEL_LEN[R3_G_DEFINED_LABEL_COUNT] = len; R3_DEFINED_LABEL_BUFUSE = R3_DEFINED_LABEL_BUFUSE + len; R3_G_DEFINED_LABEL_COUNT = R3_G_DEFINED_LABEL_COUNT + 1u32; return R3_OK }

fn r3_reset_for_function() -> u32 { R3_G_LOCAL_COUNT = 0u32; R3_G_STACK_DEPTH = 0u32; R3_G_MAX_STACK_DEPTH = 0u32; return R3_OK }

/* ─────────────── error name lookup (D14 reporting) ─────────────── */
fn iii_cg_r3_error_name(code: u32) -> u64 @export { if code == R3_OK { return &R3_ENAME_OK as u64 }; if code == R3_E_NULL_ARG { return &R3_ENAME_NULL_ARG as u64 }; if code == R3_E_IO { return &R3_ENAME_IO as u64 }; if code == R3_E_UNSUPPORTED { return &R3_ENAME_UNSUPPORTED as u64 }; if code == R3_E_ABI_ALIGN { return &R3_ENAME_ABI_ALIGN as u64 }; if code == R3_E_DUP_LABEL { return &R3_ENAME_DUP_LABEL as u64 }; if code == R3_E_WITNESS_MISMATCH { return &R3_ENAME_WITNESS_MISMATCH as u64 }; if code == R3_E_INTERNAL { return &R3_ENAME_INTERNAL as u64 }; return &R3_ENAME_UNKNOWN as u64 }

fn iii_cg_r3_last_error() -> u32 @export { return R3_G_LAST_ERROR }
fn iii_cg_r3_error_count() -> u32 @export { return R3_G_ERROR_COUNT }
fn iii_cg_r3_get_witness(out32: u64) -> u32 @export { iii_emit_memcpy_c(out32, &R3_MHASH_CACHE as u64, 32u64); return R3_OK }
fn iii_cg_r3_set_expected_witness(in32: u64) -> u32 @export { iii_emit_memcpy_c(&R3_EXPECTED_WITNESS as u64, in32, 32u64); R3_G_HAS_EXPECTED_WITNESS = 1u32; return R3_OK }
fn r3_addr_eq_lit(addr: u64, len: u64, lit_addr: u64, lit_len: u64) -> u32 { if len != lit_len { return 0u32 }; if iii_emit_memcmp_c(addr, lit_addr, lit_len) == 0i32 { return 1u32 }; return 0u32 }
