/* III Stage-0 Ring 3 codegen — cg_r3.c port to .iii.
 * Windows user-mode (.exe / .obj).  ABI-compatible with cg_r3.h.
 * Singleton state, MS x64 calling convention, 4096-entry label dedup,
 * 64-entry locals, D6 opcode table, D7 dup-label, D9 ring3 wall,
 * D11 error-recovery walk, D14 expected-witness compare, D8 cycle
 * markers.  All AST and file I/O routed through accessor surfaces
 * (NIH, no third-party libs).
 *
 * CP-025 scope: preamble — consts, externs, state, base primitives.
 * NOT yet in PORTED_TUS — iiis-1 stays green.
 */
module cgr3

const R3_OK: u32 = 0u32
const R3_E_NULL_ARG: u32 = 1u32
const R3_E_IO: u32 = 2u32
const R3_E_UNSUPPORTED: u32 = 3u32
const R3_E_ABI_ALIGN: u32 = 4u32
const R3_E_DUP_LABEL: u32 = 5u32
const R3_E_WITNESS_MISMATCH: u32 = 6u32
const R3_E_INTERNAL: u32 = 99u32

const R3_FRAME_RESERVE: u32 = 256u32
const R3_MAX_LOCALS: u32 = 64u32
const R3_MAX_LABELS: u32 = 4096u32
const R3_RING_MASK_R3: u32 = 1u32

