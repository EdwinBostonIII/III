var R3_AUD_SOVFN : [u8; 32] = [32u8, 32u8, 32u8, 32u8, 35u8, 32u8, 73u8, 73u8, 73u8, 95u8, 83u8, 79u8, 86u8, 69u8, 82u8, 69u8, 73u8, 71u8, 78u8, 95u8, 65u8, 85u8, 68u8, 73u8, 84u8, 32u8, 83u8, 79u8, 86u8, 70u8, 78u8, 32u8]
