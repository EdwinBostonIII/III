/* III Stage-0 Ring -1 (HV / hypervisor) codegen — front-end over the shared sanctum-family engine.
 *
 * The Ring -1 lowering, instruction vocabulary, sanctum state, and the HV-specific table emitters
 * (bare-metal entry, VMX/SVM dispatch, VMRUN brackets, VMEXIT/SLAT tables, witness, HV entry) now live
 * ONCE in emit_sanctum.iii (module `sanctum`), driven in HV mode (SV_MODE=1) and shared with the Ring -2
 * sanctum front-end (cg_rm2). The R-1↔R-2 byte streams are reproduced exactly via SV_MODE + config
 * pointers. This file routes the public cg_rm1 ABI to the engine and flips it into HV mode at create.
 */

module cgrm1

extern @abi(c-msvc-x64) fn sv_create(ast: u64, sema: u64, sid: u64, walloc: u64) -> u64 from "emit_sanctum.iii"
extern @abi(c-msvc-x64) fn sv_set_mode_hv() from "emit_sanctum.iii"
extern @abi(c-msvc-x64) fn sv_destroy(cg: u64) from "emit_sanctum.iii"
extern @abi(c-msvc-x64) fn sv_set_format(cg: u64, fmt: u32) from "emit_sanctum.iii"
extern @abi(c-msvc-x64) fn sv_set_const_time(cg: u64, on: u32) from "emit_sanctum.iii"
extern @abi(c-msvc-x64) fn sv_emit_module(cg: u64, out: u64) -> u32 from "emit_sanctum.iii"
extern @abi(c-msvc-x64) fn sv_module_finish(cg: u64) -> u32 from "emit_sanctum.iii"
extern @abi(c-msvc-x64) fn sv_section_mhash(cg: u64, out_mhash: u64) -> u32 from "emit_sanctum.iii"
extern @abi(c-msvc-x64) fn sv_last_error(cg: u64) -> u32 from "emit_sanctum.iii"
extern @abi(c-msvc-x64) fn sv_error_name(code: u32) -> u64 from "emit_sanctum.iii"

fn iii_cg_rm1_create(ast: u64, sema: u64, sid: u64, walloc: u64) -> u64 @export { let h: u64 = sv_create(ast, sema, sid, walloc); if h == 0u64 { return 0u64 }; sv_set_mode_hv(); return h }
fn iii_cg_rm1_destroy(cg: u64) @export { sv_destroy(cg) }
fn iii_cg_rm1_set_format(cg: u64, fmt: u32) @export { sv_set_format(cg, fmt) }
fn iii_cg_rm1_set_const_time(cg: u64, on: u32) @export { sv_set_const_time(cg, on) }
fn iii_cg_rm1_emit_module(cg: u64, out: u64) -> u32 @export { return sv_emit_module(cg, out) }
fn iii_cg_rm1_module_finish(cg: u64) -> u32 @export { return sv_module_finish(cg) }
fn iii_cg_rm1_section_mhash(cg: u64, out_mhash: u64) -> u32 @export { return sv_section_mhash(cg, out_mhash) }
fn iii_cg_rm1_last_error(cg: u64) -> u32 @export { return sv_last_error(cg) }
fn iii_cg_rm1_error_name(code: u32) -> u64 @export { return sv_error_name(code) }
