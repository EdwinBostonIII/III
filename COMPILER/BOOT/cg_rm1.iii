var RM1_ENAME_SEALED : [u8; 6] = [83u8, 69u8, 65u8, 76u8, 69u8, 68u8]
const RM1_ENAME_SEALED_LEN : u64 = 6u64
var RM1_ENAME_INTERNAL : [u8; 8] = [73u8, 78u8, 84u8, 69u8, 82u8, 78u8, 65u8, 76u8]
const RM1_ENAME_INTERNAL_LEN : u64 = 8u64
var RM1_ENAME_UNKNOWN : [u8; 9] = [60u8, 117u8, 110u8, 107u8, 110u8, 111u8, 119u8, 110u8, 62u8]
const RM1_ENAME_UNKNOWN_LEN : u64 = 9u64

fn rm1_cg_emit_bytes(addr: u64, n: u64) -> u32 { if RM1_G_SEALED != 0u32 { RM1_G_LAST_ERROR = RM1_E_SEALED; return RM1_E_SEALED }; if n == 0u64 { return RM1_OK }; if RM1_G_OUT != 0u64 { if iii_cg_rm1_fwrite_c(RM1_G_OUT, addr, n) != 0i32 { RM1_G_LAST_ERROR = RM1_E_IO; return RM1_E_IO } }; iii_cg_rm1_sha_update_c(addr,n); return RM1_OK }
fn rm1_cg_emit_arr(addr: u64, n: u64) -> u32 { return rm1_cg_emit_bytes(addr,n) }
fn rm1_cg_emit_ch(ch: u32) -> u32 { RM1_NUMBUF[0] = (ch & 0xffu32) as u8; return rm1_cg_emit_bytes(&RM1_NUMBUF as u64,1u64) }
fn rm1_cg_emit_dec(v0: u64) -> u32 { let mut v: u64 = v0; let mut n: u32 = 0u32; if v == 0u64 { RM1_NUMBUF[0]=48u8; return rm1_cg_emit_bytes(&RM1_NUMBUF as u64,1u64) }; while v > 0u64 { RM1_NUMBUF[n] = (48u64 + (v % 10u64)) as u8; n = n + 1u32; v = v / 10u64 }; let mut a: u32 = 0u32; let mut b: u32 = n - 1u32; while a < b { let tmp: u8 = RM1_NUMBUF[a]; RM1_NUMBUF[a] = RM1_NUMBUF[b]; RM1_NUMBUF[b] = tmp; a = a + 1u32; b = b - 1u32 }; return rm1_cg_emit_bytes(&RM1_NUMBUF as u64, n as u64) }
fn rm1_cg_emit_hex(v0: u64) -> u32 { let mut v: u64 = v0; let mut n: u32 = 0u32; if v == 0u64 { RM1_NUMBUF[0]=48u8; return rm1_cg_emit_bytes(&RM1_NUMBUF as u64,1u64) }; while v != 0u64 { let d: u64 = v & 15u64; if d < 10u64 { RM1_NUMBUF[n] = (48u64+d) as u8 } else { RM1_NUMBUF[n] = (87u64+d) as u8 }; n = n + 1u32; v = v >> 4u64 }; let mut a: u32 = 0u32; let mut b: u32 = n - 1u32; while a < b { let tmp: u8 = RM1_NUMBUF[a]; RM1_NUMBUF[a] = RM1_NUMBUF[b]; RM1_NUMBUF[b] = tmp; a = a + 1u32; b = b - 1u32 }; return rm1_cg_emit_bytes(&RM1_NUMBUF as u64, n as u64) }
/* NOTE: nibbles extracted via mask(&15)+shift(>>4), NOT %16/÷16: iiis-0 compiles
 * u64 %/÷ as SIGNED idiv, so 0xFFFF..FF%16 = -1 -> (87-1)=0x56='V'.  [u64-div-signed trap; Stage 3 compiler fix pending] */
fn rm1_emit_section_text() -> u32 { if RM1_G_FMT == RM1_FMT_PE { return rm1_cg_emit_arr(&RM1_SEC_TEXT_PE as u64, RM1_SEC_TEXT_PE_LEN) }; return rm1_cg_emit_arr(&RM1_SEC_TEXT_ELF as u64, RM1_SEC_TEXT_ELF_LEN) }
fn rm1_emit_section_rodata() -> u32 { if RM1_G_FMT == RM1_FMT_PE { return rm1_cg_emit_arr(&RM1_SEC_RODATA_PE as u64, RM1_SEC_RODATA_PE_LEN) }; return rm1_cg_emit_arr(&RM1_SEC_RODATA_ELF as u64, RM1_SEC_RODATA_ELF_LEN) }
fn rm1_is_sym_char(b: u32) -> u32 { if b >= 65u32 { if b <= 90u32 { return 1u32 } }; if b >= 97u32 { if b <= 122u32 { return 1u32 } }; if b >= 48u32 { if b <= 57u32 { return 1u32 } }; if b == 95u32 { return 1u32 }; return 0u32 }
fn rm1_emit_mangled(off: u32, len: u32) -> u32 { let src: u64 = iii_ast_source_buf(RM1_G_AST); rm1_cg_emit_arr(&RM1_HV_LHV as u64,RM1_HV_LHV_LEN); let mut i: u32 = 0u32; while i < len { let b: u32 = iii_emit_buf_read_u8_c(src, (off+i) as u64); if rm1_is_sym_char(b) == 1u32 { rm1_cg_emit_ch(b) } else { rm1_cg_emit_ch(95u32) }; i = i + 1u32 }; return RM1_OK }
fn rm1_build_mangled(off: u32, len: u32) -> u32 { let src: u64 = iii_ast_source_buf(RM1_G_AST); iii_emit_memcpy_c(&RM1_TMPNAME as u64, &RM1_HV_LHV as u64, RM1_HV_LHV_LEN); let mut k: u32 = RM1_HV_LHV_LEN as u32; let mut i: u32 = 0u32; while i < len { let b: u32 = iii_emit_buf_read_u8_c(src,(off+i) as u64); if rm1_is_sym_char(b) == 1u32 { RM1_TMPNAME[k] = b as u8 } else { RM1_TMPNAME[k] = 95u8 }; k = k + 1u32; i = i + 1u32; if k >= 255u32 { RM1_TMPNAME[k]=0u8; return k } }; RM1_TMPNAME[k]=0u8; return k }
fn rm1_sym_is_permitted(addr: u64, n: u32) -> u32 { if n >= (RM1_HV_LHV_LEN as u32) { if iii_emit_memcmp_c(addr,&RM1_HV_LHV as u64,RM1_HV_LHV_LEN) == 0i32 { return 1u32 } }; if n >= (RM1_PFX_LSANCTUM_LEN as u32) { if iii_emit_memcmp_c(addr,&RM1_PFX_LSANCTUM as u64,RM1_PFX_LSANCTUM_LEN) == 0i32 { return 1u32 } }; if n >= (RM1_PFX_IIISANCTUM_LEN as u32) { if iii_emit_memcmp_c(addr,&RM1_PFX_IIISANCTUM as u64,RM1_PFX_IIISANCTUM_LEN) == 0i32 { return 1u32 } }; if n >= (RM1_PFX_XIISANCTUM_LEN as u32) { if iii_emit_memcmp_c(addr,&RM1_PFX_XIISANCTUM as u64,RM1_PFX_XIISANCTUM_LEN) == 0i32 { return 1u32 } }; if n >= (RM1_PFX_IIICAP_LEN as u32) { if iii_emit_memcmp_c(addr,&RM1_PFX_IIICAP as u64,RM1_PFX_IIICAP_LEN) == 0i32 { return 1u32 } }; return 0u32 }
fn rm1_guard_symbol_load(addr: u64, n: u32) -> u32 { if rm1_sym_is_permitted(addr,n) == 0u32 { RM1_G_LAST_ERROR=RM1_E_FORBIDDEN_TARGET; return RM1_E_FORBIDDEN_TARGET }; if n == (RM1_SYM_ONEWAY_LEN as u32) { if iii_emit_memcmp_c(addr,&RM1_SYM_ONEWAY as u64,RM1_SYM_ONEWAY_LEN)==0i32 { RM1_G_LAST_ERROR=RM1_E_ONEWAY_READ; return RM1_E_ONEWAY_READ } }; return RM1_OK }
fn rm1_emit_sym_address(addr: u64, n: u32, reg: u64, regn: u64) -> u32 { let e: u32 = rm1_guard_symbol_load(addr,n); if e != RM1_OK { return e }; rm1_cg_emit_arr(&RM1_STR_LEAQ as u64,RM1_STR_LEAQ_LEN); rm1_cg_emit_bytes(addr,n as u64); rm1_cg_emit_arr(&RM1_STR_RIPCM_PCT as u64,RM1_STR_RIPCM_PCT_LEN); rm1_cg_emit_bytes(reg,regn); rm1_cg_emit_arr(&RM1_STR_NL as u64,RM1_STR_NL_LEN); return RM1_OK }
fn rm1_local_slot(off: u32, len: u32) -> i32 { let src: u64 = iii_ast_source_buf(RM1_G_AST); let mut i: u32 = 0u32; while i < RM1_G_LOCAL_COUNT { if RM1_LOCAL_LEN[i] == len { if iii_emit_memcmp_c(src+(RM1_LOCAL_OFF[i] as u64), src+(off as u64), len as u64) == 0i32 { return i as i32 } }; i = i + 1u32 }; return -1i32 }
fn rm1_local_add(off: u32, len: u32) -> u32 { if RM1_G_LOCAL_COUNT >= RM1_MAX_LOCALS { RM1_G_LAST_ERROR=RM1_E_INTERNAL; return RM1_E_INTERNAL }; RM1_LOCAL_OFF[RM1_G_LOCAL_COUNT]=off; RM1_LOCAL_LEN[RM1_G_LOCAL_COUNT]=len; RM1_G_LOCAL_COUNT = RM1_G_LOCAL_COUNT + 1u32; return RM1_OK }
fn rm1_push_rax() -> u32 { rm1_cg_emit_arr(&RM1_STR_PUSHRAX as u64,RM1_STR_PUSHRAX_LEN); RM1_G_STACK_DEPTH=RM1_G_STACK_DEPTH+1u32; return RM1_OK }
fn rm1_pop_reg(reg: u64, n: u64) -> u32 { rm1_cg_emit_arr(&RM1_STR_POPRAX as u64,0u64); rm1_cg_emit_arr(&RM1_STR_MOVQ_LD as u64,0u64); rm1_cg_emit_arr(&RM1_STR_POPRAX as u64,10u64); rm1_cg_emit_bytes(reg,n); rm1_cg_emit_arr(&RM1_STR_NL as u64,RM1_STR_NL_LEN); if RM1_G_STACK_DEPTH > 0u32 { RM1_G_STACK_DEPTH=RM1_G_STACK_DEPTH-1u32 }; return RM1_OK }

fn rm1_emit_movabs_rax(v: u64) -> u32 { rm1_cg_emit_arr(&RM1_STR_MOVABSQ_OPEN as u64,RM1_STR_MOVABSQ_OPEN_LEN); rm1_cg_emit_hex(v); rm1_cg_emit_arr(&RM1_STR_COMMA_RAX_NL as u64,RM1_STR_COMMA_RAX_NL_LEN); return RM1_OK }
fn rm1_emit_movabs_rcx(v: u64) -> u32 { rm1_cg_emit_arr(&RM1_STR_MOVABSQ_OPEN as u64,RM1_STR_MOVABSQ_OPEN_LEN); rm1_cg_emit_hex(v); rm1_cg_emit_arr(&RM1_STR_COMMA_RCX_NL as u64,RM1_STR_COMMA_RCX_NL_LEN); return RM1_OK }
fn rm1_emit_load_slot(slot: u32, reg: u64, regn: u64) -> u32 { rm1_cg_emit_arr(&RM1_STR_DASH_OPEN as u64,RM1_STR_DASH_OPEN_LEN); rm1_cg_emit_dec(((slot+1u32)*8u32) as u64); rm1_cg_emit_arr(&RM1_STR_PCT_RBP_NL as u64,6u64); rm1_cg_emit_arr(&RM1_STR_COMMA_SP as u64,RM1_STR_COMMA_SP_LEN); rm1_cg_emit_ch(37u32); rm1_cg_emit_bytes(reg,regn); rm1_cg_emit_arr(&RM1_STR_NL as u64,RM1_STR_NL_LEN); return RM1_OK }
fn rm1_emit_store_rax_slot(slot: u32) -> u32 { rm1_cg_emit_arr(&RM1_STR_MOVQRAX_DASH as u64,RM1_STR_MOVQRAX_DASH_LEN); rm1_cg_emit_dec(((slot+1u32)*8u32) as u64); rm1_cg_emit_arr(&RM1_STR_PCT_RBP_NL as u64,6u64); rm1_cg_emit_arr(&RM1_STR_NL as u64,RM1_STR_NL_LEN); return RM1_OK }
fn rm1_emit_store_rcx_slot(slot: u32) -> u32 { rm1_cg_emit_arr(&RM1_STR_MOVQ_PCT as u64,RM1_STR_MOVQ_PCT_LEN); rm1_cg_emit_arr(&RM1_REG_RCX as u64,RM1_REG_RCX_LEN); rm1_cg_emit_arr(&RM1_STR_COMMA_SP as u64,RM1_STR_COMMA_SP_LEN); rm1_cg_emit_ch(45u32); rm1_cg_emit_dec(((slot+1u32)*8u32) as u64); rm1_cg_emit_arr(&RM1_STR_BPCMA_RCX as u64,7u64); rm1_cg_emit_arr(&RM1_STR_NL as u64,RM1_STR_NL_LEN); return RM1_OK }
fn rm1_emit_bool_setcc(op: u32) -> u32 { rm1_cg_emit_arr(&RM1_STR_CMP_RCX_RAX as u64,RM1_STR_CMP_RCX_RAX_LEN); if op == 11u32 { rm1_cg_emit_arr(&RM1_STR_SETE as u64,RM1_STR_SETE_LEN) }; if op == 12u32 { rm1_cg_emit_arr(&RM1_STR_SETNE as u64,RM1_STR_SETNE_LEN) }; if op == 13u32 { rm1_cg_emit_arr(&RM1_STR_SETL as u64,RM1_STR_SETL_LEN) }; if op == 14u32 { rm1_cg_emit_arr(&RM1_STR_SETLE as u64,RM1_STR_SETLE_LEN) }; if op == 15u32 { rm1_cg_emit_arr(&RM1_STR_SETG as u64,RM1_STR_SETG_LEN) }; if op == 16u32 { rm1_cg_emit_arr(&RM1_STR_SETGE as u64,RM1_STR_SETGE_LEN) }; return RM1_OK }
fn rm1_pack_hexad_expr(node: u32) -> u64 { let mut v: u32 = 0u32; let mut i: u32 = 0u32; while i < 6u32 { let t: u32 = iii_ast_expr_hexad_trit_at(RM1_G_AST,node,i) & 3u32; v = v | (t << (2u32*i)); i = i + 1u32 }; return v as u64 }
fn rm1_pack_hexad_pat(node: u32) -> u64 { let mut v: u32 = 0u32; let mut i: u32 = 0u32; while i < 6u32 { let t: u32 = iii_ast_pat_hexad_trit_at(RM1_G_AST,node,i) & 3u32; v = v | (t << (2u32*i)); i = i + 1u32 }; return v as u64 }

fn rm1_emit_expr(node: u32) -> u32 {
    if node == 0u32 { return RM1_OK }
    let k: u32 = iii_ast_node_kind(RM1_G_AST,node)
    if k == RM1_K_EXPR_INT { rm1_emit_movabs_rax(iii_ast_expr_int_u64(RM1_G_AST,node)); rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_HEX { let lo: u64 = iii_ast_hex_value_lo(RM1_G_AST,node) as u64; let hi: u64 = iii_ast_hex_value_hi(RM1_G_AST,node) as u64; rm1_emit_movabs_rax(lo | (hi << 32u64)); rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_BOOL { if iii_ast_bool_value(RM1_G_AST,node) != 0u32 { rm1_cg_emit_arr(&RM1_STR_MOVQ1RAX as u64,RM1_STR_MOVQ1RAX_LEN) } else { rm1_cg_emit_arr(&RM1_STR_MOVQ0RAX as u64,RM1_STR_MOVQ0RAX_LEN) }; rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_TRIT { rm1_emit_movabs_rax(iii_ast_expr_trit_value(RM1_G_AST,node) as u64); rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_UNIT { rm1_cg_emit_arr(&RM1_STR_XORRAX as u64,RM1_STR_XORRAX_LEN); rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_HEXAD { rm1_emit_movabs_rax(rm1_pack_hexad_expr(node)); rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_STR { rm1_cg_emit_arr(&RM1_STR_PFX_STR as u64,0u64); let idx: u32 = iii_ast_str_payload_idx(RM1_G_AST,node); iii_emit_memcpy_c(&RM1_TMPNAME as u64,&RM1_STR_PFX_STR as u64,RM1_STR_PFX_STR_LEN); let mut off: u32 = RM1_STR_PFX_STR_LEN as u32; let mut v: u32 = idx; let mut n: u32 = 0u32; if v == 0u32 { RM1_TMPNAME[off]=48u8; off=off+1u32 } else { while v > 0u32 { RM1_NUMBUF[n]=(48u32+(v%10u32)) as u8; n=n+1u32; v=v/10u32 }; while n>0u32 { n=n-1u32; RM1_TMPNAME[off]=RM1_NUMBUF[n]; off=off+1u32 } }; rm1_emit_sym_address(&RM1_TMPNAME as u64,off,&RM1_REG_RAX as u64,RM1_REG_RAX_LEN); rm1_push_rax(); return RM1_G_LAST_ERROR }
    if k == RM1_K_EXPR_IDENT { let no: u32 = iii_ast_ident_name_offset(RM1_G_AST,node); let nl: u32 = iii_ast_ident_name_length(RM1_G_AST,node); let s: i32 = rm1_local_slot(no,nl); if s >= 0i32 { rm1_emit_load_slot(s as u32,&RM1_REG_RAX as u64,RM1_REG_RAX_LEN); rm1_push_rax(); return RM1_OK }; let l: u32 = rm1_build_mangled(no,nl); let e: u32 = rm1_emit_sym_address(&RM1_TMPNAME as u64,l,&RM1_REG_RAX as u64,RM1_REG_RAX_LEN); if e != RM1_OK { return e }; rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_PAREN { return rm1_emit_expr(iii_ast_paren_inner(RM1_G_AST,node)) }
    if k == RM1_K_EXPR_UNARY { let e0: u32 = rm1_emit_expr(iii_ast_unary_operand(RM1_G_AST,node)); if e0 != RM1_OK { return e0 }; rm1_pop_reg(&RM1_REG_RAX as u64,RM1_REG_RAX_LEN); let op: u32 = iii_ast_unary_op(RM1_G_AST,node); if op == 1u32 { rm1_cg_emit_arr(&RM1_STR_NEGQ as u64,RM1_STR_NEGQ_LEN) }; if op == 2u32 { rm1_cg_emit_arr(&RM1_STR_TESTRSTE as u64,RM1_STR_TESTRSTE_LEN) }; if op == 3u32 { rm1_cg_emit_arr(&RM1_STR_NOTQ as u64,RM1_STR_NOTQ_LEN) }; if op == 4u32 { rm1_cg_emit_arr(&RM1_STR_DEREF_RAX as u64,RM1_STR_DEREF_RAX_LEN) }; rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_BINARY { let e1: u32 = rm1_emit_expr(iii_ast_binary_lhs(RM1_G_AST,node)); if e1 != RM1_OK { return e1 }; let e2: u32 = rm1_emit_expr(iii_ast_binary_rhs(RM1_G_AST,node)); if e2 != RM1_OK { return e2 }; rm1_pop_reg(&RM1_REG_RCX as u64,RM1_REG_RCX_LEN); rm1_pop_reg(&RM1_REG_RAX as u64,RM1_REG_RAX_LEN); let op: u32 = iii_ast_binary_op(RM1_G_AST,node); if op == 1u32 { rm1_cg_emit_arr(&RM1_STR_ADDQ as u64,RM1_STR_ADDQ_LEN) }; if op == 2u32 { rm1_cg_emit_arr(&RM1_STR_SUBQ as u64,RM1_STR_SUBQ_LEN) }; if op == 3u32 { rm1_cg_emit_arr(&RM1_STR_IMULQ as u64,RM1_STR_IMULQ_LEN) }; if op == 4u32 { rm1_cg_emit_arr(&RM1_STR_IDIV as u64,RM1_STR_IDIV_LEN) }; if op == 5u32 { rm1_cg_emit_arr(&RM1_STR_IDIVMOD as u64,RM1_STR_IDIVMOD_LEN) }; if op == 6u32 { rm1_cg_emit_arr(&RM1_STR_ANDQ as u64,RM1_STR_ANDQ_LEN) }; if op == 7u32 { rm1_cg_emit_arr(&RM1_STR_ORQ as u64,RM1_STR_ORQ_LEN) }; if op == 8u32 { rm1_cg_emit_arr(&RM1_STR_XORQ as u64,RM1_STR_XORQ_LEN) }; if op == 9u32 { rm1_cg_emit_arr(&RM1_STR_SHLQ as u64,RM1_STR_SHLQ_LEN) }; if op == 10u32 { rm1_cg_emit_arr(&RM1_STR_SHRQ as u64,RM1_STR_SHRQ_LEN) }; if op >= 11u32 { if op <= 16u32 { rm1_emit_bool_setcc(op) } }; if op == 17u32 { rm1_cg_emit_arr(&RM1_STR_LAND_P1 as u64,RM1_STR_LAND_P1_LEN); rm1_cg_emit_arr(&RM1_STR_LAND_P2 as u64,RM1_STR_LAND_P2_LEN); rm1_cg_emit_arr(&RM1_STR_LAND_AND as u64,RM1_STR_LAND_AND_LEN) }; if op == 18u32 { rm1_cg_emit_arr(&RM1_STR_LOR_LINE as u64,RM1_STR_LOR_LINE_LEN) }; rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_CALL { return rm1_emit_call(node) }
    if k == RM1_K_EXPR_BLOCK { return rm1_emit_block(node) }
    if k == RM1_K_EXPR_FIELD { let obj: u32 = iii_ast_field_object(RM1_G_AST,node); if iii_ast_node_kind(RM1_G_AST,obj) != RM1_K_EXPR_IDENT { RM1_G_LAST_ERROR=RM1_E_UNSUPPORTED; return RM1_E_UNSUPPORTED }; rm1_cg_emit_arr(&RM1_STR_LEAQ as u64,RM1_STR_LEAQ_LEN); rm1_emit_field_label(obj,iii_ast_field_name_offset(RM1_G_AST,node),iii_ast_field_name_length(RM1_G_AST,node)); rm1_cg_emit_arr(&RM1_STR_RIPCM_PCT as u64,RM1_STR_RIPCM_PCT_LEN); rm1_cg_emit_arr(&RM1_REG_RAX as u64,RM1_REG_RAX_LEN); rm1_cg_emit_arr(&RM1_STR_NL as u64,RM1_STR_NL_LEN); rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_INDEX { let e3: u32 = rm1_emit_expr(iii_ast_index_object(RM1_G_AST,node)); if e3 != RM1_OK { return e3 }; let e4: u32 = rm1_emit_expr(iii_ast_index_index(RM1_G_AST,node)); if e4 != RM1_OK { return e4 }; rm1_pop_reg(&RM1_REG_RCX as u64,RM1_REG_RCX_LEN); rm1_pop_reg(&RM1_REG_RAX as u64,RM1_REG_RAX_LEN); rm1_cg_emit_arr(&RM1_STR_INDEX_LD as u64,RM1_STR_INDEX_LD_LEN); rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_MHASH { rm1_emit_section_rodata(); rm1_emit_mhash_data_label(node); rm1_emit_section_text(); iii_emit_memcpy_c(&RM1_TMPNAME as u64,&RM1_STR_PFX_MHASH as u64,RM1_STR_PFX_MHASH_LEN); let mut o: u32 = RM1_STR_PFX_MHASH_LEN as u32; let mut v2: u32 = node; let mut n2: u32 = 0u32; if v2==0u32 { RM1_TMPNAME[o]=48u8; o=o+1u32 } else { while v2>0u32 { RM1_NUMBUF[n2]=(48u32+(v2%10u32)) as u8; n2=n2+1u32; v2=v2/10u32 }; while n2>0u32 { n2=n2-1u32; RM1_TMPNAME[o]=RM1_NUMBUF[n2]; o=o+1u32 } }; rm1_emit_sym_address(&RM1_TMPNAME as u64,o,&RM1_REG_RAX as u64,RM1_REG_RAX_LEN); rm1_push_rax(); return RM1_G_LAST_ERROR }
    if k == RM1_K_EXPR_RAW_ASM { let p: u64 = iii_ast_source_buf(RM1_G_AST) + (iii_ast_raw_asm_str_idx(RM1_G_AST,node) as u64); rm1_cg_emit_bytes(p,iii_ast_raw_asm_len(RM1_G_AST,node) as u64); rm1_cg_emit_arr(&RM1_STR_NL as u64,RM1_STR_NL_LEN); rm1_cg_emit_arr(&RM1_STR_MOVQ0RAX as u64,RM1_STR_MOVQ0RAX_LEN); rm1_push_rax(); return RM1_OK }
    if k == RM1_K_EXPR_MATCH { return rm1_emit_match_expr(node) }
    RM1_G_LAST_ERROR = RM1_E_UNSUPPORTED; return RM1_E_UNSUPPORTED
}

