fn rm1_hv_emit_bare_metal_entry() -> u32 { return rm1_cg_emit_arr(&RM1_HV_BARE_METAL_ENTRY as u64, RM1_HV_BARE_METAL_ENTRY_LEN) }
fn rm1_hv_emit_vmx_svm_dispatch() -> u32 { return rm1_cg_emit_arr(&RM1_HV_VMX_SVM_DISPATCH as u64, RM1_HV_VMX_SVM_DISPATCH_LEN) }
fn rm1_hv_emit_svm_vmrun_bracket() -> u32 { return rm1_cg_emit_arr(&RM1_HV_SVM_VMRUN_BRACKET as u64, RM1_HV_SVM_VMRUN_BRACKET_LEN) }
fn rm1_hv_emit_vmx_vmrun_bracket() -> u32 { return rm1_cg_emit_arr(&RM1_HV_VMX_VMRUN_BRACKET as u64, RM1_HV_VMX_VMRUN_BRACKET_LEN) }
fn rm1_hv_emit_one_pd(g: u32) -> u32 {
    rm1_cg_emit_arr(&RM1_HV_PD_ALIGN as u64, RM1_HV_PD_ALIGN_LEN);
    if g == 0u32 { rm1_cg_emit_arr(&RM1_HV_PD0_LBL as u64, RM1_HV_PD0_LBL_LEN) };
    if g == 1u32 { rm1_cg_emit_arr(&RM1_HV_PD1_LBL as u64, RM1_HV_PD1_LBL_LEN) };
    if g == 2u32 { rm1_cg_emit_arr(&RM1_HV_PD2_LBL as u64, RM1_HV_PD2_LBL_LEN) };
    if g == 3u32 { rm1_cg_emit_arr(&RM1_HV_PD3_LBL as u64, RM1_HV_PD3_LBL_LEN) };
    let g64: u64 = g as u64
    let mut e: u32 = 0u32
    while e < 512u32 {
        let phys: u64 = (g64 << 30u64) | ((e as u64) << 21u64)
        let val: u64 = phys | 0xB7u64
        rm1_cg_emit_arr(&RM1_HV_QUAD_OPEN as u64, RM1_HV_QUAD_OPEN_LEN)
        rm1_cg_emit_hex(val)
        rm1_cg_emit_arr(&RM1_HV_NL as u64, RM1_HV_NL_LEN)
        e = e + 1u32
    }
    return RM1_OK
}
fn rm1_hv_emit_slat_tables() -> u32 {
    rm1_cg_emit_arr(&RM1_HV_SLAT_HDR as u64, RM1_HV_SLAT_HDR_LEN)
    let mut g: u32 = 0u32
    while g < 4u32 { rm1_hv_emit_one_pd(g); g = g + 1u32 }
    return RM1_OK
}
fn rm1_hv_emit_vmexit_table() -> u32 {
    rm1_cg_emit_arr(&RM1_HV_VMEXIT_TBL_HDR as u64, RM1_HV_VMEXIT_TBL_HDR_LEN)
    let mut i: u32 = 0u32
    while i < 256u32 {
        rm1_cg_emit_arr(&RM1_HV_VMEXIT_DEFAULT_LINE as u64, RM1_HV_VMEXIT_DEFAULT_LINE_LEN)
        i = i + 1u32
    }
    return RM1_OK
}
fn rm1_hv_emit_bss_and_data() -> u32 {
    return rm1_cg_emit_arr(&RM1_HV_BSS_HEAD as u64, RM1_HV_BSS_HEAD_LEN)
}

fn rm1_emit_name_raw(off: u32, len: u32) -> u32 {
    let src: u64 = iii_ast_source_buf(RM1_G_AST)
    let mut i: u32 = 0u32
    while i < len {
        let bch: u32 = iii_emit_buf_read_u8_c(src, (off + i) as u64)
        rm1_cg_emit_ch(bch)
        i = i + 1u32
    }
    return RM1_OK
}

/* D8 witness entry/exit (cg_rm1.c::emit_witness_call): subq/addq are
 * stack-depth-parity-conditional, so RM1_G_STACK_DEPTH is tracked identically. */
fn rm1_hv_emit_witness(wid: u32, is_exit: u32) -> u32 {
    rm1_cg_emit_arr(&RM1_WIT_CMT as u64, 17u64)
    if is_exit == 1u32 { rm1_cg_emit_arr(&RM1_WIT_EXIT as u64, 4u64) }
    if is_exit != 1u32 { rm1_cg_emit_arr(&RM1_WIT_ENTRY as u64, 5u64) }
    rm1_cg_emit_arr(&RM1_WIT_WIDEQ as u64, 7u64)
    rm1_cg_emit_hex(wid as u64)
    rm1_cg_emit_arr(&RM1_STR_NL as u64, RM1_STR_NL_LEN)
    rm1_cg_emit_arr(&RM1_WIT_PUSH as u64, 30u64)
    RM1_G_STACK_DEPTH = RM1_G_STACK_DEPTH + 2u32
    if (RM1_G_STACK_DEPTH & 1u32) != 0u32 { rm1_cg_emit_arr(&RM1_WIT_SUBQ8 as u64, 18u64); RM1_G_STACK_DEPTH = RM1_G_STACK_DEPTH + 1u32 }
    rm1_cg_emit_arr(&RM1_STR_MOVABSQ_OPEN as u64, RM1_STR_MOVABSQ_OPEN_LEN)
    rm1_cg_emit_hex(wid as u64)
    rm1_cg_emit_arr(&RM1_WIT_MOVRDI as u64, 37u64)
    if ((RM1_G_STACK_DEPTH - 2u32) & 1u32) != 0u32 { rm1_cg_emit_arr(&RM1_WIT_ADDQ8 as u64, 18u64); RM1_G_STACK_DEPTH = RM1_G_STACK_DEPTH - 1u32 }
    rm1_cg_emit_arr(&RM1_WIT_POP as u64, 28u64)
    RM1_G_STACK_DEPTH = RM1_G_STACK_DEPTH - 2u32
    return RM1_OK
}
fn rm1_hv_emit_function(decl: u32, kind: u32, witness_id: u32) -> u32 {
    RM1_G_LOCAL_COUNT = 0u32
    RM1_G_STACK_DEPTH = 0u32
    RM1_G_LABEL_COUNTER = 0u32
    let mut no: u32 = 0u32
    let mut nl: u32 = 0u32
    let mut pc: u32 = 0u32
    let mut body: u32 = 0u32
    if kind == RM1_K_FN_DECL {
        no = iii_ast_fn_name_off(RM1_G_AST, decl)
        nl = iii_ast_fn_name_len(RM1_G_AST, decl)
        pc = iii_ast_fn_param_count(RM1_G_AST, decl)
        body = iii_ast_fn_body(RM1_G_AST, decl)
    }
    if kind == RM1_K_CYCLE_DECL {
        no = iii_ast_cycle_name_off(RM1_G_AST, decl)
        nl = iii_ast_cycle_name_len(RM1_G_AST, decl)
        pc = iii_ast_cycle_param_count(RM1_G_AST, decl)
        body = iii_ast_cycle_forward_block(RM1_G_AST, decl)
    }
    rm1_cg_emit_arr(&RM1_HV_TEXTNL as u64, RM1_HV_TEXTNL_LEN)
    rm1_cg_emit_arr(&RM1_HV_GLOBAL_LHV as u64, RM1_HV_GLOBAL_LHV_LEN)
    rm1_emit_name_raw(no, nl)
    rm1_cg_emit_arr(&RM1_STR_NL as u64, RM1_STR_NL_LEN)
    rm1_cg_emit_arr(&RM1_HV_LHV as u64, RM1_HV_LHV_LEN)
    rm1_emit_name_raw(no, nl)
    rm1_cg_emit_arr(&RM1_STR_COLONNL as u64, RM1_STR_COLONNL_LEN)
    rm1_cg_emit_arr(&RM1_HV_ALIGN16NOP as u64, RM1_HV_ALIGN16NOP_LEN)
    rm1_cg_emit_arr(&RM1_HV_PROLOG_FULL as u64, RM1_HV_PROLOG_FULL_LEN)
    let mut i: u32 = 0u32
    while i < pc {
        if i < 6u32 {
            let mut p: u32 = 0u32
            if kind == RM1_K_FN_DECL { p = iii_ast_fn_param_at(RM1_G_AST, decl, i) }
            if kind == RM1_K_CYCLE_DECL { p = iii_ast_cycle_param_at(RM1_G_AST, decl, i) }
            if iii_ast_node_kind(RM1_G_AST, p) == RM1_K_PARAM {
                rm1_local_add(iii_ast_param_name_off(RM1_G_AST, p), iii_ast_param_name_len(RM1_G_AST, p))
                rm1_cg_emit_arr(&RM1_HV_MOVQ_PCT as u64, RM1_HV_MOVQ_PCT_LEN)
                if i == 0u32 { rm1_cg_emit_arr(&RM1_REG_RDI as u64, RM1_REG_RDI_LEN) }
                if i == 1u32 { rm1_cg_emit_arr(&RM1_REG_RSI as u64, RM1_REG_RSI_LEN) }
                if i == 2u32 { rm1_cg_emit_arr(&RM1_REG_RDX as u64, RM1_REG_RDX_LEN) }
                if i == 3u32 { rm1_cg_emit_arr(&RM1_REG_RCX as u64, RM1_REG_RCX_LEN) }
                if i == 4u32 { rm1_cg_emit_arr(&RM1_REG_R8 as u64, RM1_REG_R8_LEN) }
                if i == 5u32 { rm1_cg_emit_arr(&RM1_REG_R9 as u64, RM1_REG_R9_LEN) }
                rm1_cg_emit_arr(&RM1_HV_COMMA_DASH as u64, RM1_HV_COMMA_DASH_LEN)
                rm1_cg_emit_dec((RM1_G_LOCAL_COUNT * 8u32) as u64)
                rm1_cg_emit_arr(&RM1_HV_DASHRBP as u64, RM1_HV_DASHRBP_LEN)
            }
        }
        i = i + 1u32
    }
    if witness_id != 0u32 { rm1_hv_emit_witness(witness_id, 0u32) }
    if body != 0u32 {
        let eb: u32 = rm1_emit_block(body)
        if eb != RM1_OK { return eb }
    }
    if witness_id != 0u32 { rm1_hv_emit_witness(witness_id, 1u32) }
    rm1_cg_emit_arr(&RM1_HV_EPILOG_FULL as u64, RM1_HV_EPILOG_FULL_LEN)
    return RM1_OK
}

fn iii_cg_rm1_create(ast: u64, sema: u64, sid: u64, walloc: u64) -> u64 @export { if ast == 0u64 { return 0u64 }; RM1_G_AST=ast; RM1_G_SEMA=sema; RM1_G_SID=sid; RM1_G_WALLOC=walloc; RM1_G_OUT=0u64; RM1_G_FMT=RM1_FMT_ELF; RM1_G_CONST_TIME=0u32; RM1_G_SEALED=0u32; RM1_G_LAST_ERROR=RM1_OK; RM1_G_LOCAL_COUNT=0u32; RM1_G_STACK_DEPTH=0u32; RM1_G_LABEL_COUNTER=0u32; iii_cg_rm1_sha_init_c(); return &RM1_SENTINEL as u64 }
fn iii_cg_rm1_destroy(cg: u64) @export { RM1_G_AST=0u64; RM1_G_SEMA=0u64; RM1_G_SID=0u64; RM1_G_WALLOC=0u64; RM1_G_OUT=0u64; RM1_G_SEALED=0u32; return }
fn iii_cg_rm1_set_format(cg: u64, fmt: u32) @export { if cg != 0u64 { if RM1_G_SEALED == 0u32 { RM1_G_FMT=fmt } }; return }
fn iii_cg_rm1_set_const_time(cg: u64, on: u32) @export { if cg != 0u64 { if RM1_G_SEALED == 0u32 { RM1_G_CONST_TIME=on } }; return }
fn rm1_emit_sha_trailer() -> u32 {
    /* Snapshot streaming digest into RM1_ASM_DIGEST. C side preserves live state. */
    iii_cg_rm1_sha_snapshot_c(&RM1_ASM_DIGEST as u64)
    if RM1_G_OUT != 0u64 { iii_cg_rm1_fwrite_c(RM1_G_OUT, &RM1_TRAILER_PFX as u64, RM1_TRAILER_PFX_LEN) }
    let mut i: u32 = 0u32
    while i < 32u32 {
        let b: u32 = iii_emit_buf_read_u8_c(&RM1_ASM_DIGEST as u64, i as u64)
        let hi: u32 = (b >> 4u32) & 0x0fu32
        let lo: u32 = b & 0x0fu32
        let mut hi_c: u32 = 0u32
        if hi < 10u32 { hi_c = 48u32 + hi } else { hi_c = 87u32 + hi }
        let mut lo_c: u32 = 0u32
        if lo < 10u32 { lo_c = 48u32 + lo } else { lo_c = 87u32 + lo }
        iii_emit_write_u8_c(&RM1_TRAILER_HEX as u64, hi_c)
        iii_emit_write_u8_c((&RM1_TRAILER_HEX as u64) + 1u64, lo_c)
        if RM1_G_OUT != 0u64 { iii_cg_rm1_fwrite_c(RM1_G_OUT, &RM1_TRAILER_HEX as u64, 2u64) }
        i = i + 1u32
    }
    if RM1_G_OUT != 0u64 { iii_cg_rm1_fwrite_c(RM1_G_OUT, &RM1_TRAILER_NL as u64, 1u64) }
    return RM1_OK
}
fn iii_cg_rm1_emit_module(cg: u64, out: u64) -> u32 @export { if cg == 0u64 { return RM1_E_NULL_ARG }; if out == 0u64 { RM1_G_LAST_ERROR=RM1_E_NULL_ARG; return RM1_E_NULL_ARG }; if RM1_G_SEALED != 0u32 { RM1_G_LAST_ERROR=RM1_E_SEALED; return RM1_E_SEALED }; RM1_G_OUT=out; rm1_cg_emit_arr(&RM1_HV_HDR1 as u64,RM1_HV_HDR1_LEN); rm1_cg_emit_arr(&RM1_HV_HDR2 as u64,RM1_HV_HDR2_LEN); rm1_cg_emit_arr(&RM1_HV_ATTSYNTAX as u64,RM1_HV_ATTSYNTAX_LEN); rm1_cg_emit_arr(&RM1_HV_RODATA as u64,RM1_HV_RODATA_LEN); rm1_emit_string_pool(); rm1_hv_emit_bare_metal_entry(); rm1_hv_emit_vmx_svm_dispatch(); rm1_hv_emit_svm_vmrun_bracket(); rm1_hv_emit_vmx_vmrun_bracket(); let root: u32 = iii_ast_root_module(RM1_G_AST); if root == 0u32 { RM1_G_LAST_ERROR=RM1_E_INTERNAL; return RM1_E_INTERNAL }; let dc: u32 = iii_ast_module_decl_count(RM1_G_AST,root); let mut i: u32 = 0u32; while i < dc { let d: u32 = iii_ast_module_decl_at(RM1_G_AST,root,i); let dk: u32 = iii_ast_node_kind(RM1_G_AST,d); if dk == RM1_K_FN_DECL { let e: u32 = rm1_hv_emit_function(d, RM1_K_FN_DECL, 0u32); if e != RM1_OK { return e } }; if dk == RM1_K_CYCLE_DECL { let wid: u32 = (3250585600u32) | (i + 1u32); let e2: u32 = rm1_hv_emit_function(d, RM1_K_CYCLE_DECL, wid); if e2 != RM1_OK { return e2 } }; i=i+1u32 }; rm1_hv_emit_vmexit_table(); rm1_hv_emit_slat_tables(); rm1_hv_emit_bss_and_data(); rm1_emit_sha_trailer(); RM1_G_CONST_TIME=0u32; return RM1_OK }
fn iii_cg_rm1_module_finish(cg: u64) -> u32 @export { if cg == 0u64 { return RM1_E_NULL_ARG }; RM1_G_SEALED=1u32; return RM1_OK }
fn iii_cg_rm1_section_mhash(cg: u64, out_mhash: u64) -> u32 @export { if cg == 0u64 { return RM1_E_NULL_ARG }; if out_mhash == 0u64 { return RM1_E_NULL_ARG }; iii_cg_rm1_sha_snapshot_c(out_mhash); return RM1_OK }
fn iii_cg_rm1_last_error(cg: u64) -> u32 @export { if cg == 0u64 { return RM1_E_NULL_ARG }; return RM1_G_LAST_ERROR }
fn iii_cg_rm1_error_name(code: u32) -> u64 @export { if code==RM1_OK { return &RM1_ENAME_OK as u64 }; if code==RM1_E_NULL_ARG { return &RM1_ENAME_NULL_ARG as u64 }; if code==RM1_E_IO { return &RM1_ENAME_IO as u64 }; if code==RM1_E_UNSUPPORTED { return &RM1_ENAME_UNSUPPORTED as u64 }; if code==RM1_E_NON_PIC_RELOC { return &RM1_ENAME_NON_PIC_RELOC as u64 }; if code==RM1_E_FORBIDDEN_TARGET { return &RM1_ENAME_FORBIDDEN_TARGET as u64 }; if code==RM1_E_BAD_ENTRY_SIG { return &RM1_ENAME_BAD_ENTRY_SIG as u64 }; if code==RM1_E_ONEWAY_READ { return &RM1_ENAME_ONEWAY_READ as u64 }; if code==RM1_E_NO_CAP_REVOKE { return &RM1_ENAME_NO_CAP_REVOKE as u64 }; if code==RM1_E_SEALED { return &RM1_ENAME_SEALED as u64 }; if code==RM1_E_INTERNAL { return &RM1_ENAME_INTERNAL as u64 }; return &RM1_ENAME_UNKNOWN as u64 }
