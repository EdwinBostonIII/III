fn cgrm2_sha_init() -> u32 { CGRM2_SHA_S0=0x6a09e667u32; CGRM2_SHA_S1=0xbb67ae85u32; CGRM2_SHA_S2=0x3c6ef372u32; CGRM2_SHA_S3=0xa54ff53au32; CGRM2_SHA_S4=0x510e527fu32; CGRM2_SHA_S5=0x9b05688cu32; CGRM2_SHA_S6=0x1f83d9abu32; CGRM2_SHA_S7=0x5be0cd19u32; CGRM2_SHA_BITS_HI=0u32; CGRM2_SHA_BITS_LO=0u32; CGRM2_SHA_LEN=0u32; return 0u32 }
fn cgrm2_sha_update(data: u64, n: u64) -> u32 { let bits_lo: u32 = ((n & 0xffffffffu64) as u32) << 3u32; let bits_hi: u32 = ((n >> 29u64) as u32); let new_lo: u32 = CGRM2_SHA_BITS_LO + bits_lo; let mut carry: u32 = 0u32; if new_lo < CGRM2_SHA_BITS_LO { carry = 1u32 }; CGRM2_SHA_BITS_LO = new_lo; CGRM2_SHA_BITS_HI = CGRM2_SHA_BITS_HI + bits_hi + carry; let mut left: u64 = n; let mut p: u64 = data; while left > 0u64 { let mut take: u64 = 64u64 - (CGRM2_SHA_LEN as u64); if take > left { take = left }; iii_emit_memcpy_c((&CGRM2_SHA_BUF as u64)+(CGRM2_SHA_LEN as u64), p, take); CGRM2_SHA_LEN = CGRM2_SHA_LEN + (take as u32); p = p + take; left = left - take; if CGRM2_SHA_LEN == 64u32 { cgrm2_sha_compress(); CGRM2_SHA_LEN = 0u32 } }; return 0u32 }
fn cgrm2_sha_final(out: u64) -> u32 { cgrm2_sha_buf_set(CGRM2_SHA_LEN,0x80u8); CGRM2_SHA_LEN = CGRM2_SHA_LEN + 1u32; if CGRM2_SHA_LEN > 56u32 { while CGRM2_SHA_LEN < 64u32 { cgrm2_sha_buf_set(CGRM2_SHA_LEN,0u8); CGRM2_SHA_LEN = CGRM2_SHA_LEN + 1u32 }; cgrm2_sha_compress(); CGRM2_SHA_LEN = 0u32 }; while CGRM2_SHA_LEN < 56u32 { cgrm2_sha_buf_set(CGRM2_SHA_LEN,0u8); CGRM2_SHA_LEN = CGRM2_SHA_LEN + 1u32 }; cgrm2_sha_buf_set(56u32,((CGRM2_SHA_BITS_HI>>24u32)&0xffu32) as u8); cgrm2_sha_buf_set(57u32,((CGRM2_SHA_BITS_HI>>16u32)&0xffu32) as u8); cgrm2_sha_buf_set(58u32,((CGRM2_SHA_BITS_HI>>8u32)&0xffu32) as u8); cgrm2_sha_buf_set(59u32,(CGRM2_SHA_BITS_HI&0xffu32) as u8); cgrm2_sha_buf_set(60u32,((CGRM2_SHA_BITS_LO>>24u32)&0xffu32) as u8); cgrm2_sha_buf_set(61u32,((CGRM2_SHA_BITS_LO>>16u32)&0xffu32) as u8); cgrm2_sha_buf_set(62u32,((CGRM2_SHA_BITS_LO>>8u32)&0xffu32) as u8); cgrm2_sha_buf_set(63u32,(CGRM2_SHA_BITS_LO&0xffu32) as u8); cgrm2_sha_compress(); let mut i: u32 = 0u32; while i < 8u32 { let mut s: u32 = 0u32; if i==0u32 { s=CGRM2_SHA_S0 }; if i==1u32 { s=CGRM2_SHA_S1 }; if i==2u32 { s=CGRM2_SHA_S2 }; if i==3u32 { s=CGRM2_SHA_S3 }; if i==4u32 { s=CGRM2_SHA_S4 }; if i==5u32 { s=CGRM2_SHA_S5 }; if i==6u32 { s=CGRM2_SHA_S6 }; if i==7u32 { s=CGRM2_SHA_S7 }; iii_emit_write_u32_be_c(out + (i as u64)*4u64, s); i = i + 1u32 }; return 0u32 }

fn cg_emit_bytes(addr: u64, n: u64) -> u32 { if RM2_G_SEALED != 0u32 { RM2_G_LAST_ERROR = RM2_E_SEALED; return RM2_E_SEALED }; if n == 0u64 { return RM2_OK }; if RM2_G_OUT != 0u64 { if iii_cg_rm2_fwrite_c(RM2_G_OUT, addr, n) != 0i32 { RM2_G_LAST_ERROR = RM2_E_IO; return RM2_E_IO } }; cgrm2_sha_update(addr,n); return RM2_OK }
fn cg_emit_arr(addr: u64, n: u64) -> u32 { return cg_emit_bytes(addr,n) }
fn cg_emit_ch(ch: u32) -> u32 { RM2_NUMBUF[0] = (ch & 0xffu32) as u8; return cg_emit_bytes(&RM2_NUMBUF as u64,1u64) }
fn cg_emit_dec(v0: u64) -> u32 { let mut v: u64 = v0; let mut n: u32 = 0u32; if v == 0u64 { RM2_NUMBUF[0]=48u8; return cg_emit_bytes(&RM2_NUMBUF as u64,1u64) }; while v > 0u64 { RM2_NUMBUF[n] = (48u64 + (v % 10u64)) as u8; n = n + 1u32; v = v / 10u64 }; while n > 0u32 { n = n - 1u32; cg_emit_ch(RM2_NUMBUF[n] as u32) }; return RM2_OK }
fn cg_emit_hex(v0: u64) -> u32 { let mut v: u64 = v0; let mut n: u32 = 0u32; if v == 0u64 { RM2_NUMBUF[0]=48u8; return cg_emit_bytes(&RM2_NUMBUF as u64,1u64) }; while v > 0u64 { let d: u64 = v & 15u64; if d < 10u64 { RM2_NUMBUF[n] = (48u64+d) as u8 } else { RM2_NUMBUF[n] = (87u64+d) as u8 }; n = n + 1u32; v = v >> 4u64 }; while n > 0u32 { n = n - 1u32; cg_emit_ch(RM2_NUMBUF[n] as u32) }; return RM2_OK }
fn emit_section_text() -> u32 { if RM2_G_FMT == RM2_FMT_PE { return cg_emit_arr(&RM2_SEC_TEXT_PE as u64, RM2_SEC_TEXT_PE_LEN) }; return cg_emit_arr(&RM2_SEC_TEXT_ELF as u64, RM2_SEC_TEXT_ELF_LEN) }
fn emit_section_rodata() -> u32 { if RM2_G_FMT == RM2_FMT_PE { return cg_emit_arr(&RM2_SEC_RODATA_PE as u64, RM2_SEC_RODATA_PE_LEN) }; return cg_emit_arr(&RM2_SEC_RODATA_ELF as u64, RM2_SEC_RODATA_ELF_LEN) }
fn is_sym_char(b: u32) -> u32 { if b >= 65u32 { if b <= 90u32 { return 1u32 } }; if b >= 97u32 { if b <= 122u32 { return 1u32 } }; if b >= 48u32 { if b <= 57u32 { return 1u32 } }; if b == 95u32 { return 1u32 }; return 0u32 }
fn emit_mangled(off: u32, len: u32) -> u32 { let src: u64 = iii_ast_source_buf(RM2_G_AST); cg_emit_arr(&RM2_PFX_LSANCTUM as u64,RM2_PFX_LSANCTUM_LEN); let mut i: u32 = 0u32; while i < len { let b: u32 = iii_emit_buf_read_u8_c(src, (off+i) as u64); if is_sym_char(b) == 1u32 { cg_emit_ch(b) } else { cg_emit_ch(95u32) }; i = i + 1u32 }; return RM2_OK }
fn build_mangled(off: u32, len: u32) -> u32 { let src: u64 = iii_ast_source_buf(RM2_G_AST); iii_emit_memcpy_c(&RM2_TMPNAME as u64, &RM2_PFX_LSANCTUM as u64, RM2_PFX_LSANCTUM_LEN); let mut k: u32 = RM2_PFX_LSANCTUM_LEN as u32; let mut i: u32 = 0u32; while i < len { let b: u32 = iii_emit_buf_read_u8_c(src,(off+i) as u64); if is_sym_char(b) == 1u32 { RM2_TMPNAME[k] = b as u8 } else { RM2_TMPNAME[k] = 95u8 }; k = k + 1u32; i = i + 1u32; if k >= 255u32 { RM2_TMPNAME[k]=0u8; return k } }; RM2_TMPNAME[k]=0u8; return k }
fn sym_is_permitted(addr: u64, n: u32) -> u32 { if n >= (RM2_PFX_LSANCTUM_LEN as u32) { if iii_emit_memcmp_c(addr,&RM2_PFX_LSANCTUM as u64,RM2_PFX_LSANCTUM_LEN) == 0i32 { return 1u32 } }; if n >= (RM2_PFX_IIISANCTUM_LEN as u32) { if iii_emit_memcmp_c(addr,&RM2_PFX_IIISANCTUM as u64,RM2_PFX_IIISANCTUM_LEN) == 0i32 { return 1u32 } }; if n >= (RM2_PFX_XIISANCTUM_LEN as u32) { if iii_emit_memcmp_c(addr,&RM2_PFX_XIISANCTUM as u64,RM2_PFX_XIISANCTUM_LEN) == 0i32 { return 1u32 } }; if n >= (RM2_PFX_IIICAP_LEN as u32) { if iii_emit_memcmp_c(addr,&RM2_PFX_IIICAP as u64,RM2_PFX_IIICAP_LEN) == 0i32 { return 1u32 } }; return 0u32 }
fn guard_symbol_load(addr: u64, n: u32) -> u32 { if sym_is_permitted(addr,n) == 0u32 { RM2_G_LAST_ERROR=RM2_E_FORBIDDEN_TARGET; return RM2_E_FORBIDDEN_TARGET }; if n == (RM2_SYM_ONEWAY_LEN as u32) { if iii_emit_memcmp_c(addr,&RM2_SYM_ONEWAY as u64,RM2_SYM_ONEWAY_LEN)==0i32 { RM2_G_LAST_ERROR=RM2_E_ONEWAY_READ; return RM2_E_ONEWAY_READ } }; return RM2_OK }
fn emit_sym_address(addr: u64, n: u32, reg: u64, regn: u64) -> u32 { let e: u32 = guard_symbol_load(addr,n); if e != RM2_OK { return e }; cg_emit_arr(&RM2_STR_LEAQ as u64,RM2_STR_LEAQ_LEN); cg_emit_bytes(addr,n as u64); cg_emit_arr(&RM2_STR_RIPCM_PCT as u64,RM2_STR_RIPCM_PCT_LEN); cg_emit_bytes(reg,regn); cg_emit_arr(&RM2_STR_NL as u64,RM2_STR_NL_LEN); return RM2_OK }
fn local_slot(off: u32, len: u32) -> i32 { let src: u64 = iii_ast_source_buf(RM2_G_AST); let mut i: u32 = 0u32; while i < RM2_G_LOCAL_COUNT { if RM2_LOCAL_LEN[i] == len { if iii_emit_memcmp_c(src+(RM2_LOCAL_OFF[i] as u64), src+(off as u64), len as u64) == 0i32 { return i as i32 } }; i = i + 1u32 }; return -1i32 }
fn local_add(off: u32, len: u32) -> u32 { if RM2_G_LOCAL_COUNT >= RM2_MAX_LOCALS { RM2_G_LAST_ERROR=RM2_E_INTERNAL; return RM2_E_INTERNAL }; RM2_LOCAL_OFF[RM2_G_LOCAL_COUNT]=off; RM2_LOCAL_LEN[RM2_G_LOCAL_COUNT]=len; RM2_G_LOCAL_COUNT = RM2_G_LOCAL_COUNT + 1u32; return RM2_OK }
fn push_rax() -> u32 { cg_emit_arr(&RM2_STR_PUSHRAX as u64,RM2_STR_PUSHRAX_LEN); RM2_G_STACK_DEPTH=RM2_G_STACK_DEPTH+1u32; return RM2_OK }
