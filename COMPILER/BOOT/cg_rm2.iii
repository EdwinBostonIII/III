    if k == RM2_K_STMT_EXPR { let e2: u32 = emit_expr(iii_ast_expr_stmt_expr(RM2_G_AST,node)); if e2 != RM2_OK { return e2 }; pop_reg(&RM2_REG_RAX as u64,RM2_REG_RAX_LEN); return RM2_OK }
    if k == RM2_K_STMT_RETURN { let rv: u32 = iii_ast_return_value(RM2_G_AST,node); if rv != 0u32 { let er: u32 = emit_expr(rv); if er != RM2_OK { return er }; pop_reg(&RM2_REG_RAX as u64,RM2_REG_RAX_LEN) } else { cg_emit_arr(&RM2_STR_XORRAX as u64,RM2_STR_XORRAX_LEN) }; if RM2_G_IN_ENTRY != 0u32 { if RM2_G_CAP_REVOKE == 0u32 { RM2_G_LAST_ERROR=RM2_E_NO_CAP_REVOKE; return RM2_E_NO_CAP_REVOKE } }; emit_sanctum_epilogue(); return RM2_OK }
    if k == RM2_K_STMT_ASSIGN { return emit_assign(node) }
