fn emit_field_label(obj: u32, foff: u32, flen: u32) -> u32 { let oo: u32 = iii_ast_ident_name_offset(RM2_G_AST,obj); let ol: u32 = iii_ast_ident_name_length(RM2_G_AST,obj); emit_mangled(oo,ol); cg_emit_ch(95u32); cg_emit_ch(95u32); let src: u64 = iii_ast_source_buf(RM2_G_AST); let mut i: u32 = 0u32; while i < flen { let b: u32 = iii_emit_buf_read_u8_c(src,(foff+i) as u64); if is_sym_char(b)==1u32 { cg_emit_ch(b) } else { cg_emit_ch(95u32) }; i=i+1u32 }; return RM2_OK }
