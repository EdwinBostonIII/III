fn emit_movabs_rax(v: u64) -> u32 { cg_emit_arr(&RM2_STR_MOVABSQ_OPEN as u64,RM2_STR_MOVABSQ_OPEN_LEN); cg_emit_hex(v); cg_emit_arr(&RM2_STR_COMMA_RAX_NL as u64,RM2_STR_COMMA_RAX_NL_LEN); return RM2_OK }
fn emit_movabs_rcx(v: u64) -> u32 { cg_emit_arr(&RM2_STR_MOVABSQ_OPEN as u64,RM2_STR_MOVABSQ_OPEN_LEN); cg_emit_hex(v); cg_emit_arr(&RM2_STR_COMMA_RCX_NL as u64,RM2_STR_COMMA_RCX_NL_LEN); return RM2_OK }
fn emit_load_slot(slot: u32, reg: u64, regn: u64) -> u32 { cg_emit_arr(&RM2_STR_DASH_OPEN as u64,RM2_STR_DASH_OPEN_LEN); cg_emit_dec(((slot+1u32)*8u32) as u64); cg_emit_arr(&RM2_STR_PCT_RBP_NL as u64,6u64); cg_emit_arr(&RM2_STR_COMMA_SP as u64,RM2_STR_COMMA_SP_LEN); cg_emit_ch(37u32); cg_emit_bytes(reg,regn); cg_emit_arr(&RM2_STR_NL as u64,RM2_STR_NL_LEN); return RM2_OK }
fn emit_store_rax_slot(slot: u32) -> u32 { cg_emit_arr(&RM2_STR_MOVQRAX_DASH as u64,RM2_STR_MOVQRAX_DASH_LEN); cg_emit_dec(((slot+1u32)*8u32) as u64); cg_emit_arr(&RM2_STR_BPCMA_RAX as u64,RM2_STR_BPCMA_RAX_LEN); return RM2_OK }
fn emit_store_rcx_slot(slot: u32) -> u32 { cg_emit_arr(&RM2_STR_MOVQ_PCT as u64,RM2_STR_MOVQ_PCT_LEN); cg_emit_arr(&RM2_REG_RCX as u64,RM2_REG_RCX_LEN); cg_emit_arr(&RM2_STR_COMMA_SP as u64,RM2_STR_COMMA_SP_LEN); cg_emit_ch(45u32); cg_emit_dec(((slot+1u32)*8u32) as u64); cg_emit_arr(&RM2_STR_BPCMA_RCX as u64,7u64); cg_emit_arr(&RM2_STR_NL as u64,RM2_STR_NL_LEN); return RM2_OK }
fn emit_bool_setcc(op: u32) -> u32 { cg_emit_arr(&RM2_STR_CMP_RCX_RAX as u64,RM2_STR_CMP_RCX_RAX_LEN); if op == 11u32 { cg_emit_arr(&RM2_STR_SETE as u64,RM2_STR_SETE_LEN) }; if op == 12u32 { cg_emit_arr(&RM2_STR_SETNE as u64,RM2_STR_SETNE_LEN) }; if op == 13u32 { cg_emit_arr(&RM2_STR_SETL as u64,RM2_STR_SETL_LEN) }; if op == 14u32 { cg_emit_arr(&RM2_STR_SETLE as u64,RM2_STR_SETLE_LEN) }; if op == 15u32 { cg_emit_arr(&RM2_STR_SETG as u64,RM2_STR_SETG_LEN) }; if op == 16u32 { cg_emit_arr(&RM2_STR_SETGE as u64,RM2_STR_SETGE_LEN) }; return RM2_OK }
fn pack_hexad_expr(node: u32) -> u64 { let mut v: u32 = 0u32; let mut i: u32 = 0u32; while i < 6u32 { let t: u32 = iii_ast_expr_hexad_trit_at(RM2_G_AST,node,i) & 3u32; v = v | (t << (2u32*i)); i = i + 1u32 }; return v as u64 }
fn pack_hexad_pat(node: u32) -> u64 { let mut v: u32 = 0u32; let mut i: u32 = 0u32; while i < 6u32 { let t: u32 = iii_ast_pat_hexad_trit_at(RM2_G_AST,node,i) & 3u32; v = v | (t << (2u32*i)); i = i + 1u32 }; return v as u64 }

fn emit_expr(node: u32) -> u32 {
    if node == 0u32 { return RM2_OK }
    let k: u32 = iii_ast_node_kind(RM2_G_AST,node)
    if k == RM2_K_EXPR_INT { emit_movabs_rax(iii_ast_expr_int_u64(RM2_G_AST,node)); push_rax(); return RM2_OK }
    if k == RM2_K_EXPR_HEX { let lo: u64 = iii_ast_hex_value_lo(RM2_G_AST,node) as u64; let hi: u64 = iii_ast_hex_value_hi(RM2_G_AST,node) as u64; emit_movabs_rax(lo | (hi << 32u64)); push_rax(); return RM2_OK }
    if k == RM2_K_EXPR_BOOL { if iii_ast_bool_value(RM2_G_AST,node) != 0u32 { cg_emit_arr(&RM2_STR_MOVQ1RAX as u64,RM2_STR_MOVQ1RAX_LEN) } else { cg_emit_arr(&RM2_STR_MOVQ0RAX as u64,RM2_STR_MOVQ0RAX_LEN) }; push_rax(); return RM2_OK }
    if k == RM2_K_EXPR_TRIT { emit_movabs_rax(iii_ast_expr_trit_value(RM2_G_AST,node) as u64); push_rax(); return RM2_OK }
    if k == RM2_K_EXPR_UNIT { cg_emit_arr(&RM2_STR_XORRAX as u64,RM2_STR_XORRAX_LEN); push_rax(); return RM2_OK }
    if k == RM2_K_EXPR_HEXAD { emit_movabs_rax(pack_hexad_expr(node)); push_rax(); return RM2_OK }
    if k == RM2_K_EXPR_STR { cg_emit_arr(&RM2_STR_PFX_STR as u64,0u64); let idx: u32 = iii_ast_str_payload_idx(RM2_G_AST,node); iii_emit_memcpy_c(&RM2_TMPNAME as u64,&RM2_STR_PFX_STR as u64,RM2_STR_PFX_STR_LEN); let mut off: u32 = RM2_STR_PFX_STR_LEN as u32; let mut v: u32 = idx; let mut n: u32 = 0u32; if v == 0u32 { RM2_TMPNAME[off]=48u8; off=off+1u32 } else { while v > 0u32 { RM2_NUMBUF[n]=(48u32+(v%10u32)) as u8; n=n+1u32; v=v/10u32 }; while n>0u32 { n=n-1u32; RM2_TMPNAME[off]=RM2_NUMBUF[n]; off=off+1u32 } }; emit_sym_address(&RM2_TMPNAME as u64,off,&RM2_REG_RAX as u64,RM2_REG_RAX_LEN); push_rax(); return RM2_G_LAST_ERROR }
    if k == RM2_K_EXPR_IDENT { let no: u32 = iii_ast_ident_name_offset(RM2_G_AST,node); let nl: u32 = iii_ast_ident_name_length(RM2_G_AST,node); let s: i32 = local_slot(no,nl); if s >= 0i32 { emit_load_slot(s as u32,&RM2_REG_RAX as u64,RM2_REG_RAX_LEN); push_rax(); return RM2_OK }; let l: u32 = build_mangled(no,nl); let e: u32 = emit_sym_address(&RM2_TMPNAME as u64,l,&RM2_REG_RAX as u64,RM2_REG_RAX_LEN); if e != RM2_OK { return e }; push_rax(); return RM2_OK }
    if k == RM2_K_EXPR_PAREN { return emit_expr(iii_ast_paren_inner(RM2_G_AST,node)) }
    if k == RM2_K_EXPR_UNARY { let e0: u32 = emit_expr(iii_ast_unary_operand(RM2_G_AST,node)); if e0 != RM2_OK { return e0 }; pop_reg(&RM2_REG_RAX as u64,RM2_REG_RAX_LEN); let op: u32 = iii_ast_unary_op(RM2_G_AST,node); if op == 1u32 { cg_emit_arr(&RM2_STR_NEGQ as u64,RM2_STR_NEGQ_LEN) }; if op == 2u32 { cg_emit_arr(&RM2_STR_TESTRSTE as u64,RM2_STR_TESTRSTE_LEN) }; if op == 3u32 { cg_emit_arr(&RM2_STR_NOTQ as u64,RM2_STR_NOTQ_LEN) }; if op == 4u32 { cg_emit_arr(&RM2_STR_DEREF_RAX as u64,RM2_STR_DEREF_RAX_LEN) }; push_rax(); return RM2_OK }
