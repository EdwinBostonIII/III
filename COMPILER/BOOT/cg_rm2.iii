    if k == RM2_K_EXPR_INDEX { let e3: u32 = emit_expr(iii_ast_index_object(RM2_G_AST,node)); if e3 != RM2_OK { return e3 }; let e4: u32 = emit_expr(iii_ast_index_index(RM2_G_AST,node)); if e4 != RM2_OK { return e4 }; pop_reg(&RM2_REG_RCX as u64,RM2_REG_RCX_LEN); pop_reg(&RM2_REG_RAX as u64,RM2_REG_RAX_LEN); cg_emit_arr(&RM2_STR_INDEX_LD as u64,RM2_STR_INDEX_LD_LEN); push_rax(); return RM2_OK }
    if k == RM2_K_EXPR_MHASH { emit_section_rodata(); emit_mhash_data_label(node); emit_section_text(); iii_emit_memcpy_c(&RM2_TMPNAME as u64,&RM2_STR_PFX_MHASH as u64,RM2_STR_PFX_MHASH_LEN); let mut o: u32 = RM2_STR_PFX_MHASH_LEN as u32; let mut v2: u32 = node; let mut n2: u32 = 0u32; if v2==0u32 { RM2_TMPNAME[o]=48u8; o=o+1u32 } else { while v2>0u32 { RM2_NUMBUF[n2]=(48u32+(v2%10u32)) as u8; n2=n2+1u32; v2=v2/10u32 }; while n2>0u32 { n2=n2-1u32; RM2_TMPNAME[o]=RM2_NUMBUF[n2]; o=o+1u32 } }; emit_sym_address(&RM2_TMPNAME as u64,o,&RM2_REG_RAX as u64,RM2_REG_RAX_LEN); push_rax(); return RM2_G_LAST_ERROR }
