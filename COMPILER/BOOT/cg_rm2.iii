    if k == RM2_K_STMT_WAVEFRONT { let c: u32 = iii_ast_wavefront_node_count(RM2_G_AST,node); let mut i: u32 = 0u32; while i < c { let ew: u32 = emit_stmt(iii_ast_wavefront_node_at(RM2_G_AST,node,i)); if ew != RM2_OK { return ew }; i=i+1u32 }; return RM2_OK }
    if k == RM2_K_STMT_SANCTUM_ENTER { local_add(iii_ast_sanctum_enter_frame_off(RM2_G_AST,node),iii_ast_sanctum_enter_frame_len(RM2_G_AST,node)); cg_emit_arr(&RM2_STR_DOL_0_DASH as u64,RM2_STR_DOL_0_DASH_LEN); cg_emit_dec((RM2_G_LOCAL_COUNT*8u32) as u64); cg_emit_arr(&RM2_STR_PCT_RBP_NL as u64,RM2_STR_PCT_RBP_NL_LEN); let es: u32 = emit_block(iii_ast_sanctum_enter_body(RM2_G_AST,node)); if es != RM2_OK { return es }; pop_reg(&RM2_REG_RAX as u64,RM2_REG_RAX_LEN); return RM2_OK }
