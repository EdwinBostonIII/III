fn cgrm2_sha_w_set(i: u32, v: u32) -> u32 { let p: u64 = (&CGRM2_SHA_W as u64) + (i as u64) * 4u64; iii_emit_write_u8_c(p, v & 0xffu32); iii_emit_write_u8_c(p+1u64, (v >> 8u32) & 0xffu32); iii_emit_write_u8_c(p+2u64, (v >> 16u32) & 0xffu32); iii_emit_write_u8_c(p+3u64, (v >> 24u32) & 0xffu32); return 0u32 }
fn cgrm2_sha_w_get(i: u32) -> u32 { let p: u64 = (&CGRM2_SHA_W as u64) + (i as u64) * 4u64; let b0: u32 = iii_emit_buf_read_u8_c(p,0u64); let b1: u32 = iii_emit_buf_read_u8_c(p,1u64); let b2: u32 = iii_emit_buf_read_u8_c(p,2u64); let b3: u32 = iii_emit_buf_read_u8_c(p,3u64); return b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32) }
fn cgrm2_sha_buf_set(off: u32, v: u8) -> u32 { iii_emit_write_u8_c((&CGRM2_SHA_BUF as u64) + (off as u64), v as u32); return 0u32 }
fn cgrm2_sha_compress() -> u32 {
    let bbase: u64 = &CGRM2_SHA_BUF as u64; let mut k: u32 = 0u32
    while k < 16u32 { let off: u64 = (k as u64)*4u64; let b0: u32 = iii_emit_buf_read_u8_c(bbase,off); let b1: u32 = iii_emit_buf_read_u8_c(bbase,off+1u64); let b2: u32 = iii_emit_buf_read_u8_c(bbase,off+2u64); let b3: u32 = iii_emit_buf_read_u8_c(bbase,off+3u64); cgrm2_sha_w_set(k,(b0<<24u32)|(b1<<16u32)|(b2<<8u32)|b3); k = k + 1u32 }
    k = 16u32
    while k < 64u32 { let w15: u32 = cgrm2_sha_w_get(k-15u32); let w2: u32 = cgrm2_sha_w_get(k-2u32); let s0: u32 = cgrm2_rotr32(w15,7u32)^cgrm2_rotr32(w15,18u32)^(w15>>3u32); let s1: u32 = cgrm2_rotr32(w2,17u32)^cgrm2_rotr32(w2,19u32)^(w2>>10u32); cgrm2_sha_w_set(k,cgrm2_sha_w_get(k-16u32)+s0+cgrm2_sha_w_get(k-7u32)+s1); k = k + 1u32 }
    let mut a: u32 = CGRM2_SHA_S0; let mut b: u32 = CGRM2_SHA_S1; let mut c: u32 = CGRM2_SHA_S2; let mut d: u32 = CGRM2_SHA_S3; let mut e: u32 = CGRM2_SHA_S4; let mut f: u32 = CGRM2_SHA_S5; let mut g: u32 = CGRM2_SHA_S6; let mut h: u32 = CGRM2_SHA_S7
    k = 0u32
    while k < 64u32 { let S1: u32 = cgrm2_rotr32(e,6u32)^cgrm2_rotr32(e,11u32)^cgrm2_rotr32(e,25u32); let ch: u32 = (e & f) ^ ((!e) & g); let t1: u32 = h + S1 + ch + cgrm2_k256_at(k) + cgrm2_sha_w_get(k); let S0: u32 = cgrm2_rotr32(a,2u32)^cgrm2_rotr32(a,13u32)^cgrm2_rotr32(a,22u32); let mj: u32 = (a&b)^(a&c)^(b&c); let t2: u32 = S0 + mj; h=g; g=f; f=e; e=d+t1; d=c; c=b; b=a; a=t1+t2; k = k + 1u32 }
    CGRM2_SHA_S0 = CGRM2_SHA_S0 + a; CGRM2_SHA_S1 = CGRM2_SHA_S1 + b; CGRM2_SHA_S2 = CGRM2_SHA_S2 + c; CGRM2_SHA_S3 = CGRM2_SHA_S3 + d; CGRM2_SHA_S4 = CGRM2_SHA_S4 + e; CGRM2_SHA_S5 = CGRM2_SHA_S5 + f; CGRM2_SHA_S6 = CGRM2_SHA_S6 + g; CGRM2_SHA_S7 = CGRM2_SHA_S7 + h; return 0u32
