/* COMPILER/BOOT/cg_svir_main.iii — standalone harness for cg_svir.iii.
 *
 *   cg_svir <file.iii>   ->  gen_svir.iii text on stdout
 *
 * Drives the PRODUCTION front-end (lex.iii + parse.iii) then cg_svir — NO
 * sema, NO cg_r*, NO emit/link.  Used for fast byte-parity iteration against
 * iiisv2 without rebuilding the compiler; the SAME iii_cg_svir_emit entry is
 * wired into main.iii's --emit-svir path once parity holds.
 */
module cg_svir_main

extern @abi(c-msvc-x64) fn iii_lex_malloc_c(n: u64) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_read_u64_c(addr: u64, off: u64) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_fopen_c(path: u64, mode: u32) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_fread_c(ptr: u64, n: u64, file: u64) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_fclose_c(file: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_stdout_c() -> u64 from "lex_runtime.c"

extern @abi(c-msvc-x64) fn iii_lex_create(bytes: u64, len: u64, src: u64) -> u64 from "lex.iii"
extern @abi(c-msvc-x64) fn iii_ast_create(bytes: u64, len: u64, src: u64) -> u64 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_parse_create(lex: u64, ast: u64) -> u64 from "parse.iii"
extern @abi(c-msvc-x64) fn iii_parse_module(p: u64) -> u32 from "parse.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_emit(ast: u64, out: u64) -> u32 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_set_mode(closure: u32, membase: u64) -> u32 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_names(out: u64) -> u32 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_raw(path: u64) -> u32 from "cg_svir.iii"

/* closure-mode CLI helpers: NUL-terminated argv string ops */
fn arg_eq(s: u64, lit: u64) -> u32 {
    let a: *u8 = s as *u8
    let b: *u8 = lit as *u8
    let mut j: u64 = 0u64
    let mut go: u32 = 1u32
    while go == 1u32 {
        let ca: u32 = a[j] as u32
        let cb: u32 = b[j] as u32
        if cb == 126u32 { if ca == 0u32 { return 1u32 }  return 0u32 }
        if ca != cb { return 0u32 }
        j = j + 1u64
    }
    return 0u32
}
fn arg_dec(s: u64) -> u64 {
    let p: *u8 = s as *u8
    let mut v: u64 = 0u64
    let mut j: u64 = 0u64
    let mut go: u32 = 1u32
    while go == 1u32 {
        let c: u32 = p[j] as u32
        if c < 48u32 { go = 0u32 } else { if c > 57u32 { go = 0u32 } else { v = v * 10u64 + ((c - 48u32) as u64)  j = j + 1u64 } }
    }
    return v
}

const FOPEN_RB: u32 = 0u32
const SRC_CAP: u64 = 8388608u64

fn main(argc: u32, argv: u64) -> u32 @export {
    if argc < 2u32 { return 2u32 }
    let path: u64 = iii_lex_read_u64_c(argv, 8u64)
    let file: u64 = iii_lex_fopen_c(path, FOPEN_RB)
    if file == 0u64 { return 3u32 }
    let buf: u64 = iii_lex_malloc_c(SRC_CAP)
    if buf == 0u64 { iii_lex_fclose_c(file)  return 3u32 }
    let mut total: u64 = 0u64
    let mut go: u32 = 1u32
    while go == 1u32 {
        if total + 65536u64 > SRC_CAP { go = 0u32 }
        else {
            let n: u64 = iii_lex_fread_c(buf + total, 65536u64, file)
            total = total + n
            if n < 65536u64 { go = 0u32 }
        }
    }
    iii_lex_fclose_c(file)
    if total == 0u64 { return 3u32 }
    let lex: u64 = iii_lex_create(buf, total, path)
    if lex == 0u64 { return 4u32 }
    let ast: u64 = iii_ast_create(buf, total, path)
    if ast == 0u64 { return 4u32 }
    let p: u64 = iii_parse_create(lex, ast)
    if p == 0u64 { return 4u32 }
    if iii_parse_module(p) == 0u32 { return 5u32 }
    /* closure mode (gate v3): cg_svir <file> --closure <membase> <out.svbin> <out.names>
     * -> ALL externs become imports, cells at membase, raw container +
     * names listing to files (text module still prints to stdout). */
    if argc >= 6u32 { if arg_eq(iii_lex_read_u64_c(argv, 16u64), "--closure~" as u64) == 1u32 {
        iii_cg_svir_set_mode(1u32, arg_dec(iii_lex_read_u64_c(argv, 24u64)))
        let crc: u32 = iii_cg_svir_emit(ast, iii_lex_stdout_c())
        if crc != 0u32 { return crc }
        if iii_cg_svir_raw(iii_lex_read_u64_c(argv, 32u64)) != 0u32 { return 6u32 }
        let nf: u64 = iii_lex_fopen_c(iii_lex_read_u64_c(argv, 40u64), 1u32)
        if nf == 0u64 { return 6u32 }
        iii_cg_svir_names(nf)
        iii_lex_fclose_c(nf)
        return 0u32
    } }
    let rc: u32 = iii_cg_svir_emit(ast, iii_lex_stdout_c())
    return rc
}
