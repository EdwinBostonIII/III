extern @abi(c-msvc-x64) fn dxc_n() -> u64 from "doxa.iii"
extern @abi(c-msvc-x64) fn dxc_key_at(i: u64) -> u64 from "doxa.iii"
extern @abi(c-msvc-x64) fn dxc_grn_at(i: u64) -> u64 from "doxa.iii"
extern @abi(c-msvc-x64) fn dxc_red_at(i: u64) -> u64 from "doxa.iii"
extern @abi(c-msvc-x64) fn dxc_ern_at(i: u64) -> u64 from "doxa.iii"
extern @abi(c-msvc-x64) fn dxc_def_at(i: u64) -> u64 from "doxa.iii"
extern @abi(c-msvc-x64) fn dxc_bal_key(key: u64) -> i64 from "doxa.iii"
