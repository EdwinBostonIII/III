/* COMPILER/BOOT/doxa_main.iii -- iii-doxa: THE BELIEF ORGAN's tool face.
 *
 *   iii-doxa prove                     the self-proof alone (every law, every falsifier)
 *   iii-doxa status    [dirs]          the two books, the ledger, the certificates
 *   iii-doxa drip N    [dirs]          open up to N stakes on the audit's own schedule;
 *                                      write the ranked recommendation (drip_order.txt)
 *   iii-doxa reconcile [dirs]          settle stakes against the heart's DERIVED evidence
 *   iii-doxa dream K SEED [dirs]       a reversible excursion: zero residue PROVEN, only
 *                                      certificates retained (conjectures unadjudicated)
 *   iii-doxa loop N    [dirs]          the whole live cycle: predict -> summon the heart
 *                                      (iii-kardia audit N) -> reconcile -> calibration
 *
 *   [dirs] = [--ledger D] (default STDLIB/build/doxa)
 *            [--heart  H] (default STDLIB/build/kardia)
 *
 * EVERY verb self-proves first and REFUSES to run on a failed arm (exit 9) --
 * verification lives INSIDE (the kardia pattern: no gate, no KAT, no standing
 * arm).  The evidence that settles stakes is written by iii-kardia into ITS
 * ledger -- machinery this organ cannot parameterize.  THE HEART AUDITS THE
 * MIND.  Requires CWD = the III root.
 *
 * exit: 0 coherent | 1 books split (conservation) | 2 env | 3 usage |
 *       4 a law refused live | 9 SELF-REFUSED */
module doxa_main

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn system(cmd: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(stream: u64) -> i32 from "msvcrt"

extern @abi(c-msvc-x64) fn dx_selfprove() -> u64 from "doxa.iii"
extern @abi(c-msvc-x64) fn dx_reset() -> i32 from "doxa.iii"
