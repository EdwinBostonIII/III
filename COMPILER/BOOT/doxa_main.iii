extern @abi(c-msvc-x64) fn dx_k_name_byte(i: u64, j: u64) -> u8 from "doxa.iii"
extern @abi(c-msvc-x64) fn dx_jur(cell: u64) -> u64 from "doxa.iii"
extern @abi(c-msvc-x64) fn dx_jur_count() -> u64 from "doxa.iii"
extern @abi(c-msvc-x64) fn dx_ctx_key(cell: u64) -> u64 from "doxa.iii"
