extern @abi(c-msvc-x64) fn dxm_fact_at(i: u64) -> u64 from "doxa.iii"
extern @abi(c-msvc-x64) fn dx_dream(k: u64, seed: u64, dir: u64, sabotage: u64) -> u64 from "doxa.iii"
extern @abi(c-msvc-x64) fn dx_dream_found(i_back: u64) -> u64 from "doxa.iii"
