/* C:\Users\Edwin Boston\OneDrive\Desktop\III\COMPILER\BOOT\emit.iii
 *
 * III Stage-0 binary emitter ? Stage-1 .iii port of emit.c.
 *
 * Mirrors emit.c determinism contract D1..D18 (see emit.h).  All
 * libc / subprocess primitives are reached via emit_accessors.c so
 * the .iii body itself remains pure compiler-language.
 *
 * NIH per ADR-021: gcc/ld/objcopy/objdump on the host side; libc only
 * on our side.  No third-party deps.
 */

module emit

