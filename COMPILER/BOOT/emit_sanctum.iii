const SV_MAX_LOCALS: u32 = 64u32

/* Node-kind constants -- SYNCED to ast.iii III_AST_* (the source of truth). cg_rm2 was never
 * exercised end-to-end (no script assembled --ring R-2), so these had drifted: statements/patterns
 * were +1 and expressions/arg +2 vs the live enum, mis-classifying every body node. Re-aligned. */
