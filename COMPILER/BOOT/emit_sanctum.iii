    k = 0u32
    while k < 64u32 { let S1: u32 = sv_rotr32(e,6u32)^sv_rotr32(e,11u32)^sv_rotr32(e,25u32); let ch: u32 = (e & f) ^ ((!e) & g); let t1: u32 = h + S1 + ch + sv_k256_at(k) + sv_sha_w_get(k); let S0: u32 = sv_rotr32(a,2u32)^sv_rotr32(a,13u32)^sv_rotr32(a,22u32); let mj: u32 = (a&b)^(a&c)^(b&c); let t2: u32 = S0 + mj; h=g; g=f; f=e; e=d+t1; d=c; c=b; b=a; a=t1+t2; k = k + 1u32 }
    SV_SHA_S0 = SV_SHA_S0 + a; SV_SHA_S1 = SV_SHA_S1 + b; SV_SHA_S2 = SV_SHA_S2 + c; SV_SHA_S3 = SV_SHA_S3 + d; SV_SHA_S4 = SV_SHA_S4 + e; SV_SHA_S5 = SV_SHA_S5 + f; SV_SHA_S6 = SV_SHA_S6 + g; SV_SHA_S7 = SV_SHA_S7 + h; return 0u32
}
fn sv_sha_init() -> u32 { SV_SHA_S0=0x6a09e667u32; SV_SHA_S1=0xbb67ae85u32; SV_SHA_S2=0x3c6ef372u32; SV_SHA_S3=0xa54ff53au32; SV_SHA_S4=0x510e527fu32; SV_SHA_S5=0x9b05688cu32; SV_SHA_S6=0x1f83d9abu32; SV_SHA_S7=0x5be0cd19u32; SV_SHA_BITS_HI=0u32; SV_SHA_BITS_LO=0u32; SV_SHA_LEN=0u32; return 0u32 }
fn sv_sha_update(data: u64, n: u64) -> u32 { let bits_lo: u32 = ((n & 0xffffffffu64) as u32) << 3u32; let bits_hi: u32 = ((n >> 29u64) as u32); let new_lo: u32 = SV_SHA_BITS_LO + bits_lo; let mut carry: u32 = 0u32; if new_lo < SV_SHA_BITS_LO { carry = 1u32 }; SV_SHA_BITS_LO = new_lo; SV_SHA_BITS_HI = SV_SHA_BITS_HI + bits_hi + carry; let mut left: u64 = n; let mut p: u64 = data; while left > 0u64 { let mut take: u64 = 64u64 - (SV_SHA_LEN as u64); if take > left { take = left }; iii_emit_memcpy_c((&SV_SHA_BUF as u64)+(SV_SHA_LEN as u64), p, take); SV_SHA_LEN = SV_SHA_LEN + (take as u32); p = p + take; left = left - take; if SV_SHA_LEN == 64u32 { sv_sha_compress(); SV_SHA_LEN = 0u32 } }; return 0u32 }
fn sv_sha_final(out: u64) -> u32 { sv_sha_buf_set(SV_SHA_LEN,0x80u8); SV_SHA_LEN = SV_SHA_LEN + 1u32; if SV_SHA_LEN > 56u32 { while SV_SHA_LEN < 64u32 { sv_sha_buf_set(SV_SHA_LEN,0u8); SV_SHA_LEN = SV_SHA_LEN + 1u32 }; sv_sha_compress(); SV_SHA_LEN = 0u32 }; while SV_SHA_LEN < 56u32 { sv_sha_buf_set(SV_SHA_LEN,0u8); SV_SHA_LEN = SV_SHA_LEN + 1u32 }; sv_sha_buf_set(56u32,((SV_SHA_BITS_HI>>24u32)&0xffu32) as u8); sv_sha_buf_set(57u32,((SV_SHA_BITS_HI>>16u32)&0xffu32) as u8); sv_sha_buf_set(58u32,((SV_SHA_BITS_HI>>8u32)&0xffu32) as u8); sv_sha_buf_set(59u32,(SV_SHA_BITS_HI&0xffu32) as u8); sv_sha_buf_set(60u32,((SV_SHA_BITS_LO>>24u32)&0xffu32) as u8); sv_sha_buf_set(61u32,((SV_SHA_BITS_LO>>16u32)&0xffu32) as u8); sv_sha_buf_set(62u32,((SV_SHA_BITS_LO>>8u32)&0xffu32) as u8); sv_sha_buf_set(63u32,(SV_SHA_BITS_LO&0xffu32) as u8); sv_sha_compress(); let mut i: u32 = 0u32; while i < 8u32 { let mut s: u32 = 0u32; if i==0u32 { s=SV_SHA_S0 }; if i==1u32 { s=SV_SHA_S1 }; if i==2u32 { s=SV_SHA_S2 }; if i==3u32 { s=SV_SHA_S3 }; if i==4u32 { s=SV_SHA_S4 }; if i==5u32 { s=SV_SHA_S5 }; if i==6u32 { s=SV_SHA_S6 }; if i==7u32 { s=SV_SHA_S7 }; iii_emit_write_u32_be_c(out + (i as u64)*4u64, s); i = i + 1u32 }; return 0u32 }

fn cg_emit_bytes(addr: u64, n: u64) -> u32 { if SV_G_SEALED != 0u32 { SV_G_LAST_ERROR = SV_E_SEALED; return SV_E_SEALED }; if n == 0u64 { return SV_OK }; if SV_G_OUT != 0u64 { if sv_fwrite_c(SV_G_OUT, addr, n) != 0i32 { SV_G_LAST_ERROR = SV_E_IO; return SV_E_IO } }; if SV_MODE == 1u32 { cgsha_update(&SV_CGSHA as u64, addr, n) } else { sv_sha_update(addr,n) }; return SV_OK }
fn cg_emit_arr(addr: u64, n: u64) -> u32 { return cg_emit_bytes(addr,n) }
fn cg_emit_ch(ch: u32) -> u32 { SV_CHBUF[0] = (ch & 0xffu32) as u8; return cg_emit_bytes(&SV_CHBUF as u64,1u64) }
fn cg_emit_dec(v0: u64) -> u32 { let mut v: u64 = v0; let mut n: u32 = 0u32; if v == 0u64 { SV_NUMBUF[0]=48u8; return cg_emit_bytes(&SV_NUMBUF as u64,1u64) }; while v > 0u64 { SV_NUMBUF[n] = (48u64 + (v % 10u64)) as u8; n = n + 1u32; v = v / 10u64 }; while n > 0u32 { n = n - 1u32; cg_emit_ch(SV_NUMBUF[n] as u32) }; return SV_OK }
fn cg_emit_hex(v0: u64) -> u32 { let mut v: u64 = v0; let mut n: u32 = 0u32; if v == 0u64 { SV_NUMBUF[0]=48u8; return cg_emit_bytes(&SV_NUMBUF as u64,1u64) }; while v > 0u64 { let d: u64 = v & 15u64; if d < 10u64 { SV_NUMBUF[n] = (48u64+d) as u8 } else { SV_NUMBUF[n] = (87u64+d) as u8 }; n = n + 1u32; v = v >> 4u64 }; while n > 0u32 { n = n - 1u32; cg_emit_ch(SV_NUMBUF[n] as u32) }; return SV_OK }
fn emit_section_text() -> u32 { if SV_G_FMT == SV_FMT_PE { return cg_emit_arr(&SV_SEC_TEXT_PE as u64, SV_SEC_TEXT_PE_LEN) }; return cg_emit_arr(&SV_SEC_TEXT_ELF as u64, SV_SEC_TEXT_ELF_LEN) }
fn emit_section_rodata() -> u32 { if SV_G_FMT == SV_FMT_PE { return cg_emit_arr(&SV_SEC_RODATA_PE as u64, SV_SEC_RODATA_PE_LEN) }; return cg_emit_arr(&SV_SEC_RODATA_ELF as u64, SV_SEC_RODATA_ELF_LEN) }
fn is_sym_char(b: u32) -> u32 { if b >= 65u32 { if b <= 90u32 { return 1u32 } }; if b >= 97u32 { if b <= 122u32 { return 1u32 } }; if b >= 48u32 { if b <= 57u32 { return 1u32 } }; if b == 95u32 { return 1u32 }; return 0u32 }
fn emit_mangled(off: u32, len: u32) -> u32 { let src: u64 = iii_ast_source_buf(SV_G_AST); cg_emit_arr(SV_CUR_PFX,SV_CUR_PFX_LEN); let mut i: u32 = 0u32; while i < len { let b: u32 = iii_emit_buf_read_u8_c(src, (off+i) as u64); if is_sym_char(b) == 1u32 { cg_emit_ch(b) } else { cg_emit_ch(95u32) }; i = i + 1u32 }; return SV_OK }
fn build_mangled(off: u32, len: u32) -> u32 { let src: u64 = iii_ast_source_buf(SV_G_AST); iii_emit_memcpy_c(&SV_TMPNAME as u64, SV_CUR_PFX, SV_CUR_PFX_LEN); let mut k: u32 = SV_CUR_PFX_LEN as u32; let mut i: u32 = 0u32; while i < len { let b: u32 = iii_emit_buf_read_u8_c(src,(off+i) as u64); if is_sym_char(b) == 1u32 { SV_TMPNAME[k] = b as u8 } else { SV_TMPNAME[k] = 95u8 }; k = k + 1u32; i = i + 1u32; if k >= 255u32 { SV_TMPNAME[k]=0u8; return k } }; SV_TMPNAME[k]=0u8; return k }
fn sym_is_permitted(addr: u64, n: u32) -> u32 { if n >= (SV_CUR_PFX_LEN as u32) { if iii_emit_memcmp_c(addr,SV_CUR_PFX,SV_CUR_PFX_LEN) == 0i32 { return 1u32 } }; if n >= (SV_PFX_LSANCTUM_LEN as u32) { if iii_emit_memcmp_c(addr,&SV_PFX_LSANCTUM as u64,SV_PFX_LSANCTUM_LEN) == 0i32 { return 1u32 } }; if n >= (SV_PFX_IIISANCTUM_LEN as u32) { if iii_emit_memcmp_c(addr,&SV_PFX_IIISANCTUM as u64,SV_PFX_IIISANCTUM_LEN) == 0i32 { return 1u32 } }; if n >= (SV_PFX_XIISANCTUM_LEN as u32) { if iii_emit_memcmp_c(addr,&SV_PFX_XIISANCTUM as u64,SV_PFX_XIISANCTUM_LEN) == 0i32 { return 1u32 } }; if n >= (SV_PFX_IIICAP_LEN as u32) { if iii_emit_memcmp_c(addr,&SV_PFX_IIICAP as u64,SV_PFX_IIICAP_LEN) == 0i32 { return 1u32 } }; return 0u32 }
fn guard_symbol_load(addr: u64, n: u32) -> u32 { if sym_is_permitted(addr,n) == 0u32 { SV_G_LAST_ERROR=SV_E_FORBIDDEN_TARGET; return SV_E_FORBIDDEN_TARGET }; if n == (SV_SYM_ONEWAY_LEN as u32) { if iii_emit_memcmp_c(addr,&SV_SYM_ONEWAY as u64,SV_SYM_ONEWAY_LEN)==0i32 { SV_G_LAST_ERROR=SV_E_ONEWAY_READ; return SV_E_ONEWAY_READ } }; return SV_OK }
fn emit_sym_address(addr: u64, n: u32, reg: u64, regn: u64) -> u32 { let e: u32 = guard_symbol_load(addr,n); if e != SV_OK { return e }; cg_emit_arr(&SV_STR_LEAQ as u64,SV_STR_LEAQ_LEN); cg_emit_bytes(addr,n as u64); cg_emit_arr(&SV_STR_RIPCM_PCT as u64,SV_STR_RIPCM_PCT_LEN); cg_emit_bytes(reg,regn); cg_emit_arr(&SV_STR_NL as u64,SV_STR_NL_LEN); return SV_OK }
fn local_slot(off: u32, len: u32) -> i32 { let src: u64 = iii_ast_source_buf(SV_G_AST); let mut i: u32 = 0u32; while i < SV_G_LOCAL_COUNT { if SV_LOCAL_LEN[i] == len { if iii_emit_memcmp_c(src+(SV_LOCAL_OFF[i] as u64), src+(off as u64), len as u64) == 0i32 { return i as i32 } }; i = i + 1u32 }; return -1i32 }
fn local_add(off: u32, len: u32) -> u32 { if SV_G_LOCAL_COUNT >= SV_MAX_LOCALS { SV_G_LAST_ERROR=SV_E_INTERNAL; return SV_E_INTERNAL }; SV_LOCAL_OFF[SV_G_LOCAL_COUNT]=off; SV_LOCAL_LEN[SV_G_LOCAL_COUNT]=len; SV_G_LOCAL_COUNT = SV_G_LOCAL_COUNT + 1u32; return SV_OK }
fn push_rax() -> u32 { cg_emit_arr(&SV_STR_PUSHRAX as u64,SV_STR_PUSHRAX_LEN); SV_G_STACK_DEPTH=SV_G_STACK_DEPTH+1u32; return SV_OK }
fn pop_reg(reg: u64, n: u64) -> u32 { cg_emit_arr(&SV_STR_POPRAX as u64,10u64); cg_emit_bytes(reg,n); cg_emit_arr(&SV_STR_NL as u64,SV_STR_NL_LEN); if SV_G_STACK_DEPTH > 0u32 { SV_G_STACK_DEPTH=SV_G_STACK_DEPTH-1u32 }; return SV_OK }   /* [codegen] emit 10 = "    popq %" then reg (was 9, dropping the % at byte 9 -> invalid AT&T "popq rax"); removed 2 dead 0-byte emits */

fn emit_movabs_rax(v: u64) -> u32 { cg_emit_arr(&SV_STR_MOVABSQ_OPEN as u64,SV_STR_MOVABSQ_OPEN_LEN); cg_emit_hex(v); cg_emit_arr(&SV_STR_COMMA_RAX_NL as u64,SV_STR_COMMA_RAX_NL_LEN); return SV_OK }
fn emit_movabs_rcx(v: u64) -> u32 { cg_emit_arr(&SV_STR_MOVABSQ_OPEN as u64,SV_STR_MOVABSQ_OPEN_LEN); cg_emit_hex(v); cg_emit_arr(&SV_STR_COMMA_RCX_NL as u64,SV_STR_COMMA_RCX_NL_LEN); return SV_OK }
fn emit_load_slot(slot: u32, reg: u64, regn: u64) -> u32 { cg_emit_arr(&SV_STR_DASH_OPEN as u64,SV_STR_DASH_OPEN_LEN); cg_emit_dec(((slot+1u32)*8u32) as u64); cg_emit_arr(&SV_STR_PCT_RBP_NL as u64,6u64); cg_emit_arr(&SV_STR_COMMA_SP as u64,SV_STR_COMMA_SP_LEN); cg_emit_ch(37u32); cg_emit_bytes(reg,regn); cg_emit_arr(&SV_STR_NL as u64,SV_STR_NL_LEN); return SV_OK }
fn emit_store_rax_slot(slot: u32) -> u32 { cg_emit_arr(&SV_STR_MOVQRAX_DASH as u64,SV_STR_MOVQRAX_DASH_LEN); cg_emit_dec(((slot+1u32)*8u32) as u64); cg_emit_arr(&SV_STR_BPCMA_RAX as u64,6u64); cg_emit_arr(&SV_STR_NL as u64,SV_STR_NL_LEN); return SV_OK }   /* [codegen] emit 6 = "(%rbp)" + NL (was 13 -> dangling ", %rax" 3-operand movq -- invalid; mirrors the emit_store_rcx_slot fix) */
fn emit_store_rcx_slot(slot: u32) -> u32 { cg_emit_arr(&SV_STR_MOVQ_PCT as u64,SV_STR_MOVQ_PCT_LEN); cg_emit_arr(&SV_REG_RCX as u64,SV_REG_RCX_LEN); cg_emit_arr(&SV_STR_COMMA_SP as u64,SV_STR_COMMA_SP_LEN); cg_emit_ch(45u32); cg_emit_dec(((slot+1u32)*8u32) as u64); cg_emit_arr(&SV_STR_BPCMA_RCX as u64,6u64); cg_emit_arr(&SV_STR_NL as u64,SV_STR_NL_LEN); return SV_OK }   /* [codegen] emit 6 = "(%rbp)" (was 7 -> dangling comma "(%rbp)," from the load-tail const -> invalid store) */
fn emit_bool_setcc(op: u32) -> u32 { cg_emit_arr(&SV_STR_CMP_RCX_RAX as u64,SV_STR_CMP_RCX_RAX_LEN); if op == 11u32 { cg_emit_arr(&SV_STR_SETE as u64,SV_STR_SETE_LEN) }; if op == 12u32 { cg_emit_arr(&SV_STR_SETNE as u64,SV_STR_SETNE_LEN) }; if op == 13u32 { cg_emit_arr(&SV_STR_SETL as u64,SV_STR_SETL_LEN) }; if op == 14u32 { cg_emit_arr(&SV_STR_SETLE as u64,SV_STR_SETLE_LEN) }; if op == 15u32 { cg_emit_arr(&SV_STR_SETG as u64,SV_STR_SETG_LEN) }; if op == 16u32 { cg_emit_arr(&SV_STR_SETGE as u64,SV_STR_SETGE_LEN) }; return SV_OK }
fn pack_hexad_expr(node: u32) -> u64 { let mut v: u32 = 0u32; let mut i: u32 = 0u32; while i < 6u32 { let t: u32 = iii_ast_expr_hexad_trit_at(SV_G_AST,node,i) & 3u32; v = v | (t << (2u32*i)); i = i + 1u32 }; return v as u64 }
fn pack_hexad_pat(node: u32) -> u64 { let mut v: u32 = 0u32; let mut i: u32 = 0u32; while i < 6u32 { let t: u32 = iii_ast_pat_hexad_trit_at(SV_G_AST,node,i) & 3u32; v = v | (t << (2u32*i)); i = i + 1u32 }; return v as u64 }

fn emit_expr(node: u32) -> u32 {
    if node == 0u32 { return SV_OK }
    let k: u32 = iii_ast_node_kind(SV_G_AST,node)
    if k == SV_K_EXPR_INT { emit_movabs_rax(iii_ast_expr_int_u64(SV_G_AST,node)); push_rax(); return SV_OK }
    if k == SV_K_EXPR_HEX { let lo: u64 = iii_ast_hex_value_lo(SV_G_AST,node) as u64; let hi: u64 = iii_ast_hex_value_hi(SV_G_AST,node) as u64; emit_movabs_rax(lo | (hi << 32u64)); push_rax(); return SV_OK }
    if k == SV_K_EXPR_BOOL { if iii_ast_bool_value(SV_G_AST,node) != 0u32 { cg_emit_arr(&SV_STR_MOVQ1RAX as u64,SV_STR_MOVQ1RAX_LEN) } else { cg_emit_arr(&SV_STR_MOVQ0RAX as u64,SV_STR_MOVQ0RAX_LEN) }; push_rax(); return SV_OK }
    if k == SV_K_EXPR_TRIT { emit_movabs_rax(iii_ast_expr_trit_value(SV_G_AST,node) as u64); push_rax(); return SV_OK }
    if k == SV_K_EXPR_UNIT { cg_emit_arr(&SV_STR_XORRAX as u64,SV_STR_XORRAX_LEN); push_rax(); return SV_OK }
    if k == SV_K_EXPR_HEXAD { emit_movabs_rax(pack_hexad_expr(node)); push_rax(); return SV_OK }
    if k == SV_K_EXPR_STR { cg_emit_arr(&SV_STR_PFX_STR as u64,0u64); let idx: u32 = iii_ast_str_payload_idx(SV_G_AST,node); let mut off: u32 = build_label_name(&SV_STR_PFX_STR as u64, SV_STR_PFX_STR_LEN); let mut v: u32 = idx; let mut n: u32 = 0u32; if v == 0u32 { SV_TMPNAME[off]=48u8; off=off+1u32 } else { while v > 0u32 { SV_NUMBUF[n]=(48u32+(v%10u32)) as u8; n=n+1u32; v=v/10u32 }; while n>0u32 { n=n-1u32; SV_TMPNAME[off]=SV_NUMBUF[n]; off=off+1u32 } }; let e: u32 = emit_sym_address(&SV_TMPNAME as u64,off,&SV_REG_RAX as u64,SV_REG_RAX_LEN); if e != SV_OK { return e }; push_rax(); return SV_OK }   /* [unchecked-return] capture rc like the IDENT sibling, not stale SV_G_LAST_ERROR */
    if k == SV_K_EXPR_IDENT { let no: u32 = iii_ast_ident_name_offset(SV_G_AST,node); let nl: u32 = iii_ast_ident_name_length(SV_G_AST,node); let s: i32 = local_slot(no,nl); if s >= 0i32 { emit_load_slot(s as u32,&SV_REG_RAX as u64,SV_REG_RAX_LEN); push_rax(); return SV_OK }; let l: u32 = build_mangled(no,nl); let e: u32 = emit_sym_address(&SV_TMPNAME as u64,l,&SV_REG_RAX as u64,SV_REG_RAX_LEN); if e != SV_OK { return e }; push_rax(); return SV_OK }
