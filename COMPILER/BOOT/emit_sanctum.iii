fn sv_rotr32(x: u32, n: u32) -> u32 { return (x >> n) | (x << (32u32 - n)) }
fn sv_k256_at(i: u32) -> u32 {
    if i == 0u32 { return 0x428a2f98u32 }; if i == 1u32 { return 0x71374491u32 }; if i == 2u32 { return 0xb5c0fbcfu32 }; if i == 3u32 { return 0xe9b5dba5u32 }
    if i == 4u32 { return 0x3956c25bu32 }; if i == 5u32 { return 0x59f111f1u32 }; if i == 6u32 { return 0x923f82a4u32 }; if i == 7u32 { return 0xab1c5ed5u32 }
    if i == 8u32 { return 0xd807aa98u32 }; if i == 9u32 { return 0x12835b01u32 }; if i == 10u32 { return 0x243185beu32 }; if i == 11u32 { return 0x550c7dc3u32 }
    if i == 12u32 { return 0x72be5d74u32 }; if i == 13u32 { return 0x80deb1feu32 }; if i == 14u32 { return 0x9bdc06a7u32 }; if i == 15u32 { return 0xc19bf174u32 }
    if i == 16u32 { return 0xe49b69c1u32 }; if i == 17u32 { return 0xefbe4786u32 }; if i == 18u32 { return 0x0fc19dc6u32 }; if i == 19u32 { return 0x240ca1ccu32 }
    if i == 20u32 { return 0x2de92c6fu32 }; if i == 21u32 { return 0x4a7484aau32 }; if i == 22u32 { return 0x5cb0a9dcu32 }; if i == 23u32 { return 0x76f988dau32 }
    if i == 24u32 { return 0x983e5152u32 }; if i == 25u32 { return 0xa831c66du32 }; if i == 26u32 { return 0xb00327c8u32 }; if i == 27u32 { return 0xbf597fc7u32 }
