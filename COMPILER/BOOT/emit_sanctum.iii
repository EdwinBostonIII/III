/* III Stage-0 Ring -2 codegen — cg_rm2.c port to .iii.
 * ABI-compatible with cg_rm2.h.  State is a Stage-1 singleton like the
 * other opaque-state .iii ports in BOOT; all AST/FILE/memory access goes
 * through the accessor surfaces.
 */

module sanctum

