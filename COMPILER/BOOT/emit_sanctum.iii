var SV_HV_EPILOG_FULL : [u8; 63] = [32u8, 32u8, 32u8, 32u8, 120u8, 111u8, 114u8, 113u8, 32u8, 37u8, 114u8, 97u8, 120u8, 44u8, 32u8, 37u8, 114u8, 97u8, 120u8, 10u8, 32u8, 32u8, 32u8, 32u8, 109u8, 111u8, 118u8, 113u8, 32u8, 37u8, 114u8, 98u8, 112u8, 44u8, 32u8, 37u8, 114u8, 115u8, 112u8, 10u8, 32u8, 32u8, 32u8, 32u8, 112u8, 111u8, 112u8, 113u8, 32u8, 37u8, 114u8, 98u8, 112u8, 10u8, 32u8, 32u8, 32u8, 32u8, 114u8, 101u8, 116u8, 113u8, 10u8]
const SV_HV_EPILOG_FULL_LEN : u64 = 63u64
var SV_HV_MOVQ_PCT : [u8; 10] = [32u8, 32u8, 32u8, 32u8, 109u8, 111u8, 118u8, 113u8, 32u8, 37u8]
const SV_HV_MOVQ_PCT_LEN : u64 = 10u64
var SV_HV_DASHRBP : [u8; 7] = [40u8, 37u8, 114u8, 98u8, 112u8, 41u8, 10u8]
const SV_HV_DASHRBP_LEN : u64 = 7u64
var SV_HV_COMMA_DASH : [u8; 3] = [44u8, 32u8, 45u8]
const SV_HV_COMMA_DASH_LEN : u64 = 3u64
fn hv_emit_bare_metal_entry() -> u32 { return cg_emit_arr(&SV_HV_BARE_METAL_ENTRY as u64, SV_HV_BARE_METAL_ENTRY_LEN) }
fn hv_emit_vmx_svm_dispatch() -> u32 { return cg_emit_arr(&SV_HV_VMX_SVM_DISPATCH as u64, SV_HV_VMX_SVM_DISPATCH_LEN) }
fn hv_emit_svm_vmrun_bracket() -> u32 { return cg_emit_arr(&SV_HV_SVM_VMRUN_BRACKET as u64, SV_HV_SVM_VMRUN_BRACKET_LEN) }
fn hv_emit_vmx_vmrun_bracket() -> u32 { return cg_emit_arr(&SV_HV_VMX_VMRUN_BRACKET as u64, SV_HV_VMX_VMRUN_BRACKET_LEN) }
fn hv_emit_one_pd(g: u32) -> u32 {
    cg_emit_arr(&SV_HV_PD_ALIGN as u64, SV_HV_PD_ALIGN_LEN);
    if g == 0u32 { cg_emit_arr(&SV_HV_PD0_LBL as u64, SV_HV_PD0_LBL_LEN) };
    if g == 1u32 { cg_emit_arr(&SV_HV_PD1_LBL as u64, SV_HV_PD1_LBL_LEN) };
    if g == 2u32 { cg_emit_arr(&SV_HV_PD2_LBL as u64, SV_HV_PD2_LBL_LEN) };
    if g == 3u32 { cg_emit_arr(&SV_HV_PD3_LBL as u64, SV_HV_PD3_LBL_LEN) };
    let g64: u64 = g as u64
    let mut e: u32 = 0u32
    while e < 512u32 {
        let phys: u64 = (g64 << 30u64) | ((e as u64) << 21u64)
        let val: u64 = phys | 0xB7u64
        cg_emit_arr(&SV_HV_QUAD_OPEN as u64, SV_HV_QUAD_OPEN_LEN)
        cg_emit_hex(val)
        cg_emit_arr(&SV_HV_NL as u64, SV_HV_NL_LEN)
        e = e + 1u32
    }
    return SV_OK
}
fn hv_emit_slat_tables() -> u32 {
    cg_emit_arr(&SV_HV_SLAT_HDR as u64, SV_HV_SLAT_HDR_LEN)
    let mut g: u32 = 0u32
    while g < 4u32 { hv_emit_one_pd(g); g = g + 1u32 }
    return SV_OK
}
fn hv_emit_vmexit_table() -> u32 {
    cg_emit_arr(&SV_HV_VMEXIT_TBL_HDR as u64, SV_HV_VMEXIT_TBL_HDR_LEN)
    let mut i: u32 = 0u32
    while i < 256u32 {
        cg_emit_arr(&SV_HV_VMEXIT_DEFAULT_LINE as u64, SV_HV_VMEXIT_DEFAULT_LINE_LEN)
        i = i + 1u32
    }
    return SV_OK
}
fn hv_emit_bss_and_data() -> u32 {
    return cg_emit_arr(&SV_HV_BSS_HEAD as u64, SV_HV_BSS_HEAD_LEN)
}

fn emit_name_raw(off: u32, len: u32) -> u32 {
    let src: u64 = iii_ast_source_buf(SV_G_AST)
    let mut i: u32 = 0u32
    while i < len {
        let bch: u32 = iii_emit_buf_read_u8_c(src, (off + i) as u64)
        cg_emit_ch(bch)
        i = i + 1u32
    }
    return SV_OK
}

/* D8 witness entry/exit (cg_rm1.c::emit_witness_call): subq/addq are
 * stack-depth-parity-conditional, so SV_G_STACK_DEPTH is tracked identically. */
fn hv_emit_witness(wid: u32, is_exit: u32) -> u32 {
    cg_emit_arr(&SV_HV_WIT_CMT as u64, 17u64)
    if is_exit == 1u32 { cg_emit_arr(&SV_HV_WIT_EXIT as u64, 4u64) }
    if is_exit != 1u32 { cg_emit_arr(&SV_HV_WIT_ENTRY as u64, 5u64) }
    cg_emit_arr(&SV_HV_WIT_WIDEQ as u64, 7u64)
    cg_emit_hex(wid as u64)
    cg_emit_arr(&SV_STR_NL as u64, SV_STR_NL_LEN)
    cg_emit_arr(&SV_HV_WIT_PUSH as u64, 30u64)
    SV_G_STACK_DEPTH = SV_G_STACK_DEPTH + 2u32
    if (SV_G_STACK_DEPTH & 1u32) != 0u32 { cg_emit_arr(&SV_HV_WIT_SUBQ8 as u64, 18u64); SV_G_STACK_DEPTH = SV_G_STACK_DEPTH + 1u32 }
    cg_emit_arr(&SV_STR_MOVABSQ_OPEN as u64, SV_STR_MOVABSQ_OPEN_LEN)
    cg_emit_hex(wid as u64)
    cg_emit_arr(&SV_HV_WIT_MOVRDI as u64, 37u64)
    if ((SV_G_STACK_DEPTH - 2u32) & 1u32) != 0u32 { cg_emit_arr(&SV_HV_WIT_ADDQ8 as u64, 18u64); SV_G_STACK_DEPTH = SV_G_STACK_DEPTH - 1u32 }
    cg_emit_arr(&SV_HV_WIT_POP as u64, 28u64)
    SV_G_STACK_DEPTH = SV_G_STACK_DEPTH - 2u32
    return SV_OK
}
fn hv_emit_function(decl: u32, kind: u32, witness_id: u32) -> u32 {
    SV_G_LOCAL_COUNT = 0u32
    SV_G_STACK_DEPTH = 0u32
    SV_G_LABEL_COUNTER = 0u32
    let mut no: u32 = 0u32
    let mut nl: u32 = 0u32
    let mut pc: u32 = 0u32
    let mut body: u32 = 0u32
    if kind == SV_K_FN_DECL {
        no = iii_ast_fn_name_off(SV_G_AST, decl)
        nl = iii_ast_fn_name_len(SV_G_AST, decl)
        pc = iii_ast_fn_param_count(SV_G_AST, decl)
        body = iii_ast_fn_body(SV_G_AST, decl)
    }
    if kind == SV_K_CYCLE_DECL {
        no = iii_ast_cycle_name_off(SV_G_AST, decl)
        nl = iii_ast_cycle_name_len(SV_G_AST, decl)
        pc = iii_ast_cycle_param_count(SV_G_AST, decl)
        body = iii_ast_cycle_forward_block(SV_G_AST, decl)
    }
    cg_emit_arr(&SV_HV_TEXTNL as u64, SV_HV_TEXTNL_LEN)
    cg_emit_arr(&SV_HV_GLOBAL_LHV as u64, SV_HV_GLOBAL_LHV_LEN)
    emit_name_raw(no, nl)
    cg_emit_arr(&SV_STR_NL as u64, SV_STR_NL_LEN)
    cg_emit_arr(&SV_HV_LHV as u64, SV_HV_LHV_LEN)
    emit_name_raw(no, nl)
    cg_emit_arr(&SV_STR_COLONNL as u64, SV_STR_COLONNL_LEN)
    cg_emit_arr(&SV_HV_ALIGN16NOP as u64, SV_HV_ALIGN16NOP_LEN)
    cg_emit_arr(&SV_HV_PROLOG_FULL as u64, SV_HV_PROLOG_FULL_LEN)
    let mut i: u32 = 0u32
    while i < pc {
        if i < 6u32 {
            let mut p: u32 = 0u32
            if kind == SV_K_FN_DECL { p = iii_ast_fn_param_at(SV_G_AST, decl, i) }
            if kind == SV_K_CYCLE_DECL { p = iii_ast_cycle_param_at(SV_G_AST, decl, i) }
            if iii_ast_node_kind(SV_G_AST, p) == SV_K_PARAM {
                local_add(iii_ast_param_name_off(SV_G_AST, p), iii_ast_param_name_len(SV_G_AST, p))
                cg_emit_arr(&SV_HV_MOVQ_PCT as u64, SV_HV_MOVQ_PCT_LEN)
                if i == 0u32 { cg_emit_arr(&SV_REG_RDI as u64, SV_REG_RDI_LEN) }
                if i == 1u32 { cg_emit_arr(&SV_REG_RSI as u64, SV_REG_RSI_LEN) }
                if i == 2u32 { cg_emit_arr(&SV_REG_RDX as u64, SV_REG_RDX_LEN) }
                if i == 3u32 { cg_emit_arr(&SV_REG_RCX as u64, SV_REG_RCX_LEN) }
                if i == 4u32 { cg_emit_arr(&SV_REG_R8 as u64, SV_REG_R8_LEN) }
                if i == 5u32 { cg_emit_arr(&SV_REG_R9 as u64, SV_REG_R9_LEN) }
                cg_emit_arr(&SV_HV_COMMA_DASH as u64, SV_HV_COMMA_DASH_LEN)
                cg_emit_dec((SV_G_LOCAL_COUNT * 8u32) as u64)
                cg_emit_arr(&SV_HV_DASHRBP as u64, SV_HV_DASHRBP_LEN)
            }
        }
        i = i + 1u32
    }
    if witness_id != 0u32 { hv_emit_witness(witness_id, 0u32) }
    if body != 0u32 {
        let eb: u32 = emit_block(body)
        if eb != SV_OK { return eb }
    }
    if witness_id != 0u32 { hv_emit_witness(witness_id, 1u32) }
    cg_emit_arr(&SV_HV_EPILOG_FULL as u64, SV_HV_EPILOG_FULL_LEN)
    return SV_OK
}

var SV_ASM_DIGEST : [u8; 32]
var SV_HV_TRAILER_HEX : [u8; 2] = [48u8, 48u8]
var SV_HV_TRAILER_NL : [u8; 1] = [10u8]
fn emit_sha_trailer() -> u32 {
    cgsha_snapshot(&SV_CGSHA as u64, &SV_ASM_DIGEST as u64)
    if SV_G_OUT != 0u64 { sv_fwrite_c(SV_G_OUT, &SV_HV_TRAILER_PFX as u64, SV_HV_TRAILER_PFX_LEN) }
    let mut i: u32 = 0u32
    while i < 32u32 {
        let b: u32 = iii_emit_buf_read_u8_c(&SV_ASM_DIGEST as u64, i as u64)
        let hi: u32 = (b >> 4u32) & 0x0fu32
        let lo: u32 = b & 0x0fu32
        let mut hi_c: u32 = 0u32
        if hi < 10u32 { hi_c = 48u32 + hi } else { hi_c = 87u32 + hi }
        let mut lo_c: u32 = 0u32
        if lo < 10u32 { lo_c = 48u32 + lo } else { lo_c = 87u32 + lo }
        iii_emit_write_u8_c(&SV_HV_TRAILER_HEX as u64, hi_c)
        iii_emit_write_u8_c((&SV_HV_TRAILER_HEX as u64) + 1u64, lo_c)
        if SV_G_OUT != 0u64 { sv_fwrite_c(SV_G_OUT, &SV_HV_TRAILER_HEX as u64, 2u64) }
        i = i + 1u32
    }
    if SV_G_OUT != 0u64 { sv_fwrite_c(SV_G_OUT, &SV_HV_TRAILER_NL as u64, 1u64) }
    return SV_OK
}

fn sv_hv_emit_body(cg: u64, out: u64) -> u32 { if cg == 0u64 { return SV_E_NULL_ARG }; if out == 0u64 { SV_G_LAST_ERROR=SV_E_NULL_ARG; return SV_E_NULL_ARG }; if SV_G_SEALED != 0u32 { SV_G_LAST_ERROR=SV_E_SEALED; return SV_E_SEALED }; SV_G_OUT=out; cg_emit_arr(&SV_HV_HDR1 as u64,SV_HV_HDR1_LEN); cg_emit_arr(&SV_HV_HDR2 as u64,SV_HV_HDR2_LEN); cg_emit_arr(&SV_HV_ATTSYNTAX as u64,SV_HV_ATTSYNTAX_LEN); cg_emit_arr(&SV_HV_RODATA as u64,SV_HV_RODATA_LEN); emit_string_pool(); hv_emit_bare_metal_entry(); hv_emit_vmx_svm_dispatch(); hv_emit_svm_vmrun_bracket(); hv_emit_vmx_vmrun_bracket(); let root: u32 = iii_ast_root_module(SV_G_AST); if root == 0u32 { SV_G_LAST_ERROR=SV_E_INTERNAL; return SV_E_INTERNAL }; let dc: u32 = iii_ast_module_decl_count(SV_G_AST,root); let mut i: u32 = 0u32; while i < dc { let d: u32 = iii_ast_module_decl_at(SV_G_AST,root,i); let dk: u32 = iii_ast_node_kind(SV_G_AST,d); if dk == SV_K_FN_DECL { let e: u32 = hv_emit_function(d, SV_K_FN_DECL, 0u32); if e != SV_OK { return e } }; if dk == SV_K_CYCLE_DECL { let wid: u32 = (3250585600u32) | (i + 1u32); let e2: u32 = hv_emit_function(d, SV_K_CYCLE_DECL, wid); if e2 != SV_OK { return e2 } }; i=i+1u32 }; hv_emit_vmexit_table(); hv_emit_slat_tables(); hv_emit_bss_and_data(); emit_sha_trailer(); SV_G_CONST_TIME=0u32; return SV_OK }
