    while k < 64u32 { let w15: u32 = sv_sha_w_get(k-15u32); let w2: u32 = sv_sha_w_get(k-2u32); let s0: u32 = sv_rotr32(w15,7u32)^sv_rotr32(w15,18u32)^(w15>>3u32); let s1: u32 = sv_rotr32(w2,17u32)^sv_rotr32(w2,19u32)^(w2>>10u32); sv_sha_w_set(k,sv_sha_w_get(k-16u32)+s0+sv_sha_w_get(k-7u32)+s1); k = k + 1u32 }
