extern @abi(c-msvc-x64) fn fwrite(ptr: u64, size: u64, nmemb: u64, stream: u64) -> u64 from "msvcrt"
fn sv_fwrite_c(out_handle: u64, addr: u64, n: u64) -> i32 {
    if out_handle == 0u64 { return 1i32 }
    if addr == 0u64 { return 1i32 }
    if n == 0u64 { return 0i32 }
    let w: u64 = fwrite(addr, 1u64, n, out_handle)
    if w != n { return 1i32 }
    return 0i32
}

