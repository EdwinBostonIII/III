fn sv_sha_w_set(i: u32, v: u32) -> u32 { let p: u64 = (&SV_SHA_W as u64) + (i as u64) * 4u64; iii_emit_write_u8_c(p, v & 0xffu32); iii_emit_write_u8_c(p+1u64, (v >> 8u32) & 0xffu32); iii_emit_write_u8_c(p+2u64, (v >> 16u32) & 0xffu32); iii_emit_write_u8_c(p+3u64, (v >> 24u32) & 0xffu32); return 0u32 }
fn sv_sha_w_get(i: u32) -> u32 { let p: u64 = (&SV_SHA_W as u64) + (i as u64) * 4u64; let b0: u32 = iii_emit_buf_read_u8_c(p,0u64); let b1: u32 = iii_emit_buf_read_u8_c(p,1u64); let b2: u32 = iii_emit_buf_read_u8_c(p,2u64); let b3: u32 = iii_emit_buf_read_u8_c(p,3u64); return b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32) }
fn sv_sha_buf_set(off: u32, v: u8) -> u32 { iii_emit_write_u8_c((&SV_SHA_BUF as u64) + (off as u64), v as u32); return 0u32 }
fn sv_sha_compress() -> u32 {
    let bbase: u64 = &SV_SHA_BUF as u64; let mut k: u32 = 0u32
    while k < 16u32 { let off: u64 = (k as u64)*4u64; let b0: u32 = iii_emit_buf_read_u8_c(bbase,off); let b1: u32 = iii_emit_buf_read_u8_c(bbase,off+1u64); let b2: u32 = iii_emit_buf_read_u8_c(bbase,off+2u64); let b3: u32 = iii_emit_buf_read_u8_c(bbase,off+3u64); sv_sha_w_set(k,(b0<<24u32)|(b1<<16u32)|(b2<<8u32)|b3); k = k + 1u32 }
