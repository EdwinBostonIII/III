/* COMPILER/BOOT/ergon_main.iii -- iii-ergon: THE ERGON's tool face.
 *
 *   iii-ergon prove     the organ's own instruments (fault-map injectivity with
 *                       teeth, fold determinism/sensitivity)
 *   iii-ergon census    THE WORK-PROOF: the whole standing fleet re-derives its
 *                       laws in ONE process -- introspection's 5-organ roster,
 *                       kardia, soma, doxa, and the absorbed iscene family --
 *                       then the FORM LEDGER (the ancestral batch layer still on
 *                       the die, measured organ-natively)
 *
 * THE CONSTITUTION: verification is a property of work, not a separate act on
 * foreseen cases.  No seat here compares against a stored expected answer; every
 * seat DERIVES its law at the moment of motion, with teeth (a perturbed input
 * must be refused, a load-bearing setter must move the output).  Requires CWD =
 * the III root (the ledger reads the die).
 *
 * exit: 0 WHOLE | 1 fault (verdict printed, seat+arm located) | 2 env |
 *       3 usage | 9 SELF-REFUSED */
module ergon_main

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

extern @abi(c-msvc-x64) fn erg_selfprove() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_census() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_seat_intro() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_seat_kardia() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_seat_soma() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_seat_doxa() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_seat_iscene() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_seat_iform() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_seat_hexad() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_seat_intent() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_seat_exec() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_deep() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_autarkeia() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_zkaudit() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_zk_scanned() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_zk_claimers() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_zk_violations() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_author() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_evergreen(sel: u64) -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_evg_ran() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_evg_pass() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_observe() -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_evg_retries() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_evg_fail_name_len() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_evg_fail_name_at(i: u64) -> u8 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_evg_fail_law() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_evg_fail_rc() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_conscience(filter: u64) -> u32 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_con_total() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_con_ran_n() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_con_fail_n() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_con_excl_n() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_con_receipt_len() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_con_receipt_at(i: u64) -> u8 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_nomos_live() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_nomos_sealed() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_vitality() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn erg_ledger_runners() -> u64 from "ergon.iii"
extern @abi(c-msvc-x64) fn intro_organ_count() -> u32 from "introspection.iii"

extern @abi(c-msvc-x64) fn soma_audit(dirpath: u64) -> i64 from "soma.iii"
extern @abi(c-msvc-x64) fn soma_matched() -> u64 from "soma.iii"
extern @abi(c-msvc-x64) fn soma_phantom() -> u64 from "soma.iii"
extern @abi(c-msvc-x64) fn soma_dark() -> u64 from "soma.iii"
extern @abi(c-msvc-x64) fn soma_registry() -> u64 from "soma.iii"
extern @abi(c-msvc-x64) fn soma_territory() -> u64 from "soma.iii"

fn ps(s: u64) -> u32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }
    return 1u32
}
fn pu(v: u64) -> u32 { if v >= 10u64 { pu(v / 10u64) }   putchar((48u64 + (v % 10u64)) as i32)   return 1u32 }
fn phex(v: u64) -> u32 {
    let mut k : u64 = 64u64
    while k > 0u64 {
        k = k - 4u64
        let nib : u64 = (v >> k) & 15u64
        if nib < 10u64 { putchar((48u64 + nib) as i32) } else { putchar((87u64 + nib) as i32) }
    }
    return 1u32
}
fn streq(a: u64, b: u64) -> u32 {
    let pa : *u8 = a as *u8
    let pb : *u8 = b as *u8
    let mut i : u64 = 0u64
    while pa[i] != 0u8 { if pa[i] != pb[i] { return 0u32 }   i = i + 1u64 }
    if pb[i] != 0u8 { return 0u32 }
    return 1u32
}
fn usage() -> u64 {
    ps("iii-ergon -- THE ERGON: the machine proven by its WORK\n\n" as u64)
    ps("  iii-ergon prove     the organ's own instruments (fault map, fold), with teeth\n" as u64)
    ps("  iii-ergon census    the whole standing fleet re-derives its laws in one process,\n" as u64)
    ps("                      then the FORM LEDGER (ancestral batch debt, measured)\n" as u64)
    ps("  iii-ergon deep      the die's heavy faculties (nomos/oneiros/reversible/redeem/\n" as u64)
    ps("                      symmetry/physis/wire/presses) -- minutes of wall, on demand\n" as u64)
    ps("  iii-ergon autarkeia the sealed spine + the covenant (testament emit/re-derive,\n" as u64)
    ps("                      tamper battery, generation chain, covenant equation + quorum)\n" as u64)
    ps("  iii-ergon zkaudit   every zk soundness claim matches its query/field knobs (+ teeth)\n" as u64)
    ps("  iii-ergon author    THE NAMED-DEFICIT LAW (admit/verify/fold + 8 adversarial teeth; nobody steers)\n" as u64)
    ps("  iii-ergon evergreen every program self-builds sovereignly (witness=0) + runs; no stubs; Γ invariant\n" as u64)
    ps("  iii-ergon observe   core_H by OBSERVATION (independent SHA-256, native AND interp substrates)\n" as u64)
    ps("  iii-ergon conscience [filter]  PHI-3, THE EXIT GATE: every discovered gate (run_*.sh +\n" as u64)
    ps("                      *_gate.sh + build-spines + the sibling verbs) runs to its OS-true\n" as u64)
    ps("                      exit code; logs at COMPILED/_conscience_*.log; rows folded to ONE\n" as u64)
    ps("                      receipt.  HOURS of wall; the PHI-3 claim is only the unfiltered rite.\n\n" as u64)
    ps("no seat compares against a stored expected answer; every law is derived at the\n" as u64)
    ps("moment of motion.  requires CWD = the III root.\n" as u64)
    ps("exit: 0 WHOLE | 1 fault (located) | 2 env | 3 usage | 9 SELF-REFUSED\n" as u64)
    return 3u64
}
fn seat_line(name: u64, code: u32) -> u32 {
    ps("  " as u64)
    ps(name)
    if code == 0u32 { ps("derived\n" as u64)   return 0u32 }
    ps("FAULT " as u64)
    pu(code as u64)
    putchar(10i32)
    return 1u32
}
fn ergon_enter(argc: i32, argv: u64) -> u64 @export {
    let av : *u64 = argv as *u64
    if argc < 2i32 { return usage() }
    let sp : u64 = erg_selfprove()
    if sp != 0u64 {
        ps("THE ERGON REFUSES ITSELF: instrument arm " as u64)
        pu(sp)
        ps(" failed -- no verb runs over a broken instrument\n" as u64)
        return 9u64
    }
    let cmd : u64 = av[1u64]
    if streq(cmd, "prove" as u64) == 1u32 {
        ps("ERGON PROVEN: the fault map is INJECTIVE (a nonzero census verdict locates\n" as u64)
        ps("exactly one seat+arm; the checker itself has teeth -- a sabotaged map is caught),\n" as u64)
        ps("and the cross-fold instrument is deterministic and input-sensitive.\n" as u64)
        ps("Re-derived THIS invocation, before any verb moved.\n" as u64)
        return 0u64
    }
    if streq(cmd, "observe" as u64) == 1u32 {
        ps("== THE OBSERVE VERB: core_H by OBSERVATION, algorithm- and substrate-independent ==\n" as u64)
        ps("  (an independent SHA-256 sharing zero code with cad, run on native gcc AND the\n" as u64)
        ps("   iiisv->SVIR->svir_interp reference path, recomputes iii-judge's fold and reproduces\n" as u64)
        ps("   the covenant core bit-exact -- twice over; a tampered core refused on both)\n" as u64)
        let o : u32 = erg_observe()
        if o != 0u32 {
            ps("  OBSERVE FAULT " as u64)
            pu(o as u64)
            if o == 1902u32 { ps(" -- indep_sha256 did not reproduce the FIPS vectors on both substrates" as u64) }
            if o == 1904u32 { ps(" -- the observer did not reproduce CA bit-exact on both substrates" as u64) }
            if o == 1905u32 { ps(" -- a tampered CA was ACCEPTED (the adversary teeth did not bite)" as u64) }
            putchar(10i32)
            return 1u64
        }
        ps("  core_H OBSERVED: an algorithm-independent hasher reproduced the covenant core on a\n" as u64)
        ps("  substrate-independent executor, native AND interp; a single-nibble tamper refused on\n" as u64)
        ps("  both.  core_H is no longer trusted by construction alone -- III observed it, twice.\n" as u64)
        return 0u64
    }
    if streq(cmd, "evergreen" as u64) == 1u32 {
        ps("== THE EVERGREEN VERB: every standalone program self-builds SOVEREIGNLY ==\n" as u64)
        ps("  (no work-markers in the load-bearing sources; every `fn main` program builds through\n" as u64)
        ps("   sovas/sovld with witness=0 -- gcc NEVER assembles -- and runs to its real exit code;\n" as u64)
        ps("   then the Γ living invariant: host matrix, retarget fixpoint, spore germination)\n" as u64)
        let mut esel : u64 = 0u64
        if argc >= 3i32 {
            let tok : u64 = av[2u64]
            if streq(tok, "programs" as u64) == 1u32 { esel = 1u64 }
            if streq(tok, "gamma" as u64) == 1u32 { esel = 2u64 }
            if streq(tok, "gamma-host" as u64) == 1u32 { esel = 3u64 }
            if streq(tok, "gamma-retarget" as u64) == 1u32 { esel = 4u64 }
            if streq(tok, "gamma-germinate" as u64) == 1u32 { esel = 5u64 }
        }
        if esel != 0u64 { ps("  SUBSET (iteration aid): the evergreen CLAIM is only the bare full run\n" as u64) }
        let e : u32 = erg_evergreen(esel)
        ps("  programs: ran " as u64)  pu(erg_evg_ran())  ps(", sovereign+green " as u64)  pu(erg_evg_pass())
        ps(", settle-retries " as u64)  pu(erg_evg_retries())  putchar(10i32)
        if e != 0u32 {
            ps("  EVERGREEN FAULT " as u64)
            pu(e as u64)
            if e == 1801u32 { ps(" -- an incomplete-work marker in a load-bearing source (the floor is zero)" as u64) }
            if e == 1802u32 { ps(" -- a program failed to self-build sovereignly (witness>0 or non-99/crash)" as u64) }
            if e == 1803u32 { ps(" -- a Γ living-invariant gate is red (host matrix / retarget / germinate)" as u64) }
            putchar(10i32)
            if erg_evg_fail_name_len() > 0u64 {
                ps("  the NAMED fault: " as u64)
                let mut fi : u64 = 0u64
                while fi < erg_evg_fail_name_len() { putchar(erg_evg_fail_name_at(fi) as i32)   fi = fi + 1u64 }
                ps("  law " as u64)
                pu(erg_evg_fail_law())
                ps(" (1 no-LINKED 2 witness 3 PE-absent 4 driver-crash 5 kat-rc 6 gamma-gate)  rc=" as u64)
                pu(erg_evg_fail_rc())
                ps(" (9902=wall-timeout)" as u64)
                putchar(10i32)
            }
            return 1u64
        }
        if esel != 0u64 {
            ps("  EVERGREEN: PARTIAL -- the subset is green; the claim requires the bare full run.\n" as u64)
            return 0u64
        }
        ps("  EVERGREEN: every standalone program self-builds sovereignly (witness=0) + runs; no\n" as u64)
        ps("  stubs; the Γ living invariant (host matrix, retarget fixpoint, spore germination) holds.\n" as u64)
        return 0u64
    }
    if streq(cmd, "author" as u64) == 1u32 {
        ps("== THE AUTHOR VERB: machine growth under THE NAMED-DEFICIT LAW ==\n" as u64)
        ps("  (III adjudicates its own growth, never bash: a seal is admitted only if it cites a\n" as u64)
        ps("   NAMED deficit AND strictly shrinks it under a continuous ratchet, MACHINE, 2 routes;\n" as u64)
        ps("   every breach its DISTINCT refusal; the pilot head is a pure fn of the budget)\n" as u64)
        let a : u32 = erg_author()
        if a != 0u32 {
            ps("  AUTHOR FAULT " as u64)
            pu(a as u64)
            if a == 1703u32 { ps(" -- a law breach was NOT named-rejected with its distinct code" as u64) }
            if a == 1704u32 { ps(" -- NOBODY-STEERS broke: the pilot head is not a pure fn of the budget" as u64) }
            putchar(10i32)
            return 1u64
        }
        ps("  THE AUTHOR STANDS: 3 autonomous MACHINE cycles admitted (each strictly shrinking\n" as u64)
        ps("  unreached), the exit gate verified, the history folded; all eight law breaches\n" as u64)
        ps("  named-rejected with distinct codes (3/4/5/6/7/7/8); nobody steers (one head twice).\n" as u64)
        return 0u64
    }
    if streq(cmd, "zkaudit" as u64) == 1u32 {
        ps("== THE ZK-AUDIT VERB: every soundness claim must match its knobs ==\n" as u64)
        ps("  (each ~2^-86 production claim demands a 128-FS-query basis + its field marker;\n" as u64)
        ps("   an xref claim must NAME another zk module; an unlisted module may claim nothing\n" as u64)
        ps("   -- with FALSIFIER TEETH on perturbed copies; ex run_zk_audit, organ-native)\n" as u64)
        let z : u32 = erg_zkaudit()
        ps("  zk modules scanned: " as u64)  pu(erg_zk_scanned())
        ps(" ; soundness claimers: " as u64)  pu(erg_zk_claimers())
        ps(" ; violations: " as u64)  pu(erg_zk_violations())  putchar(10i32)
        if z != 0u32 {
            ps("  ZK-AUDIT FAULT " as u64)
            pu(z as u64)
            if z == 1603u32 { ps(" -- a live gadget's claim does not match its knobs" as u64) }
            if z == 1604u32 { ps(" -- TEETH FAILED: a downscaled production NBATCH did NOT redden" as u64) }
            if z == 1605u32 { ps(" -- TEETH FAILED: a claim in an unlisted module did NOT redden" as u64) }
            putchar(10i32)
            return 1u64
        }
        ps("  ZK AUDIT PASS: every claimed bit-count matches its NQ/field knobs, and the\n" as u64)
        ps("  falsifier teeth BITE (a downscaled knob and an unclassified claim both redden).\n" as u64)
        return 0u64
    }
    if streq(cmd, "autarkeia" as u64) == 1u32 {
        ps("== THE AUTARKEIA VERB: the sealed spine + the covenant, re-derived live ==\n" as u64)
        ps("  (emit a gen-0 testament over the committed tree, re-derive it, the full tamper\n" as u64)
        ps("   battery, the generation chain, THE COVENANT EQUATION + ML-DSA 3-of-3 quorum;\n" as u64)
        ps("   ex run_testament + run_covenant -- three SLH-DSA signings, minutes of wall)\n" as u64)
        let a : u32 = erg_autarkeia()
        if a != 0u32 {
            ps("  AUTARKEIA FAULT " as u64)
            pu(a as u64)
            putchar(10i32)
            return 1u64
        }
        ps("  the spine holds: testament emitted + re-derived against the tree; every tamper\n" as u64)
        ps("  class its DISTINCT refusal; the chain links; THE COVENANT EQUATION -- core(gen1)\n" as u64)
        ps("  == core(gen0) despite an advanced generation -- co-signed by a live ML-DSA 3-of-3\n" as u64)
        ps("  quorum, a tampered core signed by NONE.  No stored answer was consulted.\n" as u64)
        return 0u64
    }
    if streq(cmd, "deep" as u64) == 1u32 {
        ps("== THE DEEP DERIVATION: the die's heavy faculties, organ-owned ==\n" as u64)
        ps("  (nomos, oneiros, reversible, redeem, symmetry, physis/moment/taxis,\n" as u64)
        ps("   both wire faculties, both presses vs the SEALED constitution, the\n" as u64)
        ps("   author->prover chain -- minutes of wall; ex run_standing_tools deep half)\n" as u64)
        let d : u32 = erg_deep()
        if d != 0u32 {
            ps("  DEEP FAULT " as u64)
            pu(d as u64)
            putchar(10i32)
            return 1u64
        }
        ps("  presses reproduce the SEALED ids (autophasis, glossa) -- judged in-process.\n" as u64)
        if erg_nomos_live() == erg_nomos_sealed() {
            ps("  nomos: live legislation reproduces the SEALED rule set.\n" as u64)
        } else {
            ps("  nomos: live id " as u64)
            pu(erg_nomos_live())
            ps(" vs sealed " as u64)
            pu(erg_nomos_sealed())
            ps(" -- METER-CONTEXT drift (band physics, NAMED; sealed truth lives in heart cell 2748)\n" as u64)
        }
        ps("  DEEP WHOLE: every heavy faculty derived on today's die.\n" as u64)
        return 0u64
    }
    if streq(cmd, "conscience" as u64) == 1u32 {
        ps("== THE CONSCIENCE: PHI-3, the exit gate -- no decorative claims ==\n" as u64)
        ps("  (the gate set DISCOVERED from the living tree: run_*.sh + *_gate.sh across the four\n" as u64)
        ps("   gate dirs + the two build-spines + the ERGON's own sibling verbs; each spawned\n" as u64)
        ps("   SEQUENTIALLY to its OS-true exit code under a 2h cap; logs at COMPILED/_conscience_*.log;\n" as u64)
        ps("   the rows folded by iii-judge into ONE receipt root)\n" as u64)
        let mut filt : u64 = 0u64
        if argc >= 3i32 { filt = av[2u64] }
        if filt != 0u64 { ps("  FILTER (substring): a subset run -- the PHI-3 claim is ONLY the unfiltered rite\n" as u64) }
        let c : u32 = erg_conscience(filt)
        ps("  ------------------------------------------------------------\n" as u64)
        ps("  gates: enumerated " as u64)
        pu(erg_con_total())
        ps(", ran " as u64)
        pu(erg_con_ran_n())
        ps(", red " as u64)
        pu(erg_con_fail_n())
        ps(", excluded " as u64)
        pu(erg_con_excl_n())
        putchar(10i32)
        if erg_con_receipt_len() == 64u64 {
            ps("  receipt (iii-judge fold of the rite rows): " as u64)
            let mut ri : u64 = 0u64
            while ri < 64u64 { putchar(erg_con_receipt_at(ri) as i32)   ri = ri + 1u64 }
            putchar(10i32)
        }
        if c != 0u32 {
            ps("  CONSCIENCE FAULT " as u64)
            pu(c as u64)
            if c == 2001u32 { ps(" -- env: a discovery listing could not run" as u64) }
            if c == 2002u32 { ps(" -- ENUMERATION VIOLATION: a discovery class is empty (a sweep that cannot fail proves nothing)" as u64) }
            if c == 2003u32 { ps(" -- a banner's gate is red; the claim above it is DECORATIVE until fixed" as u64) }
            if c == 2004u32 { ps(" -- the receipt fold failed" as u64) }
            putchar(10i32)
            if c == 2001u32 { return 2u64 }
            return 1u64
        }
        if filt != 0u64 {
            ps("  CONSCIENCE: PARTIAL -- the filtered subset is green; the PHI-3 claim requires the unfiltered rite.\n" as u64)
            return 0u64
        }
        ps("  CONSCIENCE: PASS -- every enumerated gate is runnable and green.  No decorative claims.\n" as u64)
        return 0u64
    }
    if streq(cmd, "census" as u64) == 1u32 {
        ps("== THE WORK-PROOF CENSUS: the fleet works, therefore it is ==\n" as u64)
        let s0 : u32 = erg_seat_intro()
        ps("  introspection roster (" as u64)
        pu(intro_organ_count() as u64)
        ps(" organs, independent re-derivation + cross-fold): " as u64)
        if s0 == 0u32 { ps("derived, vitality " as u64)   phex(erg_vitality())   putchar(10i32) } else { ps("FAULT " as u64)   pu(s0 as u64)   putchar(10i32) }
        let s1 : u32 = seat_line("kardia (heart arms + garbage teeth)                  : " as u64, erg_seat_kardia())
        let s2 : u32 = seat_line("soma (body arms: address/partition/ownership/ledger) : " as u64, erg_seat_soma())
        let s3 : u32 = seat_line("doxa (belief arms, 16, each with negative control)   : " as u64, erg_seat_doxa())
        let s4 : u32 = seat_line("iscene (ABSORBED family -- laws live, pin removed)   : " as u64, erg_seat_iscene())
        let s5 : u32 = seat_line("iform (ABSORBED family -- first C1 retirement)       : " as u64, erg_seat_iform())
        let s6 : u32 = seat_line("hexad (ABSORBED -- whole 729-space, ex run-hexad-cli): " as u64, erg_seat_hexad())
        let s7 : u32 = seat_line("intent (ABSORBED -- mask-derived, ex run-intent-cli) : " as u64, erg_seat_intent())
        let s8 : u32 = seat_line("exec (tool faces via the process organ, ex standing) : " as u64, erg_seat_exec())
        /* the ledger: the ancestral form still on the die, measured */
        ps("  -- THE FORM LEDGER (ancestral batch layer, burn-down measured) --\n" as u64)
        let r : i64 = soma_audit("STDLIB/corpus" as u64)
        if r < 0i64 {
            ps("  ledger unreadable (run from the III root)\n" as u64)
            return 2u64
        }
        ps("     batch runners on the die (STDLIB/scripts run_*.sh) : " as u64)
        pu(erg_ledger_runners())
        putchar(10i32)
        ps("     registry claims (C1 expectations + C2 adopted)     : " as u64)
        pu(soma_registry())
        putchar(10i32)
        ps("     gate files in the corpus territory                 : " as u64)
        pu(soma_territory())
        ps("  (matched " as u64)
        pu(soma_matched())
        ps(", phantom " as u64)
        pu(soma_phantom())
        ps(", dark " as u64)
        pu(soma_dark())
        ps(")\n" as u64)
        ps("     absorbed into living seats so far                  : 4 families (iscene, iform, hexad, intent)\n" as u64)
        ps("     LAW: debt burns down only by ABSORPTION (a family's laws re-homed as a\n" as u64)
        ps("     seat, then its ancestral form retired) -- never by deletion on assumption.\n" as u64)
        let mut verdict : u64 = 0u64
        if s0 != 0u32 { verdict = s0 as u64 }
        if verdict == 0u64 { if s1 != 0u32 { verdict = 1u64 } }
        if verdict == 0u64 { if s2 != 0u32 { verdict = 1u64 } }
        if verdict == 0u64 { if s3 != 0u32 { verdict = 1u64 } }
        if verdict == 0u64 { if s4 != 0u32 { verdict = 1u64 } }
        if verdict == 0u64 { if s5 != 0u32 { verdict = 1u64 } }
        if verdict == 0u64 { if s6 != 0u32 { verdict = 1u64 } }
        if verdict == 0u64 { if s7 != 0u32 { verdict = 1u64 } }
        if verdict == 0u64 { if s8 != 0u32 { verdict = 1u64 } }
        if verdict != 0u64 {
            ps("  VERDICT: FAULT -- the fleet did not fully derive itself this invocation.\n" as u64)
            return 1u64
        }
        ps("  VERDICT: WHOLE -- every law above was derived THIS invocation.  No stored\n" as u64)
        ps("  expectation was consulted anywhere in this census.\n" as u64)
        return 0u64
    }
    return usage()
}
