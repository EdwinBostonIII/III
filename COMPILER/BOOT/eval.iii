const EVT_I64: u64 = 67586u64           /* 2 | 8<<8 | 1<<16 */

/* ── world layout ─────────────────────────────────────────────────────── */
const EVW_CAP: u64 = 67108864u64        /* 64 MiB flat world */
const EVG_BASE: u64 = 0u64              /* globals + string payloads (bump) */
const EVG_CAP: u64 = 16777216u64
const EVD_BASE: u64 = 16777216u64       /* locals data stack (bump/restore) */
