var EV_W : u64
var EV_SRC : u64
var EV_SRCLEN : u64
var EV_GTOP : u64
var EV_DTOP : u64
var EV_OSP : u64
var EV_LSP : u64
var EV_LBASE : u64
var EV_GCOUNT : u64
var EV_FCOUNT : u64
var EV_TCOUNT : u64
var EV_SCSP : u64
var EV_DEPTH : u64
var EV_RETV : u64
var EV_RETT : u64
var EV_RESULT : u64
