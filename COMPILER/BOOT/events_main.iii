/* COMPILER/BOOT/events_main.iii -- iii-events: THE EVENT-PRIMARY EXECUTOR AS A STANDING TOOL.
 *
 *     iii-events <file.iii>              execute the file event-primarily; program output prints AT
 *                                        FOLD TIME (read out of the retirement log, not the live
 *                                        machine), then one verdict line:
 *                                          IIIEVENTS rc=<dec> evn=<dec> wit=<16hex> term=<0|1> lasso=<dec>
 *     iii-events --quiet <file.iii>      no verdict line: pure program behavior (exit = program rc)
 *     iii-events --tamper <file.iii>     flip one bit of one recorded event after the run, then fold:
 *                                        MUST exit 193 (the log refuses corruption -- the standing tooth)
 *     iii-events --cert <file.iii>       print a CRYPTOGRAPHIC EXECUTION CERTIFICATE: the sha256 over the
 *                                        whole retirement log (via omnia::exec_cert -- real streaming
 *                                        sha256, not the FNV witness).  A portable, reproducible receipt
 *                                        of exactly what happened: same program => same certificate
 *                                        (determinism), any different run => different certificate.  The
 *                                        log is history made a carryable object -- "it from bit" cashed.
 *
 * This makes route V (STDLIB/sovir/svir_event.iii) INDEPENDENTLY USEFUL on ARBITRARY user programs:
 * the whole pipeline runs IN THIS PROCESS -- read source, lex, parse, emit SVIR (the compiler's own
 * front end + its own SVIR backend, linked in, not shelled out), execute as an append-only retirement
 * log, then read output/result back out of the log by the validating fold.  Not a demo; no hardcoded
 * examples: the input is the user's own source file.  The same leaf-tool discipline as iii-prove
 * (build_iii_prove.sh): pinned in-tree iiis-2 + committed archive; bootstrap chain untouched.
 *
 * EXIT: the program's own rc (low byte -- exactly what the native binary would exit with), with the
 * event machine's named refusals riding the same channel: 190 log-cap, 192 cap+lasso, 193 fold
 * divergence / witness mismatch, 196 tamper-arm-too-few-events, 198 unresolved import, 199 OOB
 * indirect.  Tool errors: 3 usage | 4 file/read | 5 parse | 6 SVIR refused.  A program whose own rc
 * collides with these values is disambiguated by the verdict line (rc= is the fold's value).
 */
module events_main

extern @abi(c-msvc-x64) fn iii_lex_fopen_c(path: u64, mode: u32) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_fread_c(ptr: u64, n: u64, file: u64) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_fclose_c(file: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_create(bytes: u64, len: u64, src: u64) -> u64 from "lex.iii"
extern @abi(c-msvc-x64) fn iii_ast_create(bytes: u64, len: u64, src: u64) -> u64 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_parse_create(lex: u64, ast: u64) -> u64 from "parse.iii"
extern @abi(c-msvc-x64) fn iii_parse_module(p: u64) -> u32 from "parse.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_emit_mem(ast: u64) -> u32 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_mo() -> u64 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_mlen() -> u64 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_nfunc() -> u32 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_unsup() -> u32 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn sve_reset() -> i32 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_load(mp: u64, ml: u64) -> i32 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_run() -> i32 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_replay() -> i32 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_result() -> u64 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_count() -> u64 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_wit() -> u64 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_replay_wit() -> u64 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_oob() -> u32 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_unres() -> u32 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_terminated() -> u32 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_lasso_len() -> u64 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_ev_get(i: u64, which: u32) -> u64 from "svir_event.iii"
extern @abi(c-msvc-x64) fn sve_ev_poke(i: u64, which: u32, v: u64) -> i32 from "svir_event.iii"
/* the CRYPTOGRAPHIC certificate: compose omnia::exec_cert (streaming sha256, O(1)/event) -- the log
 * folded into a reproducible, tamper-evident 32-byte receipt.  No crypto authored here; the real
 * sha256 organ is reused (NIH-strict, connect-don't-island). */
extern @abi(c-msvc-x64) fn xc_begin() -> i32 from "exec_cert.iii"
extern @abi(c-msvc-x64) fn xc_event_u32(v: u32) -> i32 from "exec_cert.iii"
extern @abi(c-msvc-x64) fn xc_seal(out32: u64) -> i32 from "exec_cert.iii"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

const CAP : u64 = 1048576u64
const MAXSVIR : u64 = 262145u64
const RD_FAIL : u64 = 18446744073709551615u64

var SRC : [u8; 1048576]
var CON : [u8; 262145]
var DIG : [u8; 24]
var CERT : [u8; 32]

fn ps(s: u64) -> u32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { putchar(p[i] as i32)  i = i + 1u64 }
    return 1u32
}
fn pd(v: u64) -> u32 {
    if v == 0u64 { putchar(48i32)  return 1u32 }
    let mut n : u64 = v
    let mut k : u64 = 0u64
    while n > 0u64 { DIG[k] = ((n % 10u64) + 48u64) as u8  n = n / 10u64  k = k + 1u64 }
    while k > 0u64 { k = k - 1u64  putchar(DIG[k] as i32) }
    return 1u32
}
fn phex16(v: u64) -> u32 {
    let mut i : u64 = 16u64
    while i > 0u64 {
        i = i - 1u64
        let nib : u32 = ((v >> (i * 4u64)) & 15u64) as u32
        if nib < 10u32 { putchar((48u32 + nib) as i32) } else { putchar((87u32 + nib) as i32) }
    }
    return 1u32
}
fn streq(a: u64, b: u64) -> u32 {
    let pa : *u8 = a as *u8
    let pb : *u8 = b as *u8
    let mut i : u64 = 0u64
    while pa[i] != 0u8 {
        if pa[i] != pb[i] { return 0u32 }
        i = i + 1u64
    }
    if pb[i] != 0u8 { return 0u32 }
    return 1u32
}

fn read_file(path: u64, buf: u64) -> u64 {
    let f : u64 = iii_lex_fopen_c(path, 0u32)
    if f == 0u64 { return RD_FAIL }
    let mut total : u64 = 0u64
    let mut go : u32 = 1u32
    while go == 1u32 {
        if total + 65536u64 > CAP { go = 0u32 }
        else {
            let n : u64 = iii_lex_fread_c(buf + total, 65536u64, f)
            total = total + n
            if n < 65536u64 { go = 0u32 }
        }
    }
    iii_lex_fclose_c(f)
    return total
}

/* fold the whole retirement log into a sha256 execution certificate (exec_cert), print it as 64 hex. */
fn emit_cert(cnt: u64) {
    xc_begin()
    let mut i : u64 = 0u64
    while i < cnt {
        let mut w : u32 = 0u32
        while w < 4u32 {
            let f : u64 = sve_ev_get(i, w)
            xc_event_u32((f & 0xFFFFFFFFu64) as u32)
            xc_event_u32(((f >> 32u64) & 0xFFFFFFFFu64) as u32)
            w = w + 1u32
        }
        i = i + 1u64
    }
    xc_seal(&CERT as u64)
    ps("IIIEVENTS-CERT sha256=" as u64)
    let mut b : u64 = 0u64
    while b < 32u64 {
        let byte : u32 = CERT[b] as u32
        let hi : u32 = (byte >> 4u32) & 15u32
        let lo : u32 = byte & 15u32
        if hi < 10u32 { putchar((48u32 + hi) as i32) } else { putchar((87u32 + hi) as i32) }
        if lo < 10u32 { putchar((48u32 + lo) as i32) } else { putchar((87u32 + lo) as i32) }
        b = b + 1u64
    }
    ps(" events=" as u64)  pd(cnt)  putchar(10i32)
}

fn verdict_line(rc: u64) {
    ps("IIIEVENTS rc=" as u64)  pd(rc)
    ps(" evn=" as u64)  pd(sve_count())
    ps(" wit=" as u64)  phex16(sve_wit())
    ps(" term=" as u64)  pd(sve_terminated() as u64)
    ps(" lasso=" as u64)  pd(sve_lasso_len())
    putchar(10i32)
}

fn main(argc: i32, argv: u64) -> u64 {
    let av : *u64 = argv as *u64
    let mut quiet : u32 = 0u32
    let mut tamper : u32 = 0u32
    let mut cert : u32 = 0u32
    let mut path : u64 = 0u64
    let mut ai : u64 = 1u64
    while ai < (argc as u64) {
        if streq(av[ai], "--quiet" as u64) == 1u32 { quiet = 1u32 }
        else { if streq(av[ai], "--tamper" as u64) == 1u32 { tamper = 1u32 }
        else { if streq(av[ai], "--cert" as u64) == 1u32 { cert = 1u32 }
        else { path = av[ai] } } }
        ai = ai + 1u64
    }
    if path == 0u64 {
        ps("iii-events -- execute a .iii program event-primarily (route V: state = fold over history)\n\n" as u64)
        ps("  iii-events <file.iii>            run; output prints AT FOLD TIME from the retirement log,\n" as u64)
        ps("                                   then: IIIEVENTS rc= evn= wit= term= lasso=\n" as u64)
        ps("  iii-events --quiet <file.iii>    no verdict line (exit = the program's own rc)\n" as u64)
        ps("  iii-events --tamper <file.iii>   corrupt one recorded event, fold: MUST exit 193\n" as u64)
        ps("  iii-events --cert <file.iii>     print a sha256 execution certificate (a portable receipt)\n\n" as u64)
        ps("refusals: 190 log-cap | 192 cap+lasso | 193 fold/witness refuses | 198 import | 199 oob-indirect\n" as u64)
        ps("tool:     3 usage | 4 file | 5 parse | 6 SVIR refused\n" as u64)
        return 3u64
    }

    let n : u64 = read_file(path, &SRC as u64)
    if n == RD_FAIL { ps("iii-events: cannot read: " as u64)  ps(path)  putchar(10i32)  return 4u64 }
    if n == 0u64 { ps("iii-events: empty file: " as u64)  ps(path)  putchar(10i32)  return 4u64 }
    let lx : u64 = iii_lex_create(&SRC as u64, n, path)
    if lx == 0u64 { ps("iii-events: lex error\n" as u64)  return 5u64 }
    let ast : u64 = iii_ast_create(&SRC as u64, n, path)
    if ast == 0u64 { ps("iii-events: ast error\n" as u64)  return 5u64 }
    let p : u64 = iii_parse_create(lx, ast)
    if p == 0u64 { ps("iii-events: parse-create error\n" as u64)  return 5u64 }
    if iii_parse_module(p) == 0u32 { ps("iii-events: parse error in: " as u64)  ps(path)  putchar(10i32)  return 5u64 }
    if iii_cg_svir_emit_mem(ast) != 0u32 {
        ps("iii-events: SVIR emission refused (unsupported construct class " as u64)
        pd(iii_cg_svir_unsup() as u64)  ps(")\n" as u64)
        return 6u64
    }
    let ml : u64 = iii_cg_svir_mlen()
    if ml + 1u64 > MAXSVIR { ps("iii-events: module too large\n" as u64)  return 6u64 }
    let d : *u8 = &CON as u64 as *u8
    let s : *u8 = (iii_cg_svir_mo()) as *u8
    d[0u64] = (iii_cg_svir_nfunc() & 255u32) as u8
    let mut i : u64 = 0u64
    while i < ml { d[1u64 + i] = s[i]  i = i + 1u64 }

    sve_reset()
    if sve_load(&CON as u64, ml + 1u64) != 0i32 { ps("iii-events: container refused\n" as u64)  return 6u64 }
    let rr : i32 = sve_run()
    if rr != 0i32 {
        if quiet == 0u32 { verdict_line(0u64) }
        return rr as u64
    }
    if tamper == 1u32 {
        let cnt : u64 = sve_count()
        if cnt < 2u64 { return 196u64 }
        let mid : u64 = cnt / 2u64
        let old : u64 = sve_ev_get(mid, 3u32)
        sve_ev_poke(mid, 3u32, old ^ 1u64)
    }
    let rp : i32 = sve_replay()
    if rp != 0i32 {
        if quiet == 0u32 { verdict_line(sve_result() & 255u64) }
        return rp as u64
    }
    if sve_wit() != sve_replay_wit() {
        if quiet == 0u32 { verdict_line(sve_result() & 255u64) }
        return 193u64
    }
    let rc : u64 = sve_result() & 255u64
    if cert == 1u32 { emit_cert(sve_count()) }
    if quiet == 0u32 { verdict_line(rc) }
    if sve_oob() > 0u32 { return 199u64 }
    if sve_unres() > 0u32 { return 198u64 }
    return rc
}
