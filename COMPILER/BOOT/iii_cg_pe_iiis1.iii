module iii_cg_pe_iiis1

/* iii_cg_pe_iiis1.iii -- native .iii partial-evaluator (Phase C.6 PE).
 *
 * Faithful port of iii_cg_pe_iiis1.c. Exposes Phase C.6 PE classification
 * to cg_r3.iii: detects `resolve(set, intent_form(LIT), ctx)` callsites
 * and returns the dispatch fn-name string so cg_r3 can emit a direct
 * `leaq <dispatch_fn>(%rip)` load (bit-identical to what cg_r3.c produced).
 *
 * The composition table (PE_PRIM / PE_LIT / PE_NOFF / PE_NAMES) is
 * AUTO-GENERATED from iii_compositions.def by gen_compositions.sh between
 * the sentinels below -- single source of truth, no hand drift.
 *
 * Hexad: passage_essence . Ring: R3 . K: 1.00 . NIH: ast.iii accessors only.
 */

/* ---- AST accessors (resolve by name from ast.iii.o) ---- */
extern @abi(c-msvc-x64) fn iii_ast_node_kind(ast: u64, node: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_arg_value(ast: u64, node: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_call_callee(ast: u64, node: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_call_arg_count(ast: u64, node: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_call_arg_at(ast: u64, node: u32, i: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_ident_name_offset(ast: u64, node: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_ident_name_length(ast: u64, node: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_expr_int_u64(ast: u64, node: u32) -> u64 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_let_value(ast: u64, node: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_fn_body(ast: u64, node: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_block_stmt_count(ast: u64, node: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_block_stmt_at(ast: u64, node: u32, i: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_return_value(ast: u64, node: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_node_binder_id(ast: u64, node: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_source_buf(ast: u64) -> u64 from "ast.iii"

/* ---- AST kind constants (module-local copies; mirror ast.iii) ---- */
const PE_K_FN_DECL : u32 = 4u32
const PE_K_STMT_LET : u32 = 20u32
const PE_K_STMT_RETURN : u32 = 26u32
const PE_K_FORWARD_BLOCK : u32 = 29u32
const PE_K_EXPR_INT : u32 = 37u32
const PE_K_EXPR_IDENT : u32 = 45u32
const PE_K_EXPR_CALL : u32 = 46u32
const PE_K_EXPR_BLOCK : u32 = 51u32
const PE_K_ARG : u32 = 57u32

/* ---- primitive-constructor names (length-explicit; no NUL needed) ---- */
var PE_NM_FORM : [u8; 11] = [105u8, 110u8, 116u8, 101u8, 110u8, 116u8, 95u8, 102u8, 111u8, 114u8, 109u8]
var PE_NM_CONVEY : [u8; 13] = [105u8, 110u8, 116u8, 101u8, 110u8, 116u8, 95u8, 99u8, 111u8, 110u8, 118u8, 101u8, 121u8]
var PE_NM_ACT : [u8; 10] = [105u8, 110u8, 116u8, 101u8, 110u8, 116u8, 95u8, 97u8, 99u8, 116u8]

/* ---- low-level byte deref ---- */
fn pe_rd_u8(base: u64, off: u64) -> u32 {
    let p : *u8 = (base + off) as *u8
    return p[0] as u32
}

/* compare `len` bytes at src_base+off to the literal at lit_addr (lengths
 * must be equal). Returns 1 on exact match, else 0. Mirrors the C strcmp
 * against a NUL-bounded copy of the callee name. */
fn pe_src_eq(src_base: u64, off: u32, len: u32, lit_addr: u64, lit_len: u32) -> u32 {
    if len != lit_len { return 0u32 }
    let mut i : u32 = 0u32
    while i < len {
        if pe_rd_u8(src_base, (off as u64) + (i as u64)) != pe_rd_u8(lit_addr, i as u64) { return 0u32 }
        i = i + 1u32
    }
    return 1u32
}

/* NUL-bounded equality of two dispatch-name pointers (strcmp == 0).
 * Bounded at 64 (longest table name is 34). */
fn pe_name_eq(a: u64, b: u64) -> u32 {
    let mut i : u64 = 0u64
    while i < 64u64 {
        let ca : u32 = pe_rd_u8(a, i)
        let cb : u32 = pe_rd_u8(b, i)
        if ca != cb { return 0u32 }
        if ca == 0u32 { return 1u32 }
        i = i + 1u64
    }
    return 1u32
}

/* Table lookup: find the entry whose primitive_id == `primitive` AND
 * literal_form_id == `literal`; return a pointer to its NUL-terminated
 * dispatch name in PE_NAMES, or 0 on miss. (@export for the de-risk KAT.) */
fn iii_cg_pe_lookup(primitive: u32, literal: u64) -> u64 @export {
    let prim : u32 = primitive
    let lit : u64 = literal
    let mut i : u64 = 0u64
    while i < PE_N {
        if (PE_PRIM[i] as u32) == prim {
            if PE_LIT[i] == lit { return (&PE_NAMES as u64) + (PE_NOFF[i] as u64) }
        }
        i = i + 1u64
    }
    return 0u64
}

/* iiis-2 cross-function PE: the dispatch name common to ALL return
 * statements of fn_decl_node's body, or 0. Bounded by depth. Mirrors
 * fn_returns_static_intent in the C. */
fn pe_fn_returns_static_intent(ast: u64, fn_decl_node: u32, depth: u32) -> u64 {
    if ast == 0u64 { return 0u64 }
    if fn_decl_node == 0u32 { return 0u64 }
    if depth == 0u32 { return 0u64 }
    if iii_ast_node_kind(ast, fn_decl_node) != PE_K_FN_DECL { return 0u64 }
    let body_id : u32 = iii_ast_fn_body(ast, fn_decl_node)
    if body_id == 0u32 { return 0u64 }
    let bk : u32 = iii_ast_node_kind(ast, body_id)
    if bk != PE_K_EXPR_BLOCK {
        if bk != PE_K_FORWARD_BLOCK { return 0u64 }
    }
    let cnt : u32 = iii_ast_block_stmt_count(ast, body_id)
    let mut common_fn : u64 = 0u64
    let mut returns_seen : u32 = 0u32
    let mut i : u32 = 0u32
    while i < cnt {
        let stmt_id : u32 = iii_ast_block_stmt_at(ast, body_id, i)
        if stmt_id != 0u32 {
            if iii_ast_node_kind(ast, stmt_id) == PE_K_STMT_RETURN {
                let ret_val : u32 = iii_ast_return_value(ast, stmt_id)
                if ret_val == 0u32 { return 0u64 }
                let fn_name : u64 = pe_classify_bounded(ast, ret_val, depth - 1u32)
                if fn_name == 0u64 { return 0u64 }
                if common_fn == 0u64 {
                    common_fn = fn_name
                } else {
                    if pe_name_eq(common_fn, fn_name) == 0u32 { return 0u64 }
                }
                returns_seen = returns_seen + 1u32
            }
        }
        i = i + 1u32
    }
    if returns_seen == 0u32 { return 0u64 }
    return common_fn
}

/* Core classifier (depth-bounded, mutually recursive with the above). */
fn pe_classify_bounded(ast: u64, intent_arg_node: u32, depth: u32) -> u64 {
    if ast == 0u64 { return 0u64 }
    if intent_arg_node == 0u32 { return 0u64 }
    if depth == 0u32 { return 0u64 }
    let mut node : u32 = intent_arg_node

    /* EXPR_ARG unwrap. */
    if iii_ast_node_kind(ast, node) == PE_K_ARG {
        node = iii_ast_arg_value(ast, node)
        if node == 0u32 { return 0u64 }
    }

    /* Find the constructor call: inline EXPR_CALL or via let-binder. */
    let kn : u32 = iii_ast_node_kind(ast, node)
    let mut call_node : u32 = 0u32
    if kn == PE_K_EXPR_CALL { call_node = node }
    if kn == PE_K_EXPR_IDENT {
        let bid : u32 = iii_ast_node_binder_id(ast, node)
        if bid != 0u32 {
            if iii_ast_node_kind(ast, bid) == PE_K_STMT_LET {
                let init_id : u32 = iii_ast_let_value(ast, bid)
                if init_id != 0u32 {
                    if iii_ast_node_kind(ast, init_id) == PE_K_EXPR_CALL { call_node = init_id }
                }
            }
        }
    }
    if call_node == 0u32 { return 0u64 }

    /* Callee must be an IDENT. */
    let callee : u32 = iii_ast_call_callee(ast, call_node)
    if callee == 0u32 { return 0u64 }
    if iii_ast_node_kind(ast, callee) != PE_K_EXPR_IDENT { return 0u64 }
    let src : u64 = iii_ast_source_buf(ast)
    if src == 0u64 { return 0u64 }
    let co : u32 = iii_ast_ident_name_offset(ast, callee)
    let cl : u32 = iii_ast_ident_name_length(ast, callee)

    /* Case A: primitive constructor -> look up by literal arg. Only
     * intent_form/intent_convey/intent_act (all < 24 chars) qualify. */
    let mut ep : u32 = 0u32
    if cl < 24u32 {
        if pe_src_eq(src, co, cl, &PE_NM_FORM as u64, 11u32) == 1u32 { ep = 1u32 }
        if pe_src_eq(src, co, cl, &PE_NM_CONVEY as u64, 13u32) == 1u32 { ep = 3u32 }
        if pe_src_eq(src, co, cl, &PE_NM_ACT as u64, 10u32) == 1u32 { ep = 5u32 }
    }
    if ep != 0u32 {
        let argc : u32 = iii_ast_call_arg_count(ast, call_node)
        if argc == 0u32 { return 0u64 }
        let a0 : u32 = iii_ast_call_arg_at(ast, call_node, 0u32)
        if a0 == 0u32 { return 0u64 }
        if iii_ast_node_kind(ast, a0) != PE_K_ARG { return 0u64 }
        let vexpr : u32 = iii_ast_arg_value(ast, a0)
        if vexpr == 0u32 { return 0u64 }
        if iii_ast_node_kind(ast, vexpr) != PE_K_EXPR_INT { return 0u64 }
        let literal : u64 = iii_ast_expr_int_u64(ast, vexpr)
        return iii_cg_pe_lookup(ep, literal)
    }

    /* Case B: callee is a user FN_DECL -> recurse on its returns. */
    let callee_decl : u32 = iii_ast_node_binder_id(ast, callee)
    if callee_decl != 0u32 {
        if iii_ast_node_kind(ast, callee_decl) == PE_K_FN_DECL {
            return pe_fn_returns_static_intent(ast, callee_decl, depth - 1u32)
        }
    }
    return 0u64
}

/* Classify the intent argument of a resolve() call. Returns the
 * dispatch-name pointer on hit, 0 on miss. Recursion depth bounded at 8. */
fn iii_cg_pe_classify_intent(ast: u64, intent_arg_node: u32) -> u64 @export {
    return pe_classify_bounded(ast, intent_arg_node, 8u32)
}

/* strlen of a dispatch name (scan to NUL). */
fn iii_cg_pe_name_len(name: u64) -> u32 @export {
    if name == 0u64 { return 0u32 }
    let nm : u64 = name
    let mut n : u32 = 0u32
    while pe_rd_u8(nm, n as u64) != 0u32 { n = n + 1u32 }
    return n
}

/* Read byte at offset from a dispatch name. */
fn iii_cg_pe_name_byte(name: u64, idx: u32) -> u32 @export {
    if name == 0u64 { return 0u32 }
    return pe_rd_u8(name, idx as u64)
}

