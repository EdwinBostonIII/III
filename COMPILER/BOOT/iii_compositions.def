# C:\Users\Edwin Boston\OneDrive\Desktop\III\COMPILER\BOOT\iii_compositions.def
#
# III Composition table — single source of truth for the prespec
# registry (runtime in STDLIB/iii/omnia/prespec.iii) and the cg_r3
# Partial Evaluator narrow table (compile time in cg_r3.c via the
# generated iii_compositions.h).
#
# DO NOT EDIT prespec.iii's auto-generated block or cg_r3.c's
# III_COMPOSITION_TABLE directly. Edit this file, then regenerate via:
#
#     bash COMPILER/BOOT/gen_compositions.sh
#
# The build script verifies that the generated artifacts match this
# .def on every iiis-0 build; manual edits to the generated sections
# are silently overwritten on the next build.
#
# Format:  SEQ_IDX PRIMITIVE_ID HEXAD_BAG K_VALUE LITERAL FN_NAME
#   SEQ_IDX     u32  — synthetic-hash sequence index (must be unique
#                       across this file). Encoded into the synth
#                       composition_hash via:
#                         (0x494E5450u64 << 32) |
#                         ((HEXAD & 0xFF) << 24) |
#                         ((PRIMITIVE & 0xFF) << 16) |
#                         (SEQ_IDX & 0xFFFF)
#   PRIMITIVE   u8   — calculus primitive id (1=FORM, 2=BIND, 3=CONVEY,
#                       4=MEAN, 5=ACT, 6=COMPOSE, 7=SEAL, 8=PROVE,
#                       9=QUERY, 10=GRANT, 11=GOVERN; see
#                       sanctus/calculus_v1.iii).
#   HEXAD_BAG   u8   — packed hexad bits (bit 1=FORM, bit 2=SUBSTANCE,
#                       bit 3=PASSAGE, bit 4=ESSENCE, bit 5=MOTION,
#                       bit 6=COMPOSE, bit 7=ORIGIN). Hex literal.
#   K_VALUE     u32  — k-cost in fixed-point ×1e9 (0..1e9).
#   LITERAL     u64  — first-arg literal that triggers PE narrowing
#                       at compile time (matched against the integer
#                       literal in intent_form/intent_act/intent_convey).
#   FN_NAME     str  — exported stdlib function symbol that
#                       implements the composition. Must be a real
#                       @export-tagged function in STDLIB/iii/.
#
# Lines starting with '#' are comments. Blank lines ignored.
# ─────────────────────────────────────────────────────────────────────

