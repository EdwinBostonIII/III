/* lex.iii - Stage-0 .iii port of lex.c (CP-029 foundation)
 *
 * Mirror of COMPILER/BOOT/lex.c (1772 LOC) under iiis-0 dialect.
 * Behavioural parity required: same token kinds, same FNV-1a-64
 * over raw bytes, same SHA-256 stream / arena mhash, same error
 * codes, same intern IDs, same keyword tables.  Token-stream
 * byte-equivalence is a Stage-1 acceptance gate.
 *
 * NOT YET in PORTED_TUS - sits beside lex.c without substituting it.
 * Will be added once the full surface (create/destroy/next/peek/
 * error_X+intern+locate+history+register_keyword+mhash+seal+etc.)
 * is implemented and verified byte-for-byte against lex.c on the
 * stage1_corpus.
 *
 * Dialect notes inherited from prior ports (sema/cg_r3):
 *   - No `;` separator (only inside [T; N]).
 *   - No char literals 'X' - use numeric byte values.
 *   - `&local as u64` is fragile (param-spill bug); prefer globals
 *     for out-pointer style returns.
 *   - `(0u64 as *u8)` parses as start of hexad literal - drop parens.
 *   - `&IDENT[i]` parses as `(&IDENT)[i]`; use offset arithmetic.
 *   - @export inline at end of fn signature.
 *   - Parser recursion limit ~8 nests; factor deep nests.
 *   - No `break`/`continue` - sentinel-flag refactor.
 *   - No `if` as expression - let mut + if-mutate.
 */

module lex

/* --- Externs from C side (memcpy/memcmp/malloc/free helpers) ------ */

extern @abi(c-msvc-x64) fn iii_lex_malloc_c(n: u64) -> u64 from "lex_runtime.c"
