/* lex_rt.iii -- native runtime memory-deref primitives for the compiler.
 *
 * The pure-deref half of lex_runtime.c: byte/word/qword read+write at addr+off.
 * Every ported TU (ast, cg_*, sema, lex, ...) externs these `from
 * "lex_runtime.c"`; the link now resolves them by name to this native module.
 * malloc/free, memcpy/memset/memcmp, the streaming SHA-256, and the file /
 * env / time / signal / exit surface stay in lex_runtime.c (the libc membrane).
 *
 * NIH: zero externs, libc-free.  Operates on REAL runtime pointers (heap /
 * caller buffers), so native pointer deref is W3-safe.  The u32/u64 forms use
 * native loads/stores: on the x64 (little-endian) target these are byte
 * identical to lex_runtime.c's explicit little-endian byte assembly.  Verified
 * by lex_rt_kat (round-trips + LE byte order) and the non-vacuous differential
 * gate (every corpus program reads its AST through these).
 */
module lex_rt

fn iii_lex_read_u8_at_c(addr: u64, off: u64) -> u32 @export {
    let p: *u8 = (addr + off) as *u8
    return p[0] as u32
}
fn iii_lex_write_u8_at_c(addr: u64, off: u64, v: u32) -> u32 @export {
    let p: *u8 = (addr + off) as *u8
    p[0] = (v & 0xffu32) as u8
    return 0u32
}
fn iii_lex_read_u32_c(addr: u64, off: u64) -> u32 @export {
    let p: *u32 = (addr + off) as *u32
    return p[0]
}
fn iii_lex_write_u32_c(addr: u64, off: u64, v: u32) -> u32 @export {
    let p: *u32 = (addr + off) as *u32
    p[0] = v
    return 0u32
}
fn iii_lex_read_u64_c(addr: u64, off: u64) -> u64 @export {
    let p: *u64 = (addr + off) as *u64
    return p[0]
}
fn iii_lex_write_u64_c(addr: u64, off: u64, v: u64) -> u32 @export {
    let p: *u64 = (addr + off) as *u64
    p[0] = v
    return 0u32
}

/* allocation -- now bound directly to msvcrt (calloc zero-inits, matching the
 * old C iii_lex_malloc_c).  The runtime libc dependency is unchanged; the C
 * wrapper is gone. */
extern @abi(c-msvc-x64) fn calloc(num: u64, size: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: u64) -> u64 from "msvcrt"
fn iii_lex_malloc_c(n: u64) -> u64 @export {
    if n == 0u64 { return calloc(1u64, 1u64) }
    return calloc(1u64, n)
}
fn iii_lex_free_c(addr: u64) -> u32 @export {
    if addr != 0u64 { free(addr) }
    return 0u32
}

/* mem ops -- bound to msvcrt directly (byte-identical to the old C passthroughs,
 * same libc functions).  Length-explicit, so no NUL-termination concern. */
extern @abi(c-msvc-x64) fn memcpy(dst: u64, src: u64, n: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn memset(dst: u64, v: i32, n: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn memcmp(a: u64, b: u64, n: u64) -> i32 from "msvcrt"
fn iii_lex_memcpy_c(dst: u64, src: u64, n: u64) -> u32 @export { memcpy(dst, src, n); return 0u32 }
fn iii_lex_memset_c(dst: u64, v: u32, n: u64) -> u32 @export { memset(dst, (v & 0xffu32) as i32, n); return 0u32 }
fn iii_lex_memcmp_c(a: u64, b: u64, n: u64) -> i32 @export { return memcmp(a, b, n) }

/* SHA-256 -- UNIFIED with cg_sha.iii (no second impl).  lex.iii treats the ctx as
 * an opaque 112-byte buffer (init/update/update_uN/final), so these are thin
 * wrappers over cg_sha's ctx-based FIPS-180-4 SHA-256.  final == snapshot: lex
 * always frees the ctx immediately after final (verified at every call site), so
 * non-destructive snapshot is identical in effect.  Digests are byte-identical
 * (both are FIPS SHA-256 over the same byte stream).  update_uN feed little-endian
 * bytes via a module-scope scratch (sequential, non-reentrant). */
extern @abi(c-msvc-x64) fn cgsha_init(ctx: u64) -> u32 from "cg_sha.iii"
extern @abi(c-msvc-x64) fn cgsha_update(ctx: u64, addr: u64, n: u64) -> u32 from "cg_sha.iii"
extern @abi(c-msvc-x64) fn cgsha_snapshot(ctx: u64, out: u64) -> u32 from "cg_sha.iii"
var LEX_SHA_TMP : [u8; 8]
fn iii_sha256_init(s: u64) -> u32 @export { return cgsha_init(s) }
fn iii_sha256_update(s: u64, data: u64, n: u64) -> u32 @export { return cgsha_update(s, data, n) }
fn iii_sha256_update_u8(s: u64, v: u32) -> u32 @export {
    LEX_SHA_TMP[0] = (v & 0xffu32) as u8
    return cgsha_update(s, &LEX_SHA_TMP as u64, 1u64)
}
fn iii_sha256_update_u16(s: u64, v: u32) -> u32 @export {
    LEX_SHA_TMP[0] = (v & 0xffu32) as u8
    LEX_SHA_TMP[1] = ((v >> 8u32) & 0xffu32) as u8
    return cgsha_update(s, &LEX_SHA_TMP as u64, 2u64)
}
fn iii_sha256_update_u32(s: u64, v: u32) -> u32 @export {
    LEX_SHA_TMP[0] = (v & 0xffu32) as u8
    LEX_SHA_TMP[1] = ((v >> 8u32) & 0xffu32) as u8
    LEX_SHA_TMP[2] = ((v >> 16u32) & 0xffu32) as u8
    LEX_SHA_TMP[3] = ((v >> 24u32) & 0xffu32) as u8
    return cgsha_update(s, &LEX_SHA_TMP as u64, 4u64)
}
fn iii_sha256_update_u64(s: u64, v: u64) -> u32 @export {
    LEX_SHA_TMP[0] = (v & 0xffu64) as u8
    LEX_SHA_TMP[1] = ((v >> 8u64) & 0xffu64) as u8
    LEX_SHA_TMP[2] = ((v >> 16u64) & 0xffu64) as u8
    LEX_SHA_TMP[3] = ((v >> 24u64) & 0xffu64) as u8
    LEX_SHA_TMP[4] = ((v >> 32u64) & 0xffu64) as u8
    LEX_SHA_TMP[5] = ((v >> 40u64) & 0xffu64) as u8
    LEX_SHA_TMP[6] = ((v >> 48u64) & 0xffu64) as u8
    LEX_SHA_TMP[7] = ((v >> 56u64) & 0xffu64) as u8
    return cgsha_update(s, &LEX_SHA_TMP as u64, 8u64)
}
fn iii_sha256_final(s: u64, out32: u64) -> u32 @export { return cgsha_snapshot(s, out32) }

/* ---- file / env / time / signal / exit OS membrane -> msvcrt directly ----
 * Fragile-symbol names verified by fragsym_kat (stderr/stdout = __acrt_iob_func,
 * exit = _Exit, + clock/signal/getenv).  NUL-terminated mode strings; fputs uses
 * an i64 cast for its >=0 check (the i32-signed-ordering codegen quirk). */
extern @abi(c-msvc-x64) fn fwrite(ptr: u64, size: u64, nmemb: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fread(ptr: u64, size: u64, nmemb: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn tmpfile() -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn ftell(stream: u64) -> i64 from "msvcrt"
extern @abi(c-msvc-x64) fn rewind(stream: u64) -> u32 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(stream: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn fputs(str: u64, stream: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn fputc(ch: i32, stream: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fseek(stream: u64, off: i64, whence: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn __acrt_iob_func(idx: u32) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn getenv(name: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn clock() -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn signal(sig: i32, handler: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn _Exit(code: i32) from "msvcrt"

var LEX_M_RB : [u8; 3] = [114u8, 98u8, 0u8]
var LEX_M_WB : [u8; 3] = [119u8, 98u8, 0u8]
var LEX_M_W  : [u8; 2] = [119u8, 0u8]
var LEX_SDE  : [u8; 18] = [83u8,79u8,85u8,82u8,67u8,69u8,95u8,68u8,65u8,84u8,69u8,95u8,69u8,80u8,79u8,67u8,72u8,0u8]

fn iii_lex_fwrite_c(ptr: u64, n: u64, file: u64) -> u64 @export { return fwrite(ptr, 1u64, n, file) }
fn iii_lex_fread_c(ptr: u64, n: u64, file: u64) -> u64 @export { return fread(ptr, 1u64, n, file) }
fn iii_lex_tmpfile_c() -> u64 @export { return tmpfile() }
fn iii_lex_ftell_c(file: u64) -> i64 @export { return ftell(file) }
fn iii_lex_rewind_c(file: u64) -> u32 @export { rewind(file); return 0u32 }
fn iii_lex_fclose_c(file: u64) -> u32 @export { return fclose(file) as u32 }
fn iii_lex_fputs_c(str: u64, file: u64) -> u32 @export {
    let r: i64 = (fputs(str, file)) as i64
    if r >= 0i64 { return 0u32 }
    return 1u32
}
fn iii_lex_fputc_c(ch: u32, file: u64) -> u32 @export {
    let b: i32 = (ch & 0xffu32) as i32
    if fputc(b, file) == b { return 0u32 }
    return 1u32
}
fn iii_lex_fopen_c(path: u64, mode: u32) -> u64 @export {
    if mode == 0u32 { return fopen(path, &LEX_M_RB as u64) }
    if mode == 1u32 { return fopen(path, &LEX_M_WB as u64) }
    return fopen(path, &LEX_M_W as u64)
}
fn iii_lex_fseek_c(file: u64, off: i64, whence: u32) -> u32 @export {
    if whence == 2u32 {
        if fseek(file, off, 2i32) == 0i32 { return 0u32 }
        return 1u32
    }
    if fseek(file, off, 0i32) == 0i32 { return 0u32 }
    return 1u32
}
fn iii_lex_stderr_c() -> u64 @export { return __acrt_iob_func(2u32) }
fn iii_lex_stdout_c() -> u64 @export { return __acrt_iob_func(1u32) }
fn iii_lex_getenv_sde_c() -> i64 @export {
    let s: u64 = getenv(&LEX_SDE as u64)
    if s == 0u64 { return 0i64 }
    let p0: *u8 = s as *u8
    if p0[0] == 0u8 { return 0i64 }
    let mut v: i64 = 0i64
    let mut i: u64 = 0u64
    let mut ch: u32 = p0[0] as u32
    while ch != 0u32 {
        if ch < 48u32 { return 0i64 }
        if ch > 57u32 { return 0i64 }
        v = v * 10i64 + ((ch - 48u32) as i64)
        i = i + 1u64
        let pn: *u8 = (s + i) as *u8
        ch = pn[0] as u32
    }
    return v
}
fn iii_lex_clock_ms_c() -> u64 @export { return clock() as u64 }
fn iii_lex_signal_c(sig: u32, handler: u64) -> u32 @export { signal(sig as i32, handler); return 0u32 }
fn iii_lex_exit_c(code: u32) -> u32 @export { _Exit(code as i32); return 0u32 }
