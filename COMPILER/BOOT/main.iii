/* ── orchestrator state (subset of main.c g_orch) ────────────────────── */
/* ORCH: ring@0 | ring_explicit@4 | emit_asm_only@8 | compile_only@12 |
 * source_mhash@16 (32B) | source_mhash_valid@48 | run_out_mhash@52 (32B) |
 * run_out_mhash_valid@84 | diag@88 | verbose@92. */
var ORCH : [u8; 256]
const O_RING: u64 = 0u64
const O_RING_EXPL: u64 = 4u64
const O_ASM_ONLY: u64 = 8u64
const O_COMPILE_ONLY: u64 = 12u64
const O_SRC_MHASH: u64 = 16u64
const O_SRC_MHASH_VALID: u64 = 48u64
const O_RUN_MHASH: u64 = 52u64
const O_RUN_MHASH_VALID: u64 = 84u64
const O_DIAG: u64 = 88u64
const O_VERBOSE: u64 = 92u64
const O_ARGV_MHASH: u64 = 96u64
const O_OUT_MHASH: u64 = 128u64
const O_OUT_MHASH_VALID: u64 = 160u64
const O_LINK_MODE: u64 = 164u64
const O_REPRO: u64 = 168u64
const O_EMIT_WITNESS: u64 = 172u64
const O_PRINT_MHASH: u64 = 176u64
const O_SEALED: u64 = 180u64
const O_SDE: u64 = 184u64
const O_OUT_PATH: u64 = 192u64
const O_SRC_PATH: u64 = 200u64
const O_AFFINE_AUDIT: u64 = 208u64   /* SW-INWARD-AUTO flag (ORCH is [u8;256]; 208..212 free) */

/* PIPE_STATE handles: lex@0|ast@8|p@16|sema@24|sid@32|wa@40|lnk@48|bytes@56. */
var PIPE_STATE : [u8; 64]
var MHF_BUF : [u8; 8192]
var ASM_PATH : [u8; 1024]
var OBJ_PATH : [u8; 1024]
var OBJ_ARR : [u8; 8]
var RF_BYTES : [u8; 8]
var RF_LEN : [u8; 8]

/* SHA-256 a file by path (8KB chunks).  Returns 0 ok / 1 fail. */
fn iii_mhash_file(path: u64, out: u64) -> u32 {
    let file: u64 = iii_lex_fopen_c(path, FOPEN_RB)
    if file == 0u64 { return 1u32 }
    msha256_init()
    let mut go: u32 = 1u32
    while go == 1u32 {
        let n: u64 = iii_lex_fread_c(&MHF_BUF as u64, 8192u64, file)
        if n != 0u64 { msha256_update(&MHF_BUF as u64, n) }
        if n < 8192u64 { go = 0u32 }
    }
    iii_lex_fclose_c(file)
    msha256_final(out)
    return 0u32
}
/* dst <- base (NUL-term) ++ suffix(litlen) ++ NUL. */
fn iiim_path_suffix(dst: u64, base: u64, suffix: u64, slen: u64) -> u32 {
    let bl: u64 = iiim_strlen(base)
    iii_lex_memcpy_c(dst, base, bl)
    iii_lex_memcpy_c(dst + bl, suffix, slen)
    iii_lex_write_u8_at_c(dst, bl + slen, 0u32)
    return 0u32
}
fn ps_get(off: u64) -> u64 { return iii_lex_read_u64_c(&PIPE_STATE as u64, off) }
fn ps_set(off: u64, v: u64) -> u32 { iii_lex_write_u64_c(&PIPE_STATE as u64, off, v) ; return 0u32 }
/* destroy every non-zero pipeline state + free the source buffer. */
fn iii_pipeline_cleanup() -> u32 {
    if ps_get(48u64) != 0u64 { iii_link_destroy(ps_get(48u64)) }
    if ps_get(40u64) != 0u64 { iii_walloc_destroy(ps_get(40u64)) }
    if ps_get(32u64) != 0u64 { iii_sid_destroy(ps_get(32u64)) }
    if ps_get(24u64) != 0u64 { iii_sema_destroy(ps_get(24u64)) }
    if ps_get(16u64) != 0u64 { iii_parse_destroy(ps_get(16u64)) }
    if ps_get(8u64) != 0u64 { iii_ast_destroy(ps_get(8u64)) }
    if ps_get(0u64) != 0u64 { iii_lex_destroy(ps_get(0u64)) }
    if ps_get(56u64) != 0u64 { iii_lex_free_c(ps_get(56u64)) }
    return 0u32
}
/* cg dispatch by ring -> emit .s to asm_out; returns cg rc (0 ok). */
fn iii_cg_dispatch(ring: u32, ast: u64, sema: u64, sid: u64, wa: u64, asm_out: u64) -> u32 {
    if ring == RING_CHOICE_R3 {
        let cg: u64 = iii_cg_r3_create(ast, sema, sid, wa)
        let rc: u32 = iii_cg_r3_emit_module(cg, asm_out)
        iii_cg_r3_destroy(cg)
        return rc
    }
    if ring == RING_CHOICE_R0 {
        let cg: u64 = iii_cg_r0_create(ast, sema, sid, wa)
        let rc: u32 = iii_cg_r0_emit_module(cg, asm_out)
        iii_cg_r0_destroy(cg)
        return rc
    }
    if ring == RING_CHOICE_RM1 {
        let cg: u64 = iii_cg_rm1_create(ast, sema, sid, wa)
        let rc: u32 = iii_cg_rm1_emit_module(cg, asm_out)
        iii_cg_rm1_destroy(cg)
        return rc
    }
    let cg: u64 = iii_cg_rm2_create(ast, sema, sid, wa)
    let rc: u32 = iii_cg_rm2_emit_module(cg, asm_out)
    iii_cg_rm2_destroy(cg)
    return rc
}
fn iii_ring_to_fmt(ring: u32) -> u32 {
    if ring == RING_CHOICE_R0 { return FMT_PE_SYS }
    if ring == RING_CHOICE_RM1 { return FMT_RAW_BIN }
    if ring == RING_CHOICE_RM2 { return FMT_SANCTUM_OBJECT }
    return FMT_PE_EXE
}
/* admit each walloc record's cycle_kind into the ceiling bitmap. */
fn iii_walloc_admit_all(wa: u64) -> u32 {
    let n: u32 = iii_walloc_record_count(wa)
    let mut i: u32 = 0u32
    while i < n {
        let r: u64 = iii_walloc_record_at(wa, i)
        iii_ceil_admit_kind(iii_lex_read_u32_c(r, 12u64) & 65535u32)
        i = i + 1u32
    }
    return 0u32
}
/* hard-fail if link verification produced a CLOSURE_MISMATCH. */
fn iii_link_hard_fail(lnk: u64) -> u32 {
    let ne: u32 = iii_link_error_count(lnk)
    let err: u64 = iii_lex_stderr_c()
    let mut hard: u32 = 0u32
    let mut i: u32 = 0u32
    while i < ne {
        iii_link_error_at(lnk, i, &ERR_LINK as u64)
        if iii_lex_read_u32_c(&ERR_LINK as u64, 0u64) == LINK_E_CLOSURE_MISMATCH {
            let msg: u64 = iii_lex_read_u64_c(&ERR_LINK as u64, 8u64)
            mw_lit(err, "link error: " as u64, 12u64)
            mw_cstr_or_empty(err, msg)
            iii_lex_fputc_c(10u32, err)
            hard = 1u32
        }
        i = i + 1u32
    }
    return hard
}

/* ── the compile pipeline (reads flags from ORCH; output mhash -> ORCH) ─
 * returns an exit code (III_EXIT_*). */
fn iii_run_pipeline(src_path: u64, out_path: u64) -> u32 {
    iii_lex_write_u32_c(&ORCH as u64, O_RUN_MHASH_VALID, 0u32)
    iii_lex_memset_c(&PIPE_STATE as u64, 0u32, 64u64)
    /* read + mhash source.  Out-params via module scratches (NOT &local --
     * iiis-0 may register-allocate locals, making &local a bogus address). */
    if iii_read_file(src_path, &RF_BYTES as u64, &RF_LEN as u64) != 0u32 {
        mw_lit(iii_lex_stderr_c(), "iiis-0: cannot read " as u64, 20u64)
        mw_cstr(iii_lex_stderr_c(), src_path)
        iii_lex_fputc_c(10u32, iii_lex_stderr_c())
        return III_EXIT_USAGE
    }
    let bytes: u64 = iii_lex_read_u64_c(&RF_BYTES as u64, 0u64)
    let len: u64 = iii_lex_read_u64_c(&RF_LEN as u64, 0u64)
    ps_set(56u64, bytes)
    iii_mhash_buf(bytes, len, &ORCH as u64 + O_SRC_MHASH)
    iii_lex_write_u32_c(&ORCH as u64, O_SRC_MHASH_VALID, 1u32)
    /* lex + parse. */
    let lex: u64 = iii_lex_create(bytes, len, src_path)
    if lex == 0u64 { iii_pipeline_cleanup() ; return III_EXIT_LEX_FAIL }
    ps_set(0u64, lex)
    let ast: u64 = iii_ast_create(bytes, len, src_path)
    if ast == 0u64 { iii_pipeline_cleanup() ; return III_EXIT_INTERNAL }
    ps_set(8u64, ast)
    let p: u64 = iii_parse_create(lex, ast)
    if p == 0u64 { iii_pipeline_cleanup() ; return III_EXIT_INTERNAL }
    ps_set(16u64, p)
    let parse_ok: u32 = iii_parse_module(p)
    iii_diag_lex(lex)
    iii_diag_parse(p)
    if parse_ok == 0u32 { iii_pipeline_cleanup() ; return III_EXIT_PARSE_FAIL }
    /* ring auto-detect / verify. */
    let rc_ring: u32 = iii_ring_autodetect(ast, iii_lex_read_u32_c(&ORCH as u64, O_RING_EXPL), &ORCH as u64 + O_RING)
    if rc_ring != 0u32 { iii_pipeline_cleanup() ; return rc_ring }
    let ring: u32 = iii_lex_read_u32_c(&ORCH as u64, O_RING)
    /* sema + sid. */
    iii_hexad_check_init()
    iii_acc_init_permissive()
    iii_ceil_init_denied()
    let sema: u64 = iii_sema_create(ast)
    ps_set(24u64, sema)
    let sema_ok: u32 = iii_sema_run(sema)
    iii_diag_sema(sema)
    if sema_ok == 0u32 { iii_pipeline_cleanup() ; return III_EXIT_SEMA_FAIL }
    /* SW-INWARD-AUTO: offline affine-bounds audit on the sema-resolved AST, then stop
     * (no sid / witness / codegen).  Sound: PROVEN/REFUTED/ABSTAIN only -- never a false
     * PROVEN.  Counts go to stderr; exit OK (the printed "AA ... R=<n>" is the signal). */
    if iii_lex_read_u32_c(&ORCH as u64, O_AFFINE_AUDIT) == 1u32 {
        iii_affine_audit_run(ast)
        iii_pipeline_cleanup()
        return III_EXIT_OK
    }
    let sid: u64 = iii_sid_create(ast, sema)
    ps_set(32u64, sid)
    let sid_ok: u32 = iii_sid_run(sid)
    iii_diag_sid(sid)
    if sid_ok == 0u32 { iii_pipeline_cleanup() ; return III_EXIT_SEMA_FAIL }
    /* witness allocation. */
    let wa: u64 = iii_walloc_create()
    if wa == 0u64 { iii_pipeline_cleanup() ; return III_EXIT_OOM }
    ps_set(40u64, wa)
    if iii_walloc_run(wa, ast) != 0u32 {
        mw_lit(iii_lex_stderr_c(), "iiis-0: witness allocation failed\n" as u64, 34u64)
        iii_pipeline_cleanup() ; return III_EXIT_WALLOC_FAIL
    }
    iii_walloc_admit_all(wa)
    /* link verification. */
    let lnk: u64 = iii_link_create()
    if lnk == 0u64 { iii_pipeline_cleanup() ; return III_EXIT_OOM }
    ps_set(48u64, lnk)
    iii_link_verify_imports(lnk, ast)
    if iii_link_hard_fail(lnk) == 1u32 { iii_pipeline_cleanup() ; return III_EXIT_LINK_FAIL }
    /* codegen -> .s */
    iiim_path_suffix(&ASM_PATH as u64, out_path, ".s" as u64, 2u64)
    let asm_out: u64 = iii_lex_fopen_c(&ASM_PATH as u64, FOPEN_W)
    if asm_out == 0u64 {
        mw_lit(iii_lex_stderr_c(), "iiis-0: cannot open .s for write\n" as u64, 33u64)
        iii_pipeline_cleanup() ; return III_EXIT_EMIT_FAIL
    }
    let cg_rc: u32 = iii_cg_dispatch(ring, ast, sema, sid, wa, asm_out)
    iii_lex_fclose_c(asm_out)
    if cg_rc != 0u32 { iii_pipeline_cleanup() ; return III_EXIT_CG_FAIL }
    /* emit. */
    let fmt: u32 = iii_ring_to_fmt(ring)
    let mut emit_rc: u32 = III_EXIT_OK
    if iii_lex_read_u32_c(&ORCH as u64, O_ASM_ONLY) == 1u32 {
        if iii_mhash_file(&ASM_PATH as u64, &ORCH as u64 + O_RUN_MHASH) == 0u32 { iii_lex_write_u32_c(&ORCH as u64, O_RUN_MHASH_VALID, 1u32) }
    }
    if iii_lex_read_u32_c(&ORCH as u64, O_ASM_ONLY) == 0u32 {
        if iii_lex_read_u32_c(&ORCH as u64, O_COMPILE_ONLY) == 1u32 {
            if iii_emit_assemble(&ASM_PATH as u64, out_path) != 0u32 {
                mw_lit(iii_lex_stderr_c(), "iiis-0: assemble failed\n" as u64, 24u64)
                emit_rc = III_EXIT_EMIT_FAIL
            }
            if emit_rc == III_EXIT_OK {
                if iii_mhash_file(out_path, &ORCH as u64 + O_RUN_MHASH) == 0u32 { iii_lex_write_u32_c(&ORCH as u64, O_RUN_MHASH_VALID, 1u32) }
                if iii_lex_read_u32_c(&ORCH as u64, O_RUN_MHASH_VALID) == 0u32 { emit_rc = III_EXIT_EMIT_FAIL }
            }
        }
        if iii_lex_read_u32_c(&ORCH as u64, O_COMPILE_ONLY) == 0u32 {
            iiim_path_suffix(&OBJ_PATH as u64, out_path, ".o" as u64, 2u64)
            if iii_emit_assemble(&ASM_PATH as u64, &OBJ_PATH as u64) != 0u32 {
                mw_lit(iii_lex_stderr_c(), "iiis-0: assemble failed\n" as u64, 24u64)
                emit_rc = III_EXIT_EMIT_FAIL
            } else {
                iii_lex_write_u64_c(&OBJ_ARR as u64, 0u64, &OBJ_PATH as u64)
                if iii_emit_link(fmt, &OBJ_ARR as u64, 1u64, out_path, 0u64) != 0u32 {
                    mw_lit(iii_lex_stderr_c(), "iiis-0: link failed\n" as u64, 20u64)
                    emit_rc = III_EXIT_LINK_FAIL
                }
            }
            if emit_rc == III_EXIT_OK {
                if iii_mhash_file(out_path, &ORCH as u64 + O_RUN_MHASH) == 0u32 { iii_lex_write_u32_c(&ORCH as u64, O_RUN_MHASH_VALID, 1u32) }
            }
        }
    }
    iii_walloc_seal(wa)
    iii_link_seal(lnk)
    iii_pipeline_cleanup()
    return emit_rc
}
/* link-only: positional .o array -> exe. */
fn iii_run_link_only(objs: u64, n_objs: u32, fmt: u32, out_path: u64) -> u32 {
    iii_lex_write_u32_c(&ORCH as u64, O_RUN_MHASH_VALID, 0u32)
    if n_objs == 0u32 {
        mw_lit(iii_lex_stderr_c(), "iiis-0: --link requires at least one .o input\n" as u64, 46u64)
        return III_EXIT_USAGE
    }
    if iii_emit_link(fmt, objs, n_objs as u64, out_path, 0u64) != 0u32 {
        mw_lit(iii_lex_stderr_c(), "iiis-0: link failed\n" as u64, 20u64)
        return III_EXIT_LINK_FAIL
    }
    if iii_mhash_file(out_path, &ORCH as u64 + O_RUN_MHASH) == 0u32 { iii_lex_write_u32_c(&ORCH as u64, O_RUN_MHASH_VALID, 1u32) }
    if iii_lex_read_u32_c(&ORCH as u64, O_RUN_MHASH_VALID) == 0u32 { return III_EXIT_EMIT_FAIL }
    return III_EXIT_OK
}

/* ── 2.4f: witness + version/help + argv + signals + main ────────────── */
extern @abi(c-msvc-x64) fn iii_lex_signal_c(sig: u32, handler: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_exit_c(code: u32) -> u32 from "lex_runtime.c"

var WP_BUF : [u8; 2048]
var REPRO_OUT : [u8; 2048]
var DEFAULT_OUT : [u8; 1024]
var SAVE_MH1 : [u8; 32]
var HEX_OUT : [u8; 65]

/* emit "format" as a quoted JSON string (no escaping needed — fixed names). */
fn iii_emit_format_name_json(w: u64, fmt: u32) -> u32 {
    iii_lex_fputc_c(34u32, w)
    if fmt == FMT_PE_EXE { mw_lit(w, "pe_exe" as u64, 6u64) }
    if fmt == FMT_PE_DLL { mw_lit(w, "pe_dll" as u64, 6u64) }
    if fmt == FMT_PE_SYS { mw_lit(w, "pe_sys" as u64, 6u64) }
    if fmt == FMT_ELF_EXE { mw_lit(w, "elf_exe" as u64, 7u64) }
    if fmt == FMT_RAW_BIN { mw_lit(w, "raw_bin" as u64, 7u64) }
    if fmt == FMT_SANCTUM_OBJECT { mw_lit(w, "sanctum_object" as u64, 14u64) }
    iii_lex_fputc_c(34u32, w)
    return 0u32
}
fn iii_ring_name_json(w: u64, ring: u32) -> u32 {
    iii_lex_fputc_c(34u32, w)
    if ring == RING_CHOICE_R3 { mw_lit(w, "R3" as u64, 2u64) }
    if ring == RING_CHOICE_R0 { mw_lit(w, "R0" as u64, 2u64) }
    if ring == RING_CHOICE_RM1 { mw_lit(w, "R-1" as u64, 3u64) }
    if ring == RING_CHOICE_RM2 { mw_lit(w, "R-2" as u64, 3u64) }
    iii_lex_fputc_c(34u32, w)
    return 0u32
}
/* sorted-key canonical build-witness JSON (main.c::iii_witness_write). */
fn iii_witness_write(wpath: u64, fmt: u32) -> u32 {
    if iii_lex_read_u32_c(&ORCH as u64, O_SEALED) == 1u32 {
        mw_lit(iii_lex_stderr_c(), "iiis-0: witness write refused (orchestrator sealed)\n" as u64, 51u64)
        return III_EXIT_INTERNAL
    }
    let w: u64 = iii_lex_fopen_c(wpath, FOPEN_WB)
    if w == 0u64 {
        mw_lit(iii_lex_stderr_c(), "iiis-0: cannot open witness sink\n" as u64, 33u64)
        return III_EXIT_EMIT_FAIL
    }
    iii_lex_fputc_c(123u32, w)
    mw_lit(w, "\"argv_mhash\":" as u64, 13u64)
    iii_lex_fputc_c(34u32, w) ; mw_hex32(w, &ORCH as u64 + O_ARGV_MHASH) ; iii_lex_fputc_c(34u32, w)
    mw_lit(w, ",\"format\":" as u64, 10u64)
    iii_emit_format_name_json(w, fmt)
    mw_lit(w, ",\"gcc_version_mhash\":null" as u64, 25u64)
    mw_lit(w, ",\"ld_version_mhash\":null" as u64, 24u64)
    mw_lit(w, ",\"output_mhash\":" as u64, 16u64)
    if iii_lex_read_u32_c(&ORCH as u64, O_OUT_MHASH_VALID) == 1u32 {
        iii_lex_fputc_c(34u32, w) ; mw_hex32(w, &ORCH as u64 + O_OUT_MHASH) ; iii_lex_fputc_c(34u32, w)
    } else { mw_lit(w, "null" as u64, 4u64) }
    mw_lit(w, ",\"output_path\":" as u64, 15u64)
    let op: u64 = iii_lex_read_u64_c(&ORCH as u64, O_OUT_PATH)
    if op != 0u64 { iii_json_emit_string(w, op) } else { mw_lit(w, "\"\"" as u64, 2u64) }
    mw_lit(w, ",\"ring\":" as u64, 8u64)
    iii_ring_name_json(w, iii_lex_read_u32_c(&ORCH as u64, O_RING))
    mw_lit(w, ",\"source_date_epoch\":" as u64, 21u64)
    mw_dec(w, iii_lex_read_u64_c(&ORCH as u64, O_SDE))
    mw_lit(w, ",\"source_files\":[{\"mhash\":" as u64, 26u64)
    if iii_lex_read_u32_c(&ORCH as u64, O_SRC_MHASH_VALID) == 1u32 {
        iii_lex_fputc_c(34u32, w) ; mw_hex32(w, &ORCH as u64 + O_SRC_MHASH) ; iii_lex_fputc_c(34u32, w)
    } else { mw_lit(w, "null" as u64, 4u64) }
    mw_lit(w, ",\"path\":" as u64, 8u64)
    let sp: u64 = iii_lex_read_u64_c(&ORCH as u64, O_SRC_PATH)
    if sp != 0u64 { iii_json_emit_string(w, sp) } else { mw_lit(w, "\"\"" as u64, 2u64) }
    mw_lit(w, "}]" as u64, 2u64)
    mw_lit(w, ",\"tool\":\"iiis-0\"" as u64, 16u64)
    mw_lit(w, ",\"version\":\"0.1.0\"" as u64, 18u64)
    iii_lex_fputc_c(125u32, w)
    iii_lex_fclose_c(w)
    return III_EXIT_OK
}

fn iii_print_version() -> u32 {
    mw_lit(iii_lex_stdout_c(), "iiis-0 v0.1.0 (commit unknown)\n" as u64, 30u64)
    return 0u32
}
fn iii_print_help() -> u32 {
    let o: u64 = iii_lex_stdout_c()
    mw_lit(o, "iiis-0 - III Stage-0 compiler (CLI orchestrator)\n" as u64, 48u64)
    mw_lit(o, "Usage: iiis-0 <source.iii> [options]\n" as u64, 37u64)
    mw_lit(o, "  --ring R3|R0|R-1|R-2   target ring (auto-detected if omitted)\n" as u64, 62u64)
    mw_lit(o, "  --out <path>           output path\n" as u64, 36u64)
    mw_lit(o, "  --emit-asm-only        stop after codegen\n" as u64, 43u64)
    mw_lit(o, "  --compile-only         stop after assemble; emit .o\n" as u64, 53u64)
    mw_lit(o, "  --link                 link mode: positional args are .o\n" as u64, 58u64)
    mw_lit(o, "  --emit-witness         write build-witness JSON sidecar\n" as u64, 56u64)
    mw_lit(o, "  --reproducibility-check  run pipeline twice; assert identical\n" as u64, 63u64)
    mw_lit(o, "  --print-mhash          print output mhash to stdout\n" as u64, 53u64)
    mw_lit(o, "  --diag=json            JSONL diagnostics on stderr\n" as u64, 52u64)
    mw_lit(o, "  -v -vv -vvv            verbose phase timing\n" as u64, 44u64)
    mw_lit(o, "  --version --help\n" as u64, 17u64)
    return 0u32
}
/* "R3"/"3"/"R0"/"0"/"R-1"/"-1"/"R-2"/"-2" -> ring choice at out_addr; 0 ok / 1 bad. */
fn iii_parse_ring_arg(r: u64, out_addr: u64) -> u32 {
    if iiim_streq(r, "R3" as u64, 2u64) == 1u32 { iii_lex_write_u32_c(out_addr, 0u64, RING_CHOICE_R3) ; return 0u32 }
    if iiim_streq(r, "3" as u64, 1u64) == 1u32 { iii_lex_write_u32_c(out_addr, 0u64, RING_CHOICE_R3) ; return 0u32 }
    if iiim_streq(r, "R0" as u64, 2u64) == 1u32 { iii_lex_write_u32_c(out_addr, 0u64, RING_CHOICE_R0) ; return 0u32 }
    if iiim_streq(r, "0" as u64, 1u64) == 1u32 { iii_lex_write_u32_c(out_addr, 0u64, RING_CHOICE_R0) ; return 0u32 }
    if iiim_streq(r, "R-1" as u64, 3u64) == 1u32 { iii_lex_write_u32_c(out_addr, 0u64, RING_CHOICE_RM1) ; return 0u32 }
    if iiim_streq(r, "-1" as u64, 2u64) == 1u32 { iii_lex_write_u32_c(out_addr, 0u64, RING_CHOICE_RM1) ; return 0u32 }
    if iiim_streq(r, "R-2" as u64, 3u64) == 1u32 { iii_lex_write_u32_c(out_addr, 0u64, RING_CHOICE_RM2) ; return 0u32 }
    if iiim_streq(r, "-2" as u64, 2u64) == 1u32 { iii_lex_write_u32_c(out_addr, 0u64, RING_CHOICE_RM2) ; return 0u32 }
    return 1u32
}

/* signal handler (D12): flush a partial witness, then terminate. */
fn iiip_sig_handler(sig: u32) -> u32 @export {
    mw_lit(iii_lex_stderr_c(), "iiis-0: caught signal, flushing partial witness\n" as u64, 48u64)
    let op: u64 = iii_lex_read_u64_c(&ORCH as u64, O_OUT_PATH)
    if op != 0u64 {
        iiim_path_suffix(&WP_BUF as u64, op, ".partial.witness.json" as u64, 21u64)
        iii_witness_write(&WP_BUF as u64, FMT_PE_EXE)
    }
    iii_lex_exit_c(III_EXIT_INTERNAL)
    return 0u32
}
fn iii_install_signals() -> u32 {
    iii_lex_signal_c(2u32, &iiip_sig_handler as u64)
    iii_lex_signal_c(15u32, &iiip_sig_handler as u64)
    return 0u32
}

/* ── entry point ─────────────────────────────────────────────────────── */
fn main(argc: u32, argv: u64) -> u32 @export {
    iii_lex_memset_c(&ORCH as u64, 0u32, 256u64)
    iii_lex_write_u32_c(&ORCH as u64, O_RING, RING_CHOICE_R3)
    iii_lex_write_u64_c(&ORCH as u64, O_SDE, iii_lex_getenv_sde_c() as u64)
    iii_install_signals()
    iii_argv_canon_mhash(argc, argv, &ORCH as u64 + O_ARGV_MHASH)
    /* prescan --version/--help. */
    let mut i: u32 = 1u32
    while i < argc {
        let a: u64 = iii_lex_read_u64_c(argv, (i as u64) * 8u64)
        if iiim_streq(a, "--version" as u64, 9u64) == 1u32 { iii_print_version() ; return III_EXIT_OK }
        if iiim_streq(a, "--help" as u64, 6u64) == 1u32 { iii_print_help() ; return III_EXIT_OK }
        if iiim_streq(a, "-h" as u64, 2u64) == 1u32 { iii_print_help() ; return III_EXIT_OK }
        i = i + 1u32
    }
    if argc < 2u32 { iii_print_help() ; return III_EXIT_USAGE }
    /* positional + flag parse. */
    let positionals: u64 = iii_lex_malloc_c((argc as u64) * 8u64)
    if positionals == 0u64 { return III_EXIT_OOM }
    let mut npos: u32 = 0u32
    let mut bad: u32 = 0u32
    i = 1u32
    while i < argc {
        let a: u64 = iii_lex_read_u64_c(argv, (i as u64) * 8u64)
        if iii_lex_read_u8_at_c(a, 0u64) != 45u32 {
            iii_lex_write_u64_c(positionals, (npos as u64) * 8u64, a)
            npos = npos + 1u32
        } else {
            let mut m: u32 = 0u32
            if iiim_streq(a, "--ring" as u64, 6u64) == 1u32 { if (i + 1u32) < argc {
                i = i + 1u32
                if iii_parse_ring_arg(iii_lex_read_u64_c(argv, (i as u64) * 8u64), &ORCH as u64 + O_RING) != 0u32 { bad = 1u32 }
                iii_lex_write_u32_c(&ORCH as u64, O_RING_EXPL, 1u32)
                m = 1u32
            } }
            if m == 0u32 { if iiim_strprefix(a, "--ring=" as u64, 7u64) == 1u32 {
                if iii_parse_ring_arg(a + 7u64, &ORCH as u64 + O_RING) != 0u32 { bad = 1u32 }
                iii_lex_write_u32_c(&ORCH as u64, O_RING_EXPL, 1u32)
                m = 1u32
            } }
            if m == 0u32 { if iiim_streq(a, "--out" as u64, 5u64) == 1u32 { if (i + 1u32) < argc {
                i = i + 1u32
                iii_lex_write_u64_c(&ORCH as u64, O_OUT_PATH, iii_lex_read_u64_c(argv, (i as u64) * 8u64))
                m = 1u32
            } } }
            if m == 0u32 { if iiim_streq(a, "--reproducibility-check" as u64, 23u64) == 1u32 { iii_lex_write_u32_c(&ORCH as u64, O_REPRO, 1u32) ; m = 1u32 } }
            if m == 0u32 { if iiim_streq(a, "--emit-asm-only" as u64, 15u64) == 1u32 { iii_lex_write_u32_c(&ORCH as u64, O_ASM_ONLY, 1u32) ; m = 1u32 } }
            if m == 0u32 { if iiim_streq(a, "--compile-only" as u64, 14u64) == 1u32 { iii_lex_write_u32_c(&ORCH as u64, O_COMPILE_ONLY, 1u32) ; m = 1u32 } }
            if m == 0u32 { if iiim_streq(a, "--link" as u64, 6u64) == 1u32 { iii_lex_write_u32_c(&ORCH as u64, O_LINK_MODE, 1u32) ; m = 1u32 } }
            if m == 0u32 { if iiim_streq(a, "--emit-witness" as u64, 14u64) == 1u32 { iii_lex_write_u32_c(&ORCH as u64, O_EMIT_WITNESS, 1u32) ; m = 1u32 } }
            if m == 0u32 { if iiim_streq(a, "--print-mhash" as u64, 13u64) == 1u32 { iii_lex_write_u32_c(&ORCH as u64, O_PRINT_MHASH, 1u32) ; m = 1u32 } }
            if m == 0u32 { if iiim_streq(a, "--diag=json" as u64, 11u64) == 1u32 { iii_lex_write_u32_c(&ORCH as u64, O_DIAG, 1u32) ; iii_lex_write_u32_c(&DIAG_MODE as u64, 0u64, 1u32) ; m = 1u32 } }
            if m == 0u32 { if iiim_streq(a, "-v" as u64, 2u64) == 1u32 { iii_lex_write_u32_c(&ORCH as u64, O_VERBOSE, 1u32) ; m = 1u32 } }
            if m == 0u32 { if iiim_streq(a, "-vv" as u64, 3u64) == 1u32 { iii_lex_write_u32_c(&ORCH as u64, O_VERBOSE, 2u32) ; m = 1u32 } }
            if m == 0u32 { if iiim_streq(a, "-vvv" as u64, 4u64) == 1u32 { iii_lex_write_u32_c(&ORCH as u64, O_VERBOSE, 3u32) ; m = 1u32 } }
            if m == 0u32 { if iiim_streq(a, "--affine-audit" as u64, 14u64) == 1u32 { iii_lex_write_u32_c(&ORCH as u64, O_AFFINE_AUDIT, 1u32) ; m = 1u32 } }
            if m == 0u32 {
                mw_lit(iii_lex_stderr_c(), "iiis-0: unknown argument '" as u64, 26u64)
                mw_cstr(iii_lex_stderr_c(), a)
                mw_lit(iii_lex_stderr_c(), "'\n" as u64, 2u64)
                iii_lex_free_c(positionals)
                return III_EXIT_USAGE
            }
        }
        i = i + 1u32
    }
    if bad == 1u32 { iii_lex_free_c(positionals) ; return III_EXIT_USAGE }
    if npos == 0u32 {
        mw_lit(iii_lex_stderr_c(), "iiis-0: missing input file(s)\n" as u64, 30u64)
        iii_lex_free_c(positionals)
        return III_EXIT_USAGE
    }
    /* mutual-exclusive: --link vs compile/asm/repro. */
    if iii_lex_read_u32_c(&ORCH as u64, O_LINK_MODE) == 1u32 {
        let bad2: u32 = iii_lex_read_u32_c(&ORCH as u64, O_COMPILE_ONLY) + iii_lex_read_u32_c(&ORCH as u64, O_ASM_ONLY) + iii_lex_read_u32_c(&ORCH as u64, O_REPRO)
        if bad2 != 0u32 { iii_lex_free_c(positionals) ; return III_EXIT_USAGE }
    }
    /* ── link mode ──────────────────────────────────────────────────── */
    if iii_lex_read_u32_c(&ORCH as u64, O_LINK_MODE) == 1u32 {
        if iii_lex_read_u64_c(&ORCH as u64, O_OUT_PATH) == 0u64 { iii_lex_free_c(positionals) ; return III_EXIT_USAGE }
        let fmt: u32 = iii_ring_to_fmt(iii_lex_read_u32_c(&ORCH as u64, O_RING))
        let rc: u32 = iii_run_link_only(positionals, npos, fmt, iii_lex_read_u64_c(&ORCH as u64, O_OUT_PATH))
        if rc != III_EXIT_OK { iii_lex_free_c(positionals) ; return rc }
        if iii_lex_read_u32_c(&ORCH as u64, O_RUN_MHASH_VALID) == 1u32 {
            iii_lex_memcpy_c(&ORCH as u64 + O_OUT_MHASH, &ORCH as u64 + O_RUN_MHASH, 32u64)
            iii_lex_write_u32_c(&ORCH as u64, O_OUT_MHASH_VALID, 1u32)
        }
        if iii_lex_read_u32_c(&ORCH as u64, O_PRINT_MHASH) == 1u32 { if iii_lex_read_u32_c(&ORCH as u64, O_OUT_MHASH_VALID) == 1u32 {
            iii_mhash_to_hex(&ORCH as u64 + O_OUT_MHASH, &HEX_OUT as u64)
            mw_cstr(iii_lex_stdout_c(), &HEX_OUT as u64)
            iii_lex_fputc_c(10u32, iii_lex_stdout_c())
        } }
        iii_lex_write_u32_c(&ORCH as u64, O_SEALED, 1u32)
        iii_lex_free_c(positionals)
        return III_EXIT_OK
    }
    /* ── multi-source compile-only ──────────────────────────────────── */
    if npos > 1u32 {
        if iii_lex_read_u32_c(&ORCH as u64, O_COMPILE_ONLY) == 0u32 { iii_lex_free_c(positionals) ; return III_EXIT_USAGE }
        if iii_lex_read_u64_c(&ORCH as u64, O_OUT_PATH) != 0u64 { iii_lex_free_c(positionals) ; return III_EXIT_USAGE }
        let mut multi_rc: u32 = III_EXIT_OK
        let mut j: u32 = 0u32
        let mut stop: u32 = 0u32
        while j < npos {
            if stop == 0u32 {
                let src: u64 = iii_lex_read_u64_c(positionals, (j as u64) * 8u64)
                iii_lex_write_u64_c(&ORCH as u64, O_SRC_PATH, src)
                iiim_path_suffix(&DEFAULT_OUT as u64, src, ".o" as u64, 2u64)
                let rc: u32 = iii_run_pipeline(src, &DEFAULT_OUT as u64)
                if rc != III_EXIT_OK { multi_rc = rc ; stop = 1u32 }
            }
            j = j + 1u32
        }
        iii_lex_free_c(positionals)
        iii_lex_write_u32_c(&ORCH as u64, O_SEALED, 1u32)
        return multi_rc
    }
    /* ── single-source ──────────────────────────────────────────────── */
    let src_path: u64 = iii_lex_read_u64_c(positionals, 0u64)
    iii_lex_free_c(positionals)
    iii_lex_write_u64_c(&ORCH as u64, O_SRC_PATH, src_path)
    if iii_lex_read_u64_c(&ORCH as u64, O_OUT_PATH) == 0u64 {
        let ring: u32 = iii_lex_read_u32_c(&ORCH as u64, O_RING)
        if iii_lex_read_u32_c(&ORCH as u64, O_COMPILE_ONLY) == 1u32 { iiim_path_suffix(&DEFAULT_OUT as u64, src_path, ".o" as u64, 2u64) }
        if iii_lex_read_u32_c(&ORCH as u64, O_COMPILE_ONLY) == 0u32 {
            if ring == RING_CHOICE_R3 { iiim_path_suffix(&DEFAULT_OUT as u64, src_path, ".exe" as u64, 4u64) }
            if ring == RING_CHOICE_R0 { iiim_path_suffix(&DEFAULT_OUT as u64, src_path, ".sys" as u64, 4u64) }
            if ring == RING_CHOICE_RM1 { iiim_path_suffix(&DEFAULT_OUT as u64, src_path, ".bin" as u64, 4u64) }
            if ring == RING_CHOICE_RM2 { iiim_path_suffix(&DEFAULT_OUT as u64, src_path, ".sanctum.o" as u64, 10u64) }
        }
        iii_lex_write_u64_c(&ORCH as u64, O_OUT_PATH, &DEFAULT_OUT as u64)
    }
    let out_path: u64 = iii_lex_read_u64_c(&ORCH as u64, O_OUT_PATH)
    let rc: u32 = iii_run_pipeline(src_path, out_path)
    if rc != III_EXIT_OK { return rc }
    if iii_lex_read_u32_c(&ORCH as u64, O_RUN_MHASH_VALID) == 1u32 {
        iii_lex_memcpy_c(&ORCH as u64 + O_OUT_MHASH, &ORCH as u64 + O_RUN_MHASH, 32u64)
        iii_lex_write_u32_c(&ORCH as u64, O_OUT_MHASH_VALID, 1u32)
        iii_lex_memcpy_c(&SAVE_MH1 as u64, &ORCH as u64 + O_RUN_MHASH, 32u64)
    }
    /* reproducibility check. */
    if iii_lex_read_u32_c(&ORCH as u64, O_REPRO) == 1u32 {
        iiim_path_suffix(&REPRO_OUT as u64, out_path, ".repro" as u64, 6u64)
        let rc2: u32 = iii_run_pipeline(src_path, &REPRO_OUT as u64)
        if rc2 != III_EXIT_OK { return rc2 }
        let mut same: u32 = 1u32
        if iii_lex_read_u32_c(&ORCH as u64, O_RUN_MHASH_VALID) == 0u32 { same = 0u32 }
        let mut k: u64 = 0u64
        while k < 32u64 {
            if iii_lex_read_u8_at_c(&SAVE_MH1 as u64, k) != iii_lex_read_u8_at_c(&ORCH as u64 + O_RUN_MHASH, k) { same = 0u32 ; k = 32u64 }
            if same == 1u32 { k = k + 1u64 }
        }
        if same == 0u32 {
            mw_lit(iii_lex_stderr_c(), "iiis-0: REPRODUCIBILITY CHECK FAILED - mhash differs\n" as u64, 53u64)
            return III_EXIT_REPRO_MISMATCH
        }
        mw_lit(iii_lex_stderr_c(), "iiis-0: reproducibility check PASSED\n" as u64, 37u64)
    }
    /* build-witness sidecar. */
    if iii_lex_read_u32_c(&ORCH as u64, O_EMIT_WITNESS) == 1u32 {
        let fmt: u32 = iii_ring_to_fmt(iii_lex_read_u32_c(&ORCH as u64, O_RING))
        iiim_path_suffix(&WP_BUF as u64, out_path, ".witness.json" as u64, 13u64)
        let wrc: u32 = iii_witness_write(&WP_BUF as u64, fmt)
        if wrc != III_EXIT_OK { return wrc }
    }
    /* --print-mhash. */
    if iii_lex_read_u32_c(&ORCH as u64, O_PRINT_MHASH) == 1u32 {
        if iii_lex_read_u32_c(&ORCH as u64, O_OUT_MHASH_VALID) == 0u32 {
            mw_lit(iii_lex_stderr_c(), "iiis-0: output mhash unavailable\n" as u64, 33u64)
            return III_EXIT_INTERNAL
        }
        iii_mhash_to_hex(&ORCH as u64 + O_OUT_MHASH, &HEX_OUT as u64)
        mw_cstr(iii_lex_stdout_c(), &HEX_OUT as u64)
        iii_lex_fputc_c(10u32, iii_lex_stdout_c())
    }
    iii_lex_write_u32_c(&ORCH as u64, O_SEALED, 1u32)
    return III_EXIT_OK
}

const III_MAIN_VERSION: u32 = 1u32

/* CP-MAIN-001 Stage 2.4 COMPLETE: full main.c port (SHA-256 + helpers +
 * diag/ring + pipeline + witness + main/argv/dispatch/signals).  Next §2.5:
 * drop main_impl.c from build_iiis1.sh + iiis-0≡iiis-1 corpus 57/0 + reseal.
 */
