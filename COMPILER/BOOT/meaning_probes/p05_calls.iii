/* calls, recursion, forward reference, params, multi-fn */
module mp05

fn add3(a: u64, b: u64, c: u64) -> u64 { return a + b + c }

fn main() -> u64 {
    if add3(1u64, 2u64, 3u64) != 6u64 { return 1u64 }
    if fib(10u64) != 55u64 { return 2u64 }
    if fact(5u64) != 120u64 { return 3u64 }
    return 99u64
}

fn fib(n: u64) -> u64 {
    if n < 2u64 { return n }
    return fib(n - 1u64) + fib(n - 2u64)
}

fn fact(n: u64) -> u64 {
    if n == 0u64 { return 1u64 }
    return n * fact(n - 1u64)
}
