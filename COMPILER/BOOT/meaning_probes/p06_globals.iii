/* module consts + var globals + string literal address + cast chains */
module mp06

const K : u64 = 40u64
const K2 : u32 = 7u32
var G : u64
var H : u8

fn bump() -> u64 { G = G + 1u64  return G }

fn main() -> u64 {
    if K != 40u64 { return 1u64 }
    if K2 != 7u32 { return 2u64 }
    if G != 0u64 { return 3u64 }              /* zero-init */
    bump()
    bump()
    if G != 2u64 { return 4u64 }
    H = 250u8 + 10u8
    if H != 4u8 { return 5u64 }               /* u8 wrap through a global */
    let s : u64 = "abc" as u64
    if s == 0u64 { return 6u64 }
    let c0 : u8 = (s as *u8)[0u64]
    if c0 != 97u8 { return 7u64 }             /* letter a */
    let x : u64 = 300u64
    let y : u8 = x as u8                      /* 300 & 255 = 44 */
    if y != 44u8 { return 8u64 }
    let z : u64 = y as u64
    if z != 44u64 { return 9u64 }
    let w : i64 = (200u64 as i8) as i64       /* 200 -> -56 sign-extended */
    if w != 0i64 - 56i64 { return 10u64 }
    return 99u64
}
