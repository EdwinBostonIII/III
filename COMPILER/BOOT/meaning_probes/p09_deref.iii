/* addr-of local, deref read/write, pointer round-trips */
module mp09

fn main() -> u64 {
    let mut x : u64 = 5u64
    let px : u64 = &x as u64
    let v : u64 = *(px as *u64)
    if v != 5u64 { return 1u64 }
    *(px as *u64) = 11u64
    if x != 11u64 { return 2u64 }
    let mut y : u32 = 7u32
    let py : u64 = &y as u64
    *(py as *u32) = 9u32
    if y != 9u32 { return 3u64 }
    return 99u64
}
