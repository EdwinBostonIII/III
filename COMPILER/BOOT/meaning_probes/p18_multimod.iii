/* p18 -- THE LOADER (Theta-1): cross-module extern fn resolution
 * (same-dir provider), module-local globals, cross-module call arg/ret
 * adaptation, and the row-6 law read remotely through the provider's
 * exported getter. */
module mp18

extern @abi(c-msvc-x64) fn p18_mix(a: u64, b: u64) -> u64 from "lib_p18.iii"
extern @abi(c-msvc-x64) fn p18_tab(i: u64) -> u32 from "lib_p18.iii"

fn main() -> u64 {
    if p18_mix(7u64, 4u64) != 25u64 { return 1u64 }
    if p18_mix(0u64, 9u64) != 9u64 { return 2u64 }
    if p18_tab(0u64) != 11u32 { return 3u64 }
    if p18_tab(1u64) != 22u32 { return 4u64 }
    if p18_tab(2u64) != 0u32 { return 5u64 }
    if p18_tab(3u64) != 0u32 { return 6u64 }
    return 99u64
}
