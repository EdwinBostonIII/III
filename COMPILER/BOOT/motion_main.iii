fn ps(s: u64) -> u32 { let p : *u8 = s as *u8   let mut i : u64 = 0u64   while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }   return 1u32 }
fn pu(v: u64) -> u32 { if v >= 10u64 { pu(v / 10u64) }   putchar((48u64 + (v % 10u64)) as i32)   return 1u32 }
fn pi(v: i64) -> u32 { if v < 0i64 { putchar(45i32)   pu((0i64 - v) as u64) } else { pu(v as u64) }   return 1u32 }
fn streq(a: u64, b: u64) -> u32 {
    let pa : *u8 = a as *u8   let pb : *u8 = b as *u8   let mut i : u64 = 0u64
    while pa[i] != 0u8 { if pa[i] != pb[i] { return 0u32 }   i = i + 1u64 }
    if pb[i] != 0u8 { return 0u32 }
    return 1u32
}
fn parse_i64(s: u64) -> i64 {
    let p : *u8 = s as *u8   let mut i : u64 = 0u64   let mut neg : i64 = 1i64
    if p[0u64] == 45u8 { neg = 0i64 - 1i64   i = 1u64 }
    let mut v : i64 = 0i64
    while p[i] >= 48u8 { if p[i] <= 57u8 { v = (v * 10i64) + ((p[i] - 48u8) as i64)   i = i + 1u64 } else { i = i + 1u64 } }
    return v * neg
}
/* load two bodies from argv[base..base+14): ax ay az avx avy avz ar  bx ... br */
fn load_pair(argc: i32, argv: u64, base: u64) -> u32 {
    let av : *u64 = argv as *u64
    if (base as i64) + 14i64 > (argc as i64) { return 0u32 }
    xm_reset()
    xm_add(parse_i64(av[base]), parse_i64(av[base+1u64]), parse_i64(av[base+2u64]),
           parse_i64(av[base+3u64]), parse_i64(av[base+4u64]), parse_i64(av[base+5u64]), parse_i64(av[base+6u64]))
    xm_add(parse_i64(av[base+7u64]), parse_i64(av[base+8u64]), parse_i64(av[base+9u64]),
           parse_i64(av[base+10u64]), parse_i64(av[base+11u64]), parse_i64(av[base+12u64]), parse_i64(av[base+13u64]))
    return 1u32
}
/* bracket the entry TOI to 1/scale by binary search over p in [0, hi*scale]:
 * prints the exact rational lower bound floor(t* * scale)/scale as p/scale. */
fn print_toi_bracket(scale: i64) -> u32 {
    let mut plo : i64 = 0i64
    let mut phi : i64 = scale
    while xm_toi_vs_rat(0u64, 1u64, phi, scale) == 1i32 { plo = phi   phi = phi * 2i64   if phi > 1000000000i64 { return 0u32 } }
    while plo + 1i64 < phi {
        let mid : i64 = (plo + phi) / 2i64
        if xm_toi_vs_rat(0u64, 1u64, mid, scale) == 1i32 { plo = mid } else { phi = mid }
    }
    ps("  t* in [ " as u64)   pi(plo)   ps("/" as u64)   pi(scale)   ps(" , " as u64)   pi(phi)   ps("/" as u64)   pi(scale)   ps(" ]\n" as u64)
    return 1u32
}

/* ==================== the two canonical gases ==================== */
/* the surd chain: e1 mints sqrt(4800); the stationary C on A's post-impact
 * surd worldline makes e2's root a NESTED radical (tower height >= 2). */
fn gas_surd() -> u64 {
    kn_reset()
    kn_add(0i64,0i64,0i64,   10i64,0i64,0i64, 1i64, 1i64)
    kn_add(10i64,1i64,0i64,  0i64-10i64,0i64,0i64, 1i64, 1i64)
    kn_add(0i64-1i64,0i64-11i64,0i64,  0i64,0i64,0i64, 2i64, 1i64)
    return kn_run(4u64)
}
/* the rational 3-collision chain (t = 4, 13/2, 9): the echo's forward leg */
fn gas_chain() -> u64 {
    kn_reset()
    kn_add(0i64,0i64,0i64,  2i64,0i64,0i64, 1i64, 1i64)
    kn_add(10i64,0i64,0i64, 0i64,0i64,0i64, 1i64, 1i64)
    kn_add(30i64,0i64,0i64, 0i64-2i64,0i64,0i64, 1i64, 1i64)
    return kn_run(10u64)
}
fn print_events(base: u64, n: u64, name: u64) -> u32 {
    let mut k : u64 = base
    while k < base + n {
        ps("  " as u64)   ps(name)   ps(" " as u64)   pu(k - base + 1u64)
        ps("  pair(" as u64)   pu(kn_ei(k))   ps("," as u64)   pu(kn_ej(k))   ps(")" as u64)
        if kn_ekind(k) == 2u64 { ps("  GRAZE" as u64) } else { ps("  hit  " as u64) }
        ps("  t in [" as u64)   pi(kn_blo(k))   ps("/10000, " as u64)   pi(kn_bhi(k))   ps("/10000]" as u64)
        ps("  H=" as u64)   pu(kn_eh(k))
        putchar(10i32)
        k = k + 1u64
    }
    return 1u32
}

/* ==================== the EIDOLOS voice ==================== */
var MM_SCR : [u8; 6144]
var MM_SN : u64 = 0u64
var MM_TA : [u8; 96]
var MM_TAN : u64 = 0u64
var MM_TB : [u8; 96]
var MM_TBN : u64 = 0u64
var MM_SEL : u64 = 0u64                  /* 0 -> scroll, 1 -> TA, 2 -> TB       */
fn wb(c: u8) -> i32 {
    if MM_SEL == 0u64 { if MM_SN < 6144u64 { MM_SCR[MM_SN] = c   MM_SN = MM_SN + 1u64 } }
    if MM_SEL == 1u64 { if MM_TAN < 96u64 { MM_TA[MM_TAN] = c   MM_TAN = MM_TAN + 1u64 } }
    if MM_SEL == 2u64 { if MM_TBN < 96u64 { MM_TB[MM_TBN] = c   MM_TBN = MM_TBN + 1u64 } }
    return 0i32
}
fn wstr(s: u64) -> i32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { wb(p[i])   i = i + 1u64 }
    return 0i32
}
fn wu(v: u64) -> i32 {
    if v >= 10u64 { wu(v / 10u64) }
    wb((48u64 + (v % 10u64)) as u8)
    return 0i32
}
/* thing text: <name> <seq> pair <i> <j> at <lo>:10000 */
fn wthing(name: u64, seq: u64, i: u64, j: u64, lo: i64) -> i32 {
    wstr(name)   wb(32u8)   wu(seq)
    wstr(" pair " as u64)   wu(i)   wb(32u8)   wu(j)
    wstr(" at " as u64)   wu(lo as u64)   wb(58u8)   wu(10000u64)
    return 0i32
}
fn wthing_ev(name: u64, base: u64, k: u64) -> i32 {
    return wthing(name, k - base + 1u64, kn_ei(k), kn_ej(k), kn_blo(k))
}
fn mk_frac(n: i64, d: i64) -> u64 {
    return py_el_from_rat(py_rat_frac(n, d), 0u64)
}
fn wclaim_open() -> i32 { wb(91u8)   return 0i32 }
fn wclaim_verb(c: u8) -> i32 { wb(32u8)   wb(c)   wb(32u8)   return 0i32 }
fn wclaim_close() -> i32 { wb(93u8)   wb(32u8)   return 0i32 }
fn print_out() -> u32 {
    eol_write()
    let n : u64 = eol_out_len()
    let mut i : u64 = 0u64
    while i < n {
        putchar(eol_out_byte(i) as i32)
        i = i + 1u64
    }
    putchar(10i32)
    return 1u32
}

fn usage() -> u64 {
    ps("iii motion -- GAMMA-MOTION + THE KINETIC SCROLL: exact impacts, the\n" as u64)
    ps("constructible tower, the event fold past irrational impacts, the EIDOLOS voice.\n\n" as u64)
    ps("  iii motion prove       full self-proof (arms 170..179, 180..187, 190..196)\n" as u64)
    ps("  iii motion toi     <ax ay az avx avy avz ar>  <bx by bz bvx bvy bvz br>\n" as u64)
    ps("  iii motion respond <14 ints>   exact elastic response (equal mass)\n" as u64)
    ps("  iii motion scroll      fold the surd chain PAST its radicals (nested tower)\n" as u64)
    ps("  iii motion echo        the Loschmidt echo: exact return to the genesis\n" as u64)
    ps("  iii motion speak       the fold as EIDOLOS; the mirror law derives the echo\n" as u64)
    ps("  iii motion ballistic   uniform gravity: parabolic worldlines, exact echo\n" as u64)
    ps("  iii motion quartic     per-body acceleration: exact Sturm trichotomy + bracket\n\n" as u64)
    ps("exit: 0 ok | 1 miss | 3 usage | 9 SELF-REFUSED\n" as u64)
    return 3u64
}
fn motion_enter(argc: i32, argv: u64) -> u64 @export {
    let av : *u64 = argv as *u64
    if argc < 2i32 { return usage() }
    let sp : u64 = xm_selfprove()
    if sp != 0u64 {
        ps("MOTION REFUSES ITSELF: exact_motion arm " as u64)   pu(sp)   ps(" failed\n" as u64)
        return 9u64
    }
    let sp2 : u64 = py_selfprove()
    if sp2 != 0u64 {
        ps("MOTION REFUSES ITSELF: pyrgos arm " as u64)   pu(sp2)   ps(" failed\n" as u64)
        return 9u64
    }
    let sp3 : u64 = kn_selfprove()
    if sp3 != 0u64 {
        ps("MOTION REFUSES ITSELF: kinesis arm " as u64)   pu(sp3)   ps(" failed\n" as u64)
        return 9u64
    }
    let cmd : u64 = av[1u64]
    if streq(cmd, "ballistic" as u64) == 1u32 {
        ps("BALLISTICS, EXACT: the uniform field cancels in every pairwise\n" as u64)
        ps("separation, so gravity costs the fold NOTHING -- impacts stay surds,\n" as u64)
        ps("worldlines become exact parabolas, and time reversal still returns\n" as u64)
        ps("the integer genesis.\n\n" as u64)
        ps("  g = (0,-2);  A falls from rest at y=10;  B rises at 3 from y=0.\n" as u64)
        ps("  contact at the exact rational t = 8/3; the at-impact velocities\n" as u64)
        ps("  -16/3 and -7/3 EXCHANGE (equal masses):\n\n" as u64)
        kn_reset()
        kn_setg(0i64, 0i64 - 2i64, 0i64, 1i64)
        kn_add(0i64,10i64,0i64, 0i64,0i64,0i64, 1i64, 1i64)
        kn_add(0i64,0i64,0i64,  0i64,3i64,0i64, 1i64, 1i64)
        let n : u64 = kn_run(4u64)
        print_events(0u64, n, "impact" as u64)
        let e : u64 = kn_echo(3i64)
        let n2 : u64 = kn_evn() - n
        print_events(n, n2, "echo  " as u64)
        putchar(10i32)
        if e == 0u64 {
            ps("  THE BALLISTIC ECHO: the parabolas retraced to the exact genesis.  0 drift.\n" as u64)
        } else {
            ps("  ECHO BROKE at check " as u64)   pu(e)   putchar(10i32)
            return 1u64
        }
        ps("  conservation breaks = " as u64)   pu(kn_lawviol())
        ps("   tower height = " as u64)   pu(py_h())
        ps("   refusals = " as u64)   pu(py_err())   putchar(10i32)
        if kn_lawviol() != 0u64 { return 1u64 }
        if py_err() != 0u64 { return 1u64 }
        return 0u64
    }
    if streq(cmd, "quartic" as u64) == 1u32 {
        ps("THE QUARTIC ORACLE: per-body acceleration makes the separation a\n" as u64)
        ps("QUARTIC whose roots are generally NOT constructible (the resolvent\n" as u64)
        ps("cubic demands cube roots) -- no tower can HOLD them.  III still\n" as u64)
        ps("DECIDES them: a Sturm chain with tower-element coefficients and\n" as u64)
        ps("exact field-division remainders counts and brackets every root.\n\n" as u64)
        ps("  A at rest at 0 accelerating +x at 2;  B at rest at 10;  r = 1 each.\n" as u64)
        ps("  4*sep2 = 4 t^4 - 80 t^2 + 384:  first contact t = sqrt8, exit t = sqrt12.\n\n" as u64)
        kn_reset()
        kn_add(0i64,0i64,0i64,  0i64,0i64,0i64, 1i64, 1i64)
        kn_add(10i64,0i64,0i64, 0i64,0i64,0i64, 1i64, 1i64)
        kn_seta(0u64, 2i64, 0i64, 0i64)
        let m : u64 = py_mark()
        kq_build(0u64, 1u64)
        ps("  roots in (0,2] = " as u64)   pi(kq_count(0i64,1i64, 2i64,1i64))
        ps("   in (0,3] = " as u64)   pi(kq_count(0i64,1i64, 3i64,1i64))
        ps("   in (0,4] = " as u64)   pi(kq_count(0i64,1i64, 4i64,1i64))
        ps("   degenerate = " as u64)   pu(kq_degen())   putchar(10i32)
        kq_bracket(4i64)
        ps("  first impact bracketed: t in [" as u64)   pi(kq_blo2())
        ps("/10000, " as u64)   pi(kq_bhi2())   ps("/10000]\n" as u64)
        let blo : i64 = kq_blo2()
        py_release(m)
        ps("\n  the INDEPENDENT path: the tower surd sqrt8 (norm descent, no Sturm):\n" as u64)
        let r8 : u64 = py_sqrt(py_el_from_i64(8i64, 0u64))
        let agree1 : i64 = py_cmp(r8, mk_frac(28284i64, 10000i64))
        let agree2 : i64 = py_cmp(r8, mk_frac(28285i64, 10000i64))
        ps("    sqrt8 > 28284/10000 : " as u64)   if agree1 == 1i64 { ps("yes\n" as u64) } else { ps("NO\n" as u64) }
        ps("    sqrt8 < 28285/10000 : " as u64)   if agree2 == (0i64 - 1i64) { ps("yes\n" as u64) } else { ps("NO\n" as u64) }
        if blo == 28284i64 { ps("  TWO PATHS, ONE BRACKET: Sturm count and norm descent agree exactly.\n" as u64) } else { ps("  DISAGREEMENT\n" as u64)   return 1u64 }
        if py_err() != 0u64 { return 1u64 }
        return 0u64
    }
    if streq(cmd, "prove" as u64) == 1u32 {
        ps("THE KINETIC SCROLL PROVEN (arms 170..179 + 180..188 + 190..199):\n" as u64)
        ps("  exact_motion   the exact surd TOI, ordered, no tunneling (170..179)\n" as u64)
        ps("  pyrgos         the constructible tower: nested radicals EXACT at any\n" as u64)
        ps("                 depth -- sqrt2+sqrt3-sqrt(5+2sqrt6) DECIDED zero; 125\n" as u64)
        ps("                 flat cases cross-agree with the separation-bound oracle;\n" as u64)
        ps("                 total sign, total inverse, watermark pools; the\n" as u64)
        ps("                 DENESTING ORACLE keeps the spine minimal -- sqrt6,\n" as u64)
        ps("                 sqrt(3+2sqrt2) recognized, sqrt(2+sqrt2) proven\n" as u64)
        ps("                 independent (180..188)\n" as u64)
        ps("  kinesis        the event fold PAST irrational impacts: the rational\n" as u64)
        ps("                 3-chain lands t = 4, 13/2, 9; the surd chain mints a\n" as u64)
        ps("                 NESTED radical; the Loschmidt echo returns the exact\n" as u64)
        ps("                 integer genesis WITHOUT growing the tower (the denest\n" as u64)
        ps("                 law); simultaneity DETECTED; the graze exchanges\n" as u64)
        ps("                 nothing; conservation exact at every event; GENERAL\n" as u64)
        ps("                 MASSES; uniform gravity folds exactly (the ballistic\n" as u64)
        ps("                 echo); the quartic Sturm oracle two-paths against the\n" as u64)
        ps("                 tower surd; deterministic (190..199)\n" as u64)
        return 0u64
    }
    if streq(cmd, "toi" as u64) == 1u32 {
        if load_pair(argc, argv, 2u64) != 1u32 { return usage() }
        let h : i32 = xm_hit(0u64, 1u64)
        if h == -2i32 { ps("DEGENERATE: no relative motion (A = 0) -- the worldlines are parallel.\n" as u64)   return 1u64 }
        let d : i64 = xm_disc(0u64, 1u64)
        ps("A = " as u64)  pi(xm_getA())  ps("   B = " as u64)  pi(xm_getB())  ps("   C = " as u64)  pi(xm_getC())
        ps("   discriminant Delta = " as u64)  pi(d)  putchar(10i32)
        if h == -1i32 { ps("MISS: Delta < 0 -- the worldlines never touch.\n" as u64)   return 1u64 }
        if h == 0i32 {
            xm_graze_time(0u64, 1u64)
            ps("GRAZE: Delta = 0 -- tangent contact at the exact rational t* = " as u64)
            pi(xm_graze_num())  ps("/" as u64)  pi(xm_graze_den())  putchar(10i32)
            return 0u64
        }
        let sq : i64 = xm_isqrt_floor(d)
        if sq * sq == d {
            ps("HIT (rational): t* = (" as u64)  pi(0i64 - xm_getB())  ps(" - " as u64)  pi(sq)
            ps(") / " as u64)  pi(2i64 * xm_getA())  ps("   -- an exact rational impact\n" as u64)
        } else {
            ps("HIT (surd): t* = (" as u64)  pi(0i64 - xm_getB())  ps(" - sqrt(" as u64)  pi(d)
            ps(")) / " as u64)  pi(2i64 * xm_getA())  ps("   -- an exact IRRATIONAL impact (choreo refuses this)\n" as u64)
        }
        print_toi_bracket(1000i64)
        return 0u64
    }
    if streq(cmd, "respond" as u64) == 1u32 {
        if load_pair(argc, argv, 2u64) != 1u32 { return usage() }
        if xm_respond(0u64, 1u64) != 1i32 { ps("COINCIDENT: no contact normal (bodies share a centre).\n" as u64)   return 1u64 }
        let dd : i64 = xm_rd()
        ps("exact elastic response (equal masses), post-collision velocities over " as u64)  pi(dd)  ps(":\n" as u64)
        ps("  body A' = ( " as u64)  pi(xm_rv(0u64))  ps(" , " as u64)  pi(xm_rv(1u64))  ps(" , " as u64)  pi(xm_rv(2u64))  ps(" ) / " as u64)  pi(dd)  putchar(10i32)
        ps("  body B' = ( " as u64)  pi(xm_rv(3u64))  ps(" , " as u64)  pi(xm_rv(4u64))  ps(" , " as u64)  pi(xm_rv(5u64))  ps(" ) / " as u64)  pi(dd)  putchar(10i32)
        ps("  (momentum conserved: A'+B' == A+B, exactly)\n" as u64)
        return 0u64
    }
    if streq(cmd, "scroll" as u64) == 1u32 {
        ps("THE KINETIC SCROLL: the fold does not stop at the first surd.\n\n" as u64)
        ps("  A(0,0) -> +x at 10;  B(10,1) -> -x at 10;  C(-1,-11) at rest, r=2.\n" as u64)
        ps("  event 1 mints sqrt(4800): t1 = (10 - sqrt3)/20, IRRATIONAL; the state\n" as u64)
        ps("  moves into Q(sqrt(Delta1)); event 2's discriminant lives in that field\n" as u64)
        ps("  and its root is a NESTED radical no flat oracle accepts.  The fold\n" as u64)
        ps("  continues exactly:\n\n" as u64)
        let n : u64 = gas_surd()
        print_events(0u64, n, "event" as u64)
        putchar(10i32)
        ps("  events folded          = " as u64)   pu(n)   putchar(10i32)
        ps("  tower height (spine)   = " as u64)   pu(py_h())   ps("   (nested radicals minted)\n" as u64)
        ps("  conservation breaks    = " as u64)   pu(kn_lawviol())   ps("   (momentum + energy, EXACT, per event)\n" as u64)
        ps("  causal order breaks    = " as u64)   pu(kn_ordviol())   putchar(10i32)
        ps("  exact ties detected    = " as u64)   pu(kn_tie())   putchar(10i32)
        ps("  pools: limbs " as u64)   pu(py_ltop())   ps(" / rats " as u64)   pu(py_rtop())
        ps(" / elems " as u64)   pu(py_etop())   ps("   refusals = " as u64)   pu(py_err())   putchar(10i32)
        if kn_lawviol() != 0u64 { return 1u64 }
        if py_err() != 0u64 { return 1u64 }
        return 0u64
    }
    if streq(cmd, "echo" as u64) == 1u32 {
        ps("THE LOSCHMIDT ECHO: time reversal is EXACT, not approximate.\n\n" as u64)
        ps("  the rational 3-chain folds forward (t = 4, 13/2, 9); at t = 10 every\n" as u64)
        ps("  velocity is negated; the fold runs FORWARD again; at t = 20 velocities\n" as u64)
        ps("  are negated once more.  A float engine returns near the start.  III\n" as u64)
        ps("  returns THE start -- every coordinate exactly the integer genesis.\n\n" as u64)
        let n1 : u64 = gas_chain()
        print_events(0u64, n1, "impact" as u64)
        let e : u64 = kn_echo(10i64)
        let n2 : u64 = kn_evn() - n1
        print_events(n1, n2, "echo  " as u64)
        putchar(10i32)
        if e == 0u64 {
            ps("  EXACT RECOVERY: every position and velocity equals the genesis.  0 drift.\n" as u64)
        } else {
            ps("  ECHO BROKE at check " as u64)   pu(e)   putchar(10i32)
            return 1u64
        }
        ps("  conservation breaks = " as u64)   pu(kn_lawviol())   ps("   refusals = " as u64)   pu(py_err())   putchar(10i32)
        if kn_lawviol() != 0u64 { return 1u64 }
        if py_err() != 0u64 { return 1u64 }
        return 0u64
    }
    if streq(cmd, "speak" as u64) == 1u32 {
        /* movement I: the surd chain speaks its causal order with exact brackets */
        ps("MOVEMENT I -- the surd chain speaks (each time is the exact bracket):\n\n" as u64)
        let n : u64 = gas_surd()
        eol_reset()
        MM_SEL = 0u64   MM_SN = 0u64
        let mut k : u64 = 0u64
        while k + 1u64 < n {
            if kn_estrict(k + 1u64) == 1u64 {
                wclaim_open()
                wthing_ev("impact" as u64, 0u64, k)
                wclaim_verb(60u8)
                wthing_ev("impact" as u64, 0u64, k + 1u64)
                wclaim_close()
            }
            k = k + 1u64
        }
        let r1 : i64 = eol_read((&MM_SCR) as u64, MM_SN)
        let law1 : u64 = eol_lawcheck()
        ps("  " as u64)   print_out()
        ps("\n  claims stated = " as u64)   pi(r1)
        ps("   coherent = " as u64)   if law1 == 0u64 { ps("YES" as u64) } else { ps("NO" as u64) }
        ps("   scroll address = " as u64)   pu(eol_addr())   putchar(10i32)
        ps("  tower height reached = " as u64)   pu(py_h())   putchar(10i32)
        /* movement II: the echo -- state the forward chain and the mirror pairs
         * ONLY; the echo's own causal order is stated by NO ONE */
        ps("\nMOVEMENT II -- the echo: forward chain + mirror pairs stated; the\n" as u64)
        ps("echo's causality stated by NO claim:\n\n" as u64)
        let n1 : u64 = gas_chain()
        let e : u64 = kn_echo(10i64)
        let n2 : u64 = kn_evn() - n1
        eol_reset()
        MM_SEL = 0u64   MM_SN = 0u64
        k = 0u64
        while k + 1u64 < n1 {
            wclaim_open()
            wthing_ev("impact" as u64, 0u64, k)
            wclaim_verb(60u8)
            wthing_ev("impact" as u64, 0u64, k + 1u64)
            wclaim_close()
            k = k + 1u64
        }
        k = 0u64
        while k < n1 {
            if k < n2 {
                wclaim_open()
                wthing_ev("impact" as u64, 0u64, k)
                wclaim_verb(126u8)
                wthing_ev("echo" as u64, n1, n1 + (n1 - 1u64 - k))
                wclaim_close()
            }
            k = k + 1u64
        }
        let r2 : i64 = eol_read((&MM_SCR) as u64, MM_SN)
        let law2 : u64 = eol_lawcheck()
        ps("  " as u64)   print_out()
        ps("\n  echo exact recovery = " as u64)   if e == 0u64 { ps("YES" as u64) } else { ps("NO" as u64) }
        ps("   claims stated = " as u64)   pi(r2)
        ps("   coherent = " as u64)   if law2 == 0u64 { ps("YES" as u64) } else { ps("NO" as u64) }
        putchar(10i32)
        /* movement III: ask the language what physics implied.  The mirror law
         * (~ reverses <) must DERIVE the echo causality. */
        ps("\nMOVEMENT III -- the derivation (asked, never stated):\n\n" as u64)
        MM_SEL = 1u64   MM_TAN = 0u64
        wthing_ev("echo" as u64, n1, n1)                       /* echo 1 (earliest) */
        MM_SEL = 2u64   MM_TBN = 0u64
        wthing_ev("echo" as u64, n1, n1 + 1u64)                /* echo 2            */
        let q1 : u64 = eol_entails((&MM_TA) as u64, MM_TAN, 0u64, (&MM_TB) as u64, MM_TBN)
        ps("  [echo 1 < echo 2] ? " as u64)
        if q1 == 1u64 { ps("DERIVED" as u64) } else { if q1 == 0u64 { ps("not entailed" as u64) } else { ps("refused" as u64) } }
        putchar(10i32)
        MM_SEL = 2u64   MM_TBN = 0u64
        wthing_ev("echo" as u64, n1, n1 + 2u64)                /* echo 3 (latest)   */
        let q2 : u64 = eol_entails((&MM_TA) as u64, MM_TAN, 0u64, (&MM_TB) as u64, MM_TBN)
        ps("  [echo 1 < echo 3] ? " as u64)
        if q2 == 1u64 { ps("DERIVED (transitively)" as u64) } else { if q2 == 0u64 { ps("not entailed" as u64) } else { ps("refused" as u64) } }
        putchar(10i32)
        let q3 : u64 = eol_entails((&MM_TB) as u64, MM_TBN, 0u64, (&MM_TA) as u64, MM_TAN)
        ps("  [echo 3 < echo 1] ? " as u64)
        if q3 == 1u64 { ps("claimed (WRONG)" as u64) } else { if q3 == 0u64 { ps("NOT entailed (the negative control holds)" as u64) } else { ps("refused" as u64) } }
        putchar(10i32)
        putchar(10i32)
        ps("  the fold stated the FORWARD order and the mirror pairs.  EIDOLOS's own\n" as u64)
        ps("  law (a mirror REVERSES under) derived the echo's causality -- language\n" as u64)
        ps("  and physics agree about time reversal, and neither copied the other.\n" as u64)
        if q1 != 1u64 { return 1u64 }
        if q2 != 1u64 { return 1u64 }
        if q3 == 1u64 { return 1u64 }
        if e != 0u64 { return 1u64 }
        return 0u64
    }
    return usage()
}
