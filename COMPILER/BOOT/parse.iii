/* ============================================================================
 * parse.iii - Stage-1 .iii port of parse.c (RITCHIE Stage 2.3).
 *
 * Byte-equivalent re-implementation of the C reference parse.c (3760 LOC):
 * the recursive-descent LL(1) + Pratt operator-precedence parser over the III
 * grammar.  Mirrors lex.iii/ast.iii discipline: the opaque iii_parse_state
 * lives in a malloc'd block accessed by byte offset (iiis-0 cannot deref C
 * structs); it embeds two 104-byte iii_token_t lookahead buffers, the heap
 * error queue (48-byte iii_parse_error_t entries), the breadcrumb LIFO, the
 * 112-byte witness SHA-256 context (lex_runtime's iii_sha256, no 7th copy),
 * the fn-pointer witness/Pratt sinks, the three registry tables, dedup state,
 * and the orphan-range array.  Drives the now-real lex.iii (iii_lex_next/
 * error_info) and builds via the now-real ast.iii (alloc_node/get/
 * position_first).  parse_state is opaque to callers (parse.c defines it in
 * the .c, not parse.h), so this layout is self-chosen; only the PUBLIC
 * iii_parse_error_t (48B) + iii_parse_binop_info_t (16B) structs and the
 * callback signatures bind to parse.c (CONVERGENCE-AUDIT S2.3-interface).
 *
 * iiis-0 trap discipline: single-line fn decls, params->locals to dodge the
 * 5+-arg spill trap, no break/continue (sentinel flags), unsigned ordering
 * only (no signed i32/i64 < > <= >=), ASCII comments, balanced slash-star.
 * RITCHIE Stage 2.3.1 = the parser state-machine foundation.
 * ============================================================================ */

module parse

/* --- generic C-side runtime helpers (shared with lex.iii/ast.iii) -------- */
extern @abi(c-msvc-x64) fn iii_lex_malloc_c(n: u64) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_free_c(p: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_read_u8_at_c(addr: u64, off: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_write_u8_at_c(addr: u64, off: u64, v: u32) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_read_u32_c(addr: u64, off: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_write_u32_c(addr: u64, off: u64, v: u32) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_read_u64_c(addr: u64, off: u64) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_write_u64_c(addr: u64, off: u64, v: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_memcpy_c(dst: u64, src: u64, n: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_memset_c(dst: u64, v: u32, n: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_sha256_init(s: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_sha256_update(s: u64, data: u64, n: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_sha256_final(s: u64, out32: u64) -> u32 from "lex_runtime.c"
/* --- lexer (lex.iii @exports) -------------------------------------------- */
extern @abi(c-msvc-x64) fn iii_lex_next(st: u64, out: u64) -> i32 from "lex.iii"
extern @abi(c-msvc-x64) fn iii_lex_error_info(st: u64, out_err: u64) -> u32 from "lex.iii"
/* --- ast (ast.iii @exports) ---------------------------------------------- */
extern @abi(c-msvc-x64) fn iii_ast_get(ast: u64, node_index: u32) -> u64 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_alloc_node(ast: u64, kind: u32, pos: u64) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_position_first(ast: u64, node_index: u32, out: u64) -> i32 from "ast.iii"

/* --- parse error codes (parse.h:40-64) ----------------------------------- */
const III_PARSE_OK: u32 = 0u32
const III_PARSE_E_LEX: u32 = 10u32
const III_PARSE_E_OOM: u32 = 11u32
const III_PARSE_E_ERRORS_TRUNCATED: u32 = 15u32

/* --- constants (parse.c:242-247) ----------------------------------------- */
const III_PARSE_MAX_DEPTH: u32 = 512u32
const III_PARSE_INIT_ERRORS: u32 = 32u32
const III_PARSE_HARD_ERR_CAP: u32 = 65536u32
const III_PARSE_DUP_THRESHOLD: u32 = 3u32
const III_PARSE_BREADCRUMB_CAP: u32 = 64u32

/* --- token / error / position struct offsets (offsetof-verified) --------- */
const TOK_BYTES: u64 = 104u64
const TOK_KIND: u64 = 0u64
const TOK_START: u64 = 4u64
const TOK_END: u64 = 8u64
const TOK_LINE: u64 = 12u64
const TOK_COL: u64 = 16u64
const PARSE_TOK_INVALID: u32 = 0u32
const PERR_BYTES: u64 = 48u64
const PE_CODE: u64 = 0u64
const PE_BYTE: u64 = 4u64
const PE_LINE: u64 = 8u64
const PE_COL: u64 = 12u64
const PE_MESSAGE: u64 = 16u64
const PE_SAW: u64 = 24u64
const PE_EXPECTED: u64 = 28u64
const PE_BREADCRUMB: u64 = 32u64
const PE_DUP: u64 = 40u64
const LE_MESSAGE: u64 = 16u64
const LERR_BYTES: u64 = 24u64
const APOS_KIND: u64 = 0u64
const APOS_PHYS_START: u64 = 4u64
const APOS_PHYS_END: u64 = 8u64
const III_POS_PHYSICAL_P: u32 = 0u32

/* --- prod ids (parse.c:250-287; MODULE=0 .. HEXAD=31, COUNT=32) ---------- */
const IIIP_PROD_PAREN_EXPR: u32 = 21u32
const IIIP_PROD_CYCLE_DECL: u32 = 3u32
const IIIP_PROD_FN_DECL: u32 = 4u32
const IIIP_PROD_TYPE_EXPR: u32 = 15u32
const IIIP_PROD_TYPE_SIMPLE: u32 = 16u32
const IIIP_PROD_EXPR: u32 = 17u32
const IIIP_PROD_PRIMARY: u32 = 18u32
const IIIP_PROD_UNARY: u32 = 19u32
const IIIP_PROD_PATTERN: u32 = 30u32
const IIIP_PROD_BLOCK: u32 = 22u32
const IIIP_PROD_COUNT: u32 = 32u32

/* --- self-chosen parse_state layout (opaque; ~4440 bytes) ---------------- */
const PS_BYTES: u64 = 4440u64
const PS_LEX: u64 = 0u64
const PS_AST: u64 = 8u64
const PS_LA: u64 = 16u64
const PS_LA_VALID: u64 = 120u64
const PS_LA_STATUS: u64 = 124u64
const PS_LA2: u64 = 128u64
const PS_LA2_VALID: u64 = 232u64
const PS_LA2_STATUS: u64 = 236u64
const PS_ERRORS: u64 = 240u64
const PS_ERR_COUNT: u64 = 248u64
const PS_ERR_CAP: u64 = 252u64
const PS_ERR_TRUNC: u64 = 256u64
const PS_DEPTH: u64 = 260u64
const PS_WITNESS_COMMITTED: u64 = 264u64
const PS_WITNESS_CTX: u64 = 272u64
const PS_WITNESS_SINK: u64 = 384u64
const PS_WITNESS_SINK_CTX: u64 = 392u64
const PS_PRATT_TRACE: u64 = 400u64
const PS_PRATT_TRACE_CTX: u64 = 408u64
const PS_LAST_ERR_CODE: u64 = 416u64
const PS_LAST_ERR_LINE: u64 = 420u64
const PS_LAST_ERR_DUPS: u64 = 424u64
const PS_BC_DEPTH: u64 = 428u64
const PS_BC_STACK: u64 = 432u64
const PS_BC_DETAIL: u64 = 688u64
const PS_ORPHAN_COUNT: u64 = 1200u64
const PS_ORPHAN_RANGES: u64 = 1208u64
const PS_REG_DECL: u64 = 1336u64
const PS_REG_STMT: u64 = 2368u64
const PS_REG_PRIMARY: u64 = 3400u64
const PS_REG_NEXT_HANDLE: u64 = 4432u64
const PARSE_SHA_STATE_BYTES: u64 = 112u64

/* ============================================================================
 * production-name NUL-pool (parse.c iiip_prod_name, 32 entries) + budget.
 * ============================================================================ */
var PN_POOL : [u8; 512]
var PN_OFF  : [u32; 32]
var PN_INIT : u8 = 0u8
var PN_NEXT : u64 = 0u64
var PN_DEC_SCR : [u8; 16]

fn pn_add(id: u32, lit: u64, litlen: u64) -> u32 {
    let base: u64 = (&PN_POOL as u64) + PN_NEXT
    iii_lex_memcpy_c(base, lit, litlen)
    iii_lex_write_u8_at_c(base + litlen, 0u64, 0u32)
    iii_lex_write_u32_c(&PN_OFF as u64, (id as u64) * 4u64, PN_NEXT as u32)
    PN_NEXT = PN_NEXT + litlen + 1u64
    return 0u32
}
fn pn_init() -> u32 {
    if PN_INIT == 1u8 { return 0u32 }
    pn_add(0u32, "module" as u64, 6u64)
    pn_add(1u32, "use" as u64, 3u64)
    pn_add(2u32, "top-decl" as u64, 8u64)
    pn_add(3u32, "cycle" as u64, 5u64)
    pn_add(4u32, "fn" as u64, 2u64)
    pn_add(5u32, "type-decl" as u64, 9u64)
    pn_add(6u32, "const" as u64, 5u64)
    pn_add(7u32, "extern" as u64, 6u64)
    pn_add(8u32, "mobius_candidate" as u64, 16u64)
    pn_add(9u32, "schema" as u64, 6u64)
    pn_add(10u32, "sealed_call" as u64, 11u64)
    pn_add(11u32, "param-list" as u64, 10u64)
    pn_add(12u32, "arg-list" as u64, 8u64)
    pn_add(13u32, "arg" as u64, 3u64)
    pn_add(14u32, "modifier" as u64, 8u64)
    pn_add(15u32, "type-expr" as u64, 9u64)
    pn_add(16u32, "type-simple" as u64, 11u64)
    pn_add(17u32, "expr" as u64, 4u64)
    pn_add(18u32, "primary" as u64, 7u64)
    pn_add(19u32, "unary" as u64, 5u64)
    pn_add(20u32, "postfix" as u64, 7u64)
    pn_add(21u32, "paren-expr" as u64, 10u64)
    pn_add(22u32, "block" as u64, 5u64)
    pn_add(23u32, "stmt" as u64, 4u64)
    pn_add(24u32, "let" as u64, 3u64)
    pn_add(25u32, "wavefront" as u64, 9u64)
    pn_add(26u32, "sanctum_enter" as u64, 13u64)
    pn_add(27u32, "metal" as u64, 5u64)
    pn_add(28u32, "for" as u64, 3u64)
    pn_add(29u32, "return" as u64, 6u64)
    pn_add(30u32, "pattern" as u64, 7u64)
    pn_add(31u32, "hexad" as u64, 5u64)
    PN_INIT = 1u8
    return 0u32
}
fn iiip_prod_name(p: u32) -> u64 {
    pn_init()
    if p >= IIIP_PROD_COUNT { return 0u64 }
    return (&PN_POOL as u64) + (iii_lex_read_u32_c(&PN_OFF as u64, (p as u64) * 4u64) as u64)
}
fn iiip_prod_budget(p: u32) -> u32 {
    if p == IIIP_PROD_PAREN_EXPR { return 256u32 }
    if p == IIIP_PROD_CYCLE_DECL { return 8u32 }
    if p == IIIP_PROD_FN_DECL { return 8u32 }
    if p == IIIP_PROD_TYPE_EXPR { return 128u32 }
    if p == IIIP_PROD_TYPE_SIMPLE { return 128u32 }
    if p == IIIP_PROD_EXPR { return 256u32 }
    if p == IIIP_PROD_PRIMARY { return 256u32 }
    if p == IIIP_PROD_UNARY { return 256u32 }
    if p == IIIP_PROD_PATTERN { return 128u32 }
    if p == IIIP_PROD_BLOCK { return 256u32 }
    return III_PARSE_MAX_DEPTH
}

/* ============================================================================
 * lifetime + token-stream foundation.
 * ============================================================================ */

fn iii_parse_create(lex_state: u64, ast: u64) -> u64 @export {
    if lex_state == 0u64 { return 0u64 }
    if ast == 0u64 { return 0u64 }
    let st: u64 = iii_lex_malloc_c(PS_BYTES)
    if st == 0u64 { return 0u64 }
    iii_lex_memset_c(st, 0u32, PS_BYTES)
    iii_lex_write_u64_c(st, PS_LEX, lex_state)
    iii_lex_write_u64_c(st, PS_AST, ast)
    iii_sha256_init(st + PS_WITNESS_CTX)
    return st
}

fn iii_parse_destroy(st: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    let errors: u64 = iii_lex_read_u64_c(st, PS_ERRORS)
    if errors != 0u64 { iii_lex_free_c(errors) }
    iii_lex_free_c(st)
    return 0u32
}

/* Record a III_PARSE_E_LEX from the lexer's current error info. */
fn iiip_record_lex_error(st: u64, tok: u64) -> u32 {
    let le: u64 = iii_lex_malloc_c(LERR_BYTES)
    if le == 0u64 { return 0u32 }
    iii_lex_error_info(iii_lex_read_u64_c(st, PS_LEX), le)
    iiip_record_error(st, III_PARSE_E_LEX, tok, iii_lex_read_u64_c(le, LE_MESSAGE), PARSE_TOK_INVALID)
    iii_lex_free_c(le)
    return 0u32
}

/* iiip_refill: ensure lookahead valid; returns lookahead status. */
fn iiip_refill(st: u64) -> i32 {
    if iii_lex_read_u8_at_c(st, PS_LA_VALID) != 0u32 {
        return iii_lex_read_u32_c(st, PS_LA_STATUS) as i32
    }
    if iii_lex_read_u8_at_c(st, PS_LA2_VALID) != 0u32 {
        iii_lex_memcpy_c(st + PS_LA, st + PS_LA2, TOK_BYTES)
        iii_lex_write_u32_c(st, PS_LA_STATUS, iii_lex_read_u32_c(st, PS_LA2_STATUS))
        iii_lex_write_u8_at_c(st, PS_LA_VALID, 1u32)
        iii_lex_write_u8_at_c(st, PS_LA2_VALID, 0u32)
        return iii_lex_read_u32_c(st, PS_LA_STATUS) as i32
    }
    let lex: u64 = iii_lex_read_u64_c(st, PS_LEX)
    let status: i32 = iii_lex_next(lex, st + PS_LA)
    iii_lex_write_u32_c(st, PS_LA_STATUS, status as u32)
    iii_lex_write_u8_at_c(st, PS_LA_VALID, 1u32)
    if (status as u32) >= 2147483648u32 {
        iiip_record_lex_error(st, st + PS_LA)
    }
    return status
}

fn iiip_peek(st: u64) -> u64 {
    iiip_refill(st)
    return st + PS_LA
}
fn iiip_peek_kind(st: u64) -> u32 {
    iiip_refill(st)
    return iii_lex_read_u32_c(st + PS_LA, TOK_KIND)
}
fn iiip_peek2(st: u64) -> u64 {
    iiip_refill(st)
    if iii_lex_read_u8_at_c(st, PS_LA2_VALID) == 0u32 {
        let lex: u64 = iii_lex_read_u64_c(st, PS_LEX)
        let status: i32 = iii_lex_next(lex, st + PS_LA2)
        iii_lex_write_u32_c(st, PS_LA2_STATUS, status as u32)
        iii_lex_write_u8_at_c(st, PS_LA2_VALID, 1u32)
        if (status as u32) >= 2147483648u32 {
            iiip_record_lex_error(st, st + PS_LA2)
        }
    }
    return st + PS_LA2
}
fn iiip_peek2_kind(st: u64) -> u32 {
    return iii_lex_read_u32_c(iiip_peek2(st), TOK_KIND)
}

/* Consume the lookahead into out_tok (104B); refill is lazy on next peek. */
fn iiip_advance(st: u64, out_tok: u64) -> u32 {
    iiip_refill(st)
    iii_lex_memcpy_c(out_tok, st + PS_LA, TOK_BYTES)
    iii_lex_write_u8_at_c(st, PS_LA_VALID, 0u32)
    return 0u32
}

/* ============================================================================
 * error queue (C1) + dedup (C2).
 * ============================================================================ */

fn iiip_errq_grow(st: u64) -> u32 {
    if iii_lex_read_u8_at_c(st, PS_ERR_TRUNC) != 0u32 { return 0u32 }
    let cap: u32 = iii_lex_read_u32_c(st, PS_ERR_CAP)
    let mut new_cap: u32 = III_PARSE_INIT_ERRORS
    if cap != 0u32 { new_cap = cap * 2u32 }
    if new_cap > III_PARSE_HARD_ERR_CAP { new_cap = III_PARSE_HARD_ERR_CAP }
    if new_cap == cap {
        iii_lex_write_u8_at_c(st, PS_ERR_TRUNC, 1u32)
        return 0u32
    }
    let old: u64 = iii_lex_read_u64_c(st, PS_ERRORS)
    let np: u64 = iii_lex_malloc_c((new_cap as u64) * PERR_BYTES)
    if np == 0u64 { iii_lex_write_u8_at_c(st, PS_ERR_TRUNC, 1u32) ; return 0u32 }
    iii_lex_memset_c(np, 0u32, (new_cap as u64) * PERR_BYTES)
    if old != 0u64 {
        iii_lex_memcpy_c(np, old, (cap as u64) * PERR_BYTES)
        iii_lex_free_c(old)
    }
    iii_lex_write_u64_c(st, PS_ERRORS, np)
    iii_lex_write_u32_c(st, PS_ERR_CAP, new_cap)
    return 1u32
}

/* On closing a suppressed dedup run (prev.dup_count>0), insert a sentinel. */
fn iiip_dedup_close(st: u64) -> u32 {
    let ec: u32 = iii_lex_read_u32_c(st, PS_ERR_COUNT)
    let cap: u32 = iii_lex_read_u32_c(st, PS_ERR_CAP)
    if ec == 0u32 { return 0u32 }
    if ec >= cap { return 0u32 }
    let base: u64 = iii_lex_read_u64_c(st, PS_ERRORS)
    let prev: u64 = base + ((ec - 1u32) as u64) * PERR_BYTES
    if iii_lex_read_u32_c(prev, PE_DUP) == 0u32 { return 0u32 }
    let s: u64 = base + (ec as u64) * PERR_BYTES
    iii_lex_memset_c(s, 0u32, PERR_BYTES)
    iii_lex_write_u32_c(s, PE_CODE, III_PARSE_E_ERRORS_TRUNCATED)
    iii_lex_write_u32_c(s, PE_BYTE, iii_lex_read_u32_c(prev, PE_BYTE))
    iii_lex_write_u32_c(s, PE_LINE, iii_lex_read_u32_c(prev, PE_LINE))
    iii_lex_write_u32_c(s, PE_COL, iii_lex_read_u32_c(prev, PE_COL))
    iii_lex_write_u32_c(s, PE_SAW, PARSE_TOK_INVALID)
    iii_lex_write_u32_c(s, PE_EXPECTED, PARSE_TOK_INVALID)
    iii_lex_write_u64_c(s, PE_BREADCRUMB, iii_lex_read_u64_c(prev, PE_BREADCRUMB))
    iii_lex_write_u64_c(s, PE_MESSAGE, "(N identical errors suppressed)" as u64)
    iii_lex_write_u32_c(s, PE_DUP, iii_lex_read_u32_c(prev, PE_DUP))
    iii_lex_write_u32_c(st, PS_ERR_COUNT, ec + 1u32)
    return 0u32
}

fn iiip_record_error(st: u64, code: u32, tok: u64, msg: u64, expected: u32) -> u32 {
    if st == 0u64 { return 0u32 }
    let cd: u32 = code
    let mut line: u32 = 0u32
    if tok != 0u64 { line = iii_lex_read_u32_c(tok, TOK_LINE) }
    /* C2 dedup of consecutive identical (code,line). */
    let mut suppressed: u32 = 0u32
    if cd == iii_lex_read_u32_c(st, PS_LAST_ERR_CODE) {
        if line == iii_lex_read_u32_c(st, PS_LAST_ERR_LINE) {
            if cd != III_PARSE_OK {
                let d: u32 = iii_lex_read_u32_c(st, PS_LAST_ERR_DUPS) + 1u32
                iii_lex_write_u32_c(st, PS_LAST_ERR_DUPS, d)
                if d >= III_PARSE_DUP_THRESHOLD {
                    let ec0: u32 = iii_lex_read_u32_c(st, PS_ERR_COUNT)
                    if ec0 > 0u32 {
                        let slot0: u64 = iii_lex_read_u64_c(st, PS_ERRORS) + ((ec0 - 1u32) as u64) * PERR_BYTES
                        iii_lex_write_u32_c(slot0, PE_DUP, iii_lex_read_u32_c(slot0, PE_DUP) + 1u32)
                    }
                    suppressed = 1u32
                }
            }
        }
    }
    if suppressed == 1u32 { return 0u32 }
    /* C2 transition: code or line changed -> close any suppressed run. */
    let mut changed: u32 = 0u32
    if cd != iii_lex_read_u32_c(st, PS_LAST_ERR_CODE) { changed = 1u32 }
    if line != iii_lex_read_u32_c(st, PS_LAST_ERR_LINE) { changed = 1u32 }
    if changed == 1u32 {
        iiip_dedup_close(st)
        iii_lex_write_u32_c(st, PS_LAST_ERR_CODE, cd)
        iii_lex_write_u32_c(st, PS_LAST_ERR_LINE, line)
        iii_lex_write_u32_c(st, PS_LAST_ERR_DUPS, 1u32)
    }
    /* grow if full (C1) */
    let ec: u32 = iii_lex_read_u32_c(st, PS_ERR_COUNT)
    let cap: u32 = iii_lex_read_u32_c(st, PS_ERR_CAP)
    let mut dropped: u32 = 0u32
    if ec >= cap {
        if iiip_errq_grow(st) == 0u32 {
            let cap2: u32 = iii_lex_read_u32_c(st, PS_ERR_CAP)
            if cap2 > 0u32 {
                if iii_lex_read_u32_c(st, PS_ERR_COUNT) == cap2 {
                    let slot2: u64 = iii_lex_read_u64_c(st, PS_ERRORS) + ((cap2 - 1u32) as u64) * PERR_BYTES
                    if iii_lex_read_u32_c(slot2, PE_CODE) != III_PARSE_E_ERRORS_TRUNCATED {
                        iii_lex_write_u32_c(slot2, PE_CODE, III_PARSE_E_ERRORS_TRUNCATED)
                        iii_lex_write_u64_c(slot2, PE_MESSAGE, "error queue truncated; subsequent diagnostics dropped" as u64)
                    }
                }
            }
            dropped = 1u32
        }
    }
    if dropped == 1u32 { return 0u32 }
    let ec3: u32 = iii_lex_read_u32_c(st, PS_ERR_COUNT)
    let e: u64 = iii_lex_read_u64_c(st, PS_ERRORS) + (ec3 as u64) * PERR_BYTES
    iii_lex_memset_c(e, 0u32, PERR_BYTES)
    iii_lex_write_u32_c(e, PE_CODE, cd)
    let mut saw: u32 = PARSE_TOK_INVALID
    if tok != 0u64 {
        iii_lex_write_u32_c(e, PE_BYTE, iii_lex_read_u32_c(tok, TOK_START))
        iii_lex_write_u32_c(e, PE_COL, iii_lex_read_u32_c(tok, TOK_COL))
        saw = iii_lex_read_u32_c(tok, TOK_KIND)
    }
    iii_lex_write_u32_c(e, PE_LINE, line)
    iii_lex_write_u64_c(e, PE_MESSAGE, msg)
    iii_lex_write_u32_c(e, PE_SAW, saw)
    iii_lex_write_u32_c(e, PE_EXPECTED, expected)
    iii_lex_write_u64_c(e, PE_BREADCRUMB, iiip_breadcrumb_render(st))
    iii_lex_write_u32_c(st, PS_ERR_COUNT, ec3 + 1u32)
    return 0u32
}

/* ============================================================================
 * public error API.
 * ============================================================================ */

fn iii_parse_error_info(st: u64, out_err: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    if out_err == 0u64 { return 0u32 }
    if iii_lex_read_u32_c(st, PS_ERR_COUNT) == 0u32 {
        iii_lex_memset_c(out_err, 0u32, PERR_BYTES)
        iii_lex_write_u32_c(out_err, PE_CODE, III_PARSE_OK)
        return 0u32
    }
    iii_lex_memcpy_c(out_err, iii_lex_read_u64_c(st, PS_ERRORS), PERR_BYTES)
    return 0u32
}
fn iii_parse_error_count(st: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    return iii_lex_read_u32_c(st, PS_ERR_COUNT)
}
fn iii_parse_error_at(st: u64, i: u32, out_err: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    if out_err == 0u64 { return 0u32 }
    if i >= iii_lex_read_u32_c(st, PS_ERR_COUNT) {
        iii_lex_memset_c(out_err, 0u32, PERR_BYTES)
        return 0u32
    }
    iii_lex_memcpy_c(out_err, iii_lex_read_u64_c(st, PS_ERRORS) + (i as u64) * PERR_BYTES, PERR_BYTES)
    return 0u32
}

/* ============================================================================
 * witness (A1/A2) + alloc-wrapper.
 * ============================================================================ */
var WC_BUF : [u8; 24]
var POS_SCRATCH_P : [u8; 48]

fn iiip_witness_sink_emit(st: u64, node_id: u32, kind: u32, start: u32, end: u32) -> u32 {
    let fnp: u64 = iii_lex_read_u64_c(st, PS_WITNESS_SINK)
    if fnp != 0u64 {
        let ctx: u64 = iii_lex_read_u64_c(st, PS_WITNESS_SINK_CTX)
        fnp(ctx, node_id, kind, start, end)
    }
    return 0u32
}

fn wc_be32(off: u64, v: u32) -> u32 {
    iii_lex_write_u8_at_c(&WC_BUF as u64, off, v >> 24u32)
    iii_lex_write_u8_at_c(&WC_BUF as u64, off + 1u64, v >> 16u32)
    iii_lex_write_u8_at_c(&WC_BUF as u64, off + 2u64, v >> 8u32)
    iii_lex_write_u8_at_c(&WC_BUF as u64, off + 3u64, v)
    return 0u32
}
fn iiip_witness_commit(st: u64, node_id: u32) -> u32 {
    if st == 0u64 { return 0u32 }
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let node: u64 = iii_ast_get(ast, node_id)
    if node == 0u64 { return 0u32 }
    let kind: u32 = iii_lex_read_u32_c(node, TOK_KIND)
    let mut lo: u32 = 0u32
    let mut hi: u32 = 0u32
    if node_id != 0u32 {
        if iii_ast_position_first(ast, node_id, &POS_SCRATCH_P as u64) == 1i32 {
            if iii_lex_read_u32_c(&POS_SCRATCH_P as u64, APOS_KIND) == III_POS_PHYSICAL_P {
                lo = iii_lex_read_u32_c(&POS_SCRATCH_P as u64, APOS_PHYS_START)
                hi = iii_lex_read_u32_c(&POS_SCRATCH_P as u64, APOS_PHYS_END)
            }
        }
    }
    let ord: u32 = iii_lex_read_u32_c(st, PS_WITNESS_COMMITTED)
    wc_be32(0u64, kind)
    wc_be32(4u64, lo)
    wc_be32(8u64, hi)
    wc_be32(12u64, node_id)
    wc_be32(16u64, ord)
    wc_be32(20u64, 0u32)
    iii_sha256_update(st + PS_WITNESS_CTX, &WC_BUF as u64, 24u64)
    iii_lex_write_u32_c(st, PS_WITNESS_COMMITTED, ord + 1u32)
    return 0u32
}

/* The sole AST node-alloc entry: alloc, plant ERROR_NODE on OOM, witness. */
fn iiip_alloc_node(st: u64, kind: u32, pos: u64) -> u32 {
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut id: u32 = iii_ast_alloc_node(ast, kind, pos)
    if id == 0u32 {
        id = iii_ast_alloc_node(ast, 62u32, pos)
        iiip_record_error(st, III_PARSE_E_OOM, iiip_peek(st), "AST allocator returned 0 (out of capacity)" as u64, PARSE_TOK_INVALID)
    }
    iiip_witness_commit(st, id)
    let start: u32 = 0u32
    iiip_witness_sink_emit(st, id, kind, start, start)
    return id
}

fn iii_parse_witness_mhash(st: u64, out: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    if out == 0u64 { return 0u32 }
    let tmp: u64 = iii_lex_malloc_c(PARSE_SHA_STATE_BYTES)
    if tmp == 0u64 { return 0u32 }
    iii_lex_memcpy_c(tmp, st + PS_WITNESS_CTX, PARSE_SHA_STATE_BYTES)
    iii_sha256_final(tmp, out)
    iii_lex_free_c(tmp)
    return 0u32
}
fn iii_parse_set_witness_sink(st: u64, fn_ptr: u64, ctx: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    iii_lex_write_u64_c(st, PS_WITNESS_SINK, fn_ptr)
    iii_lex_write_u64_c(st, PS_WITNESS_SINK_CTX, ctx)
    return 0u32
}
fn iii_parse_set_pratt_trace(st: u64, fn_ptr: u64, ctx: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    iii_lex_write_u64_c(st, PS_PRATT_TRACE, fn_ptr)
    iii_lex_write_u64_c(st, PS_PRATT_TRACE_CTX, ctx)
    return 0u32
}

/* ============================================================================
 * breadcrumb (H2): rotating ring of 16 x 192-byte rendered strings.
 * ============================================================================ */
var BC_RING : [u8; 3072]
var BC_CURSOR : u32 = 0u32

fn bc_put_str(out: u64, off: u64, s: u64) -> u64 {
    let mut o: u64 = off
    let mut i: u64 = 0u64
    let mut done: u32 = 0u32
    while done == 0u32 {
        if o + 1u64 >= 192u64 { done = 1u32 }
        if done == 0u32 {
            let c: u32 = iii_lex_read_u8_at_c(s, i)
            if c == 0u32 { done = 1u32 }
            if done == 0u32 {
                iii_lex_write_u8_at_c(out, o, c)
                o = o + 1u64
                i = i + 1u64
            }
        }
    }
    return o
}
fn bc_put_dec(out: u64, off: u64, v: u32) -> u64 {
    let mut o: u64 = off
    if v == 0u32 {
        if o + 1u64 < 192u64 { iii_lex_write_u8_at_c(out, o, 48u32) ; o = o + 1u64 }
        return o
    }
    let mut n: u32 = v
    let mut len: u64 = 0u64
    while n != 0u32 {
        iii_lex_write_u8_at_c(&PN_DEC_SCR as u64, len, 48u32 + (n % 10u32))
        n = n / 10u32
        len = len + 1u64
    }
    let mut k: u64 = len
    while k != 0u64 {
        k = k - 1u64
        if o + 1u64 < 192u64 {
            iii_lex_write_u8_at_c(out, o, iii_lex_read_u8_at_c(&PN_DEC_SCR as u64, k))
            o = o + 1u64
        }
    }
    return o
}

fn iiip_breadcrumb_render(st: u64) -> u64 {
    if st == 0u64 { return 0u64 }
    let bcd: u32 = iii_lex_read_u32_c(st, PS_BC_DEPTH)
    if bcd == 0u32 { return 0u64 }
    let slot: u32 = BC_CURSOR
    BC_CURSOR = (BC_CURSOR + 1u32) & 15u32
    let out: u64 = (&BC_RING as u64) + (slot as u64) * 192u64
    let mut off: u64 = bc_put_str(out, 0u64, "in " as u64)
    let mut i: u32 = 0u32
    while i != bcd {
        if i > 0u32 { off = bc_put_str(out, off, " > " as u64) }
        let pid: u32 = iii_lex_read_u32_c(st + PS_BC_STACK, (i as u64) * 4u64)
        let nm: u64 = iiip_prod_name(pid)
        if nm != 0u64 { off = bc_put_str(out, off, nm) }
        if nm == 0u64 { off = bc_put_str(out, off, "?" as u64) }
        let detail: u64 = st + PS_BC_DETAIL + (i as u64) * 8u64
        if iii_lex_read_u32_c(detail, 4u64) > 0u32 {
            off = bc_put_str(out, off, "(#" as u64)
            off = bc_put_dec(out, off, iii_lex_read_u32_c(detail, 0u64))
            off = bc_put_str(out, off, ")" as u64)
        }
        i = i + 1u32
    }
    iii_lex_write_u8_at_c(out, off, 0u32)
    return out
}

fn iiip_bc_push(st: u64, pid: u32, detail_off: u32, detail_len: u32) -> u32 {
    if st == 0u64 { return 0u32 }
    let bcd: u32 = iii_lex_read_u32_c(st, PS_BC_DEPTH)
    if bcd >= III_PARSE_BREADCRUMB_CAP { return 0u32 }
    iii_lex_write_u32_c(st + PS_BC_STACK, (bcd as u64) * 4u64, pid)
    iii_lex_write_u32_c(st + PS_BC_DETAIL + (bcd as u64) * 8u64, 0u64, detail_off)
    iii_lex_write_u32_c(st + PS_BC_DETAIL + (bcd as u64) * 8u64, 4u64, detail_len)
    iii_lex_write_u32_c(st, PS_BC_DEPTH, bcd + 1u32)
    return 0u32
}
fn iiip_bc_pop(st: u64) -> u32 {
    if st == 0u64 { return 0u32 }
    let bcd: u32 = iii_lex_read_u32_c(st, PS_BC_DEPTH)
    if bcd == 0u32 { return 0u32 }
    iii_lex_write_u32_c(st, PS_BC_DEPTH, bcd - 1u32)
    return 0u32
}
fn iiip_current_budget(st: u64) -> u32 {
    if st == 0u64 { return 512u32 }
    let bcd: u32 = iii_lex_read_u32_c(st, PS_BC_DEPTH)
    if bcd == 0u32 { return 512u32 }
    return iiip_prod_budget(iii_lex_read_u32_c(st + PS_BC_STACK, ((bcd - 1u32) as u64) * 4u64))
}

/* ============================================================================
 * RITCHIE Stage 2.3.2 -- Pratt binop precedence table (N1) + error_name.
 * Mirrors ast.c... err parse.c iiip_binop_table_data (504-525) +
 * iii_parse_binop_table (530) + iii_parse_error_name (3517).  The public
 * iii_parse_binop_info_t is 16B {token@0(u32), prec@4(i32), right_assoc@8(u8),
 * op@12(i32)}; 20 entries, all left-assoc.  Token/binop numeric values are
 * lex.h/ast.h-probed (CONVERGENCE-AUDIT S2.3.2).
 * ============================================================================ */
var BINOP_TABLE : [u8; 320]
var BINOP_INIT : u8 = 0u8
const IIIP_BINOP_TABLE_LEN: u64 = 20u64

fn bt_set(idx: u32, token: u32, prec: u32, op: u32) -> u32 {
    let e: u64 = (&BINOP_TABLE as u64) + (idx as u64) * 16u64
    iii_lex_write_u32_c(e, 0u64, token)
    iii_lex_write_u32_c(e, 4u64, prec)
    iii_lex_write_u8_at_c(e, 8u64, 0u32)
    iii_lex_write_u32_c(e, 12u64, op)
    return 0u32
}
fn binop_init() -> u32 {
    if BINOP_INIT == 1u8 { return 0u32 }
    iii_lex_memset_c(&BINOP_TABLE as u64, 0u32, 320u64)
    bt_set(0u32, 44u32, 1u32, 18u32)     /* KW_OR  -> LOR  */
    bt_set(1u32, 43u32, 2u32, 17u32)     /* KW_AND -> LAND */
    bt_set(2u32, 96u32, 3u32, 11u32)     /* OP_EQ  -> EQ   */
    bt_set(3u32, 97u32, 3u32, 12u32)     /* OP_NEQ -> NEQ  */
    bt_set(4u32, 98u32, 4u32, 13u32)     /* OP_LT  -> LT   */
    bt_set(5u32, 99u32, 4u32, 14u32)     /* OP_LE  -> LE   */
    bt_set(6u32, 100u32, 4u32, 15u32)    /* OP_GT  -> GT   */
    bt_set(7u32, 101u32, 4u32, 16u32)    /* OP_GE  -> GE   */
    bt_set(8u32, 31u32, 4u32, 19u32)     /* KW_IN  -> IN   */
    bt_set(9u32, 81u32, 5u32, 7u32)      /* PIPE   -> OR   */
    bt_set(10u32, 91u32, 6u32, 8u32)     /* CARET  -> XOR  */
    bt_set(11u32, 90u32, 7u32, 6u32)     /* AMP    -> AND  */
    bt_set(12u32, 94u32, 8u32, 9u32)     /* SHL    -> SHL  */
    bt_set(13u32, 95u32, 8u32, 10u32)    /* SHR    -> SHR  */
    bt_set(14u32, 85u32, 9u32, 1u32)     /* PLUS   -> ADD  */
    bt_set(15u32, 86u32, 9u32, 2u32)     /* MINUS  -> SUB  */
    bt_set(16u32, 87u32, 10u32, 3u32)    /* STAR   -> MUL  */
    bt_set(17u32, 88u32, 10u32, 4u32)    /* SLASH  -> DIV  */
    bt_set(18u32, 89u32, 10u32, 5u32)    /* PERCENT-> MOD  */
    bt_set(19u32, 45u32, 11u32, 20u32)   /* KW_COMPOSE -> COMPOSE */
    BINOP_INIT = 1u8
    return 0u32
}
fn iii_parse_binop_table(out_n: u64) -> u64 @export {
    binop_init()
    if out_n != 0u64 { iii_lex_write_u64_c(out_n, 0u64, IIIP_BINOP_TABLE_LEN) }
    return &BINOP_TABLE as u64
}

/* Pratt lookup: precedence (0 = not a binop) + op for a trigger token. */
fn iiip_binop_prec(token: u32) -> u32 {
    binop_init()
    let mut i: u32 = 0u32
    let mut res: u32 = 0u32
    while i != 20u32 {
        let e: u64 = (&BINOP_TABLE as u64) + (i as u64) * 16u64
        if iii_lex_read_u32_c(e, 0u64) == token { res = iii_lex_read_u32_c(e, 4u64) }
        i = i + 1u32
    }
    return res
}
fn iiip_binop_op(token: u32) -> u32 {
    binop_init()
    let mut i: u32 = 0u32
    let mut res: u32 = 0u32
    while i != 20u32 {
        let e: u64 = (&BINOP_TABLE as u64) + (i as u64) * 16u64
        if iii_lex_read_u32_c(e, 0u64) == token { res = iii_lex_read_u32_c(e, 12u64) }
        i = i + 1u32
    }
    return res
}

/* iii_parse_error_name: 18-entry NUL-pool (codes 0-17) + "<unknown>". */
var EN_POOL : [u8; 256]
var EN_OFF  : [u32; 18]
var EN_INIT : u8 = 0u8
var EN_NEXT : u64 = 0u64
var EN_UNKNOWN : u32 = 0u32

fn en_add(code: u32, lit: u64, litlen: u64) -> u32 {
    let base: u64 = (&EN_POOL as u64) + EN_NEXT
    iii_lex_memcpy_c(base, lit, litlen)
    iii_lex_write_u8_at_c(base + litlen, 0u64, 0u32)
    iii_lex_write_u32_c(&EN_OFF as u64, (code as u64) * 4u64, EN_NEXT as u32)
    EN_NEXT = EN_NEXT + litlen + 1u64
    return 0u32
}
fn en_init() -> u32 {
    if EN_INIT == 1u8 { return 0u32 }
    en_add(0u32, "OK" as u64, 2u64)
    en_add(1u32, "UNEXPECTED_TOKEN" as u64, 16u64)
    en_add(2u32, "EXPECTED_IDENT" as u64, 14u64)
    en_add(3u32, "EXPECTED_LITERAL" as u64, 16u64)
    en_add(4u32, "EXPECTED_TYPE" as u64, 13u64)
    en_add(5u32, "EXPECTED_EXPR" as u64, 13u64)
    en_add(6u32, "EXPECTED_PATTERN" as u64, 16u64)
    en_add(7u32, "BAD_MODIFIER" as u64, 12u64)
    en_add(8u32, "BAD_HEXAD" as u64, 9u64)
    en_add(9u32, "BAD_RING_SET" as u64, 12u64)
    en_add(10u32, "LEX" as u64, 3u64)
    en_add(11u32, "OOM" as u64, 3u64)
    en_add(12u32, "RECURSION_LIMIT" as u64, 15u64)
    en_add(13u32, "NULL_ARG" as u64, 8u64)
    en_add(14u32, "UNEXPECTED_EOF" as u64, 14u64)
    en_add(15u32, "ERRORS_TRUNCATED" as u64, 16u64)
    en_add(16u32, "INSERTED_TOKEN" as u64, 14u64)
    en_add(17u32, "REGISTRY_FULL" as u64, 13u64)
    EN_UNKNOWN = EN_NEXT as u32
    let ub: u64 = (&EN_POOL as u64) + EN_NEXT
    iii_lex_memcpy_c(ub, "<unknown>" as u64, 9u64)
    iii_lex_write_u8_at_c(ub + 9u64, 0u64, 0u32)
    EN_NEXT = EN_NEXT + 10u64
    EN_INIT = 1u8
    return 0u32
}
fn iii_parse_error_name(code: u32) -> u64 @export {
    en_init()
    if code >= 18u32 { return (&EN_POOL as u64) + (EN_UNKNOWN as u64) }
    return (&EN_POOL as u64) + (iii_lex_read_u32_c(&EN_OFF as u64, (code as u64) * 4u64) as u64)
}

/* ============================================================================
 * RITCHIE Stage 2.3.3 -- FIRST/FOLLOW table (B1) + grammar_mhash (E1).
 * Mirrors parse.c iiip_ff_table (372-479) + iiip_ff_lookup (483) +
 * iii_parse_grammar_mhash (3620).  32 rows {id@0(u32), first@4(12 u32,
 * 0-terminated), follow@52(12 u32, 0-terminated)} = 100B each.  Token values
 * lex.h-probed (CONVERGENCE-AUDIT S2.3.3).  recover_to/recover_follow/
 * synth_insert/expect are production-layer helpers (only the productions call
 * them) -> ship + verify with §2.3.4.
 * ============================================================================ */
var FF_TABLE : [u8; 3200]
var FF_INIT : u8 = 0u8
const FF_ROW_BYTES: u64 = 100u64
const FF_FIRST: u64 = 4u64
const FF_FOLLOW: u64 = 52u64
const IIIP_FF_TABLE_LEN: u32 = 32u32

fn ff_id(idx: u32, id: u32) -> u32 {
    iii_lex_write_u32_c((&FF_TABLE as u64) + (idx as u64) * FF_ROW_BYTES, 0u64, id)
    return 0u32
}
fn ff_fst(idx: u32, j: u64, tok: u32) -> u32 {
    iii_lex_write_u32_c((&FF_TABLE as u64) + (idx as u64) * FF_ROW_BYTES + FF_FIRST + j * 4u64, 0u64, tok)
    return 0u32
}
fn ff_fol(idx: u32, j: u64, tok: u32) -> u32 {
    iii_lex_write_u32_c((&FF_TABLE as u64) + (idx as u64) * FF_ROW_BYTES + FF_FOLLOW + j * 4u64, 0u64, tok)
    return 0u32
}
fn ff_init() -> u32 {
    if FF_INIT == 1u8 { return 0u32 }
    iii_lex_memset_c(&FF_TABLE as u64, 0u32, 3200u64)
    /* row 0 MODULE */
    ff_id(0u32, 0u32) ; ff_fst(0u32, 0u64, 12u32) ; ff_fol(0u32, 0u64, 1u32)
    /* row 1 USE_DECL */
    ff_id(1u32, 1u32) ; ff_fst(1u32, 0u64, 13u32)
    ff_fol(1u32, 0u64, 2u32) ; ff_fol(1u32, 1u64, 13u32) ; ff_fol(1u32, 2u64, 15u32) ; ff_fol(1u32, 3u64, 16u32) ; ff_fol(1u32, 4u64, 17u32) ; ff_fol(1u32, 5u64, 18u32) ; ff_fol(1u32, 6u64, 19u32) ; ff_fol(1u32, 7u64, 20u32) ; ff_fol(1u32, 8u64, 21u32) ; ff_fol(1u32, 9u64, 23u32) ; ff_fol(1u32, 10u64, 1u32)
    /* row 2 TOP_DECL */
    ff_id(2u32, 2u32)
    ff_fst(2u32, 0u64, 15u32) ; ff_fst(2u32, 1u64, 16u32) ; ff_fst(2u32, 2u64, 17u32) ; ff_fst(2u32, 3u64, 18u32) ; ff_fst(2u32, 4u64, 19u32) ; ff_fst(2u32, 5u64, 20u32) ; ff_fst(2u32, 6u64, 21u32) ; ff_fst(2u32, 7u64, 23u32)
    ff_fol(2u32, 0u64, 2u32) ; ff_fol(2u32, 1u64, 15u32) ; ff_fol(2u32, 2u64, 16u32) ; ff_fol(2u32, 3u64, 17u32) ; ff_fol(2u32, 4u64, 18u32) ; ff_fol(2u32, 5u64, 19u32) ; ff_fol(2u32, 6u64, 20u32) ; ff_fol(2u32, 7u64, 21u32) ; ff_fol(2u32, 8u64, 23u32) ; ff_fol(2u32, 9u64, 1u32)
    /* row 3 CYCLE_DECL */
    ff_id(3u32, 3u32) ; ff_fst(3u32, 0u64, 15u32) ; ff_fol(3u32, 0u64, 2u32) ; ff_fol(3u32, 1u64, 72u32) ; ff_fol(3u32, 2u64, 1u32)
    /* row 4 FN_DECL */
    ff_id(4u32, 4u32) ; ff_fst(4u32, 0u64, 16u32) ; ff_fol(4u32, 0u64, 2u32) ; ff_fol(4u32, 1u64, 72u32) ; ff_fol(4u32, 2u64, 1u32)
    /* row 5 TYPE_DECL */
    ff_id(5u32, 5u32) ; ff_fst(5u32, 0u64, 17u32) ; ff_fol(5u32, 0u64, 2u32) ; ff_fol(5u32, 1u64, 1u32)
    /* row 6 CONST_DECL */
    ff_id(6u32, 6u32) ; ff_fst(6u32, 0u64, 18u32) ; ff_fol(6u32, 0u64, 2u32) ; ff_fol(6u32, 1u64, 1u32)
    /* row 7 EXTERN_DECL */
    ff_id(7u32, 7u32) ; ff_fst(7u32, 0u64, 19u32) ; ff_fol(7u32, 0u64, 2u32) ; ff_fol(7u32, 1u64, 1u32)
    /* row 8 MOBIUS_CANDIDATE */
    ff_id(8u32, 8u32) ; ff_fst(8u32, 0u64, 20u32) ; ff_fol(8u32, 0u64, 2u32) ; ff_fol(8u32, 1u64, 72u32) ; ff_fol(8u32, 2u64, 1u32)
    /* row 9 SCHEMA_DECL */
    ff_id(9u32, 9u32) ; ff_fst(9u32, 0u64, 21u32) ; ff_fol(9u32, 0u64, 2u32) ; ff_fol(9u32, 1u64, 72u32) ; ff_fol(9u32, 2u64, 1u32)
    /* row 10 SEALED_CALL */
    ff_id(10u32, 10u32) ; ff_fst(10u32, 0u64, 23u32) ; ff_fol(10u32, 0u64, 2u32) ; ff_fol(10u32, 1u64, 72u32) ; ff_fol(10u32, 2u64, 1u32)
    /* row 11 PARAM_LIST */
    ff_id(11u32, 11u32) ; ff_fst(11u32, 0u64, 69u32) ; ff_fol(11u32, 0u64, 70u32) ; ff_fol(11u32, 1u64, 83u32) ; ff_fol(11u32, 2u64, 71u32) ; ff_fol(11u32, 3u64, 80u32)
    /* row 12 ARG_LIST (empty FIRST) */
    ff_id(12u32, 12u32) ; ff_fol(12u32, 0u64, 70u32) ; ff_fol(12u32, 1u64, 74u32)
    /* row 13 ARG (empty FIRST) */
    ff_id(13u32, 13u32) ; ff_fol(13u32, 0u64, 75u32) ; ff_fol(13u32, 1u64, 70u32)
    /* row 14 MODIFIER */
    ff_id(14u32, 14u32) ; ff_fst(14u32, 0u64, 80u32)
    ff_fol(14u32, 0u64, 80u32) ; ff_fol(14u32, 1u64, 2u32) ; ff_fol(14u32, 2u64, 71u32) ; ff_fol(14u32, 3u64, 76u32) ; ff_fol(14u32, 4u64, 75u32) ; ff_fol(14u32, 5u64, 70u32) ; ff_fol(14u32, 6u64, 72u32)
    /* row 15 TYPE_EXPR */
    ff_id(15u32, 15u32)
    ff_fst(15u32, 0u64, 87u32) ; ff_fst(15u32, 1u64, 73u32) ; ff_fst(15u32, 2u64, 69u32) ; ff_fst(15u32, 3u64, 16u32) ; ff_fst(15u32, 4u64, 4u32)
    ff_fol(15u32, 0u64, 75u32) ; ff_fol(15u32, 1u64, 70u32) ; ff_fol(15u32, 2u64, 74u32) ; ff_fol(15u32, 3u64, 100u32) ; ff_fol(15u32, 4u64, 102u32) ; ff_fol(15u32, 5u64, 71u32) ; ff_fol(15u32, 6u64, 80u32) ; ff_fol(15u32, 7u64, 2u32) ; ff_fol(15u32, 8u64, 24u32) ; ff_fol(15u32, 9u64, 83u32)
    /* row 16 TYPE_SIMPLE (same sets as TYPE_EXPR) */
    ff_id(16u32, 16u32)
    ff_fst(16u32, 0u64, 87u32) ; ff_fst(16u32, 1u64, 73u32) ; ff_fst(16u32, 2u64, 69u32) ; ff_fst(16u32, 3u64, 16u32) ; ff_fst(16u32, 4u64, 4u32)
    ff_fol(16u32, 0u64, 75u32) ; ff_fol(16u32, 1u64, 70u32) ; ff_fol(16u32, 2u64, 74u32) ; ff_fol(16u32, 3u64, 100u32) ; ff_fol(16u32, 4u64, 102u32) ; ff_fol(16u32, 5u64, 71u32) ; ff_fol(16u32, 6u64, 80u32) ; ff_fol(16u32, 7u64, 2u32) ; ff_fol(16u32, 8u64, 24u32) ; ff_fol(16u32, 9u64, 83u32)
    /* row 17 EXPR (empty FIRST) */
    ff_id(17u32, 17u32)
    ff_fol(17u32, 0u64, 75u32) ; ff_fol(17u32, 1u64, 70u32) ; ff_fol(17u32, 2u64, 74u32) ; ff_fol(17u32, 3u64, 72u32) ; ff_fol(17u32, 4u64, 76u32) ; ff_fol(17u32, 5u64, 2u32) ; ff_fol(17u32, 6u64, 84u32) ; ff_fol(17u32, 7u64, 71u32) ; ff_fol(17u32, 8u64, 36u32) ; ff_fol(17u32, 9u64, 32u32)
    /* row 18 PRIMARY (empty FIRST) */
    ff_id(18u32, 18u32)
    ff_fol(18u32, 0u64, 75u32) ; ff_fol(18u32, 1u64, 70u32) ; ff_fol(18u32, 2u64, 74u32) ; ff_fol(18u32, 3u64, 79u32) ; ff_fol(18u32, 4u64, 69u32) ; ff_fol(18u32, 5u64, 73u32)
    /* row 19 UNARY (empty FIRST) */
    ff_id(19u32, 19u32) ; ff_fol(19u32, 0u64, 75u32) ; ff_fol(19u32, 1u64, 70u32) ; ff_fol(19u32, 2u64, 74u32)
    /* row 20 POSTFIX (empty FIRST) */
    ff_id(20u32, 20u32) ; ff_fol(20u32, 0u64, 75u32) ; ff_fol(20u32, 1u64, 70u32) ; ff_fol(20u32, 2u64, 74u32)
    /* row 21 PAREN_EXPR */
    ff_id(21u32, 21u32) ; ff_fst(21u32, 0u64, 69u32) ; ff_fol(21u32, 0u64, 70u32)
    /* row 22 BLOCK */
    ff_id(22u32, 22u32) ; ff_fst(22u32, 0u64, 71u32) ; ff_fol(22u32, 0u64, 72u32) ; ff_fol(22u32, 1u64, 2u32) ; ff_fol(22u32, 2u64, 1u32)
    /* row 23 STMT */
    ff_id(23u32, 23u32)
    ff_fst(23u32, 0u64, 25u32) ; ff_fst(23u32, 1u64, 27u32) ; ff_fst(23u32, 2u64, 28u32) ; ff_fst(23u32, 3u64, 29u32) ; ff_fst(23u32, 4u64, 30u32) ; ff_fst(23u32, 5u64, 35u32) ; ff_fst(23u32, 6u64, 33u32)
    ff_fol(23u32, 0u64, 2u32) ; ff_fol(23u32, 1u64, 76u32) ; ff_fol(23u32, 2u64, 72u32) ; ff_fol(23u32, 3u64, 1u32)
    /* row 24 LET */
    ff_id(24u32, 24u32) ; ff_fst(24u32, 0u64, 25u32) ; ff_fol(24u32, 0u64, 2u32) ; ff_fol(24u32, 1u64, 76u32) ; ff_fol(24u32, 2u64, 72u32)
    /* row 25 WAVEFRONT */
    ff_id(25u32, 25u32) ; ff_fst(25u32, 0u64, 27u32) ; ff_fol(25u32, 0u64, 2u32) ; ff_fol(25u32, 1u64, 72u32)
    /* row 26 SANCTUM_ENTER */
    ff_id(26u32, 26u32) ; ff_fst(26u32, 0u64, 28u32) ; ff_fol(26u32, 0u64, 2u32) ; ff_fol(26u32, 1u64, 72u32)
    /* row 27 METAL */
    ff_id(27u32, 27u32) ; ff_fst(27u32, 0u64, 29u32) ; ff_fol(27u32, 0u64, 2u32) ; ff_fol(27u32, 1u64, 72u32)
    /* row 28 FOR */
    ff_id(28u32, 28u32) ; ff_fst(28u32, 0u64, 30u32) ; ff_fol(28u32, 0u64, 2u32) ; ff_fol(28u32, 1u64, 72u32)
    /* row 29 RETURN */
    ff_id(29u32, 29u32) ; ff_fst(29u32, 0u64, 35u32) ; ff_fol(29u32, 0u64, 2u32) ; ff_fol(29u32, 1u64, 76u32) ; ff_fol(29u32, 2u64, 72u32)
    /* row 30 PATTERN */
    ff_id(30u32, 30u32)
    ff_fst(30u32, 0u64, 82u32) ; ff_fst(30u32, 1u64, 69u32) ; ff_fst(30u32, 2u64, 5u32) ; ff_fst(30u32, 3u64, 6u32) ; ff_fst(30u32, 4u64, 8u32) ; ff_fst(30u32, 5u64, 41u32) ; ff_fst(30u32, 6u64, 42u32) ; ff_fst(30u32, 7u64, 4u32)
    ff_fol(30u32, 0u64, 84u32) ; ff_fol(30u32, 1u64, 34u32) ; ff_fol(30u32, 2u64, 75u32) ; ff_fol(30u32, 3u64, 70u32) ; ff_fol(30u32, 4u64, 72u32)
    /* row 31 HEXAD */
    ff_id(31u32, 31u32) ; ff_fst(31u32, 0u64, 69u32) ; ff_fol(31u32, 0u64, 70u32)
    FF_INIT = 1u8
    return 0u32
}
fn iiip_ff_lookup(id: u32) -> u64 {
    ff_init()
    let mut i: u32 = 0u32
    let mut res: u64 = 0u64
    while i != IIIP_FF_TABLE_LEN {
        let row: u64 = (&FF_TABLE as u64) + (i as u64) * FF_ROW_BYTES
        if iii_lex_read_u32_c(row, 0u64) == id { res = row }
        i = i + 1u32
    }
    return res
}

/* Lexicographic a<=b for two NUL-terminated strings (no signed compare). */
fn parse_str_le(a: u64, b: u64) -> u32 {
    let mut i: u64 = 0u64
    let mut res: u32 = 2u32
    while res == 2u32 {
        let ca: u32 = iii_lex_read_u8_at_c(a, i)
        let cb: u32 = iii_lex_read_u8_at_c(b, i)
        if ca != cb {
            res = 0u32
            if ca < cb { res = 1u32 }
        }
        if res == 2u32 {
            if ca == 0u32 { res = 1u32 }
            if res == 2u32 { i = i + 1u64 }
        }
    }
    return res
}

var GM_ORDER : [u8; 32]
var GM_SEP : [u8; 1]

fn iii_parse_grammar_mhash(st: u64, out: u64) -> u32 @export {
    if out == 0u64 { return 0u32 }
    if st == 0u64 { iii_lex_memset_c(out, 0u32, 32u64) ; return 0u32 }
    ff_init()
    let h: u64 = iii_lex_malloc_c(PARSE_SHA_STATE_BYTES)
    if h == 0u64 { return 0u32 }
    iii_sha256_init(h)
    iii_lex_write_u8_at_c(&GM_SEP as u64, 0u64, 0u32)
    /* order[0..31] = row indices, insertion-sorted by prod_name. */
    let mut i: u32 = 0u32
    while i != IIIP_FF_TABLE_LEN {
        iii_lex_write_u8_at_c(&GM_ORDER as u64, i as u64, i)
        i = i + 1u32
    }
    let mut a: u32 = 1u32
    while a != IIIP_FF_TABLE_LEN {
        let v: u32 = iii_lex_read_u8_at_c(&GM_ORDER as u64, a as u64)
        let vrow: u64 = (&FF_TABLE as u64) + (v as u64) * FF_ROW_BYTES
        let vn: u64 = iiip_prod_name(iii_lex_read_u32_c(vrow, 0u64))
        let mut j: u32 = a
        let mut sorting: u32 = 1u32
        while sorting == 1u32 {
            if j == 0u32 { sorting = 0u32 }
            if sorting == 1u32 {
                let pidx: u32 = iii_lex_read_u8_at_c(&GM_ORDER as u64, (j - 1u32) as u64)
                let prow: u64 = (&FF_TABLE as u64) + (pidx as u64) * FF_ROW_BYTES
                let pn: u64 = iiip_prod_name(iii_lex_read_u32_c(prow, 0u64))
                if parse_str_le(pn, vn) == 1u32 { sorting = 0u32 }
                if sorting == 1u32 {
                    iii_lex_write_u8_at_c(&GM_ORDER as u64, j as u64, pidx)
                    j = j - 1u32
                }
            }
        }
        iii_lex_write_u8_at_c(&GM_ORDER as u64, j as u64, v)
        a = a + 1u32
    }
    /* fold (name || 0 || FIRST u32s || 0 || FOLLOW u32s || 0). */
    let mut k: u32 = 0u32
    while k != IIIP_FF_TABLE_LEN {
        let ridx: u32 = iii_lex_read_u8_at_c(&GM_ORDER as u64, k as u64)
        let row: u64 = (&FF_TABLE as u64) + (ridx as u64) * FF_ROW_BYTES
        let nm: u64 = iiip_prod_name(iii_lex_read_u32_c(row, 0u64))
        iii_sha256_update(h, nm, parse_strlen(nm))
        iii_sha256_update(h, &GM_SEP as u64, 1u64)
        let mut f: u64 = 0u64
        let mut fdone: u32 = 0u32
        while fdone == 0u32 {
            if f == 12u64 { fdone = 1u32 }
            if fdone == 0u32 {
                let t: u32 = iii_lex_read_u32_c(row + FF_FIRST, f * 4u64)
                if t == 0u32 { fdone = 1u32 }
                if fdone == 0u32 { gm_u32_be(h,t) ; f = f + 1u64 }
            }
        }
        iii_sha256_update(h, &GM_SEP as u64, 1u64)
        let mut g: u64 = 0u64
        let mut gdone: u32 = 0u32
        while gdone == 0u32 {
            if g == 12u64 { gdone = 1u32 }
            if gdone == 0u32 {
                let t: u32 = iii_lex_read_u32_c(row + FF_FOLLOW, g * 4u64)
                if t == 0u32 { gdone = 1u32 }
                if gdone == 0u32 { gm_u32_be(h,t) ; g = g + 1u64 }
            }
        }
        iii_sha256_update(h, &GM_SEP as u64, 1u64)
        k = k + 1u32
    }
    /* fold the 3 registries in handle order. */
    let mut t: u32 = 0u32
    while t != 3u32 {
        let tbl: u64 = ps_reg_table(st, t)
        gm_u32_be(h,t)
        let mut e: u32 = 0u32
        while e != 64u32 {
            let entry: u64 = tbl + (e as u64) * 16u64
            if iii_lex_read_u32_c(entry, 0u64) != 0u32 {
                gm_u32_be(h,iii_lex_read_u32_c(entry, 0u64))
                gm_u32_be(h,iii_lex_read_u32_c(entry, 4u64))
            }
            e = e + 1u32
        }
        t = t + 1u32
    }
    iii_sha256_final(h, out)
    iii_lex_free_c(h)
    return 0u32
}

/* strlen helper (NUL-terminated). */
fn parse_strlen(s: u64) -> u64 {
    let mut i: u64 = 0u64
    let mut done: u32 = 0u32
    while done == 0u32 {
        if iii_lex_read_u8_at_c(s, i) == 0u32 { done = 1u32 }
        if done == 0u32 { i = i + 1u64 }
    }
    return i
}
/* address of the t-th registry table (t=0 decl, 1 stmt, 2 primary). */
fn ps_reg_table(st: u64, t: u32) -> u64 {
    if t == 0u32 { return st + PS_REG_DECL }
    if t == 1u32 { return st + PS_REG_STMT }
    return st + PS_REG_PRIMARY
}

/* BIG-ENDIAN u32 fold -- parse.c's iiip_sha256_u32 (199) folds v>>24 first;
 * lex_runtime's iii_sha256_update_u32 is LITTLE-endian, so it must NOT be used
 * here or the grammar mhash diverges from parse.c. */
var GM_U32 : [u8; 4]
fn gm_u32_be(h: u64, v: u32) -> u32 {
    iii_lex_write_u8_at_c(&GM_U32 as u64, 0u64, v >> 24u32)
    iii_lex_write_u8_at_c(&GM_U32 as u64, 1u64, v >> 16u32)
    iii_lex_write_u8_at_c(&GM_U32 as u64, 2u64, v >> 8u32)
    iii_lex_write_u8_at_c(&GM_U32 as u64, 3u64, v)
    iii_sha256_update(h, &GM_U32 as u64, 4u64)
    return 0u32
}

/* ============================================================================
 * RITCHIE Stage 2.3.4 -- production-helper layer (parse.c 811-1320).
 * The token-consume / recovery / pos+text / recursion-budget helpers that
 * every production calls.  Self-contained (no recursion into productions), so
 * compile-checked here; functionally exercised + diffed vs parse.c at §2.3.5
 * (the first production via iii_parse_expression).  iii_token_kind_name returns
 * SHORT display names ("cycle", ";") so keyword_hint's "III_TOK_KW_" strip is a
 * faithful no-op (parse.c calls the same kind_name).  COLON=77.
 * ============================================================================ */
extern @abi(c-msvc-x64) fn iii_token_kind_name(k: u32) -> u64 from "lex.iii"
extern @abi(c-msvc-x64) fn iii_token_raw_eq(st: u64, tok: u64, literal: u64) -> u32 from "lex.iii"

const III_TOK_NEWLINE_P: u32 = 2u32
const III_TOK_EOF_P: u32 = 1u32
const III_TOK_IDENTIFIER_P: u32 = 4u32
const III_TOK_SEMI_P: u32 = 76u32
const III_TOK_RBRACE_P: u32 = 72u32
const III_TOK_RPAREN_P: u32 = 70u32
const III_TOK_COLON_P: u32 = 77u32

var ADV_SCRATCH : [u8; 104]
var FMT_SCRATCH : [u8; 192]
var KW_LC : [u8; 32]
var KW_TMP : [u8; 32]

/* iiip_pos_of: write the token's 16B src_pos {start,end,line,col} to out. */
fn iiip_pos_of(tok: u64, out: u64) -> u32 {
    if tok == 0u64 { iii_lex_memset_c(out, 0u32, 16u64) ; return 0u32 }
    iii_lex_write_u32_c(out, 0u64, iii_lex_read_u32_c(tok, TOK_START))
    iii_lex_write_u32_c(out, 4u64, iii_lex_read_u32_c(tok, TOK_END))
    iii_lex_write_u32_c(out, 8u64, iii_lex_read_u32_c(tok, TOK_LINE))
    iii_lex_write_u32_c(out, 12u64, iii_lex_read_u32_c(tok, TOK_COL))
    return 0u32
}
/* iiip_text_of: packed src_text {offset@lo, length@hi} of the token. */
fn iiip_text_of(tok: u64) -> u64 {
    if tok == 0u64 { return 0u64 }
    let off: u64 = iii_lex_read_u32_c(tok, TOK_START) as u64
    let len: u64 = (iii_lex_read_u32_c(tok, TOK_END) - iii_lex_read_u32_c(tok, TOK_START)) as u64
    return off | (len << 32u64)
}
/* iiip_pos_span: out = a (16B) with end_byte replaced by b.end_byte. */
fn iiip_pos_span(a: u64, b: u64, out: u64) -> u32 {
    iii_lex_memcpy_c(out, a, 16u64)
    iii_lex_write_u32_c(out, 4u64, iii_lex_read_u32_c(b, 4u64))
    return 0u32
}

fn iiip_skip_newlines(st: u64) -> u32 {
    while iiip_peek_kind(st) == III_TOK_NEWLINE_P { iiip_advance(st, &ADV_SCRATCH as u64) }
    return 0u32
}
fn iiip_match(st: u64, k: u32) -> u32 {
    if iiip_peek_kind(st) == k { return 1u32 }
    return 0u32
}
fn iiip_accept(st: u64, k: u32) -> u32 {
    if iiip_peek_kind(st) == k { iiip_advance(st, &ADV_SCRATCH as u64) ; return 1u32 }
    return 0u32
}
fn iiip_enter_recursion(st: u64) -> u32 {
    let mut budget: u32 = iiip_current_budget(st)
    if budget > III_PARSE_MAX_DEPTH { budget = III_PARSE_MAX_DEPTH }
    let d: u32 = iii_lex_read_u32_c(st, PS_DEPTH)
    if d >= budget {
        iiip_record_error(st, 12u32, iiip_peek(st), "parse recursion limit exceeded" as u64, PARSE_TOK_INVALID)
        return 0u32
    }
    iii_lex_write_u32_c(st, PS_DEPTH, d + 1u32)
    return 1u32
}
fn iiip_leave_recursion(st: u64) -> u32 {
    let d: u32 = iii_lex_read_u32_c(st, PS_DEPTH)
    if d > 0u32 { iii_lex_write_u32_c(st, PS_DEPTH, d - 1u32) }
    return 0u32
}

/* strdup_rotating: copy NUL-terminated src into a 16x96 rotating ring. */
var SR_RING : [u8; 1536]
var SR_CURSOR : u32 = 0u32
fn iiip_strdup_rotating(src: u64) -> u64 {
    let slot: u32 = SR_CURSOR
    SR_CURSOR = (SR_CURSOR + 1u32) & 15u32
    let out: u64 = (&SR_RING as u64) + (slot as u64) * 96u64
    let mut i: u64 = 0u64
    let mut done: u32 = 0u32
    while done == 0u32 {
        if i >= 95u64 { done = 1u32 }
        if done == 0u32 {
            let c: u32 = iii_lex_read_u8_at_c(src, i)
            iii_lex_write_u8_at_c(out, i, c)
            if c == 0u32 { done = 1u32 }
            if done == 0u32 { i = i + 1u64 }
        }
    }
    iii_lex_write_u8_at_c(out, i, 0u32)
    return out
}

/* pp_cat: append NUL-terminated src to dst[off..], cap 191; return new off. */
fn pp_cat(dst: u64, off: u64, src: u64) -> u64 {
    let mut o: u64 = off
    let mut i: u64 = 0u64
    let mut done: u32 = 0u32
    while done == 0u32 {
        if o >= 191u64 { done = 1u32 }
        if done == 0u32 {
            let c: u32 = iii_lex_read_u8_at_c(src, i)
            if c == 0u32 { done = 1u32 }
            if done == 0u32 { iii_lex_write_u8_at_c(dst, o, c) ; o = o + 1u64 ; i = i + 1u64 }
        }
    }
    iii_lex_write_u8_at_c(dst, o, 0u32)
    return o
}
/* pp_strncmp: 1 if the first n bytes of a equal literal lit, else 0. */
fn pp_strncmp(a: u64, lit: u64, n: u64) -> u32 {
    let mut i: u64 = 0u64
    let mut res: u32 = 1u32
    while i != n {
        if iii_lex_read_u8_at_c(a, i) != iii_lex_read_u8_at_c(lit, i) { res = 0u32 ; i = n }
        if res == 1u32 { i = i + 1u64 }
    }
    return res
}

/* H1 keyword_hint: edit-distance-1 "did you mean" hint via raw_eq probing. */
fn iiip_keyword_hint(st: u64, base: u64, expected: u32) -> u64 {
    if base == 0u64 { return base }
    if expected == PARSE_TOK_INVALID { return base }
    let saw: u64 = iiip_peek(st)
    if iii_lex_read_u32_c(saw, TOK_KIND) != III_TOK_IDENTIFIER_P { return base }
    let want: u64 = iii_token_kind_name(expected)
    if want == 0u64 { return base }
    if iii_lex_read_u8_at_c(want, 0u64) == 0u32 { return base }
    let mut kw: u64 = want
    if pp_strncmp(want, "III_TOK_KW_" as u64, 11u64) == 1u32 { kw = want + 11u64 }
    if kw == want {
        if pp_strncmp(want, "III_TOK_" as u64, 8u64) == 1u32 { kw = want + 8u64 }
    }
    /* lowercase kw -> KW_LC, klen (cap 31). */
    let mut klen: u64 = 0u64
    let mut lc_done: u32 = 0u32
    while lc_done == 0u32 {
        if klen >= 31u64 { lc_done = 1u32 }
        if lc_done == 0u32 {
            let mut c: u32 = iii_lex_read_u8_at_c(kw, klen)
            if c == 0u32 { lc_done = 1u32 }
            if lc_done == 0u32 {
                if c >= 65u32 { if c <= 90u32 { c = c + 32u32 } }
                iii_lex_write_u8_at_c(&KW_LC as u64, klen, c)
                klen = klen + 1u64
            }
        }
    }
    iii_lex_write_u8_at_c(&KW_LC as u64, klen, 0u32)
    let slen: u32 = iii_lex_read_u32_c(saw, TOK_END) - iii_lex_read_u32_c(saw, TOK_START)
    if (slen as u64) >= 32u64 { return base }
    if iii_token_raw_eq(iii_lex_read_u64_c(st, PS_LEX), saw, &KW_LC as u64) == 1u32 { return base }
    let lex: u64 = iii_lex_read_u64_c(st, PS_LEX)
    let mut d1: u32 = 0u32
    /* substitution */
    let mut si: u64 = 0u64
    while si != klen {
        if d1 == 0u32 {
            let orig: u32 = iii_lex_read_u8_at_c(&KW_LC as u64, si)
            let mut c: u32 = 97u32
            while c != 123u32 {
                if c != orig {
                    if d1 == 0u32 {
                        iii_lex_memcpy_c(&KW_TMP as u64, &KW_LC as u64, klen + 1u64)
                        iii_lex_write_u8_at_c(&KW_TMP as u64, si, c)
                        if iii_token_raw_eq(lex, saw, &KW_TMP as u64) == 1u32 { d1 = 1u32 }
                    }
                }
                c = c + 1u32
            }
        }
        si = si + 1u64
    }
    /* insertion (saw one longer) */
    if d1 == 0u32 {
        if klen + 1u64 < 32u64 {
            let mut ii: u64 = 0u64
            while ii != klen + 1u64 {
                if d1 == 0u32 {
                    let mut c: u32 = 97u32
                    while c != 123u32 {
                        if d1 == 0u32 {
                            if ii > 0u64 { iii_lex_memcpy_c(&KW_TMP as u64, &KW_LC as u64, ii) }
                            iii_lex_write_u8_at_c(&KW_TMP as u64, ii, c)
                            if klen - ii > 0u64 { iii_lex_memcpy_c((&KW_TMP as u64) + ii + 1u64, (&KW_LC as u64) + ii, klen - ii) }
                            iii_lex_write_u8_at_c(&KW_TMP as u64, klen + 1u64, 0u32)
                            if iii_token_raw_eq(lex, saw, &KW_TMP as u64) == 1u32 { d1 = 1u32 }
                        }
                        c = c + 1u32
                    }
                }
                ii = ii + 1u64
            }
        }
    }
    /* deletion (saw one shorter) */
    if d1 == 0u32 {
        if klen >= 1u64 {
            let mut di: u64 = 0u64
            while di != klen {
                if d1 == 0u32 {
                    if di > 0u64 { iii_lex_memcpy_c(&KW_TMP as u64, &KW_LC as u64, di) }
                    if klen - di - 1u64 > 0u64 { iii_lex_memcpy_c((&KW_TMP as u64) + di, (&KW_LC as u64) + di + 1u64, klen - di - 1u64) }
                    iii_lex_write_u8_at_c(&KW_TMP as u64, klen - 1u64, 0u32)
                    if iii_token_raw_eq(lex, saw, &KW_TMP as u64) == 1u32 { d1 = 1u32 }
                }
                di = di + 1u64
            }
        }
    }
    if d1 == 0u32 { return base }
    let mut o: u64 = pp_cat(&FMT_SCRATCH as u64, 0u64, base)
    o = pp_cat(&FMT_SCRATCH as u64, o, " (did you mean `" as u64)
    o = pp_cat(&FMT_SCRATCH as u64, o, &KW_LC as u64)
    o = pp_cat(&FMT_SCRATCH as u64, o, "`?)" as u64)
    return iiip_strdup_rotating(&FMT_SCRATCH as u64)
}

/* B2 synth_insert: "missing <k>; assumed inserted" + INSERTED_TOKEN. */
fn iiip_synth_insert(st: u64, k: u32) -> u32 {
    let mut o: u64 = pp_cat(&FMT_SCRATCH as u64, 0u64, "missing " as u64)
    o = pp_cat(&FMT_SCRATCH as u64, o, iii_token_kind_name(k))
    o = pp_cat(&FMT_SCRATCH as u64, o, "; assumed inserted" as u64)
    iiip_record_error(st, 16u32, iiip_peek(st), iiip_strdup_rotating(&FMT_SCRATCH as u64), k)
    return 0u32
}
fn iiip_try_skip_token(st: u64, k: u32) -> u32 {
    if iiip_peek_kind(st) == III_TOK_EOF_P { return 0u32 }
    iiip_advance(st, &ADV_SCRATCH as u64)
    if iiip_peek_kind(st) == k { return 1u32 }
    return 0u32
}
/* iiip_expect: consume k or record UNEXPECTED_TOKEN + B2 soft-terminator
 * recovery.  out (104B token, or 0) receives the consumed/synthesised token. */
fn iiip_expect(st: u64, k: u32, out: u64) -> u32 {
    let mut dst: u64 = out
    if dst == 0u64 { dst = &ADV_SCRATCH as u64 }
    if iiip_peek_kind(st) == k {
        iiip_advance(st, dst)
        return 1u32
    }
    let mut o: u64 = pp_cat(&FMT_SCRATCH as u64, 0u64, "expected " as u64)
    o = pp_cat(&FMT_SCRATCH as u64, o, iii_token_kind_name(k))
    o = pp_cat(&FMT_SCRATCH as u64, o, ", saw " as u64)
    o = pp_cat(&FMT_SCRATCH as u64, o, iii_token_kind_name(iiip_peek_kind(st)))
    let msg: u64 = iiip_keyword_hint(st, &FMT_SCRATCH as u64, k)
    iiip_record_error(st, 1u32, iiip_peek(st), iiip_strdup_rotating(msg), k)
    let mut soft: u32 = 0u32
    if k == III_TOK_SEMI_P { soft = 1u32 }
    if k == III_TOK_RBRACE_P { soft = 1u32 }
    if k == III_TOK_RPAREN_P { soft = 1u32 }
    if k == III_TOK_COLON_P { soft = 1u32 }
    if soft == 1u32 {
        if iiip_try_skip_token(st, k) == 1u32 {
            iiip_advance(st, dst)
            return 1u32
        }
        iiip_synth_insert(st, k)
        if out != 0u64 { iii_lex_memset_c(out, 0u32, TOK_BYTES) ; iii_lex_write_u32_c(out, TOK_KIND, k) }
        return 1u32
    }
    return 0u32
}

/* recover_to: skip tokens until one of kinds[0..n) (or EOF). */
fn iiip_recover_to(st: u64, kinds: u64, n: u64) -> u32 {
    let mut go: u32 = 1u32
    while go == 1u32 {
        let k: u32 = iiip_peek_kind(st)
        if k == III_TOK_EOF_P { go = 0u32 }
        if go == 1u32 {
            let mut i: u64 = 0u64
            let mut hit: u32 = 0u32
            while i != n {
                if k == iii_lex_read_u32_c(kinds, i * 4u64) { hit = 1u32 ; i = n }
                if hit == 0u32 { i = i + 1u64 }
            }
            if hit == 1u32 { go = 0u32 }
            if go == 1u32 { iiip_advance(st, &ADV_SCRATCH as u64) }
        }
    }
    return 0u32
}
var RECOVER_FALLBACK : [u32; 4]
fn iiip_recover_follow(st: u64, pid: u32) -> u32 {
    let row: u64 = iiip_ff_lookup(pid)
    if row == 0u64 {
        iii_lex_write_u32_c(&RECOVER_FALLBACK as u64, 0u64, III_TOK_SEMI_P)
        iii_lex_write_u32_c(&RECOVER_FALLBACK as u64, 4u64, III_TOK_RBRACE_P)
        iii_lex_write_u32_c(&RECOVER_FALLBACK as u64, 8u64, III_TOK_EOF_P)
        iiip_recover_to(st, &RECOVER_FALLBACK as u64, 3u64)
        return 0u32
    }
    /* count FOLLOW entries (0-terminated, cap 16 -> our table holds 12). */
    let mut n: u64 = 0u64
    let mut cnt_done: u32 = 0u32
    while cnt_done == 0u32 {
        if n >= 12u64 { cnt_done = 1u32 }
        if cnt_done == 0u32 {
            if iii_lex_read_u32_c(row + FF_FOLLOW, n * 4u64) == 0u32 { cnt_done = 1u32 }
            if cnt_done == 0u32 { n = n + 1u64 }
        }
    }
    if n == 0u64 {
        iii_lex_write_u32_c(&RECOVER_FALLBACK as u64, 0u64, III_TOK_SEMI_P)
        iii_lex_write_u32_c(&RECOVER_FALLBACK as u64, 4u64, III_TOK_RBRACE_P)
        iii_lex_write_u32_c(&RECOVER_FALLBACK as u64, 8u64, III_TOK_EOF_P)
        iiip_recover_to(st, &RECOVER_FALLBACK as u64, 3u64)
        return 0u32
    }
    iiip_recover_to(st, row + FF_FOLLOW, n)
    return 0u32
}

/* ============================================================================
 * RITCHIE Stage 2.3.5 -- production cluster (the SCC).  Ported in compile-
 * checked batches via forward `extern from "parse.iii"` declarations for not-
 * yet-written productions (removed as each def lands).  Batch 1a = the Pratt
 * core: node_pos + binop_ra + unary + expr_prec + expr.  AST node offsets are
 * offsetof-probed (CONVERGENCE-AUDIT §2.3.5-prep).
 * ============================================================================ */
extern @abi(c-msvc-x64) fn iii_ast_get_mut(ast: u64, node_index: u32) -> u64 from "ast.iii"
/* forward externs -- removed when these productions are written in later batches */
/* primary + postfix + type_expr + block all defined (1c/1d/1f/1g).  No forward externs remain. */

const PA_AST_EXPR_BINARY: u32 = 49u32
const PA_AST_EXPR_UNARY: u32 = 50u32
const PA_UN_NEG: u32 = 1u32
const PA_UN_NOT: u32 = 2u32
const PA_UN_BNOT: u32 = 3u32
const PA_UN_DEREF: u32 = 4u32
const PA_UN_ADDR: u32 = 5u32
const III_TOK_OP_MINUS_P: u32 = 86u32
const III_TOK_OP_BANG_P: u32 = 93u32
const III_TOK_OP_TILDE_P: u32 = 92u32
const III_TOK_OP_STAR_P: u32 = 87u32
const III_TOK_OP_AMP_P: u32 = 90u32
const APOS_PHYS_LINE: u64 = 12u64
const APOS_PHYS_COL: u64 = 16u64
const NODE_U: u64 = 8u64

var NP_A : [u8; 16]
var NP_B : [u8; 16]

/* iiip_node_pos: write the node's first-physical-position 16B src_pos to out
 * (zeroed if none / synthetic). */
fn iiip_node_pos(st: u64, id: u32, out: u64) -> u32 {
    iii_lex_memset_c(out, 0u32, 16u64)
    if id == 0u32 { return 0u32 }
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    if iii_ast_position_first(ast, id, &POS_SCRATCH_P as u64) == 1i32 {
        if iii_lex_read_u32_c(&POS_SCRATCH_P as u64, APOS_KIND) == III_POS_PHYSICAL_P {
            iii_lex_write_u32_c(out, 0u64, iii_lex_read_u32_c(&POS_SCRATCH_P as u64, APOS_PHYS_START))
            iii_lex_write_u32_c(out, 4u64, iii_lex_read_u32_c(&POS_SCRATCH_P as u64, APOS_PHYS_END))
            iii_lex_write_u32_c(out, 8u64, iii_lex_read_u32_c(&POS_SCRATCH_P as u64, APOS_PHYS_LINE))
            iii_lex_write_u32_c(out, 12u64, iii_lex_read_u32_c(&POS_SCRATCH_P as u64, APOS_PHYS_COL))
        }
    }
    return 0u32
}
/* right-assoc flag for a binop trigger token (0 for all current entries). */
fn iiip_binop_ra(token: u32) -> u32 {
    binop_init()
    let mut i: u32 = 0u32
    let mut res: u32 = 0u32
    while i != 20u32 {
        let e: u64 = (&BINOP_TABLE as u64) + (i as u64) * 16u64
        if iii_lex_read_u32_c(e, 0u64) == token { res = iii_lex_read_u8_at_c(e, 8u64) }
        i = i + 1u32
    }
    return res
}

fn iiip_parse_unary(st: u64) -> u32 {
    let tok: u64 = iiip_peek(st)
    let k: u32 = iii_lex_read_u32_c(tok, TOK_KIND)
    let mut isunop: u32 = 0u32
    if k == III_TOK_OP_MINUS_P { isunop = 1u32 }
    if k == III_TOK_OP_BANG_P { isunop = 1u32 }
    if k == III_TOK_OP_TILDE_P { isunop = 1u32 }
    if k == III_TOK_OP_STAR_P { isunop = 1u32 }
    if k == III_TOK_OP_AMP_P { isunop = 1u32 }
    if isunop == 1u32 {
        /* capture the op token's pos as scalar locals (recursion-safe) before
         * advancing -- the shared NP_A/token globals are clobbered by the
         * recursive parse_unary below. */
        let op_start: u32 = iii_lex_read_u32_c(tok, TOK_START)
        let op_end: u32 = iii_lex_read_u32_c(tok, TOK_END)
        let op_line: u32 = iii_lex_read_u32_c(tok, TOK_LINE)
        let op_col: u32 = iii_lex_read_u32_c(tok, TOK_COL)
        iiip_advance(st, &ADV_SCRATCH as u64)
        let operand: u32 = iiip_parse_unary(st)
        if operand == 0u32 { return 0u32 }
        let mut op: u32 = PA_UN_ADDR
        if k == III_TOK_OP_MINUS_P { op = PA_UN_NEG }
        if k == III_TOK_OP_BANG_P { op = PA_UN_NOT }
        if k == III_TOK_OP_TILDE_P { op = PA_UN_BNOT }
        if k == III_TOK_OP_STAR_P { op = PA_UN_DEREF }
        let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
        let mut p_end: u32 = op_end
        if iii_ast_get(ast, operand) != 0u64 {
            iiip_node_pos(st, operand, &NP_B as u64)
            p_end = iii_lex_read_u32_c(&NP_B as u64, 4u64)
        }
        iii_lex_write_u32_c(&NP_A as u64, 0u64, op_start)
        iii_lex_write_u32_c(&NP_A as u64, 4u64, p_end)
        iii_lex_write_u32_c(&NP_A as u64, 8u64, op_line)
        iii_lex_write_u32_c(&NP_A as u64, 12u64, op_col)
        let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_UNARY, &NP_A as u64)
        if n == 0u32 { return 0u32 }
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u32_c(nn, NODE_U, op)
        iii_lex_write_u32_c(nn, NODE_U + 4u64, operand)
        return n
    }
    let prim: u32 = iiip_parse_primary(st)
    if prim == 0u32 { return 0u32 }
    return iiip_parse_postfix(st, prim)
}

/* Stage 3.11: cast level, looser than unary, tighter than binary, so `as`
 * binds the whole unary expr to its left (`&x as T` == `(&x) as T`, not
 * `&(x as T)`).  Left-associative for chains; non-unary `expr as T` is
 * unchanged (parse_unary->parse_postfix(expr), then the `as` here). */
fn iiip_parse_cast(st: u64) -> u32 {
    let mut lhs: u32 = iiip_parse_unary(st)
    if lhs == 0u32 { return 0u32 }
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut go: u32 = 1u32
    while go == 1u32 {
        if iiip_accept(st, III_TOK_KW_AS_P) == 1u32 {
            let target: u32 = iiip_parse_type_expr(st)
            if iii_ast_get(ast, lhs) != 0u64 { iiip_node_pos(st, lhs, &NP_A as u64) }
            if iii_ast_get(ast, lhs) == 0u64 { iiip_pos_of(iiip_peek(st), &NP_A as u64) }
            let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_CAST, &NP_A as u64)
            if n == 0u32 { return lhs }
            let nn: u64 = iii_ast_get_mut(ast, n)
            iii_lex_write_u32_c(nn, NODE_U, lhs)
            iii_lex_write_u32_c(nn, NODE_U + 4u64, target)
            lhs = n
        } else { go = 0u32 }
    }
    return lhs
}

fn iiip_parse_expr_prec(st: u64, min_prec: u32) -> u32 {
    let mut lhs: u32 = iiip_parse_cast(st)
    if lhs == 0u32 { return 0u32 }
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut go: u32 = 1u32
    while go == 1u32 {
        let k: u32 = iiip_peek_kind(st)
        let prec: u32 = iiip_binop_prec(k)
        if prec == 0u32 { go = 0u32 }
        if go == 1u32 { if prec < min_prec { go = 0u32 } }
        if go == 1u32 {
            let pt: u64 = iii_lex_read_u64_c(st, PS_PRATT_TRACE)
            if pt != 0u64 {
                let ptctx: u64 = iii_lex_read_u64_c(st, PS_PRATT_TRACE_CTX)
                pt(ptctx, iii_lex_read_u32_c(iiip_peek(st), TOK_START), prec, min_prec, 1u32)
            }
            iiip_advance(st, &ADV_SCRATCH as u64)
            let ra: u32 = iiip_binop_ra(k)
            let mut next_min: u32 = prec + 1u32
            if ra == 1u32 { next_min = prec }
            let rhs: u32 = iiip_parse_expr_prec(st, next_min)
            if rhs == 0u32 { go = 0u32 }
            if go == 1u32 {
                if iii_ast_get(ast, lhs) != 0u64 { iiip_node_pos(st, lhs, &NP_A as u64) }
                if iii_ast_get(ast, lhs) == 0u64 { iiip_pos_of(iiip_peek(st), &NP_A as u64) }
                if iii_ast_get(ast, rhs) != 0u64 {
                    iiip_node_pos(st, rhs, &NP_B as u64)
                    iii_lex_write_u32_c(&NP_A as u64, 4u64, iii_lex_read_u32_c(&NP_B as u64, 4u64))
                }
                let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_BINARY, &NP_A as u64)
                if n == 0u32 { go = 0u32 }
                if go == 1u32 {
                    let nn: u64 = iii_ast_get_mut(ast, n)
                    iii_lex_write_u32_c(nn, NODE_U, iiip_binop_op(k))
                    iii_lex_write_u32_c(nn, NODE_U + 4u64, lhs)
                    iii_lex_write_u32_c(nn, NODE_U + 8u64, rhs)
                    lhs = n
                }
            }
        }
    }
    return lhs
}

fn iiip_parse_expr(st: u64) -> u32 {
    iiip_bc_push(st, IIIP_PROD_EXPR, 0u32, 0u32)
    if iiip_enter_recursion(st) == 0u32 { iiip_bc_pop(st) ; return 0u32 }
    let r: u32 = iiip_parse_expr_prec(st, 1u32)
    iiip_leave_recursion(st)
    iiip_bc_pop(st)
    return r
}

/* ============================================================================
 * Batch 1b -- expression-cluster leaves: hexad_trits (6-trit reader),
 * arg (named/positional), arg_list.  (Defined now; called by primary/postfix
 * once those land in batch 1c.)
 * ============================================================================ */
extern @abi(c-msvc-x64) fn iii_ast_intern_string(ast: u64, payload: u64) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_open_list_create(ast: u64) -> u64 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_open_list_push(ol: u64, node_index: u32) -> i32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_open_list_commit(ast: u64, ol: u64) -> u64 from "ast.iii"

const III_TOK_KW_NEG_P: u32 = 49u32
const III_TOK_KW_ZERO_P: u32 = 50u32
const III_TOK_KW_POS_P: u32 = 51u32
const III_TOK_KW_TRIT_INVALID_P: u32 = 52u32
const III_TOK_OP_PLUS_P: u32 = 85u32
const III_TOK_UNDERSCORE_P: u32 = 82u32
const III_TOK_INT_LITERAL_P: u32 = 5u32
const III_TOK_OP_ASSIGN_P: u32 = 102u32
const III_TOK_COMMA_P: u32 = 75u32
const TOK_INT_VALUE: u64 = 40u64
const PA_AST_ARG: u32 = 57u32
const PARSE_TRIT_NEG: u32 = 0u32
const PARSE_TRIT_ZERO: u32 = 1u32
const PARSE_TRIT_POS: u32 = 2u32
const PARSE_TRIT_INVALID: u32 = 3u32

var HEXAD_ONE : [u8; 104]
var ARG_POS : [u8; 16]
var ARG_NAME_TOK : [u8; 104]

/* L1 hexad: read exactly 6 comma-separated trits into out[6]; 1=ok 0=fail. */
fn iiip_parse_hexad_trits(st: u64, out: u64, allow_pattern_extras: u32) -> u32 {
    let mut i: u64 = 0u64
    let mut failed: u32 = 0u32
    let mut done: u32 = 0u32
    while done == 0u32 {
        if i == 6u64 { done = 1u32 }
        if done == 0u32 {
            let tk: u32 = iii_lex_read_u32_c(iiip_peek(st), TOK_KIND)
            let mut handled: u32 = 0u32
            if tk == III_TOK_KW_NEG_P { iiip_advance(st, &ADV_SCRATCH as u64) ; iii_lex_write_u8_at_c(out, i, PARSE_TRIT_NEG) ; handled = 1u32 }
            if handled == 0u32 { if tk == III_TOK_KW_ZERO_P { iiip_advance(st, &ADV_SCRATCH as u64) ; iii_lex_write_u8_at_c(out, i, PARSE_TRIT_ZERO) ; handled = 1u32 } }
            if handled == 0u32 { if tk == III_TOK_KW_POS_P { iiip_advance(st, &ADV_SCRATCH as u64) ; iii_lex_write_u8_at_c(out, i, PARSE_TRIT_POS) ; handled = 1u32 } }
            if handled == 0u32 { if tk == III_TOK_KW_TRIT_INVALID_P { iiip_advance(st, &ADV_SCRATCH as u64) ; iii_lex_write_u8_at_c(out, i, PARSE_TRIT_INVALID) ; handled = 1u32 } }
            if handled == 0u32 { if allow_pattern_extras == 1u32 { if tk == III_TOK_UNDERSCORE_P { iiip_advance(st, &ADV_SCRATCH as u64) ; iii_lex_write_u8_at_c(out, i, PARSE_TRIT_INVALID) ; handled = 1u32 } } }
            if handled == 0u32 { if tk == III_TOK_OP_PLUS_P {
                iiip_advance(st, &ADV_SCRATCH as u64)
                if iiip_expect(st, III_TOK_INT_LITERAL_P, &HEXAD_ONE as u64) == 0u32 { failed = 1u32 ; done = 1u32 }
                if done == 0u32 { if iii_lex_read_u64_c(&HEXAD_ONE as u64, TOK_INT_VALUE) != 1u64 { failed = 1u32 ; done = 1u32 } }
                if done == 0u32 { iii_lex_write_u8_at_c(out, i, PARSE_TRIT_POS) ; handled = 1u32 }
            } }
            if handled == 0u32 { if done == 0u32 { if tk == III_TOK_OP_MINUS_P {
                iiip_advance(st, &ADV_SCRATCH as u64)
                if iiip_expect(st, III_TOK_INT_LITERAL_P, &HEXAD_ONE as u64) == 0u32 { failed = 1u32 ; done = 1u32 }
                if done == 0u32 { if iii_lex_read_u64_c(&HEXAD_ONE as u64, TOK_INT_VALUE) != 1u64 { failed = 1u32 ; done = 1u32 } }
                if done == 0u32 { iii_lex_write_u8_at_c(out, i, PARSE_TRIT_NEG) ; handled = 1u32 }
            } } }
            if handled == 0u32 { if done == 0u32 { if tk == III_TOK_INT_LITERAL_P {
                if iii_lex_read_u64_c(iiip_peek(st), TOK_INT_VALUE) == 0u64 { iiip_advance(st, &ADV_SCRATCH as u64) ; iii_lex_write_u8_at_c(out, i, PARSE_TRIT_ZERO) ; handled = 1u32 }
            } } }
            if handled == 0u32 { if done == 0u32 { failed = 1u32 ; done = 1u32 } }
            if done == 0u32 {
                if i < 5u64 { if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { failed = 1u32 ; done = 1u32 } }
                if done == 0u32 { i = i + 1u64 }
            }
        }
    }
    if failed == 1u32 { return 0u32 }
    return 1u32
}

/* arg ::= (IDENT "=")? expr  -- 2-token lookahead for the named form. */
fn iiip_parse_arg(st: u64) -> u32 {
    if iiip_enter_recursion(st) == 0u32 { return 0u32 }
    let mut arg_name: u64 = 0u64
    /* scalar pos locals (recursion-safe across the parse_expr below, which can
     * re-enter arg via f(g(x)) -> the ARG_POS global would be clobbered). */
    let mut named: u32 = 0u32
    let mut name_start: u32 = 0u32
    let mut name_line: u32 = 0u32
    let mut name_col: u32 = 0u32
    if iiip_peek_kind(st) == III_TOK_IDENTIFIER_P {
        if iiip_peek2_kind(st) == III_TOK_OP_ASSIGN_P {
            let nt: u64 = iiip_peek(st)
            name_start = iii_lex_read_u32_c(nt, TOK_START)
            name_line = iii_lex_read_u32_c(nt, TOK_LINE)
            name_col = iii_lex_read_u32_c(nt, TOK_COL)
            arg_name = iiip_text_of(nt)
            iiip_advance(st, &ADV_SCRATCH as u64)
            iiip_advance(st, &ADV_SCRATCH as u64)
            named = 1u32
        }
    }
    let value: u32 = iiip_parse_expr(st)
    if value == 0u32 { iiip_leave_recursion(st) ; return 0u32 }
    iiip_node_pos(st, value, &NP_B as u64)
    if named == 1u32 {
        iii_lex_write_u32_c(&ARG_POS as u64, 0u64, name_start)
        iii_lex_write_u32_c(&ARG_POS as u64, 4u64, iii_lex_read_u32_c(&NP_B as u64, 4u64))
        iii_lex_write_u32_c(&ARG_POS as u64, 8u64, name_line)
        iii_lex_write_u32_c(&ARG_POS as u64, 12u64, name_col)
    } else {
        iii_lex_memcpy_c(&ARG_POS as u64, &NP_B as u64, 16u64)
    }
    let arg: u32 = iiip_alloc_node(st, PA_AST_ARG, &ARG_POS as u64)
    if arg == 0u32 { iiip_leave_recursion(st) ; return 0u32 }
    let an: u64 = iii_ast_get_mut(iii_lex_read_u64_c(st, PS_AST), arg)
    iii_lex_write_u64_c(an, NODE_U, arg_name)
    iii_lex_write_u32_c(an, NODE_U + 8u64, value)
    iiip_leave_recursion(st)
    return arg
}

/* arg_list -> packed 8B iii_ast_list_t (0 = empty). */
fn iiip_parse_arg_list(st: u64) -> u64 {
    if iiip_match(st, III_TOK_RPAREN_P) == 1u32 { return 0u64 }
    let ol: u64 = iii_ast_open_list_create(iii_lex_read_u64_c(st, PS_AST))
    if ol == 0u64 { return 0u64 }
    let mut go: u32 = 1u32
    while go == 1u32 {
        let arg: u32 = iiip_parse_arg(st)
        if arg == 0u32 { go = 0u32 }
        if go == 1u32 {
            let pr: i32 = iii_ast_open_list_push(ol, arg)
            if pr == 0i32 { iiip_record_error(st, III_PARSE_E_OOM, iiip_peek(st), "argument list grow failed (out of memory)" as u64, PARSE_TOK_INVALID) ; go = 0u32 }   /* [soundness] OOM drop would compile a wrong-arity call */
            if go == 1u32 {
                if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { go = 0u32 }
                if go == 1u32 { iiip_skip_newlines(st) }
            }
        }
    }
    return iii_ast_open_list_commit(iii_lex_read_u64_c(st, PS_AST), ol)
}

/* ============================================================================
 * Batch 1c -- postfix (field/call/index/cast) + pattern.  postfix def removes
 * its forward extern; primary stays externed (batch 1d); type_expr/block are
 * forward-externed.  AST kinds/offsets per §2.3.5-prep.
 * ============================================================================ */
const PA_AST_EXPR_FIELD: u32 = 47u32
const PA_AST_EXPR_CALL: u32 = 46u32
const PA_AST_EXPR_INDEX: u32 = 48u32
const PA_AST_EXPR_CAST: u32 = 72u32
const PA_AST_PAT_WILDCARD: u32 = 35u32
const PA_AST_PAT_HEXAD: u32 = 34u32
const PA_AST_PAT_TUPLE: u32 = 36u32
const PA_AST_PAT_LITERAL: u32 = 32u32
const PA_AST_PAT_IDENT: u32 = 33u32
const III_TOK_DOT_P: u32 = 79u32
const III_TOK_LBRACKET_P: u32 = 73u32
const III_TOK_RBRACKET_P: u32 = 74u32
const III_TOK_KW_AS_P: u32 = 14u32
const III_TOK_LPAREN_P: u32 = 69u32
const III_TOK_HEX_LITERAL_P: u32 = 6u32
const III_TOK_STRING_LITERAL_P: u32 = 8u32
const III_TOK_KW_TRUE_P: u32 = 41u32
const III_TOK_KW_FALSE_P: u32 = 42u32

var PF_NAME : [u8; 104]
var PF_CLOSE : [u8; 104]
var PAT_TOK : [u8; 104]
var PAT_TRITS : [u8; 8]

fn iiip_parse_postfix(st: u64, lhs_in: u32) -> u32 {
    let mut lhs: u32 = lhs_in
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut go: u32 = 1u32
    while go == 1u32 {
        let mut matched: u32 = 0u32
        if iiip_accept(st, III_TOK_DOT_P) == 1u32 {
            matched = 1u32
            if iiip_expect(st, III_TOK_IDENTIFIER_P, &PF_NAME as u64) == 0u32 { go = 0u32 }
            if go == 1u32 {
                if iii_ast_get(ast, lhs) != 0u64 { iiip_node_pos(st, lhs, &NP_A as u64) }
                if iii_ast_get(ast, lhs) == 0u64 { iiip_pos_of(&PF_NAME as u64, &NP_A as u64) }
                iii_lex_write_u32_c(&NP_A as u64, 4u64, iii_lex_read_u32_c(&PF_NAME as u64, TOK_END))
                let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_FIELD, &NP_A as u64)
                if n == 0u32 { go = 0u32 }
                if go == 1u32 {
                    let nn: u64 = iii_ast_get_mut(ast, n)
                    iii_lex_write_u32_c(nn, NODE_U, lhs)
                    iii_lex_write_u64_c(nn, NODE_U + 4u64, iiip_text_of(&PF_NAME as u64))
                    lhs = n
                }
            }
        }
        if matched == 0u32 { if iiip_accept(st, III_TOK_LPAREN_P) == 1u32 {
            matched = 1u32
            let args: u64 = iiip_parse_arg_list(st)
            iiip_expect(st, III_TOK_RPAREN_P, &PF_CLOSE as u64)
            if iii_ast_get(ast, lhs) != 0u64 { iiip_node_pos(st, lhs, &NP_A as u64) }
            if iii_ast_get(ast, lhs) == 0u64 { iiip_pos_of(&PF_CLOSE as u64, &NP_A as u64) }
            iii_lex_write_u32_c(&NP_A as u64, 4u64, iii_lex_read_u32_c(&PF_CLOSE as u64, TOK_END))
            let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_CALL, &NP_A as u64)
            if n == 0u32 { go = 0u32 }
            if go == 1u32 {
                let nn: u64 = iii_ast_get_mut(ast, n)
                iii_lex_write_u32_c(nn, NODE_U, lhs)
                iii_lex_write_u64_c(nn, NODE_U + 4u64, args)
                lhs = n
            }
        } }
        if matched == 0u32 { if iiip_accept(st, III_TOK_LBRACKET_P) == 1u32 {
            matched = 1u32
            let idx: u32 = iiip_parse_expr(st)
            iiip_expect(st, III_TOK_RBRACKET_P, &PF_CLOSE as u64)
            if iii_ast_get(ast, lhs) != 0u64 { iiip_node_pos(st, lhs, &NP_A as u64) }
            if iii_ast_get(ast, lhs) == 0u64 { iiip_pos_of(&PF_CLOSE as u64, &NP_A as u64) }
            iii_lex_write_u32_c(&NP_A as u64, 4u64, iii_lex_read_u32_c(&PF_CLOSE as u64, TOK_END))
            let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_INDEX, &NP_A as u64)
            if n == 0u32 { go = 0u32 }
            if go == 1u32 {
                let nn: u64 = iii_ast_get_mut(ast, n)
                iii_lex_write_u32_c(nn, NODE_U, lhs)
                iii_lex_write_u32_c(nn, NODE_U + 4u64, idx)
                lhs = n
            }
        } }
        /* Stage 3.11: `as` is handled at iiip_parse_cast (looser than unary)
         * so `&x as T` == `(&x) as T`, not `&(x as T)`.  Not parsed here. */
        if matched == 0u32 { go = 0u32 }
    }
    return lhs
}

fn iiip_parse_pattern(st: u64) -> u32 {
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    iii_lex_memcpy_c(&PAT_TOK as u64, iiip_peek(st), TOK_BYTES)
    let tk: u32 = iii_lex_read_u32_c(&PAT_TOK as u64, TOK_KIND)
    /* capture pat-token pos before any recursion (PAT_TOK is shared global). */
    let pat_s: u32 = iii_lex_read_u32_c(&PAT_TOK as u64, TOK_START)
    let pat_e: u32 = iii_lex_read_u32_c(&PAT_TOK as u64, TOK_END)
    let pat_l: u32 = iii_lex_read_u32_c(&PAT_TOK as u64, TOK_LINE)
    let pat_c: u32 = iii_lex_read_u32_c(&PAT_TOK as u64, TOK_COL)
    if tk == III_TOK_UNDERSCORE_P {
        iiip_advance(st, &ADV_SCRATCH as u64)
        lparen_pos(pat_s, pat_e, pat_l, pat_c)
        return iiip_alloc_node(st, PA_AST_PAT_WILDCARD, &NP_A as u64)
    }
    if tk == III_TOK_LPAREN_P {
        iiip_advance(st, &ADV_SCRATCH as u64)
        let lk: u32 = iii_lex_read_u32_c(iiip_peek(st), TOK_KIND)
        let lv: u64 = iii_lex_read_u64_c(iiip_peek(st), TOK_INT_VALUE)
        let mut is_trit: u32 = 0u32
        if lk == III_TOK_KW_NEG_P { is_trit = 1u32 }
        if lk == III_TOK_KW_ZERO_P { is_trit = 1u32 }
        if lk == III_TOK_KW_POS_P { is_trit = 1u32 }
        if lk == III_TOK_KW_TRIT_INVALID_P { is_trit = 1u32 }
        if lk == III_TOK_OP_PLUS_P { is_trit = 1u32 }
        if lk == III_TOK_OP_MINUS_P { is_trit = 1u32 }
        if lk == III_TOK_INT_LITERAL_P { if lv == 0u64 { is_trit = 1u32 } }
        if lk == III_TOK_INT_LITERAL_P { if lv == 1u64 { is_trit = 1u32 } }
        if is_trit == 1u32 {
            if iiip_parse_hexad_trits(st, &PAT_TRITS as u64, 1u32) == 1u32 {
                if iiip_accept(st, III_TOK_RPAREN_P) == 1u32 {
                    lparen_pos(pat_s, pat_e, pat_l, pat_c)
                    iii_lex_write_u32_c(&NP_A as u64, 4u64, iii_lex_read_u32_c(iiip_peek(st), TOK_START))
                    let n: u32 = iiip_alloc_node(st, PA_AST_PAT_HEXAD, &NP_A as u64)
                    if n != 0u32 { iii_lex_memcpy_c(iii_ast_get_mut(ast, n) + NODE_U, &PAT_TRITS as u64, 6u64) }
                    return n
                }
            }
        }
        /* tuple pattern */
        let ol: u64 = iii_ast_open_list_create(ast)
        if ol != 0u64 { if iiip_match(st, III_TOK_RPAREN_P) == 0u32 {
            let mut go: u32 = 1u32
            while go == 1u32 {
                let p: u32 = iiip_parse_pattern(st)
                if p == 0u32 { go = 0u32 }
                if go == 1u32 {
                    let pr: i32 = iii_ast_open_list_push(ol, p)
                    if pr == 0i32 { iiip_record_error(st, III_PARSE_E_OOM, iiip_peek(st), "tuple pattern grow failed (out of memory)" as u64, PARSE_TOK_INVALID) ; go = 0u32 }   /* [soundness] OOM drop would compile a wrong-arity tuple pattern */
                    if go == 1u32 { if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { go = 0u32 } }
                }
            }
        } }
        iiip_expect(st, III_TOK_RPAREN_P, 0u64)
        let mut comps: u64 = 0u64
        if ol != 0u64 { comps = iii_ast_open_list_commit(ast, ol) }
        lparen_pos(pat_s, pat_e, pat_l, pat_c)
        let n: u32 = iiip_alloc_node(st, PA_AST_PAT_TUPLE, &NP_A as u64)
        if n != 0u32 { iii_lex_write_u64_c(iii_ast_get_mut(ast, n), NODE_U, comps) }
        return n
    }
    let mut islit: u32 = 0u32
    if tk == III_TOK_INT_LITERAL_P { islit = 1u32 }
    if tk == III_TOK_HEX_LITERAL_P { islit = 1u32 }
    if tk == III_TOK_STRING_LITERAL_P { islit = 1u32 }
    if tk == III_TOK_KW_TRUE_P { islit = 1u32 }
    if tk == III_TOK_KW_FALSE_P { islit = 1u32 }
    if islit == 1u32 {
        let lit: u32 = iiip_parse_primary(st)
        if iii_ast_get(ast, lit) != 0u64 { iiip_node_pos(st, lit, &NP_A as u64) }
        if iii_ast_get(ast, lit) == 0u64 { iiip_pos_of(&PAT_TOK as u64, &NP_A as u64) }
        let n: u32 = iiip_alloc_node(st, PA_AST_PAT_LITERAL, &NP_A as u64)
        if n != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(ast, n), NODE_U, lit) }
        return n
    }
    if tk == III_TOK_IDENTIFIER_P {
        iiip_advance(st, &ADV_SCRATCH as u64)
        let mut pats: u64 = 0u64
        if iiip_accept(st, III_TOK_LPAREN_P) == 1u32 {
            let ol: u64 = iii_ast_open_list_create(ast)
            if ol != 0u64 { if iiip_match(st, III_TOK_RPAREN_P) == 0u32 {
                let mut go: u32 = 1u32
                while go == 1u32 {
                    let p: u32 = iiip_parse_pattern(st)
                    if p == 0u32 { go = 0u32 }
                    if go == 1u32 {
                        iii_ast_open_list_push(ol, p)
                        if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { go = 0u32 }
                    }
                }
            } }
            iiip_expect(st, III_TOK_RPAREN_P, 0u64)
            if ol != 0u64 { pats = iii_ast_open_list_commit(ast, ol) }
        }
        lparen_pos(pat_s, pat_e, pat_l, pat_c)
        let n: u32 = iiip_alloc_node(st, PA_AST_PAT_IDENT, &NP_A as u64)
        if n != 0u32 {
            let nn: u64 = iii_ast_get_mut(ast, n)
            iii_lex_write_u64_c(nn, NODE_U, iiip_text_of(&PAT_TOK as u64))
            iii_lex_write_u64_c(nn, NODE_U + 8u64, pats)
        }
        return n
    }
    iiip_record_error(st, 6u32, &PAT_TOK as u64, "expected pattern" as u64, PARSE_TOK_INVALID)
    return 0u32
}

/* ============================================================================
 * Batch 1d -- primary (all arms) + registry_dispatch (R1).  primary def removes
 * its forward extern; block/type_expr stay externed.
 * ============================================================================ */
const PA_AST_EXPR_SIZEOF: u32 = 73u32
const PA_AST_EXPR_INT: u32 = 37u32
const PA_AST_EXPR_HEX: u32 = 38u32
const PA_AST_EXPR_MHASH: u32 = 39u32
const PA_AST_EXPR_STR: u32 = 40u32
const PA_AST_EXPR_BOOL: u32 = 41u32
const PA_AST_EXPR_TRIT: u32 = 42u32
const PA_AST_EXPR_IDENT: u32 = 45u32
const PA_AST_EXPR_UNIT: u32 = 44u32
const PA_AST_EXPR_HEXAD: u32 = 43u32
const PA_AST_EXPR_PAREN: u32 = 53u32
const PA_AST_EXPR_MATCH: u32 = 52u32
const PA_AST_MATCH_ARM: u32 = 31u32
const III_TOK_KW_SIZEOF_P: u32 = 107u32
const III_TOK_MHASH_LITERAL_P: u32 = 7u32
const III_TOK_KW_MATCH_P: u32 = 33u32
const III_TOK_KW_IF_P: u32 = 34u32
const III_TOK_FAT_ARROW_P: u32 = 84u32
const III_TOK_LBRACE_P: u32 = 71u32
const III_TOK_KW_TRUE_2P: u32 = 41u32
const TOK_MHASH: u64 = 52u64
const TOK_STRING_LEN: u64 = 84u64
const TOK_STRING_PAYLOAD: u64 = 88u64
const REG_COUNT_OFF: u64 = 1024u64
const REG_ENTRY_BYTES: u64 = 16u64

var PRIM_TOK : [u8; 104]
var PRIM_CLOSE : [u8; 104]
var PRIM_TRITS : [u8; 8]

/* R1 registry dispatch: first registered handler whose first_token matches
 * `leading` runs; non-zero return wins, else 0 (built-in path). */
fn iiip_registry_dispatch(st: u64, tbl: u64, leading: u32) -> u32 {
    if tbl == 0u64 { return 0u32 }
    if iii_lex_read_u32_c(tbl, REG_COUNT_OFF) == 0u32 { return 0u32 }
    if leading == PARSE_TOK_INVALID { return 0u32 }
    let mut i: u32 = 0u32
    let mut res: u32 = 0u32
    let mut done: u32 = 0u32
    while done == 0u32 {
        if i == 64u32 { done = 1u32 }
        if done == 0u32 {
            let e: u64 = tbl + (i as u64) * REG_ENTRY_BYTES
            if iii_lex_read_u32_c(e, 0u64) != 0u32 {
                if iii_lex_read_u32_c(e, 4u64) == leading {
                    let fnp: u64 = iii_lex_read_u64_c(e, 8u64)
                    if fnp != 0u64 { res = fnp(st) }
                    done = 1u32
                }
            }
            if done == 0u32 { i = i + 1u32 }
        }
    }
    return res
}

fn iiip_parse_primary(st: u64) -> u32 {
    iii_lex_memcpy_c(&PRIM_TOK as u64, iiip_peek(st), TOK_BYTES)
    let tk: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_KIND)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let r: u32 = iiip_registry_dispatch(st, st + PS_REG_PRIMARY, tk)
    if r != 0u32 { return r }
    if tk == III_TOK_KW_SIZEOF_P {
        let sz_s: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_START)
        let sz_e: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_END)
        let sz_l: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_LINE)
        let sz_c: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_COL)
        iiip_advance(st, &ADV_SCRATCH as u64)
        let target: u32 = iiip_parse_type_expr(st)
        iii_lex_write_u32_c(&NP_A as u64, 0u64, sz_s)
        iii_lex_write_u32_c(&NP_A as u64, 4u64, sz_e)
        iii_lex_write_u32_c(&NP_A as u64, 8u64, sz_l)
        iii_lex_write_u32_c(&NP_A as u64, 12u64, sz_c)
        let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_SIZEOF, &NP_A as u64)
        if n != 0u32 {
            let nn: u64 = iii_ast_get_mut(ast, n)
            iii_lex_write_u32_c(nn, NODE_U, target)
            iii_lex_write_u32_c(nn, NODE_U + 8u64, 0u32)
        }
        return n
    }
    if tk == III_TOK_INT_LITERAL_P {
        iiip_advance(st, &ADV_SCRATCH as u64)
        iiip_pos_of(&PRIM_TOK as u64, &NP_A as u64)
        let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_INT, &NP_A as u64)
        if n != 0u32 { iii_lex_write_u64_c(iii_ast_get_mut(ast, n), NODE_U, iii_lex_read_u64_c(&PRIM_TOK as u64, TOK_INT_VALUE)) }
        return n
    }
    if tk == III_TOK_HEX_LITERAL_P {
        iiip_advance(st, &ADV_SCRATCH as u64)
        iiip_pos_of(&PRIM_TOK as u64, &NP_A as u64)
        let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_HEX, &NP_A as u64)
        if n != 0u32 { iii_lex_write_u64_c(iii_ast_get_mut(ast, n), NODE_U, iii_lex_read_u64_c(&PRIM_TOK as u64, TOK_INT_VALUE)) }
        return n
    }
    if tk == III_TOK_MHASH_LITERAL_P {
        iiip_advance(st, &ADV_SCRATCH as u64)
        iiip_pos_of(&PRIM_TOK as u64, &NP_A as u64)
        let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_MHASH, &NP_A as u64)
        if n != 0u32 { iii_lex_memcpy_c(iii_ast_get_mut(ast, n) + NODE_U, (&PRIM_TOK as u64) + TOK_MHASH, 32u64) }
        return n
    }
    if tk == III_TOK_STRING_LITERAL_P {
        iiip_advance(st, &ADV_SCRATCH as u64)
        iiip_pos_of(&PRIM_TOK as u64, &NP_A as u64)
        let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_STR, &NP_A as u64)
        if n != 0u32 {
            let idx: u32 = iii_ast_intern_string(ast, iii_lex_read_u64_c(&PRIM_TOK as u64, TOK_STRING_PAYLOAD))
            let nn: u64 = iii_ast_get_mut(ast, n)
            iii_lex_write_u32_c(nn, NODE_U, idx)
            iii_lex_write_u32_c(nn, NODE_U + 4u64, iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_STRING_LEN))
        }
        return n
    }
    if tk == III_TOK_KW_TRUE_2P { return iiip_prim_bool(st, 1u32) }
    if tk == III_TOK_KW_FALSE_P { return iiip_prim_bool(st, 0u32) }
    if tk == III_TOK_KW_NEG_P { return iiip_prim_trit(st, PARSE_TRIT_NEG) }
    if tk == III_TOK_KW_ZERO_P { return iiip_prim_trit(st, PARSE_TRIT_ZERO) }
    if tk == III_TOK_KW_POS_P { return iiip_prim_trit(st, PARSE_TRIT_POS) }
    if tk == III_TOK_KW_TRIT_INVALID_P { return iiip_prim_trit(st, PARSE_TRIT_INVALID) }
    if tk == III_TOK_IDENTIFIER_P {
        iiip_advance(st, &ADV_SCRATCH as u64)
        iiip_pos_of(&PRIM_TOK as u64, &NP_A as u64)
        let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_IDENT, &NP_A as u64)
        if n != 0u32 { iii_lex_write_u64_c(iii_ast_get_mut(ast, n), NODE_U, iiip_text_of(&PRIM_TOK as u64)) }
        return n
    }
    if tk == III_TOK_LPAREN_P { return iiip_prim_lparen(st) }
    if tk == III_TOK_LBRACE_P { return iiip_parse_block(st) }
    if tk == III_TOK_KW_MATCH_P { return iiip_prim_match(st) }
    iiip_record_error(st, 5u32, &PRIM_TOK as u64, "expected expression" as u64, PARSE_TOK_INVALID)
    return 0u32
}

/* primary helpers (split out to keep iiip_parse_primary readable). */
fn iiip_prim_bool(st: u64, v: u32) -> u32 {
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    iiip_advance(st, &ADV_SCRATCH as u64)
    iiip_pos_of(&PRIM_TOK as u64, &NP_A as u64)
    let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_BOOL, &NP_A as u64)
    if n != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(ast, n), NODE_U, v) }
    return n
}
fn iiip_prim_trit(st: u64, trit: u32) -> u32 {
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    iiip_advance(st, &ADV_SCRATCH as u64)
    iiip_pos_of(&PRIM_TOK as u64, &NP_A as u64)
    let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_TRIT, &NP_A as u64)
    if n != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(ast, n), NODE_U, trit) }
    return n
}
fn iiip_prim_is_trit_start(tok: u64) -> u32 {
    let lk: u32 = iii_lex_read_u32_c(tok, TOK_KIND)
    let mut res: u32 = 0u32
    if lk == III_TOK_KW_NEG_P { res = 1u32 }
    if lk == III_TOK_KW_ZERO_P { res = 1u32 }
    if lk == III_TOK_KW_POS_P { res = 1u32 }
    if lk == III_TOK_KW_TRIT_INVALID_P { res = 1u32 }
    if lk == III_TOK_OP_PLUS_P { res = 1u32 }
    if lk == III_TOK_OP_MINUS_P { res = 1u32 }
    if lk == III_TOK_INT_LITERAL_P {
        let lv: u64 = iii_lex_read_u64_c(tok, TOK_INT_VALUE)
        if lv == 0u64 { res = 1u32 }
        if lv == 1u64 { res = 1u32 }
    }
    return res
}
fn iiip_prim_lparen(st: u64) -> u32 {
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    /* capture LPAREN pos before any recursion (PRIM_TOK is a shared global). */
    let lp_s: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_START)
    let lp_l: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_LINE)
    let lp_c: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_COL)
    iiip_advance(st, &ADV_SCRATCH as u64)
    if iiip_accept(st, III_TOK_RPAREN_P) == 1u32 {
        lparen_pos(lp_s, iii_lex_read_u32_c(iiip_peek(st), TOK_START), lp_l, lp_c)
        return iiip_alloc_node(st, PA_AST_EXPR_UNIT, &NP_A as u64)
    }
    if iiip_prim_is_trit_start(iiip_peek(st)) == 1u32 {
        if iiip_parse_hexad_trits(st, &PRIM_TRITS as u64, 0u32) == 1u32 {
            if iiip_expect(st, III_TOK_RPAREN_P, 0u64) == 0u32 {
                iiip_record_error(st, 8u32, &PRIM_TOK as u64, "hexad must contain exactly 6 trits" as u64, III_TOK_RPAREN_P)
            }
            lparen_pos(lp_s, iii_lex_read_u32_c(iiip_peek(st), TOK_START), lp_l, lp_c)
            let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_HEXAD, &NP_A as u64)
            if n != 0u32 { iii_lex_memcpy_c(iii_ast_get_mut(ast, n) + NODE_U, &PRIM_TRITS as u64, 6u64) }
            return n
        }
        iiip_record_error(st, 5u32, iiip_peek(st), "ambiguous parenthesised expression after partial hexad" as u64, PARSE_TOK_INVALID)
        return 0u32
    }
    let inner: u32 = iiip_parse_expr(st)
    iiip_expect(st, III_TOK_RPAREN_P, &PRIM_CLOSE as u64)
    iiip_pos_of(&PRIM_CLOSE as u64, &NP_B as u64)
    lparen_pos(lp_s, iii_lex_read_u32_c(&NP_B as u64, 4u64), lp_l, lp_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_PAREN, &NP_A as u64)
    if n != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(ast, n), NODE_U, inner) }
    return n
}
/* build NP_A = {start, end, line, col} from scalars (no clobber across recursion). */
fn lparen_pos(s: u32, e: u32, l: u32, c: u32) -> u32 {
    iii_lex_write_u32_c(&NP_A as u64, 0u64, s)
    iii_lex_write_u32_c(&NP_A as u64, 4u64, e)
    iii_lex_write_u32_c(&NP_A as u64, 8u64, l)
    iii_lex_write_u32_c(&NP_A as u64, 12u64, c)
    return 0u32
}
fn iiip_prim_match(st: u64) -> u32 {
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    /* capture MATCH-token pos before recursion (PRIM_TOK is shared). */
    let m_s: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_START)
    let m_e: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_END)
    let m_l: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_LINE)
    let m_c: u32 = iii_lex_read_u32_c(&PRIM_TOK as u64, TOK_COL)
    iiip_advance(st, &ADV_SCRATCH as u64)
    let scrut: u32 = iiip_parse_expr(st)
    iiip_expect(st, III_TOK_LBRACE_P, 0u64)
    let arms_ol: u64 = iii_ast_open_list_create(ast)
    let mut go: u32 = 1u32
    while go == 1u32 {
        iiip_skip_newlines(st)
        if iiip_accept(st, III_TOK_RBRACE_P) == 1u32 { go = 0u32 }
        if go == 1u32 { if iiip_match(st, III_TOK_EOF_P) == 1u32 { go = 0u32 } }
        if go == 1u32 {
            let pat: u32 = iiip_parse_pattern(st)
            let mut guard: u32 = 0u32
            if iiip_accept(st, III_TOK_KW_IF_P) == 1u32 { guard = iiip_parse_expr(st) }
            iiip_expect(st, III_TOK_FAT_ARROW_P, 0u64)
            let body: u32 = iiip_parse_expr(st)
            if pat != 0u32 { iiip_node_pos(st, pat, &NP_A as u64) }
            if pat == 0u32 { lparen_pos(m_s, m_e, m_l, m_c) }
            let arm: u32 = iiip_alloc_node(st, PA_AST_MATCH_ARM, &NP_A as u64)
            if arm != 0u32 {
                let an: u64 = iii_ast_get_mut(ast, arm)
                iii_lex_write_u32_c(an, NODE_U, pat)
                iii_lex_write_u32_c(an, NODE_U + 4u64, guard)
                iii_lex_write_u32_c(an, NODE_U + 8u64, body)
                if arms_ol != 0u64 { iii_ast_open_list_push(arms_ol, arm) }
            }
            iiip_accept(st, III_TOK_COMMA_P)
        }
    }
    let mut arms: u64 = 0u64
    if arms_ol != 0u64 { arms = iii_ast_open_list_commit(ast, arms_ol) }
    lparen_pos(m_s, m_e, m_l, m_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_MATCH, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u32_c(nn, NODE_U, scrut)
        iii_lex_write_u64_c(nn, NODE_U + 4u64, arms)
    }
    return n
}

/* ============================================================================
 * Batch 1e -- modifier productions (M1).  modifier_after_at + ring_set +
 * modifier + modifier_list.  No type_expr ref (stays externed).  MOD_* name
 * tokens are contiguous ranges 53-68 + 113-127 (+IDENT/KW_TYPE).
 * ============================================================================ */
const III_TOK_AT_P: u32 = 80u32
const III_TOK_KW_ANY_P: u32 = 48u32
const III_TOK_KW_TYPE_P: u32 = 17u32
const PA_AST_MODIFIER: u32 = 14u32
const III_RING_ANY: u32 = 15u32
const III_RING_R0: u32 = 2u32
const III_RING_R3: u32 = 1u32
const III_RING_RM1: u32 = 4u32
const III_RING_RM2: u32 = 8u32
const MOD_NAME_OFF: u64 = 8u64
const MOD_ARGS_OFF: u64 = 16u64
const MOD_RING_OFF: u64 = 24u64
const MOD_HEXAD_OFF: u64 = 28u64
const MOD_TIER_OFF: u64 = 32u64
const MOD_EPOCH_OFF: u64 = 36u64

var MOD_AT : [u8; 104]
var MOD_RT : [u8; 104]
var MOD_INT : [u8; 104]

fn iiip_mod_is_name(k: u32) -> u32 {
    if k == III_TOK_IDENTIFIER_P { return 1u32 }
    if k == III_TOK_KW_TYPE_P { return 1u32 }
    if k >= 53u32 { if k <= 68u32 { return 1u32 } }
    if k >= 113u32 { if k <= 127u32 { return 1u32 } }
    return 0u32
}

/* compound ring name R-1 / R-2 (the 'R' token already consumed into MOD_RT). */
fn iiip_ring_compound(st: u64) -> u32 {
    if iiip_accept(st, III_TOK_OP_MINUS_P) == 0u32 {
        iiip_record_error(st, 9u32, &MOD_RT as u64, "expected '-' after 'R' in compound ring name" as u64, III_TOK_OP_MINUS_P)
        return 0u32
    }
    if iiip_expect(st, III_TOK_INT_LITERAL_P, &MOD_INT as u64) == 0u32 { return 0u32 }
    let iv: u64 = iii_lex_read_u64_c(&MOD_INT as u64, TOK_INT_VALUE)
    if iv == 1u64 { return III_RING_RM1 }
    if iv == 2u64 { return III_RING_RM2 }
    iiip_record_error(st, 9u32, &MOD_INT as u64, "compound ring negative integer must be 1 or 2" as u64, III_TOK_INT_LITERAL_P)
    return 0u32
}
/* one IDENTIFIER ring name (already consumed into MOD_RT) -> mask bit. */
fn iiip_ring_ident(st: u64, lex: u64) -> u32 {
    if iiip_raw_eq(st, &MOD_RT as u64, "R0" as u64, 2u64) == 1u32 { return III_RING_R0 }
    if iiip_raw_eq(st, &MOD_RT as u64, "R3" as u64, 2u64) == 1u32 { return III_RING_R3 }
    if iiip_raw_eq(st, &MOD_RT as u64, "R" as u64, 1u64) == 1u32 { return iiip_ring_compound(st) }
    iiip_record_error(st, 9u32, &MOD_RT as u64, "unrecognised ring name in @ring(...)" as u64, III_TOK_IDENTIFIER_P)
    return 0u32
}
/* ring-set: comma-separated ring names inside @ring(...)/@phase(...). */
fn iiip_parse_ring_set(st: u64) -> u32 {
    let lex: u64 = iii_lex_read_u64_c(st, PS_LEX)
    let mut mask: u32 = 0u32
    let mut go: u32 = 1u32
    while go == 1u32 {
        if iiip_accept(st, III_TOK_RPAREN_P) == 1u32 { go = 0u32 }
        if go == 1u32 { if iiip_match(st, III_TOK_EOF_P) == 1u32 { go = 0u32 } }
        if go == 1u32 {
            let k: u32 = iiip_peek_kind(st)
            if k == III_TOK_KW_ANY_P {
                iiip_advance(st, &ADV_SCRATCH as u64)
                mask = mask | III_RING_ANY
            }
            if k == III_TOK_IDENTIFIER_P {
                iii_lex_memcpy_c(&MOD_RT as u64, iiip_peek(st), TOK_BYTES)
                iiip_advance(st, &ADV_SCRATCH as u64)
                mask = mask | iiip_ring_ident(st, lex)
            }
            if k != III_TOK_KW_ANY_P { if k != III_TOK_IDENTIFIER_P {
                iiip_record_error(st, 9u32, iiip_peek(st), "expected ring name in @ring(...)" as u64, III_TOK_IDENTIFIER_P)
                iiip_advance(st, &ADV_SCRATCH as u64)
            } }
            if go == 1u32 {
                if iiip_accept(st, III_TOK_COMMA_P) == 0u32 {
                    if iiip_accept(st, III_TOK_RPAREN_P) == 1u32 { go = 0u32 }
                }
            }
        }
    }
    return mask
}

fn iiip_parse_modifier_after_at(st: u64, at_tok: u64) -> u32 {
    let k: u32 = iiip_peek_kind(st)
    if iiip_mod_is_name(k) == 0u32 {
        iiip_record_error(st, 7u32, iiip_peek(st), "modifier name must be identifier or modifier keyword" as u64, III_TOK_IDENTIFIER_P)
        return 0u32
    }
    let lex: u64 = iii_lex_read_u64_c(st, PS_LEX)
    let nt: u64 = iiip_peek(st)
    let name_text: u64 = iiip_text_of(nt)
    let name_end: u32 = iii_lex_read_u32_c(nt, TOK_END)
    let is_ring: u32 = iiip_raw_eq(st, nt, "ring" as u64, 4u64)
    let is_phase: u32 = iiip_raw_eq(st, nt, "phase" as u64, 5u64)
    iiip_advance(st, &ADV_SCRATCH as u64)
    let at_start: u32 = iii_lex_read_u32_c(at_tok, TOK_START)
    let at_line: u32 = iii_lex_read_u32_c(at_tok, TOK_LINE)
    let at_col: u32 = iii_lex_read_u32_c(at_tok, TOK_COL)
    let mut args: u64 = 0u64
    let mut ring_mask: u32 = 0u32
    let mut pos_end: u32 = name_end
    if iiip_accept(st, III_TOK_LPAREN_P) == 1u32 {
        let mut isring: u32 = 0u32
        if is_ring == 1u32 { isring = 1u32 }
        if is_phase == 1u32 { isring = 1u32 }
        if isring == 1u32 { ring_mask = iiip_parse_ring_set(st) }
        if isring == 0u32 {
            args = iiip_parse_arg_list(st)
            iiip_expect(st, III_TOK_RPAREN_P, 0u64)
        }
        pos_end = iii_lex_read_u32_c(iiip_peek(st), TOK_START)
    }
    lparen_pos(at_start, pos_end, at_line, at_col)
    let mod: u32 = iiip_alloc_node(st, PA_AST_MODIFIER, &NP_A as u64)
    if mod == 0u32 { return 0u32 }
    let mn: u64 = iii_ast_get_mut(iii_lex_read_u64_c(st, PS_AST), mod)
    iii_lex_write_u64_c(mn, MOD_NAME_OFF, name_text)
    iii_lex_write_u64_c(mn, MOD_ARGS_OFF, args)
    iii_lex_write_u32_c(mn, MOD_RING_OFF, ring_mask)
    iii_lex_write_u32_c(mn, MOD_HEXAD_OFF, 0u32)
    iii_lex_write_u32_c(mn, MOD_TIER_OFF, 0u32)
    iii_lex_write_u32_c(mn, MOD_EPOCH_OFF, 0u32)
    return mod
}

fn iiip_parse_modifier(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_AT_P, &MOD_AT as u64) == 0u32 { return 0u32 }
    return iiip_parse_modifier_after_at(st, &MOD_AT as u64)
}

fn iiip_parse_modifier_list(st: u64) -> u64 {
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let ol: u64 = iii_ast_open_list_create(ast)
    if ol == 0u64 { return 0u64 }
    let mut go: u32 = 1u32
    while go == 1u32 {
        if iiip_match(st, III_TOK_AT_P) == 0u32 { go = 0u32 }
        if go == 1u32 {
            let mod: u32 = iiip_parse_modifier(st)
            if mod == 0u32 { go = 0u32 }
            if go == 1u32 {
                iii_ast_open_list_push(ol, mod)
                iiip_skip_newlines(st)
            }
        }
    }
    return iii_ast_open_list_commit(ast, ol)
}

/* ============================================================================
 * Batch 1f -- type productions.  5 arms split into shallow helpers (iiis-0
 * parser-depth rule) with recursion-safe scalar pos capture (the §1d rule).
 * type_expr delegates to type_simple.  Removes the type_expr forward extern.
 * ============================================================================ */
const PA_AST_TYPE_PTR: u32 = 16u32
const PA_AST_TYPE_ARRAY: u32 = 17u32
const PA_AST_TYPE_TUPLE: u32 = 18u32
const PA_AST_TYPE_FN: u32 = 19u32
const PA_AST_TYPE_REF: u32 = 15u32
const PA_AST_PARAM: u32 = 12u32
const III_TOK_OP_LT_P: u32 = 98u32
const III_TOK_OP_GT_P: u32 = 100u32
const III_TOK_COLON_PP: u32 = 77u32
const III_TOK_ARROW_P: u32 = 83u32
const III_TOK_KW_FN_P: u32 = 16u32

var TY_CNT : [u8; 104]
var TY_CLOSE : [u8; 104]
var TY_NAME : [u8; 104]
var TY_N2 : [u8; 104]

/* *T pointer type. */
fn iiip_type_ptr(st: u64) -> u32 {
    let tok: u64 = iiip_peek(st)
    let f_s: u32 = iii_lex_read_u32_c(tok, TOK_START)
    let f_e: u32 = iii_lex_read_u32_c(tok, TOK_END)
    let f_l: u32 = iii_lex_read_u32_c(tok, TOK_LINE)
    let f_c: u32 = iii_lex_read_u32_c(tok, TOK_COL)
    iiip_advance(st, &ADV_SCRATCH as u64)
    let inner: u32 = iiip_parse_type_expr(st)
    if inner == 0u32 { return 0u32 }
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut p_end: u32 = f_e
    if iii_ast_get(ast, inner) != 0u64 { iiip_node_pos(st, inner, &NP_B as u64) ; p_end = iii_lex_read_u32_c(&NP_B as u64, 4u64) }
    lparen_pos(f_s, p_end, f_l, f_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_TYPE_PTR, &NP_A as u64)
    if n == 0u32 { return 0u32 }
    let nn: u64 = iii_ast_get_mut(ast, n)
    iii_lex_write_u32_c(nn, 8u64, inner)
    iii_lex_write_u64_c(nn, 12u64, 0u64)
    return n
}
/* [T; N] array type. */
fn iiip_type_array(st: u64) -> u32 {
    let tok: u64 = iiip_peek(st)
    let f_s: u32 = iii_lex_read_u32_c(tok, TOK_START)
    let f_l: u32 = iii_lex_read_u32_c(tok, TOK_LINE)
    let f_c: u32 = iii_lex_read_u32_c(tok, TOK_COL)
    iiip_advance(st, &ADV_SCRATCH as u64)
    let inner: u32 = iiip_parse_type_expr(st)
    iiip_expect(st, III_TOK_SEMI_P, 0u64)
    if iiip_expect(st, III_TOK_INT_LITERAL_P, &TY_CNT as u64) == 0u32 { return 0u32 }
    let cnt_val: u64 = iii_lex_read_u64_c(&TY_CNT as u64, TOK_INT_VALUE)
    iiip_expect(st, III_TOK_RBRACKET_P, &TY_CLOSE as u64)
    lparen_pos(f_s, iii_lex_read_u32_c(&TY_CLOSE as u64, TOK_END), f_l, f_c)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let n: u32 = iiip_alloc_node(st, PA_AST_TYPE_ARRAY, &NP_A as u64)
    if n == 0u32 { return 0u32 }
    let nn: u64 = iii_ast_get_mut(ast, n)
    iii_lex_write_u32_c(nn, 8u64, inner)
    iii_lex_write_u64_c(nn, 16u64, cnt_val)
    iii_lex_write_u64_c(nn, 24u64, 0u64)
    return n
}
/* (T, T, ...) tuple type. */
fn iiip_type_tuple(st: u64) -> u32 {
    let tok: u64 = iiip_peek(st)
    let f_s: u32 = iii_lex_read_u32_c(tok, TOK_START)
    let f_l: u32 = iii_lex_read_u32_c(tok, TOK_LINE)
    let f_c: u32 = iii_lex_read_u32_c(tok, TOK_COL)
    iiip_advance(st, &ADV_SCRATCH as u64)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let ol: u64 = iii_ast_open_list_create(ast)
    if ol != 0u64 { if iiip_match(st, III_TOK_RPAREN_P) == 0u32 {
        let mut go: u32 = 1u32
        while go == 1u32 {
            let t: u32 = iiip_parse_type_expr(st)
            if t == 0u32 { go = 0u32 }
            if go == 1u32 {
                iii_ast_open_list_push(ol, t)
                if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { go = 0u32 }
                if go == 1u32 { iiip_skip_newlines(st) }
            }
        }
    } }
    iiip_expect(st, III_TOK_RPAREN_P, &TY_CLOSE as u64)
    let mut comps: u64 = 0u64
    if ol != 0u64 { comps = iii_ast_open_list_commit(ast, ol) }
    lparen_pos(f_s, iii_lex_read_u32_c(&TY_CLOSE as u64, TOK_END), f_l, f_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_TYPE_TUPLE, &NP_A as u64)
    if n == 0u32 { return 0u32 }
    let nn: u64 = iii_ast_get_mut(ast, n)
    iii_lex_write_u64_c(nn, 8u64, comps)
    iii_lex_write_u64_c(nn, 16u64, 0u64)
    return n
}
/* one `name : T` fn-type parameter. */
fn iiip_type_fn_param(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &TY_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&TY_NAME as u64)
    let p_s: u32 = iii_lex_read_u32_c(&TY_NAME as u64, TOK_START)
    let p_e: u32 = iii_lex_read_u32_c(&TY_NAME as u64, TOK_END)
    let p_l: u32 = iii_lex_read_u32_c(&TY_NAME as u64, TOK_LINE)
    let p_c: u32 = iii_lex_read_u32_c(&TY_NAME as u64, TOK_COL)
    iiip_expect(st, III_TOK_COLON_PP, 0u64)
    let pt: u32 = iiip_parse_type_expr(st)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut pe: u32 = p_e
    if pt != 0u32 { iiip_node_pos(st, pt, &NP_B as u64) ; pe = iii_lex_read_u32_c(&NP_B as u64, 4u64) }
    lparen_pos(p_s, pe, p_l, p_c)
    let pn: u32 = iiip_alloc_node(st, PA_AST_PARAM, &NP_A as u64)
    if pn == 0u32 { return 0u32 }
    let pnp: u64 = iii_ast_get_mut(ast, pn)
    iii_lex_write_u64_c(pnp, 8u64, nm)
    iii_lex_write_u32_c(pnp, 16u64, pt)
    return pn
}
/* fn(params) -> T function type. */
fn iiip_type_fn(st: u64) -> u32 {
    let tok: u64 = iiip_peek(st)
    let f_s: u32 = iii_lex_read_u32_c(tok, TOK_START)
    let f_e: u32 = iii_lex_read_u32_c(tok, TOK_END)
    let f_l: u32 = iii_lex_read_u32_c(tok, TOK_LINE)
    let f_c: u32 = iii_lex_read_u32_c(tok, TOK_COL)
    iiip_advance(st, &ADV_SCRATCH as u64)
    iiip_expect(st, III_TOK_LPAREN_P, 0u64)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let pol: u64 = iii_ast_open_list_create(ast)
    if pol != 0u64 { if iiip_match(st, III_TOK_RPAREN_P) == 0u32 {
        let mut go: u32 = 1u32
        while go == 1u32 {
            let pn: u32 = iiip_type_fn_param(st)
            if pn == 0u32 { go = 0u32 }
            if go == 1u32 {
                iii_ast_open_list_push(pol, pn)
                if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { go = 0u32 }
                if go == 1u32 { iiip_skip_newlines(st) }
            }
        }
    } }
    iiip_expect(st, III_TOK_RPAREN_P, 0u64)
    let mut params: u64 = 0u64
    if pol != 0u64 { params = iii_ast_open_list_commit(ast, pol) }
    iiip_expect(st, III_TOK_ARROW_P, 0u64)
    let ret: u32 = iiip_parse_type_expr(st)
    let mut p_end: u32 = f_e
    if ret != 0u32 { iiip_node_pos(st, ret, &NP_B as u64) ; p_end = iii_lex_read_u32_c(&NP_B as u64, 4u64) }
    lparen_pos(f_s, p_end, f_l, f_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_TYPE_FN, &NP_A as u64)
    if n == 0u32 { return 0u32 }
    let nn: u64 = iii_ast_get_mut(ast, n)
    iii_lex_write_u64_c(nn, 8u64, params)
    iii_lex_write_u32_c(nn, 16u64, ret)
    iii_lex_write_u32_c(nn, 20u64, 0u32)
    return n
}
/* type-arg list inside `<...>`; one arg = type_expr or (int/hex/mhash) expr. */
fn iiip_type_arg_one(st: u64) -> u32 {
    let a: u32 = iiip_parse_type_expr(st)
    if a != 0u32 { return a }
    if iiip_match(st, III_TOK_INT_LITERAL_P) == 1u32 { return iiip_parse_expr(st) }
    if iiip_match(st, III_TOK_HEX_LITERAL_P) == 1u32 { return iiip_parse_expr(st) }
    if iiip_match(st, III_TOK_MHASH_LITERAL_P) == 1u32 { return iiip_parse_expr(st) }
    return 0u32
}
/* name[.name]*[<type_args>] reference type. */
fn iiip_type_ref(st: u64) -> u32 {
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &TY_NAME as u64) == 0u32 {
        iiip_record_error(st, 4u32, iiip_peek(st), "expected type expression" as u64, III_TOK_IDENTIFIER_P)
        return 0u32
    }
    let name_off: u64 = iii_lex_read_u32_c(&TY_NAME as u64, TOK_START) as u64
    let mut name_len: u64 = (iii_lex_read_u32_c(&TY_NAME as u64, TOK_END) - iii_lex_read_u32_c(&TY_NAME as u64, TOK_START)) as u64
    let r_s: u32 = iii_lex_read_u32_c(&TY_NAME as u64, TOK_START)
    let r_l: u32 = iii_lex_read_u32_c(&TY_NAME as u64, TOK_LINE)
    let r_c: u32 = iii_lex_read_u32_c(&TY_NAME as u64, TOK_COL)
    let mut r_end: u32 = iii_lex_read_u32_c(&TY_NAME as u64, TOK_END)
    let mut dot: u32 = 1u32
    while dot == 1u32 {
        if iiip_accept(st, III_TOK_DOT_P) == 0u32 { dot = 0u32 }
        if dot == 1u32 {
            if iiip_expect(st, III_TOK_IDENTIFIER_P, &TY_N2 as u64) == 0u32 { dot = 0u32 }
            if dot == 1u32 {
                name_len = (iii_lex_read_u32_c(&TY_N2 as u64, TOK_END) as u64) - name_off
                r_end = iii_lex_read_u32_c(&TY_N2 as u64, TOK_END)
            }
        }
    }
    let mut type_args: u64 = 0u64
    if iiip_accept(st, III_TOK_OP_LT_P) == 1u32 {
        let tol: u64 = iii_ast_open_list_create(ast)
        if tol != 0u64 { if iiip_match(st, III_TOK_OP_GT_P) == 0u32 {
            let mut go: u32 = 1u32
            while go == 1u32 {
                let a: u32 = iiip_type_arg_one(st)
                if a == 0u32 { go = 0u32 }
                if go == 1u32 {
                    iii_ast_open_list_push(tol, a)
                    if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { go = 0u32 }
                }
            }
        } }
        iiip_expect(st, III_TOK_OP_GT_P, 0u64)
        if tol != 0u64 { type_args = iii_ast_open_list_commit(ast, tol) }
        r_end = iii_lex_read_u32_c(iiip_peek(st), TOK_START)
    }
    lparen_pos(r_s, r_end, r_l, r_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_TYPE_REF, &NP_A as u64)
    if n == 0u32 { return 0u32 }
    let nn: u64 = iii_ast_get_mut(ast, n)
    iii_lex_write_u64_c(nn, 8u64, name_off | (name_len << 32u64))
    iii_lex_write_u64_c(nn, 16u64, type_args)
    iii_lex_write_u64_c(nn, 24u64, 0u64)
    return n
}
fn iiip_type_dispatch(st: u64) -> u32 {
    let fk: u32 = iiip_peek_kind(st)
    if fk == III_TOK_OP_STAR_P { return iiip_type_ptr(st) }
    if fk == III_TOK_LBRACKET_P { return iiip_type_array(st) }
    if fk == III_TOK_LPAREN_P { return iiip_type_tuple(st) }
    if fk == III_TOK_KW_FN_P { return iiip_type_fn(st) }
    return iiip_type_ref(st)
}
fn iiip_parse_type_simple(st: u64) -> u32 {
    if iiip_enter_recursion(st) == 0u32 { return 0u32 }
    let r: u32 = iiip_type_dispatch(st)
    iiip_leave_recursion(st)
    return r
}
fn iiip_parse_type_expr(st: u64) -> u32 {
    return iiip_parse_type_simple(st)
}

/* ============================================================================
 * Batch 1g -- statement layer: block + stmt-dispatch + 12 statement helpers.
 * Closes the expression+type+pattern+statement SCC (block forward-extern gone).
 * Shallow helpers + recursion-safe kw-pos capture.
 * ============================================================================ */
const PA_AST_EXPR_BLOCK: u32 = 51u32
const PA_AST_STMT_LET: u32 = 20u32
const PA_AST_STMT_EXPR: u32 = 28u32
const PA_AST_STMT_WAVEFRONT: u32 = 21u32
const PA_AST_STMT_SANCTUM_ENTER: u32 = 22u32
const PA_AST_STMT_METAL: u32 = 23u32
const PA_AST_STMT_IF: u32 = 69u32
const PA_AST_STMT_WHILE: u32 = 70u32
const PA_AST_STMT_LOOP: u32 = 76u32
const PA_AST_STMT_BREAK: u32 = 77u32
const PA_AST_STMT_CONTINUE: u32 = 78u32
const PA_AST_STMT_FOR: u32 = 24u32
const PA_AST_STMT_RETURN: u32 = 26u32
const PA_AST_STMT_ASSIGN: u32 = 27u32
const PA_AST_EXPR_RANGE: u32 = 71u32
const III_TOK_KW_LET_P: u32 = 25u32
const III_TOK_KW_MUT_P: u32 = 26u32
const III_TOK_KW_WAVEFRONT_P: u32 = 27u32
const III_TOK_KW_SANCTUM_ENTER_P: u32 = 28u32
const III_TOK_KW_METAL_P: u32 = 29u32
const III_TOK_KW_FOR_P: u32 = 30u32
const III_TOK_KW_RETURN_P: u32 = 35u32
const III_TOK_KW_IF_PP: u32 = 34u32
const III_TOK_KW_WHILE_P: u32 = 105u32
const III_TOK_KW_LOOP_P: u32 = 110u32
const III_TOK_KW_BREAK_P: u32 = 111u32
const III_TOK_KW_CONTINUE_P: u32 = 112u32
const III_TOK_KW_MATCH_PP: u32 = 33u32
const III_TOK_KW_ELSE_P: u32 = 104u32
const III_TOK_KW_IN_P: u32 = 31u32
const III_TOK_KW_UNTIL_P: u32 = 36u32
const III_TOK_KW_QUIESCENT_P: u32 = 37u32
const III_TOK_KW_ON_ROLLBACK_P: u32 = 38u32
const III_TOK_KW_WHERE_P: u32 = 32u32
const III_TOK_OP_DOTDOT_P: u32 = 106u32

var ST_KW : [u8; 104]
var ST_NAME : [u8; 104]
var ST_AT : [u8; 104]
var ST_CLOSE : [u8; 104]

/* read kw token pos -> NP_A (recursion-safe via scalar locals). */
fn st_kw_pos(s: u32, e: u32, l: u32, c: u32) -> u32 {
    iii_lex_write_u32_c(&NP_A as u64, 0u64, s)
    iii_lex_write_u32_c(&NP_A as u64, 4u64, e)
    iii_lex_write_u32_c(&NP_A as u64, 8u64, l)
    iii_lex_write_u32_c(&NP_A as u64, 12u64, c)
    return 0u32
}
/* attach trailing @modifier(...) to a TYPE_REF type node (let/param). */
fn iiip_attach_type_mods(st: u64, type_node: u32) -> u32 {
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut ol: u64 = 0u64
    let mut go: u32 = 1u32
    while go == 1u32 {
        if iiip_match(st, III_TOK_AT_P) == 0u32 { go = 0u32 }
        if go == 1u32 {
            iiip_advance(st, &ST_AT as u64)
            let m: u32 = iiip_parse_modifier_after_at(st, &ST_AT as u64)
            if m != 0u32 {
                if ol == 0u64 { ol = iii_ast_open_list_create(ast) }
                if ol != 0u64 { iii_ast_open_list_push(ol, m) }
            }
        }
    }
    if ol != 0u64 {
        let mods: u64 = iii_ast_open_list_commit(ast, ol)
        if type_node != 0u32 {
            let tnp: u64 = iii_ast_get_mut(ast, type_node)
            if iii_lex_read_u32_c(tnp, 0u64) == PA_AST_TYPE_REF { iii_lex_write_u64_c(tnp, 24u64, mods) }
        }
    }
    return 0u32
}

fn iiip_parse_block(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_LBRACE_P, &ST_KW as u64) == 0u32 { return 0u32 }
    /* Push the BLOCK recursion budget (IIIP_PROD_BLOCK=256) for the duration of this block,
     * so statement nesting inside it is NOT capped at the enclosing context's budget.  The
     * budget table defines IIIP_PROD_BLOCK=256 expressly for this, but parse_block never pushed
     * it -- so a function body inherited IIIP_PROD_FN_DECL's budget of 8, falsely rejecting any
     * function nested deeper than ~8 with "parse recursion limit exceeded".  Popped before the
     * single return below (bc stack is bounded + self-balancing; bc_pop is a no-op at depth 0). */
    iiip_bc_push(st, IIIP_PROD_BLOCK, 0u32, 0u32)
    let lb_s: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_START)
    let lb_e: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_END)
    let lb_l: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE)
    let lb_c: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_COL)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let ol: u64 = iii_ast_open_list_create(ast)
    let mut go: u32 = 1u32
    while go == 1u32 {
        iiip_skip_newlines(st)
        if iiip_accept(st, III_TOK_RBRACE_P) == 1u32 { go = 0u32 }
        if go == 1u32 { if iiip_match(st, III_TOK_EOF_P) == 1u32 { go = 0u32 } }
        if go == 1u32 {
            let s: u32 = iiip_parse_stmt(st)
            if s == 0u32 {
                iiip_recover_follow(st, IIIP_PROD_BLOCK)
                iiip_accept(st, III_TOK_SEMI_P)
                iiip_accept(st, III_TOK_NEWLINE_P)
            } else {
                if ol != 0u64 { iii_ast_open_list_push(ol, s) }
                iiip_skip_newlines(st)
                iiip_accept(st, III_TOK_SEMI_P)
            }
        }
    }
    let mut stmts: u64 = 0u64
    if ol != 0u64 { stmts = iii_ast_open_list_commit(ast, ol) }
    st_kw_pos(lb_s, lb_e, lb_l, lb_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_EXPR_BLOCK, &NP_A as u64)
    if n != 0u32 { iii_lex_write_u64_c(iii_ast_get_mut(ast, n), 8u64, stmts) }
    iiip_bc_pop(st)
    return n
}

fn iiip_parse_let(st: u64) -> u32 {
    /* Stage 3.17: accept `let` or `var` (var = mutable local; enables local
     * arrays via the array-typed STMT_LET codegen).  Module-scope `var`
     * routes separately; this is statement position only. */
    let lv_k: u32 = iiip_peek_kind(st)
    if lv_k == III_TOK_KW_VAR_P {
        if iiip_expect(st, III_TOK_KW_VAR_P, &ST_KW as u64) == 0u32 { return 0u32 }
    } else {
        if iiip_expect(st, III_TOK_KW_LET_P, &ST_KW as u64) == 0u32 { return 0u32 }
    }
    let kw_s: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_COL)
    let mut mutable_: u32 = 0u32
    if lv_k == III_TOK_KW_VAR_P { mutable_ = 1u32 } else { mutable_ = iiip_accept(st, III_TOK_KW_MUT_P) }
    if iiip_peek_kind(st) == III_TOK_UNDERSCORE_P {
        iii_lex_memcpy_c(&ST_NAME as u64, iiip_peek(st), TOK_BYTES)
        iiip_advance(st, &ADV_SCRATCH as u64)
    } else {
        if iiip_expect(st, III_TOK_IDENTIFIER_P, &ST_NAME as u64) == 0u32 { return 0u32 }
    }
    let name_text: u64 = iiip_text_of(&ST_NAME as u64)
    let mut type_node: u32 = 0u32
    if iiip_accept(st, III_TOK_COLON_PP) == 1u32 {
        type_node = iiip_parse_type_expr(st)
        iiip_attach_type_mods(st, type_node)
    }
    let mut value: u32 = 0u32
    if iiip_accept(st, III_TOK_OP_ASSIGN_P) == 1u32 {
        value = iiip_parse_expr(st)
    } else {
        if type_node == 0u32 {
            iiip_record_error(st, 5u32, iiip_peek(st), "let without type annotation requires '= expr' initializer" as u64, III_TOK_OP_ASSIGN_P)
        }
    }
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let n: u32 = iiip_alloc_node(st, PA_AST_STMT_LET, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u32_c(nn, 8u64, mutable_)
        iii_lex_write_u64_c(nn, 12u64, name_text)
        iii_lex_write_u32_c(nn, 20u64, type_node)
        iii_lex_write_u32_c(nn, 24u64, value)
    }
    return n
}

fn iiip_parse_wavefront(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_WAVEFRONT_P, &ST_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_COL)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mods: u64 = iiip_parse_modifier_list(st)
    iiip_expect(st, III_TOK_LBRACE_P, 0u64)
    let ol: u64 = iii_ast_open_list_create(ast)
    let mut go: u32 = 1u32
    while go == 1u32 {
        iiip_skip_newlines(st)
        if iiip_accept(st, III_TOK_RBRACE_P) == 1u32 { go = 0u32 }
        if go == 1u32 { if iiip_match(st, III_TOK_EOF_P) == 1u32 { go = 0u32 } }
        if go == 1u32 {
            let expr: u32 = iiip_parse_expr(st)
            if expr == 0u32 { go = 0u32 }
            if go == 1u32 {
                iiip_node_pos(st, expr, &NP_A as u64)
                let es: u32 = iiip_alloc_node(st, PA_AST_STMT_EXPR, &NP_A as u64)
                if es != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(ast, es), 8u64, expr) }
                if ol != 0u64 { iii_ast_open_list_push(ol, es) }
                iiip_accept(st, III_TOK_SEMI_P)
                iiip_skip_newlines(st)
            }
        }
    }
    let mut nodes: u64 = 0u64
    if ol != 0u64 { nodes = iii_ast_open_list_commit(ast, ol) }
    iiip_accept(st, III_TOK_KW_UNTIL_P)
    iiip_accept(st, III_TOK_KW_QUIESCENT_P)
    let mut on_rb: u32 = 0u32
    if iiip_accept(st, III_TOK_SEMI_P) == 1u32 {
        if iiip_accept(st, III_TOK_KW_ON_ROLLBACK_P) == 1u32 { on_rb = iiip_parse_block(st) }
    }
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_STMT_WAVEFRONT, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, mods)
        iii_lex_write_u64_c(nn, 16u64, nodes)
        iii_lex_write_u32_c(nn, 24u64, on_rb)
    }
    return n
}

fn iiip_parse_sanctum_enter(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_SANCTUM_ENTER_P, &ST_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_COL)
    iiip_expect(st, III_TOK_PIPE_P, 0u64)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &ST_NAME as u64) == 0u32 { return 0u32 }
    let var_text: u64 = iiip_text_of(&ST_NAME as u64)
    iiip_expect(st, III_TOK_PIPE_P, 0u64)
    let body: u32 = iiip_parse_block(st)
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let n: u32 = iiip_alloc_node(st, PA_AST_STMT_SANCTUM_ENTER, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, var_text)
        iii_lex_write_u32_c(nn, 16u64, body)
    }
    return n
}

fn iiip_parse_metal(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_METAL_P, &ST_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_COL)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut ring_mask: u32 = 0u32
    if iiip_match(st, III_TOK_AT_P) == 1u32 {
        let mod: u32 = iiip_parse_modifier(st)
        if mod != 0u32 {
            let mn: u64 = iii_ast_get(ast, mod)
            if mn != 0u64 { ring_mask = iii_lex_read_u32_c(mn, MOD_RING_OFF) }
        }
    }
    iiip_expect(st, III_TOK_LBRACE_P, 0u64)
    let mut depth: u32 = 1u32
    let body_start: u32 = iii_lex_read_u32_c(iiip_peek(st), TOK_START)
    let mut body_end: u32 = body_start
    let mut go: u32 = 1u32
    while go == 1u32 {
        let mk: u32 = iiip_peek_kind(st)
        if mk == III_TOK_LBRACE_P {
            depth = depth + 1u32
            body_end = iii_lex_read_u32_c(iiip_peek(st), TOK_END)
            iiip_advance(st, &ADV_SCRATCH as u64)
        }
        if mk == III_TOK_RBRACE_P {
            depth = depth - 1u32
            iii_lex_memcpy_c(&ST_CLOSE as u64, iiip_peek(st), TOK_BYTES)
            iiip_advance(st, &ADV_SCRATCH as u64)
            if depth == 0u32 { body_end = iii_lex_read_u32_c(&ST_CLOSE as u64, TOK_START) ; go = 0u32 }
            if depth != 0u32 { body_end = iii_lex_read_u32_c(&ST_CLOSE as u64, TOK_END) }
        }
        if mk == III_TOK_EOF_P {
            iiip_record_error(st, 14u32, iiip_peek(st), "unterminated metal {} block" as u64, III_TOK_RBRACE_P)
            go = 0u32
        }
        if mk != III_TOK_LBRACE_P { if mk != III_TOK_RBRACE_P { if mk != III_TOK_EOF_P {
            body_end = iii_lex_read_u32_c(iiip_peek(st), TOK_END)
            iiip_advance(st, &ADV_SCRATCH as u64)
        } } }
    }
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_STMT_METAL, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u32_c(nn, 8u64, ring_mask)
        iii_lex_write_u32_c(nn, 12u64, body_start)
        iii_lex_write_u32_c(nn, 16u64, body_end - body_start)
    }
    return n
}

fn iiip_parse_if(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_IF_PP, &ST_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_COL)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let cond: u32 = iiip_parse_expr(st)
    let then_block: u32 = iiip_parse_block(st)
    let mut else_block: u32 = 0u32
    iiip_skip_newlines(st)
    if iiip_accept(st, III_TOK_KW_ELSE_P) == 1u32 {
        iiip_skip_newlines(st)
        /* capture the match ONCE: parse_if consumes tokens, so re-checking
         * match(KW_IF) after the first branch would wrongly fire the second. */
        let is_elif: u32 = iiip_match(st, III_TOK_KW_IF_PP)
        if is_elif == 1u32 { else_block = iiip_parse_if(st) }
        if is_elif == 0u32 { else_block = iiip_parse_block(st) }
    }
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_STMT_IF, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u32_c(nn, 8u64, cond)
        iii_lex_write_u32_c(nn, 12u64, then_block)
        iii_lex_write_u32_c(nn, 16u64, else_block)
    }
    return n
}

fn iiip_parse_while(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_WHILE_P, &ST_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_COL)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let cond: u32 = iiip_parse_expr(st)
    let body: u32 = iiip_parse_block(st)
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_STMT_WHILE, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u32_c(nn, 8u64, cond)
        iii_lex_write_u32_c(nn, 12u64, body)
    }
    return n
}

fn iiip_parse_loop(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_LOOP_P, &ST_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_COL)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let body: u32 = iiip_parse_block(st)
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_STMT_LOOP, &NP_A as u64)
    if n != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(ast, n), 8u64, body) }
    return n
}

fn iiip_parse_break(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_BREAK_P, &ST_KW as u64) == 0u32 { return 0u32 }
    st_kw_pos(iii_lex_read_u32_c(&ST_KW as u64, TOK_START), iii_lex_read_u32_c(&ST_KW as u64, TOK_END), iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE), iii_lex_read_u32_c(&ST_KW as u64, TOK_COL))
    let n: u32 = iiip_alloc_node(st, PA_AST_STMT_BREAK, &NP_A as u64)
    if n != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(iii_lex_read_u64_c(st, PS_AST), n), 8u64, 0u32) }
    return n
}
fn iiip_parse_continue(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_CONTINUE_P, &ST_KW as u64) == 0u32 { return 0u32 }
    st_kw_pos(iii_lex_read_u32_c(&ST_KW as u64, TOK_START), iii_lex_read_u32_c(&ST_KW as u64, TOK_END), iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE), iii_lex_read_u32_c(&ST_KW as u64, TOK_COL))
    let n: u32 = iiip_alloc_node(st, PA_AST_STMT_CONTINUE, &NP_A as u64)
    if n != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(iii_lex_read_u64_c(st, PS_AST), n), 8u64, 0u32) }
    return n
}

fn iiip_parse_for(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_FOR_P, &ST_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_COL)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &ST_NAME as u64) == 0u32 { return 0u32 }
    let var_text: u64 = iiip_text_of(&ST_NAME as u64)
    iiip_expect(st, III_TOK_KW_IN_P, 0u64)
    let mut iter: u32 = iiip_parse_expr(st)
    if iiip_accept(st, III_TOK_OP_DOTDOT_P) == 1u32 {
        let hi: u32 = iiip_parse_expr(st)
        iiip_node_pos(st, iter, &NP_B as u64)
        let rn: u32 = iiip_alloc_node(st, PA_AST_EXPR_RANGE, &NP_B as u64)
        if rn != 0u32 {
            let rnp: u64 = iii_ast_get_mut(ast, rn)
            iii_lex_write_u32_c(rnp, 8u64, iter)
            iii_lex_write_u32_c(rnp, 12u64, hi)
            iter = rn
        }
    }
    let mut where_e: u32 = 0u32
    if iiip_accept(st, III_TOK_KW_WHERE_P) == 1u32 { where_e = iiip_parse_expr(st) }
    let body: u32 = iiip_parse_block(st)
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_STMT_FOR, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, var_text)
        iii_lex_write_u32_c(nn, 16u64, iter)
        iii_lex_write_u32_c(nn, 20u64, where_e)
        iii_lex_write_u32_c(nn, 24u64, body)
    }
    return n
}

fn iiip_parse_return(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_RETURN_P, &ST_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&ST_KW as u64, TOK_COL)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut v: u32 = 0u32
    let mut has: u32 = 1u32
    if iiip_match(st, III_TOK_NEWLINE_P) == 1u32 { has = 0u32 }
    if iiip_match(st, III_TOK_SEMI_P) == 1u32 { has = 0u32 }
    if iiip_match(st, III_TOK_RBRACE_P) == 1u32 { has = 0u32 }
    if has == 1u32 { v = iiip_parse_expr(st) }
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_STMT_RETURN, &NP_A as u64)
    if n != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(ast, n), 8u64, v) }
    return n
}

/* default stmt arm: expr, then `= expr` -> ASSIGN else EXPR-stmt. */
fn iiip_stmt_expr_or_assign(st: u64) -> u32 {
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let lhs: u32 = iiip_parse_expr(st)
    if lhs == 0u32 { return 0u32 }
    if iiip_accept(st, III_TOK_OP_ASSIGN_P) == 1u32 {
        let rhs: u32 = iiip_parse_expr(st)
        iiip_node_pos(st, lhs, &NP_A as u64)
        let r: u32 = iiip_alloc_node(st, PA_AST_STMT_ASSIGN, &NP_A as u64)
        if r != 0u32 {
            let rn: u64 = iii_ast_get_mut(ast, r)
            iii_lex_write_u32_c(rn, 8u64, lhs)
            iii_lex_write_u32_c(rn, 12u64, rhs)
        }
        return r
    }
    iiip_node_pos(st, lhs, &NP_A as u64)
    let r: u32 = iiip_alloc_node(st, PA_AST_STMT_EXPR, &NP_A as u64)
    if r != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(ast, r), 8u64, lhs) }
    return r
}
/* match-as-statement -> EXPR-stmt wrapping a match expr. */
fn iiip_stmt_match(st: u64) -> u32 {
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let e: u32 = iiip_parse_expr(st)
    if e != 0u32 { iiip_node_pos(st, e, &NP_A as u64) }
    if e == 0u32 { iiip_pos_of(iiip_peek(st), &NP_A as u64) }
    let r: u32 = iiip_alloc_node(st, PA_AST_STMT_EXPR, &NP_A as u64)
    if r != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(ast, r), 8u64, e) }
    return r
}

fn iiip_parse_stmt(st: u64) -> u32 {
    if iiip_enter_recursion(st) == 0u32 { return 0u32 }
    let k: u32 = iiip_peek_kind(st)
    let r0: u32 = iiip_registry_dispatch(st, st + PS_REG_STMT, k)
    if r0 != 0u32 { iiip_leave_recursion(st) ; return r0 }
    let mut r: u32 = 0u32
    if k == III_TOK_KW_LET_P { r = iiip_parse_let(st) }
    if k == III_TOK_KW_VAR_P { r = iiip_parse_let(st) }
    if k == III_TOK_KW_WAVEFRONT_P { r = iiip_parse_wavefront(st) }
    if k == III_TOK_KW_SANCTUM_ENTER_P { r = iiip_parse_sanctum_enter(st) }
    if k == III_TOK_KW_METAL_P { r = iiip_parse_metal(st) }
    if k == III_TOK_KW_FOR_P { r = iiip_parse_for(st) }
    if k == III_TOK_KW_RETURN_P { r = iiip_parse_return(st) }
    if k == III_TOK_KW_IF_PP { r = iiip_parse_if(st) }
    if k == III_TOK_KW_WHILE_P { r = iiip_parse_while(st) }
    if k == III_TOK_KW_LOOP_P { r = iiip_parse_loop(st) }
    if k == III_TOK_KW_BREAK_P { r = iiip_parse_break(st) }
    if k == III_TOK_KW_CONTINUE_P { r = iiip_parse_continue(st) }
    if k == III_TOK_KW_MATCH_PP { r = iiip_stmt_match(st) }
    if iiip_stmt_is_simple(k) == 0u32 { r = iiip_stmt_expr_or_assign(st) }
    iiip_leave_recursion(st)
    return r
}
/* true if k is one of the keyword-led statement forms (has a dedicated arm). */
fn iiip_stmt_is_simple(k: u32) -> u32 {
    if k == III_TOK_KW_LET_P { return 1u32 }
    if k == III_TOK_KW_VAR_P { return 1u32 }
    if k == III_TOK_KW_WAVEFRONT_P { return 1u32 }
    if k == III_TOK_KW_SANCTUM_ENTER_P { return 1u32 }
    if k == III_TOK_KW_METAL_P { return 1u32 }
    if k == III_TOK_KW_FOR_P { return 1u32 }
    if k == III_TOK_KW_RETURN_P { return 1u32 }
    if k == III_TOK_KW_IF_PP { return 1u32 }
    if k == III_TOK_KW_WHILE_P { return 1u32 }
    if k == III_TOK_KW_LOOP_P { return 1u32 }
    if k == III_TOK_KW_BREAK_P { return 1u32 }
    if k == III_TOK_KW_CONTINUE_P { return 1u32 }
    if k == III_TOK_KW_MATCH_PP { return 1u32 }
    return 0u32
}

const III_TOK_PIPE_P: u32 = 81u32

/* F1 public sub-entry wrappers (parse.c 3552). decl/decl_next need top_decl (1h). */
fn iii_parse_expression(st: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    return iiip_parse_expr(st)
}
fn iii_parse_type(st: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    return iiip_parse_type_expr(st)
}
fn iii_parse_pattern(st: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    return iiip_parse_pattern(st)
}

/* ============================================================================
 * Batch 1h-i -- decl shared helpers + simplest decls (param_list/param_one/
 * bracket_init + const/var).  Self-contained; shallow + recursion-safe.
 * ============================================================================ */
const PA_AST_CONST_DECL: u32 = 6u32
const PA_AST_VAR_DECL: u32 = 74u32
const PA_AST_STRUCT_DECL: u32 = 75u32
const PA_AST_TYPE_DECL: u32 = 5u32
const PA_AST_TYPE_PARAM: u32 = 13u32
const PA_AST_EXPR_PARALLEL: u32 = 61u32
const III_TOK_KW_CONST_P: u32 = 18u32
const III_TOK_KW_VAR_P: u32 = 108u32
const III_TOK_KW_STRUCT_P: u32 = 109u32

var DC_KW : [u8; 104]
var DC_NAME : [u8; 104]
var DC_CLOSE : [u8; 104]

/* one `[mut] name : T [@mods]` parameter -> PARAM node. */
fn iiip_param_one(st: u64) -> u32 {
    iiip_accept(st, III_TOK_KW_MUT_P)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_NAME as u64)
    let p_s: u32 = iii_lex_read_u32_c(&DC_NAME as u64, TOK_START)
    let p_e: u32 = iii_lex_read_u32_c(&DC_NAME as u64, TOK_END)
    let p_l: u32 = iii_lex_read_u32_c(&DC_NAME as u64, TOK_LINE)
    let p_c: u32 = iii_lex_read_u32_c(&DC_NAME as u64, TOK_COL)
    iiip_skip_newlines(st)
    iiip_expect(st, III_TOK_COLON_PP, 0u64)
    iiip_skip_newlines(st)
    let type_node: u32 = iiip_parse_type_expr(st)
    iiip_skip_newlines(st)
    iiip_attach_type_mods(st, type_node)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut pe: u32 = p_e
    if type_node != 0u32 { iiip_node_pos(st, type_node, &NP_B as u64) ; pe = iii_lex_read_u32_c(&NP_B as u64, 4u64) }
    lparen_pos(p_s, pe, p_l, p_c)
    let pn: u32 = iiip_alloc_node(st, PA_AST_PARAM, &NP_A as u64)
    if pn == 0u32 { return 0u32 }
    let pp: u64 = iii_ast_get_mut(ast, pn)
    iii_lex_write_u64_c(pp, 8u64, nm)
    iii_lex_write_u32_c(pp, 16u64, type_node)
    return pn
}
/* (params) -> packed 8B list. */
fn iiip_parse_param_list(st: u64) -> u64 {
    if iiip_expect(st, III_TOK_LPAREN_P, 0u64) == 0u32 { return 0u64 }
    iiip_skip_newlines(st)
    if iiip_accept(st, III_TOK_RPAREN_P) == 1u32 { return 0u64 }
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let ol: u64 = iii_ast_open_list_create(ast)
    if ol == 0u64 { iiip_expect(st, III_TOK_RPAREN_P, 0u64) ; return 0u64 }
    let mut go: u32 = 1u32
    while go == 1u32 {
        let pn: u32 = iiip_param_one(st)
        if pn == 0u32 { go = 0u32 }
        if go == 1u32 {
            iii_ast_open_list_push(ol, pn)
            iiip_skip_newlines(st)
            if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { go = 0u32 }
            if go == 1u32 { iiip_skip_newlines(st) }
        }
    }
    iiip_skip_newlines(st)
    iiip_expect(st, III_TOK_RPAREN_P, 0u64)
    return iii_ast_open_list_commit(ast, ol)
}
/* [e, e, ...] bracket initializer -> EXPR_PARALLEL. */
fn iiip_parse_bracket_init(st: u64) -> u32 {
    if iiip_match(st, III_TOK_LBRACKET_P) == 0u32 { return 0u32 }
    iiip_advance(st, &ADV_SCRATCH as u64)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let ol: u64 = iii_ast_open_list_create(ast)
    if ol != 0u64 {
        iiip_skip_newlines(st)
        if iiip_match(st, III_TOK_RBRACKET_P) == 0u32 {
            let mut go: u32 = 1u32
            while go == 1u32 {
                iiip_skip_newlines(st)
                let e: u32 = iiip_parse_expr(st)
                if e == 0u32 { go = 0u32 }
                if go == 1u32 {
                    iii_ast_open_list_push(ol, e)
                    iiip_skip_newlines(st)
                    if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { go = 0u32 }
                }
            }
        }
    }
    iiip_skip_newlines(st)
    iiip_expect(st, III_TOK_RBRACKET_P, &DC_CLOSE as u64)
    let mut branches: u64 = 0u64
    if ol != 0u64 { branches = iii_ast_open_list_commit(ast, ol) }
    iiip_pos_of(&DC_CLOSE as u64, &NP_A as u64)
    let pn: u32 = iiip_alloc_node(st, PA_AST_EXPR_PARALLEL, &NP_A as u64)
    if pn != 0u32 { iii_lex_write_u64_c(iii_ast_get_mut(ast, pn), 8u64, branches) }
    return pn
}

fn iiip_parse_const_decl(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_CONST_P, &DC_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_NAME as u64)
    iiip_expect(st, III_TOK_COLON_PP, 0u64)
    let t: u32 = iiip_parse_type_expr(st)
    iiip_expect(st, III_TOK_OP_ASSIGN_P, 0u64)
    let mut v: u32 = 0u32
    let cv_brk: u32 = iiip_match(st, III_TOK_LBRACKET_P)
    if cv_brk == 1u32 { v = iiip_parse_bracket_init(st) }
    if cv_brk == 0u32 { v = iiip_parse_expr(st) }
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let n: u32 = iiip_alloc_node(st, PA_AST_CONST_DECL, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, nm)
        iii_lex_write_u32_c(nn, 16u64, t)
        iii_lex_write_u32_c(nn, 20u64, v)
    }
    return n
}

fn iiip_parse_var_decl(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_VAR_P, &DC_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_NAME as u64)
    let mut t: u32 = 0u32
    if iiip_accept(st, III_TOK_COLON_PP) == 1u32 { t = iiip_parse_type_expr(st) }
    let mut init: u32 = 0u32
    if iiip_accept(st, III_TOK_OP_ASSIGN_P) == 1u32 {
        let vd_brk: u32 = iiip_match(st, III_TOK_LBRACKET_P)
        if vd_brk == 1u32 { init = iiip_parse_bracket_init(st) }
        if vd_brk == 0u32 { init = iiip_parse_expr(st) }
    }
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let n: u32 = iiip_alloc_node(st, PA_AST_VAR_DECL, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, nm)
        iii_lex_write_u32_c(nn, 16u64, t)
        iii_lex_write_u32_c(nn, 20u64, init)
    }
    return n
}

/* ============================================================================
 * Batch 1h-ii -- struct / type / sealed_call decls (shallow, recursion-safe).
 * ============================================================================ */
const PA_AST_SEALED_CALL_METHOD_DECL: u32 = 11u32
const III_TOK_KW_SEALED_CALL_P: u32 = 23u32
/* The lexer fuses the post-@ modifier name `seal_id` into MOD_SEAL_ID (kind 68, lex.iii:583/126),
 * exactly as `@abi` -> MOD_ABI. The sealed_call grammar must accept it (mirror of III_TOK_MOD_ABI_P). */
const III_TOK_MOD_SEAL_ID_P: u32 = 68u32

var DC_TP : [u8; 104]

/* one `name : T` struct field -> PARAM. */
fn iiip_struct_field(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_TP as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_TP as u64)
    let f_s: u32 = iii_lex_read_u32_c(&DC_TP as u64, TOK_START)
    let f_e: u32 = iii_lex_read_u32_c(&DC_TP as u64, TOK_END)
    let f_l: u32 = iii_lex_read_u32_c(&DC_TP as u64, TOK_LINE)
    let f_c: u32 = iii_lex_read_u32_c(&DC_TP as u64, TOK_COL)
    iiip_expect(st, III_TOK_COLON_PP, 0u64)
    let ft: u32 = iiip_parse_type_expr(st)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut pe: u32 = f_e
    if ft != 0u32 { iiip_node_pos(st, ft, &NP_B as u64) ; pe = iii_lex_read_u32_c(&NP_B as u64, 4u64) }
    lparen_pos(f_s, pe, f_l, f_c)
    let fn_: u32 = iiip_alloc_node(st, PA_AST_PARAM, &NP_A as u64)
    if fn_ == 0u32 { return 0u32 }
    let fnp: u64 = iii_ast_get_mut(ast, fn_)
    iii_lex_write_u64_c(fnp, 8u64, nm)
    iii_lex_write_u32_c(fnp, 16u64, ft)
    return fn_
}
fn iiip_parse_struct_decl(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_STRUCT_P, &DC_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_NAME as u64)
    iiip_expect(st, III_TOK_LBRACE_P, 0u64)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let ol: u64 = iii_ast_open_list_create(ast)
    let mut go: u32 = 1u32
    while go == 1u32 {
        iiip_skip_newlines(st)
        if iiip_accept(st, III_TOK_RBRACE_P) == 1u32 { go = 0u32 }
        if go == 1u32 { if iiip_match(st, III_TOK_EOF_P) == 1u32 { go = 0u32 } }
        if go == 1u32 {
            let fld: u32 = iiip_struct_field(st)
            if fld == 0u32 { go = 0u32 }
            if go == 1u32 {
                if ol != 0u64 { iii_ast_open_list_push(ol, fld) }
                if iiip_accept(st, III_TOK_COMMA_P) == 0u32 {
                    iiip_skip_newlines(st)
                    iiip_accept(st, III_TOK_RBRACE_P)
                    go = 0u32
                }
            }
        }
    }
    let mut fields: u64 = 0u64
    if ol != 0u64 { fields = iii_ast_open_list_commit(ast, ol) }
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_STRUCT_DECL, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, nm)
        iii_lex_write_u64_c(nn, 16u64, fields)
    }
    return n
}

/* one `name [: kind]` type-param -> TYPE_PARAM. */
fn iiip_type_param_one(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_TP as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_TP as u64)
    let p_s: u32 = iii_lex_read_u32_c(&DC_TP as u64, TOK_START)
    let p_e: u32 = iii_lex_read_u32_c(&DC_TP as u64, TOK_END)
    let p_l: u32 = iii_lex_read_u32_c(&DC_TP as u64, TOK_LINE)
    let p_c: u32 = iii_lex_read_u32_c(&DC_TP as u64, TOK_COL)
    let mut kind_text: u64 = 0u64
    if iiip_accept(st, III_TOK_COLON_PP) == 1u32 {
        if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_TP as u64) == 1u32 { kind_text = iiip_text_of(&DC_TP as u64) }
    }
    lparen_pos(p_s, p_e, p_l, p_c)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let tn: u32 = iiip_alloc_node(st, PA_AST_TYPE_PARAM, &NP_A as u64)
    if tn == 0u32 { return 0u32 }
    let tnp: u64 = iii_ast_get_mut(ast, tn)
    iii_lex_write_u64_c(tnp, 8u64, nm)
    iii_lex_write_u64_c(tnp, 16u64, kind_text)
    return tn
}
fn iiip_parse_type_decl(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_TYPE_P, &DC_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_NAME as u64)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let mut tparams: u64 = 0u64
    if iiip_accept(st, III_TOK_OP_LT_P) == 1u32 {
        let ol: u64 = iii_ast_open_list_create(ast)
        if ol != 0u64 { if iiip_match(st, III_TOK_OP_GT_P) == 0u32 {
            let mut go: u32 = 1u32
            while go == 1u32 {
                let tp: u32 = iiip_type_param_one(st)
                if tp == 0u32 { go = 0u32 }
                if go == 1u32 {
                    iii_ast_open_list_push(ol, tp)
                    if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { go = 0u32 }
                }
            }
        } }
        iiip_expect(st, III_TOK_OP_GT_P, 0u64)
        if ol != 0u64 { tparams = iii_ast_open_list_commit(ast, ol) }
    }
    iiip_expect(st, III_TOK_OP_ASSIGN_P, 0u64)
    let rhs: u32 = iiip_parse_type_expr(st)
    let mods: u64 = iiip_parse_modifier_list(st)
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_TYPE_DECL, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, nm)
        iii_lex_write_u64_c(nn, 16u64, tparams)
        iii_lex_write_u32_c(nn, 24u64, rhs)
        iii_lex_write_u64_c(nn, 28u64, mods)
    }
    return n
}

fn iiip_parse_sealed_call_method(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_SEALED_CALL_P, &DC_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_NAME as u64)
    let params: u64 = iiip_parse_param_list(st)
    let mut ret: u32 = 0u32
    if iiip_accept(st, III_TOK_ARROW_P) == 1u32 { ret = iiip_parse_type_expr(st) }
    iiip_expect(st, III_TOK_AT_P, 0u64)
    /* `seal_id` after `@` lexes as the fused MOD_SEAL_ID token, NOT a bare IDENTIFIER (mirror of
     * iiip_extern_abi accepting MOD_ABI).  Accept either spelling, then consume the modifier name. */
    let mk: u32 = iiip_peek_kind(st)
    if mk == III_TOK_MOD_SEAL_ID_P {
        iiip_advance(st, &ADV_SCRATCH as u64)
    } else {
        if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_TP as u64) == 0u32 {
            iiip_record_error(st, 7u32, &DC_TP as u64, "sealed_call declaration requires @seal_id(N) modifier" as u64, III_TOK_IDENTIFIER_P)
        } else {
            if iiip_raw_eq(st, &DC_TP as u64, "seal_id" as u64, 7u64) == 0u32 {
                iiip_record_error(st, 7u32, &DC_TP as u64, "sealed_call declaration requires @seal_id(N) modifier" as u64, III_TOK_IDENTIFIER_P)
            }
        }
    }
    iiip_expect(st, III_TOK_LPAREN_P, 0u64)
    iiip_expect(st, III_TOK_INT_LITERAL_P, &DC_TP as u64)
    let seal_id: u32 = iii_lex_read_u64_c(&DC_TP as u64, TOK_INT_VALUE) as u32
    iiip_expect(st, III_TOK_RPAREN_P, 0u64)
    let body: u32 = iiip_parse_block(st)
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let n: u32 = iiip_alloc_node(st, PA_AST_SEALED_CALL_METHOD_DECL, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, nm)
        iii_lex_write_u64_c(nn, 16u64, params)
        iii_lex_write_u32_c(nn, 24u64, ret)
        iii_lex_write_u32_c(nn, 28u64, seal_id)
        iii_lex_write_u32_c(nn, 32u64, body)
    }
    return n
}

/* ============================================================================
 * Batch 1h-iii -- cycle / fn / mobius decls (forward-block carriers).
 * ============================================================================ */
const PA_AST_CYCLE_DECL: u32 = 3u32
const PA_AST_FN_DECL: u32 = 4u32
const PA_AST_MOBIUS_CANDIDATE_DECL: u32 = 8u32
const PA_AST_FORWARD_BLOCK: u32 = 29u32
const PA_AST_COMPROMISE_BLOCK: u32 = 30u32
const III_TOK_KW_CYCLE_P: u32 = 15u32
const III_TOK_KW_MOBIUS_CANDIDATE_P: u32 = 20u32
const III_TOK_KW_FORWARD_P: u32 = 39u32
const III_TOK_KW_COMPROMISE_P: u32 = 40u32
const PA_COMPROMISE_NOTE: u32 = 1u32
const PA_COMPROMISE_LOW: u32 = 2u32
const PA_COMPROMISE_MEDIUM: u32 = 3u32
const PA_COMPROMISE_HIGH: u32 = 4u32
const PA_COMPROMISE_CRITICAL: u32 = 5u32

var DC_SEV : [u8; 104]

/* `forward { stmts }` -> FORWARD_BLOCK (pos from the enclosing decl kw); 0 if
 * no `forward`. */
fn iiip_fwd_block(st: u64, ks: u32, ke: u32, kl: u32, kc: u32) -> u32 {
    if iiip_accept(st, III_TOK_KW_FORWARD_P) == 0u32 { return 0u32 }
    iiip_expect(st, III_TOK_LBRACE_P, 0u64)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let ol: u64 = iii_ast_open_list_create(ast)
    let mut go: u32 = 1u32
    while go == 1u32 {
        iiip_skip_newlines(st)
        if iiip_accept(st, III_TOK_RBRACE_P) == 1u32 { go = 0u32 }
        if go == 1u32 { if iiip_match(st, III_TOK_EOF_P) == 1u32 { go = 0u32 } }
        if go == 1u32 {
            let s: u32 = iiip_parse_stmt(st)
            if s == 0u32 { go = 0u32 }
            if go == 1u32 { if ol != 0u64 { iii_ast_open_list_push(ol, s) } ; iiip_accept(st, III_TOK_SEMI_P) }
        }
    }
    let mut stmts: u64 = 0u64
    if ol != 0u64 { stmts = iii_ast_open_list_commit(ast, ol) }
    st_kw_pos(ks, ke, kl, kc)
    let fb: u32 = iiip_alloc_node(st, PA_AST_FORWARD_BLOCK, &NP_A as u64)
    if fb != 0u32 { iii_lex_write_u64_c(iii_ast_get_mut(ast, fb), 8u64, stmts) }
    return fb
}
/* `compromise ( SEV )` -> COMPROMISE_BLOCK; 0 if absent. */
fn iiip_cycle_compromise(st: u64) -> u32 {
    if iiip_accept(st, III_TOK_KW_COMPROMISE_P) == 0u32 { return 0u32 }
    let lex: u64 = iii_lex_read_u64_c(st, PS_LEX)
    iiip_expect(st, III_TOK_LPAREN_P, 0u64)
    iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_SEV as u64)
    iiip_expect(st, III_TOK_RPAREN_P, 0u64)
    let mut sev: u32 = PA_COMPROMISE_LOW
    if iiip_raw_eq(st, &DC_SEV as u64, "NOTE" as u64, 4u64) == 1u32 { sev = PA_COMPROMISE_NOTE }
    if iiip_raw_eq(st, &DC_SEV as u64, "LOW" as u64, 3u64) == 1u32 { sev = PA_COMPROMISE_LOW }
    if iiip_raw_eq(st, &DC_SEV as u64, "MEDIUM" as u64, 6u64) == 1u32 { sev = PA_COMPROMISE_MEDIUM }
    if iiip_raw_eq(st, &DC_SEV as u64, "HIGH" as u64, 4u64) == 1u32 { sev = PA_COMPROMISE_HIGH }
    if iiip_raw_eq(st, &DC_SEV as u64, "CRITICAL" as u64, 8u64) == 1u32 { sev = PA_COMPROMISE_CRITICAL }
    iiip_pos_of(&DC_SEV as u64, &NP_A as u64)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let cb: u32 = iiip_alloc_node(st, PA_AST_COMPROMISE_BLOCK, &NP_A as u64)
    if cb != 0u32 { iii_lex_write_u32_c(iii_ast_get_mut(ast, cb), 8u64, sev) }
    return cb
}
/* push a CYCLE/FN breadcrumb with the name span as detail. */
fn iiip_bc_push_named(st: u64, pid: u32, name_text: u64) -> u32 {
    iiip_bc_push(st, pid, (name_text & 4294967295u64) as u32, (name_text >> 32u64) as u32)
    return 0u32
}

fn iiip_parse_cycle_decl(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_CYCLE_P, &DC_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_NAME as u64)
    iiip_bc_push_named(st, IIIP_PROD_CYCLE_DECL, nm)
    let params: u64 = iiip_parse_param_list(st)
    let mut ret: u32 = 0u32
    if iiip_accept(st, III_TOK_ARROW_P) == 1u32 { ret = iiip_parse_type_expr(st) }
    let mods: u64 = iiip_parse_modifier_list(st)
    iiip_expect(st, III_TOK_LBRACE_P, 0u64)
    iiip_skip_newlines(st)
    let fb: u32 = iiip_fwd_block(st, kw_s, kw_e, kw_l, kw_c)
    iiip_skip_newlines(st)
    let cb: u32 = iiip_cycle_compromise(st)
    iiip_skip_newlines(st)
    iiip_expect(st, III_TOK_RBRACE_P, 0u64)
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let n: u32 = iiip_alloc_node(st, PA_AST_CYCLE_DECL, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, nm)
        iii_lex_write_u64_c(nn, 16u64, params)
        iii_lex_write_u32_c(nn, 24u64, ret)
        iii_lex_write_u64_c(nn, 28u64, mods)
        iii_lex_write_u32_c(nn, 36u64, fb)
        iii_lex_write_u32_c(nn, 40u64, cb)
    }
    iiip_bc_pop(st)
    return n
}

fn iiip_parse_fn_decl(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_FN_P, &DC_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_NAME as u64)
    iiip_bc_push_named(st, IIIP_PROD_FN_DECL, nm)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    /* Stage 7.1: optional generic type-params `<T[: kind][, U]>` for @specialize.
     * Mirrors iiip_parse_type_decl; absent for ordinary fns (next token is '('). */
    let mut tparams: u64 = 0u64
    if iiip_accept(st, III_TOK_OP_LT_P) == 1u32 {
        let ol: u64 = iii_ast_open_list_create(ast)
        if ol != 0u64 {
            if iiip_match(st, III_TOK_OP_GT_P) == 0u32 {
                let mut go: u32 = 1u32
                while go == 1u32 {
                    let tp: u32 = iiip_type_param_one(st)
                    if tp == 0u32 { go = 0u32 }
                    if go == 1u32 {
                        iii_ast_open_list_push(ol, tp)
                        if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { go = 0u32 }
                    }
                }
            }
            iiip_expect(st, III_TOK_OP_GT_P, 0u64)
            tparams = iii_ast_open_list_commit(ast, ol)
        }
    }
    let params: u64 = iiip_parse_param_list(st)
    let mut ret: u32 = 0u32
    if iiip_accept(st, III_TOK_ARROW_P) == 1u32 { ret = iiip_parse_type_expr(st) }
    let mods: u64 = iiip_parse_modifier_list(st)
    let body: u32 = iiip_parse_block(st)
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_FN_DECL, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, nm)
        iii_lex_write_u64_c(nn, 16u64, params)
        iii_lex_write_u32_c(nn, 24u64, ret)
        iii_lex_write_u64_c(nn, 28u64, mods)
        iii_lex_write_u32_c(nn, 36u64, body)
        iii_lex_write_u64_c(nn, 40u64, tparams)
    }
    iiip_bc_pop(st)
    return n
}

fn iiip_parse_mobius_candidate(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_MOBIUS_CANDIDATE_P, &DC_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_NAME as u64)
    iiip_expect(st, III_TOK_COLON_PP, 0u64)
    let in_t: u32 = iiip_parse_type_expr(st)
    iiip_expect(st, III_TOK_ARROW_P, 0u64)
    let out_t: u32 = iiip_parse_type_expr(st)
    let mods: u64 = iiip_parse_modifier_list(st)
    iiip_expect(st, III_TOK_LBRACE_P, 0u64)
    iiip_skip_newlines(st)
    let fb: u32 = iiip_fwd_block(st, kw_s, kw_e, kw_l, kw_c)
    iiip_skip_newlines(st)
    iiip_expect(st, III_TOK_RBRACE_P, 0u64)
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let n: u32 = iiip_alloc_node(st, PA_AST_MOBIUS_CANDIDATE_DECL, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, nm)
        iii_lex_write_u32_c(nn, 16u64, in_t)
        iii_lex_write_u32_c(nn, 20u64, out_t)
        iii_lex_write_u64_c(nn, 24u64, mods)
        iii_lex_write_u32_c(nn, 32u64, fb)
    }
    return n
}

/* ============================================================================
 * Batch 1h-iv -- extern (multi-token @abi span) + schema (observatory fields).
 * ============================================================================ */
extern @abi(c-msvc-x64) fn iii_ast_source_buf(ast: u64) -> u64 from "ast.iii"

/* token-bytes == literal, with EXPLICIT length (the lex.iii iii_token_raw_eq
 * strlen()s its literal arg, but .iii string literals are NOT NUL-terminated --
 * they pack back-to-back -- so raw_eq always mismatched.  This length-bounded
 * variant via pp_strncmp is the byte-equivalent replacement for every
 * token-vs-keyword check in the decl/modifier productions). */
fn iiip_raw_eq(st: u64, tok: u64, lit: u64, litlen: u64) -> u32 {
    let len: u64 = (iii_lex_read_u32_c(tok, TOK_END) - iii_lex_read_u32_c(tok, TOK_START)) as u64
    if len != litlen { return 0u32 }
    let src: u64 = iii_ast_source_buf(iii_lex_read_u64_c(st, PS_AST))
    if src == 0u64 { return 0u32 }
    return pp_strncmp(src + (iii_lex_read_u32_c(tok, TOK_START) as u64), lit, litlen)
}

const PA_AST_EXTERN_DECL: u32 = 7u32
const PA_AST_SCHEMA_DECL: u32 = 9u32
const PA_AST_SCHEMA_FIELD: u32 = 10u32
const PA_ABI_C_MSVC_X64: u32 = 1u32
const PA_ABI_C_SYSV_X64: u32 = 2u32
const PA_ABI_VMRUN_TRAMPOLINE: u32 = 3u32
const PA_ABI_MAGIC_MSR: u32 = 4u32
const PA_ABI_IOCTL: u32 = 5u32
const PA_SCH_F_ACCUMULATOR: u32 = 1u32
const PA_SCH_F_THRESHOLD: u32 = 2u32
const PA_SCH_F_SAMPLE_SOURCE: u32 = 3u32
const PA_SCH_F_MAX_RECORDS: u32 = 4u32
const PA_SCH_F_PLAN_ANCHOR: u32 = 5u32
const III_TOK_KW_EXTERN_P: u32 = 19u32
const III_TOK_MOD_ABI_P: u32 = 64u32
const III_TOK_KW_FROM_P: u32 = 24u32
const III_TOK_KW_SCHEMA_P: u32 = 21u32
const III_TOK_KW_OBSERVATORY_P: u32 = 22u32

var DC_ABI : [u8; 104]
var DC_PATH : [u8; 104]

/* `@abi( <multi-token kind> )` -> ABI enum (default MSVC_X64). */
fn iiip_extern_abi(st: u64) -> u32 {
    iiip_expect(st, III_TOK_AT_P, 0u64)
    let lex: u64 = iii_lex_read_u64_c(st, PS_LEX)
    let awk: u32 = iiip_peek_kind(st)
    let mut isabi: u32 = 0u32
    if awk == III_TOK_IDENTIFIER_P { isabi = 1u32 }
    if awk == III_TOK_MOD_ABI_P { isabi = 1u32 }
    if isabi == 0u32 {
        iiip_record_error(st, 7u32, iiip_peek(st), "extern declaration requires @abi(<kind>) modifier" as u64, III_TOK_IDENTIFIER_P)
        return PA_ABI_C_MSVC_X64
    }
    iii_lex_memcpy_c(&DC_ABI as u64, iiip_peek(st), TOK_BYTES)
    iiip_advance(st, &ADV_SCRATCH as u64)
    if iiip_raw_eq(st, &DC_ABI as u64, "abi" as u64, 3u64) == 0u32 {
        iiip_record_error(st, 7u32, &DC_ABI as u64, "extern declaration requires @abi(<kind>) modifier" as u64, III_TOK_IDENTIFIER_P)
    }
    iiip_expect(st, III_TOK_LPAREN_P, 0u64)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_ABI as u64) == 0u32 { return PA_ABI_C_MSVC_X64 }
    let span_start: u32 = iii_lex_read_u32_c(&DC_ABI as u64, TOK_START)
    let mut span_end: u32 = iii_lex_read_u32_c(&DC_ABI as u64, TOK_END)
    let mut dl: u32 = 1u32
    while dl == 1u32 {
        if iiip_match(st, III_TOK_OP_MINUS_P) == 0u32 { dl = 0u32 }
        if dl == 1u32 {
            iiip_advance(st, &ADV_SCRATCH as u64)
            let ck: u32 = iiip_peek_kind(st)
            if ck == III_TOK_IDENTIFIER_P { span_end = iii_lex_read_u32_c(iiip_peek(st), TOK_END) ; iiip_advance(st, &ADV_SCRATCH as u64) }
            if ck != III_TOK_IDENTIFIER_P { if ck == III_TOK_INT_LITERAL_P { span_end = iii_lex_read_u32_c(iiip_peek(st), TOK_END) ; iiip_advance(st, &ADV_SCRATCH as u64) } }
            if ck != III_TOK_IDENTIFIER_P { if ck != III_TOK_INT_LITERAL_P { dl = 0u32 } }
        }
    }
    iiip_expect(st, III_TOK_RPAREN_P, 0u64)
    let src: u64 = iii_ast_source_buf(iii_lex_read_u64_c(st, PS_AST))
    let slen: u32 = span_end - span_start
    let mut abi: u32 = PA_ABI_C_MSVC_X64
    if src != 0u64 {
        let s: u64 = src + (span_start as u64)
        if slen == 10u32 { if pp_strncmp(s, "c-msvc-x64" as u64, 10u64) == 1u32 { abi = PA_ABI_C_MSVC_X64 } }
        if slen == 10u32 { if pp_strncmp(s, "c-sysv-x64" as u64, 10u64) == 1u32 { abi = PA_ABI_C_SYSV_X64 } }
        if slen == 16u32 { if pp_strncmp(s, "vmrun-trampoline" as u64, 16u64) == 1u32 { abi = PA_ABI_VMRUN_TRAMPOLINE } }
        if slen == 9u32 { if pp_strncmp(s, "magic-msr" as u64, 9u64) == 1u32 { abi = PA_ABI_MAGIC_MSR } }
        if slen == 5u32 { if pp_strncmp(s, "ioctl" as u64, 5u64) == 1u32 { abi = PA_ABI_IOCTL } }
    }
    if iiip_raw_eq(st, &DC_ABI as u64, "ioctl" as u64, 5u64) == 1u32 { abi = PA_ABI_IOCTL }
    return abi
}
fn iiip_parse_extern_decl(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_EXTERN_P, &DC_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    let abi: u32 = iiip_extern_abi(st)
    iiip_expect(st, III_TOK_KW_FN_P, 0u64)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_NAME as u64)
    let params: u64 = iiip_parse_param_list(st)
    let mut ret: u32 = 0u32
    if iiip_accept(st, III_TOK_ARROW_P) == 1u32 { ret = iiip_parse_type_expr(st) }
    iiip_expect(st, III_TOK_KW_FROM_P, 0u64)
    if iiip_expect(st, III_TOK_STRING_LITERAL_P, &DC_PATH as u64) == 0u32 { return 0u32 }
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let path_idx: u32 = iii_ast_intern_string(ast, iii_lex_read_u64_c(&DC_PATH as u64, TOK_STRING_PAYLOAD))
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_EXTERN_DECL, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u32_c(nn, 8u64, abi)
        iii_lex_write_u64_c(nn, 12u64, nm)
        iii_lex_write_u64_c(nn, 20u64, params)
        iii_lex_write_u32_c(nn, 28u64, ret)
        iii_lex_write_u32_c(nn, 32u64, path_idx)
    }
    return n
}

/* one observatory field -> SCHEMA_FIELD (mirrors parse.c's stored-fnp). */
fn iiip_schema_field(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let f_s: u32 = iii_lex_read_u32_c(&DC_NAME as u64, TOK_START)
    let f_e: u32 = iii_lex_read_u32_c(&DC_NAME as u64, TOK_END)
    let f_l: u32 = iii_lex_read_u32_c(&DC_NAME as u64, TOK_LINE)
    let f_c: u32 = iii_lex_read_u32_c(&DC_NAME as u64, TOK_COL)
    iiip_expect(st, III_TOK_COLON_PP, 0u64)
    let lex: u64 = iii_lex_read_u64_c(st, PS_LEX)
    let mut fk: u32 = PA_SCH_F_ACCUMULATOR
    if iiip_raw_eq(st, &DC_NAME as u64, "accumulator" as u64, 11u64) == 1u32 { fk = PA_SCH_F_ACCUMULATOR }
    if iiip_raw_eq(st, &DC_NAME as u64, "threshold" as u64, 9u64) == 1u32 { fk = PA_SCH_F_THRESHOLD }
    if iiip_raw_eq(st, &DC_NAME as u64, "sample_source" as u64, 13u64) == 1u32 { fk = PA_SCH_F_SAMPLE_SOURCE }
    if iiip_raw_eq(st, &DC_NAME as u64, "max_records" as u64, 11u64) == 1u32 { fk = PA_SCH_F_MAX_RECORDS }
    if iiip_raw_eq(st, &DC_NAME as u64, "plan_anchor" as u64, 11u64) == 1u32 { fk = PA_SCH_F_PLAN_ANCHOR }
    lparen_pos(f_s, f_e, f_l, f_c)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let fn_: u32 = iiip_alloc_node(st, PA_AST_SCHEMA_FIELD, &NP_A as u64)
    if fn_ == 0u32 { return 0u32 }
    let fnp: u64 = iii_ast_get_mut(ast, fn_)
    iii_lex_write_u32_c(fnp, 8u64, fk)
    if fk == PA_SCH_F_SAMPLE_SOURCE {
        iiip_expect(st, III_TOK_IDENTIFIER_P, 0u64)
        iiip_expect(st, III_TOK_KW_WHERE_P, 0u64)
        iii_lex_write_u32_c(fnp, 28u64, iiip_parse_expr(st))
    }
    if fk == PA_SCH_F_MAX_RECORDS { if iiip_expect(st, III_TOK_INT_LITERAL_P, &DC_SEV as u64) == 1u32 { iii_lex_write_u32_c(fnp, 32u64, iii_lex_read_u64_c(&DC_SEV as u64, TOK_INT_VALUE) as u32) } }
    if fk == PA_SCH_F_PLAN_ANCHOR { if iiip_expect(st, III_TOK_INT_LITERAL_P, &DC_SEV as u64) == 1u32 { iii_lex_write_u32_c(fnp, 32u64, iii_lex_read_u64_c(&DC_SEV as u64, TOK_INT_VALUE) as u32) } }
    let mut isspec: u32 = 1u32
    if fk == PA_SCH_F_SAMPLE_SOURCE { isspec = 0u32 }
    if fk == PA_SCH_F_MAX_RECORDS { isspec = 0u32 }
    if fk == PA_SCH_F_PLAN_ANCHOR { isspec = 0u32 }
    if isspec == 1u32 {
        if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_SEV as u64) == 1u32 { iii_lex_write_u64_c(fnp, 12u64, iiip_text_of(&DC_SEV as u64)) }
        if iiip_accept(st, III_TOK_LPAREN_P) == 1u32 {
            iii_lex_write_u64_c(fnp, 20u64, iiip_parse_arg_list(st))
            iiip_expect(st, III_TOK_RPAREN_P, 0u64)
        }
    }
    return fn_
}
fn iiip_parse_schema_decl(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_SCHEMA_P, &DC_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let nm: u64 = iiip_text_of(&DC_NAME as u64)
    iiip_expect(st, III_TOK_OP_ASSIGN_P, 0u64)
    iiip_expect(st, III_TOK_KW_OBSERVATORY_P, 0u64)
    iiip_expect(st, III_TOK_LBRACE_P, 0u64)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    let ol: u64 = iii_ast_open_list_create(ast)
    let mut go: u32 = 1u32
    while go == 1u32 {
        iiip_skip_newlines(st)
        if iiip_accept(st, III_TOK_RBRACE_P) == 1u32 { go = 0u32 }
        if go == 1u32 { if iiip_match(st, III_TOK_EOF_P) == 1u32 { go = 0u32 } }
        if go == 1u32 {
            let fld: u32 = iiip_schema_field(st)
            if fld == 0u32 { go = 0u32 }
            if go == 1u32 {
                if ol != 0u64 { iii_ast_open_list_push(ol, fld) }
                if iiip_accept(st, III_TOK_COMMA_P) == 0u32 { go = 0u32 }
                if go == 1u32 { iiip_skip_newlines(st) }
            }
        }
    }
    iiip_accept(st, III_TOK_RBRACE_P)
    let mut fields: u64 = 0u64
    if ol != 0u64 { fields = iii_ast_open_list_commit(ast, ol) }
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_SCHEMA_DECL, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, nm)
        iii_lex_write_u64_c(nn, 16u64, fields)
    }
    return n
}

/* ============================================================================
 * Batch 1h-v -- parser closure: kind_to_prod + top_decl + use_decl + module +
 * decl_next + grammar-extension registries + public wrappers.
 * ============================================================================ */
extern @abi(c-msvc-x64) fn iii_ast_set_root_module(ast: u64, n: u32) -> u32 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_ast_recompute_root_mhash(ast: u64) -> u32 from "ast.iii"

const IIIP_PROD_USE_DECL: u32 = 1u32
const IIIP_PROD_TOP_DECL: u32 = 2u32
const IIIP_PROD_LET: u32 = 24u32
const IIIP_PROD_FOR_D: u32 = 28u32
const IIIP_PROD_RETURN_D: u32 = 29u32
const III_TOK_KW_USE_P: u32 = 13u32
const III_TOK_KW_MODULE_P: u32 = 12u32
const PA_AST_USE: u32 = 2u32
const PA_AST_MODULE: u32 = 1u32
const REG_CAP: u32 = 64u32

fn iiip_kind_to_prod(k: u32) -> u32 {
    if k == III_TOK_KW_CYCLE_P { return IIIP_PROD_CYCLE_DECL }
    if k == III_TOK_KW_FN_P { return IIIP_PROD_FN_DECL }
    if k == III_TOK_KW_USE_P { return IIIP_PROD_USE_DECL }
    if k == III_TOK_KW_LET_P { return IIIP_PROD_LET }
    if k == III_TOK_KW_RETURN_P { return IIIP_PROD_RETURN_D }
    if k == III_TOK_KW_FOR_P { return IIIP_PROD_FOR_D }
    if k == III_TOK_KW_MATCH_PP { return IIIP_PROD_PRIMARY }
    return IIIP_PROD_TOP_DECL
}
/* is k one of the 10 keyword-led decl forms (has a dedicated arm)? */
fn iiip_topdecl_is_known(k: u32) -> u32 {
    if k == III_TOK_KW_CYCLE_P { return 1u32 }
    if k == III_TOK_KW_FN_P { return 1u32 }
    if k == III_TOK_KW_TYPE_P { return 1u32 }
    if k == III_TOK_KW_CONST_P { return 1u32 }
    if k == III_TOK_KW_EXTERN_P { return 1u32 }
    if k == III_TOK_KW_MOBIUS_CANDIDATE_P { return 1u32 }
    if k == III_TOK_KW_SCHEMA_P { return 1u32 }
    if k == III_TOK_KW_SEALED_CALL_P { return 1u32 }
    if k == III_TOK_KW_VAR_P { return 1u32 }
    if k == III_TOK_KW_STRUCT_P { return 1u32 }
    return 0u32
}
fn iiip_parse_top_decl(st: u64) -> u32 {
    let k: u32 = iiip_peek_kind(st)
    let r0: u32 = iiip_registry_dispatch(st, st + PS_REG_DECL, k)
    if r0 != 0u32 { return r0 }
    iiip_bc_push(st, iiip_kind_to_prod(k), 0u32, 0u32)
    let mut out: u32 = 0u32
    if k == III_TOK_KW_CYCLE_P { out = iiip_parse_cycle_decl(st) }
    if k == III_TOK_KW_FN_P { out = iiip_parse_fn_decl(st) }
    if k == III_TOK_KW_TYPE_P { out = iiip_parse_type_decl(st) }
    if k == III_TOK_KW_CONST_P { out = iiip_parse_const_decl(st) }
    if k == III_TOK_KW_EXTERN_P { out = iiip_parse_extern_decl(st) }
    if k == III_TOK_KW_MOBIUS_CANDIDATE_P { out = iiip_parse_mobius_candidate(st) }
    if k == III_TOK_KW_SCHEMA_P { out = iiip_parse_schema_decl(st) }
    if k == III_TOK_KW_SEALED_CALL_P { out = iiip_parse_sealed_call_method(st) }
    if k == III_TOK_KW_VAR_P { out = iiip_parse_var_decl(st) }
    if k == III_TOK_KW_STRUCT_P { out = iiip_parse_struct_decl(st) }
    if iiip_topdecl_is_known(k) == 0u32 {
        iiip_record_error(st, 1u32, iiip_peek(st), "expected top-level declaration" as u64, PARSE_TOK_INVALID)
        iiip_recover_follow(st, IIIP_PROD_TOP_DECL)
        out = 0u32
    }
    iiip_bc_pop(st)
    return out
}

fn iiip_parse_use_decl(st: u64) -> u32 {
    if iiip_expect(st, III_TOK_KW_USE_P, &DC_KW as u64) == 0u32 { return 0u32 }
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let qoff: u64 = iii_lex_read_u32_c(&DC_NAME as u64, TOK_START) as u64
    let mut qlen: u64 = (iii_lex_read_u32_c(&DC_NAME as u64, TOK_END) - iii_lex_read_u32_c(&DC_NAME as u64, TOK_START)) as u64
    let mut dot: u32 = 1u32
    while dot == 1u32 {
        if iiip_accept(st, III_TOK_DOT_P) == 0u32 { dot = 0u32 }
        if dot == 1u32 {
            if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_TP as u64) == 0u32 { dot = 0u32 }
            if dot == 1u32 { qlen = (iii_lex_read_u32_c(&DC_TP as u64, TOK_END) as u64) - qoff }
        }
    }
    let mut closure: u32 = 0u32
    if iiip_accept(st, III_TOK_AT_P) == 1u32 {
        iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_ABI as u64)
        iiip_expect(st, III_TOK_LPAREN_P, 0u64)
        if iiip_expect(st, III_TOK_MHASH_LITERAL_P, &DC_PATH as u64) == 1u32 {
            iiip_pos_of(&DC_PATH as u64, &NP_A as u64)
            closure = iiip_alloc_node(st, PA_AST_EXPR_MHASH, &NP_A as u64)
            if closure != 0u32 { iii_lex_memcpy_c(iii_ast_get_mut(ast, closure) + NODE_U, &DC_PATH as u64 + TOK_MHASH, 32u64) }
        }
        iiip_expect(st, III_TOK_RPAREN_P, 0u64)
    }
    let mut alias: u64 = 0u64
    if iiip_accept(st, III_TOK_KW_AS_P) == 1u32 {
        if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_SEV as u64) == 1u32 { alias = iiip_text_of(&DC_SEV as u64) }
    }
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_USE, &NP_A as u64)
    if n != 0u32 {
        let nn: u64 = iii_ast_get_mut(ast, n)
        iii_lex_write_u64_c(nn, 8u64, qoff | (qlen << 32u64))
        iii_lex_write_u32_c(nn, 16u64, closure)
        iii_lex_write_u64_c(nn, 20u64, alias)
    }
    return n
}

fn iii_parse_module(st: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    let ast: u64 = iii_lex_read_u64_c(st, PS_AST)
    if ast == 0u64 {
        iiip_record_error(st, 13u32, iiip_peek(st), "null parser/AST" as u64, PARSE_TOK_INVALID)
        return 0u32
    }
    iiip_skip_newlines(st)
    if iiip_match(st, III_TOK_KW_MODULE_P) == 0u32 {
        iiip_record_error(st, 1u32, iiip_peek(st), "source must begin with `module` declaration" as u64, III_TOK_KW_MODULE_P)
        return 0u32
    }
    iii_lex_memcpy_c(&DC_KW as u64, iiip_peek(st), TOK_BYTES)
    iiip_advance(st, &ADV_SCRATCH as u64)
    let kw_s: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_START)
    let kw_e: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_END)
    let kw_l: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_LINE)
    let kw_c: u32 = iii_lex_read_u32_c(&DC_KW as u64, TOK_COL)
    if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_NAME as u64) == 0u32 { return 0u32 }
    let moff: u64 = iii_lex_read_u32_c(&DC_NAME as u64, TOK_START) as u64
    let mut mlen: u64 = (iii_lex_read_u32_c(&DC_NAME as u64, TOK_END) - iii_lex_read_u32_c(&DC_NAME as u64, TOK_START)) as u64
    let mut dot: u32 = 1u32
    while dot == 1u32 {
        if iiip_accept(st, III_TOK_DOT_P) == 0u32 { dot = 0u32 }
        if dot == 1u32 {
            if iiip_expect(st, III_TOK_IDENTIFIER_P, &DC_TP as u64) == 0u32 { dot = 0u32 }
            if dot == 1u32 { mlen = (iii_lex_read_u32_c(&DC_TP as u64, TOK_END) as u64) - moff }
        }
    }
    let mods: u64 = iiip_parse_modifier_list(st)
    let uol: u64 = iii_ast_open_list_create(ast)
    let mut ug: u32 = 1u32
    while ug == 1u32 {
        iiip_skip_newlines(st)
        if iiip_match(st, III_TOK_KW_USE_P) == 0u32 { ug = 0u32 }
        if ug == 1u32 {
            let u: u32 = iiip_parse_use_decl(st)
            if u == 0u32 { iiip_recover_follow(st, IIIP_PROD_USE_DECL) }
            if u != 0u32 { if uol != 0u64 { iii_ast_open_list_push(uol, u) } }
        }
    }
    let mut uses: u64 = 0u64
    if uol != 0u64 { uses = iii_ast_open_list_commit(ast, uol) }
    let dol: u64 = iii_ast_open_list_create(ast)
    let mut dg: u32 = 1u32
    while dg == 1u32 {
        iiip_skip_newlines(st)
        if iiip_match(st, III_TOK_EOF_P) == 1u32 { dg = 0u32 }
        if dg == 1u32 {
            let d: u32 = iiip_parse_top_decl(st)
            if d == 0u32 {
                iiip_recover_follow(st, IIIP_PROD_TOP_DECL)
                iiip_accept(st, III_TOK_NEWLINE_P)
                if iiip_match(st, III_TOK_EOF_P) == 1u32 { dg = 0u32 }
            }
            if d != 0u32 { if dol != 0u64 { iii_ast_open_list_push(dol, d) } }
        }
    }
    let mut decls: u64 = 0u64
    if dol != 0u64 { decls = iii_ast_open_list_commit(ast, dol) }
    st_kw_pos(kw_s, kw_e, kw_l, kw_c)
    let n: u32 = iiip_alloc_node(st, PA_AST_MODULE, &NP_A as u64)
    if n == 0u32 { return 0u32 }
    let nn: u64 = iii_ast_get_mut(ast, n)
    iii_lex_write_u64_c(nn, 8u64, moff | (mlen << 32u64))
    iii_lex_write_u64_c(nn, 16u64, mods)
    iii_lex_write_u64_c(nn, 24u64, uses)
    iii_lex_write_u64_c(nn, 32u64, decls)
    iii_ast_set_root_module(ast, n)
    iii_ast_recompute_root_mhash(ast)
    if iii_lex_read_u32_c(st, PS_ERR_COUNT) == 0u32 { return 1u32 }
    return 0u32
}

fn iii_parse_decl(st: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    iiip_skip_newlines(st)
    return iiip_parse_top_decl(st)
}
fn iii_parse_decl_next(st: u64, out_node: u64) -> u32 @export {
    if out_node != 0u64 { iii_lex_write_u32_c(out_node, 0u64, 0u32) }
    if st == 0u64 { return 4294967295u32 }
    iiip_skip_newlines(st)
    if iiip_peek_kind(st) == III_TOK_EOF_P { return 0u32 }
    let n: u32 = iiip_parse_top_decl(st)
    if out_node != 0u64 { iii_lex_write_u32_c(out_node, 0u64, n) }
    if n != 0u32 { return 1u32 }
    return 4294967295u32
}

/* R1 grammar-extension registries. */
fn iiip_register_into(st: u64, tbl: u64, first_token: u32, fn_ptr: u64) -> u32 {
    if st == 0u64 { return 0u32 }
    if tbl == 0u64 { return 0u32 }
    if fn_ptr == 0u64 { return 0u32 }
    if first_token == PARSE_TOK_INVALID { return 0u32 }
    let mut i: u32 = 0u32
    let mut h: u32 = 0u32
    let mut done: u32 = 0u32
    while done == 0u32 {
        if i >= REG_CAP { done = 1u32 }
        if done == 0u32 {
            let e: u64 = tbl + (i as u64) * REG_ENTRY_BYTES
            if iii_lex_read_u32_c(e, 0u64) == 0u32 {
                let mut nh: u32 = iii_lex_read_u32_c(st, PS_REG_NEXT_HANDLE) + 1u32
                if nh == 0u32 { nh = 1u32 }
                iii_lex_write_u32_c(st, PS_REG_NEXT_HANDLE, nh)
                iii_lex_write_u32_c(e, 0u64, nh)
                iii_lex_write_u32_c(e, 4u64, first_token)
                iii_lex_write_u64_c(e, 8u64, fn_ptr)
                iii_lex_write_u32_c(tbl, REG_COUNT_OFF, iii_lex_read_u32_c(tbl, REG_COUNT_OFF) + 1u32)
                h = nh
                done = 1u32
            }
            i = i + 1u32
        }
    }
    if h == 0u32 { iiip_record_error(st, 17u32, 0u64, "grammar-extension registry is full" as u64, PARSE_TOK_INVALID) }
    return h
}
fn iii_parse_register_decl_kind(st: u64, first_token: u32, fn_ptr: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    return iiip_register_into(st, st + PS_REG_DECL, first_token, fn_ptr)
}
fn iii_parse_register_stmt_kind(st: u64, first_token: u32, fn_ptr: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    return iiip_register_into(st, st + PS_REG_STMT, first_token, fn_ptr)
}
fn iii_parse_register_primary_kind(st: u64, first_token: u32, fn_ptr: u64) -> u32 @export {
    if st == 0u64 { return 0u32 }
    return iiip_register_into(st, st + PS_REG_PRIMARY, first_token, fn_ptr)
}
fn iii_parse_unregister(st: u64, reg_handle: u32) -> u32 @export {
    if st == 0u64 { return 0u32 }
    if reg_handle == 0u32 { return 0u32 }
    let mut found: u32 = 0u32
    let mut t: u32 = 0u32
    while t < 3u32 {
        let tbl: u64 = ps_reg_table(st, t)
        let mut i: u32 = 0u32
        while i < REG_CAP {
            let e: u64 = tbl + (i as u64) * REG_ENTRY_BYTES
            if iii_lex_read_u32_c(e, 0u64) == reg_handle {
                iii_lex_memset_c(e, 0u32, REG_ENTRY_BYTES)
                let c: u32 = iii_lex_read_u32_c(tbl, REG_COUNT_OFF)
                if c > 0u32 { iii_lex_write_u32_c(tbl, REG_COUNT_OFF, c - 1u32) }
                found = 1u32
            }
            i = i + 1u32
        }
        t = t + 1u32
    }
    return found
}

const III_PARSE_VERSION: u32 = 1u32

/* CP-PARSE-001 + Stage 2.3.1..2.3.5 COMPLETE: full recursive-descent+Pratt
 * parser ported (expr/type/pattern/stmt/decl/module + registries + 5 public
 * sub-entries + module + decl_next).  Next: verify iii_parse_module vs parse.c;
 * then S2.3.9 -- drop parse_impl.c from build_iiis1.sh + iiis-0 == iiis-1 fixpoint.
 */
