/* C:\Users\Edwin Boston\OneDrive\Desktop\III\COMPILER\BOOT\proof.iii
 *
 * III Stage-0 Proof Certificate Emitter — .iii port of proof.c.
 *
 * Mirrors proof.h ABI exactly so this object file is link-compatible
 * with the C iiis-0 build (replaces proof.o).  All eight public
 * symbols are @export'd (unmangled).  SHA-256 is hand-rolled inline.
 *
 * Stage-0 simplifications versus proof.c:
 *
 *   - No iii_proof_state_t heap struct
 state lives in module-scope
 *     globals.  iii_proof_create returns a sentinel pointer (the
 *     address of PF_SENTINEL[0]) and iii_proof_destroy is a no-op
 *     reset.  Proof is single-instance — main.c calls create/destroy
 *     once per build, never concurrently (consistent with the rest
 *     of BOOT's single-process model).
 *
 *   - errors[] and certs[] are fixed-cap arrays (256 errors,
 *     1024 certs) instead of growable.  Excess is silently dropped
 *     after the cap (parity with C's behaviour after realloc OOM).
 *
 *   - Error messages are fixed strings (no arena printf).  The
 *     "subtree of decl node N contains an error node" message loses
 *     the N (logged as the generic message instead).  Stage-1's
 *     iii dialect with format-string support will restore it.
 *
 *   - AST/sema field access uses the flat accessor surface in
 *     ast_accessors.c rather than struct-field-through-pointer
 *     (which the Stage-0 cg_r3 doesn't yet support).
 *
 * NIH: only ast.h / sema.h / hexad_check.h / ast_accessors.c.  No
 * external CIC kernel.  Hand-rolled SHA-256 inside this TU.
 */

module proof

/* ─── Public ABI: error codes (must match proof.h) ─────────────────── */

/* Error codes (inlined as i32 literals in this file; mirrors proof.h):
 *   III_PROOF_OK = 0, E_HEXAD_UNREP = 1, E_RING_MALFORMED = 2,
 *   E_ERROR_NODE = 3, E_OOM = 99. */

/* ─── AST kind constants (mirror ast.h, append-only enum) ──────────── */

const PF_K_MODULE                  : u32 = 1u32
const PF_K_CYCLE_DECL              : u32 = 3u32
const PF_K_FN_DECL                 : u32 = 4u32
const PF_K_TYPE_DECL               : u32 = 5u32
const PF_K_CONST_DECL              : u32 = 6u32
const PF_K_EXTERN_DECL             : u32 = 7u32
const PF_K_MOBIUS_CANDIDATE_DECL   : u32 = 8u32
const PF_K_SCHEMA_DECL             : u32 = 9u32
const PF_K_SEALED_CALL_METHOD_DECL : u32 = 11u32
const PF_K_STMT_LET                : u32 = 20u32
const PF_K_STMT_RETURN             : u32 = 26u32
const PF_K_STMT_ASSIGN             : u32 = 27u32
const PF_K_STMT_EXPR               : u32 = 28u32
const PF_K_FORWARD_BLOCK           : u32 = 29u32
const PF_K_EXPR_CALL               : u32 = 46u32
const PF_K_EXPR_FIELD              : u32 = 47u32
const PF_K_EXPR_INDEX              : u32 = 48u32
const PF_K_EXPR_BINARY             : u32 = 49u32
const PF_K_EXPR_UNARY              : u32 = 50u32
const PF_K_EXPR_BLOCK              : u32 = 51u32
const PF_K_EXPR_PAREN              : u32 = 53u32
const PF_K_ARG                     : u32 = 57u32
const PF_K_ERROR_NODE              : u32 = 62u32

/* Ring lattice mask (must match ast.h III_RING_ANY = 0x0F). */
const PF_RING_ANY : u32 = 0x0Fu32

/* ─── Externs from C side ─────────────────────────────────────────── */

extern @abi(c-msvc-x64) fn iii_ast_node_kind(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_decl_name_offset(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_decl_name_length(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_module_decl_count(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_module_decl_at(ast: u64, node: u32, i: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_forward_block_stmt_count(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_forward_block_stmt_at(ast: u64, node: u32, i: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_block_stmt_count(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_block_stmt_at(ast: u64, node: u32, i: u32) -> u32 from "ast_accessors.c"
