    PF_ANNO_PHASE[14] = 115u8
    PF_ANNO_PHASE[15] = 104u8
    PF_ANNO_PHASE[16] = 0u8
    PF_ANNO_INIT = 1u8
    return 0u32
}

fn pf_init_domains_once() -> u32 {
    if PF_DOMAIN_INIT == 1u8 { return 0u32 }
    /* "III_PROOF_v1\0" — 13 bytes. */
    PF_DOMAIN[0]  = 73u8
    PF_DOMAIN[1]  = 73u8
    PF_DOMAIN[2]  = 73u8
    PF_DOMAIN[3]  = 95u8
