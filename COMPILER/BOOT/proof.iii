    PF_DOMAIN_AGG[22] = 0u8

    PF_DOMAIN_INIT = 1u8
    return 0u32
}

/* ─── Error/cert table helpers ───────────────────────────────────── */

/* Store a u64 message pointer at slot `i` in PF_ERR_MSG_BYTES. */
fn pf_msg_set(i: u32, ptr: u64) -> u32 {
    let base: u32 = i * 8u32
    PF_ERR_MSG_BYTES[base + 0u32] = ( ptr           & 0xffu64) as u8
    PF_ERR_MSG_BYTES[base + 1u32] = ((ptr >>  8u64) & 0xffu64) as u8
    PF_ERR_MSG_BYTES[base + 2u32] = ((ptr >> 16u64) & 0xffu64) as u8
    PF_ERR_MSG_BYTES[base + 3u32] = ((ptr >> 24u64) & 0xffu64) as u8
    PF_ERR_MSG_BYTES[base + 4u32] = ((ptr >> 32u64) & 0xffu64) as u8
    PF_ERR_MSG_BYTES[base + 5u32] = ((ptr >> 40u64) & 0xffu64) as u8
    PF_ERR_MSG_BYTES[base + 6u32] = ((ptr >> 48u64) & 0xffu64) as u8
    PF_ERR_MSG_BYTES[base + 7u32] = ((ptr >> 56u64) & 0xffu64) as u8
    return 0u32
}

fn pf_msg_get(i: u32) -> u64 {
    let base: u32 = i * 8u32
    let b0: u64 = PF_ERR_MSG_BYTES[base + 0u32] as u64
    let b1: u64 = PF_ERR_MSG_BYTES[base + 1u32] as u64
    let b2: u64 = PF_ERR_MSG_BYTES[base + 2u32] as u64
    let b3: u64 = PF_ERR_MSG_BYTES[base + 3u32] as u64
    let b4: u64 = PF_ERR_MSG_BYTES[base + 4u32] as u64
    let b5: u64 = PF_ERR_MSG_BYTES[base + 5u32] as u64
    let b6: u64 = PF_ERR_MSG_BYTES[base + 6u32] as u64
    let b7: u64 = PF_ERR_MSG_BYTES[base + 7u32] as u64
    let lo: u64 = b0 | (b1 << 8u64) | (b2 << 16u64) | (b3 << 24u64)
    let hi: u64 = (b4 << 32u64) | (b5 << 40u64) | (b6 << 48u64) | (b7 << 56u64)
    return lo | hi
}

fn pf_emit_error(code: i32, decl_node: u32, msg: u64) -> u32 {
    if PF_ERR_COUNT == PF_ERR_CAP { return 0u32 }
    PF_ERR_CODE[PF_ERR_COUNT] = code
    PF_ERR_NODE[PF_ERR_COUNT] = decl_node
    pf_msg_set(PF_ERR_COUNT, msg)
    PF_ERR_COUNT = PF_ERR_COUNT + 1u32
    return 0u32
}

fn pf_record_cert(decl_node: u32, cert: *u8) -> u32 {
    if PF_CERT_COUNT == PF_CERT_CAP { return 0u32 }
    PF_CERT_NODE[PF_CERT_COUNT] = decl_node
    let base: u32 = PF_CERT_COUNT * 32u32
    for k in 0..32 {
        PF_CERT_BYTES[base + (k as u32)] = cert[k as u64]
    }
    PF_CERT_COUNT = PF_CERT_COUNT + 1u32
    return 0u32
}

/* ─── Recursive ERROR_NODE walker ────────────────────────────────── */

fn pf_subtree_has_error_node(node: u32) -> u8 {
    if node == 0u32 { return 0u8 }
    let k: u32 = iii_ast_node_kind(PF_AST, node)
    if k == 0u32 { return 0u8 }
    if k == PF_K_ERROR_NODE { return 1u8 }

    if k == PF_K_FORWARD_BLOCK {
        let n: u32 = iii_ast_forward_block_stmt_count(PF_AST, node)
        let mut i: u32 = 0u32
        while i < n {
            let c: u32 = iii_ast_forward_block_stmt_at(PF_AST, node, i)
            if pf_subtree_has_error_node(c) == 1u8 { return 1u8 }
            i = i + 1u32
        }
        return 0u8
    }
    if k == PF_K_EXPR_BLOCK {
        let n: u32 = iii_ast_block_stmt_count(PF_AST, node)
        let mut i: u32 = 0u32
        while i < n {
            let c: u32 = iii_ast_block_stmt_at(PF_AST, node, i)
            if pf_subtree_has_error_node(c) == 1u8 { return 1u8 }
            i = i + 1u32
        }
        return 0u8
    }
    if k == PF_K_STMT_LET {
        return pf_subtree_has_error_node(iii_ast_let_value(PF_AST, node))
    }
    if k == PF_K_STMT_EXPR {
        return pf_subtree_has_error_node(iii_ast_expr_stmt_expr(PF_AST, node))
    }
    if k == PF_K_STMT_RETURN {
        return pf_subtree_has_error_node(iii_ast_return_value(PF_AST, node))
    }
    if k == PF_K_STMT_ASSIGN {
        let lv: u32 = iii_ast_assign_lvalue(PF_AST, node)
        if pf_subtree_has_error_node(lv) == 1u8 { return 1u8 }
        return pf_subtree_has_error_node(iii_ast_assign_value(PF_AST, node))
    }
    if k == PF_K_EXPR_CALL {
        let cl: u32 = iii_ast_call_callee(PF_AST, node)
        if pf_subtree_has_error_node(cl) == 1u8 { return 1u8 }
        let n: u32 = iii_ast_call_arg_count(PF_AST, node)
        let mut i: u32 = 0u32
        while i < n {
            let a: u32 = iii_ast_call_arg_at(PF_AST, node, i)
            if pf_subtree_has_error_node(a) == 1u8 { return 1u8 }
            i = i + 1u32
        }
        return 0u8
    }
    if k == PF_K_EXPR_FIELD {
        return pf_subtree_has_error_node(iii_ast_field_object(PF_AST, node))
    }
    if k == PF_K_EXPR_INDEX {
        let o: u32 = iii_ast_index_object(PF_AST, node)
        if pf_subtree_has_error_node(o) == 1u8 { return 1u8 }
        return pf_subtree_has_error_node(iii_ast_index_index(PF_AST, node))
    }
    if k == PF_K_EXPR_BINARY {
        let lh: u32 = iii_ast_binary_lhs(PF_AST, node)
        if pf_subtree_has_error_node(lh) == 1u8 { return 1u8 }
        return pf_subtree_has_error_node(iii_ast_binary_rhs(PF_AST, node))
    }
    if k == PF_K_EXPR_UNARY {
        return pf_subtree_has_error_node(iii_ast_unary_operand(PF_AST, node))
    }
    if k == PF_K_EXPR_PAREN {
        return pf_subtree_has_error_node(iii_ast_paren_inner(PF_AST, node))
    }
    if k == PF_K_ARG {
        return pf_subtree_has_error_node(iii_ast_arg_value(PF_AST, node))
    }
    return 0u8
}

/* ─── Certificate emission (per decl) ────────────────────────────── */

/* Compute a 32-byte SHA-256 over the canonical bytes of the decl,
 * matching proof.c::pf_compute_cert exactly. */
fn pf_compute_cert(decl_node: u32, kind: u32, out: *u8) -> u32 {
    pf_init_domains_once()
    pf_sha_init()
    pf_sha_update(&PF_DOMAIN[0], 13u64)            /* "III_PROOF_v1\0" */
    pf_sha_update_u32(kind)

    let name_off: u32 = iii_ast_decl_name_offset(PF_AST, decl_node)
    let name_len: u32 = iii_ast_decl_name_length(PF_AST, decl_node)
    pf_sha_update_u32(name_len)
    if name_len > 0u32 {
        let src: u64 = iii_ast_source_slice(PF_AST, name_off, name_len)
        if src != 0u64 {
            pf_sha_update(src as *u8, name_len as u64)
        }
    }

    /* Resolved sema annotations (cycle decls only). */
    let mut hexad: u32 = 0xFFFFu32
    let mut ring:  u32 = 0u32
    if PF_SEMA != 0u64 {
        if kind == PF_K_CYCLE_DECL {
            hexad = iii_sema_cycle_hexad(PF_SEMA, decl_node)
            ring  = iii_sema_cycle_ring_mask(PF_SEMA, decl_node)
        }
    }
    if hexad == 0xFFFFu32 {
        pf_sha_update_u32(0xFFFFFFFFu32)
    } else {
        pf_sha_update_u32(hexad)
    }
    pf_sha_update_u32(ring)
    pf_sha_update_u32(0xFFFFFFFFu32)            /* tier sentinel */
    pf_sha_update_u64(0u64)                     /* epoch */

    /* Subtree mhash. */
    let mh: u64 = iii_ast_node_mhash(PF_AST, decl_node)
    if mh != 0u64 {
        pf_sha_update(mh as *u8, 32u64)
    } else {
        for i in 0..32 {
            pf_sha_update_byte(0u8)
        }
    }

    pf_sha_final(out)
    return 0u32
}

/* ─── Per-decl processing ────────────────────────────────────────── */

var PF_TMP_CERT : [u8; 32]

fn pf_process_decl(decl_node: u32, kind: u32) -> u32 {
    if kind == PF_K_ERROR_NODE {
        pf_emit_error(3i32, decl_node, &PF_MSG_ERROR_NODE[0] as u64)
        return 0u32
    }

    if pf_subtree_has_error_node(decl_node) == 1u8 {
        pf_emit_error(3i32, decl_node, &PF_MSG_ERROR_NODE[0] as u64)
        return 0u32
    }

    if kind == PF_K_CYCLE_DECL {
        if PF_SEMA != 0u64 {
            let h: u32 = iii_sema_cycle_hexad(PF_SEMA, decl_node)
            if h != 0xFFFFu32 {
                if iii_hexad_packed_admitted(h) == 0u8 {
                    pf_emit_error(1i32, decl_node, &PF_MSG_HEXAD_UNREP[0] as u64)
                }
            }
            let ring: u32 = iii_sema_cycle_ring_mask(PF_SEMA, decl_node)
            if ring != 0u32 {
                if (ring & (~PF_RING_ANY)) != 0u32 {
                    pf_emit_error(2i32, decl_node, &PF_MSG_RING_MALFORMED[0] as u64)
                }
            }
        }
    }

    pf_compute_cert(decl_node, kind, &PF_TMP_CERT[0])
    pf_record_cert(decl_node, &PF_TMP_CERT[0])
    pf_init_anno_phase_once()
    iii_ast_annotate(PF_AST, &PF_ANNO_PHASE[0] as u64, decl_node, &PF_TMP_CERT[0] as u64, 32u64)
    return 0u32
}

/* ─── Public API ─────────────────────────────────────────────────── */

fn iii_proof_create(ast: u64, sema: u64) -> u64 @export {
    if ast == 0u64 { return 0u64 }
    PF_AST = ast
    PF_SEMA = sema
    PF_RAN = 0u8
    PF_ERR_COUNT = 0u32
    PF_CERT_COUNT = 0u32
    pf_init_strings_once()
    pf_init_anno_phase_once()
    pf_init_domains_once()
    return &PF_SENTINEL[0] as u64
}

fn iii_proof_destroy(p: u64) -> u32 @export {
    if p == 0u64 { return 0u32 }
    PF_AST = 0u64
    PF_SEMA = 0u64
    PF_RAN = 0u8
    PF_ERR_COUNT = 0u32
    PF_CERT_COUNT = 0u32
    return 0u32
}

fn iii_proof_run(p: u64) -> i32 @export {
    if p == 0u64 { return 0 }
    if PF_AST == 0u64 { return 0 }
    if PF_RAN == 1u8 {
        if PF_ERR_COUNT == 0u32 { return 1 }
        return 0
    }
    PF_RAN = 1u8

    iii_hexad_check_init()

    let mod_node: u32 = iii_ast_root_module(PF_AST)
    if mod_node == 0u32 { return 0 }
    let mk: u32 = iii_ast_node_kind(PF_AST, mod_node)
    if mk != PF_K_MODULE { return 0 }

    let n: u32 = iii_ast_module_decl_count(PF_AST, mod_node)
    let mut i: u32 = 0u32
    while i < n {
        let didx: u32 = iii_ast_module_decl_at(PF_AST, mod_node, i)
        if didx != 0u32 {
            let dk: u32 = iii_ast_node_kind(PF_AST, didx)
            if dk != 0u32 {
                pf_process_decl(didx, dk)
            }
        }
        i = i + 1u32
    }

    if PF_ERR_COUNT == 0u32 { return 1 }
    return 0
}

fn iii_proof_error_count(p: u64) -> u32 @export {
    if p == 0u64 { return 0u32 }
    return PF_ERR_COUNT
}

fn iii_proof_error_at(p: u64, i: u32, out: *u8) -> u32 @export {
    if (out as u64) == 0u64 { return 0u32 }   /* [null-deref] C proof.c:456 `if(!out) return;` -- guard before the 16-byte zero-fill */
        /* Zero out the 16-byte struct first (sizeof iii_proof_error_t). */
    for k in 0..16 {
        out[k as u64] = 0u8
    }
    if p == 0u64 { return 0u32 }
    if i >= PF_ERR_COUNT { return 0u32 }
    let code: i32 = PF_ERR_CODE[i]
    let node: u32 = PF_ERR_NODE[i]
    let msg:  u64 = pf_msg_get(i)
    /* Field layout (matches struct iii_proof_error_t):
     *   off 0,4: int code
     *   off 4,4: uint32_t decl_node
     *   off 8,8: const char *message  (after natural padding)
     */
    let cu: u32 = code as u32
    out[0u64] = ( cu           & 0xffu32) as u8
    out[1u64] = ((cu >>  8u32) & 0xffu32) as u8
    out[2u64] = ((cu >> 16u32) & 0xffu32) as u8
    out[3u64] = ((cu >> 24u32) & 0xffu32) as u8
    out[4u64] = ( node          & 0xffu32) as u8
    out[5u64] = ((node >>  8u32) & 0xffu32) as u8
    out[6u64] = ((node >> 16u32) & 0xffu32) as u8
    out[7u64] = ((node >> 24u32) & 0xffu32) as u8
    out[8u64]  = ( msg           & 0xffu64) as u8
    out[9u64]  = ((msg >>  8u64) & 0xffu64) as u8
    out[10u64] = ((msg >> 16u64) & 0xffu64) as u8
    out[11u64] = ((msg >> 24u64) & 0xffu64) as u8
    out[12u64] = ((msg >> 32u64) & 0xffu64) as u8
    out[13u64] = ((msg >> 40u64) & 0xffu64) as u8
    out[14u64] = ((msg >> 48u64) & 0xffu64) as u8
    out[15u64] = ((msg >> 56u64) & 0xffu64) as u8
    return 0u32
}

fn iii_proof_error_name(code: i32) -> u64 @export {
    pf_init_strings_once()
    if code == 0i32  { return &PF_MSG_OK[0]         as u64 }
    if code == 1i32  { return &PF_MSG_NAME_HEXAD[0] as u64 }
    if code == 2i32  { return &PF_MSG_NAME_RING[0]  as u64 }
    if code == 3i32  { return &PF_MSG_NAME_ERROR[0] as u64 }
    if code == 99i32 { return &PF_MSG_NAME_OOM[0]   as u64 }
    return &PF_MSG_UNKNOWN[0] as u64
}

fn iii_proof_cert_for_decl(p: u64, decl_node: u32, out: *u8) -> u8 @export {
    if p == 0u64 { return 0u8 }
    if (out as u64) == 0u64 { return 0u8 }    /* [null-deref] C proof.c:477 `if(!p || !out) return false;` */
        let mut i: u32 = 0u32
    while i < PF_CERT_COUNT {
        if PF_CERT_NODE[i] == decl_node {
            let base: u32 = i * 32u32
            for k in 0..32 {
                out[k as u64] = PF_CERT_BYTES[base + (k as u32)]
            }
            return 1u8
        }
        i = i + 1u32
    }
    return 0u8
}

fn iii_proof_aggregate_root(p: u64, out: *u8) -> u32 @export {
        if p == 0u64 {
        for k in 0..32 { out[k as u64] = 0u8 }
        return 0u32
    }
    if PF_CERT_COUNT == 0u32 {
        for k in 0..32 { out[k as u64] = 0u8 }
        return 0u32
    }
    pf_init_domains_once()
    pf_sha_init()
    pf_sha_update(&PF_DOMAIN_AGG[0], 23u64)         /* "III_PROOF_AGGREGATE_v1\0" */
    let mut i: u32 = 0u32
    while i < PF_CERT_COUNT {
        pf_sha_update_u32(PF_CERT_NODE[i])
        let base: u32 = i * 32u32
        for k in 0..32 {
            pf_sha_update_byte(PF_CERT_BYTES[base + (k as u32)])
        }
        i = i + 1u32
    }
    pf_sha_final(out)
    return 0u32
}