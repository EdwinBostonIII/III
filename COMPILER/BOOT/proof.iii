extern @abi(c-msvc-x64) fn iii_ast_assign_lvalue(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_assign_value(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_call_callee(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_field_object(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_index_object(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_index_index(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_binary_lhs(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_binary_rhs(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_unary_operand(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_paren_inner(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_arg_value(ast: u64, node: u32) -> u32 from "ast_accessors.c"
extern @abi(c-msvc-x64) fn iii_ast_source_slice(ast: u64, offset: u32, length: u32) -> u64 from "ast_accessors.c"

extern @abi(c-msvc-x64) fn iii_ast_root_module(ast: u64) -> u32 from "ast.c"
extern @abi(c-msvc-x64) fn iii_ast_node_mhash(ast: u64, node: u32) -> u64 from "ast.c"
extern @abi(c-msvc-x64) fn iii_ast_annotate(ast: u64, phase: u64, node: u32, bytes: u64, len: u64) -> u8 from "ast.c"

extern @abi(c-msvc-x64) fn iii_sema_cycle_hexad(sema: u64, node: u32) -> u32 from "sema.c"
extern @abi(c-msvc-x64) fn iii_sema_cycle_ring_mask(sema: u64, node: u32) -> u32 from "sema.c"

extern @abi(c-msvc-x64) fn iii_hexad_check_init() -> u32 from "hexad_check.c"
extern @abi(c-msvc-x64) fn iii_hexad_packed_admitted(packed: u32) -> u8 from "hexad_check.c"

/* ─── Module-global state (single proof instance) ─────────────────── */

/* Sentinel "opaque pointer" — taking its address yields a non-NULL
 * value for iii_proof_create's return. */
var PF_SENTINEL : [u8; 1]

var PF_AST          : u64 = 0u64
var PF_SEMA         : u64 = 0u64
var PF_RAN          : u8  = 0u8

/* Error queue: fixed cap 256. */
const PF_ERR_CAP : u32 = 256u32
var PF_ERR_CODE  : [i32; 256]
var PF_ERR_NODE  : [u32; 256]
/* Message pointers (u64 each — addresses of static const message
 * arrays).  Stored as a flat byte buffer indexed by 8 to avoid the
 * non-u8 stride bug in Stage-0 EXPR_INDEX dispatch. */
var PF_ERR_MSG_BYTES : [u8; 2048]
var PF_ERR_COUNT : u32 = 0u32

/* Cert table: fixed cap 1024. */
const PF_CERT_CAP    : u32 = 1024u32
var PF_CERT_NODE     : [u32; 1024]
var PF_CERT_BYTES    : [u8; 32768]
var PF_CERT_COUNT    : u32 = 0u32

/* Annotation phase string ("proof/cert_mhash\0"). */
var PF_ANNO_PHASE : [u8; 17]
var PF_ANNO_INIT  : u8 = 0u8

/* Domain-separation strings. */
var PF_DOMAIN     : [u8; 13]   /* "III_PROOF_v1\0" — 13 bytes */
var PF_DOMAIN_AGG : [u8; 23]   /* "III_PROOF_AGGREGATE_v1\0" — 23 bytes */
var PF_DOMAIN_INIT : u8 = 0u8

/* Scratch buffer for u32/u64 byte-encoding. */
var PF_SCRATCH8 : [u8; 8]

/* Error message tables.  Each is a `var` (so EXPR_IDENT yields leaq
 * — the address — rather than load).  Null-terminated. */
var PF_MSG_ERROR_NODE     : [u8; 48]
var PF_MSG_HEXAD_UNREP    : [u8; 56]
var PF_MSG_RING_MALFORMED : [u8; 64]
var PF_MSG_OK             : [u8; 4]
var PF_MSG_UNKNOWN        : [u8; 8]
var PF_MSG_NAME_HEXAD     : [u8; 16]
var PF_MSG_NAME_RING      : [u8; 16]
var PF_MSG_NAME_ERROR     : [u8; 16]
var PF_MSG_NAME_OOM       : [u8; 4]
var PF_MSG_INIT           : u8 = 0u8

/* ─── SHA-256 working state ──────────────────────────────────────── */

var PF_K       : [u32; 64]
var PF_K_INIT  : u8 = 0u8
var PF_W       : [u32; 64]
var PF_H       : [u32; 8]
var PF_BUF     : [u8; 64]
var PF_BUFLEN  : u32 = 0u32
var PF_BITS    : u64 = 0u64

/* ─── Helpers ────────────────────────────────────────────────────── */

fn pf_rotr(x: u32, n: u32) -> u32 {
    return (x >> n) | (x << (32u32 - n))
}

fn pf_init_k_once() -> u32 {
    if PF_K_INIT == 1u8 { return 0u32 }
    PF_K[0]  = 0x428a2f98u32
    PF_K[1]  = 0x71374491u32
    PF_K[2]  = 0xb5c0fbcfu32
    PF_K[3]  = 0xe9b5dba5u32
    PF_K[4]  = 0x3956c25bu32
    PF_K[5]  = 0x59f111f1u32
    PF_K[6]  = 0x923f82a4u32
    PF_K[7]  = 0xab1c5ed5u32
    PF_K[8]  = 0xd807aa98u32
    PF_K[9]  = 0x12835b01u32
    PF_K[10] = 0x243185beu32
    PF_K[11] = 0x550c7dc3u32
    PF_K[12] = 0x72be5d74u32
    PF_K[13] = 0x80deb1feu32
    PF_K[14] = 0x9bdc06a7u32
    PF_K[15] = 0xc19bf174u32
    PF_K[16] = 0xe49b69c1u32
    PF_K[17] = 0xefbe4786u32
    PF_K[18] = 0x0fc19dc6u32
    PF_K[19] = 0x240ca1ccu32
    PF_K[20] = 0x2de92c6fu32
    PF_K[21] = 0x4a7484aau32
    PF_K[22] = 0x5cb0a9dcu32
    PF_K[23] = 0x76f988dau32
    PF_K[24] = 0x983e5152u32
    PF_K[25] = 0xa831c66du32
    PF_K[26] = 0xb00327c8u32
    PF_K[27] = 0xbf597fc7u32
    PF_K[28] = 0xc6e00bf3u32
    PF_K[29] = 0xd5a79147u32
    PF_K[30] = 0x06ca6351u32
    PF_K[31] = 0x14292967u32
    PF_K[32] = 0x27b70a85u32
    PF_K[33] = 0x2e1b2138u32
    PF_K[34] = 0x4d2c6dfcu32
    PF_K[35] = 0x53380d13u32
    PF_K[36] = 0x650a7354u32
    PF_K[37] = 0x766a0abbu32
    PF_K[38] = 0x81c2c92eu32
    PF_K[39] = 0x92722c85u32
    PF_K[40] = 0xa2bfe8a1u32
    PF_K[41] = 0xa81a664bu32
    PF_K[42] = 0xc24b8b70u32
    PF_K[43] = 0xc76c51a3u32
    PF_K[44] = 0xd192e819u32
    PF_K[45] = 0xd6990624u32
    PF_K[46] = 0xf40e3585u32
    PF_K[47] = 0x106aa070u32
    PF_K[48] = 0x19a4c116u32
    PF_K[49] = 0x1e376c08u32
    PF_K[50] = 0x2748774cu32
    PF_K[51] = 0x34b0bcb5u32
    PF_K[52] = 0x391c0cb3u32
    PF_K[53] = 0x4ed8aa4au32
    PF_K[54] = 0x5b9cca4fu32
    PF_K[55] = 0x682e6ff3u32
    PF_K[56] = 0x748f82eeu32
    PF_K[57] = 0x78a5636fu32
    PF_K[58] = 0x84c87814u32
    PF_K[59] = 0x8cc70208u32
    PF_K[60] = 0x90befffau32
    PF_K[61] = 0xa4506cebu32
    PF_K[62] = 0xbef9a3f7u32
    PF_K[63] = 0xc67178f2u32
    PF_K_INIT = 1u8
    return 0u32
}

fn pf_sha_init() -> u32 {
    pf_init_k_once()
    PF_H[0] = 0x6a09e667u32
    PF_H[1] = 0xbb67ae85u32
    PF_H[2] = 0x3c6ef372u32
    PF_H[3] = 0xa54ff53au32
    PF_H[4] = 0x510e527fu32
    PF_H[5] = 0x9b05688cu32
    PF_H[6] = 0x1f83d9abu32
    PF_H[7] = 0x5be0cd19u32
    PF_BITS = 0u64
    PF_BUFLEN = 0u32
    return 0u32
}

fn pf_sha_block() -> u32 {
    for i in 0..16 {
        let i4: u32 = (i as u32) * 4u32
        let b0: u32 = PF_BUF[i4 + 0u32] as u32
        let b1: u32 = PF_BUF[i4 + 1u32] as u32
        let b2: u32 = PF_BUF[i4 + 2u32] as u32
        let b3: u32 = PF_BUF[i4 + 3u32] as u32
        PF_W[i] = (b0 << 24u32) | (b1 << 16u32) | (b2 << 8u32) | b3
    }
    for j in 16..64 {
        let w15: u32 = PF_W[j - 15]
        let w2:  u32 = PF_W[j - 2]
        let s0: u32 = pf_rotr(w15, 7u32) ^ pf_rotr(w15, 18u32) ^ (w15 >> 3u32)
        let s1: u32 = pf_rotr(w2, 17u32) ^ pf_rotr(w2, 19u32) ^ (w2 >> 10u32)
        PF_W[j] = PF_W[j - 16] + s0 + PF_W[j - 7] + s1
    }
    let mut a: u32 = PF_H[0]
    let mut b: u32 = PF_H[1]
    let mut c: u32 = PF_H[2]
    let mut d: u32 = PF_H[3]
    let mut e: u32 = PF_H[4]
    let mut f: u32 = PF_H[5]
    let mut g: u32 = PF_H[6]
    let mut h: u32 = PF_H[7]
    for i in 0..64 {
        let S1: u32 = pf_rotr(e, 6u32) ^ pf_rotr(e, 11u32) ^ pf_rotr(e, 25u32)
        let ch: u32 = (e & f) ^ ((~e) & g)
        let t1: u32 = h + S1 + ch + PF_K[i] + PF_W[i]
        let S0: u32 = pf_rotr(a, 2u32) ^ pf_rotr(a, 13u32) ^ pf_rotr(a, 22u32)
        let mj: u32 = (a & b) ^ (a & c) ^ (b & c)
        let t2: u32 = S0 + mj
        h = g
        g = f
        f = e
        e = d + t1
        d = c
        c = b
        b = a
        a = t1 + t2
    }
    PF_H[0] = PF_H[0] + a
    PF_H[1] = PF_H[1] + b
    PF_H[2] = PF_H[2] + c
    PF_H[3] = PF_H[3] + d
    PF_H[4] = PF_H[4] + e
    PF_H[5] = PF_H[5] + f
    PF_H[6] = PF_H[6] + g
    PF_H[7] = PF_H[7] + h
    return 0u32
}

fn pf_sha_update_byte(b: u8) -> u32 {
    PF_BITS = PF_BITS + 8u64
    PF_BUF[PF_BUFLEN] = b
    PF_BUFLEN = PF_BUFLEN + 1u32
    if PF_BUFLEN == 64u32 {
        pf_sha_block()
        PF_BUFLEN = 0u32
    }
    return 0u32
}

fn pf_sha_update(data: *u8, len: u64) -> u32 {
    if len == 0u64 { return 0u32 }
    let mut off: u64 = 0u64
    while off < len {
        pf_sha_update_byte(data[off])
        off = off + 1u64
    }
    return 0u32
}

fn pf_sha_update_u32(v: u32) -> u32 {
    PF_SCRATCH8[0] = ( v          & 0xffu32) as u8
    PF_SCRATCH8[1] = ((v >> 8u32)  & 0xffu32) as u8
    PF_SCRATCH8[2] = ((v >> 16u32) & 0xffu32) as u8
    PF_SCRATCH8[3] = ((v >> 24u32) & 0xffu32) as u8
    pf_sha_update_byte(PF_SCRATCH8[0])
    pf_sha_update_byte(PF_SCRATCH8[1])
    pf_sha_update_byte(PF_SCRATCH8[2])
    pf_sha_update_byte(PF_SCRATCH8[3])
    return 0u32
}

fn pf_sha_update_u64(v: u64) -> u32 {
    PF_SCRATCH8[0] = ( v           & 0xffu64) as u8
    PF_SCRATCH8[1] = ((v >>  8u64) & 0xffu64) as u8
    PF_SCRATCH8[2] = ((v >> 16u64) & 0xffu64) as u8
    PF_SCRATCH8[3] = ((v >> 24u64) & 0xffu64) as u8
    PF_SCRATCH8[4] = ((v >> 32u64) & 0xffu64) as u8
    PF_SCRATCH8[5] = ((v >> 40u64) & 0xffu64) as u8
    PF_SCRATCH8[6] = ((v >> 48u64) & 0xffu64) as u8
    PF_SCRATCH8[7] = ((v >> 56u64) & 0xffu64) as u8
    pf_sha_update_byte(PF_SCRATCH8[0])
    pf_sha_update_byte(PF_SCRATCH8[1])
    pf_sha_update_byte(PF_SCRATCH8[2])
    pf_sha_update_byte(PF_SCRATCH8[3])
    pf_sha_update_byte(PF_SCRATCH8[4])
    pf_sha_update_byte(PF_SCRATCH8[5])
    pf_sha_update_byte(PF_SCRATCH8[6])
    pf_sha_update_byte(PF_SCRATCH8[7])
    return 0u32
}

fn pf_sha_final(out: *u8) -> u32 {
    let final_bits: u64 = PF_BITS
    pf_sha_update_byte(0x80u8)
    while PF_BUFLEN != 56u32 {
        pf_sha_update_byte(0u8)
    }
    pf_sha_update_byte(((final_bits >> 56u64) & 0xffu64) as u8)
    pf_sha_update_byte(((final_bits >> 48u64) & 0xffu64) as u8)
    pf_sha_update_byte(((final_bits >> 40u64) & 0xffu64) as u8)
    pf_sha_update_byte(((final_bits >> 32u64) & 0xffu64) as u8)
    pf_sha_update_byte(((final_bits >> 24u64) & 0xffu64) as u8)
    pf_sha_update_byte(((final_bits >> 16u64) & 0xffu64) as u8)
    pf_sha_update_byte(((final_bits >>  8u64) & 0xffu64) as u8)
    pf_sha_update_byte(( final_bits          & 0xffu64) as u8)
    for i in 0..8 {
        let hi: u32 = PF_H[i]
        let i4: u32 = (i as u32) * 4u32
        out[i4 + 0u32] = ((hi >> 24u32) & 0xffu32) as u8
        out[i4 + 1u32] = ((hi >> 16u32) & 0xffu32) as u8
        out[i4 + 2u32] = ((hi >>  8u32) & 0xffu32) as u8
        out[i4 + 3u32] = ( hi           & 0xffu32) as u8
    }
    return 0u32
}

/* ─── Static-string init ─────────────────────────────────────────── */

fn pf_init_strings_once() -> u32 {
    if PF_MSG_INIT == 1u8 { return 0u32 }
    /* "decl is a parser-recovery error node" + NUL = 38 bytes (fits in 48) */
    PF_MSG_ERROR_NODE[0]  = 100u8
    PF_MSG_ERROR_NODE[1]  = 101u8
    PF_MSG_ERROR_NODE[2]  = 99u8
    PF_MSG_ERROR_NODE[3]  = 108u8
    PF_MSG_ERROR_NODE[4]  = 32u8
    PF_MSG_ERROR_NODE[5]  = 105u8
    PF_MSG_ERROR_NODE[6]  = 115u8
    PF_MSG_ERROR_NODE[7]  = 32u8
    PF_MSG_ERROR_NODE[8]  = 97u8
    PF_MSG_ERROR_NODE[9]  = 32u8
    PF_MSG_ERROR_NODE[10] = 112u8
    PF_MSG_ERROR_NODE[11] = 97u8
    PF_MSG_ERROR_NODE[12] = 114u8
    PF_MSG_ERROR_NODE[13] = 115u8
    PF_MSG_ERROR_NODE[14] = 101u8
    PF_MSG_ERROR_NODE[15] = 114u8
    PF_MSG_ERROR_NODE[16] = 45u8
    PF_MSG_ERROR_NODE[17] = 114u8
    PF_MSG_ERROR_NODE[18] = 101u8
    PF_MSG_ERROR_NODE[19] = 99u8
    PF_MSG_ERROR_NODE[20] = 111u8
    PF_MSG_ERROR_NODE[21] = 118u8
    PF_MSG_ERROR_NODE[22] = 101u8
    PF_MSG_ERROR_NODE[23] = 114u8
    PF_MSG_ERROR_NODE[24] = 121u8
    PF_MSG_ERROR_NODE[25] = 32u8
    PF_MSG_ERROR_NODE[26] = 101u8
    PF_MSG_ERROR_NODE[27] = 114u8
    PF_MSG_ERROR_NODE[28] = 114u8
    PF_MSG_ERROR_NODE[29] = 111u8
    PF_MSG_ERROR_NODE[30] = 114u8
    PF_MSG_ERROR_NODE[31] = 32u8
    PF_MSG_ERROR_NODE[32] = 110u8
    PF_MSG_ERROR_NODE[33] = 111u8
    PF_MSG_ERROR_NODE[34] = 100u8
    PF_MSG_ERROR_NODE[35] = 101u8
    PF_MSG_ERROR_NODE[36] = 0u8

    /* "cycle hexad fails defense-in-depth admission" + NUL = 46 bytes (fits in 56) */
    PF_MSG_HEXAD_UNREP[0]  = 99u8
    PF_MSG_HEXAD_UNREP[1]  = 121u8
    PF_MSG_HEXAD_UNREP[2]  = 99u8
    PF_MSG_HEXAD_UNREP[3]  = 108u8
    PF_MSG_HEXAD_UNREP[4]  = 101u8
