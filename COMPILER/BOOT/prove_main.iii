/* COMPILER/BOOT/prove_main.iii -- iii prove: THE EQUIVALENCE PROVER AS A STANDING TOOL.
 *
 *     iii prove <a.iii> <fnA> <b.iii> <fnB>     prove fnA == fnB over ALL 2^64 inputs
 *     iii prove --list <a.iii>                  list the provable functions in a file
 *
 * This is the disposer (numera/ser_kinduct_sym's seq_equiv) made INDEPENDENTLY USEFUL: it decides,
 * for two functions written by ANYONE in ANY .iii file, whether they compute the same thing for
 * EVERY possible input -- not on sampled vectors, not on a curated suite: a bit-blast proof over the
 * entire 2^64 input space of every parameter, or a CONCRETE COUNTEREXAMPLE, or an honest refusal.
 *
 * It is not a demo and takes no hardcoded examples: the inputs are the user's own source files.
 * The whole pipeline runs IN THIS PROCESS -- read source, lex, parse, emit SVIR (the compiler's own
 * front end and its own SVIR backend, linked in, not shelled out), locate the two functions by name,
 * miter their denotations, decide.  No script, no glue, no operator.
 *
 * VERDICTS (exit code = verdict, so it composes into any pipeline):
 *   0  PROVEN     the two functions are equal for every input (bb_equal UNSAT over all 2^64)
 *   1  REFUTED    they differ -- a concrete counterexample is PRINTED (the inputs that break it)
 *   2  UNDECIDED  a body left the decided straight-line fragment (variable shift, division, call,
 *                 symbolic memory, control flow beyond the modelled forms) or exceeded bit-blast
 *                 capacity.  The tool says WHY.  It NEVER guesses, and it NEVER says "equal" unless
 *                 it proved it.
 *   3  usage   4  file/read error   5  parse error   6  SVIR emission refused   7  no such function
 *   8  arity mismatch (the miter is undefined -- distinct signatures are not comparable)
 *
 * WHY THIS IS SOUND: a wrong "PROVEN" is the one unrecoverable outcome, so the verdict is only ever
 * emitted from bb_equal == 1 (a UNSAT proof).  Every other outcome -- refutation, out-of-fragment,
 * capacity, poison -- maps to REFUTED/UNDECIDED.  This is the same judgment the mathesis engine
 * admits theorems through; it is now the same judgment a user can run on their own code.
 */
module prove_main

extern @abi(c-msvc-x64) fn iii_lex_malloc_c(n: u64) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_read_u64_c(addr: u64, off: u64) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_fopen_c(path: u64, mode: u32) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_fread_c(ptr: u64, n: u64, file: u64) -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_fclose_c(file: u64) -> u32 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_stdout_c() -> u64 from "lex_runtime.c"
extern @abi(c-msvc-x64) fn iii_lex_create(bytes: u64, len: u64, src: u64) -> u64 from "lex.iii"
extern @abi(c-msvc-x64) fn iii_ast_create(bytes: u64, len: u64, src: u64) -> u64 from "ast.iii"
extern @abi(c-msvc-x64) fn iii_parse_create(lex: u64, ast: u64) -> u64 from "parse.iii"
extern @abi(c-msvc-x64) fn iii_parse_module(p: u64) -> u32 from "parse.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_emit_mem(ast: u64) -> u32 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_mo() -> u64 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_mlen() -> u64 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_nfunc() -> u32 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_fn_index(namep: u64, namelen: u64) -> u32 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_names(out: u64) -> u32 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn iii_cg_svir_unsup() -> u32 from "cg_svir.iii"
extern @abi(c-msvc-x64) fn sd_locate(base: u64, len: u64, fnidx: u32) -> u64 from "ser_kinduct_sym.iii"
extern @abi(c-msvc-x64) fn seq_equiv(ba: u64, oa: u64, la: u64, bx: u64, ox: u64, lx: u64, nparam: u32) -> u32 from "ser_kinduct_sym.iii"
extern @abi(c-msvc-x64) fn sd_denote(base: u64, boff: u64, blen: u64, nparam: u32) -> u32 from "ser_kinduct_sym.iii"
extern @abi(c-msvc-x64) fn sd_stdiag() -> u64 from "ser_kinduct_sym.iii"
extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_equal(a: u32, b: u32) -> u8 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_witness(v: u32) -> u64 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

const CAP : u64 = 1048576u64          /* max source size (1 MiB) */
const MAXSVIR : u64 = 262145u64       /* nfunc byte + MO capacity */
const SD_LOCFAIL : u64 = 18446744073709551615u64
const SD_TOP : u32 = 4294967295u32
const SEQ_TOP : u32 = 2u32

var SRCA : [u8; 1048576]
var SRCB : [u8; 1048576]
var CONA : [u8; 262145]      /* module A's SVIR container (copied: emitting B overwrites the emitter) */
var CONB : [u8; 262145]
var LENA : [u64; 1]
var LENB : [u64; 1]
var DIG : [u8; 24]

fn ps(s: u64) -> u32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { putchar(p[i] as i32)  i = i + 1u64 }
    return 1u32
}
fn pd(v: u64) -> u32 {
    if v == 0u64 { putchar(48i32)  return 1u32 }
    let mut n : u64 = v
    let mut k : u64 = 0u64
    while n > 0u64 { DIG[k] = ((n % 10u64) + 48u64) as u8  n = n / 10u64  k = k + 1u64 }
    while k > 0u64 { k = k - 1u64  putchar(DIG[k] as i32) }
    return 1u32
}
fn phex(v: u64) -> u32 {
    ps("0x" as u64)
    let mut i : u64 = 16u64
    while i > 0u64 {
        i = i - 1u64
        let nib : u32 = ((v >> (i * 4u64)) & 15u64) as u32
        if nib < 10u32 { putchar((48u32 + nib) as i32) } else { putchar((87u32 + nib) as i32) }
    }
    return 1u32
}
fn slen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { i = i + 1u64 }
    return i
}
fn streq(a: u64, b: u64) -> u32 {
    let pa : *u8 = a as *u8
    let pb : *u8 = b as *u8
    let mut i : u64 = 0u64
    while pa[i] != 0u8 {
        if pa[i] != pb[i] { return 0u32 }
        i = i + 1u64
    }
    if pb[i] != 0u8 { return 0u32 }
    return 1u32
}

/* read a whole file into buf; returns length, or SD_LOCFAIL on failure.
 * fread is a SHORT-READ interface: it must be looped (the eval_main discipline) -- a single
 * call returns only what one buffered chunk yielded, which silently truncates a real source file. */
fn read_file(path: u64, buf: u64) -> u64 {
    let f : u64 = iii_lex_fopen_c(path, 0u32)       /* FOPEN_RB */
    if f == 0u64 { return SD_LOCFAIL }
    let mut total : u64 = 0u64
    let mut go : u32 = 1u32
    while go == 1u32 {
        if total + 65536u64 > CAP { go = 0u32 }
        else {
            let n : u64 = iii_lex_fread_c(buf + total, 65536u64, f)
            total = total + n
            if n < 65536u64 { go = 0u32 }
        }
    }
    iii_lex_fclose_c(f)
    return total
}

/* lex+parse+emit-SVIR one source in this process; copy the container out (the emitter is global
 * state, so the caller MUST take its bytes before compiling the next file).
 * returns 0 ok | 5 parse error | 6 svir refused | 4 read error */
fn compile_to_svir(path: u64, src: u64, con: u64, lenout: u64) -> u32 {
    let n : u64 = read_file(path, src)
    if n == SD_LOCFAIL { return 4u32 }
    if n == 0u64 { return 4u32 }
    let lx : u64 = iii_lex_create(src, n, path)
    if lx == 0u64 { return 5u32 }
    let ast : u64 = iii_ast_create(src, n, path)
    if ast == 0u64 { return 5u32 }
    let p : u64 = iii_parse_create(lx, ast)
    if p == 0u64 { return 5u32 }
    if iii_parse_module(p) == 0u32 { return 5u32 }   /* parse_module: 1 = OK, 0 = failed */
    if iii_cg_svir_emit_mem(ast) != 0u32 { return 6u32 }
    /* container = [u8 nfunc][MO...] -- byte-identical to iii_cg_svir_raw's file */
    let mo : u64 = iii_cg_svir_mo()
    let ml : u64 = iii_cg_svir_mlen()
    if ml + 1u64 > MAXSVIR { return 6u32 }
    let d : *u8 = con as *u8
    let s : *u8 = mo as *u8
    d[0u64] = (iii_cg_svir_nfunc() & 255u32) as u8
    let mut i : u64 = 0u64
    while i < ml { d[1u64 + i] = s[i]  i = i + 1u64 }
    let lp : *u64 = lenout as *u64
    lp[0u64] = ml + 1u64
    return 0u32
}

fn prove_enter(argc: i32, argv: u64) -> u64 @export {
    let av : *u64 = argv as *u64
    if argc < 2i32 {
        ps("iii prove -- prove two functions equal over ALL 2^64 inputs (III's own disposer)\n\n" as u64)
        ps("  iii prove <a.iii> <fnA> <b.iii> <fnB>   prove fnA == fnB for EVERY input\n" as u64)
        ps("  iii prove --list <file.iii>             list the provable functions in a file\n\n" as u64)
        ps("exit: 0 PROVEN | 1 REFUTED (counterexample printed) | 2 UNDECIDED (reason printed)\n" as u64)
        return 3u64
    }

    /* ---- --list: name the functions this file offers, with their indices ---- */
    if streq(av[1u64], "--list" as u64) == 1u32 {
        if argc < 3i32 { ps("iii prove: --list needs a file\n" as u64)  return 3u64 }
        let rc : u32 = compile_to_svir(av[2u64], &SRCA as u64, &CONA as u64, &LENA as u64)
        if rc == 4u32 { ps("iii prove: cannot read: " as u64)  ps(av[2u64])  putchar(10i32)  return 4u64 }
        if rc == 5u32 { ps("iii prove: parse error in: " as u64)  ps(av[2u64])  putchar(10i32)  return 5u64 }
        if rc == 6u32 {
            ps("iii prove: SVIR emission refused (unsupported construct class " as u64)
            pd(iii_cg_svir_unsup() as u64)  ps(")\n" as u64)
            return 6u64
        }
        iii_cg_svir_names(iii_lex_stdout_c())
        return 0u64
    }

    if argc < 5i32 {
        ps("iii prove: need <a.iii> <fnA> <b.iii> <fnB>\n" as u64)
        return 3u64
    }

    /* ---- compile A, take its container; then compile B (the emitter is reused) ---- */
    let ra : u32 = compile_to_svir(av[1u64], &SRCA as u64, &CONA as u64, &LENA as u64)
    if ra == 4u32 { ps("iii prove: cannot read: " as u64)  ps(av[1u64])  putchar(10i32)  return 4u64 }
    if ra == 5u32 { ps("iii prove: parse error in: " as u64)  ps(av[1u64])  putchar(10i32)  return 5u64 }
    if ra == 6u32 {
        ps("iii prove: SVIR emission refused for " as u64)  ps(av[1u64])
        ps(" (class " as u64)  pd(iii_cg_svir_unsup() as u64)  ps(")\n" as u64)
        return 6u64
    }
    let ia : u32 = iii_cg_svir_fn_index(av[2u64], slen(av[2u64]))
    if ia == 0xFFFFFFFFu32 {
        ps("iii prove: no such function '" as u64)  ps(av[2u64])
        ps("' in " as u64)  ps(av[1u64])  putchar(10i32)
        ps("  (run: iii prove --list " as u64)  ps(av[1u64])  ps(")\n" as u64)
        return 7u64
    }

    let rb : u32 = compile_to_svir(av[3u64], &SRCB as u64, &CONB as u64, &LENB as u64)
    if rb == 4u32 { ps("iii prove: cannot read: " as u64)  ps(av[3u64])  putchar(10i32)  return 4u64 }
    if rb == 5u32 { ps("iii prove: parse error in: " as u64)  ps(av[3u64])  putchar(10i32)  return 5u64 }
    if rb == 6u32 {
        ps("iii prove: SVIR emission refused for " as u64)  ps(av[3u64])
        ps(" (class " as u64)  pd(iii_cg_svir_unsup() as u64)  ps(")\n" as u64)
        return 6u64
    }
    let ib : u32 = iii_cg_svir_fn_index(av[4u64], slen(av[4u64]))
    if ib == 0xFFFFFFFFu32 {
        ps("iii prove: no such function '" as u64)  ps(av[4u64])
        ps("' in " as u64)  ps(av[3u64])  putchar(10i32)
        ps("  (run: iii prove --list " as u64)  ps(av[3u64])  ps(")\n" as u64)
        return 7u64
    }

    /* ---- locate both bodies inside their containers ---- */
    let pa : u64 = sd_locate(&CONA as u64, LENA[0u64], ia)
    if pa == SD_LOCFAIL { ps("iii prove: cannot locate function body (A)\n" as u64)  return 7u64 }
    let pb : u64 = sd_locate(&CONB as u64, LENB[0u64], ib)
    if pb == SD_LOCFAIL { ps("iii prove: cannot locate function body (B)\n" as u64)  return 7u64 }
    let npa : u32 = (pa & 255u64) as u32
    let npb : u32 = (pb & 255u64) as u32
    if npa != npb {
        ps("iii prove: ARITY MISMATCH -- " as u64)  ps(av[2u64])  ps(" takes " as u64)  pd(npa as u64)
        ps(" param(s), " as u64)  ps(av[4u64])  ps(" takes " as u64)  pd(npb as u64)  putchar(10i32)
        ps("  distinct signatures are not comparable; the miter is undefined.\n" as u64)
        return 8u64
    }
    let boa : u64 = pa >> 24u64
    let bla : u64 = (pa >> 8u64) & 65535u64
    let bob : u64 = pb >> 24u64
    let blb : u64 = (pb >> 8u64) & 65535u64

    /* ---- THE JUDGMENT: over all 2^64 assignments of every parameter ---- */
    let v : u32 = seq_equiv(&CONA as u64, boa, bla, &CONB as u64, bob, blb, npa)

    if v == 1u32 {
        ps("PROVEN: " as u64)  ps(av[2u64])  ps(" == " as u64)  ps(av[4u64])
        ps("  for EVERY input (all 2^64 assignments of " as u64)  pd(npa as u64)
        ps(" parameter(s); bit-blast UNSAT, not sampled).\n" as u64)
        ps("[prove 1:1 = proven]\n" as u64)
        return 0u64
    }

    if v == 0u32 {
        /* REFUTED -- rebuild the miter and extract the concrete inputs that break it. */
        ps("REFUTED: " as u64)  ps(av[2u64])  ps(" != " as u64)  ps(av[4u64])  putchar(10i32)
        bb_reset(64u64)
        let da : u32 = sd_denote(&CONA as u64, boa, bla, npa)
        let db : u32 = sd_denote(&CONB as u64, bob, blb, npa)
        if da != SD_TOP { if db != SD_TOP {
            if bb_equal(da, db) == 0u8 {
                ps("  counterexample:\n" as u64)
                let mut k : u32 = 0u32
                while k < npa {
                    ps("    param " as u64)  pd(k as u64)  ps(" = " as u64)
                    phex(bb_witness(k))  putchar(10i32)
                    k = k + 1u32
                }
            }
        } }
        ps("[prove 0:1 = refuted]\n" as u64)
        return 1u64
    }

    /* UNDECIDED -- say exactly why, never guess. */
    ps("UNDECIDED: cannot decide " as u64)  ps(av[2u64])  ps(" vs " as u64)  ps(av[4u64])  putchar(10i32)
    ps("[prove = undecided]\n" as u64)
    bb_reset(64u64)
    let ta : u32 = sd_denote(&CONA as u64, boa, bla, npa)
    if ta == SD_TOP {
        ps("  " as u64)  ps(av[2u64])  ps(" left the decided fragment (sd diag " as u64)
        pd(sd_stdiag())  ps(")\n" as u64)
    }
    bb_reset(64u64)
    let tb : u32 = sd_denote(&CONB as u64, bob, blb, npa)
    if tb == SD_TOP {
        ps("  " as u64)  ps(av[4u64])  ps(" left the decided fragment (sd diag " as u64)
        pd(sd_stdiag())  ps(")\n" as u64)
    }
    ps("  decidable fragment: straight-line ALU over params + constants, constant shift counts,\n" as u64)
    ps("  structured if/else, counter loops with constant stride, constant-address byte memory.\n" as u64)
    ps("  (variable shifts, division, calls, symbolic addresses are outside it -- by design:\n" as u64)
    ps("   this tool NEVER reports 'equal' unless it PROVED it.)\n" as u64)
    return 2u64
}
