module rm2_sample

/* iii_cap_revoke is the sanctum-runtime capability-revoke primitive. cg_rm2 recognises the call by
 * name (sets RM2_G_CAP_REVOKE -- a sealed_call entry MUST revoke its cap), but sema still needs it
 * declared. The sanctum runtime provides the symbol at link time. */
extern @abi(c-sysv-x64) fn iii_cap_revoke(h: u64) -> u64 from "sanctum_rt"

sealed_call do_thing(x: u64) @seal_id(1) {
    iii_cap_revoke(x)
    let a: u64 = x + x
    let b: u64 = a + x
    return b
}

/* De-vacuum the gate against the unsigned-ordering setcc bug: a UNSIGNED u64 ordering with the high bit
 * set. x=0x4000000000000000 -> x+x=0x8000000000000000; x < (x+x) is TRUE unsigned (-> 1) but FALSE under
 * the old signed setl (+0x4e18 < INT64_MIN). do_ord(0x4000000000000000) must be 1. */
sealed_call do_ord(x: u64) @seal_id(2) {
    iii_cap_revoke(x)
    let r: u64 = x < (x + x)
    return r
}

/* No-regression: a SIGNED i64 ordering must STAY signed. neg=-7; neg < 5 is TRUE signed (-> 1) but FALSE
 * if it wrongly went unsigned (0xFFFF...F9 < 5). do_sord(_) must be 1. */
sealed_call do_sord(x: u64) @seal_id(3) {
    iii_cap_revoke(x)
    let neg: i64 = 0i64 - 7i64
    let r: u64 = neg < 5i64
    return r
}

/* R2 (cg_typeclass shared resolver): unsigned u64 ordering when an operand is a TYPED BINARY whose lhs is
 * an unclassifiable literal but rhs is u64 (the lhs-ELSE-rhs class). x=0x8000000000000001 (bit 63 set);
 * (0+x) > (0+lo) is TRUE unsigned (-> 1) but FALSE under the OLD sv_expr_is_u64 lhs-only walk (literal lhs
 * -> unknown -> signed setcc). do_ord_binop(0x8000000000000001) must be 1. Prove-the-negative for emit_sanctum. */
sealed_call do_ord_binop(x: u64) @seal_id(4) {
    iii_cap_revoke(x)
    let lo: u64 = 2u64
    let r: u64 = (0u64 + x) > (0u64 + lo)
    return r
}
