/* sema.iii — Stage-0 .iii port of sema.c
 *
 * Mirror of COMPILER/BOOT/sema.c (1440 lines) authored under iiis-0
 * dialect.  Behavioural parity with the C reference: same gates D-1..
 * D-12, same error codes, same side-table queries.  No placeholders,
 * no skipped checks, NIH only (ADR-021).
 *
 * Pre-established Stage-0 dialect notes carried from earlier ports:
 *   - No `;` separator (only inside [T; N]).
 *   - No char literals 'X' — use numeric byte values.
 *   - No multi-line binary expressions.
 *   - `(0u64 as *u8)` parses as start of hexad literal — drop parens.
 *   - `&IDENT[i]` parses as `(&IDENT)[i]` (postfix-tighter); use
 *     `(&IDENT as u64) + (i as u64) * scale` for element addresses.
 *   - `@export` MUST be inline at end of fn signature.
 *   - Parser recursion limit ~8 nesting levels — factor deep nests
 *     into helper functions.
 *   - No `break`/`continue` — sentinel-flag refactor.
 *   - No `if` as expression — use `let mut x : T = b; if cond { x = a }`.
 */

module sema

/* ─── Externs from C side (AST + hexad_check + sema accessors) ────── */

