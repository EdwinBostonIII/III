/* C:\Users\Edwin Boston\OneDrive\Desktop\III\COMPILER\BOOT\sid.iii
 *
 * III Stage-0 Side-effect Inverse Derivation (SID) — .iii port of sid.c.
 *
 * Mirrors sid.h ABI: every public entry point is @export and link-
 * compatible with the C iiis-0 build.  The opaque iii_sid_state_t is
 * collapsed into module-singleton state — iii_sid_create returns a
 * sentinel pointer, every other entry point ignores its `s` argument.
 *
 * Stage-0 simplifications versus sid.c:
 *   - Records and errors live in fixed-cap flat byte arrays.
 *     SID_REC_CAP = 256 cycles; SID_ERR_CAP = 256 errors.  The boot
 *     tree never approaches even 64 cycles in practice.
 *   - Error messages are static per-code strings (no printf-style
 *     interpolation).  The C version interpolates the offending IRPD
 *     method name into one of the messages; this drops that detail,
 *     which is acceptable per main.c::iii_diag_sid (message may be
 *     NULL, code-name carries the diagnostic).
 *   - Records are exposed via a flat 56-byte stride (decl_node u32 @0,
 *     composed_hexad u32 @4 (0xFFFF sentinel), replay_bitmap u32 @8,
 *     call_count u32 @12, irreversible u32 @16, calls u8[32] @20,
 *     pad u32 @52).  No external consumer reads this layout in
 *     Stage 0; cg consumes only the AST annotation blob, which keeps
 *     the documented sid.c::sid_process_cycle wire format byte-for-byte.
 *
 * Annotation blob layout (must match sid.c lines 459-475):
 *   off  type   field
 *    0   u16    composed_hexad (LE)
 *    2   u16    pad (zero)
 *    4   u32    replay_bitmap (LE)
 *    8   u8     call_count
 *    9   u8     irreversible
 *   10   u8[N]  calls (one byte per call_count, each an SE kind 1..17)
 */

module sid

/* ─── ABI / SE kinds (mirror sid.h) ────────────────────────────────── */

const SID_SE_NONE              : u32 = 0u32
const SID_SE_MSR_WRITE         : u32 = 1u32
const SID_SE_CR_WRITE          : u32 = 2u32
const SID_SE_NPT_ENTRY_WRITE   : u32 = 3u32
const SID_SE_VMCB_FIELD_WRITE  : u32 = 4u32
const SID_SE_IOMMU_DTE_WORD    : u32 = 5u32
const SID_SE_AVIC_TBL_WRITE    : u32 = 6u32
const SID_SE_MSRPM_BIT_SET     : u32 = 7u32
const SID_SE_IOPM_BIT_SET      : u32 = 8u32
const SID_SE_PKRU_WRITE        : u32 = 9u32
const SID_SE_XCR0_WRITE        : u32 = 10u32
const SID_SE_CAP_ACQUIRE       : u32 = 11u32
const SID_SE_CAP_RELEASE       : u32 = 12u32
const SID_SE_PAGE_ALLOC        : u32 = 13u32
const SID_SE_PAGE_FREE         : u32 = 14u32
const SID_SE_DPC_ARM           : u32 = 15u32
const SID_SE_DPC_CANCEL        : u32 = 16u32
const SID_SE_NMI_INSTALL       : u32 = 17u32

/* Error codes (mirror sid.h). */
const SID_E_PARSE_IRPD             : i32 = 1i32
const SID_E_UNKNOWN_METHOD         : i32 = 2i32
const SID_E_HEXAD_COMPOSE_FAIL     : i32 = 3i32
const SID_E_CEILING_REJECT         : i32 = 4i32
const SID_E_TOO_MANY_CALLS         : i32 = 5i32
const SID_E_REPLAY_BITMAP_OVERFLOW : i32 = 6i32
const SID_E_OOM                    : i32 = 99i32

/* Per-cycle hexad default (mirror sid.c::SID_IRPD_DEFAULT_HEXAD = 377). */
const SID_IRPD_DEFAULT_HEXAD : u32 = 377u32
const SID_HEXAD_UNSET        : u32 = 0xFFFFu32
const SID_MAX_CALLS          : u32 = 32u32

/* AST kind constants (mirror ast.h enum order). */
const SID_K_MODULE             : u32 = 1u32
const SID_K_CYCLE_DECL         : u32 = 3u32
const SID_K_MODIFIER           : u32 = 14u32
const SID_K_STMT_LET           : u32 = 20u32
const SID_K_STMT_WAVEFRONT     : u32 = 21u32
const SID_K_STMT_SANCTUM_ENTER : u32 = 22u32
const SID_K_STMT_FOR           : u32 = 24u32
const SID_K_STMT_MATCH         : u32 = 25u32
const SID_K_STMT_RETURN        : u32 = 26u32
const SID_K_STMT_ASSIGN        : u32 = 27u32
const SID_K_STMT_EXPR          : u32 = 28u32
const SID_K_FORWARD_BLOCK      : u32 = 29u32
const SID_K_COMPROMISE_BLOCK   : u32 = 30u32
const SID_K_MATCH_ARM          : u32 = 31u32
const SID_K_EXPR_IDENT         : u32 = 45u32
const SID_K_EXPR_CALL          : u32 = 46u32
const SID_K_EXPR_FIELD         : u32 = 47u32
const SID_K_EXPR_INDEX         : u32 = 48u32
const SID_K_EXPR_BINARY        : u32 = 49u32
const SID_K_EXPR_UNARY         : u32 = 50u32
const SID_K_EXPR_BLOCK         : u32 = 51u32
const SID_K_EXPR_MATCH         : u32 = 52u32
const SID_K_EXPR_PAREN         : u32 = 53u32
const SID_K_ARG                : u32 = 57u32
const SID_K_EXPR_PARALLEL      : u32 = 61u32

/* Caps. */
const SID_REC_CAP   : u32 = 256u32
const SID_REC_BYTES : u32 = 56u32
const SID_ERR_CAP   : u32 = 256u32
const SID_ERR_BYTES : u32 = 16u32   /* i32 code @0, u32 decl @4, u64 msg @8 */

/* ─── Externs from C side (AST + sema + hexad_check) ──────────────── */

