/* sq04 -- every v1 operator + comparison + bitwise, precedence-mixed. */
module sq04
fn f(a: i64, b: i64) -> i64 {
    let mut r : i64 = a * b + a - b
    r = r % 100
    r = r / 3
    r = (r << 2) - (r >> 1)
    r = (r & 255) | (r ^ 7)
    if r < 0 { r = 0 - r }
    if a == b { r = r + 1 } else { r = r + 2 }
    if a != b { if a > b { r = r + 10 } else { r = r + 20 } }
    if r >= 5 { if r <= 1000 { r = r + 100 } }
    return r
}
fn main() -> i64 { return f(17, 5) }
