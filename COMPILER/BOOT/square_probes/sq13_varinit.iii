/* sq13 -- S-frontier slice 2 (§W.8): nonzero-initialized module cells hold
 * their language-defined values through the ENTRY-fn init preamble --
 * scalars, CTFE scalars, bracket arrays with zeros mixed (zero-skip), and
 * narrow element widths; mutation after init behaves.  97 = §W.8 holds. */
module sq13

const K : u64 = 21u64

var S1 : u64 = 7u64
var S2 : u64 = K * 2u64
var A : [u32; 4] = [1u32, 0u32, 3u32, 0u32]
var W : [u16; 2] = [65535u16, 2u16]
var Z : u64

fn main() -> u64 {
    if S1 != 7u64 { return 81u64 }
    if S2 != 42u64 { return 82u64 }
    if A[0u64] != 1u32 { return 83u64 }
    if A[1u64] != 0u32 { return 84u64 }
    if A[2u64] != 3u32 { return 85u64 }
    if A[3u64] != 0u32 { return 86u64 }
    if W[0u64] != 65535u16 { return 87u64 }
    if W[1u64] != 2u16 { return 88u64 }
    if Z != 0u64 { return 89u64 }
    A[1u64] = A[0u64] + A[2u64]
    if A[1u64] != 4u32 { return 90u64 }
    S1 = S1 + S2
    if S1 != 49u64 { return 91u64 }
    if (W[0u64] + W[1u64]) != 1u16 { return 92u64 }
    return 97u64
}
