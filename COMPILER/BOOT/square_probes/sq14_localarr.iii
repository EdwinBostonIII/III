/* sq14 -- S-frontier slice 3 (§W.9): local `var x : [T; N]` lives in the
 * frame arena -- 0x8B reserves+ZEROES per activation (eval's fresh-world
 * law), 0x8C addresses it.  Teeth: indexed stores/loads (corpus 191),
 * runtime indices (corpus 1089), adjacent-scalar non-overlap, TWO arrays'
 * offset separation, u64 elements, and RECURSION ISOLATION (each depth's
 * array is fresh and survives the inner call).  98 = the arena holds. */
module sq14

/* NOTE (named open corner, adjudication deferred): FIRST-READ of a never-
 * written local array differs across routes today -- E/S read 0 (world/
 * arena zero law), N reads stack garbage.  The corpus never pinned it;
 * this probe tests only DEFINED behavior (write-then-read + isolation). */
fn rec(d: u64) -> u64 {
    var loc : [u64; 4]
    loc[0u64] = d
    loc[3u64] = d * 10u64
    if d > 0u64 {
        let sub: u64 = rec(d - 1u64)
        if sub != 0u64 { return sub }
    }
    if loc[0u64] != d { return 2u64 }
    if loc[3u64] != d * 10u64 { return 3u64 }
    return 0u64
}

fn main() -> u64 {
    var buf : [u8; 8]
    buf[0u32] = 0xAAu8
    buf[3u32] = 0xBBu8
    buf[7u32] = 0xCCu8
    if buf[0u32] != 0xAAu8 { return 81u64 }
    if buf[3u32] != 0xBBu8 { return 82u64 }
    if buf[7u32] != 0xCCu8 { return 83u64 }
    var n : u32 = 5u32
    n = n + 10u32
    if n != 15u32 { return 84u64 }
    if buf[0u32] != 0xAAu8 { return 85u64 }
    var w : [u64; 3]
    let mut i : u64 = 0u64
    while i < 3u64 {
        w[i] = i * 7u64
        i = i + 1u64
    }
    if w[0u64] != 0u64 { return 86u64 }
    if w[1u64] != 7u64 { return 87u64 }
    if w[2u64] != 14u64 { return 88u64 }
    if buf[3u32] != 0xBBu8 { return 89u64 }
    if rec(5u64) != 0u64 { return 90u64 }
    if buf[7u32] != 0xCCu8 { return 91u64 }
    return 98u64
}
