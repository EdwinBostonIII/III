module stage1_acc

/* III Stage-1 Algebraic Cycle Composition (Wall-Y) — .iii port of
 * COMPILER/BOOT/acc.c.
 *
 * 729-state Z3⁶ admission bitmap.  Each state is a 6-component vector
 * with each comp in {0, 1, 2}.  Composition is componentwise (a + b)
 * mod 3.  Admission is a bit lookup in a 729-bit bitmap.
 *
 * Z3 component encoding (per acc.h §"Layout parity"):
 *   NEG  ↦ 2     (mod-3 representative of -1)
 *   ZERO ↦ 0
 *   POS  ↦ 1
 *
 * Canonical state index (BIG-endian trit packing):
 *   idx = ((((c0*3 + c1)*3 + c2)*3 + c3)*3 + c4)*3 + c5
 *   i.e. c0 is the MOST significant trit.  This is opposite of the
 *   hexad library's encoding (which has c0 as LSB).  Both are valid
 *   for their respective libraries; the runtime mirror in
 *   CONSTITUTIONAL/include/acc.h uses the same big-endian layout
 *   for ACC.
 *
 * Stage-1 bitmap layout: 12 × u64 = 768 bits ≥ 729.  Identical to
 * the C version's u64[12] layout.  Bit i (0 ≤ i < 729) is admitted
 * iff `(g_acc_bitmap[i / 64] >> (i % 64)) & 1`.
 *
 * Stage-1 deferred work:
 *   - canonical_bytes 92-byte (ceil(729/8)) export
 *   - bitmap_fingerprint (FNV-1a-64 over canonical 92 bytes)
 *   - bitmap_sha256 over canonical 92 bytes
 *   - audit-sink callbacks
 *   - seal + self-check
 */

var g_acc_bitmap: [u64; 12]
var g_acc_init:   u64 = 0
var g_acc_sealed: u64 = 0

/* Bootstrap-permissive init: all 729 bits set, padding (bits 729..767)
 * forced clear. */
fn iii_acc_init_permissive() -> u64 {
    let mut i: u64 = 0
    while i < 11 {
        g_acc_bitmap[i] = 0xFFFFFFFFFFFFFFFF
        i = i + 1
    }
    /* Word 11: bits 0..24 set (representing bits 704..728), bits 25..63 clear. */
    g_acc_bitmap[11] = 0x1FFFFFF
    g_acc_init = 1
    g_acc_sealed = 0
    return 0
}

/* Compose Z3 vectors componentwise mod 3.  Returns the composed
 * canonical index. */
fn iii_acc_compose_index(idx_a: u64, idx_b: u64) -> u64 {
    /* Decompose idx_a into 6 trits.  BIG-endian: c0 is most significant. */
    let mut a0: u64 = 0
    let mut a1: u64 = 0
    let mut a2: u64 = 0
    let mut a3: u64 = 0
    let mut a4: u64 = 0
    let mut a5: u64 = 0
    let mut b0: u64 = 0
    let mut b1: u64 = 0
    let mut b2: u64 = 0
    let mut b3: u64 = 0
    let mut b4: u64 = 0
    let mut b5: u64 = 0
    let mut tmp: u64 = idx_a
    a5 = tmp % 3
    tmp = tmp / 3
    a4 = tmp % 3
    tmp = tmp / 3
    a3 = tmp % 3
    tmp = tmp / 3
    a2 = tmp % 3
    tmp = tmp / 3
    a1 = tmp % 3
    tmp = tmp / 3
    a0 = tmp % 3
    tmp = idx_b
    b5 = tmp % 3
    tmp = tmp / 3
    b4 = tmp % 3
    tmp = tmp / 3
    b3 = tmp % 3
    tmp = tmp / 3
    b2 = tmp % 3
    tmp = tmp / 3
    b1 = tmp % 3
    tmp = tmp / 3
    b0 = tmp % 3
    let c0: u64 = (a0 + b0) % 3
    let c1: u64 = (a1 + b1) % 3
    let c2: u64 = (a2 + b2) % 3
    let c3: u64 = (a3 + b3) % 3
    let c4: u64 = (a4 + b4) % 3
    let c5: u64 = (a5 + b5) % 3
    return ((((c0 * 3 + c1) * 3 + c2) * 3 + c3) * 3 + c4) * 3 + c5
}

/* Pack 6 components (BIG-endian, c0 most significant) into canonical
 * Wall-Y index. */
fn iii_acc_pack(c0: u64, c1: u64, c2: u64, c3: u64, c4: u64, c5: u64) -> u64 {
    return ((((c0 * 3 + c1) * 3 + c2) * 3 + c3) * 3 + c4) * 3 + c5
}

/* Bit-level setters/queries, mirroring ceiling.iii pattern. */
fn iii_acc_admit_index(idx: u64) -> u64 {
    if g_acc_sealed > 0 {
        return 1
    }
    if idx >= 729 {
        return 1
    }
    g_acc_init = 1
    let word_idx: u64 = idx / 64
    let bit_pos:  u64 = idx % 64
    let mask:     u64 = 1 << bit_pos
    g_acc_bitmap[word_idx] = g_acc_bitmap[word_idx] | mask
    return 0
}

fn iii_acc_deny_index(idx: u64) -> u64 {
    if g_acc_sealed > 0 {
        return 1
    }
    if idx >= 729 {
        return 1
    }
    g_acc_init = 1
    let word_idx: u64 = idx / 64
    let bit_pos:  u64 = idx % 64
    let mask:     u64 = 1 << bit_pos
    let inv:      u64 = ~mask
    g_acc_bitmap[word_idx] = g_acc_bitmap[word_idx] & inv
    return 0
}

fn iii_acc_is_admitted_index(idx: u64) -> u64 {
    if g_acc_init == 0 {
        return 0
    }
    if idx >= 729 {
        return 0
    }
    let word_idx: u64 = idx / 64
    let bit_pos:  u64 = idx % 64
    let word:     u64 = g_acc_bitmap[word_idx]
    let shifted:  u64 = word >> bit_pos
    return shifted & 1
}

fn iii_acc_count_admitted() -> u64 {
    if g_acc_init == 0 {
        return 0
    }
    let mut total: u64 = 0
    let mut i: u64 = 0
    let mut w: u64 = 0
    while i < 12 {
        w = g_acc_bitmap[i]
        while w > 0 {
            total = total + (w & 1)
            w = w >> 1
        }
        i = i + 1
    }
    return total
}

fn iii_acc_seal() -> u64 {
    g_acc_sealed = 1
    return 0
}

/* Test driver — encodes test outcomes in exit code:
 *   bit 0:  count == 729 after permissive init
 *   bit 1:  pack(0,0,0,0,0,0) → index 0 admitted
 *   bit 2:  pack(2,2,2,2,2,2) → index 728 admitted
 *   bit 3:  pack(1,2,0,1,2,0) → some-mid-index admitted
 *   bit 4:  compose(idx_zero, idx) == idx (ZERO is identity)
 *   bit 5:  compose(idx_pos_uniform, idx_pos_uniform) → 2-uniform
 *           (POS+POS = 2 mod 3)
 *   bit 6:  deny(100) actually clears bit 100
 *   bit 7:  count after deny == 728
 * Pass = exit 255.
 */
fn main() -> u64 {
    iii_acc_init_permissive()
    let mut score: u64 = 0
    if iii_acc_count_admitted() == 729 {
        score = score | 1
    }
    let zero_idx: u64 = iii_acc_pack(0, 0, 0, 0, 0, 0)
    if iii_acc_is_admitted_index(zero_idx) == 1 {
        score = score | 2
    }
    let max_idx: u64 = iii_acc_pack(2, 2, 2, 2, 2, 2)
    if iii_acc_is_admitted_index(max_idx) == 1 {
        score = score | 4
    }
    let mid_idx: u64 = iii_acc_pack(1, 2, 0, 1, 2, 0)
    if iii_acc_is_admitted_index(mid_idx) == 1 {
        score = score | 8
    }
    /* Identity composition: zero ⊕ mid = mid */
    if iii_acc_compose_index(zero_idx, mid_idx) == mid_idx {
        score = score | 16
    }
    /* Uniform POS ⊕ uniform POS = uniform 2 (POS+POS=2 mod 3) */
    let pos_uniform: u64 = iii_acc_pack(1, 1, 1, 1, 1, 1)
    let two_uniform: u64 = iii_acc_pack(2, 2, 2, 2, 2, 2)
    if iii_acc_compose_index(pos_uniform, pos_uniform) == two_uniform {
        score = score | 32
    }
    /* Deny bit 100 then test. */
    iii_acc_deny_index(100)
    if iii_acc_is_admitted_index(100) == 0 {
        score = score | 64
    }
    if iii_acc_count_admitted() == 728 {
        score = score | 128
    }
    return score
}
