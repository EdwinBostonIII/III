module stage1_hexad_check

/* III Stage-1 Hexad Admission Bitmap — .iii port of
 * COMPILER/BOOT/hexad_check.c.
 *
 * Mirrors the asymmetric-ternary representability theorem of
 * III-HEXAD.md §3 + §4: 729-bit bitmap (over 3^6 hexads), default
 * all-set, six PFS bricking-class hexads explicitly cleared.
 *
 * Bitmap layout: 729 bits packed into 12 × u64 words = 96 bytes used
 * (vs the C version's 144-byte block, which includes 48 bytes of
 * pad).  Stage-1 uses the smaller 12-u64 form because (a) the bit
 * mathematics are identical, (b) the eventual SHA-256 mhash is
 * computed over the canonical 144-byte form by zero-extending these
 * 96 bytes — handled by the future bitmap_mhash port.
 *
 * Pillar trit encoding (matches AST + TYPES library):
 *     NEG  = 0
 *     ZERO = 1
 *     POS  = 2
 *
 * Composition (asymmetric per III-HEXAD §1.2):
 *     ZERO ⊙ x = x   (identity)
 *     NEG  ⊙ x = NEG (NEG dominates)
 *     POS ⊙ POS = POS
 *
 * Deferred work (Stage-1+):
 *     - SHA-256 + iii_hexad_bitmap_mhash (~80 LoC of FIPS-180-4 in iii)
 *     - canonical_bytes 144-byte zero-padded export
 *     - AST-trit ↔ pillar-trit converters (need iii enum constants)
 */

/* The bitmap: 729 bits in 12 u64 slots (768 bits total; high 39 bits
 * of word 11 are zero). */
var hxc_bitmap: [u64; 12]
var hxc_init:   u64 = 0

/* Helper: pack 6 pillar trits (NEG=0, ZERO=1, POS=2) into the
 * canonical ternary index sum_{p=0..5} pillar[p] * 3^p. */
fn hxc_pack(p0: u64, p1: u64, p2: u64, p3: u64, p4: u64, p5: u64) -> u64 {
    let mut v: u64 = 0
    v = v + p0 * 1
    v = v + p1 * 3
    v = v + p2 * 9
    v = v + p3 * 27
    v = v + p4 * 81
    v = v + p5 * 243
    return v
}

/* Asymmetric trit composition.  Returns 3 (INVALID) for out-of-range. */
fn hxc_trit_compose(a: u64, b: u64) -> u64 {
    if a > 2 {
        return 3
    }
    if b > 2 {
        return 3
    }
    if a == 1 {
        return b
    }
    if b == 1 {
        return a
    }
    if a == 0 {
        return 0
    }
    if b == 0 {
        return 0
    }
    return 2
}

/* Trit negation.  Returns 3 for out-of-range. */
fn hxc_trit_neg(a: u64) -> u64 {
    if a == 0 {
        return 2
    }
    if a == 2 {
        return 0
    }
    if a == 1 {
        return 1
    }
    return 3
}

/* Bitmap admission test — checks bit `packed` in hxc_bitmap.
 * Returns 1 if admitted, 0 otherwise. */
fn iii_hxc_packed_admitted(packed: u64) -> u64 {
    if hxc_init == 0 {
        return 0
    }
    if packed >= 729 {
        return 0
    }
    let word_idx: u64 = packed / 64
    let bit_pos:  u64 = packed % 64
    let word:     u64 = hxc_bitmap[word_idx]
    let shifted:  u64 = word >> bit_pos
    return shifted & 1
}

/* Set bit `packed` in hxc_bitmap.  Used during init to flip the
 * default-all-set state. */
fn hxc_bitmap_set(packed: u64) -> u64 {
    if packed >= 729 {
        return 1
    }
    let word_idx: u64 = packed / 64
    let bit_pos:  u64 = packed % 64
    let mask:     u64 = 1 << bit_pos
    hxc_bitmap[word_idx] = hxc_bitmap[word_idx] | mask
    return 0
}

fn hxc_bitmap_clear(packed: u64) -> u64 {
    if packed >= 729 {
        return 1
    }
    let word_idx: u64 = packed / 64
    let bit_pos:  u64 = packed % 64
    let mask:     u64 = 1 << bit_pos
    let inv:      u64 = ~mask
    hxc_bitmap[word_idx] = hxc_bitmap[word_idx] & inv
    return 0
}

/* Initialise: set all 729 bits, then clear the six PFS bricking
 * hexads.  Mirrors TYPES/src/hexad.c::bitmap_init exactly so the
 * eventual SHA-256 produces an identical digest (when the byte
 * layout is canonicalised to 144 bytes). */
fn iii_hxc_init() -> u64 {
    /* Set all 729 bits.  Word 0..10: full set (64 bits each = 704).
     * Word 11: low 25 bits set (704 + 25 = 729). */
    let mut i: u64 = 0
    while i < 11 {
        hxc_bitmap[i] = 0xFFFFFFFFFFFFFFFF
        i = i + 1
    }
    /* Word 11: bits 0..24 set, bits 25..63 clear.  Computed as
     * 0x1FFFFFF (the parser's hexad-detection heuristic mistakes
     * `(1 << 25) - 1` for a hexad-literal start; using the hex form
     * sidesteps the ambiguity until the parser gains 2-token peek). */
    hxc_bitmap[11] = 0x1FFFFFF
    /* Clear the six PFS bricks.  Pillar layouts (P0 P1 P2 P3 P4 P5):
     *   capsule_update    (NEG, NEG, NEG, NEG, ZERO, ZERO)
     *   microcode_load    (NEG, NEG, NEG, ZERO, ZERO, ZERO)
     *   bootorder_set     (NEG, NEG, ZERO, NEG, ZERO, ZERO)
     *   real_nvram_write  (NEG, ZERO, NEG, NEG, ZERO, ZERO)
     *   me_psp_mailbox    (ZERO, NEG, NEG, NEG, ZERO, ZERO)
     *   smram_write       (NEG, NEG, NEG, NEG, NEG, ZERO)
     */
    hxc_bitmap_clear(hxc_pack(0, 0, 0, 0, 1, 1))    /* capsule_update */
    hxc_bitmap_clear(hxc_pack(0, 0, 0, 1, 1, 1))    /* microcode_load */
    hxc_bitmap_clear(hxc_pack(0, 0, 1, 0, 1, 1))    /* bootorder_set */
    hxc_bitmap_clear(hxc_pack(0, 1, 0, 0, 1, 1))    /* real_nvram_write */
    hxc_bitmap_clear(hxc_pack(1, 0, 0, 0, 1, 1))    /* me_psp_mailbox */
    hxc_bitmap_clear(hxc_pack(0, 0, 0, 0, 0, 1))    /* smram_write */
    hxc_init = 1
    return 0
}

/* Count of admitted bits — should be 729 - 6 = 723 after init.
 *
 * IMPORTANT iii grammar discipline: loop-temporaries must be declared
 * OUTSIDE the loop body and ASSIGNED inside.  Stage-1 cg_r3 implements
 * `let` as "always allocate a fresh stack slot"; combined with the
 * "first match wins" identifier resolution, a `let` inside a loop body
 * becomes invisible to subsequent reads (they keep finding the
 * outer/first slot, which has a stale value).  Stage-2+ may add
 * proper scope marking; until then, the convention is: `let mut w`
 * once outside, then `w = ...` inside. */
fn iii_hxc_count_admitted() -> u64 {
    if hxc_init == 0 {
        return 0
    }
    let mut total: u64 = 0
    let mut i: u64 = 0
    let mut w: u64 = 0
    while i < 12 {
        w = hxc_bitmap[i]
        while w > 0 {
            total = total + (w & 1)
            w = w >> 1
        }
        i = i + 1
    }
    return total
}

/* Test driver — encodes findings in the exit code.
 *   bit 0:  POS-uniform (POS,POS,POS,POS,POS,POS) admitted
 *   bit 1:  POS-ZERO     (POS,ZERO,POS,ZERO,POS,ZERO) admitted
 *   bit 2:  ZERO-uniform admitted
 *   bit 3:  capsule_update REJECTED
 *   bit 4:  smram_write   REJECTED
 *   bit 5:  count_admitted == 723  (post-init, 729 minus 6 bricks)
 *   bit 6:  trit_compose(NEG, POS) == NEG
 *   bit 7:  trit_neg(POS) == NEG
 * Pass = exit 255 (0xFF).
 */
fn main() -> u64 {
    iii_hxc_init()
    let mut score: u64 = 0
    /* Admitted (POS-uniform: hexad encoded as 2,2,2,2,2,2) */
    let pos_uniform: u64 = hxc_pack(2, 2, 2, 2, 2, 2)
    if iii_hxc_packed_admitted(pos_uniform) == 1 {
        score = score | 1
    }
    let pos_zero: u64 = hxc_pack(2, 1, 2, 1, 2, 1)
    if iii_hxc_packed_admitted(pos_zero) == 1 {
        score = score | 2
    }
    let zero_uniform: u64 = hxc_pack(1, 1, 1, 1, 1, 1)
    if iii_hxc_packed_admitted(zero_uniform) == 1 {
        score = score | 4
    }
    let capsule: u64 = hxc_pack(0, 0, 0, 0, 1, 1)
    if iii_hxc_packed_admitted(capsule) == 0 {
        score = score | 8
    }
    let smram: u64 = hxc_pack(0, 0, 0, 0, 0, 1)
    if iii_hxc_packed_admitted(smram) == 0 {
        score = score | 16
    }
    /* Diagnose count: return the count itself so we can read it
     * via exit code (low byte).  Comment-out once verified. */
    let actual: u64 = iii_hxc_count_admitted()
    if actual == 723 {
        score = score | 32
    }
    /* For debugging: uncomment to dump the count instead of score.
     * return actual */
    if hxc_trit_compose(0, 2) == 0 {
        score = score | 64
    }
    if hxc_trit_neg(2) == 0 {
        score = score | 128
    }
    return score
}
