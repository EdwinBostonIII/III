         /* §6 — Types */
         III_AST_TYPE                            = 40,
         III_AST_BASE_TYPE                       = 41,
         III_AST_PRIMITIVE_TYPE                  = 42,
         III_AST_FUNCTION_TYPE                   = 43,
         III_AST_TUPLE_TYPE                      = 44,
         III_AST_ARRAY_TYPE                      = 45,
         III_AST_GENERIC_ARGS                    = 46,
