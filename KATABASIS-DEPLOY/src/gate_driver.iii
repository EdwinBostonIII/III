module gate_driver

/* KATABASIS Tier-3: the R3-INVOKABLE gate. A standing kernel driver that exposes the full
   gate DECISION to user mode over DeviceIoControl. driver_entry creates \Device\IIIKatabasisGate
   + the \??\IIIKatabasisGate symlink (so R3 opens \\.\IIIKatabasisGate), installs IRP_MJ_CREATE/
   CLOSE/DEVICE_CONTROL handlers + DriverUnload into the DRIVER_OBJECT, and returns STATUS_SUCCESS
   so the driver STAYS RESIDENT (unlike the Tier-2 selftest which self-unloaded).

   IOCTL_KATABASIS_ADMIT = CTL_CODE(FILE_DEVICE_UNKNOWN, 0x800, METHOD_BUFFERED, FILE_ANY_ACCESS)
                         = 0x222000. Input/Output share the METHOD_BUFFERED SystemBuffer.
   Input  (6 x u64): [0]=family [1]=target_kind [2]=target [3]=action_hexad [4]=cap_rights
                     [5]=seal_mode (0=seal the cycle correctly; 1=claim a DIFFERENT cycle's seal).
   Output (1 x u64): [0]=verdict (0=OK 1=REJECT_SEAL 2=REJECT_CAP 3=REJECT_HEXAD).
   The kernel builds the cycle in the xii_term arena, seals it (scalar SHA/keccak -- forced), and
   runs katabasis_gate_admit; the seal never leaves the kernel (R3 cannot reproduce cg_r0's
   self-consistent hash), so R3 drives verdicts via the cycle params + seal_mode, not by supplying
   a seal. This is the gate decision, exactly as Tier-2 proved on metal, now queryable from R3. */

/* --- ntoskrnl marshalling shims (KATABASIS-DEPLOY/src/kernel_abi.s; aligned, ABI-correct) --- */
extern @abi(c-msvc-x64) fn iii_kio_create_device(drv: u64, out: u64) -> u64 from "kernel_abi.s"
extern @abi(c-msvc-x64) fn iii_kio_create_symlink() -> u64 from "kernel_abi.s"
extern @abi(c-msvc-x64) fn iii_kio_complete_request(irp: u64, boost: u64) -> u64 from "kernel_abi.s"
extern @abi(c-msvc-x64) fn iii_kio_delete_device(dev: u64) -> u64 from "kernel_abi.s"
extern @abi(c-msvc-x64) fn iii_kio_delete_symlink() -> u64 from "kernel_abi.s"
extern @abi(c-msvc-x64) fn iii_kio_cpuid(leaf: u32, subleaf: u32, out4: u64) -> u64 from "kernel_abi.s"
extern @abi(c-msvc-x64) fn iii_kio_readmsr(msr: u32) -> u64 from "kernel_abi.s"
extern @abi(c-msvc-x64) fn iii_kio_pci_cfg_read(cf8_addr: u32) -> u32 from "kernel_abi.s"

/* --- PCI config-space DERIVATION (the live deriver for census's GPU facts; pure decoders @ katabasis/pci_enum) --- */
extern @abi(c-msvc-x64) fn pci_vendor(dw0: u32) -> u32 from "pci_enum.iii"
extern @abi(c-msvc-x64) fn pci_device(dw0: u32) -> u32 from "pci_enum.iii"
extern @abi(c-msvc-x64) fn pci_present(dw0: u32) -> u8 from "pci_enum.iii"
extern @abi(c-msvc-x64) fn pci_class(dw2: u32) -> u32 from "pci_enum.iii"
extern @abi(c-msvc-x64) fn pci_rev(dw2: u32) -> u32 from "pci_enum.iii"
extern @abi(c-msvc-x64) fn pci_bar_base32(bar: u32) -> u64 from "pci_enum.iii"
extern @abi(c-msvc-x64) fn pci_bar_base64(lo: u32, hi: u32) -> u64 from "pci_enum.iii"

/* --- the gate-admit closure (same modules as the Tier-2 resident gate) --- */
extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent_id: u64, rights_mask: u64, expires_at: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn katabasis_cycle_act(family: u32, target_kind: u32, target: u64, action_hexad: u32) -> u32 from "cycle_term.iii"
extern @abi(c-msvc-x64) fn katabasis_cycle_under_cap(act_idx: u32, cap_id: u32) -> u32 from "cycle_term.iii"
extern @abi(c-msvc-x64) fn katabasis_cycle_seal(cycle_idx: u32, out_addr: u64) -> i32 from "seal.iii"
extern @abi(c-msvc-x64) fn katabasis_gate_admit(cycle_idx: u32, claimed_seal_addr: u64) -> u32 from "admit.iii"
extern @abi(c-msvc-x64) fn sha256_sched_force(p: u32) -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn keccak_chi_force_path(p: u32) -> i32 from "keccak.iii"
/* M23 / capability 11: the below-OS behavioral quine-seal (the gate attests ITSELF). */
extern @abi(c-msvc-x64) fn ks_engine_ok() -> u8 from "quine_seal.iii"
extern @abi(c-msvc-x64) fn ks_self_measure(image_base: u64, out: u64) -> i32 from "quine_seal.iii"

/* --- driver state --- */
var G_DEVOBJ : [u64; 1]    /* the created PDEVICE_OBJECT (for DriverUnload) */
var G_SEAL   : [u8; 32]
var G_WRONG  : [u8; 32]
var G_CPUID  : [u64; 2]    /* I0 scratch: 4 packed u32 from CPUID (shim writes; read as 2 u64) */
var G_ATTEST : [u64; 4]    /* M23: the below-OS quine-seal measurement of my OWN .text, taken at load */

/* --- WDM struct accessors (x64 offsets; cg_r0 is 8-byte-uniform so index = byteoff/8) --- */
fn wdm_current_stack(irp: u64) -> u64 { return (irp as *u64)[23u64] }              /* IRP.Tail.Overlay.CurrentStackLocation @0xB8 */
fn wdm_ioctl_code(stk: u64) -> u32 { return ((stk as *u64)[3u64] & 0xFFFFFFFFu64) as u32 } /* IO_STACK.Parameters.DeviceIoControl.IoControlCode @0x18 */
fn wdm_out_len(stk: u64) -> u64 { return (stk as *u64)[1u64] & 0xFFFFFFFFu64 }     /* Parameters.DeviceIoControl.OutputBufferLength @0x08 */
fn wdm_in_len(stk: u64) -> u64 { return (stk as *u64)[2u64] & 0xFFFFFFFFu64 }      /* Parameters.DeviceIoControl.InputBufferLength  @0x10 */
fn wdm_system_buffer(irp: u64) -> u64 { return (irp as *u64)[3u64] }               /* IRP.AssociatedIrp.SystemBuffer @0x18 */
fn wdm_set_status(irp: u64, status: u64, info: u64) -> i32 {
    (irp as *u64)[6u64] = status                                                   /* IRP.IoStatus.Status @0x30 */
    (irp as *u64)[7u64] = info                                                     /* IRP.IoStatus.Information @0x38 */
    return 0i32
}

/* --- IRP_MJ_CREATE / IRP_MJ_CLOSE: succeed immediately --- */
fn gate_create(device_object: u64, irp: u64) -> u64 {
    wdm_set_status(irp, 0u64, 0u64)
    iii_kio_complete_request(irp, 0u64)
    return 0u64
}
fn gate_close(device_object: u64, irp: u64) -> u64 {
    wdm_set_status(irp, 0u64, 0u64)
    iii_kio_complete_request(irp, 0u64)
    return 0u64
}

/* [BSOD/OOB] METHOD_BUFFERED SystemBuffer validator for gate_ioctl.  Returns `code` when buf is non-NULL
   and the lengths meet that IOCTL's footprint; 0 when a KNOWN IOCTL is called with a NULL/short buffer
   (gate_ioctl rejects with STATUS_BUFFER_TOO_SMALL, buffer untouched).  Unknown codes pass through.
   ADMIT(0x222000): in 6 x u64 = 48, out 1 x u64 = 8.  PROBE(0x222004): out 4 x u64 = 32, no input.
   need_out/need_in held HERE, off gate_ioctl's local budget (cg_r0 per-function ceiling). */
fn gate_validated_code(stk: u64, buf: u64, code: u32) -> u32 {
    let mut need_out : u64 = 0u64
    let mut need_in  : u64 = 0u64
    if code == 0x222000u32 { need_out = 8u64 ; need_in = 48u64 }
    if code == 0x222004u32 { need_out = 32u64 }
    if code == 0x222008u32 { need_out = 32u64 }      /* IOCTL_ATTEST: 32-byte measurement out, no input */
    if code == 0x22200Cu32 { need_out = 56u64 }      /* IOCTL_PCI_ENUM: 7 x u64 derived GPU facts, no input */
    if need_out == 0u64 { return code }              /* unknown code: pass through, matches no branch */
    if buf == 0u64 { return 0u32 }
    if wdm_out_len(stk) < need_out { return 0u32 }
    if wdm_in_len(stk) < need_in { return 0u32 }
    return code
}

/* IOCTL_ATTEST report (factored OUT of gate_ioctl to stay under cg_r0's per-function ceiling, like
   gate_validated_code): copy the 32-byte below-OS quine-seal measurement (taken at load) to the
   METHOD_BUFFERED SystemBuffer.  Read-only; the challenger compares it to the independently-built seed. */
fn gate_attest_report(buf: u64) -> i32 {
    let b : u64 = buf
    (b as *u64)[0u64] = G_ATTEST[0u64]
    (b as *u64)[1u64] = G_ATTEST[1u64]
    (b as *u64)[2u64] = G_ATTEST[2u64]
    (b as *u64)[3u64] = G_ATTEST[3u64]
    return 0i32
}

/* M23 self-attestation, factored OUT of driver_entry (cg_r0 per-function ceiling).  FAIL-CLOSED on a
   broken sealer (returns STATUS_UNSUCCESSFUL); else measure my own running .text into G_ATTEST and
   return 0.  driver_entry refuses residency on a nonzero return. */
fn gate_self_attest(driver_object: u64) -> u64 {
    let dobj : u64 = driver_object
    if ks_engine_ok() != 1u8 { return 0xC0000001u64 }       /* STATUS_UNSUCCESSFUL */
    let ibase : u64 = (dobj as *u64)[3u64]                  /* DRIVER_OBJECT.DriverStart @0x18 = ASLR load base */
    ks_self_measure(ibase, &G_ATTEST as u64)
    return 0u64
}

/* --- IOCTL_PCI_ENUM (read-only): DERIVE census's GPU facts from live PCI config space via CF8h/CFCh ---
   bdf packs bus<<16 | dev<<11 | fn<<8 (doubles as the CF8 low bits AND census fact 11).  Helpers are factored +
   flag-driven (no break) + <=2 params for cg_r0; decoded by katabasis/pci_enum's PURE decoders on single dwords
   (no packed buffer -> sidesteps cg_r0's 8-byte-uniform arrays).  All reads non-destructive; absent slot = all-ones. */
fn pci_cfg(bdf: u32, off: u32) -> u32 {
    return iii_kio_pci_cfg_read(0x80000000u32 | bdf | (off & 0xFCu32))
}
fn pci_probe_at(bdf: u32) -> u8 {
    let dw0 : u32 = pci_cfg(bdf, 0u32)
    if pci_present(dw0) != 1u8 { return 0u8 }
    let dw2 : u32 = pci_cfg(bdf, 8u32)
    if pci_class(dw2) != 0x03u32 { return 0u8 }       /* display controller */
    return 1u8
}
fn pci_scan_bus(bus: u32) -> u32 {
    let mut found : u32 = 0xFFFFFFFFu32
    let mut dev : u32 = 0u32
    while dev < 32u32 {
        if found == 0xFFFFFFFFu32 {
            let mut fnum : u32 = 0u32
            while fnum < 8u32 {
                if found == 0xFFFFFFFFu32 {
                    let bdf : u32 = (bus << 16u32) | (dev << 11u32) | (fnum << 8u32)
                    if pci_probe_at(bdf) == 1u8 { found = bdf }
                }
                fnum = fnum + 1u32
            }
        }
        dev = dev + 1u32
    }
    return found
}
fn pci_find_gpu_bdf() -> u32 {
    let mut found : u32 = 0xFFFFFFFFu32
    let mut bus : u32 = 0u32
    while bus < 256u32 {
        if found == 0xFFFFFFFFu32 {
            let r : u32 = pci_scan_bus(bus)
            if r != 0xFFFFFFFFu32 { found = r }
        }
        bus = bus + 1u32
    }
    return found
}
/* write the found GPU's DERIVED facts to the METHOD_BUFFERED output (7 x u64): [0]=found [1]=vendev [2]=rev
   [3]=BAR0 [4]=BAR1 [5]=BAR3 [6]=bdf. */
fn pci_report(bdf: u32, buf: u64) -> i32 {
    let b : u64 = buf
    let dw0 : u32 = pci_cfg(bdf, 0u32)
    let dw2 : u32 = pci_cfg(bdf, 8u32)
    (b as *u64)[0u64] = 1u64
    (b as *u64)[1u64] = ((pci_vendor(dw0) as u64) << 16u64) | (pci_device(dw0) as u64)
    (b as *u64)[2u64] = pci_rev(dw2) as u64
    (b as *u64)[3u64] = pci_bar_base32(pci_cfg(bdf, 16u32))
    (b as *u64)[4u64] = pci_bar_base64(pci_cfg(bdf, 20u32), pci_cfg(bdf, 24u32))
    (b as *u64)[5u64] = pci_bar_base64(pci_cfg(bdf, 28u32), pci_cfg(bdf, 32u32))
    (b as *u64)[6u64] = bdf as u64
    return 0i32
}

/* --- IRP_MJ_DEVICE_CONTROL: the gate decision --- */
fn gate_ioctl(device_object: u64, irp: u64) -> u64 {
    let stk  : u64 = wdm_current_stack(irp)
    let buf  : u64 = wdm_system_buffer(irp)
    let mut status : u64 = 0xC0000010u64   /* STATUS_INVALID_DEVICE_REQUEST */
    let mut info   : u64 = 0u64
    /* [BSOD/OOB] validate the METHOD_BUFFERED SystemBuffer in gate_validated_code (its need table lives
       off gate_ioctl's local budget -- cg_r0 per-function ceiling) BEFORE any branch reads/writes `buf`:
       a user-mode 0/short-buffer request yields a NULL or undersized SystemBuffer, and the admit branch
       reads 6 x u64 + writes 1 x u64 -> a trivially user-triggerable kernel NULL-deref / pool OOB (the
       output write could also leak uninitialised pool).  code2==0 => known IOCTL with a NULL/short
       buffer (reject untouched); an unknown code passes through to no branch -> INVALID_DEVICE_REQUEST. */
    let code2 : u32 = gate_validated_code(stk, buf, wdm_ioctl_code(stk))
    if code2 == 0u32 { status = 0xC0000023u64 }
    if code2 == 0x222000u32 {
        let family : u32 = (buf as *u64)[0u64] as u32
        let tk     : u32 = (buf as *u64)[1u64] as u32
        let tgt    : u64 = (buf as *u64)[2u64]
        let ah     : u32 = (buf as *u64)[3u64] as u32
        let crts   : u64 = (buf as *u64)[4u64]
        let smode  : u64 = (buf as *u64)[5u64]
        xii_term_arena_reset()
        let root : u64 = cap_env_init()
        let cap  : u64 = cap_attenuate(root, crts, 0u64)
        let a    : u32 = katabasis_cycle_act(family, tk, tgt, ah)
        let c    : u32 = katabasis_cycle_under_cap(a, cap as u32)
        katabasis_cycle_seal(c, &G_SEAL as u64)
        let mut seal_addr : u64 = &G_SEAL as u64
        if smode == 1u64 {
            let a2 : u32 = katabasis_cycle_act(9u32, 2u32, 0xFB000000u64, 728u32)
            let c2 : u32 = katabasis_cycle_under_cap(a2, cap as u32)
            katabasis_cycle_seal(c2, &G_WRONG as u64)
            seal_addr = &G_WRONG as u64
        }
        let verdict : u32 = katabasis_gate_admit(c, seal_addr)
        (buf as *u64)[0u64] = verdict as u64
        status = 0u64
        info   = 8u64
    }
    if code2 == 0x222004u32 {
        /* IOCTL_SVM_PROBE (Ring-1 I0, READ-ONLY): report SVM capability. No SVM enable, no VMRUN.
           VM_CR (AMD-only) is read ONLY when CPUID(0x80000001).ECX[2]=SVM is set (a bit Intel never
           sets) -> RDMSR cannot #GP. EFER is universal. out: [0]=svm_avail [1]=efer [2]=vm_cr [3]=ecx. */
        iii_kio_cpuid(0x80000001u32, 0u32, &G_CPUID as u64)
        let ecx80     : u64 = G_CPUID[1u64] & 0xFFFFFFFFu64
        let svm_avail : u64 = (ecx80 >> 2u64) & 1u64
        let efer      : u64 = iii_kio_readmsr(0xC0000080u32)
        let mut vmcr  : u64 = 0u64
        if svm_avail == 1u64 { vmcr = iii_kio_readmsr(0xC0010114u32) }
        (buf as *u64)[0u64] = svm_avail
        (buf as *u64)[1u64] = efer
        (buf as *u64)[2u64] = vmcr
        (buf as *u64)[3u64] = ecx80
        status = 0u64
        info   = 32u64
    }
    if code2 == 0x222008u32 {
        /* IOCTL_ATTEST (capability 11): report the below-OS quine-seal -- the measurement of my OWN
           running .text, taken at load in driver_entry.  attest-by-report: the anchor is EXTERNAL (the
           challenger holds cad(.text) built independently), so a tampered self cannot forge a match. */
        gate_attest_report(buf)
        status = 0u64
        info   = 32u64
    }
    if code2 == 0x22200Cu32 {
        /* IOCTL_PCI_ENUM (READ-ONLY): scan PCI config space (CF8h/CFCh) for the display controller and DERIVE
           its facts (VEN/DEV, rev, BAR0/1/3, bus:dev:fn).  No device writes -- the OUT to 0xCF8 only selects a
           register.  out (7 x u64): [0]=found [1]=vendev [2]=rev [3]=BAR0 [4]=BAR1 [5]=BAR3 [6]=bdf. */
        let bdf : u32 = pci_find_gpu_bdf()
        (buf as *u64)[0u64] = 0u64                    /* default: not found */
        if bdf != 0xFFFFFFFFu32 { pci_report(bdf, buf) }
        status = 0u64
        info   = 56u64
    }
    wdm_set_status(irp, status, info)
    iii_kio_complete_request(irp, 0u64)
    return status
}

/* --- DriverUnload: tear down symlink + device (installed at DRIVER_OBJECT+0x68) --- */
fn gate_unload(driver_object: u64) -> u64 {
    iii_kio_delete_symlink()
    iii_kio_delete_device(G_DEVOBJ[0u64])
    return 0u64
}

/* --- DriverEntry: create device, install dispatch + unload, create symlink, stay resident --- */
fn driver_entry(driver_object: u64, registry_path: u64) -> u64 {
    sha256_sched_force(1u32)
    keccak_chi_force_path(1u32)
    /* M23 / capability 11 -- the BELOW-OS behavioral quine-seal.  FAIL-CLOSED: refuse to go resident
       if the sealed hasher does not compute the FIPS-180-2 vector at Ring 0 (a broken/miscompiled
       sealer is an incoherent self -- "refuse to ship or run an incoherent self", capability 1, at the
       metal).  Then measure my OWN running .text (relocation-free => byte-identical on disk and in
       memory every load AND bound to the executing code) and cache it for IOCTL_ATTEST, so a challenger
       compares it to the independently-built seed -- "I am exactly this source and executed behavior". */
    let att : u64 = gate_self_attest(driver_object)
    if att != 0u64 { return att }                           /* STATUS_UNSUCCESSFUL -> the driver does NOT load (fail-closed) */
    iii_kio_create_device(driver_object, &G_DEVOBJ as u64)
    (driver_object as *u64)[13u64] = &gate_unload as u64   /* DRIVER_OBJECT.DriverUnload @0x68 */
    (driver_object as *u64)[14u64] = &gate_create as u64   /* MajorFunction[IRP_MJ_CREATE=0] @0x70 */
    (driver_object as *u64)[16u64] = &gate_close as u64    /* MajorFunction[IRP_MJ_CLOSE=2] @0x80 */
    (driver_object as *u64)[28u64] = &gate_ioctl as u64    /* MajorFunction[IRP_MJ_DEVICE_CONTROL=14] @0xE0 */
    iii_kio_create_symlink()
    return 0u64    /* STATUS_SUCCESS -> resident */
}
