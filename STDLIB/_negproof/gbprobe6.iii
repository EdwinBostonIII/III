module gbprobe6
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn gb_init(nvars: u32) -> i32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_begin(arena: u64, p: u64) -> i32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_new_poly() -> u32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_append_term(slot: u32, coeff_bid: u64, exps: *u32) -> i32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_normalize(slot: u32) -> i32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_spoly(f: u32, g: u32) -> u32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_reduce(target: u32, basis: *u32, basis_n: u32) -> u32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_make_monic(slot: u32) -> i32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_lead_coeff(slot: u32) -> u64 from "groebner.iii"
extern @abi(c-msvc-x64) fn bigint_to_u64_lo(id: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn gb_lead_exp(slot: u32, out_exps: *u32) -> i32 from "groebner.iii"

var GP_EXPS : [u32; 4]
var GP_GENS : [u32; 8]
var GP_LE   : [u32; 4]

fn gp_gen(arena: u64, l0: u32, l1: u32) -> u32 {
    let s : u32 = gb_new_poly()
    GP_EXPS[0u64] = l0  GP_EXPS[1u64] = l1
    gb_append_term(s, bigint_from_u64(arena, 1u64), (&GP_EXPS as u64) as *u32)
    GP_EXPS[0u64] = 0u32  GP_EXPS[1u64] = 0u32
    gb_append_term(s, bigint_from_u64(arena, 1u64), (&GP_EXPS as u64) as *u32)
    gb_normalize(s)
    return s
}

fn main() -> u64 {
    let arena : u64 = arena_new(1u64 << 22u64)
    gb_init(2u32)
    gb_begin(arena, 7u64)
    let f0 : u32 = gp_gen(arena, 1u32, 1u32)
    let f1 : u32 = gp_gen(arena, 2u32, 1u32)
    GP_GENS[0u64] = f0
    GP_GENS[1u64] = f1
    let s : u32 = gb_spoly(f0, f1)
    if s == 0xFFFFFFFFu32 { return 10u64 }
    let r : u32 = gb_reduce(s, (&GP_GENS as u64) as *u32, 2u32)
    if r == 0xFFFFFFFFu32 { return 20u64 }
    if gb_lead_exp(r, (&GP_LE as u64) as *u32) != 0i32 { return 30u64 }
    let mrc : i32 = gb_make_monic(r)
    if mrc != 0i32 { return (40i64 - (mrc as i64)) as u64 }
    /* report: lead exps + lead coeff value packed */
    let lc : u64 = bigint_to_u64_lo(gb_lead_coeff(r))
    return 100u64 + (GP_LE[0u64] as u64) * 25u64 + (GP_LE[1u64] as u64) * 5u64 + lc
}
