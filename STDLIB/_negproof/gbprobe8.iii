module gbprobe8
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_to_u64_lo(id: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn gb_init(nvars: u32) -> i32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_begin(arena: u64, p: u64) -> i32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_new_poly() -> u32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_append_term(slot: u32, coeff_bid: u64, exps: *u32) -> i32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_normalize(slot: u32) -> i32 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_lead_coeff(slot: u32) -> u64 from "groebner.iii"
extern @abi(c-msvc-x64) fn gb_lead_exp(slot: u32, out_exps: *u32) -> i32 from "groebner.iii"

var GP_EXPS : [u32; 4]
var GP_LE   : [u32; 4]

fn main() -> u64 {
    let arena : u64 = arena_new(1u64 << 22u64)
    if gb_init(2u32) != 0i32 { return 1u64 }
    if gb_begin(arena, 7u64) != 0i32 { return 2u64 }
    let s : u32 = gb_new_poly()
    if s == 0xFFFFFFFFu32 { return 3u64 }
    GP_EXPS[0u64] = 1u32  GP_EXPS[1u64] = 0u32
    let c1 : u64 = bigint_from_u64(arena, 1u64)
    if c1 == 0u64 { return 4u64 }
    let rc1 : i32 = gb_append_term(s, c1, (&GP_EXPS as u64) as *u32)
    if rc1 != 0i32 { return (10i64 - (rc1 as i64)) as u64 }
    GP_EXPS[0u64] = 0u32  GP_EXPS[1u64] = 0u32
    let c2 : u64 = bigint_from_u64(arena, 6u64)
    let rc2 : i32 = gb_append_term(s, c2, (&GP_EXPS as u64) as *u32)
    if rc2 != 0i32 { return (20i64 - (rc2 as i64)) as u64 }
    if gb_normalize(s) != 0i32 { return 30u64 }
    let lc : u64 = gb_lead_coeff(s)
    if lc == 0u64 { return 31u64 }
    if gb_lead_exp(s, (&GP_LE as u64) as *u32) != 0i32 { return 32u64 }
    return 100u64 + (GP_LE[0u64] as u64) * 20u64 + (GP_LE[1u64] as u64) * 4u64 + bigint_to_u64_lo(lc)
}
