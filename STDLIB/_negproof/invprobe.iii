module invprobe
extern @abi(c-msvc-x64) fn fz_decode(src: u64, dst: u64) -> i32 from "fe25519.iii"
extern @abi(c-msvc-x64) fn fz_encode(src: u64, dst: u64) -> i32 from "fe25519.iii"
extern @abi(c-msvc-x64) fn fz_mul(a: u64, b: u64, r: u64) -> i32 from "fe25519.iii"
extern @abi(c-msvc-x64) fn fz_invert(a: u64, r: u64) -> i32 from "fe25519.iii"

var IB : [u8; 32]
var IA : [u64; 8]
var IR : [u64; 8]
var IP : [u64; 8]
var IE : [u8; 32]

fn main() -> u64 {
    let mut i : u64 = 0u64
    while i < 32u64 { IB[i] = 0u8  i = i + 1u64 }
    IB[0u64] = 0x35u8
    IB[7u64] = 0xA1u8
    fz_decode(&IB as u64, &IA as u64)
    fz_invert(&IA as u64, &IR as u64)
    fz_mul(&IA as u64, &IR as u64, &IP as u64)
    fz_encode(&IP as u64, &IE as u64)
    let mut bad : u64 = 0u64
    i = 1u64
    while i < 32u64 { if IE[i] != 0u8 { bad = 1u64 }  i = i + 1u64 }
    if IE[0u64] != 1u8 { bad = bad + 2u64 }
    return 50u64 + bad + (IE[0u64] as u64) * 100u64
}
