module ecpk_probe
extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn ed25519_pubkey(seed: *u8, out_pk: *u8) -> u8 from "crypt_ed25519.iii"
fn main() -> u64 {
    let s : *u8 = malloc(32u64)
    let pk : *u8 = malloc(32u64)
    s[0]=0x9Du8 s[1]=0x61u8 s[2]=0xB1u8 s[3]=0x9Du8 s[4]=0xEFu8 s[5]=0xFDu8 s[6]=0x5Au8 s[7]=0x60u8
    s[8]=0xBAu8 s[9]=0x84u8 s[10]=0x4Au8 s[11]=0xF4u8 s[12]=0x92u8 s[13]=0xECu8 s[14]=0x2Cu8 s[15]=0xC4u8
    s[16]=0x44u8 s[17]=0x49u8 s[18]=0xC5u8 s[19]=0x69u8 s[20]=0x7Bu8 s[21]=0x32u8 s[22]=0x69u8 s[23]=0x19u8
    s[24]=0x70u8 s[25]=0x3Bu8 s[26]=0xACu8 s[27]=0x03u8 s[28]=0x1Cu8 s[29]=0xAEu8 s[30]=0x7Fu8 s[31]=0x60u8
    if ed25519_pubkey(s, pk) != 1u8 { return 1u64 }
    if pk[0] != 0xD7u8 { return 2u64 }
    if pk[1] != 0x5Au8 { return 3u64 }
    if pk[2] != 0x98u8 { return 4u64 }
    if pk[31] != 0x1Au8 { return 5u64 }
    return 99u64
}
