/* TDD probe for the fixed-size fe25519 field (radix 2^32, 8 limbs, allocation-free).
 * Pointer-based reentrant ops; KAT'd against independent Python vectors.
 * exit 99 = fe_mul x3 + fe_add + fe_sub + fe_sq + fe_invert all match. */
module fe25519_test

var FE_T   : [u64; 16]
var FE_S   : [u64; 9]
var FE_P   : [u64; 8]
var FE_2P  : [u64; 8]
var FE_PM2 : [u8; 32]
var FE_ACC : [u64; 8]
var FE_TMP : [u64; 8]
var BA     : [u64; 8]
var BB     : [u64; 8]
var BR     : [u64; 8]
var TA     : [u8; 32]
var TB     : [u8; 32]
var TE     : [u8; 32]
var TOUT   : [u8; 32]

fn fe_copy(src: u64, dst: u64) -> i32 {
    let sp : *u64 = src as *u64
    let dp : *u64 = dst as *u64
    let mut k : u64 = 0u64
    while k < 8u64 { dp[k] = sp[k]  k = k + 1u64 }
    return 0i32
}
fn fe_decode(src: u64, dst: u64) -> i32 {
    let sp : *u8 = src as *u8
    let dp : *u64 = dst as *u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        let b0 : u64 = sp[k * 4u64] as u64
        let b1 : u64 = sp[k * 4u64 + 1u64] as u64
        let b2 : u64 = sp[k * 4u64 + 2u64] as u64
        let b3 : u64 = sp[k * 4u64 + 3u64] as u64
        dp[k] = b0 | (b1 << 8u64) | (b2 << 16u64) | (b3 << 24u64)
        k = k + 1u64
    }
    return 0i32
}
fn fe_encode(src: u64, dst: u64) -> i32 {
    let sp : *u64 = src as *u64
    let dp : *u8 = dst as *u8
    let mut k : u64 = 0u64
    while k < 8u64 {
        let v : u64 = sp[k]
        dp[k * 4u64]        = (v & 0xFFu64) as u8
        dp[k * 4u64 + 1u64] = ((v >> 8u64) & 0xFFu64) as u8
        dp[k * 4u64 + 2u64] = ((v >> 16u64) & 0xFFu64) as u8
        dp[k * 4u64 + 3u64] = ((v >> 24u64) & 0xFFu64) as u8
        k = k + 1u64
    }
    return 0i32
}
fn fe_consts() -> i32 {
    FE_P[0u64] = 0xFFFFFFEDu64
    FE_2P[0u64] = 0xFFFFFFDAu64
    let mut k : u64 = 1u64
    while k < 7u64 { FE_P[k] = 0xFFFFFFFFu64  FE_2P[k] = 0xFFFFFFFFu64  k = k + 1u64 }
    FE_P[7u64] = 0x7FFFFFFFu64
    FE_2P[7u64] = 0xFFFFFFFFu64
    return 0i32
}
/* a*b -> r, reduced to < 2^256 (radix 2^32) */
fn fe_mul(a: u64, b: u64, r: u64) -> i32 {
    let ap : *u64 = a as *u64
    let bp : *u64 = b as *u64
    let rp : *u64 = r as *u64
    let mut k : u64 = 0u64
    while k < 16u64 { FE_T[k] = 0u64  k = k + 1u64 }
    k = 0u64
    let mut clo : u64 = 0u64
    while k < 15u64 {
        let mut acc_lo : u64 = clo
        let mut acc_hi : u64 = 0u64
        let mut i : u64 = 0u64
        if k > 7u64 { i = k - 7u64 }
        let mut iend : u64 = k
        if iend > 7u64 { iend = 7u64 }
        while i <= iend {
            let prod : u64 = ap[i] * bp[k - i]
            let tmp : u64 = acc_lo + prod
            if tmp < acc_lo { acc_hi = acc_hi + 1u64 }
            acc_lo = tmp
            i = i + 1u64
        }
        FE_T[k] = acc_lo & 0xFFFFFFFFu64
        clo = (acc_lo >> 32u64) | (acc_hi << 32u64)
        k = k + 1u64
    }
    FE_T[15u64] = clo
    let mut carry : u64 = 0u64
    k = 0u64
    while k < 8u64 {
        let acc : u64 = FE_T[k] + 38u64 * FE_T[k + 8u64] + carry
        rp[k] = acc & 0xFFFFFFFFu64
        carry = acc >> 32u64
        k = k + 1u64
    }
    let mut extra : u64 = 38u64 * carry
    k = 0u64
    while k < 8u64 {
        let acc : u64 = rp[k] + extra
        rp[k] = acc & 0xFFFFFFFFu64
        extra = acc >> 32u64
        k = k + 1u64
    }
    extra = 38u64 * extra
    k = 0u64
    while k < 8u64 {
        let acc : u64 = rp[k] + extra
        rp[k] = acc & 0xFFFFFFFFu64
        extra = acc >> 32u64
        k = k + 1u64
    }
    return 0i32
}
fn fe_sq(a: u64, r: u64) -> i32 { return fe_mul(a, a, r) }
/* a+b -> r */
fn fe_add(a: u64, b: u64, r: u64) -> i32 {
    let ap : *u64 = a as *u64
    let bp : *u64 = b as *u64
    let rp : *u64 = r as *u64
    let mut carry : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        let acc : u64 = ap[k] + bp[k] + carry
        rp[k] = acc & 0xFFFFFFFFu64
        carry = acc >> 32u64
        k = k + 1u64
    }
    let mut extra : u64 = 38u64 * carry
    k = 0u64
    while k < 8u64 {
        let acc : u64 = rp[k] + extra
        rp[k] = acc & 0xFFFFFFFFu64
        extra = acc >> 32u64
        k = k + 1u64
    }
    return 0i32
}
/* a-b -> r  (= a + 2p - b, then fold) */
fn fe_sub(a: u64, b: u64, r: u64) -> i32 {
    let ap : *u64 = a as *u64
    let bp : *u64 = b as *u64
    let rp : *u64 = r as *u64
    /* FE_S = a + 2p  (9 limbs) */
    let mut carry : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        let acc : u64 = ap[k] + FE_2P[k] + carry
        FE_S[k] = acc & 0xFFFFFFFFu64
        carry = acc >> 32u64
        k = k + 1u64
    }
    FE_S[8u64] = carry
    /* FE_S -= b */
    let mut borrow : u64 = 0u64
    k = 0u64
    while k < 8u64 {
        let sub : u64 = bp[k] + borrow
        if FE_S[k] >= sub {
            FE_S[k] = FE_S[k] - sub
            borrow = 0u64
        } else {
            FE_S[k] = (FE_S[k] + 0x100000000u64) - sub
            borrow = 1u64
        }
        k = k + 1u64
    }
    FE_S[8u64] = FE_S[8u64] - borrow
    /* fold FE_S[8] (bits 256+) via 38 */
    let mut c2 : u64 = 38u64 * FE_S[8u64]
    k = 0u64
    while k < 8u64 {
        let acc : u64 = FE_S[k] + c2
        rp[k] = acc & 0xFFFFFFFFu64
        c2 = acc >> 32u64
        k = k + 1u64
    }
    c2 = 38u64 * c2
    k = 0u64
    while k < 8u64 {
        let acc : u64 = rp[k] + c2
        rp[k] = acc & 0xFFFFFFFFu64
        c2 = acc >> 32u64
        k = k + 1u64
    }
    return 0i32
}
fn fe_ge(r: u64, m: u64) -> u8 {
    let rp : *u64 = r as *u64
    let mp : *u64 = m as *u64
    let mut k : u64 = 8u64
    while k > 0u64 {
        let idx : u64 = k - 1u64
        if rp[idx] > mp[idx] { return 1u8 }
        if rp[idx] < mp[idx] { return 0u8 }
        k = k - 1u64
    }
    return 1u8
}
fn fe_subm(r: u64, m: u64) -> i32 {
    let rp : *u64 = r as *u64
    let mp : *u64 = m as *u64
    let mut borrow : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        let sub : u64 = mp[k] + borrow
        if rp[k] >= sub { rp[k] = rp[k] - sub  borrow = 0u64 }
        else { rp[k] = (rp[k] + 0x100000000u64) - sub  borrow = 1u64 }
        k = k + 1u64
    }
    return 0i32
}
fn fe_freeze(r: u64) -> i32 {
    if fe_ge(r, &FE_P as u64) == 1u8 { fe_subm(r, &FE_P as u64) }
    if fe_ge(r, &FE_P as u64) == 1u8 { fe_subm(r, &FE_P as u64) }
    return 0i32
}
/* r = a^(p-2) mod p  (square-and-multiply over FE_PM2 = p-2 LE) */
fn fe_invert(a: u64, r: u64) -> i32 {
    FE_ACC[0u64] = 1u64
    let mut k : u64 = 1u64
    while k < 8u64 { FE_ACC[k] = 0u64  k = k + 1u64 }
    let mut j : u64 = 0u64
    while j < 255u64 {
        let bit_idx : u64 = 254u64 - j
        fe_sq(&FE_ACC as u64, &FE_TMP as u64)
        fe_copy(&FE_TMP as u64, &FE_ACC as u64)
        let byte : u64 = FE_PM2[bit_idx >> 3u64] as u64
        let bit : u64 = (byte >> (bit_idx & 7u64)) & 1u64
        if bit == 1u64 {
            fe_mul(&FE_ACC as u64, a, &FE_TMP as u64)
            fe_copy(&FE_TMP as u64, &FE_ACC as u64)
        }
        j = j + 1u64
    }
    fe_copy(&FE_ACC as u64, r)
    return 0i32
}

fn check_out() -> u8 {
    fe_freeze(&BR as u64)
    fe_encode(&BR as u64, &TOUT as u64)
    let mut k : u64 = 0u64
    while k < 32u64 { if TOUT[k] != TE[k] { return 0u8 }  k = k + 1u64 }
    return 1u8
}
fn clr() -> i32 {
    let mut k : u64 = 0u64
    while k < 32u64 { TA[k] = 0u8  TB[k] = 0u8  TE[k] = 0u8  k = k + 1u64 }
    return 0i32
}
fn hexset(buf: u64, idx: u64, val: u8) -> i32 { let p : *u8 = buf as *u8  p[idx] = val  return 0i32 }

fn main() -> u64 {
    fe_consts()
    /* p-2 LE = eb ff..ff 7f */
    let mut k : u64 = 0u64
    while k < 32u64 { FE_PM2[k] = 0xFFu8  k = k + 1u64 }
    FE_PM2[0u64] = 0xEBu8
    FE_PM2[31u64] = 0x7Fu8

    /* --- fe_mul vec0: 5*7=35 --- */
    clr()  TA[0u64] = 5u8  TB[0u64] = 7u8  TE[0u64] = 35u8
    fe_decode(&TA as u64, &BA as u64)  fe_decode(&TB as u64, &BB as u64)
    fe_mul(&BA as u64, &BB as u64, &BR as u64)
    if check_out() != 1u8 { return 1u64 }
    /* --- fe_mul vec1: (p-1)^2=1 --- */
    k = 0u64  while k < 32u64 { TA[k] = 0xFFu8  TB[k] = 0xFFu8  TE[k] = 0u8  k = k + 1u64 }
    TA[0u64] = 0xECu8  TB[0u64] = 0xECu8  TA[31u64] = 0x7Fu8  TB[31u64] = 0x7Fu8  TE[0u64] = 1u8
    fe_decode(&TA as u64, &BA as u64)  fe_decode(&TB as u64, &BB as u64)
    fe_mul(&BA as u64, &BB as u64, &BR as u64)
    if check_out() != 1u8 { return 2u64 }
    /* --- fe_add: (p-1)+3=2 --- */
    clr()  TE[0u64] = 2u8
    k = 0u64  while k < 32u64 { TA[k] = 0xFFu8  k = k + 1u64 }
    TA[0u64] = 0xECu8  TA[31u64] = 0x7Fu8  TB[0u64] = 3u8
    fe_decode(&TA as u64, &BA as u64)  fe_decode(&TB as u64, &BB as u64)
    fe_add(&BA as u64, &BB as u64, &BR as u64)
    if check_out() != 1u8 { return 4u64 }
    /* --- fe_sub: 3-7 = p-4 = e9 ff..ff 7f --- */
    clr()  TA[0u64] = 3u8  TB[0u64] = 7u8
    k = 0u64  while k < 32u64 { TE[k] = 0xFFu8  k = k + 1u64 }
    TE[0u64] = 0xE9u8  TE[31u64] = 0x7Fu8
    fe_decode(&TA as u64, &BA as u64)  fe_decode(&TB as u64, &BB as u64)
    fe_sub(&BA as u64, &BB as u64, &BR as u64)
    if check_out() != 1u8 { return 5u64 }
    /* --- fe_sq(vec2A) = e8fb96c0...b10e --- */
    clr()
    TA[0u64]=0x67u8 TA[1u64]=0x45u8 TA[2u64]=0x23u8 TA[3u64]=0x01u8 TA[4u64]=0xffu8 TA[5u64]=0xeeu8 TA[6u64]=0xddu8 TA[7u64]=0xccu8
    TA[8u64]=0xbbu8 TA[9u64]=0xaau8 TA[10u64]=0x99u8 TA[11u64]=0x88u8 TA[12u64]=0x77u8 TA[13u64]=0x66u8 TA[14u64]=0x55u8 TA[15u64]=0x44u8
    TA[16u64]=0x33u8 TA[17u64]=0x22u8 TA[18u64]=0x11u8 TA[19u64]=0x00u8 TA[20u64]=0x1fu8 TA[21u64]=0x2eu8 TA[22u64]=0x3du8 TA[23u64]=0x4cu8
    TA[24u64]=0x5au8 TA[25u64]=0x6fu8 TA[26u64]=0x7eu8 TA[27u64]=0x8bu8 TA[28u64]=0x9du8 TA[29u64]=0x1cu8 TA[30u64]=0x3fu8 TA[31u64]=0x2au8
    TE[0u64]=0xe8u8 TE[1u64]=0xfbu8 TE[2u64]=0x96u8 TE[3u64]=0xc0u8 TE[4u64]=0x64u8 TE[5u64]=0xd9u8 TE[6u64]=0x17u8 TE[7u64]=0x1bu8
    TE[8u64]=0xd2u8 TE[9u64]=0x05u8 TE[10u64]=0x1du8 TE[11u64]=0xc0u8 TE[12u64]=0x58u8 TE[13u64]=0xc2u8 TE[14u64]=0x80u8 TE[15u64]=0xa1u8
    TE[16u64]=0x17u8 TE[17u64]=0x93u8 TE[18u64]=0xc9u8 TE[19u64]=0x6cu8 TE[20u64]=0x19u8 TE[21u64]=0x03u8 TE[22u64]=0x35u8 TE[23u64]=0xecu8
    TE[24u64]=0xb7u8 TE[25u64]=0x81u8 TE[26u64]=0x23u8 TE[27u64]=0xecu8 TE[28u64]=0xc4u8 TE[29u64]=0xf0u8 TE[30u64]=0xb1u8 TE[31u64]=0x0eu8
    fe_decode(&TA as u64, &BA as u64)
    fe_sq(&BA as u64, &BR as u64)
    if check_out() != 1u8 { return 6u64 }
    /* --- fe_invert(7): check 7 * inv(7) == 1 --- */
    clr()  TA[0u64] = 7u8
    fe_decode(&TA as u64, &BA as u64)
    fe_invert(&BA as u64, &BB as u64)          /* BB = inv(7) */
    fe_mul(&BA as u64, &BB as u64, &BR as u64) /* 7 * inv(7) */
    TE[0u64] = 1u8
    if check_out() != 1u8 { return 7u64 }
    return 99u64
}
