/* V1 Stage 5 — 4-node HotStuff: WITNESS-RECONCILIATION coordinator (gospel
 * L24444).  A real network partition + heal + reconcile-to-canonical:
 *
 *   Phase 1 (views 1-3, all 4 nodes): commit 3 blocks lockstep -> common head.
 *   Phase 2 (views 4-6): node 3 is PARTITIONED OFF.  The majority {0,1,2}
 *           (= quorum 2f+1=3) commits 3 more blocks; node 3 receives nothing
 *           and its committed head DIVERGES (stays behind canonical).
 *   Phase 3 (heal): the heal driver (aether/hotstuff_heal) RECORDS node 3's
 *           divergence (local head vs canonical) and the operator RESOLVES it
 *           into canonical (V1 = operator review; bisimulation auto-merge is
 *           V3).  Node 3 then catches up by replaying the canonical blocks ->
 *           its head reconciles to canonical.  All four agree again.
 *
 * Exit 99 = real divergence occurred, was recorded+resolved, and node 3
 * reconciled to canonical (all four heads equal).  40 = no divergence (setup),
 * 41 = heal driver bookkeeping wrong, 42 = node 3 failed to reconcile.
 */
module hs4_coord_wr

extern @abi(c-msvc-x64) fn net_init() -> i32 from "net.iii"
extern @abi(c-msvc-x64) fn net_pack_sockaddr_ipv4(buf_addr: u64, ip_packed: u32, port: u32) -> u32 from "net.iii"
extern @abi(c-msvc-x64) fn net_tcp_listen_ipv4(cap: u64, sockaddr_ptr: u64, sockaddr_len: u32) -> u64 from "net.iii"
extern @abi(c-msvc-x64) fn net_tcp_accept(listen_handle: u64, dial_cap: u64) -> u64 from "net.iii"
extern @abi(c-msvc-x64) fn net_tcp_send(handle_id: u64, buf: u64, n: u64) -> i32 from "net.iii"
extern @abi(c-msvc-x64) fn net_tcp_recv(handle_id: u64, buf: u64, n: u64) -> i32 from "net.iii"
extern @abi(c-msvc-x64) fn net_close(handle_id: u64) -> i32 from "net.iii"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent_id: u64, rights_mask: u64, expires_at: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn ed25519_pubkey(seed: *u8, out_pk: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn hh_init() -> i32 from "hotstuff_heal.iii"
extern @abi(c-msvc-x64) fn hh_record_partition(local_head: *u8, canonical_head: *u8, divergence_view: u64) -> i32 from "hotstuff_heal.iii"
extern @abi(c-msvc-x64) fn hh_resolve(idx: u64, decision: u8) -> i32 from "hotstuff_heal.iii"
extern @abi(c-msvc-x64) fn hh_pending_count() -> u32 from "hotstuff_heal.iii"

const COORD_PORT : u32 = 19220u32

var C_LISTEN : [u64; 1]
var C_CONN   : [u64; 4]
var C_CAP    : [u64; 1]
var C_SEED   : [u8; 128]
var C_PK     : [u8; 128]
var C_BLOCK  : [u8; 424]
var C_BLOCKS : [u8; 1272]   /* 3 saved partition blocks (views 4,5,6) */
var C_VOTE   : [u8; 324]
var C_BMH    : [u8; 32]
var C_VARG   : [u8; 40]
var C_PAY    : [u8; 32]
var C_INIT   : [u8; 200]
var C_HDR    : [u8; 4]
var C_OP     : [u8; 1]
var C_BUF    : [u8; 600]
var C_CANON  : [u8; 32]
var C_N3     : [u8; 32]
var C_HEAD   : [u8; 32]
var C_SADDR  : [u8; 16]

fn c_wr_u32(addr: u64, v: u32) -> i32 {
    let p : *u8 = addr as *u8
    p[0u64] = (v & 0xFFu32) as u8
    p[1u64] = ((v >> 8u32) & 0xFFu32) as u8
    p[2u64] = ((v >> 16u32) & 0xFFu32) as u8
    p[3u64] = ((v >> 24u32) & 0xFFu32) as u8
    return 0i32
}
fn c_rd_u32(addr: u64) -> u32 {
    let p : *u8 = addr as *u8
    return (p[0u64] as u32) | ((p[1u64] as u32) << 8u32) | ((p[2u64] as u32) << 16u32) | ((p[3u64] as u32) << 24u32)
}
fn c_send_raw(conn: u64, addr: u64, n: u64) -> i32 {
    let mut sent : u64 = 0u64
    while sent < n {
        let s : i32 = net_tcp_send(conn, addr + sent, n - sent)
        if s <= 0i32 { return 0i32 - 1i32 }
        sent = sent + (s as u64)
    }
    return 0i32
}
fn c_recv_raw(conn: u64, addr: u64, n: u64) -> i32 {
    let mut got : u64 = 0u64
    while got < n {
        let r : i32 = net_tcp_recv(conn, addr + got, n - got)
        if r <= 0i32 { return 0i32 - 1i32 }
        got = got + (r as u64)
    }
    return 0i32
}
fn c_send_cmd(conn: u64, op: u8, args_addr: u64, args_len: u64) -> i32 {
    c_wr_u32(&C_HDR as u64, (args_len + 1u64) as u32)
    if c_send_raw(conn, &C_HDR as u64, 4u64) != 0i32 { return 0i32 - 1i32 }
    C_OP[0u64] = op
    if c_send_raw(conn, &C_OP as u64, 1u64) != 0i32 { return 0i32 - 1i32 }
    if args_len > 0u64 { return c_send_raw(conn, args_addr, args_len) }
    return 0i32
}
fn c_recv_frame(conn: u64, dst: u64) -> u64 {
    if c_recv_raw(conn, &C_HDR as u64, 4u64) != 0i32 { return 0u64 }
    let len : u32 = c_rd_u32(&C_HDR as u64)
    if (len as u64) > 600u64 { return 0u64 }
    if c_recv_raw(conn, dst, len as u64) != 0i32 { return 0u64 }
    return len as u64
}
fn c_get_head(conn: u64, dst: u64) -> i32 {
    c_send_cmd(conn, 0x43u8, 0u64, 0u64)
    if c_recv_frame(conn, dst) != 32u64 { return 0i32 - 1i32 }
    return 0i32
}
fn c_mem_eq(a: u64, b: u64) -> u8 {
    let ap : *u8 = a as *u8
    let bp : *u8 = b as *u8
    let mut i : u64 = 0u64
    while i < 32u64 { if ap[i] != bp[i] { return 0u8 }  i = i + 1u64 }
    return 1u8
}
/* Drive one 3-phase round for view v on nodes [lo..hi]: block already in
 * C_BLOCK with mhash C_BMH; collect 3 honest votes from {0,1,2}; deliver. */
fn c_vote_round(v: u64, lo: u64, hi: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < 32u64 { C_VARG[i] = C_BMH[i]  i = i + 1u64 }
    i = 0u64
    while i < 8u64 { C_VARG[32u64 + i] = ((v >> (i * 8u64)) & 0xFFu64) as u8  i = i + 1u64 }
    i = 0u64
    while i < 3u64 {
        c_send_cmd(C_CONN[i], 0x56u8, &C_VARG as u64, 40u64)
        if c_recv_frame(C_CONN[i], ((&C_VOTE as u64) + i * 108u64)) != 108u64 { return 0i32 - 1i32 }
        i = i + 1u64
    }
    let mut phase : u64 = 0u64
    while phase < 3u64 {
        let mut vi : u64 = 0u64
        while vi < 3u64 {
            let mut nj : u64 = lo
            while nj <= hi {
                c_send_cmd(C_CONN[nj], 0x48u8, ((&C_VOTE as u64) + vi * 108u64), 108u64)
                c_recv_frame(C_CONN[nj], &C_BUF as u64)
                nj = nj + 1u64
            }
            vi = vi + 1u64
        }
        phase = phase + 1u64
    }
    return 0i32
}

fn main() -> u64 {
    net_init()
    C_CAP[0] = cap_attenuate(cap_env_init(), 0x60u64, 0xFFFFFFFFFFFFFFFFu64)
    let mut i : u64 = 0u64
    while i < 4u64 {
        let mut j : u64 = 0u64
        while j < 32u64 { C_SEED[i * 32u64 + j] = (i * 9u64 + j + 3u64) as u8  j = j + 1u64 }
        ed25519_pubkey(((&C_SEED as u64) + i * 32u64) as *u8, ((&C_PK as u64) + i * 32u64) as *u8)
        i = i + 1u64
    }
    net_pack_sockaddr_ipv4(&C_SADDR as u64, 0x7F000001u32, COORD_PORT)
    C_LISTEN[0] = net_tcp_listen_ipv4(C_CAP[0], &C_SADDR as u64, 16u32)
    if C_LISTEN[0] == 0u64 { return 1u64 }
    i = 0u64
    while i < 4u64 {
        let h : u64 = net_tcp_accept(C_LISTEN[0], C_CAP[0])
        if h == 0u64 { return 2u64 }
        C_CONN[i] = h
        i = i + 1u64
    }
    i = 0u64
    while i < 4u64 {
        c_wr_u32(&C_INIT as u64, i as u32)
        let mut k : u64 = 0u64
        while k < 128u64 { C_INIT[4u64 + k] = C_PK[k]  k = k + 1u64 }
        k = 0u64
        while k < 32u64 { C_INIT[132u64 + k] = C_SEED[i * 32u64 + k]  k = k + 1u64 }
        k = 0u64
        while k < 32u64 { C_INIT[164u64 + k] = C_PK[i * 32u64 + k]  k = k + 1u64 }
        c_send_cmd(C_CONN[i], 0x49u8, &C_INIT as u64, 196u64)
        if c_recv_frame(C_CONN[i], &C_BUF as u64) != 1u64 { return 3u64 }
        i = i + 1u64
    }
    /* ---- Phase 1: views 1-3, all 4 nodes commit lockstep ---- */
    let mut v : u64 = 1u64
    while v <= 3u64 {
        let leader : u64 = v & 3u64
        i = 0u64
        while i < 4u64 { c_send_cmd(C_CONN[i], 0x54u8, 0u64, 0u64)  c_recv_frame(C_CONN[i], &C_BUF as u64)  i = i + 1u64 }
        i = 0u64
        while i < 32u64 { C_PAY[i] = (v + i) as u8  i = i + 1u64 }
        c_send_cmd(C_CONN[leader], 0x50u8, &C_PAY as u64, 32u64)
        if c_recv_frame(C_CONN[leader], &C_BLOCK as u64) != 424u64 { return 10u64 }
        i = 0u64
        while i < 32u64 { C_BMH[i] = C_BLOCK[296u64 + i]  i = i + 1u64 }
        i = 0u64
        while i < 4u64 { c_send_cmd(C_CONN[i], 0x42u8, &C_BLOCK as u64, 424u64)  c_recv_frame(C_CONN[i], &C_BUF as u64)  i = i + 1u64 }
        if c_vote_round(v, 0u64, 3u64) != 0i32 { return 11u64 }
        v = v + 1u64
    }
    /* ---- Phase 2: views 4-6, node 3 PARTITIONED; majority {0,1,2} commits ---- */
    v = 4u64
    while v <= 6u64 {
        let leader : u64 = v & 3u64                  /* 4->0, 5->1, 6->2 (all in majority) */
        i = 0u64
        while i < 3u64 { c_send_cmd(C_CONN[i], 0x54u8, 0u64, 0u64)  c_recv_frame(C_CONN[i], &C_BUF as u64)  i = i + 1u64 }
        i = 0u64
        while i < 32u64 { C_PAY[i] = (v + i) as u8  i = i + 1u64 }
        c_send_cmd(C_CONN[leader], 0x50u8, &C_PAY as u64, 32u64)
        if c_recv_frame(C_CONN[leader], &C_BLOCK as u64) != 424u64 { return 12u64 }
        /* save the partition block for the later replay */
        let slot : u64 = (v - 4u64) * 424u64
        i = 0u64
        while i < 424u64 { C_BLOCKS[slot + i] = C_BLOCK[i]  i = i + 1u64 }
        i = 0u64
        while i < 32u64 { C_BMH[i] = C_BLOCK[296u64 + i]  i = i + 1u64 }
        i = 0u64
        while i < 3u64 { c_send_cmd(C_CONN[i], 0x42u8, &C_BLOCK as u64, 424u64)  c_recv_frame(C_CONN[i], &C_BUF as u64)  i = i + 1u64 }
        if c_vote_round(v, 0u64, 2u64) != 0i32 { return 13u64 }
        v = v + 1u64
    }
    /* ---- Detect the real divergence ---- */
    c_get_head(C_CONN[0u64], &C_CANON as u64)        /* canonical (view-6 block) */
    c_get_head(C_CONN[3u64], &C_N3 as u64)           /* node 3 (still at the view-3 block) */
    if c_mem_eq(&C_CANON as u64, &C_N3 as u64) == 1u8 { return 40u64 }   /* must have diverged */
    /* ---- Heal: record + resolve node 3's divergence into canonical ---- */
    hh_init()
    if hh_record_partition(&C_N3 as u64 as *u8, &C_CANON as u64 as *u8, 4u64) != 0i32 { return 41u64 }
    hh_resolve(0u64, 1u8)
    if hh_pending_count() != 0u32 { return 41u64 }
    /* ---- Reconcile node 3: replay the canonical blocks 4-6 to it ---- */
    v = 4u64
    while v <= 6u64 {
        c_send_cmd(C_CONN[3u64], 0x54u8, 0u64, 0u64)  c_recv_frame(C_CONN[3u64], &C_BUF as u64)   /* tick node 3 -> view v */
        let slot : u64 = (v - 4u64) * 424u64
        i = 0u64
        while i < 424u64 { C_BLOCK[i] = C_BLOCKS[slot + i]  i = i + 1u64 }
        i = 0u64
        while i < 32u64 { C_BMH[i] = C_BLOCK[296u64 + i]  i = i + 1u64 }
        c_send_cmd(C_CONN[3u64], 0x42u8, &C_BLOCK as u64, 424u64)  c_recv_frame(C_CONN[3u64], &C_BUF as u64)
        if c_vote_round(v, 3u64, 3u64) != 0i32 { return 42u64 }
        v = v + 1u64
    }
    /* ---- Verify reconciliation: node 3 now equals canonical ---- */
    c_get_head(C_CONN[3u64], &C_HEAD as u64)
    if c_mem_eq(&C_HEAD as u64, &C_CANON as u64) == 0u8 { return 42u64 }
    i = 0u64
    while i < 4u64 { c_send_cmd(C_CONN[i], 0x44u8, 0u64, 0u64)  i = i + 1u64 }
    return 99u64
}
