/* §4.13 driver: STARK field/NTT + Merkle + LDE + full prove/verify KAT. exit 99 = pass. */
module zkst_probe
extern @abi(c-msvc-x64) fn zk_stark_ntt_selftest() -> u64 from "zk_stark.iii"
extern @abi(c-msvc-x64) fn zk_stark_merkle_selftest() -> u64 from "zk_stark.iii"
extern @abi(c-msvc-x64) fn zk_stark_lde_selftest() -> u64 from "zk_stark.iii"
extern @abi(c-msvc-x64) fn zk_stark_kat() -> u64 from "zk_stark.iii"
fn main() -> u64 {
    let a : u64 = zk_stark_ntt_selftest()
    if a != 99u64 { return a }
    let b : u64 = zk_stark_merkle_selftest()
    if b != 99u64 { return 10u64 + b }
    let c : u64 = zk_stark_lde_selftest()
    if c != 99u64 { return 20u64 + c }
    let d : u64 = zk_stark_kat()
    if d != 99u64 { return 200u64 + d }
    return 99u64
}
