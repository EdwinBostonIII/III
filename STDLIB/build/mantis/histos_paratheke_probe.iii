/* histos_paratheke_probe.iii -- ONE STANDING, TWO AXES: where the ledger meets the web.
 *
 * PARATHEKE holds the R1-order claim across TIME: a deposit re-earned each read by re-sealing
 * it (man_seal_order) -- the LOGOS witness. HISTOS holds it across the organ SPACE: the
 * witness -> membrane -> krisis chain, re-derived by the exact engines (kr_sign) -- the
 * SUBSTRATE witness. They are the SAME claim, and its standing is not a truth to be stored but
 * a DEBT re-derived on BOTH axes: III's own two-engine / no-self-grading law, lifted to whole
 * organs.
 *
 * THE ONTOLOGICAL MOVE (no coordinator, no island): the deposit does not "call" the web -- it
 * BECOMES A NODE in it. Its own cell IS its temporal re-derivation (PARATHEKE's pk_std_line, the
 * seal); its edge [r1_order_standing < membrane_verdict] IS its spatial re-derivation (HISTOS's
 * exact chain). Because it IS a standing claim, histos_stand yields (seal re-derives) AND
 * (substrate stands) with no new machinery -- the conjunction EMERGES from the web's recursive law.
 *
 * WHY LOAD-BEARING: the R1 deposit is ORDER-kind -- man_seal_order does NOT run kr_sign. So a
 * broken kr_sign leaves PARATHEKE's seal STANDING (the gate asserts this), while HISTOS's exact
 * chain reddens. Only the web, unified with the ledger, catches the substrate break behind a
 * still-valid seal -- and names krisis. Conversely the deposit gives the web-node PERMANENCE: its
 * standing is a ledger entry, re-earned every session, never duplicating kardia.
 *
 * Both organs are externed READ-ONLY; nothing here modifies paratheke.iii or histos.iii. */
module histos_paratheke_probe

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
/* PARATHEKE -- the temporal axis (mint + re-derive the R1-order deposit) */
extern @abi(c-msvc-x64) fn pk_mint_begin(seq: u64, prev: u64, kind: u64, of_seq: u64) -> i32 from "paratheke.iii"
extern @abi(c-msvc-x64) fn pk_mint_pair(win: u64, los: u64) -> i32 from "paratheke.iii"
extern @abi(c-msvc-x64) fn pk_mint_close(pin: u64) -> u64 from "paratheke.iii"
extern @abi(c-msvc-x64) fn pk_out_len() -> u64 from "paratheke.iii"
extern @abi(c-msvc-x64) fn pk_out_byte(i: u64) -> u8 from "paratheke.iii"
extern @abi(c-msvc-x64) fn pk_std_begin() -> i32 from "paratheke.iii"
extern @abi(c-msvc-x64) fn pk_std_line(base: u64, len: u64, pin_krisis: u64, pin_order: u64, waive: u64) -> u64 from "paratheke.iii"
/* HISTOS -- the spatial axis (the web + the deposit node) */
extern @abi(c-msvc-x64) fn histos_weave_mvp() -> u64 from "histos.iii"
extern @abi(c-msvc-x64) fn hs_node(name: u64) -> u64 from "histos.iii"
extern @abi(c-msvc-x64) fn hs_edge(src: u64, dst: u64, ob: u64, chain: u64) -> u64 from "histos.iii"
extern @abi(c-msvc-x64) fn hs_set_verdict(idx: u64, v: u64) -> i32 from "histos.iii"
extern @abi(c-msvc-x64) fn hs_verdict(idx: u64) -> u64 from "histos.iii"
extern @abi(c-msvc-x64) fn histos_stand(idx: u64) -> u64 from "histos.iii"
extern @abi(c-msvc-x64) fn histos_reddened_by(idx: u64) -> u64 from "histos.iii"
/* the substrate organs whose REAL selfproves are the exact-chain cells */
extern @abi(c-msvc-x64) fn pb_attn_selfprove() -> u64 from "probole.iii"
extern @abi(c-msvc-x64) fn kr_selfprove() -> u64 from "krisis.iii"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(arena: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_add(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_cmp(a: u64, b: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop_arena(arena: u64) -> i32 from "bigint.iii"

fn ps(s: u64) -> u32 { let p : *u8 = s as *u8   let mut i : u64 = 0u64   while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }   return 1u32 }
fn pz(s: u64) -> u32 { let p : *u8 = s as *u8   let mut i : u64 = 0u64   while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }   return 1u32 }

const PK_ORDER : u64 = 2u64
var HP_LINE : [u8; 1024]                  /* the minted R1-order deposit, byte-form */

fn bigint_kat() -> u64 {
    let ar : u64 = arena_new(4096u64)
    if ar == 0u64 { return 1u64 }
    let two : u64 = bigint_from_u64(ar, 2u64)
    let four : u64 = bigint_add(ar, two, two)
    let three : u64 = bigint_from_u64(ar, 3u64)
    let fourlit : u64 = bigint_from_u64(ar, 4u64)
    let mut rc : u64 = 0u64
    if bigint_cmp(four, three) <= 0i32 { rc = 1u64 }
    if bigint_cmp(four, fourlit) != 0i32 { rc = 1u64 }
    bigint_drop_arena(ar)
    arena_drop(ar)
    return rc
}
fn set_cell(idx: u64, v: u64) -> i32 { if v == 0u64 { hs_set_verdict(idx, 0u64) } else { hs_set_verdict(idx, 1u64) }   return 0i32 }

fn main(argc: i32, argv: u64) -> u64 {
    let _a : i32 = argc   let _v : u64 = argv

    /* THE TEMPORAL AXIS: mint the R1-order deposit and re-derive it (the seal, man_seal_order). */
    pk_mint_begin(1u64, 0u64, PK_ORDER, 0u64)
    pk_mint_pair(24792u64, 1925u64)
    if pk_mint_close(187u64) != 0u64 { ps("mint failed" as u64)   putchar(10i32)   return 9u64 }
    let n : u64 = pk_out_len()
    if n == 0u64 { ps("empty deposit" as u64)   putchar(10i32)   return 9u64 }
    if n > 1024u64 { ps("deposit too long" as u64)   putchar(10i32)   return 9u64 }
    let dst : *u8 = (&HP_LINE) as *u8
    let mut i : u64 = 0u64
    while i < n { dst[i] = pk_out_byte(i)   i = i + 1u64 }
    pk_std_begin()
    let seal : u64 = pk_std_line((&HP_LINE) as u64, n, 170u64, 187u64, 0u64)   /* 0 = STANDS */

    /* THE SPATIAL AXIS: weave the exact chain and place the deposit AS A NODE resting on it. */
    if histos_weave_mvp() != 0u64 { ps("weave failed" as u64)   putchar(10i32)   return 9u64 }
    let dep : u64 = hs_node("r1_order_standing" as u64)                          /* node 4 */
    let e : u64 = hs_edge(dep, 1u64, "[r1_order_standing < membrane_verdict]" as u64,
        "[r1_order_standing < pb_head_order_trusted] [pb_head_order_trusted < membrane_verdict]" as u64)
    if e == 0xFFFFFFFFFFFFFFFFu64 { ps("edge refused" as u64)   putchar(10i32)   return 9u64 }

    /* the cells: the deposit's own cell IS the seal re-derivation; the substrate cells are the
     * organs' REAL selfproves. */
    let mut sealv : u64 = 1u64
    if seal == 0u64 { sealv = 0u64 }
    set_cell(dep, sealv)
    let vm : u64 = pb_attn_selfprove()
    let vk : u64 = kr_selfprove()
    let vb : u64 = bigint_kat()
    set_cell(1u64, vm)
    set_cell(2u64, vk)
    set_cell(3u64, vb)

    /* report: the seal (temporal) and the web-node (spatial) verdicts of the ONE standing. */
    ps("seal (paratheke, temporal): " as u64)
    if seal == 0u64 { ps("STANDS" as u64) } else { ps("refused(" as u64)   putchar((48u64 + (seal % 10u64)) as i32)   ps(")" as u64) }
    putchar(10i32)
    ps("web (histos, spatial): r1_order_standing " as u64)
    let st : u64 = histos_stand(dep)
    if st == 0u64 { ps("GREEN" as u64) } else { ps("RED" as u64) }
    ps(" (seal-cell " as u64)
    if hs_verdict(dep) == 0u64 { ps("GREEN" as u64) } else { ps("RED" as u64) }
    ps(") rooted-at " as u64)
    pz(histos_reddened_by(dep))
    putchar(10i32)

    if st == 0u64 { return 0u64 }
    return 2u64
}
