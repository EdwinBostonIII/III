module show_compute
extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_loop(body: u32, count: u64) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_if(p: u32, a: u32, b: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_canonicalise(t: u32) -> u32 from "xii_canonicalise.iii"
extern @abi(c-msvc-x64) fn xii_term_get_aux(idx: u32) -> u64 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_kind(idx: u32) -> u8 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_struct_eq(a: u32, b: u32) -> u8 from "xii_rewrite.iii"
const SEL : u64 = 3u64
fn main() -> u64 {
    xii_term_arena_reset()
    let b : u32 = xii_term_make_basis(11u8, 1u32)
    let folded : u32 = xii_canonicalise(xii_term_make_loop(xii_term_make_loop(b, 2u64), 3u64))
    if SEL == 1u64 { return xii_term_get_aux(folded) }      /* loop(loop(b,2),3) -> loop(b, ?) ; expect 6 */
    /* decision collapse: if(p, x, x) -> x  (a redundant branch is eliminated) */
    let p : u32 = xii_term_make_basis(0u8, 9u32)
    let x : u32 = xii_term_make_basis(11u8, 7u32)
    let collapsed : u32 = xii_canonicalise(xii_term_make_if(p, x, x))
    if SEL == 2u64 { return xii_rewrite_struct_eq(collapsed, x) as u64 }  /* expect 1: it became just x */
    if SEL == 3u64 { return xii_term_get_kind(collapsed) as u64 }        /* expect 11 (K12 leaf), NOT 22 (FIF) */
    return 0u64
}
