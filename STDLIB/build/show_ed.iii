module show_ed
extern @abi(c-msvc-x64) fn ed25519_keypair_from_seed(seed_32: *u8, pubkey_32: *u8, privkey_64: *u8) -> u32 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn ed25519_sign(seed: *u8, pk: *u8, msg: *u8, msg_len: u64, sig_out: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn ed25519_verify(pubkey: *u8, msg: *u8, msg_len: u64, sig: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn _write(fd: i32, buf: *u8, n: u32) -> i32 from "msvcrt"
var SEED : [u8; 32]
var PK : [u8; 32]
var SK : [u8; 64]
var MSG : [u8; 16]
var SIG : [u8; 64]
var HEX : [u8; 140]
fn _nib(v: u8) -> u8 { if v < 10u8 { return (48u8 + v) }  return (87u8 + v) }
fn _hexline(p: *u8, n: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < n { let b : u8 = p[i]  HEX[i*2u64]=_nib((b >> 4u8) & 0x0Fu8)  HEX[(i*2u64)+1u64]=_nib(b & 0x0Fu8)  i = i + 1u64 }
    HEX[n*2u64]=10u8  _write(1i32, (&HEX as u64) as *u8, ((n*2u64)+1u64) as u32)  return 0i32
}
fn main() -> u64 {
    let mut i : u64 = 0u64
    while i < 32u64 { SEED[i] = (i & 0xFFu64) as u8  i = i + 1u64 }
    MSG[0u64]=115u8 MSG[1u64]=111u8 MSG[2u64]=118u8 MSG[3u64]=101u8 MSG[4u64]=114u8 MSG[5u64]=101u8 MSG[6u64]=105u8 MSG[7u64]=103u8 MSG[8u64]=110u8
    ed25519_keypair_from_seed((&SEED as u64) as *u8, (&PK as u64) as *u8, (&SK as u64) as *u8)
    ed25519_sign((&SEED as u64) as *u8, (&PK as u64) as *u8, (&MSG as u64) as *u8, 9u64, (&SIG as u64) as *u8)
    let r1 : u8 = ed25519_verify((&PK as u64) as *u8, (&MSG as u64) as *u8, 9u64, (&SIG as u64) as *u8)
    _hexline((&PK as u64) as *u8, 32u64)
    _hexline((&SIG as u64) as *u8, 64u64)
    SIG[0u64] = SIG[0u64] + 1u8
    let r2 : u8 = ed25519_verify((&PK as u64) as *u8, (&MSG as u64) as *u8, 9u64, (&SIG as u64) as *u8)
    HEX[0u64]=(48u8 + r1)  HEX[1u64]=32u8  HEX[2u64]=(48u8 + r2)  HEX[3u64]=10u8  _write(1i32, (&HEX as u64) as *u8, 4u32)  return 0u64
}
