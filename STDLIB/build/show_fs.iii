module show_fs
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent_id: u64, rights_mask: u64, expires_at: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_verify_rights(id: u64, required: u64) -> u8 from "capability.iii"
extern @abi(c-msvc-x64) fn fs_open(cap_id: u64, path: u64, mode: u32) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_read(handle_id: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_close(handle_id: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn sha256_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn _write(fd: i32, buf: *u8, n: u32) -> i32 from "msvcrt"
const FS_RIGHT_READ : u64 = 0x0002u64
const FS_RIGHT_WRITE : u64 = 0x0004u64
var PATH : [u8; 8]
var BUF : [u8; 4096]
var DIG : [u8; 32]
var HEX : [u8; 70]
var LINE : [u8; 8]
fn _nib(v: u8) -> u8 { if v < 10u8 { return (48u8 + v) }  return (87u8 + v) }
fn main() -> u64 {
    let root : u64 = cap_env_init()
    let fscap : u64 = cap_attenuate(root, FS_RIGHT_READ, 0u64)
    let has_read : u8 = cap_verify_rights(fscap, FS_RIGHT_READ)
    let has_write : u8 = cap_verify_rights(fscap, FS_RIGHT_WRITE)
    LINE[0u64]=(48u8 + has_read)  LINE[1u64]=32u8  LINE[2u64]=(48u8 + has_write)  LINE[3u64]=10u8
    _write(1i32, (&LINE as u64) as *u8, 4u32)
    PATH[0u64]=102u8  PATH[1u64]=105u8  PATH[2u64]=110u8  PATH[3u64]=0u8
    let h : u64 = fs_open(fscap, (&PATH as u64), 1u32)
    if h == 0u64 { return 7u64 }
    let n : u64 = fs_read(h, (&BUF as u64), 4096u64)
    fs_close(h)
    sha256_oneshot((&BUF as u64) as *u8, n, (&DIG as u64) as *u8)
    let mut i : u64 = 0u64
    while i < 32u64 { HEX[i*2u64]=_nib((DIG[i] >> 4u8) & 0x0Fu8)  HEX[(i*2u64)+1u64]=_nib(DIG[i] & 0x0Fu8)  i = i + 1u64 }
    HEX[64u64]=10u8  _write(1i32, (&HEX as u64) as *u8, 65u32)
    return 0u64
}
