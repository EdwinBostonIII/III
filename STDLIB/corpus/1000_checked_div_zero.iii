/* 1000_checked_div_zero.iii -- falsifier for checked_u32_div's divide-by-zero guard
 * (numera/checked.iii:43). The option_u64 encoding is some(v)=(v<<1)|1, none=0. A zero
 * divisor must return NONE (0u64) -- never a hardware divide-by-zero; a valid divisor
 * returns some(a/b). 145_checked_crystal exercises only the @crystal provenance variant,
 * so the bare checked_u32_div div0 guard had no falsifier. (First 4-digit corpus test.)
 * 99 = pass. */
module corpus_1000

extern @abi(c-msvc-x64) fn checked_u32_div(a: u32, b: u32) -> u64 from "checked.iii"

fn main() -> u64 {
    /* b==0 -> none (0u64); no division-by-zero */
    if checked_u32_div(10u32, 0u32) != 0u64 { return 1u64 }
    if checked_u32_div(4294967295u32, 0u32) != 0u64 { return 2u64 }
    /* b!=0 -> some(a/b) = ((a/b)<<1)|1 */
    if checked_u32_div(10u32, 2u32) != 11u64 { return 3u64 }    /* some 5  */
    if checked_u32_div(100u32, 7u32) != 29u64 { return 4u64 }   /* some 14 */
    /* some(0) = 1, distinct from the none sentinel 0 (non-vacuity) */
    if checked_u32_div(0u32, 5u32) != 1u64 { return 5u64 }
    return 99u64
}
