/* 1003_merkle_tree_open_many.iii -- falsifier for merkle.iii's APOTHEOSIS C.3 build-once/
 * open-many u32 surface (merkle_tree_build_u32/root/open/verify_u32). The existing
 * merkle_compute_proof rebuilds the whole tree per proof over byte-array leaves; this new
 * surface persists ONE tree in a caller pool and opens many leaves -- the zk-STARK pattern.
 * Positive: build once, open+verify several leaves. Negatives (the real protection): a
 * tampered leaf value rejects; a leaf presented at the WRONG index rejects (index bits are
 * load-bearing, not prover-chosen). 99 = pass. */
module corpus_1003

extern @abi(c-msvc-x64) fn merkle_tree_build_u32(arrBase: u64, leafOff: u64, n: u64, poolBase: u64, treeOff: u64) -> i32 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_tree_root(poolBase: u64, treeOff: u64) -> u64 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_tree_open(poolBase: u64, treeOff: u64, n: u64, idx: u64, pathBase: u64) -> u64 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_tree_verify_u32(rootAddr: u64, n: u64, idx: u64, leafVal: u32, pathBase: u64, plen: u64) -> u64 from "merkle.iii"

var LEAVES : [u32; 8]
var POOL   : [u8; 1024]   /* 2*8*32 = 512 bytes needed */
var PATH   : [u8; 512]

fn main() -> u64 {
    let mut i : u64 = 0u64
    while i < 8u64 { LEAVES[i] = (i*7u64 + 3u64) as u32  i = i + 1u64 }
    /* build the tree ONCE */
    merkle_tree_build_u32(&LEAVES as u64, 0u64, 8u64, &POOL as u64, 0u64)
    let root : u64 = merkle_tree_root(&POOL as u64, 0u64)
    /* open + verify leaf 5 */
    let plen : u64 = merkle_tree_open(&POOL as u64, 0u64, 8u64, 5u64, &PATH as u64)
    if plen != 3u64 { return 1u64 }
    if merkle_tree_verify_u32(root, 8u64, 5u64, LEAVES[5u64], &PATH as u64, plen) != 1u64 { return 2u64 }
    /* negative: tampered leaf value -> reject */
    if merkle_tree_verify_u32(root, 8u64, 5u64, LEAVES[5u64] ^ 1u32, &PATH as u64, plen) != 0u64 { return 3u64 }
    /* negative: same value+path at the WRONG index -> reject (index bits load-bearing) */
    if merkle_tree_verify_u32(root, 8u64, 4u64, LEAVES[5u64], &PATH as u64, plen) != 0u64 { return 4u64 }
    /* open+verify a SECOND leaf from the SAME built tree (open-many) */
    let plen0 : u64 = merkle_tree_open(&POOL as u64, 0u64, 8u64, 0u64, &PATH as u64)
    if merkle_tree_verify_u32(root, 8u64, 0u64, LEAVES[0u64], &PATH as u64, plen0) != 1u64 { return 5u64 }
    /* and a third, the last leaf */
    let plen7 : u64 = merkle_tree_open(&POOL as u64, 0u64, 8u64, 7u64, &PATH as u64)
    if merkle_tree_verify_u32(root, 8u64, 7u64, LEAVES[7u64], &PATH as u64, plen7) != 1u64 { return 6u64 }
    return 99u64
}
