/* sanctus::quality — aggregate gate Q1..Q6 returns 0x3F when all six
 * inputs are satisfied; specific bits drop when individual gates fail. */
module corpus_93

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn kchain_new(custom_floor: u64) -> u64 from "kchain.iii"
extern @abi(c-msvc-x64) fn kchain_compose(id: u64, k_call_fx: u64) -> u8 from "kchain.iii"

extern @abi(c-msvc-x64) fn quality_set_corpus(prev_pass: u32, this_pass: u32) -> i32 from "quality.iii"
extern @abi(c-msvc-x64) fn quality_set_mhash_pair(a_ptr: u64, b_ptr: u64) -> i32 from "quality.iii"
extern @abi(c-msvc-x64) fn quality_set_golden(actual_ptr: u64, golden_ptr: u64) -> i32 from "quality.iii"
extern @abi(c-msvc-x64) fn quality_set_witness_counts(prev: u32, new_c: u32) -> i32 from "quality.iii"
extern @abi(c-msvc-x64) fn quality_set_witness_roots(prev_ptr: u64, new_ptr: u64) -> i32 from "quality.iii"
extern @abi(c-msvc-x64) fn quality_set_kchain(id: u64) -> i32 from "quality.iii"
extern @abi(c-msvc-x64) fn quality_set_seal(prev_ptr: u64, new_ptr: u64, step_no: u32) -> i32 from "quality.iii"
extern @abi(c-msvc-x64) fn quality_gate_check() -> u32 from "quality.iii"
extern @abi(c-msvc-x64) fn quality_all_mask() -> u32 from "quality.iii"
extern @abi(c-msvc-x64) fn quality_set_resolver_lint_passed() -> i32 from "quality_q7.iii"
extern @abi(c-msvc-x64) fn seal_resolver_compute() -> i32 from "seal_resolver.iii"
extern @abi(c-msvc-x64) fn pattern_registry_seal_global() -> u64 from "pattern_table.iii"

fn fill_buf(p: *u8, base: u8) -> u32 {
    let mut i : u64 = 0u64
    while i < 32u64 {
        p[i] = base + (i as u8)
        i = i + 1u64
    }
    return 0u32
}

fn main() -> u64 {
    let buf_a   : *u8 = malloc(32u64)
    let buf_b   : *u8 = malloc(32u64)
    let buf_c   : *u8 = malloc(32u64)
    let buf_d   : *u8 = malloc(32u64)
    let buf_x   : *u8 = malloc(32u64)
    fill_buf(buf_a, 0u8)
    fill_buf(buf_b, 0u8)         /* equals buf_a */
    fill_buf(buf_c, 0u8)         /* used for golden + actual + seal pairs */
    fill_buf(buf_d, 0u8)         /* paired with buf_c (equal) */
    fill_buf(buf_x, 0xFFu8)      /* differs from buf_a */

    /* Q7 setup: lint passed + registry sealed + resolver seal computed. */
    quality_set_resolver_lint_passed()
    pattern_registry_seal_global()
    seal_resolver_compute()

    /* All-six-pass setup. */
    quality_set_corpus(10u32, 12u32)
    quality_set_mhash_pair(buf_a as u64, buf_b as u64)
    quality_set_golden(buf_c as u64, buf_d as u64)
    quality_set_witness_counts(0u32, 0u32)
    quality_set_witness_roots(buf_a as u64, buf_b as u64)
    let k : u64 = kchain_new(0u64)
    kchain_compose(k, 950000000u64)
    quality_set_kchain(k)
    /* Step 0 = genesis; gate trivially passes regardless of root content. */
    quality_set_seal(buf_a as u64, buf_b as u64, 0u32)

    let bits : u32 = quality_gate_check()
    let all  : u32 = quality_all_mask()
    if bits != all { return 1u64 }

    /* Q1 failure path: this_pass < prev_pass — bit 0 must drop. */
    quality_set_corpus(20u32, 5u32)
    let bits2 : u32 = quality_gate_check()
    if (bits2 & 0x00000001u32) != 0u32 { return 2u64 }
    /* restore */
    quality_set_corpus(0u32, 0u32)

    /* Q2 failure path: pair differs — bit 1 must drop. */
    quality_set_mhash_pair(buf_a as u64, buf_x as u64)
    let bits3 : u32 = quality_gate_check()
    if (bits3 & 0x00000002u32) != 0u32 { return 3u64 }
    /* restore */
    quality_set_mhash_pair(buf_a as u64, buf_b as u64)

    /* Q3 failure path: actual differs from golden — bit 2 must drop. */
    quality_set_golden(buf_a as u64, buf_x as u64)
    let bits4 : u32 = quality_gate_check()
    if (bits4 & 0x00000004u32) != 0u32 { return 4u64 }
    /* restore */
    quality_set_golden(buf_c as u64, buf_d as u64)

    /* Q5 failure path: K below floor (drop K to 0.81 < 0.85) — bit 4 drops. */
    let k2 : u64 = kchain_new(0u64)
    kchain_compose(k2, 900000000u64)
    kchain_compose(k2, 900000000u64)         /* 0.81 */
    quality_set_kchain(k2)
    let bits5 : u32 = quality_gate_check()
    if (bits5 & 0x00000010u32) != 0u32 { return 5u64 }
    /* restore — back to healthy K. */
    quality_set_kchain(k)

    /* Final all-pass. */
    let bits_final : u32 = quality_gate_check()
    if bits_final != all { return 6u64 }

    free(buf_a); free(buf_b); free(buf_c); free(buf_d); free(buf_x)
    return 99u64
}
