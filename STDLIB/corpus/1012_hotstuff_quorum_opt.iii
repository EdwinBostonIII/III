/* 1012_hotstuff_quorum_opt.iii -- falsifier for the tournament quorum optimizer (APOTHEOSIS C.11,
 * hotstuff_predict_opt.iii). A tournament over SEALED peer availability facts selects the 2f+1
 * most-available peers: DETERMINISTIC (the no-ML arm -- same sealed facts always yield the same
 * selection, no observed state to train), FACT-DRIVEN (re-sealing a peer as most-available enters
 * it / drops the ex-marginal one), and Byzantine-available by construction (>= 2f+1 selected).
 * 99 = pass. */
module corpus_1012

extern @abi(c-msvc-x64) fn hpo_predict_opt_selftest() -> u64 from "hotstuff_predict_opt.iii"

fn main() -> u64 { return hpo_predict_opt_selftest() }
