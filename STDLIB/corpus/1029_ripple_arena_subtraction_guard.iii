/* 1029 -- forcefield/ripple.iii rn_insert arena-overflow guard (#3 backlog, subtraction-form).
 *
 * rn_insert appends `vlen` bytes of a value into the `arena` (capacity acap) at offset `used`.
 * The old bound check `used + vlen > acap` WRAPS when a caller-supplied vlen (reachable via the
 * @export rn_publish / rn_merge) is near u64-max: used+vlen overflows back to a small value that
 * passes the check, and rn_copy then writes vlen bytes past the arena -> heap OOB.  The fix is the
 * overflow-proof subtraction form:  if acap < used { fail }  ;  if vlen > acap - used { fail }.
 *
 * This KAT drives the guard from both sides on a deliberately tiny (64-byte) arena:
 *   - boundary EXACT fit (vlen == acap-used) SUCCEEDS and is not false-rejected;
 *   - any overflow (vlen > acap-used), including a large vlen on an empty arena, returns 3 (oom)
 *     and leaves used/count UNCHANGED (no partial/aliased write).
 * The subtraction compare `vlen > acap-used` is exactly the wrap-proof predicate, so the same arm
 * that rejects vlen=200 here rejects a u64-max vlen identically (acap-used is always small).  99 = pass. */
module corpus_1029

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn rn_store_init(meta: *u8, slots: *u8, cap: u64, arena_cap: u64) -> u64 from "ripple.iii"
extern @abi(c-msvc-x64) fn rn_publish(meta: *u8, slots: *u8, arena: *u8, val: *u8, vo: u64, vlen: u64, addr_out: *u8, ao: u64) -> u64 from "ripple.iii"
extern @abi(c-msvc-x64) fn rn_count(meta: *u8) -> u64 from "ripple.iii"

fn filln(p: *u8, v: u8, n: u64) -> u32 {
    let mut i : u64 = 0u64
    while i < n { p[i] = v  i = i + 1u64 }
    return 0u32
}

/* arena bytes consumed so far = meta@16 (u64). */
fn used_of(meta: *u8) -> u64 {
    return (meta as *u64)[2u64]
}

fn main() -> u64 {
    let meta  : *u8 = malloc(64u64)
    let slots : *u8 = malloc(256u64)        /* cap=4 -> 4*64 */
    let arena : *u8 = malloc(64u64)         /* arena_cap = 64 */
    let addr  : *u8 = malloc(32u64)
    let val   : *u8 = malloc(256u64)        /* >= any vlen we hash/copy */
    if (meta as u64) == 0u64 { return 1u64 }
    if (slots as u64) == 0u64 { return 2u64 }
    if (arena as u64) == 0u64 { return 3u64 }
    if (addr as u64) == 0u64 { return 4u64 }
    if (val as u64) == 0u64 { return 5u64 }

    if rn_store_init(meta, slots, 4u64, 64u64) != 0u64 { return 10u64 }

    /* (1) first value: 32 bytes into a 64-byte arena -> ok, used 0->32. */
    filln(val, 0x11u8, 32u64)
    if rn_publish(meta, slots, arena, val, 0u64, 32u64, addr, 0u64) != 0u64 { return 11u64 }
    if rn_count(meta) != 1u64 { return 12u64 }
    if used_of(meta) != 32u64 { return 13u64 }

    /* (2) BOUNDARY exact fit: vlen == acap-used (32 == 64-32) -> ok, used 32->64, NOT rejected. */
    filln(val, 0x22u8, 32u64)
    if rn_publish(meta, slots, arena, val, 0u64, 32u64, addr, 0u64) != 0u64 { return 14u64 }
    if rn_count(meta) != 2u64 { return 15u64 }
    if used_of(meta) != 64u64 { return 16u64 }

    /* (3) OVERFLOW by 1 on a full arena: acap-used = 0, vlen 1 > 0 -> 3 (oom); used/count UNCHANGED. */
    filln(val, 0x33u8, 1u64)
    if rn_publish(meta, slots, arena, val, 0u64, 1u64, addr, 0u64) != 3u64 { return 17u64 }
    if rn_count(meta) != 2u64 { return 18u64 }
    if used_of(meta) != 64u64 { return 19u64 }

    /* (4) LARGE vlen on a FRESH empty arena: vlen 200 > acap 64 -> 3; nothing written. The wrap-proof
     *     `vlen > acap-used` rejects this identically to a u64-max vlen (acap-used is always <= 64). */
    let meta2  : *u8 = malloc(64u64)
    let slots2 : *u8 = malloc(256u64)
    let arena2 : *u8 = malloc(64u64)
    if (meta2 as u64) == 0u64 { return 20u64 }
    if (slots2 as u64) == 0u64 { return 21u64 }
    if (arena2 as u64) == 0u64 { return 22u64 }
    if rn_store_init(meta2, slots2, 4u64, 64u64) != 0u64 { return 23u64 }
    filln(val, 0x44u8, 200u64)
    if rn_publish(meta2, slots2, arena2, val, 0u64, 200u64, addr, 0u64) != 3u64 { return 24u64 }
    if rn_count(meta2) != 0u64 { return 25u64 }
    if used_of(meta2) != 0u64 { return 26u64 }

    /* (5) POSITIVE control: a single value that fills the arena EXACTLY (vlen 64 == acap 64) succeeds,
     *     proving the guard does not false-reject the exact-fit edge. */
    filln(val, 0x66u8, 64u64)
    if rn_publish(meta2, slots2, arena2, val, 0u64, 64u64, addr, 0u64) != 0u64 { return 27u64 }
    if rn_count(meta2) != 1u64 { return 28u64 }
    if used_of(meta2) != 64u64 { return 29u64 }

    free(meta); free(slots); free(arena); free(addr); free(val)
    free(meta2); free(slots2); free(arena2)
    return 99u64
}
