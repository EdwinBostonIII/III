/* 1031_intent_form_int_overflow.iii -- prove-the-negative for the verba form-parser integer
 * overflow guards (the two-stage decimal guard + the `>> 60` hex guard).  intent_form's value
 * parser shares byte-identical guard code with transform_form/pattern_form/http Content-Length;
 * intent_partial_arg returns the parsed value directly, so the boundary is observable.
 *
 * The decisive case: 2^64 ("...616").  A LONE `value > MAX/10` guard lets value==MAX/10 accept the
 * final digit and WRAP to 0 (off-by-one).  The two-stage guard (`*10` then `+digit`, reject on either
 * wrap -- matches verba::semver/parse) stops exactly at MAX/10.  This KAT fails on the broken guard
 * (would read 0) and on an over-aggressive guard (would reject the valid 2^64-1), so it pins the
 * boundary precisely.  Lengths are explicit (string literals are not NUL-terminated).
 * rc 99 = pass; 1..8 = which check failed. */
module corpus_1031

extern @abi(c-msvc-x64) fn intent_form_parse(src: u64, len: u64) -> u64 from "intent_form.iii"
extern @abi(c-msvc-x64) fn intent_partial_arg(p: u64, slot: u32) -> u64 from "intent.iii"

fn main() -> u64 {
    /* DECIMAL max u64 (2^64-1) parses EXACTLY -- the guard must not over-reject. */
    let s_max : u64 = ("arg0=18446744073709551615" as *u8) as u64   /* 25 chars */
    let p1 : u64 = intent_form_parse(s_max, 25u64)
    if p1 == 0u64 { return 1u64 }
    if intent_partial_arg(p1, 0u32) != 18446744073709551615u64 { return 2u64 }

    /* DECIMAL boundary 2^64 -- REJECTED at the overflow point; value frozen at MAX/10, NOT wrapped to 0. */
    let s_ovf : u64 = ("arg0=18446744073709551616" as *u8) as u64   /* 25 chars, 2^64 */
    let p2 : u64 = intent_form_parse(s_ovf, 25u64)
    if p2 == 0u64 { return 3u64 }
    if intent_partial_arg(p2, 0u32) != 1844674407370955161u64 { return 4u64 }   /* MAX/10, boundary caught */

    /* HEX 16 nibbles (2^64-1) parses EXACTLY. */
    let h_max : u64 = ("arg0=0xFFFFFFFFFFFFFFFF" as *u8) as u64      /* 23 chars */
    let p3 : u64 = intent_form_parse(h_max, 23u64)
    if p3 == 0u64 { return 5u64 }
    if intent_partial_arg(p3, 0u32) != 18446744073709551615u64 { return 6u64 }

    /* HEX 17th nibble -- REJECTED by the `>> 60` guard; value frozen at the 16-nibble max, not shifted out. */
    let h_ovf : u64 = ("arg0=0xFFFFFFFFFFFFFFFF0" as *u8) as u64     /* 24 chars, 17 nibbles */
    let p4 : u64 = intent_form_parse(h_ovf, 24u64)
    if p4 == 0u64 { return 7u64 }
    if intent_partial_arg(p4, 0u32) != 18446744073709551615u64 { return 8u64 }

    return 99u64
}
