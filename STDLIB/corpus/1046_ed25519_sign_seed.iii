/* 1046 — ed25519_sign_seed: the footgun-free signing entry that derives pk from
 * the seed internally. Proves a full sign->verify roundtrip for an ARBITRARY seed
 * + a NON-EMPTY message — exactly the case where the raw ed25519_sign with an
 * uninitialized pk silently produces an invalid signature. Negative arms: a
 * tampered message and a tampered signature must both be rejected. */
module corpus_1046
extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn ed25519_sign_seed(seed: *u8, msg: *u8, msg_len: u64, sig_out: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn ed25519_pubkey(seed: *u8, out_pk: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn ed25519_verify(pubkey: *u8, msg: *u8, msg_len: u64, sig: *u8) -> u8 from "crypt_ed25519.iii"

fn main() -> u64 {
    let seed : *u8 = malloc(32u64)
    let mut i : u64 = 0u64
    while i < 32u64 { seed[i] = 0x5Au8 + (i as u8)  i = i + 1u64 }
    let msg : *u8 = malloc(40u64)
    i = 0u64
    while i < 40u64 { msg[i] = 0xA0u8 + (i as u8)  i = i + 1u64 }
    let sig : *u8 = malloc(64u64)
    /* footgun-free: derives pk internally, then signs */
    if ed25519_sign_seed(seed, msg, 40u64, sig) != 1u8 { return 1u64 }
    let pk : *u8 = malloc(32u64)
    if ed25519_pubkey(seed, pk) != 1u8 { return 2u64 }
    /* POSITIVE: the signature verifies (raw-API footgun case now works) */
    if ed25519_verify(pk, msg, 40u64, sig) != 1u8 { return 3u64 }
    /* NEGATIVE 1: tampered message must be rejected */
    msg[7u64] = msg[7u64] ^ 0xFFu8
    if ed25519_verify(pk, msg, 40u64, sig) != 0u8 { return 4u64 }
    msg[7u64] = msg[7u64] ^ 0xFFu8
    /* NEGATIVE 2: tampered signature must be rejected */
    sig[20u64] = sig[20u64] ^ 0xFFu8
    if ed25519_verify(pk, msg, 40u64, sig) != 0u8 { return 5u64 }
    return 99u64
}
