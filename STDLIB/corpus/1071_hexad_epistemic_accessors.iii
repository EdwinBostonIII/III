/* 1071 -- omnia::hexad_epistemic field-accessor coverage (gap-backlog #86).
 *
 * Closes iii_hexad_epistemic_hexad/_questions/_domain (+ _confidence) field getters.
 * _make packs h@p0, conf@p1, questions=qd>>32@p2, domain=qd&0xFFFFFFFF@p3; the accessors
 * must read each field back distinctly.  A wrong field-read reddens an arm. 99 = pass.
 */
module corpus_1071

extern @abi(c-msvc-x64) fn iii_hexad_epistemic_make(buf_addr: u64, h: u16, conf_ppm: u32, qd: u64) -> i32 from "hexad_epistemic.iii"
extern @abi(c-msvc-x64) fn iii_hexad_epistemic_hexad(buf_addr: u64) -> u16 from "hexad_epistemic.iii"
extern @abi(c-msvc-x64) fn iii_hexad_epistemic_confidence(buf_addr: u64) -> u32 from "hexad_epistemic.iii"
extern @abi(c-msvc-x64) fn iii_hexad_epistemic_questions(buf_addr: u64) -> u32 from "hexad_epistemic.iii"
extern @abi(c-msvc-x64) fn iii_hexad_epistemic_domain(buf_addr: u64) -> u32 from "hexad_epistemic.iii"

var EBUF : [u8; 16]

fn main() -> u64 {
    let b : u64 = (&EBUF) as u64
    /* h=0x1234, conf=500000 (<= 1ppm clamp), qd = (7<<32)|0xABCD: questions=7, domain=0xABCD */
    if iii_hexad_epistemic_make(b, 0x1234u16, 500000u32, 0x70000ABCDu64) != 0i32 { return 1u64 }
    if iii_hexad_epistemic_hexad(b) != 0x1234u16 { return 2u64 }
    if iii_hexad_epistemic_confidence(b) != 500000u32 { return 3u64 }
    if iii_hexad_epistemic_questions(b) != 7u32 { return 4u64 }
    if iii_hexad_epistemic_domain(b) != 0xABCDu32 { return 5u64 }
    return 99u64
}
