/* 1080 -- numera::chacha20 scalar-vs-AVX bit-identity differential (gap-backlog #9).
 * Forces each keystream path via cc20_force_path and asserts byte-identical 64-byte blocks:
 *   path 1 (scalar) -- always runs; must equal the RFC 8439 §2.3.2 known answer;
 *   path 2 (avx512) / path 3 (avx2) -- run ONLY when cpufeat reports the ISA (else the forced
 *   block would execute illegal instructions), and must be byte-identical to the scalar block.
 * Resets force_path(0) at the end.  99 = pass.
 */
module corpus_1080

extern @abi(c-msvc-x64) fn chacha20_set_state(key: *u8, nonce: *u8, counter: u32) -> i32 from "chacha20.iii"
extern @abi(c-msvc-x64) fn chacha20_keystream(out: *u8) -> i32 from "chacha20.iii"
extern @abi(c-msvc-x64) fn cc20_force_path(p: u32) -> i32 from "chacha20.iii"
extern @abi(c-msvc-x64) fn cpufeat_has_avx2() -> u8 from "cpufeat.iii"
extern @abi(c-msvc-x64) fn cpufeat_has_avx512f() -> u8 from "cpufeat.iii"

var KEY      : [u8; 32]
var NONCE    : [u8; 12]
var B_SCALAR : [u8; 64]
var B_AVX    : [u8; 64]

fn check_rfc(o: u64) -> u64 {
    let p : *u8 = o as *u8
    if p[0u64]  != 0x10u8 { return 1u64 }
    if p[1u64]  != 0xF1u8 { return 2u64 }
    if p[15u64] != 0xC4u8 { return 3u64 }
    if p[16u64] != 0xC7u8 { return 4u64 }
    if p[31u64] != 0x4Eu8 { return 5u64 }
    if p[32u64] != 0xD2u8 { return 6u64 }
    if p[47u64] != 0xA2u8 { return 7u64 }
    if p[48u64] != 0xB5u8 { return 8u64 }
    if p[63u64] != 0x4Eu8 { return 9u64 }
    return 0u64
}

fn eq64(a: u64, b: u64) -> u8 {
    let pa : *u8 = a as *u8
    let pb : *u8 = b as *u8
    let mut i : u64 = 0u64
    while i < 64u64 { if pa[i] != pb[i] { return 0u8 } i = i + 1u64 }
    return 1u8
}

fn gen(path: u32, out: u64) -> i32 {
    cc20_force_path(path)
    chacha20_set_state((&KEY as u64) as *u8, (&NONCE as u64) as *u8, 1u32)
    chacha20_keystream(out as *u8)
    return 0i32
}

fn main() -> u64 {
    let mut i : u64 = 0u64
    while i < 32u64 { KEY[i] = i as u8; i = i + 1u64 }
    NONCE[0u64]=0u8  NONCE[1u64]=0u8  NONCE[2u64]=0u8  NONCE[3u64]=9u8
    NONCE[4u64]=0u8  NONCE[5u64]=0u8  NONCE[6u64]=0u8  NONCE[7u64]=0x4Au8
    NONCE[8u64]=0u8  NONCE[9u64]=0u8  NONCE[10u64]=0u8 NONCE[11u64]=0u8

    gen(1u32, (&B_SCALAR) as u64)
    let e : u64 = check_rfc((&B_SCALAR) as u64)
    if e != 0u64 { return 10u64 + e }

    if cpufeat_has_avx512f() == 1u8 {
        gen(2u32, (&B_AVX) as u64)
        if eq64((&B_AVX) as u64, (&B_SCALAR) as u64) != 1u8 { return 30u64 }
    }
    if cpufeat_has_avx2() == 1u8 {
        gen(3u32, (&B_AVX) as u64)
        if eq64((&B_AVX) as u64, (&B_SCALAR) as u64) != 1u8 { return 31u64 }
    }
    cc20_force_path(0u32)
    return 99u64
}
