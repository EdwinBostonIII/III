/* 1085 -- aether::http_client request-BUILDING surface (gap-backlog #1).
 * The six request-builder exports (http_method/http_path/http_header_name/http_header_value/
 * http_end_headers/http_body) had no test and no caller anywhere.  This drives them into a
 * verba/builder and byte-asserts the EXACT emitted wire form, then a negative arm proves a
 * bad builder_id propagates the non-HTTP_OK rc (not silently swallowed).
 *
 *   "GET /x HTTP/1.1\r\nHost: h\r\n\r\nBODY"  (32 bytes)
 *
 * 99 = pass.  Mirrors corpus 65 (the http_server send side).
 */
module corpus_1085

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn builder_new(arena: u64, hint: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_seal(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_len(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn http_method(builder_id: u64, method_base: u64, method_len: u64) -> i32 from "http_client.iii"
extern @abi(c-msvc-x64) fn http_path(builder_id: u64, path_base: u64, path_len: u64) -> i32 from "http_client.iii"
extern @abi(c-msvc-x64) fn http_header_name(builder_id: u64, name_base: u64, name_len: u64) -> i32 from "http_client.iii"
extern @abi(c-msvc-x64) fn http_header_value(builder_id: u64, value_base: u64, value_len: u64) -> i32 from "http_client.iii"
extern @abi(c-msvc-x64) fn http_end_headers(builder_id: u64) -> i32 from "http_client.iii"
extern @abi(c-msvc-x64) fn http_body(builder_id: u64, body_base: u64, body_len: u64) -> i32 from "http_client.iii"

var GET  : [u8; 3]    /* "GET" */
var PATH : [u8; 2]    /* "/x"  */
var HNAM : [u8; 4]    /* "Host" */
var HVAL : [u8; 1]    /* "h"  */
var BODY : [u8; 4]    /* "BODY" */
var EXP  : [u8; 32]   /* full expected wire */

fn main() -> u64 {
    GET[0u64]  = 71u8  GET[1u64]  = 69u8  GET[2u64]  = 84u8                       /* G E T */
    PATH[0u64] = 47u8  PATH[1u64] = 120u8                                          /* / x   */
    HNAM[0u64] = 72u8  HNAM[1u64] = 111u8 HNAM[2u64] = 115u8 HNAM[3u64] = 116u8    /* H o s t */
    HVAL[0u64] = 104u8                                                             /* h     */
    BODY[0u64] = 66u8  BODY[1u64] = 79u8  BODY[2u64] = 68u8  BODY[3u64] = 89u8     /* B O D Y */

    /* expected: "GET /x HTTP/1.1\r\nHost: h\r\n\r\nBODY" */
    EXP[0u64]=71u8  EXP[1u64]=69u8  EXP[2u64]=84u8  EXP[3u64]=32u8                 /* "GET " */
    EXP[4u64]=47u8  EXP[5u64]=120u8 EXP[6u64]=32u8                                 /* "/x "  */
    EXP[7u64]=72u8  EXP[8u64]=84u8  EXP[9u64]=84u8  EXP[10u64]=80u8  EXP[11u64]=47u8 /* "HTTP/" */
    EXP[12u64]=49u8 EXP[13u64]=46u8 EXP[14u64]=49u8                                /* "1.1"  */
    EXP[15u64]=13u8 EXP[16u64]=10u8                                                /* CRLF  */
    EXP[17u64]=72u8 EXP[18u64]=111u8 EXP[19u64]=115u8 EXP[20u64]=116u8 EXP[21u64]=58u8 EXP[22u64]=32u8 /* "Host: " */
    EXP[23u64]=104u8 EXP[24u64]=13u8 EXP[25u64]=10u8                               /* "h"CRLF */
    EXP[26u64]=13u8 EXP[27u64]=10u8                                                /* CRLF (end headers) */
    EXP[28u64]=66u8 EXP[29u64]=79u8 EXP[30u64]=68u8 EXP[31u64]=89u8                /* "BODY" */

    let a : u64 = arena_new(1u64 << 16u64)
    let b : u64 = builder_new(a, 256u64)
    if b == 0u64 { return 1u64 }

    /* positive arm: each builder call returns HTTP_OK (0) */
    if http_method(b, &GET as u64, 3u64)        != 0i32 { return 2u64 }
    if http_path(b, &PATH as u64, 2u64)         != 0i32 { return 3u64 }
    if http_header_name(b, &HNAM as u64, 4u64)  != 0i32 { return 4u64 }
    if http_header_value(b, &HVAL as u64, 1u64) != 0i32 { return 5u64 }
    if http_end_headers(b)                      != 0i32 { return 6u64 }
    if http_body(b, &BODY as u64, 4u64)         != 0i32 { return 7u64 }

    /* exact wire form */
    if builder_len(b) != 32u64 { return 8u64 }
    let buf : *u8 = builder_seal(b) as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        if buf[i] != EXP[i] { return 100u64 + i }
        i = i + 1u64
    }

    /* negative arm: a bad builder_id propagates the non-HTTP_OK rc (BLD_E_BADID = -3), NOT 0 */
    if http_method(0xDEADu64, &GET as u64, 3u64) == 0i32 { return 9u64 }
    if http_body(0xDEADu64, &BODY as u64, 4u64)  == 0i32 { return 10u64 }

    arena_drop(a)
    return 99u64
}
