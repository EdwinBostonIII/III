/* 1108_sov_self_extend.iii -- THE SELF-IMPROVEMENT LOOP, REALIZED.
 *
 * The whole point of confluence + bit-determinism + nous + the forcefield: a loop where III uses its
 * own systematic reasoning to IMPROVE and ADD to itself.  This is that loop, run for real.
 *
 * III extends its OWN sov_isa optimizer with a new rule -- mul(1,2) -> 2 (Rule G) -- that it lacked
 * (mul(1,2) previously descended only to shl(1,1), 3 nodes).  The e-graph (untrusted "nous") PROPOSES
 * the fold; III's CIC kernel (the trusted core) DISPOSES it (certifies 1*2 == 2) and GOVERNS it
 * (rejects the meaning-changing 1*2 == 1).  Drives numera/sov_isa::sov_isa_selfext_kat -- no logic here:
 *   (1) IMPROVEMENT: the optimizer now folds mul(1,2) to the single literal 2 (a capability it gained).
 *   (2) KERNEL DISPOSES: the kernel certifies the rule sound.
 *   (3) KERNEL GOVERNS: the kernel rejects the unsound variant.
 * No rigging: the optimization is the e-graph's; every acceptance is the kernel's.  99 = the loop ran. */
module corpus_1108

extern @abi(c-msvc-x64) fn sov_isa_selfext_kat() -> u64 from "sov_isa.iii"

fn main() -> u64 {
    let r : u64 = sov_isa_selfext_kat()
    if r != 99u64 { return r }
    return 99u64
}
