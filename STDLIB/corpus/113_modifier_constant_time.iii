/* Lattice plan Step 0010: @constant_time discipline.
 * The body must avoid data-dependent branches; the equality test below
 * uses an arithmetic trick: (a^b == 0) ⇔ ((a^b)-1 >> 63) == 1. */
module corpus_113

fn ct_eq(a: u64, b: u64) -> u8 @constant_time {
    return (((a ^ b) - 1u64) >> 63u64) as u8
}

fn main() -> u64 {
    if ct_eq(7u64, 7u64) != 1u8 { return 1u64 }
    if ct_eq(7u64, 8u64) != 0u8 { return 2u64 }
    return 99u64
}
