/* 1211_commons_cite_reuse.iii -- PROOF REUSE: the optimizer CITES the Theorem Commons (loop closed).
 *
 * sov_cite_or_prove_strength checks the Commons FIRST: on a miss it proves + admits the strength schema
 * (returns 88); on a hit it CITES the kernel-certified theorem by content-address and SKIPS the expensive
 * proof (returns 77). This closes the propose->prove->persist->CITE loop: a kernel proof, certified once,
 * is reused by content-address instead of being recomputed -- proof-carrying optimization that gets cheaper
 * as III's certified repertoire grows. No other compiler reuses KERNEL PROOFS this way.
 *
 * (1) empty commons; (2) COLD call -> 88 (proved + admitted); (3) size 1; (4) WARM call -> 77 (cited, proof
 * skipped); (5) size still 1 (cited, not re-admitted). 99 = the reuse path is real (77 != 88 distinguishes
 * cite from prove). */
module corpus_1211

extern @abi(c-msvc-x64) fn tcom_init() -> i32 from "theorem_commons.iii"
extern @abi(c-msvc-x64) fn tcom_size() -> u64 from "theorem_commons.iii"
extern @abi(c-msvc-x64) fn sov_cite_or_prove_strength() -> u64 from "sov_isa.iii"

fn main() -> u64 {
    tcom_init()
    if tcom_size() != 0u64 { return 1u64 }
    if sov_cite_or_prove_strength() != 88u64 { return 2u64 }   /* COLD: prove + admit */
    if tcom_size() != 1u64 { return 3u64 }
    if sov_cite_or_prove_strength() != 77u64 { return 4u64 }   /* WARM: CITE, skip the proof */
    if tcom_size() != 1u64 { return 5u64 }
    return 99u64
}
