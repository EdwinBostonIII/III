/* memoria::arena + memoria::region — provable reset (APOTHEOSIS S.7 / ADR-S7b).
 * The advisory clear_fn registry (arena_reset_safe / region_reset_safe) was
 * retired in favour of arena_reset_with_witness: a reset fires only if the
 * caller holds the arena's current incarnation witness, and is refused on a
 * wrong witness.  region keeps the plain region_reset. */
module corpus_121

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_alloc8(id: u64, n: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_used(id: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_witness_lo(id: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_witness_hi(id: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_reset_with_witness(id: u64, w_lo: u64, w_hi: u64) -> i32 from "arena.iii"

extern @abi(c-msvc-x64) fn region_create(bytes: u64) -> u64 from "region.iii"
extern @abi(c-msvc-x64) fn region_release(id: u64) -> i32 from "region.iii"
extern @abi(c-msvc-x64) fn region_alloc(id: u64, n: u64, align: u64) -> u64 from "region.iii"
extern @abi(c-msvc-x64) fn region_used(id: u64) -> u64 from "region.iii"
extern @abi(c-msvc-x64) fn region_reset(id: u64) -> i32 from "region.iii"

fn main() -> u64 {
    /* arena path: witnessed reset */
    let a : u64 = arena_new(1u64 << 12u64)
    if a == 0u64 { return 1u64 }
    let _p1 : u64 = arena_alloc8(a, 64u64)
    if arena_used(a) == 0u64 { return 2u64 }

    let wlo : u64 = arena_witness_lo(a)
    let whi : u64 = arena_witness_hi(a)

    /* correct witness -> reset succeeds, used -> 0 */
    if arena_reset_with_witness(a, wlo, whi) != 0i32 { return 3u64 }
    if arena_used(a) != 0u64 { return 4u64 }

    /* wrong witness (lo+1 cannot equal the real lo) -> REFUSE, used preserved */
    let _p2 : u64 = arena_alloc8(a, 64u64)
    if arena_reset_with_witness(a, wlo + 1u64, whi) != -7i32 { return 5u64 }
    if arena_used(a) == 0u64 { return 6u64 }
    /* the real witness still works */
    if arena_reset_with_witness(a, wlo, whi) != 0i32 { return 7u64 }
    if arena_used(a) != 0u64 { return 8u64 }
    arena_drop(a)

    /* region path: plain reset */
    let r : u64 = region_create(1u64 << 12u64)
    if r == 0u64 { return 10u64 }
    let _q1 : u64 = region_alloc(r, 64u64, 8u64)
    if region_used(r) == 0u64 { return 11u64 }
    if region_reset(r) != 0i32 { return 12u64 }
    if region_used(r) != 0u64 { return 13u64 }
    region_release(r)

    return 99u64
}
