/* 1220_ru_kernel_merge.iii -- KERNEL-DISCHARGED CERTIFIED MERGE (harmony loop item 1).
 *
 * ripple_unify's certified-refactoring merge previously took proof_ok as a caller LITERAL that NO in-tree
 * module discharged via the CIC kernel for a class MERGE -- the one faked gate in the self-refactoring loop.
 * ru_certify_unify_kernel now computes proof_ok = tc_check(proof, goal), genuinely composing ripple_unify
 * <-> congruence <-> the kernel.  Three arms prove the gate is now sound AND non-vacuous:
 *  (1) POSITIVE -- two DISTINCT content-address classes are MERGED via a kernel-checked beta-iota equality
 *      Id(Bool, (λx.x)true, true) with proof refl(true);
 *  (2) FALSE-GOAL NEGATIVE -- a false goal Id(Bool,true,false) makes tc_check==0 -> the merge is REFUSED,
 *      classes untouched (the soundness arm the caller-literal proof_ok could not enforce);
 *  (3) INTENT-VETO NEGATIVE -- an intentional-variation pair (different intent-class) WITH a valid kernel
 *      proof is STILL refused (behavioral equality is necessary, not sufficient -- the cpufeat lesson).
 * 99 = all three hold. */
module corpus_1243

extern @abi(c-msvc-x64) fn cgr_init() -> i32 from "congruence.iii"
extern @abi(c-msvc-x64) fn cgr_intern(p: *u8, cost: u64) -> u32 from "congruence.iii"
extern @abi(c-msvc-x64) fn cgr_find(i: u32) -> u32 from "congruence.iii"
extern @abi(c-msvc-x64) fn rm_reset() -> u64 from "ripple_metric.iii"
extern @abi(c-msvc-x64) fn rm_add_node(cap: u64, iclass: u32) -> u32 from "ripple_metric.iii"
extern @abi(c-msvc-x64) fn tc_reset() -> u64 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bool() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_true() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_false() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_var(k: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_lam(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_app(f: u32, a: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_id(ty: u32, l: u32, r: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_refl(v: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn ru_certify_unify_kernel(node_i: u32, node_j: u32, class_i: u32, class_j: u32, proof: u32, goal: u32) -> u32 from "ripple_unify.iii"

var ADDR_A : [u8; 32]
var ADDR_B : [u8; 32]

fn fill32(p: *u8, b: u8) -> u64 {
    let mut i : u64 = 0u64
    while i < 32u64 { p[i] = b ; i = i + 1u64 }
    return 0u64
}

/* fresh, distinct content-address classes + a clean kernel arena each arm. */
fn setup() -> u64 {
    cgr_init()
    rm_reset()
    tc_reset()
    fill32((&ADDR_A) as u64 as *u8, 0xAAu8)
    fill32((&ADDR_B) as u64 as *u8, 0xBBu8)
    return 0u64
}

/* the true beta-iota equality goal: (λx:Bool. x) true == true, with proof refl(true). */
fn true_goal() -> u32 {
    return tc_id(tc_bool(), tc_app(tc_lam(tc_bool(), tc_var(0u32)), tc_true()), tc_true())
}

fn main() -> u64 {
    /* ---- ARM 1: POSITIVE -- distinct classes MERGED via the kernel-checked equality ---- */
    setup()
    let ci : u32 = cgr_intern((&ADDR_A) as u64 as *u8, 10u64)
    let cj : u32 = cgr_intern((&ADDR_B) as u64 as *u8, 20u64)
    if cgr_find(ci) == cgr_find(cj) { return 1u64 }                                    /* must START distinct */
    let ni : u32 = rm_add_node(0x1234u64, 7u32)
    let nj : u32 = rm_add_node(0x1234u64, 7u32)                                        /* cap+intent equal -> unifiable */
    if ru_certify_unify_kernel(ni, nj, ci, cj, tc_refl(tc_true()), true_goal()) != 1u32 { return 2u64 }
    if cgr_find(ci) != cgr_find(cj) { return 3u64 }                                    /* genuinely MERGED */

    /* ---- ARM 2: FALSE-GOAL NEGATIVE -- tc_check==0 -> REFUSED, classes untouched ---- */
    setup()
    let di : u32 = cgr_intern((&ADDR_A) as u64 as *u8, 10u64)
    let dj : u32 = cgr_intern((&ADDR_B) as u64 as *u8, 20u64)
    let mi : u32 = rm_add_node(0x1234u64, 7u32)
    let mj : u32 = rm_add_node(0x1234u64, 7u32)
    let badgoal : u32 = tc_id(tc_bool(), tc_true(), tc_false())                        /* Id(Bool,true,false) -- FALSE */
    if ru_certify_unify_kernel(mi, mj, di, dj, tc_refl(tc_true()), badgoal) != 0u32 { return 4u64 }
    if cgr_find(di) == cgr_find(dj) { return 5u64 }                                    /* NOT merged (soundness) */

    /* ---- ARM 3: INTENT-VETO NEGATIVE -- valid proof but intent-class differs -> REFUSED ---- */
    setup()
    let ei : u32 = cgr_intern((&ADDR_A) as u64 as *u8, 10u64)
    let ej : u32 = cgr_intern((&ADDR_B) as u64 as *u8, 20u64)
    let vi : u32 = rm_add_node(0x1234u64, 7u32)
    let vj : u32 = rm_add_node(0x1234u64, 9u32)                                        /* DIFFERENT intent-class */
    if ru_certify_unify_kernel(vi, vj, ei, ej, tc_refl(tc_true()), true_goal()) != 0u32 { return 6u64 }
    if cgr_find(ei) == cgr_find(ej) { return 7u64 }                                    /* NOT merged (intent gate) */

    return 99u64
}
