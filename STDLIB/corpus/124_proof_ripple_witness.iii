/* Lattice plan Steps 0019 + 0020 — proof_ripple_equivalence mints +
 * verifies an equivalence cert; witness_append_ripple grows the
 * append-only chain with a ripple-tagged record. */
module corpus_124

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"

extern @abi(c-msvc-x64) fn crystal_mint(error_code: u32, site_hash_ptr: u64,
                                         cap_id: u64, cause_seq: u64) -> u64 from "crystal.iii"
extern @abi(c-msvc-x64) fn crystal_drop(id: u64) -> i32 from "crystal.iii"

extern @abi(c-msvc-x64) fn proof_ripple_equivalence(old_id: u64, new_id: u64,
                                                     corpus_witness: u64) -> u64 from "proof_ripple.iii"
extern @abi(c-msvc-x64) fn proof_ripple_verify(cert_id: u64, old_id: u64, new_id: u64,
                                                corpus_witness: u64) -> u8 from "proof_ripple.iii"

extern @abi(c-msvc-x64) fn witness_init() -> i32 from "witness.iii"
extern @abi(c-msvc-x64) fn witness_count() -> u32 from "witness.iii"
extern @abi(c-msvc-x64) fn witness_append_ripple(mhash_ptr: u64, ripple_result: u64) -> i32 from "witness.iii"

fn fill(p: *u8, v: u8) -> u32 {
    let mut i : u64 = 0u64
    while i < 32u64 {
        p[i] = v
        i = i + 1u64
    }
    return 0u32
}

fn main() -> u64 {
    witness_init()
    let prior_w : u32 = witness_count()

    let site : *u8 = malloc(32u64)
    let cw   : *u8 = malloc(32u64)
    fill(site, 0u8)
    fill(cw, 0x77u8)

    let _a : u64 = arena_new(1u64 << 12u64)
    let old_c : u64 = crystal_mint(0u32, site as u64, 0u64, 0u64)
    let new_c : u64 = crystal_mint(0u32, site as u64, 0u64, 0u64)
    if old_c == 0u64 { return 1u64 }
    if new_c == 0u64 { return 2u64 }

    /* Mint cert; verify it. */
    let cert : u64 = proof_ripple_equivalence(old_c, new_c, cw as u64)
    if cert == 0u64 { return 3u64 }
    if proof_ripple_verify(cert, old_c, new_c, cw as u64) != 1u8 { return 4u64 }

    /* Tampering: pass the wrong witness ptr → verify fails. */
    let bad : *u8 = malloc(32u64)
    fill(bad, 0xAAu8)
    if proof_ripple_verify(cert, old_c, new_c, bad as u64) != 0u8 { return 5u64 }
    free(bad)

    /* Append a ripple-tagged witness record; assert chain grew by 1. */
    if witness_append_ripple(cw as u64, cert) != 0i32 { return 6u64 }
    if witness_count() != prior_w + 1u32 { return 7u64 }

    crystal_drop(old_c); crystal_drop(new_c); crystal_drop(cert)
    free(site); free(cw)
    return 99u64
}
