/* 1272_reduced_product.iii -- emergent precision from domain intersection (interval x parity).
 * Drives numera::reduced_product::reduced_product_kat: 99 = reduction tightens [3,8] even to [4,8]; the
 * reduced product [2,9]+even has 4 values, strictly below the interval's 8 (emergent precision); addition
 * carries both dimensions ([2,4]even + [1,3]odd = [3,7] odd = {3,5,7}); and every concrete sum lands in the
 * product (sound). Two granular analyses intersecting to be sharper than either alone. */
module corpus_1272

extern @abi(c-msvc-x64) fn reduced_product_kat() -> u64 from "reduced_product.iii"

fn main() -> u64 {
    let r : u64 = reduced_product_kat()
    if r != 99u64 { return r }
    return 99u64
}
