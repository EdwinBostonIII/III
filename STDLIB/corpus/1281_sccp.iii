/* 1281_sccp.iii -- constant propagation over the constant lattice, verified.
 * Drives numera::sccp::sccp_kat: 99 = v0+v1 folds to constant 5 and v0*v1 to 6; v0+input is VARYING (a
 * constant plus a runtime value); phi of differing constants (5,6) is VARYING while phi of equal constants
 * (5,5) is the constant 5; the runtime input is VARYING and no value is left UNDEF. The constant-folding
 * heart of sparse conditional constant propagation. */
module corpus_1281

extern @abi(c-msvc-x64) fn sccp_kat() -> u64 from "sccp.iii"

fn main() -> u64 {
    let r : u64 = sccp_kat()
    if r != 99u64 { return r }
    return 99u64
}
