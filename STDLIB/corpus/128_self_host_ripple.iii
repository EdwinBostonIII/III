/* Lattice plan Step 0026 — self-host ripple end-to-end:
 *  1. Build a small lattice (3 crystals with edges).
 *  2. Register dynamic mode + dynamic_impact for each crystal.
 *  3. Mint a change against one of them; analyze; execute(strict); verify.
 *  4. Commit; query layered_seal; assert all bookkeeping consistent.
 *  5. JIT-swap-acquire/release on a crystal; assert no double-decrement.
 */
module corpus_128

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"

extern @abi(c-msvc-x64) fn crystal_mint(error_code: u32, site_hash_ptr: u64,
                                         cap_id: u64, cause_seq: u64) -> u64 from "crystal.iii"
extern @abi(c-msvc-x64) fn crystal_drop(id: u64) -> i32 from "crystal.iii"
extern @abi(c-msvc-x64) fn crystal_edges_init(id: u64, arena_id: u64) -> i32 from "crystal.iii"
extern @abi(c-msvc-x64) fn crystal_edges_add(parent: u64, child: u64) -> i32 from "crystal.iii"

extern @abi(c-msvc-x64) fn ripple_change_new(arena_id: u64, kind: u32, target: u64,
                                              old_mhash: u64, new_mhash: u64) -> u64 from "ripple.iii"
extern @abi(c-msvc-x64) fn ripple_analyze(arena_id: u64, change_id: u64) -> u64 from "ripple.iii"
extern @abi(c-msvc-x64) fn ripple_execute(arena_id: u64, plan_id: u64, mode: u32) -> u64 from "ripple.iii"
extern @abi(c-msvc-x64) fn ripple_verify(result_id: u64) -> u8 from "ripple.iii"
extern @abi(c-msvc-x64) fn ripple_commit(result_id: u64) -> u64 from "ripple.iii"

extern @abi(c-msvc-x64) fn dynamic_record_register(id: u64, mode: u32) -> i32 from "dynamic_record.iii"
extern @abi(c-msvc-x64) fn dynamic_record_lookup(id: u64) -> u32 from "dynamic_record.iii"

extern @abi(c-msvc-x64) fn dynamic_impact_register(id: u64, perf: u32, ux: u32) -> i32 from "dynamic_impact.iii"
extern @abi(c-msvc-x64) fn dynamic_impact_count() -> u32 from "dynamic_impact.iii"

extern @abi(c-msvc-x64) fn jit_swap_acquire(id: u64) -> i32 from "jit_swap.iii"
extern @abi(c-msvc-x64) fn jit_swap_release(id: u64) -> i32 from "jit_swap.iii"
extern @abi(c-msvc-x64) fn jit_swap_owned_count(id: u64) -> u32 from "jit_swap.iii"

extern @abi(c-msvc-x64) fn layered_seal_emit(prev: u64, new_r: u64) -> i32 from "layered_seal.iii"
extern @abi(c-msvc-x64) fn layered_seal_has() -> u8 from "layered_seal.iii"
extern @abi(c-msvc-x64) fn layered_seal_size() -> u32 from "layered_seal.iii"

fn fill(p: *u8, v: u8) -> u32 {
    let mut i : u64 = 0u64
    while i < 32u64 {
        p[i] = v
        i = i + 1u64
    }
    return 0u32
}

fn main() -> u64 {
    let site : *u8 = malloc(32u64)
    let old_h : *u8 = malloc(32u64)
    let new_h : *u8 = malloc(32u64)
    fill(site, 0u8)
    fill(old_h, 0xAAu8)
    fill(new_h, 0xBBu8)

    let ar : u64 = arena_new(1u64 << 16u64)
    if ar == 0u64 { return 1u64 }

    /* 3-crystal lattice: A → B → C. */
    let a : u64 = crystal_mint(0u32, site as u64, 0u64, 0u64)
    let b : u64 = crystal_mint(0u32, site as u64, 0u64, 0u64)
    let c : u64 = crystal_mint(0u32, site as u64, 0u64, 0u64)
    if a == 0u64 { return 2u64 }
    if b == 0u64 { return 3u64 }
    if c == 0u64 { return 4u64 }
    crystal_edges_init(a, ar)
    crystal_edges_init(b, ar)
    crystal_edges_init(c, ar)
    crystal_edges_add(a, b)
    crystal_edges_add(b, c)

    /* Register dynamic mode + impact for each crystal. */
    if dynamic_record_register(a, 1u32) != 0i32 { return 5u64 }
    if dynamic_record_register(b, 1u32) != 0i32 { return 6u64 }
    if dynamic_record_register(c, 2u32) != 0i32 { return 7u64 }
    if dynamic_record_lookup(a) != 1u32 { return 8u64 }
    if dynamic_record_lookup(c) != 2u32 { return 9u64 }

    if dynamic_impact_register(a, 200u32, 10u32) != 0i32 { return 10u64 }
    if dynamic_impact_register(b, 100u32,  5u32) != 0i32 { return 11u64 }
    if dynamic_impact_count() < 2u32 { return 12u64 }

    /* Ripple a change against A. */
    let chg : u64 = ripple_change_new(ar, 1u32, a, old_h as u64, new_h as u64)
    if chg == 0u64 { return 13u64 }
    let plan : u64 = ripple_analyze(ar, chg)
    if plan == 0u64 { return 14u64 }
    let result : u64 = ripple_execute(ar, plan, 1u32)
    if result == 0u64 { return 15u64 }
    if ripple_verify(result) != 1u8 { return 16u64 }
    let commit : u64 = ripple_commit(result)
    if commit == 0u64 { return 17u64 }

    /* Layered seal record across the change. */
    if layered_seal_emit(old_h as u64, new_h as u64) != 0i32 { return 18u64 }
    if layered_seal_has() != 1u8 { return 19u64 }
    if layered_seal_size() != 128u32 { return 20u64 }

    /* JIT-swap acquire/release symmetry. */
    if jit_swap_acquire(b) != 0i32 { return 21u64 }
    if jit_swap_acquire(b) != 0i32 { return 22u64 }
    if jit_swap_owned_count(b) != 2u32 { return 23u64 }
    if jit_swap_release(b) != 0i32 { return 24u64 }
    if jit_swap_release(b) != 0i32 { return 25u64 }
    if jit_swap_owned_count(b) != 0u32 { return 26u64 }

    crystal_drop(a); crystal_drop(b); crystal_drop(c)
    crystal_drop(chg); crystal_drop(plan); crystal_drop(result); crystal_drop(commit)
    arena_drop(ar)
    free(site); free(old_h); free(new_h)
    return 99u64
}
