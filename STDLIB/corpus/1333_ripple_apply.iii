/* 1333_ripple_apply.iii -- the Sovereign Ripple Calculus CUT applier's source tier (forcefield::ripple_apply).
 * Drives ra_cut_fn: 99 = the applier excises exactly the named top-level fn from .iii source bytes, producing
 * an edited candidate. Proven (prove-the-negative):
 *   (1-2) cut the second / first fn -> the OTHER fn survives, the cut one is gone (handles a fn at the start);
 *   (3)   cutting an ABSENT name -> RA_E_NOTFOUND (-1), not a corrupt edit;
 *   (4)   NESTED braces in the body are matched -- cutting an outer fn with `{{}}` removes the WHOLE fn, the
 *         following fn intact (the brace counter is correct, not first-`}`);
 *   (5)   a `fn NAME` that occurs only inside a /* comment */ is NOT matched (the scanner skips comments) -> -1. */
module corpus_1333

extern @abi(c-msvc-x64) fn ra_cut_fn(src: *u8, src_len: u64, fn_name: *u8, name_len: u64, out: *u8, out_cap: u64) -> i64 from "ripple_apply.iii"

var OUT : [u8; 256]

var SRC1 : [u8; 17] = [0x66u8,0x6Eu8,0x20u8,0x61u8,0x28u8,0x29u8,0x7Bu8,0x7Du8,0x20u8,0x66u8,0x6Eu8,0x20u8,0x62u8,0x28u8,0x29u8,0x7Bu8,0x7Du8]                                                   /* "fn a(){} fn b(){}"     */
var SRC2 : [u8; 19] = [0x66u8,0x6Eu8,0x20u8,0x70u8,0x28u8,0x29u8,0x7Bu8,0x7Bu8,0x7Du8,0x7Du8,0x20u8,0x66u8,0x6Eu8,0x20u8,0x71u8,0x28u8,0x29u8,0x7Bu8,0x7Du8]                                  /* "fn p(){{}} fn q(){}"   */
var SRC3 : [u8; 23] = [0x2Fu8,0x2Au8,0x20u8,0x66u8,0x6Eu8,0x20u8,0x67u8,0x28u8,0x29u8,0x7Bu8,0x7Du8,0x20u8,0x2Au8,0x2Fu8,0x20u8,0x66u8,0x6Eu8,0x20u8,0x72u8,0x28u8,0x29u8,0x7Bu8,0x7Du8]     /* "/* fn g(){} */ fn r(){}" */

var NM_A : [u8; 1] = [0x61u8]
var NM_B : [u8; 1] = [0x62u8]
var NM_C : [u8; 1] = [0x63u8]
var NM_P : [u8; 1] = [0x70u8]
var NM_G : [u8; 1] = [0x67u8]
var FN_A : [u8; 4] = [0x66u8,0x6Eu8,0x20u8,0x61u8]   /* "fn a" */
var FN_B : [u8; 4] = [0x66u8,0x6Eu8,0x20u8,0x62u8]   /* "fn b" */
var FN_P : [u8; 4] = [0x66u8,0x6Eu8,0x20u8,0x70u8]   /* "fn p" */
var FN_Q : [u8; 4] = [0x66u8,0x6Eu8,0x20u8,0x71u8]   /* "fn q" */

extern @abi(c-msvc-x64) fn ra_merge_fn(src: *u8, src_len: u64, fn_name: *u8, name_len: u64, canon: *u8, canon_len: u64, out: *u8, out_cap: u64) -> i64 from "ripple_apply.iii"
var SRC4 : [u8; 14] = [0x66u8,0x6Eu8,0x20u8,0x64u8,0x28u8,0x29u8,0x2Du8,0x3Eu8,0x75u8,0x33u8,0x32u8,0x7Bu8,0x78u8,0x7Du8]  /* "fn d()->u32{x}" */
var NM_D : [u8; 1] = [0x64u8]
var MOD_M : [u8; 1] = [0x6Du8]                                                  /* "m" */
var N_EXTERN : [u8; 6] = [0x65u8,0x78u8,0x74u8,0x65u8,0x72u8,0x6Eu8]            /* "extern" */
var N_FROM   : [u8; 4] = [0x66u8,0x72u8,0x6Fu8,0x6Du8]                          /* "from"   */
var N_BODY   : [u8; 3] = [0x7Bu8,0x78u8,0x7Du8]                                 /* "{x}"    */
var FN_D     : [u8; 4] = [0x66u8,0x6Eu8,0x20u8,0x64u8]                          /* "fn d"   */

extern @abi(c-msvc-x64) fn ra_extract_module(fn_src: *u8, fn_src_len: u64, mod_name: *u8, mod_name_len: u64, out: *u8, out_cap: u64) -> i64 from "ripple_apply.iii"
var SRC5 : [u8; 14] = [0x66u8,0x6Eu8,0x20u8,0x73u8,0x28u8,0x29u8,0x2Du8,0x3Eu8,0x75u8,0x33u8,0x32u8,0x7Bu8,0x35u8,0x7Du8]  /* "fn s()->u32{5}" (no @export) */
var MOD_SHARED : [u8; 6] = [0x73u8,0x68u8,0x61u8,0x72u8,0x65u8,0x64u8]          /* "shared"  */
var N_MODULE   : [u8; 6] = [0x6Du8,0x6Fu8,0x64u8,0x75u8,0x6Cu8,0x65u8]          /* "module"  */
var FN_S       : [u8; 4] = [0x66u8,0x6Eu8,0x20u8,0x73u8]                        /* "fn s"    */
var N_EXPORT2  : [u8; 7] = [0x40u8,0x65u8,0x78u8,0x70u8,0x6Fu8,0x72u8,0x74u8]   /* "@export" */
var N_BODY5    : [u8; 3] = [0x7Bu8,0x35u8,0x7Du8]                               /* "{5}"     */

extern @abi(c-msvc-x64) fn ra_apply(move_kind: u32, src: *u8, src_len: u64, fn_name: *u8, name_len: u64, aux: *u8, aux_len: u64, out: *u8, out_cap: u64) -> i64 from "ripple_apply.iii"
extern @abi(c-msvc-x64) fn ra_check_balanced(src: *u8, src_len: u64) -> u8 from "ripple_apply.iii"
var UNBAL : [u8; 7] = [0x66u8,0x6Eu8,0x20u8,0x78u8,0x28u8,0x29u8,0x7Bu8]        /* "fn x(){" (unbalanced) */

fn contains(buf: u64, len: u64, needle: u64, nlen: u64) -> u8 {
    if nlen > len { return 0u8 }
    let bp : *u8 = buf as *u8
    let np : *u8 = needle as *u8
    let lim : u64 = len - nlen
    let mut i : u64 = 0u64
    while i <= lim {
        let mut k : u64 = 0u64
        let mut m : u8 = 1u8
        while k < nlen {
            if bp[i + k] != np[k] { m = 0u8  k = nlen } else { k = k + 1u64 }
        }
        if m == 1u8 { return 1u8 }
        i = i + 1u64
    }
    return 0u8
}

fn main() -> u64 {
    /* (1) cut "b" -> "fn a" survives, "fn b" gone */
    let n1 : i64 = ra_cut_fn(&SRC1 as *u8, 17u64, &NM_B as *u8, 1u64, &OUT as *u8, 256u64)
    if n1 <= 0i64 { return 1u64 }
    if contains(&OUT as u64, n1 as u64, &FN_A as u64, 4u64) != 1u8 { return 2u64 }
    if contains(&OUT as u64, n1 as u64, &FN_B as u64, 4u64) != 0u8 { return 3u64 }
    /* (2) cut "a" (the first fn) -> "fn b" survives, "fn a" gone */
    let n2 : i64 = ra_cut_fn(&SRC1 as *u8, 17u64, &NM_A as *u8, 1u64, &OUT as *u8, 256u64)
    if n2 <= 0i64 { return 4u64 }
    if contains(&OUT as u64, n2 as u64, &FN_B as u64, 4u64) != 1u8 { return 5u64 }
    if contains(&OUT as u64, n2 as u64, &FN_A as u64, 4u64) != 0u8 { return 6u64 }
    /* (3) absent name -> -1 */
    if ra_cut_fn(&SRC1 as *u8, 17u64, &NM_C as *u8, 1u64, &OUT as *u8, 256u64) != -1i64 { return 7u64 }
    /* (4) nested braces: cut "p" -> "fn q" survives, "fn p" (whole nested body) gone */
    let n4 : i64 = ra_cut_fn(&SRC2 as *u8, 19u64, &NM_P as *u8, 1u64, &OUT as *u8, 256u64)
    if n4 <= 0i64 { return 8u64 }
    if contains(&OUT as u64, n4 as u64, &FN_Q as u64, 4u64) != 1u8 { return 9u64 }
    if contains(&OUT as u64, n4 as u64, &FN_P as u64, 4u64) != 0u8 { return 10u64 }
    /* (5) comment-skip: "fn g" only in a /* */ comment -> not matched -> -1 */
    if ra_cut_fn(&SRC3 as *u8, 23u64, &NM_G as *u8, 1u64, &OUT as *u8, 256u64) != -1i64 { return 11u64 }
    /* (6) MERGE: replace fn "d" with an extern to "m" -- the signature kept, body gone, extern/from synthesized */
    let n6 : i64 = ra_merge_fn(&SRC4 as *u8, 14u64, &NM_D as *u8, 1u64, &MOD_M as *u8, 1u64, &OUT as *u8, 256u64)
    if n6 <= 0i64 { return 12u64 }
    if contains(&OUT as u64, n6 as u64, &N_EXTERN as u64, 6u64) != 1u8 { return 13u64 }   /* extern synthesized */
    if contains(&OUT as u64, n6 as u64, &N_FROM as u64,   4u64) != 1u8 { return 14u64 }   /* from clause        */
    if contains(&OUT as u64, n6 as u64, &FN_D as u64,     4u64) != 1u8 { return 15u64 }   /* signature kept     */
    if contains(&OUT as u64, n6 as u64, &N_BODY as u64,   3u64) != 0u8 { return 16u64 }   /* body excised       */
    /* (7) merge an absent name -> -1 */
    if ra_merge_fn(&SRC4 as *u8, 14u64, &NM_C as *u8, 1u64, &MOD_M as *u8, 1u64, &OUT as *u8, 256u64) != -1i64 { return 17u64 }
    /* (8) EXTRACT: wrap fn "s" into a new module "shared" -- module decl + @export inserted + body kept */
    let n8 : i64 = ra_extract_module(&SRC5 as *u8, 14u64, &MOD_SHARED as *u8, 6u64, &OUT as *u8, 256u64)
    if n8 <= 0i64 { return 18u64 }
    if contains(&OUT as u64, n8 as u64, &N_MODULE as u64,   6u64) != 1u8 { return 19u64 }   /* "module" decl    */
    if contains(&OUT as u64, n8 as u64, &MOD_SHARED as u64, 6u64) != 1u8 { return 20u64 }   /* the module name  */
    if contains(&OUT as u64, n8 as u64, &N_EXPORT2 as u64,  7u64) != 1u8 { return 21u64 }   /* @export inserted */
    if contains(&OUT as u64, n8 as u64, &FN_S as u64,       4u64) != 1u8 { return 22u64 }   /* the fn           */
    if contains(&OUT as u64, n8 as u64, &N_BODY5 as u64,    3u64) != 1u8 { return 23u64 }   /* the body kept    */
    /* (9) A4 unified entry + structural self-check */
    if ra_check_balanced(&SRC1 as *u8, 17u64) != 1u8 { return 24u64 }   /* balanced source accepted  */
    if ra_check_balanced(&UNBAL as *u8, 7u64)  != 0u8 { return 25u64 }   /* unbalanced source refused */
    let na : i64 = ra_apply(1u32, &SRC1 as *u8, 17u64, &NM_B as *u8, 1u64, &MOD_M as *u8, 1u64, &OUT as *u8, 256u64)
    if na <= 0i64 { return 26u64 }
    if contains(&OUT as u64, na as u64, &FN_A as u64, 4u64) != 1u8 { return 27u64 }       /* CUT dispatched     */
    let nb : i64 = ra_apply(0u32, &SRC4 as *u8, 14u64, &NM_D as *u8, 1u64, &MOD_M as *u8, 1u64, &OUT as *u8, 256u64)
    if nb <= 0i64 { return 28u64 }
    if contains(&OUT as u64, nb as u64, &N_EXTERN as u64, 6u64) != 1u8 { return 29u64 }   /* MERGE dispatched   */
    let nc : i64 = ra_apply(2u32, &SRC5 as *u8, 14u64, &NM_D as *u8, 1u64, &MOD_SHARED as *u8, 6u64, &OUT as *u8, 256u64)
    if nc <= 0i64 { return 30u64 }
    if contains(&OUT as u64, nc as u64, &N_MODULE as u64, 6u64) != 1u8 { return 31u64 }   /* EXTRACT dispatched */
    if ra_apply(99u32, &SRC1 as *u8, 17u64, &NM_B as *u8, 1u64, &MOD_M as *u8, 1u64, &OUT as *u8, 256u64) != -1i64 { return 32u64 }  /* unknown kind -> error */
    return 99u64
}
