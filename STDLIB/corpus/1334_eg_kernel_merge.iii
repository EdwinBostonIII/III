/* 1334_eg_kernel_merge.iii -- KERNEL-DISPOSED E-GRAPH MERGE (harmony item 7).
 *
 * eg_union, as an exported surface, let any caller assert two e-classes equal with NO proof
 * obligation -- the e-graph analogue of the proof_ok-literal gap that ru_certify_unify_kernel
 * (harmony item 1, KAT 1243) closed for the congruence spine.  eg_union_kernel closes it here:
 * the CIC kernel's conversion oracle (tc_conv) must DISCHARGE the equality of the two classes'
 * caller-supplied denotations before the classes join.  Four arms:
 *  (1) POSITIVE -- two DISTINCT e-classes whose denotations are beta-convertible
 *      ((lambda x:Bool. x) true  ~  true) are MERGED: returns 1 and eg_find agrees after;
 *  (2) FALSE-EQUALITY NEGATIVE -- two distinct classes with NON-convertible denotations
 *      (true vs false) are REFUSED: returns 0 and the classes remain DISTINCT (untouched);
 *  (3) AUTO-CONGRUENCE -- re-merging the already-joined pair is 1 WITHOUT a kernel proof
 *      (congruence is proof-free; same convention as ru_certify_unify_kernel);
 *  (4) SENT-INPUT NEGATIVE -- a sentinel class id is refused (0), never unioned.
 * Exit 99 = the e-graph's external join is proof-carrying, sound, and non-vacuous. */
module corpus_1334

extern @abi(c-msvc-x64) fn eg_init() -> i32 from "egraph.iii"
extern @abi(c-msvc-x64) fn eg_add(sym_id: *u8, children: *u32, n: u32) -> u32 from "egraph.iii"
extern @abi(c-msvc-x64) fn eg_find(a: u32) -> u32 from "egraph.iii"
extern @abi(c-msvc-x64) fn eg_union_kernel(a: u32, b: u32, a_tc: u32, b_tc: u32) -> u32 from "egraph.iii"
extern @abi(c-msvc-x64) fn tc_reset() -> u64 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bool() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_true() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_false() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_var(k: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_lam(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_app(f: u32, a: u32) -> u32 from "typecheck.iii"

const EG_SENT : u32 = 0xFFFFFFFFu32

var SYM : [u8; 32]
var CH  : [u32; 8]

fn mk_leaf(tag: u8) -> u32 {
    let mut i : u64 = 0u64
    while i < 32u64 { SYM[i] = 0u8  i = i + 1u64 }
    SYM[0u64] = tag
    return eg_add((&SYM as u64) as *u8, (&CH as u64) as *u32, 0u32)
}

fn main() -> u64 {
    eg_init()
    tc_reset()

    /* kernel terms: app = (lambda x:Bool. x) true -- beta-convertible to true; and false. */
    let bool_ty : u32 = tc_bool()
    let id_fn   : u32 = tc_lam(bool_ty, tc_var(0u32))
    let app     : u32 = tc_app(id_fn, tc_true())
    let tru     : u32 = tc_true()
    let fls     : u32 = tc_false()

    /* four distinct leaf classes */
    let ca : u32 = mk_leaf(1u8)
    let cb : u32 = mk_leaf(2u8)
    let cc : u32 = mk_leaf(3u8)
    let cd : u32 = mk_leaf(4u8)
    if ca == EG_SENT { return 10u64 }
    if cd == EG_SENT { return 10u64 }
    if eg_find(ca) == eg_find(cb) { return 11u64 }
    if eg_find(cc) == eg_find(cd) { return 12u64 }

    /* (1) POSITIVE: kernel-convertible denotations -> MERGED */
    if eg_union_kernel(ca, cb, app, tru) != 1u32 { return 1u64 }
    if eg_find(ca) != eg_find(cb) { return 2u64 }

    /* (2) FALSE-EQUALITY NEGATIVE: true vs false is NOT convertible -> REFUSED, classes untouched */
    if eg_union_kernel(cc, cd, tru, fls) != 0u32 { return 3u64 }
    if eg_find(cc) == eg_find(cd) { return 4u64 }

    /* (3) AUTO-CONGRUENCE: the already-joined pair re-merges proof-free (even with a false proof) */
    if eg_union_kernel(ca, cb, tru, fls) != 1u32 { return 5u64 }

    /* (4) SENT-INPUT NEGATIVE: a sentinel class id is refused */
    if eg_union_kernel(EG_SENT, cd, app, tru) != 0u32 { return 6u64 }
    if eg_union_kernel(cc, EG_SENT, app, tru) != 0u32 { return 7u64 }

    return 99u64
}
