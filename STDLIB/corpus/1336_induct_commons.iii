/* 1336_induct_commons.iii -- THE LEARNED UNIVERSAL BECOMES CITABLE (harmony item 9).
 *
 * The inductive bridge certified universals and threw the certificates away; every consumer re-ran
 * the induction.  ind_forall_commons / ind_forall_w_commons / ind_forall_id_commons Pi-close the
 * universal and admit it to the Theorem Commons under its kernel-serialized goal address; the
 * ind_forall_*_cite duals answer by address WITHOUT re-proving.  The Commons re-runs tc_check, so
 * soundness is zero-trust (the kernel stays sole arbiter).  Nine arms across all three limbs:
 *  Nat (1) POSITIVE  ∀n:Nat.Bool-motive universal ADMITTED (TCOM_OK) and (2) CITABLE;
 *      (3) NEGATIVE  a base of the WRONG fiber (true : Bool vs P2 = λ_.Unit) is E_UNPROVEN
 *      and (4) its goal stays ABSENT (the false universal never becomes citable);
 *  W   (5) POSITIVE  the Nat-as-W dependent-algebra universal ADMITTED + CITABLE;
 *      (6) NEGATIVE  a non-function algebra is E_UNPROVEN;
 *  Id  (7) POSITIVE  the FULL transport universal ∀y:Bool. ∀q:Id(Bool,true,y). Id(Bool,y,true)
 *      ADMITTED + CITABLE (BOTH endpoint and path quantified -- J under binders);
 *      (8) NEGATIVE  an off-diagonal base is E_UNPROVEN;
 *  (9) the registry holds EXACTLY the three true universals (size==3) and re-admission is
 *      idempotent (size stays 3).
 * Exit 99 = the inductive engine feeds the self-growing, citable, kernel-sovereign Theorem DAG. */
module corpus_1336

extern @abi(c-msvc-x64) fn ind_forall_commons(p: u32, z: u32, s: u32) -> i32 from "induct.iii"
extern @abi(c-msvc-x64) fn ind_forall_cite(p: u32) -> i32 from "induct.iii"
extern @abi(c-msvc-x64) fn ind_forall_w_commons(p: u32, s: u32, wty: u32) -> i32 from "induct.iii"
extern @abi(c-msvc-x64) fn ind_forall_w_cite(p: u32, wty: u32) -> i32 from "induct.iii"
extern @abi(c-msvc-x64) fn ind_forall_id_commons(motive: u32, base: u32, a_ty: u32, lhs: u32) -> i32 from "induct.iii"
extern @abi(c-msvc-x64) fn ind_forall_id_cite(motive: u32, a_ty: u32, lhs: u32) -> i32 from "induct.iii"
extern @abi(c-msvc-x64) fn tcom_init() -> i32 from "theorem_commons.iii"
extern @abi(c-msvc-x64) fn tcom_size() -> u64 from "theorem_commons.iii"
extern @abi(c-msvc-x64) fn tc_reset() -> u64 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bool() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_unit() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_empty() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_nat() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_true() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_tt() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_var(k: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_lam(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_pi(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_id(ty: u32, l: u32, r: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_refl(v: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_sort(n: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_w(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_absurd(mtv: u32, e: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_if(c: u32, a: u32, b: u32) -> u32 from "typecheck.iii"

const TCOM_OK         : i32 =  0i32
const TCOM_E_ABSENT   : i32 = -2i32
const TCOM_E_UNPROVEN : i32 = -3i32

fn main() -> u64 {
    tc_reset()
    tcom_init()
    let kb : u32 = tc_bool()
    let ku : u32 = tc_unit()
    let ke : u32 = tc_empty()
    let kn : u32 = tc_nat()
    let tt : u32 = tc_true()

    /* ---- Nat limb ---- */
    let p1 : u32 = tc_lam(kn, kb)                                /* P  = λ_:Nat. Bool */
    let z1 : u32 = tt                                            /* z  : P 0 = Bool */
    let s1 : u32 = tc_lam(kn, tc_lam(kb, tc_var(0u32)))          /* s  = λk. λih. ih */
    if ind_forall_commons(p1, z1, s1) != TCOM_OK { return 1u64 }     /* (1) admitted */
    if ind_forall_cite(p1) != TCOM_OK { return 2u64 }                /* (2) citable, no re-proof */
    let p2 : u32 = tc_lam(kn, ku)                                /* P2 = λ_:Nat. Unit */
    if ind_forall_commons(p2, tt, s1) != TCOM_E_UNPROVEN { return 3u64 }   /* (3) wrong-fiber base refused */
    if ind_forall_cite(p2) != TCOM_E_ABSENT { return 4u64 }          /* (4) the false universal is NOT citable */

    /* ---- W limb (Nat-as-W, mirror 1247) ---- */
    let arity : u32 = tc_if(tc_var(0u32), ku, ke)
    let wnat  : u32 = tc_w(kb, arity)
    let npmot : u32 = tc_lam(wnat, kb)                           /* P = λ_:WNat. Bool */
    let nft   : u32 = tc_pi(tc_if(tc_var(0u32), ku, ke), wnat)
    let niht  : u32 = tc_pi(tc_if(tc_var(1u32), ku, ke), kb)
    let nstep : u32 = tc_lam(kb, tc_lam(nft, tc_lam(niht, tt)))
    if ind_forall_w_commons(npmot, nstep, wnat) != TCOM_OK { return 5u64 }   /* (5a) tree universal admitted */
    if ind_forall_w_cite(npmot, wnat) != TCOM_OK { return 6u64 }             /* (5b) citable */
    if ind_forall_w_commons(npmot, tt, wnat) != TCOM_E_UNPROVEN { return 7u64 }  /* (6) non-function algebra refused */

    /* ---- Id limb (path-dependent symmetry, BOTH endpoint and path quantified) ---- */
    let csym : u32 = tc_lam(kb, tc_lam(tc_id(kb, tt, tc_var(0u32)), tc_id(kb, tc_var(1u32), tt)))
    let dpos : u32 = tc_refl(tt)
    if ind_forall_id_commons(csym, dpos, kb, tt) != TCOM_OK { return 8u64 }  /* (7a) transport universal admitted */
    if ind_forall_id_cite(csym, kb, tt) != TCOM_OK { return 9u64 }           /* (7b) citable */
    if ind_forall_id_commons(csym, tc_sort(0u32), kb, tt) != TCOM_E_UNPROVEN { return 10u64 }  /* (8) off-diagonal base refused */

    /* ---- (9) exactly the three TRUE universals; re-admission idempotent ---- */
    if tcom_size() != 3u64 { return 11u64 }
    if ind_forall_commons(p1, z1, s1) != TCOM_OK { return 12u64 }
    if tcom_size() != 3u64 { return 13u64 }

    return 99u64
}
