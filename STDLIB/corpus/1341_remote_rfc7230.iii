/* 1341_remote_rfc7230.iii -- THE L4 REMOTE LEG SPEAKS RFC 7230 (harmony item 14).
 *
 * backend_remote's body scan was find-CRLFCRLF + take-the-rest: a chunked 200 handed RAW chunk
 * framing to the integrity gate (correct remote -> unreachable content), and a keep-alive response
 * glued trailing bytes onto the body (hash mismatch).  backend_remote_decode now routes through
 * aether/http_client's RFC 7230 sec 3.3.3 parser -- and is the EXACT live path (backend_remote_get
 * calls it), driven here deterministically via the inject seam.  Arms:
 *  (1) CONTENT-LENGTH framing -- a 200 with Content-Length: 5 followed by trailing keep-alive
 *      garbage yields EXACTLY the 5 body bytes (the old path returned body+garbage);
 *  (2) CHUNKED decode -- "3\r\nFOO\r\n2\r\nBA\r\n0\r\n\r\n" yields the DECODED "FOOBA" (the old
 *      path returned the raw framing);
 *  (3) EOF framing -- an HTTP/1.0 response with neither header yields the rest-of-stream body;
 *  (4) non-200 -> REMOTE_NOTFOUND (a 404 is absence, not bytes);
 *  (5) unparseable garbage -> REMOTE_NOTFOUND (never a fabricated body);
 *  (6) a body larger than the caller's max -> REMOTE_E_TOOBIG (refuse, don't truncate);
 *  (7) determinism -- re-decoding the same bytes yields byte-identical output (the lazy arena
 *      resets per decode; no cross-call residue).
 * Exit 99 = the internet leg is RFC-correct, framing-exact, and refuse-not-corrupt. */
module corpus_1341

extern @abi(c-msvc-x64) fn backend_remote_inject(src: u64, n: u64) -> u64 from "backend_remote.iii"
extern @abi(c-msvc-x64) fn backend_remote_decode(total: u64, out: u64, mx: u64, out_len: u64) -> i32 from "backend_remote.iii"

const R_OK       : i32 = 0i32
const R_NOTFOUND : i32 = 2i32
const R_TOOBIG   : i32 = -1i32

var RESP : [u8; 512]
var RP   : u64 = 0u64
var OUT  : [u8; 128]
var OUT2 : [u8; 128]
var OLEN : [u64; 1]

fn rput(b: u8) -> u64 {
    RESP[RP] = b
    RP = RP + 1u64
    return 0u64
}
fn rlit(p: *u8, n: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < n {
        rput(p[i])
        i = i + 1u64
    }
    return 0u64
}
fn rcrlf() -> u64 {
    rput(13u8)
    rput(10u8)
    return 0u64
}

fn main() -> u64 {
    let op : u64 = &OUT as u64
    let olp : u64 = &OLEN as u64

    /* (1) Content-Length + trailing keep-alive garbage */
    RP = 0u64
    rlit("HTTP/1.1 200 OK" as *u8, 15u64)
    rcrlf()
    rlit("Content-Length: 5" as *u8, 17u64)
    rcrlf()
    rcrlf()
    rlit("HELLOXYZJUNK" as *u8, 12u64)          /* body HELLO + 7 trailing bytes */
    backend_remote_inject(&RESP as u64, RP)
    if backend_remote_decode(RP, op, 128u64, olp) != R_OK { return 1u64 }
    if OLEN[0u64] != 5u64 { return 2u64 }
    if OUT[0u64] != 72u8 { return 3u64 }         /* H */
    if OUT[4u64] != 79u8 { return 3u64 }         /* O */

    /* (2) chunked decode */
    RP = 0u64
    rlit("HTTP/1.1 200 OK" as *u8, 15u64)
    rcrlf()
    rlit("Transfer-Encoding: chunked" as *u8, 26u64)
    rcrlf()
    rcrlf()
    rlit("3" as *u8, 1u64)
    rcrlf()
    rlit("FOO" as *u8, 3u64)
    rcrlf()
    rlit("2" as *u8, 1u64)
    rcrlf()
    rlit("BA" as *u8, 2u64)
    rcrlf()
    rlit("0" as *u8, 1u64)
    rcrlf()
    rcrlf()
    backend_remote_inject(&RESP as u64, RP)
    if backend_remote_decode(RP, op, 128u64, olp) != R_OK { return 4u64 }
    if OLEN[0u64] != 5u64 { return 5u64 }
    if OUT[0u64] != 70u8 { return 6u64 }         /* F */
    if OUT[3u64] != 66u8 { return 6u64 }         /* B */
    if OUT[4u64] != 65u8 { return 6u64 }         /* A */

    /* (3) EOF framing (HTTP/1.0, neither header) */
    RP = 0u64
    rlit("HTTP/1.0 200 OK" as *u8, 15u64)
    rcrlf()
    rlit("X-Y: z" as *u8, 6u64)
    rcrlf()
    rcrlf()
    rlit("WORLD" as *u8, 5u64)
    backend_remote_inject(&RESP as u64, RP)
    if backend_remote_decode(RP, op, 128u64, olp) != R_OK { return 7u64 }
    if OLEN[0u64] != 5u64 { return 8u64 }
    if OUT[0u64] != 87u8 { return 9u64 }         /* W */

    /* (4) non-200 is absence */
    RP = 0u64
    rlit("HTTP/1.1 404 NF" as *u8, 15u64)
    rcrlf()
    rlit("Content-Length: 2" as *u8, 17u64)
    rcrlf()
    rcrlf()
    rlit("NO" as *u8, 2u64)
    backend_remote_inject(&RESP as u64, RP)
    if backend_remote_decode(RP, op, 128u64, olp) != R_NOTFOUND { return 10u64 }

    /* (5) unparseable garbage is absence, never a fabricated body */
    RP = 0u64
    rlit("GARBAGEGARBAGE" as *u8, 14u64)
    backend_remote_inject(&RESP as u64, RP)
    if backend_remote_decode(RP, op, 128u64, olp) != R_NOTFOUND { return 11u64 }

    /* (6) refuse, don't truncate */
    RP = 0u64
    rlit("HTTP/1.1 200 OK" as *u8, 15u64)
    rcrlf()
    rlit("Content-Length: 5" as *u8, 17u64)
    rcrlf()
    rcrlf()
    rlit("HELLO" as *u8, 5u64)
    backend_remote_inject(&RESP as u64, RP)
    if backend_remote_decode(RP, op, 3u64, olp) != R_TOOBIG { return 12u64 }

    /* (7) determinism across the arena reset */
    if backend_remote_decode(RP, op, 128u64, olp) != R_OK { return 13u64 }
    if backend_remote_decode(RP, &OUT2 as u64, 128u64, olp) != R_OK { return 14u64 }
    let mut i : u64 = 0u64
    while i < 5u64 {
        if OUT[i] != OUT2[i] { return 15u64 }
        i = i + 1u64
    }

    return 99u64
}
