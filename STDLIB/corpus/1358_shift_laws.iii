/* 1358_shift_laws.iii -- THE SHIFT-COMBINING LAW FAMILY, COUNT-MASK HONEST (wave-4 M2).
 *
 * The peephole class a code generator combines shifts with, certified parametrically into the
 * 0xB7 registry by UNSAT (bv_bits; literal shifts are zero-clause bit remaps).  THE TRANSFER
 * CONDITION is the heart: bv_bits models the MATHEMATICAL shift while silicon count-masks (&63),
 * so laws transfer ONLY with every count (a, b, a+b) strictly below the width -- the admission
 * wall refuses the FALSE silicon 'law' (x>>40)>>40 == x>>((80)&63) outright.  Arms:
 *  (1) zero budget admits nothing;
 *  (2) singles admit: (x>>3)>>5==x>>8, (x<<7)<<2==x<<9, (x<<13)>>13==x&(~0>>13);
 *  (3) THE WALL: a+b>=64 refused (40,40); a>=64 refused; 63+1 refused; shape-3 with b!=0
 *      refused; the registry never grows on refusal;
 *  (4) the 6x6 sweep discovers exactly 78 laws (36+36 combines + 6 mask recoveries);
 *  (5) the authority discriminates: the false miter (x>>3)>>5 vs x>>9 has a COUNTERMODEL;
 *  (6) out-of-catalog shape ids refuse.
 * Exit 99 = the shift-combining peephole class is autonomously certified, and its boundary --
 * where silicon and mathematics part ways -- is part of the law. */
module corpus_1358

extern @abi(c-msvc-x64) fn cga_dispose_shift(shape: u32, a: u32, b: u32, budget: u32) -> u8 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_shift_discover(g: u32, budget: u32) -> u32 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_shift_count() -> u32 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_shift_get_shape(i: u32) -> u32 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shr(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_equal(a: u32, b: u32) -> u8 from "bv_bits.iii"

fn main() -> u64 {
    /* (1) zero budget */
    if cga_shift_discover(4u32, 0u32) != 0u32 { return 1u64 }
    if cga_shift_count() != 0u32 { return 2u64 }

    /* (2) singles */
    if cga_dispose_shift(1u32, 3u32, 5u32, 1u32) != 1u8 { return 3u64 }
    if cga_dispose_shift(2u32, 7u32, 2u32, 1u32) != 1u8 { return 4u64 }
    if cga_dispose_shift(3u32, 13u32, 0u32, 1u32) != 1u8 { return 5u64 }
    if cga_shift_count() != 3u32 { return 6u64 }
    if cga_shift_get_shape(0u32) != 1u32 { return 7u64 }

    /* (3) THE COUNT-MASK WALL */
    if cga_dispose_shift(1u32, 40u32, 40u32, 1u32) != 0u8 { return 8u64 }
    if cga_dispose_shift(1u32, 64u32, 1u32, 1u32) != 0u8 { return 9u64 }
    if cga_dispose_shift(2u32, 63u32, 1u32, 1u32) != 0u8 { return 10u64 }
    if cga_dispose_shift(3u32, 13u32, 5u32, 1u32) != 0u8 { return 11u64 }
    if cga_shift_count() != 3u32 { return 12u64 }

    /* (4) the sweep: 36 + 36 combines + 6 mask recoveries = 78 */
    if cga_shift_discover(6u32, 1u32) != 78u32 { return 13u64 }
    if cga_shift_count() != 81u32 { return 14u64 }

    /* (5) the authority discriminates */
    bb_reset(64u64)
    let x : u32 = bb_var(0u32)
    let l : u32 = bb_shr(bb_shr(x, 3u64), 5u64)
    let r : u32 = bb_shr(x, 9u64)
    if bb_equal(l, r) != 0u8 { return 15u64 }

    /* (6) out-of-catalog */
    if cga_dispose_shift(4u32, 1u32, 1u32, 1u32) != 0u8 { return 16u64 }
    if cga_dispose_shift(0u32, 1u32, 1u32, 1u32) != 0u8 { return 17u64 }

    return 99u64
}
