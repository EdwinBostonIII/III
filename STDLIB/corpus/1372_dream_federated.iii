/* 1372_dream_federated.iii -- THE DREAM'S DISCOVERIES BECOME FEDERATABLE THEOREMS (wave-4 M21).
 *
 * M16 made the hand-curated machine laws citable; M19/M20 taught the optimizer from the dream.
 * M21 fuses discovery with federation: every count-mask strength pair the dream certifies is
 * admitted into the Theorem Commons as a refl-proven theorem Pi(BV). Id(BV, x*2^a, x<<b) -- so
 * a law the system DREAMED crosses the wire and re-proves on a peer that never saw the dream.
 * Double-gated: the registry's UNSAT-grade admission, then tcom_admit's tc_check re-proves the
 * refl in the local kernel.  Arms:
 *  (1) certify (5,5) and (12,12) in the registry; bvc_federate_dream admits exactly 2;
 *  (2) the discovered laws cite back by power (5 and 12 present; an undiscovered power absent);
 *  (3) THE PEER: bvc_admit_strength(5,5) admits on a FRESH Commons -- the dreamed law re-proves
 *      with no registry present, purely from the wire-rebuildable goal + refl;
 *  (4) THE FALSE DREAM REFUSES: a corrupt pair (5,6) -- x*32 == x<<6 (=x*64) is FALSE -- is
 *      rejected by the kernel re-check with exactly E_UNPROVEN; nothing false federates;
 *  (5) the silicon identity federates: (0,64) admits (x*1 == x<<64, the count-mask truth).
 * Exit 99 = a machine's dreamed arithmetic, proven once, holds everywhere the wire reaches. */
module corpus_1372

extern @abi(c-msvc-x64) fn tcom_init() -> i32 from "theorem_commons.iii"
extern @abi(c-msvc-x64) fn cga_bv_reset() -> u64 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_dispose_bv(a: u32, b: u32, budget: u32) -> u8 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn bvc_federate_dream() -> u32 from "bv_commons.iii"
extern @abi(c-msvc-x64) fn bvc_cite_strength(a: u32) -> i32 from "bv_commons.iii"
extern @abi(c-msvc-x64) fn bvc_admit_strength(a: u32, b: u32) -> i32 from "bv_commons.iii"

fn main() -> u64 {
    tcom_init()
    cga_bv_reset()

    /* (1) certify two pairs, federate exactly 2 */
    if cga_dispose_bv(5u32, 5u32, 1u32) != 1u8 { return 1u64 }
    if cga_dispose_bv(12u32, 12u32, 1u32) != 1u8 { return 2u64 }
    if bvc_federate_dream() != 2u32 { return 3u64 }

    /* (2) the discovered laws cite by power; an undiscovered one is absent */
    if bvc_cite_strength(5u32) != 0i32 { return 4u64 }
    if bvc_cite_strength(12u32) != 0i32 { return 5u64 }
    if bvc_cite_strength(7u32) == 0i32 { return 6u64 }       /* never discovered -> absent */

    /* (3) THE PEER: a dreamed law re-proves on a FRESH Commons (no registry) */
    tcom_init()
    if bvc_admit_strength(5u32, 5u32) != 0i32 { return 7u64 }

    /* (4) THE FALSE DREAM REFUSES: x*32 == x<<6 is FALSE (x<<6 = x*64) -> E_UNPROVEN */
    if bvc_admit_strength(5u32, 6u32) != -3i32 { return 8u64 }

    /* (5) the silicon identity federates: x*1 == x<<64 */
    if bvc_admit_strength(0u32, 64u32) != 0i32 { return 9u64 }
    if bvc_cite_strength(0u32) != 0i32 { return 10u64 }

    return 99u64
}
