/* 1394_endian_exact.iii -- THE WIRE-ORDER BYTE LAWS, PROVEN (burn-down tranche 3).
 *
 * The coverage census flagged eight endian exports (u16/u64 load+store, both orders) as
 * referenced nowhere -- the explicit byte-order layer under every wire format was unproven.
 * This KAT proves the full surface BYTE-EXACTLY, at a misaligned offset (3), so no aligned
 * fast-path could fake it:
 *  (1) LE stores lay bytes least-significant-first (each byte asserted), BE most-first;
 *  (2) load round-trips: load_X_le(store_X_le(v)) == v, same for be, all three widths;
 *  (3) CROSS-ORDER LAW: load_u64_be over LE-stored bytes == bswap64(v) (and u32/u16
 *      analogues) -- ties loads, stores, and swaps into one consistency triangle;
 *  (4) bswap32/64 are involutions with exact known vectors;
 *  (5) u16/u32 loads return ONLY their width's bytes (neighbours don't bleed in).
 * Exit 99 = network byte order in III is law, not convention. */
module corpus_1394

extern @abi(c-msvc-x64) fn endian_load_u16_le(p: *u8, off: u64) -> u32 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_load_u32_le(p: *u8, off: u64) -> u32 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_load_u64_le(p: *u8, off: u64) -> u64 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_load_u16_be(p: *u8, off: u64) -> u32 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_load_u32_be(p: *u8, off: u64) -> u32 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_load_u64_be(p: *u8, off: u64) -> u64 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_store_u16_le(p: *u8, off: u64, v: u32) -> i32 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_store_u32_le(p: *u8, off: u64, v: u32) -> i32 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_store_u64_le(p: *u8, off: u64, v: u64) -> i32 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_store_u16_be(p: *u8, off: u64, v: u32) -> i32 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_store_u32_be(p: *u8, off: u64, v: u32) -> i32 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_store_u64_be(p: *u8, off: u64, v: u64) -> i32 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_bswap32(v: u32) -> u32 from "endian.iii"
extern @abi(c-msvc-x64) fn endian_bswap64(v: u64) -> u64 from "endian.iii"

var BUF : [u8; 32]

const V64 : u64 = 0x1122334455667788u64
const V32 : u32 = 0xA1B2C3D4u32
const V16 : u32 = 0xBEEFu32
const OFF : u64 = 3u64          /* misaligned on purpose */

fn bp() -> *u8 { return ((&BUF as u64)) as *u8 }

fn main() -> u64 {
    let p : *u8 = bp()

    /* (1) LE u64 byte layout at a misaligned offset */
    if endian_store_u64_le(p, OFF, V64) != 0i32 { return 1u64 }
    if p[OFF + 0u64] != 0x88u8 { return 2u64 }
    if p[OFF + 1u64] != 0x77u8 { return 3u64 }
    if p[OFF + 2u64] != 0x66u8 { return 4u64 }
    if p[OFF + 3u64] != 0x55u8 { return 5u64 }
    if p[OFF + 4u64] != 0x44u8 { return 6u64 }
    if p[OFF + 5u64] != 0x33u8 { return 7u64 }
    if p[OFF + 6u64] != 0x22u8 { return 8u64 }
    if p[OFF + 7u64] != 0x11u8 { return 9u64 }
    /* (2) LE round-trip + (3) cross-order law */
    if endian_load_u64_le(p, OFF) != V64 { return 10u64 }
    if endian_load_u64_be(p, OFF) != endian_bswap64(V64) { return 11u64 }

    /* (1) BE u64 byte layout */
    if endian_store_u64_be(p, OFF, V64) != 0i32 { return 12u64 }
    if p[OFF + 0u64] != 0x11u8 { return 13u64 }
    if p[OFF + 7u64] != 0x88u8 { return 14u64 }
    if endian_load_u64_be(p, OFF) != V64 { return 15u64 }
    if endian_load_u64_le(p, OFF) != endian_bswap64(V64) { return 16u64 }

    /* u32 both orders */
    if endian_store_u32_le(p, OFF, V32) != 0i32 { return 17u64 }
    if p[OFF + 0u64] != 0xD4u8 { return 18u64 }
    if p[OFF + 3u64] != 0xA1u8 { return 19u64 }
    if endian_load_u32_le(p, OFF) != V32 { return 20u64 }
    if endian_load_u32_be(p, OFF) != endian_bswap32(V32) { return 21u64 }
    if endian_store_u32_be(p, OFF, V32) != 0i32 { return 22u64 }
    if p[OFF + 0u64] != 0xA1u8 { return 23u64 }
    if endian_load_u32_be(p, OFF) != V32 { return 24u64 }

    /* u16 both orders + width isolation: plant sentinels around the two bytes */
    p[OFF + 2u64] = 0x5Au8
    if endian_store_u16_be(p, OFF, V16) != 0i32 { return 25u64 }
    if p[OFF + 0u64] != 0xBEu8 { return 26u64 }
    if p[OFF + 1u64] != 0xEFu8 { return 27u64 }
    if endian_load_u16_be(p, OFF) != V16 { return 28u64 }
    if endian_load_u16_le(p, OFF) != 0xEFBEu32 { return 29u64 }   /* cross-order, exact */
    if p[OFF + 2u64] != 0x5Au8 { return 30u64 }                   /* u16 store touched 2 bytes only */
    if endian_store_u16_le(p, OFF, V16) != 0i32 { return 31u64 }
    if p[OFF + 0u64] != 0xEFu8 { return 32u64 }
    if p[OFF + 1u64] != 0xBEu8 { return 33u64 }
    if endian_load_u16_le(p, OFF) != V16 { return 34u64 }
    /* (5) u16/u32 loads return only their width (sentinel 0x5A at +2 never bleeds in) */
    if endian_load_u16_le(p, OFF) > 0xFFFFu32 { return 35u64 }
    if endian_load_u16_be(p, OFF) > 0xFFFFu32 { return 36u64 }

    /* (4) involutions + exact vectors */
    if endian_bswap32(V32) != 0xD4C3B2A1u32 { return 37u64 }
    if endian_bswap32(endian_bswap32(V32)) != V32 { return 38u64 }
    if endian_bswap64(V64) != 0x8877665544332211u64 { return 39u64 }
    if endian_bswap64(endian_bswap64(V64)) != V64 { return 40u64 }

    return 99u64
}
