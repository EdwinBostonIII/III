/* 1399_anchor_store_wave.iii -- FOUNDERS DIRECTIVES, ERASURE ROOTS, CLOSURE+RESOLVER,
 * BIT-BLAST DIAGNOSTICS, BOOLEAN WAVES, CONSTANTS, CRITICAL PAIRS, AIR TRACE, ASCII FORMAT
 * (burn-down tranche 8; sixteen census orphans, each with exact laws).
 *
 *  FOUNDERS (3): fa_pfs_deny_verify / fa_witness_inject_verify / fa_revoke_verify -- each
 *      directive's EXACT byte layout is rebuilt here, signed with a REAL ed25519 key, and
 *      verified (1); a tampered signature refuses (0); a changed parameter refuses (0) --
 *      the signature BINDS every field;
 *  ERASURE (3): es_n / es_k / es_root_ptr -- after encode(64B, k=4, n=6) the params read
 *      back exactly; the root is nonzero, deterministic (re-encode same blob -> identical
 *      32 bytes), and content-sensitive (one blob byte flips >=1 root byte);
 *  CLOSURE (2): closure_includes_resolver_seal (0 before seal_resolver_compute, 1 after)
 *      and closure_with_resolver_byte (0x100 before compute, exact+reproducible after,
 *      0x100 OOB);
 *  BIT-BLAST (3): bb_diag_init / bb_diag_add / bb_diag_solve -- after a real decide
 *      (x&x == x at w=4) the 0x7F sentinels are REPLACED (the engine ran) and no clause
 *      was refused (add 0);
 *  WAVE (1): bws_true -- the boolean identity TRUE AND x == x holds pointwise (bws_equal),
 *      and TRUE != x (x is not the constant);
 *  CONSTANTS (1): constants_value -- slot 1 yields a stable nonzero-length value
 *      (byte-reproducible); slot 0 and slot count+1 yield 0;
 *  CRITPAIRS (1): cpe_count -- deterministic across calls (after xrp_selftest=99);
 *  AIR (1): air_get_trace -- set(2,3)=77 reads back 77; OOB row/col read 0;
 *  FORMAT (1): format_char_ascii -- pushes exactly one byte; the input is masked to ASCII
 *      width (0x141 -> one byte, len grows by exactly 1).
 * Exit 99. */
module corpus_1399

extern @abi(c-msvc-x64) fn fa_pfs_deny_verify(pubkey: *u8, target_kind: u8, target_id: u64, reason: u8, sig: *u8) -> u8 from "founders_anchor.iii"
extern @abi(c-msvc-x64) fn fa_witness_inject_verify(pubkey: *u8, cycle_kind: u32, payload_mhash: *u8, timestamp: u64, flags: u32, sig: *u8) -> u8 from "founders_anchor.iii"
extern @abi(c-msvc-x64) fn fa_revoke_verify(pubkey: *u8, promotion_id: u64, cascade: u8, sig: *u8) -> u8 from "founders_anchor.iii"
extern @abi(c-msvc-x64) fn ed25519_pubkey(seed: *u8, out_pk: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn ed25519_sign(seed: *u8, pk: *u8, msg: *u8, msg_len: u64, sig_out: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn es_encode(blob_ptr: u64, dlen: u32, k: u32, n: u32) -> i32 from "erasure_store.iii"
extern @abi(c-msvc-x64) fn es_n() -> u32 from "erasure_store.iii"
extern @abi(c-msvc-x64) fn es_k() -> u32 from "erasure_store.iii"
extern @abi(c-msvc-x64) fn es_root_ptr() -> u64 from "erasure_store.iii"
extern @abi(c-msvc-x64) fn closure_set(root_ptr: u64) -> i32 from "closure.iii"
extern @abi(c-msvc-x64) fn closure_compute_with_resolver() -> i32 from "closure.iii"
extern @abi(c-msvc-x64) fn closure_with_resolver_byte(i: u32) -> u32 from "closure.iii"
extern @abi(c-msvc-x64) fn closure_includes_resolver_seal() -> u8 from "seal_resolver.iii"
extern @abi(c-msvc-x64) fn seal_resolver_compute() -> i32 from "seal_resolver.iii"
extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_and(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_equal(a: u32, b: u32) -> u8 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_diag_init() -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_diag_add() -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_diag_solve() -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bws_init(k: u32) -> i32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bws_true() -> u64 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bws_var(i: u32) -> u64 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bws_and(a: u64, b: u64) -> u64 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bws_equal(a: u64, b: u64) -> u8 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn constants_count() -> u32 from "constants.iii"
extern @abi(c-msvc-x64) fn constants_value(slot: u32, out: *u8, cap: u64) -> u64 from "constants.iii"
extern @abi(c-msvc-x64) fn xrp_selftest() -> u64 from "xii_rule_patterns.iii"
extern @abi(c-msvc-x64) fn cpe_count() -> u32 from "xii_critpair_enum.iii"
extern @abi(c-msvc-x64) fn air_reset(w_cols: u32, n_rows: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_get_trace(row: u64, col: u64) -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn builder_new(arena_id: u64, hint: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_len(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn format_char_ascii(builder_id: u64, c: u32) -> i32 from "format.iii"

var SEED : [u8; 32]
var PK   : [u8; 32]
var SIG  : [u8; 64]
var DIR  : [u8; 64]      /* directive byte staging */
var MH   : [u8; 32]      /* witness-inject payload mhash */
var BLOB : [u8; 64]
var ROOT1: [u8; 32]
var ROOT2: [u8; 32]
var CROOT: [u8; 32]
var CWB  : [u8; 32]
var CVAL1: [u8; 64]
var CVAL2: [u8; 64]

fn dir_u64(off: u64, v: u64) {
    let mut i : u64 = 0u64
    while i < 8u64 { DIR[off + i] = ((v >> (i * 8u64)) & 0xFFu64) as u8   i = i + 1u64 }
}

fn dir_u32(off: u64, v: u32) {
    let mut i : u64 = 0u64
    while i < 4u64 { DIR[off + i] = (((v as u64) >> (i * 8u64)) & 0xFFu64) as u8   i = i + 1u64 }
}

fn dir_lit(off: u64, src_addr: u64, n: u64) {
    let s : *u8 = src_addr as *u8
    let mut i : u64 = 0u64
    while i < n { DIR[off + i] = s[i]   i = i + 1u64 }
}

fn sign_dir(n: u64) -> u8 {
    return ed25519_sign(((&SEED as u64)) as *u8, ((&PK as u64)) as *u8,
                        ((&DIR as u64)) as *u8, n, ((&SIG as u64)) as *u8)
}

fn main() -> u64 {
    let mut i : u64 = 0u64
    while i < 32u64 {
        SEED[i] = (0x60u64 + i & 0xFFu64) as u8
        MH[i]   = (0x90u64 + i & 0xFFu64) as u8
        CROOT[i] = (0x21u64 + i & 0xFFu64) as u8
        i = i + 1u64
    }
    if ed25519_pubkey(((&SEED as u64)) as *u8, ((&PK as u64)) as *u8) != 1u8 { return 1u64 }

    /* ---- FOUNDERS: pfs-deny "III-FOUNDERS-PFS-DENY-V1"(24)||kind(1)||id(8)||reason(1) ---- */
    dir_lit(0u64, ("III-FOUNDERS-PFS-DENY-V1" as u64), 24u64)
    DIR[24u64] = 7u8
    dir_u64(25u64, 0x1122334455u64)
    DIR[33u64] = 3u8
    if sign_dir(34u64) != 1u8 { return 2u64 }
    if fa_pfs_deny_verify(((&PK as u64)) as *u8, 7u8, 0x1122334455u64, 3u8, ((&SIG as u64)) as *u8) != 1u8 { return 3u64 }
    if fa_pfs_deny_verify(((&PK as u64)) as *u8, 7u8, 0x1122334455u64, 4u8, ((&SIG as u64)) as *u8) != 0u8 { return 4u64 }   /* param bound */
    SIG[5u64] = SIG[5u64] ^ 0x11u8
    if fa_pfs_deny_verify(((&PK as u64)) as *u8, 7u8, 0x1122334455u64, 3u8, ((&SIG as u64)) as *u8) != 0u8 { return 5u64 }   /* sig bound */
    SIG[5u64] = SIG[5u64] ^ 0x11u8

    /* ---- FOUNDERS: witness-inject ck(2 LE)||mhash[32]||ts(8)||flags(4) = 46 ---- */
    DIR[0u64] = 0x34u8
    DIR[1u64] = 0x12u8                                     /* cycle_kind 0x1234 LE */
    dir_lit(2u64, (&MH as u64), 32u64)
    dir_u64(34u64, 0xAABBCCu64)
    dir_u32(42u64, 0xF00Du32)
    if sign_dir(46u64) != 1u8 { return 6u64 }
    if fa_witness_inject_verify(((&PK as u64)) as *u8, 0x1234u32, ((&MH as u64)) as *u8, 0xAABBCCu64, 0xF00Du32, ((&SIG as u64)) as *u8) != 1u8 { return 7u64 }
    if fa_witness_inject_verify(((&PK as u64)) as *u8, 0x1234u32, ((&MH as u64)) as *u8, 0xAABBCDu64, 0xF00Du32, ((&SIG as u64)) as *u8) != 0u8 { return 8u64 }

    /* ---- FOUNDERS: revoke "III-FOUNDERS-REVOKE-V1"(22)||pid(8)||cascade(1) = 31 ---- */
    dir_lit(0u64, ("III-FOUNDERS-REVOKE-V1" as u64), 22u64)
    dir_u64(22u64, 0xCAFE99u64)
    DIR[30u64] = 1u8
    if sign_dir(31u64) != 1u8 { return 9u64 }
    if fa_revoke_verify(((&PK as u64)) as *u8, 0xCAFE99u64, 1u8, ((&SIG as u64)) as *u8) != 1u8 { return 10u64 }
    if fa_revoke_verify(((&PK as u64)) as *u8, 0xCAFE99u64, 0u8, ((&SIG as u64)) as *u8) != 0u8 { return 11u64 }   /* cascade bound */

    /* ---- ERASURE: params exact; root nonzero, deterministic, content-sensitive ---- */
    let mut b : u64 = 0u64
    while b < 64u64 { BLOB[b] = (b * 7u64 & 0xFFu64) as u8   b = b + 1u64 }
    if es_encode((&BLOB as u64), 64u32, 4u32, 6u32) != 0i32 { return 20u64 }
    if es_n() != 6u32 { return 21u64 }
    if es_k() != 4u32 { return 22u64 }
    let rp : u64 = es_root_ptr()
    if rp == 0u64 { return 23u64 }
    let rb : *u8 = rp as *u8
    let mut nz : u32 = 0u32
    let mut j : u64 = 0u64
    while j < 32u64 { ROOT1[j] = rb[j]   if rb[j] != 0u8 { nz = nz + 1u32 }   j = j + 1u64 }
    if nz == 0u32 { return 24u64 }
    BLOB[10u64] = BLOB[10u64] ^ 0xFFu8
    if es_encode((&BLOB as u64), 64u32, 4u32, 6u32) != 0i32 { return 25u64 }
    let mut diff : u32 = 0u32
    let mut j2 : u64 = 0u64
    while j2 < 32u64 { if rb[j2] != ROOT1[j2] { diff = diff + 1u32 }   j2 = j2 + 1u64 }
    if diff == 0u32 { return 26u64 }                       /* content-sensitive */
    BLOB[10u64] = BLOB[10u64] ^ 0xFFu8
    if es_encode((&BLOB as u64), 64u32, 4u32, 6u32) != 0i32 { return 27u64 }
    let mut j3 : u64 = 0u64
    while j3 < 32u64 { if rb[j3] != ROOT1[j3] { return 28u64 }   j3 = j3 + 1u64 }   /* deterministic */

    /* ---- CLOSURE + RESOLVER SEAL: the before/after laws ---- */
    if closure_includes_resolver_seal() != 0u8 { return 30u64 }       /* pre-seal */
    if closure_with_resolver_byte(0u32) != 0x100u32 { return 31u64 }  /* pre-compute sentinel */
    if closure_set((&CROOT as u64)) != 0i32 { return 32u64 }
    if seal_resolver_compute() != 0i32 { return 33u64 }
    if closure_includes_resolver_seal() != 1u8 { return 34u64 }       /* post-seal */
    if closure_compute_with_resolver() != 0i32 { return 35u64 }
    let mut k : u32 = 0u32
    while k < 32u32 {
        let v : u32 = closure_with_resolver_byte(k)
        if v > 0xFFu32 { return 36u64 }
        CWB[(k as u64) & 0x1Fu64] = (v & 0xFFu32) as u8
        k = k + 1u32
    }
    if closure_with_resolver_byte(32u32) != 0x100u32 { return 37u64 } /* OOB */
    if closure_compute_with_resolver() != 0i32 { return 38u64 }       /* recompute: same bytes */
    let mut k2 : u32 = 0u32
    while k2 < 32u32 {
        if closure_with_resolver_byte(k2) != (CWB[(k2 as u64) & 0x1Fu64] as u32) { return 39u64 }
        k2 = k2 + 1u32
    }

    /* ---- BIT-BLAST diagnostics: sentinels replaced by a real decide ---- */
    if bb_diag_init() != 0x7Fi32 { return 40u64 }          /* virgin sentinels */
    if bb_diag_solve() != 0x7Fi32 { return 41u64 }
    if bb_reset(4u64) != 0i32 { return 42u64 }
    let x : u32 = bb_var(0u32)
    let t : u32 = bb_and(x, x)
    if bb_equal(t, x) != 1u8 { return 43u64 }              /* x&x == x at w=4 */
    if bb_diag_init() == 0x7Fi32 { return 44u64 }          /* the engine RAN */
    if bb_diag_solve() == 0x7Fi32 { return 45u64 }
    if bb_diag_add() != 0i32 { return 46u64 }              /* no clause refused */

    /* ---- WAVE: TRUE AND x == x (pointwise); TRUE != x ---- */
    if bws_init(3u32) != 0i32 { return 50u64 }
    let tt : u64 = bws_true()
    let xv : u64 = bws_var(0u32)
    let ax : u64 = bws_and(tt, xv)
    if bws_equal(ax, xv) != 1u8 { return 51u64 }
    if bws_equal(tt, xv) != 0u8 { return 52u64 }

    /* ---- CONSTANTS: stable nonzero value; dead slots 0 ---- */
    let cc : u32 = constants_count()
    if cc == 0u32 { return 60u64 }
    let v1 : u64 = constants_value(1u32, ((&CVAL1 as u64)) as *u8, 64u64)
    if v1 == 0u64 { return 61u64 }
    let v2 : u64 = constants_value(1u32, ((&CVAL2 as u64)) as *u8, 64u64)
    if v2 != v1 { return 62u64 }
    let mut m : u64 = 0u64
    let mut lim : u64 = v1
    if lim > 64u64 { lim = 64u64 }
    while m < lim { if CVAL1[m] != CVAL2[m] { return 63u64 }   m = m + 1u64 }
    if constants_value(0u32, ((&CVAL1 as u64)) as *u8, 64u64) != 0u64 { return 64u64 }
    if constants_value(cc + 1u32, ((&CVAL1 as u64)) as *u8, 64u64) != 0u64 { return 65u64 }

    /* ---- CRITPAIRS: deterministic enumeration ---- */
    if xrp_selftest() != 99u64 { return 70u64 }
    let c1 : u32 = cpe_count()
    let c2 : u32 = cpe_count()
    if c1 != c2 { return 71u64 }

    /* ---- AIR: exact trace cell + OOB zeros ---- */
    if air_reset(4u32, 8u32) != 0i32 { return 80u64 }
    if air_set_trace(2u64, 3u64, 77u32) != 0i32 { return 81u64 }
    if air_get_trace(2u64, 3u64) != 77u32 { return 82u64 }
    if air_get_trace(0u64, 5u64) != 0u32 { return 83u64 }      /* OOB col */
    if air_get_trace(1000000u64, 0u64) != 0u32 { return 84u64 } /* OOB row */

    /* ---- FORMAT: one byte per char, ASCII-masked ---- */
    let ar : u64 = arena_new(1024u64)
    if ar == 0u64 { return 90u64 }
    let bld : u64 = builder_new(ar, 4u64)
    if bld == 0u64 { return 91u64 }
    if format_char_ascii(bld, 0x41u32) != 0i32 { return 92u64 }
    if builder_len(bld) != 1u64 { return 93u64 }
    if format_char_ascii(bld, 0x141u32) != 0i32 { return 94u64 }   /* masked to one byte */
    if builder_len(bld) != 2u64 { return 95u64 }

    return 99u64
}
