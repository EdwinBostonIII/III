/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\1401_gap_conjecture.iii
 *
 * Falsifier KAT for nous::gap_conjecture (autogenesis Wave C #1).  Positive arm: sound structural
 * laws hold pointwise and saturate clean (ADMITTED).  Biting negative arm: the false probe is
 * REFUTED with a concrete counterexample (cx==0).  Safety arm: a budget timeout is GAP, never a
 * false admission.  Composition arms: proposals read the self-model (sm_next_gap / sm_node_cost)
 * and ride the existing nous_conjecture_gen disposer.  Emit arm: the loop writes its own test. */

module corpus_1401_gap_conjecture

extern @abi(c-msvc-x64) fn gc_law_holds(law: u32, x: u32) -> u8 from "gap_conjecture.iii"
extern @abi(c-msvc-x64) fn gc_scan(law: u32, n: u32) -> u32 from "gap_conjecture.iii"
extern @abi(c-msvc-x64) fn gc_propose(node_i: u64) -> u8 from "gap_conjecture.iii"
extern @abi(c-msvc-x64) fn gc_propose_next() -> u8 from "gap_conjecture.iii"
extern @abi(c-msvc-x64) fn gc_propose_budgeted(node_i: u64, budget: u32) -> u8 from "gap_conjecture.iii"
extern @abi(c-msvc-x64) fn gc_test_law(law: u32) -> u8 from "gap_conjecture.iii"
extern @abi(c-msvc-x64) fn gc_check_base(kind: u32) -> i32 from "gap_conjecture.iii"
extern @abi(c-msvc-x64) fn gc_outcome() -> u8 from "gap_conjecture.iii"
extern @abi(c-msvc-x64) fn gc_cx() -> u32 from "gap_conjecture.iii"
extern @abi(c-msvc-x64) fn gc_last_law() -> u32 from "gap_conjecture.iii"
extern @abi(c-msvc-x64) fn gc_emit_falsifier(out: u64, max: u64) -> i32 from "gap_conjecture.iii"

var KBUF : [u8; 512]

fn main() -> u64 {
    if gc_law_holds(0u32, 0u32) != 1u8 { return 1u64 }
    if gc_law_holds(0u32, 7u32) != 1u8 { return 2u64 }
    if gc_law_holds(3u32, 123u32) != 1u8 { return 3u64 }
    if gc_law_holds(4u32, 0u32) != 0u8 { return 4u64 }

    if gc_scan(0u32, 256u32) != 256u32 { return 5u64 }
    if gc_scan(4u32, 256u32) != 0u32 { return 6u64 }

    let a : u8 = gc_test_law(1u32)
    if a != 0u8 { return 7u64 }
    if gc_outcome() != 0u8 { return 8u64 }
    if gc_last_law() != 1u32 { return 9u64 }

    let r : u8 = gc_test_law(4u32)
    if r != 2u8 { return 10u64 }
    if gc_outcome() != 2u8 { return 11u64 }
    if gc_cx() != 0u32 { return 12u64 }

    let g : u8 = gc_propose_budgeted(0u64, 0u32)
    if g != 1u8 { return 13u64 }

    let n : u8 = gc_propose_next()
    if n != 0u8 { return 14u64 }

    let p : u8 = gc_propose(0u64)
    if p != 0u8 { return 15u64 }

    if gc_check_base(0u32) != 1i32 { return 16u64 }
    if gc_check_base(3u32) != -1i32 { return 17u64 }

    let ln : i32 = gc_emit_falsifier((&KBUF as u64), 512u64)
    if ln <= 0i32 { return 18u64 }
    if KBUF[0u64] != 109u8 { return 19u64 }
    if KBUF[7u64] != 99u8 { return 20u64 }

    return 99u64
}
