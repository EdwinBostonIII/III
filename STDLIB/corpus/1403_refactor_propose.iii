 *
 * Falsifier KAT for nous::refactor_propose (autogenesis Wave C #3).  Positive arm: two skeletons
 * asserted equivalent share an e-class and saturate complete (rp_equiv == 1), and a sound CIC proof
 * certifies the refactor through commit_gate, realizing the congruence-ring merge (class count -1).
 * Biting structural arm: a genuinely distinct skeleton is NOT equivalent (rp_equiv == 0).  Biting
 * kernel arm: a wrong proof yields CG_REJECT_KERNEL (-5) and leaves the ring untouched. */

module corpus_1403_refactor_propose

extern @abi(c-msvc-x64) fn rp_scan() -> u64 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_ncand() -> u64 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_kind(k: u64) -> u32 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_equiv(a: u32, b: u32) -> u8 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_tf() -> u32 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_tg() -> u32 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_th() -> u32 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_rule_sound(k: u64) -> u32 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_classes() -> u32 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_goal() -> u32 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_proof_ok() -> u32 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_proof_bad() -> u32 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn rp_certify(k: u64, proof: u32) -> i32 from "refactor_propose.iii"

fn main() -> u64 {
    let nc : u64 = rp_scan()
    if nc < 2u64 { return 1u64 }
    if rp_ncand() != nc { return 2u64 }
    if rp_kind(0u64) != 1u32 { return 3u64 }
    if rp_kind(1u64) != 2u32 { return 4u64 }
    if rp_kind(999u64) != 0u32 { return 5u64 }

    if rp_equiv(rp_tf(), rp_tg()) != 1u8 { return 6u64 }
    if rp_equiv(rp_tf(), rp_th()) != 0u8 { return 7u64 }

    if rp_rule_sound(0u64) != 1u32 { return 8u64 }
    if rp_rule_sound(1u64) != 1u32 { return 9u64 }
    if rp_goal() == 0u32 { return 10u64 }

    let c0 : u32 = rp_classes()

    let pbad : u32 = rp_proof_bad()
    if rp_certify(0u64, pbad) == 0i32 { return 11u64 }
    if rp_classes() != c0 { return 12u64 }

    let pok : u32 = rp_proof_ok()
    if rp_certify(0u64, pok) != 0i32 { return 13u64 }
    if rp_classes() != (c0 - 1u32) { return 14u64 }

    return 99u64
}
