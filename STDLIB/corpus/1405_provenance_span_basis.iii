/* 1405_provenance_span_basis.iii -- SCALAR OVERFLOW PROVENANCE, SPAN BOUNDS, XII BASIS
 * ALGEBRA (burn-down tranche 14; ~16 census orphans).
 *
 *  SCALAR PROVENANCE (4): sp_u32_sub/mul, sp_u64_add/sub -- a NON-event returns 0 (no
 *      crystal minted); an overflow/underflow MINTS a verified crystal whose code is the
 *      documented op code (0x5102/03/04/05) -- the same crystal-on-error discipline 1393
 *      proved for checked_crystal, here at the scalar layer;
 *  SPAN u8 (2): span_u8_store bounds law (idx<len writes the masked byte; idx>=len refuses
 *      E_BOUNDS; null refuses E_NULL), span_u8_copy cap laws (n<=both lens copies exactly;
 *      n over either len refuses; null refuses);
 *  STRING (1): str_byte_len is the identity on len (the documented byte-length contract);
 *  XII BASIS (9): kind predicates are MUTUALLY EXCLUSIVE over every legal kind
 *      (origin/motion/essence at most one), is_fusion_op is UPWARD CLOSED (a threshold
 *      predicate), kind_max is the top, and the four term accessors are KIND-FUNCTIONS:
 *      two terms of the same kind agree on k_cost/hexad/cap_class/mpo_weight, all total
 *      and deterministic.
 * Exit 99. */
module corpus_1405

extern @abi(c-msvc-x64) fn sp_u32_sub(a: u32, b: u32) -> u64 from "scalar_provenance.iii"
extern @abi(c-msvc-x64) fn sp_u32_mul(a: u32, b: u32) -> u64 from "scalar_provenance.iii"
extern @abi(c-msvc-x64) fn sp_u64_add(a: u64, b: u64) -> u64 from "scalar_provenance.iii"
extern @abi(c-msvc-x64) fn sp_u64_sub(a: u64, b: u64) -> u64 from "scalar_provenance.iii"
extern @abi(c-msvc-x64) fn crystal_code(id: u64) -> u32 from "crystal.iii"
extern @abi(c-msvc-x64) fn crystal_verify(id: u64) -> u8 from "crystal.iii"
extern @abi(c-msvc-x64) fn span_u8_store(base: u64, len: u64, idx: u64, value: u32) -> i32 from "span.iii"
extern @abi(c-msvc-x64) fn span_u8_copy(dst: u64, dst_len: u64, src: u64, src_len: u64, n: u64) -> i32 from "span.iii"
extern @abi(c-msvc-x64) fn str_byte_len(base: u64, len: u64) -> u64 from "string.iii"
extern @abi(c-msvc-x64) fn xii_basis_is_origin(kind: u8) -> u8 from "xii_basis.iii"
extern @abi(c-msvc-x64) fn xii_basis_is_motion(kind: u8) -> u8 from "xii_basis.iii"
extern @abi(c-msvc-x64) fn xii_basis_is_essence(kind: u8) -> u8 from "xii_basis.iii"
extern @abi(c-msvc-x64) fn xii_basis_is_fusion_op(kind: u8) -> u8 from "xii_basis.iii"
extern @abi(c-msvc-x64) fn xii_basis_kind_max() -> u8 from "xii_basis.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, subform: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_basis_term_k_cost(term_ref: u32) -> u32 from "xii_basis.iii"
extern @abi(c-msvc-x64) fn xii_basis_term_hexad(term_ref: u32) -> u8 from "xii_basis.iii"
extern @abi(c-msvc-x64) fn xii_basis_term_cap_class(term_ref: u32) -> u32 from "xii_basis.iii"
extern @abi(c-msvc-x64) fn xii_basis_term_mpo_weight(term_ref: u32) -> u32 from "xii_basis.iii"

var SBUF : [u8; 16]
var DBUF : [u8; 16]

fn main() -> u64 {
    /* ---- SCALAR PROVENANCE: silence on non-events, verified crystals on events ---- */
    if sp_u32_sub(5u32, 3u32) != 0u64 { return 1u64 }                  /* no underflow: silent */
    let c1 : u64 = sp_u32_sub(1u32, 2u32)
    if c1 == 0u64 { return 2u64 }                                      /* underflow minted */
    if crystal_code(c1) != 0x5102u32 { return 3u64 }
    if crystal_verify(c1) != 1u8 { return 4u64 }
    if sp_u32_mul(6u32, 7u32) != 0u64 { return 5u64 }
    let c2 : u64 = sp_u32_mul(0x10000u32, 0x10000u32)
    if c2 == 0u64 { return 6u64 }
    if crystal_code(c2) != 0x5103u32 { return 7u64 }
    if sp_u64_add(40u64, 2u64) != 0u64 { return 8u64 }
    let c3 : u64 = sp_u64_add(0xFFFFFFFFFFFFFFFFu64, 1u64)
    if c3 == 0u64 { return 9u64 }
    if crystal_code(c3) != 0x5104u32 { return 10u64 }
    if sp_u64_sub(9u64, 4u64) != 0u64 { return 11u64 }
    let c4 : u64 = sp_u64_sub(0u64, 1u64)
    if c4 == 0u64 { return 12u64 }
    if crystal_code(c4) != 0x5105u32 { return 13u64 }
    if crystal_verify(c4) != 1u8 { return 14u64 }

    /* ---- SPAN u8: bounds + cap laws, exact codes ---- */
    if span_u8_store((&SBUF as u64), 16u64, 3u64, 0x1ABu32) != 0i32 { return 20u64 }
    if SBUF[3u64] != 0xABu8 { return 21u64 }                           /* masked write */
    if span_u8_store((&SBUF as u64), 16u64, 16u64, 1u32) != -1i32 { return 22u64 }   /* E_BOUNDS */
    if span_u8_store(0u64, 16u64, 0u64, 1u32) != -2i32 { return 23u64 }              /* E_NULL */
    let mut i : u64 = 0u64
    while i < 8u64 { SBUF[i] = (0x40u64 + i & 0xFFu64) as u8   i = i + 1u64 }
    if span_u8_copy((&DBUF as u64), 16u64, (&SBUF as u64), 8u64, 8u64) != 0i32 { return 24u64 }
    let mut j : u64 = 0u64
    while j < 8u64 { if DBUF[j] != SBUF[j] { return 25u64 }   j = j + 1u64 }
    if span_u8_copy((&DBUF as u64), 4u64, (&SBUF as u64), 8u64, 8u64) != -1i32 { return 26u64 }  /* dst cap */
    if span_u8_copy((&DBUF as u64), 16u64, (&SBUF as u64), 4u64, 8u64) != -1i32 { return 27u64 } /* src cap */
    if span_u8_copy(0u64, 16u64, (&SBUF as u64), 8u64, 4u64) != -2i32 { return 28u64 }

    /* ---- STRING: byte-length contract ---- */
    if str_byte_len((&SBUF as u64), 7u64) != 7u64 { return 30u64 }
    if str_byte_len((&SBUF as u64), 0u64) != 0u64 { return 31u64 }

    /* ---- XII BASIS: partition + threshold laws over EVERY legal kind ---- */
    let kmax : u8 = xii_basis_kind_max()
    if kmax == 0u8 { return 40u64 }
    let mut k : u8 = 0u8
    let mut seen_fusion_start : u8 = 0u8
    let mut scanning : u8 = 1u8
    while scanning == 1u8 {
        let o : u8 = xii_basis_is_origin(k)
        let m : u8 = xii_basis_is_motion(k)
        let e : u8 = xii_basis_is_essence(k)
        if o > 1u8 { return 41u64 }
        if m > 1u8 { return 42u64 }
        if e > 1u8 { return 43u64 }
        let sum : u8 = o + m + e
        if sum > 1u8 { return 44u64 }                                  /* mutual exclusivity */
        let f : u8 = xii_basis_is_fusion_op(k)
        if f == 1u8 { seen_fusion_start = 1u8 }
        if seen_fusion_start == 1u8 {
            if f != 1u8 { return 45u64 }                               /* upward closed */
        }
        if k == kmax { scanning = 0u8 } else { k = k + 1u8 }
    }
    if xii_basis_is_fusion_op(kmax) != 1u8 { return 46u64 }            /* the top is a fusion op */

    /* term accessors are KIND-FUNCTIONS: same kind -> identical four values; total */
    let t1 : u32 = xii_term_make_basis(0u8, 0u32)
    let t2 : u32 = xii_term_make_basis(0u8, 1u32)
    if t1 == 0xFFFFFFFFu32 { return 50u64 }
    if t2 == 0xFFFFFFFFu32 { return 51u64 }
    if xii_basis_term_k_cost(t1) != xii_basis_term_k_cost(t2) { return 52u64 }
    if xii_basis_term_hexad(t1) != xii_basis_term_hexad(t2) { return 53u64 }
    if xii_basis_term_cap_class(t1) != xii_basis_term_cap_class(t2) { return 54u64 }
    if xii_basis_term_mpo_weight(t1) != xii_basis_term_mpo_weight(t2) { return 55u64 }
    /* determinism on repeat */
    if xii_basis_term_k_cost(t1) != xii_basis_term_k_cost(t1) { return 56u64 }

    return 99u64
}
