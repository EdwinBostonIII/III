/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\1405_theorem_grow.iii
 *
 * Falsifier KAT for nous::theorem_grow (autogenesis Wave D).  Positive arm: registered theorems
 * persist to disk and RELOAD with every proof re-checked (2 in, 2 re-admitted).  Monotone arm: the
 * root changes as the registry grows.  Tamper arm: a single appended byte breaks the seal -- verify
 * fails and reload refuses (-1).  Biting kernel arm: a file whose record is FALSE (refl(0) for
 * Id(Nat,0,1)) re-checks to 0 admitted on reload, while the true pair re-admits 1. */

module corpus_1405_theorem_grow

extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn fs_open(cap: u64, path: u64, mode: u32) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_write(h: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_close(h: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_delete(cap: u64, path: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn tc_nat() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_zero() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_succ(n: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_id(ty: u32, lhs: u32, rhs: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_refl(a: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tg_register(proof: u32, goal: u32) -> i32 from "theorem_grow.iii"
extern @abi(c-msvc-x64) fn tg_count() -> u64 from "theorem_grow.iii"
extern @abi(c-msvc-x64) fn tg_root(out_32: u64) -> i32 from "theorem_grow.iii"
extern @abi(c-msvc-x64) fn tg_merkle_root(out_32: u64) -> i32 from "theorem_grow.iii"
extern @abi(c-msvc-x64) fn tg_persist(cap: u64, path: u64) -> i32 from "theorem_grow.iii"
extern @abi(c-msvc-x64) fn tg_reload(cap: u64, path: u64) -> i32 from "theorem_grow.iii"
extern @abi(c-msvc-x64) fn tg_persist_pair(cap: u64, path: u64, proof: u32, goal: u32) -> i32 from "theorem_grow.iii"
extern @abi(c-msvc-x64) fn tg_verify(cap: u64, path: u64) -> u8 from "theorem_grow.iii"

var P1 : [u8; 48]
var P2 : [u8; 48]
var R1 : [u8; 32]
var R2 : [u8; 32]
var ONEB : [u8; 4]

fn bcopy(dst: u64, src: u64, n: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < n {
        let s : *u8 = (src + i) as *u8
        let d : *u8 = (dst + i) as *u8
        d[0u64] = s[0u64]
        i = i + 1u64
    }
    return 0i32
}

fn eq32(a: u64, b: u64) -> u8 {
    let ap : *u8 = a as *u8
    let bp : *u8 = b as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        if ap[i] != bp[i] { return 0u8 }
        i = i + 1u64
    }
    return 1u8
}

fn append_byte(cap: u64, path: u64) -> i32 {
    let h : u64 = fs_open(cap, path, 3u32)
    if h == 0u64 { return -1i32 }
    ONEB[0u64] = 0x5Au8
    fs_write(h, (&ONEB as u64), 1u64)
    fs_close(h)
    return 0i32
}

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)
    bcopy((&P1 as u64), ("./iii_tg_kat_1.bin" as u64), 18u64)
    bcopy((&P2 as u64), ("./iii_tg_kat_2.bin" as u64), 18u64)

    let nat : u32 = tc_nat()
    let z : u32 = tc_zero()
    let one : u32 = tc_succ(z)
    let goal0 : u32 = tc_id(nat, z, z)
    let proof0 : u32 = tc_refl(z)
    let goal1 : u32 = tc_id(nat, one, one)
    let proof1 : u32 = tc_refl(one)
    let goalF : u32 = tc_id(nat, z, one)

    if tg_register(proof0, goal0) != 0i32 { return 1u64 }
    if tg_count() != 1u64 { return 2u64 }
    tg_root((&R1 as u64))
    if tg_register(proof1, goal1) != 0i32 { return 3u64 }
    if tg_count() != 2u64 { return 4u64 }
    tg_root((&R2 as u64))
    if eq32((&R1 as u64), (&R2 as u64)) != 0u8 { return 5u64 }

    if tg_persist(cap, (&P1 as u64)) != 0i32 { return 6u64 }
    if tg_verify(cap, (&P1 as u64)) != 1u8 { return 7u64 }
    if tg_reload(cap, (&P1 as u64)) != 2i32 { return 8u64 }
    if tg_count() != 2u64 { return 9u64 }

    append_byte(cap, (&P1 as u64))
    if tg_verify(cap, (&P1 as u64)) != 0u8 { return 10u64 }
    if tg_reload(cap, (&P1 as u64)) != -1i32 { return 11u64 }

    if tg_persist_pair(cap, (&P2 as u64), proof0, goalF) != 0i32 { return 12u64 }
    if tg_verify(cap, (&P2 as u64)) != 1u8 { return 13u64 }
    if tg_reload(cap, (&P2 as u64)) != 0i32 { return 14u64 }

    if tg_persist_pair(cap, (&P2 as u64), proof0, goal0) != 0i32 { return 15u64 }
    if tg_reload(cap, (&P2 as u64)) != 1i32 { return 16u64 }

    if tg_merkle_root((&R1 as u64)) != 0i32 { return 17u64 }

    fs_delete(cap, (&P1 as u64))
    fs_delete(cap, (&P2 as u64))
    return 99u64
}
