/* 1410_semver_uri_sha512_tp.iii -- SEMVER FIELDS, URI LIFECYCLE, SHA-512 STREAMING,
 * TRANSFORM TABLE METADATA (burn-down tranche 19; ~11 census orphans).
 *
 *  SEMVER (3): semver_last_pre_off / last_build_off / last_build_len -- parsing
 *      "1.2.3-rc.1+build.7" records the EXACT byte spans (pre at off 6 len 4, build at
 *      off 11 len 7); a version with NO build clears build_len to 0;
 *  URI (2): uri_parse + uri_drop -- "http://host/path" parses to scheme "http" (len 4)
 *      and path "/path" (len 5) at the right source offsets; drop frees the slot (the
 *      parsed accessors go to 0); a second drop refuses;
 *  SHA-512 (1): sha512_update_byte -- streaming 'a','b','c' + finalize produces a digest
 *      BYTE-IDENTICAL to sha512_oneshot("abc") (the streaming path == the one-shot path);
 *  TRANSFORM TABLE (3): tp_table_get_src / get_dst read back the EXACT registered
 *      (src_form, dst_form) pairs (idx 0 = 1→3, idx 2 = 2→1, idx 4 = 7→1), idx>=24 reads
 *      0, and tp_table_call on a bad index refuses (0).
 * Exit 99. */
module corpus_1410

extern @abi(c-msvc-x64) fn semver_parse(src: *u8, src_len: u64) -> i32 from "semver.iii"
extern @abi(c-msvc-x64) fn semver_last_major() -> u64 from "semver.iii"
extern @abi(c-msvc-x64) fn semver_last_pre_off() -> u64 from "semver.iii"
extern @abi(c-msvc-x64) fn semver_last_pre_len() -> u64 from "semver.iii"
extern @abi(c-msvc-x64) fn semver_last_build_off() -> u64 from "semver.iii"
extern @abi(c-msvc-x64) fn semver_last_build_len() -> u64 from "semver.iii"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn uri_parse(arena: u64, raw_base: u64, raw_len: u64) -> u64 from "uri.iii"
extern @abi(c-msvc-x64) fn uri_drop(id: u64) -> i32 from "uri.iii"
extern @abi(c-msvc-x64) fn uri_scheme_len(id: u64) -> u64 from "uri.iii"
extern @abi(c-msvc-x64) fn uri_scheme_base(id: u64) -> u64 from "uri.iii"
extern @abi(c-msvc-x64) fn uri_path_len(id: u64) -> u64 from "uri.iii"
extern @abi(c-msvc-x64) fn sha512_oneshot(input: *u8, len: u64, out_64: *u8) -> u32 from "sha512.iii"
extern @abi(c-msvc-x64) fn sha512_digest_byte(i: u32) -> u32 from "sha512.iii"
extern @abi(c-msvc-x64) fn sha512_init() -> u32 from "sha512.iii"
extern @abi(c-msvc-x64) fn sha512_update_byte(b: u32) -> u32 from "sha512.iii"
extern @abi(c-msvc-x64) fn sha512_finalize_internal() -> u32 from "sha512.iii"
extern @abi(c-msvc-x64) fn transform_register_all() -> i32 from "transform_patterns.iii"
extern @abi(c-msvc-x64) fn tp_table_get_src(idx: u32) -> u8 from "transform_patterns.iii"
extern @abi(c-msvc-x64) fn tp_table_get_dst(idx: u32) -> u8 from "transform_patterns.iii"
extern @abi(c-msvc-x64) fn tp_table_call(idx: u32, src: u64, src_len: u64, dst: u64, dst_cap: u64) -> u64 from "transform_patterns.iii"

var SV1 : [u8; 32]
var SV2 : [u8; 16]
var URL : [u8; 32]
var ABC : [u8; 4]
var OUT : [u8; 64]
var WANT : [u8; 64]      /* module-scope: a function-local array indexed by a loop var segfaults */

fn setb(dst_addr: u64, src_addr: u64, n: u64) {
    let d : *u8 = dst_addr as *u8
    let s : *u8 = src_addr as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]   i = i + 1u64 }
}

fn main() -> u64 {
    /* ---- SEMVER: exact field spans ---- */
    setb((&SV1 as u64), ("1.2.3-rc.1+build.7" as u64), 18u64)
    if semver_parse(((&SV1 as u64)) as *u8, 18u64) != 0i32 { return 1u64 }
    if semver_last_major() != 1u64 { return 2u64 }
    if semver_last_pre_off() != 6u64 { return 3u64 }                   /* "rc.1" starts at 6 */
    if semver_last_pre_len() != 4u64 { return 4u64 }
    if semver_last_build_off() != 11u64 { return 5u64 }                /* "build.7" starts at 11 */
    if semver_last_build_len() != 7u64 { return 6u64 }
    /* a version with no build clears build_len */
    setb((&SV2 as u64), ("2.0.0" as u64), 5u64)
    if semver_parse(((&SV2 as u64)) as *u8, 5u64) != 0i32 { return 7u64 }
    if semver_last_major() != 2u64 { return 8u64 }
    if semver_last_build_len() != 0u64 { return 9u64 }

    /* ---- URI: parse spans + drop lifecycle ---- */
    setb((&URL as u64), ("http://host/path" as u64), 16u64)
    let ar : u64 = arena_new(8192u64)
    if ar == 0u64 { return 20u64 }
    let u : u64 = uri_parse(ar, (&URL as u64), 16u64)
    if u == 0u64 { return 21u64 }
    if uri_scheme_len(u) != 4u64 { return 22u64 }                      /* "http" */
    if uri_scheme_base(u) != (&URL as u64) { return 23u64 }
    if uri_path_len(u) != 5u64 { return 24u64 }                        /* "/path" */
    if uri_drop(u) != 0i32 { return 25u64 }
    if uri_scheme_len(u) != 0u64 { return 26u64 }                      /* dropped -> 0 */
    if uri_drop(u) == 0i32 { return 27u64 }                            /* second drop refuses */

    /* ---- SHA-512: streaming == one-shot ---- */
    ABC[0u64] = 0x61u8
    ABC[1u64] = 0x62u8
    ABC[2u64] = 0x63u8
    sha512_oneshot(((&ABC as u64)) as *u8, 3u64, ((&OUT as u64)) as *u8)
    /* OUT now holds the one-shot digest; also capture the digest-byte view */
    let mut i : u32 = 0u32
    while i < 64u32 {
        WANT[(i as u64) & 0x3Fu64] = (sha512_digest_byte(i) & 0xFFu32) as u8
        i = i + 1u32
    }
    if sha512_init() != 0u32 { return 30u64 }
    if sha512_update_byte(0x61u32) != 0u32 { return 31u64 }
    if sha512_update_byte(0x62u32) != 0u32 { return 32u64 }
    if sha512_update_byte(0x63u32) != 0u32 { return 33u64 }
    if sha512_finalize_internal() != 0u32 { return 34u64 }
    let mut j : u32 = 0u32
    while j < 64u32 {
        if (sha512_digest_byte(j) & 0xFFu32) != (WANT[(j as u64) & 0x3Fu64] as u32) { return 35u64 }
        j = j + 1u32
    }
    /* and the OUT buffer (oneshot wrote it) matches the digest-byte view */
    if OUT[0u64] != WANT[0u64] { return 36u64 }
    if OUT[63u64] != WANT[63u64] { return 37u64 }

    /* ---- TRANSFORM TABLE: exact registered (src,dst); bad index refusals ---- */
    if transform_register_all() != 0i32 { return 40u64 }
    if tp_table_get_src(0u32) != 1u8 { return 41u64 }                  /* idx 0 = 1 -> 3 */
    if tp_table_get_dst(0u32) != 3u8 { return 42u64 }
    if tp_table_get_src(2u32) != 2u8 { return 43u64 }                  /* idx 2 = 2 -> 1 */
    if tp_table_get_dst(2u32) != 1u8 { return 44u64 }
    if tp_table_get_src(4u32) != 7u8 { return 45u64 }                  /* idx 4 = 7 -> 1 */
    if tp_table_get_dst(4u32) != 1u8 { return 46u64 }
    if tp_table_get_src(24u32) != 0u8 { return 47u64 }                 /* OOB -> 0 */
    if tp_table_get_dst(24u32) != 0u8 { return 48u64 }
    if tp_table_call(99u32, (&ABC as u64), 3u64, (&OUT as u64), 64u64) != 0u64 { return 49u64 }   /* bad idx refused */

    return 99u64
}
