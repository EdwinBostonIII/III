/* 1411_sovereign_optimizer.iii -- THE CONSTANTLY-RUNNING SOVEREIGN OPTIMIZER, OBSERVED
 * (burn-down tranche 20; 5 census orphans on the autonomous self-optimization loop).
 *
 * sovereign_optimizer is III's autonomous discovery loop: each tick hallucinates a strength
 * candidate and disposes it through the CIC kernel sieve; certified discoveries accumulate in
 * a VOLATILE registry (no sealed-state mutation -- M20/ADR-FORGE-4).  The census flagged the
 * observation surface as consumer-less; this KAT drives the loop and proves its contract:
 *  (1) MONOTONE + ENHANCING -- sopt_run_continuous discovers >= 1 optimization and the
 *      discovered count never decreases across the session;
 *  (2) CONVERGENT FIXPOINT -- after enough ticks the count reaches the full distinct
 *      strength space (4) and a further burst discovers NOTHING new (runs harmlessly
 *      forever, no churn); sopt_ticks counts every tick exactly;
 *  (3) DETERMINISTIC -- a fresh session with the same seed reaches the identical fixpoint;
 *  (4) NON-IMPAIRING TOTALS -- sopt_total_certified == the proven catalog PLUS the
 *      autonomously-discovered set (> the catalog alone, since the dream finds >= 1), and
 *      sopt_total_cost_saved is the (positive, deterministic) census cost.
 * Exit 99 = the optimizer that runs constantly is proven non-impairing, enhancing, and
 * convergent -- exactly the "perfect system enhances itself even while working perfectly". */
module corpus_1411

extern @abi(c-msvc-x64) fn sopt_init(seed: u64) -> u64 from "sovereign_optimizer.iii"
extern @abi(c-msvc-x64) fn sopt_run_continuous(n_ticks: u32) -> u32 from "sovereign_optimizer.iii"
extern @abi(c-msvc-x64) fn sopt_discovered() -> u32 from "sovereign_optimizer.iii"
extern @abi(c-msvc-x64) fn sopt_ticks() -> u64 from "sovereign_optimizer.iii"
extern @abi(c-msvc-x64) fn sopt_total_certified() -> u32 from "sovereign_optimizer.iii"
extern @abi(c-msvc-x64) fn sopt_total_cost_saved() -> u64 from "sovereign_optimizer.iii"
extern @abi(c-msvc-x64) fn census_certified() -> u32 from "scythe_census.iii"

const SEED : u64 = 0x5A5A5A5A12345678u64

fn main() -> u64 {
    /* (1) + (2): run a long session; discover the full space; count ticks exactly */
    sopt_init(SEED)
    if sopt_discovered() != 0u32 { return 1u64 }
    if sopt_ticks() != 0u64 { return 2u64 }
    let d1 : u32 = sopt_run_continuous(300u32)
    if d1 < 1u32 { return 3u64 }                            /* enhancing / non-vacuous */
    if d1 != 4u32 { return 4u64 }                           /* full distinct strength space */
    if sopt_discovered() != 4u32 { return 5u64 }
    if sopt_ticks() != 300u64 { return 6u64 }               /* exact tick count */

    /* (2) CONVERGENT: a further burst discovers nothing new */
    let d2 : u32 = sopt_run_continuous(100u32)
    if d2 != 4u32 { return 7u64 }                           /* fixpoint: no churn */
    if sopt_ticks() != 400u64 { return 8u64 }

    /* (3) DETERMINISTIC: fresh same-seed session reaches the identical fixpoint */
    sopt_init(SEED)
    if sopt_discovered() != 0u32 { return 9u64 }            /* init clears */
    if sopt_run_continuous(300u32) != 4u32 { return 10u64 }

    /* (4) NON-IMPAIRING TOTALS: certified == catalog + autonomously-discovered (> catalog) */
    let catalog : u32 = census_certified()
    if catalog == 0u32 { return 11u64 }
    let total : u32 = sopt_total_certified()
    if total <= catalog { return 12u64 }                   /* the dream adds >= 1 */
    if sopt_total_cost_saved() == 0u64 { return 13u64 }     /* positive, data-driven */

    return 99u64
}
