/* 1424_solve_sandbox_sign_measure.iii -- VERIFIED SAT-SOLVE, SANDBOX QUOTA/RESULT,
 * TCP RIGHTS REFUSALS, WITNESS-ROLE SIGNING, HDL NORMALIZING COMPILE, QUINE SELF-MEASURE
 * (burn-down tranche 33; 9 census orphans).
 *
 *  SATS (2): sats_solve over the 56-byte SatsReq -- a SAT unit formula solves to result 1
 *      with a 5-byte model cert RE-VERIFIED independently (sats_verify), and an UNSAT
 *      complementary-unit pair to result 0 with a 16-byte refutation; sats_verify_len
 *      reports the staged cert length EXACTLY (== the LE u32 written to out_cert_len);
 *      a cap without SATS_RIGHT_SOLVE is DENIED, a null formula refused, a bad magic
 *      BADFMT, and a tampered model cert REJECTED by the verifier;
 *  SANDBOX (2): cpu quota is append-only exact accounting -- 300 then refuse-800 (the
 *      refusal commits NOTHING) then admit-700 to the exact 1000 cap then refuse-1;
 *      sandbox_result round-trips set_result, dead/dropped ids read 0;
 *  TCP (2): connect/listen with a cap lacking DIAL(0x20)/LISTEN(0x40) -- and the null
 *      cap -- refuse with handle 0 BEFORE any socket exists (pure rights gate);
 *  NI (1): ni_witness_sign pre-init refuses -1; after ni_init the detached RFC-8032
 *      signature VERIFIES under ni_witness_pub, is deterministic (re-sign byte-identical),
 *      rejects a tampered msg AND a tampered sig, and the identity-role signature does
 *      NOT verify under the witness pubkey (role separation); null out_sig refused;
 *  HC (1): hc_compile_normalized preserves the compiled function (truth table ==
 *      un-normalized compile == the hand-built OR(x,w) oracle) while strictly shrinking
 *      the live-gate count; an underflowing program refuses HC_BAD;
 *  KS (1): ks_self_measure walks a SYNTHETIC PE (e_lfanew->nsec=1->section at RVA 0x1000,
 *      VirtualSize 48) and measures cad(SHA-256) of exactly that window -- byte-equal to
 *      an independent cad_oneshot of the same bytes, reproducible, and flipping one
 *      measured byte changes the digest (content binding).
 * Exit 99. */
module corpus_1424

extern @abi(c-msvc-x64) fn sats_init() -> i32 from "sat_at_scale.iii"
extern @abi(c-msvc-x64) fn sats_solve(req: *u8) -> i32 from "sat_at_scale.iii"
extern @abi(c-msvc-x64) fn sats_verify(formula: *u8, formula_len: u32, result: u8, cert: *u8) -> i32 from "sat_at_scale.iii"
extern @abi(c-msvc-x64) fn sats_verify_len() -> u32 from "sat_at_scale.iii"
extern @abi(c-msvc-x64) fn wh_init(initial_time: u64) -> i32 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn sandbox_new(cap_set: u64, mem_cap_bytes: u64, cpu_cap_micros: u64) -> u64 from "sandbox_ctor.iii"
extern @abi(c-msvc-x64) fn sandbox_set_result(sb_id: u64, result: u64) -> i32 from "sandbox_ctor.iii"
extern @abi(c-msvc-x64) fn sandbox_result(sb_id: u64) -> u64 from "sandbox_ctor.iii"
extern @abi(c-msvc-x64) fn sandbox_drop(sb_id: u64) -> i32 from "sandbox_ctor.iii"
extern @abi(c-msvc-x64) fn sandbox_clear_all() -> i32 from "sandbox_ctor.iii"
extern @abi(c-msvc-x64) fn sandbox_quota_record_cpu(sb_id: u64, micros: u64) -> u8 from "sandbox_quota.iii"
extern @abi(c-msvc-x64) fn sandbox_quota_cpu_used(sb_id: u64) -> u64 from "sandbox_quota.iii"
extern @abi(c-msvc-x64) fn sandbox_quota_clear_all() -> i32 from "sandbox_quota.iii"
extern @abi(c-msvc-x64) fn tcp_connect_ipv4(cap: u64, sockaddr_ptr: u64, sockaddr_len: u32) -> u64 from "tcp.iii"
extern @abi(c-msvc-x64) fn tcp_listen_ipv4(cap: u64, sockaddr_ptr: u64, sockaddr_len: u32) -> u64 from "tcp.iii"
extern @abi(c-msvc-x64) fn ni_is_inited() -> u8 from "node_identity.iii"
extern @abi(c-msvc-x64) fn ni_init(args: *u8) -> i32 from "node_identity.iii"
extern @abi(c-msvc-x64) fn ni_witness_pub(out_pub: *u8) -> i32 from "node_identity.iii"
extern @abi(c-msvc-x64) fn ni_witness_sign(msg: *u8, msg_len: u64, out_sig: *u8) -> i32 from "node_identity.iii"
extern @abi(c-msvc-x64) fn ni_identity_sign(msg: *u8, msg_len: u64, out_sig: *u8) -> i32 from "node_identity.iii"
extern @abi(c-msvc-x64) fn ed25519_verify(pubkey: *u8, msg: *u8, msg_len: u64, sig: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn hdl_reset() -> u64 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_add_in(input_idx: u32) -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_add(kind: u32, a: u32, b: u32) -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_opt_truth_table(out: u32, n: u32) -> u64 from "hdl_optimize.iii"
extern @abi(c-msvc-x64) fn hdl_opt_live(out: u32) -> u32 from "hdl_optimize.iii"
extern @abi(c-msvc-x64) fn hc_tok(op: u32, operand: u32) -> u32 from "hdl_compiler.iii"
extern @abi(c-msvc-x64) fn hc_compile(prog: *u32, n: u32) -> u32 from "hdl_compiler.iii"
extern @abi(c-msvc-x64) fn hc_compile_normalized(prog: *u32, n: u32) -> u32 from "hdl_compiler.iii"
extern @abi(c-msvc-x64) fn ks_self_measure(image_base: u64, out: u64) -> i32 from "quine_seal.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"

const HCBAD : u32 = 0xFFFFFFFFu32

var FORM  : [u8; 64]
var REQ   : [u8; 56]
var ORES  : [u8; 8]
var OCERT : [u8; 64]
var OLEN  : [u8; 4]
var SA    : [u8; 16]
var HW    : [u8; 8]
var BS    : [u8; 8]
var ARGS  : [u8; 32]
var MSG   : [u8; 8]
var PUB   : [u8; 32]
var SIG1  : [u8; 64]
var SIG2  : [u8; 64]
var SIG3  : [u8; 64]
var PROG  : [u32; 8]
var BADP  : [u32; 2]
var KSIMG : [u8; 4160]
var KOUT  : [u8; 32]
var KOUT2 : [u8; 32]
var KEXP  : [u8; 32]

/* LE u32 store through *u8 (params spilled to locals per house discipline). */
fn kw32(p: u64, v: u32) -> i32 {
    let pl : u64 = p
    let vl : u32 = v
    let b : *u8 = pl as *u8
    b[0u64] = (vl & 0xFFu32) as u8
    b[1u64] = ((vl >> 8u32) & 0xFFu32) as u8
    b[2u64] = ((vl >> 16u32) & 0xFFu32) as u8
    b[3u64] = ((vl >> 24u32) & 0xFFu32) as u8
    return 0i32
}

fn kw64(p: u64, v: u64) -> i32 {
    let pl : u64 = p
    let vl : u64 = v
    kw32(pl, (vl & 0xFFFFFFFFu64) as u32)
    kw32(pl + 4u64, ((vl >> 32u64) & 0xFFFFFFFFu64) as u32)
    return 0i32
}

fn rd_olen() -> u32 {
    let b0 : u32 = OLEN[0u64] as u32
    let b1 : u32 = OLEN[1u64] as u32
    let b2 : u32 = OLEN[2u64] as u32
    let b3 : u32 = OLEN[3u64] as u32
    return b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32)
}

fn main() -> u64 {
    /* ---- SATS: cap-gated verified solve over the 56B SatsReq ---- */
    if sats_init() != 0i32 { return 1u64 }
    wh_init(1u64)
    let env : u64 = cap_env_init()
    if env == 0u64 { return 2u64 }
    let capS : u64 = cap_attenuate(env, 0x00010000u64, 0u64)   /* SATS_RIGHT_SOLVE */
    if capS == 0u64 { return 3u64 }
    let capN : u64 = cap_attenuate(env, 0x4u64, 0u64)          /* read-only: no SOLVE/DIAL/LISTEN */
    if capN == 0u64 { return 4u64 }
    let fb : u64 = &FORM as u64
    kw32(fb, 0x53415431u32)            /* SATS_MAGIC */
    kw32(fb + 4u64, 1u32)              /* n_vars = 1 */
    kw32(fb + 8u64, 1u32)              /* n_clauses = 1 */
    kw32(fb + 12u64, 1u32)             /* k = 1 */
    kw32(fb + 16u64, 2u32)             /* lit = pos(x1) */
    let rb : u64 = &REQ as u64
    kw64(rb, fb)                       /* formula ptr   [0..8)  */
    kw32(rb + 8u64, 20u32)             /* formula_len   [8..12) */
    kw64(rb + 16u64, 0u64)             /* budget = default      */
    kw64(rb + 24u64, capS)             /* capability    [24..32) */
    kw64(rb + 32u64, &ORES as u64)
    kw64(rb + 40u64, &OCERT as u64)
    kw64(rb + 48u64, &OLEN as u64)
    if sats_solve(rb as *u8) != 0i32 { return 5u64 }
    if ORES[0u64] != 1u8 { return 6u64 }                       /* SAT */
    if rd_olen() != 5u32 { return 7u64 }                       /* model cert = 4 + n_vars */
    if sats_verify_len() != 5u32 { return 8u64 }               /* the staged length agrees */
    if sats_verify(fb as *u8, 20u32, 1u8, (&OCERT as u64) as *u8) != 0i32 { return 9u64 }
    OCERT[4u64] = 0u8                                          /* tamper assign[1] */
    if sats_verify(fb as *u8, 20u32, 1u8, (&OCERT as u64) as *u8) != -7i32 { return 10u64 }
    kw64(rb + 24u64, capN)
    if sats_solve(rb as *u8) != -6i32 { return 11u64 }         /* DENIED without SOLVE */
    kw64(rb + 24u64, capS)
    kw64(rb, 0u64)
    if sats_solve(rb as *u8) != -1i32 { return 12u64 }         /* null formula */
    kw64(rb, fb)
    kw32(fb, 0xDEADBEEFu32)
    if sats_solve(rb as *u8) != -4i32 { return 13u64 }         /* bad magic */
    kw32(fb, 0x53415431u32)
    kw32(fb + 8u64, 2u32)                                      /* now (x1) AND (~x1) */
    kw32(fb + 20u64, 1u32)
    kw32(fb + 24u64, 3u32)                                     /* lit = neg(x1) */
    kw32(rb + 8u64, 28u32)
    if sats_solve(rb as *u8) != 0i32 { return 14u64 }
    if ORES[0u64] != 0u8 { return 15u64 }                      /* UNSAT */
    if rd_olen() != 16u32 { return 16u64 }                     /* 1-step refutation cert */
    if sats_verify_len() != 16u32 { return 17u64 }
    if sats_verify(fb as *u8, 28u32, 0u8, (&OCERT as u64) as *u8) != 0i32 { return 18u64 }

    /* ---- SANDBOX: exact append-only cpu accounting + result round-trip ---- */
    sandbox_clear_all()
    sandbox_quota_clear_all()
    let sb : u64 = sandbox_new(0xABCu64, 4096u64, 1000u64)
    if sb != 1u64 { return 20u64 }                             /* first slot after clear */
    if sandbox_quota_cpu_used(sb) != 0u64 { return 21u64 }
    if sandbox_quota_record_cpu(sb, 300u64) != 1u8 { return 22u64 }
    if sandbox_quota_cpu_used(sb) != 300u64 { return 23u64 }
    if sandbox_quota_record_cpu(sb, 800u64) != 0u8 { return 24u64 }   /* would exceed 1000 */
    if sandbox_quota_cpu_used(sb) != 300u64 { return 25u64 }   /* the refusal commits NOTHING */
    if sandbox_quota_record_cpu(sb, 700u64) != 1u8 { return 26u64 }   /* head == m admitted */
    if sandbox_quota_cpu_used(sb) != 1000u64 { return 27u64 }  /* the exact cap */
    if sandbox_quota_record_cpu(sb, 1u64) != 0u8 { return 28u64 }
    if sandbox_quota_cpu_used(9999u64) != 0u64 { return 29u64 }       /* dead id */
    if sandbox_result(sb) != 0u64 { return 30u64 }
    if sandbox_set_result(sb, 0xFEEDFACEu64) != 0i32 { return 31u64 }
    if sandbox_result(sb) != 0xFEEDFACEu64 { return 32u64 }
    if sandbox_result(0u64) != 0u64 { return 33u64 }
    sandbox_drop(sb)
    if sandbox_result(sb) != 0u64 { return 34u64 }             /* dropped reads 0 */

    /* ---- TCP: pure rights-gate refusals (no socket is ever created) ---- */
    if tcp_connect_ipv4(capN, (&SA as u64), 16u32) != 0u64 { return 40u64 }
    if tcp_listen_ipv4(capN, (&SA as u64), 16u32) != 0u64 { return 41u64 }
    if tcp_connect_ipv4(0u64, (&SA as u64), 16u32) != 0u64 { return 42u64 }
    if tcp_listen_ipv4(0u64, (&SA as u64), 16u32) != 0u64 { return 43u64 }

    /* ---- NI: the witness role signs; the proof is the verifier ---- */
    MSG[0u64] = 0x57u8   /* W */
    MSG[1u64] = 0x49u8   /* I */
    MSG[2u64] = 0x54u8   /* T */
    MSG[3u64] = 0x4Eu8   /* N */
    MSG[4u64] = 0x53u8   /* S */
    if ni_is_inited() != 0u8 { return 50u64 }
    if ni_witness_sign((&MSG as u64) as *u8, 5u64, (&SIG1 as u64) as *u8) != -1i32 { return 51u64 }
    HW[0u64] = 0x48u8   HW[1u64] = 0x57u8   HW[2u64] = 0x31u8   /* HW1 */
    BS[0u64] = 0x42u8   BS[1u64] = 0x53u8   BS[2u64] = 0x31u8   /* BS1 */
    let ab : u64 = &ARGS as u64
    kw64(ab, &HW as u64)
    kw64(ab + 8u64, 3u64)
    kw64(ab + 16u64, &BS as u64)
    kw64(ab + 24u64, 3u64)
    if ni_init(ab as *u8) != 0i32 { return 52u64 }
    if ni_witness_pub((&PUB as u64) as *u8) != 0i32 { return 53u64 }
    if ni_witness_sign((&MSG as u64) as *u8, 5u64, (&SIG1 as u64) as *u8) != 0i32 { return 54u64 }
    if ed25519_verify((&PUB as u64) as *u8, (&MSG as u64) as *u8, 5u64, (&SIG1 as u64) as *u8) != 1u8 { return 55u64 }
    if ni_witness_sign((&MSG as u64) as *u8, 5u64, (&SIG2 as u64) as *u8) != 0i32 { return 56u64 }
    let mut d : u64 = 0u64
    while d < 64u64 { if SIG1[d] != SIG2[d] { return 57u64 }   d = d + 1u64 }   /* deterministic */
    MSG[0u64] = 0x58u8                                         /* tamper msg */
    if ed25519_verify((&PUB as u64) as *u8, (&MSG as u64) as *u8, 5u64, (&SIG1 as u64) as *u8) != 0u8 { return 58u64 }
    MSG[0u64] = 0x57u8
    let sv : u8 = SIG1[10u64]
    SIG1[10u64] = sv + 1u8                                     /* tamper sig */
    if ed25519_verify((&PUB as u64) as *u8, (&MSG as u64) as *u8, 5u64, (&SIG1 as u64) as *u8) != 0u8 { return 59u64 }
    SIG1[10u64] = sv
    if ni_identity_sign((&MSG as u64) as *u8, 5u64, (&SIG3 as u64) as *u8) != 0i32 { return 60u64 }
    if ed25519_verify((&PUB as u64) as *u8, (&MSG as u64) as *u8, 5u64, (&SIG3 as u64) as *u8) != 0u8 { return 61u64 }   /* role separation */
    let np : *u8 = (0u64) as *u8
    if ni_witness_sign((&MSG as u64) as *u8, 5u64, np) != -1i32 { return 62u64 }

    /* ---- HC: normalize preserves the function and shrinks the netlist ---- */
    hdl_reset()
    PROG[0u64] = hc_tok(0u32, 0u32)    /* INPUT 0  (x) */
    PROG[1u64] = hc_tok(2u32, 0u32)    /* DUP      */
    PROG[2u64] = hc_tok(3u32, 0u32)    /* AND -> AND(x,x) */
    PROG[3u64] = hc_tok(0u32, 1u32)    /* INPUT 1  (w) */
    PROG[4u64] = hc_tok(4u32, 0u32)    /* OR  -> OR(AND(x,x), w) */
    let o0 : u32 = hc_compile((&PROG as u64) as *u32, 5u32)
    if o0 == HCBAD { return 70u64 }
    let t0 : u64 = hdl_opt_truth_table(o0, 2u32)
    let l0 : u32 = hdl_opt_live(o0)
    hdl_reset()
    let o1 : u32 = hc_compile_normalized((&PROG as u64) as *u32, 5u32)
    if o1 == HCBAD { return 71u64 }
    let t1 : u64 = hdl_opt_truth_table(o1, 2u32)
    if t1 != t0 { return 72u64 }                               /* function preserved */
    let l1 : u32 = hdl_opt_live(o1)
    if l1 >= l0 { return 73u64 }                               /* and strictly shrunk */
    hdl_reset()
    let x : u32 = hdl_add_in(0u32)
    let w : u32 = hdl_add_in(1u32)
    let orc : u32 = hdl_add(6u32, x, w)                        /* the OR(x,w) oracle */
    if hdl_opt_truth_table(orc, 2u32) != t1 { return 74u64 }   /* exact function */
    BADP[0u64] = hc_tok(3u32, 0u32)                            /* lone AND underflows */
    if hc_compile_normalized((&BADP as u64) as *u32, 1u32) != HCBAD { return 75u64 }

    /* ---- KS: self-measure a synthetic PE; the digest is independently recomputed ---- */
    let ib : u64 = &KSIMG as u64
    kw32(ib + 0x3Cu64, 0x40u32)        /* e_lfanew -> PE at +0x40 */
    KSIMG[0x46u64] = 1u8               /* nsec = 1 */
    KSIMG[0x47u64] = 0u8
    KSIMG[0x54u64] = 0u8               /* optsize = 0 -> sectab at PE+0x18 */
    KSIMG[0x55u64] = 0u8
    kw32(ib + 0x60u64, 48u32)          /* section VirtualSize  = 48 */
    kw32(ib + 0x64u64, 0x1000u32)      /* section VirtualAddress = KS_TEXT_RVA */
    let mut ki : u64 = 0u64
    while ki < 48u64 {
        KSIMG[0x1000u64 + ki] = (((ki * 7u64) + 3u64) & 0xFFu64) as u8
        ki = ki + 1u64
    }
    if ks_self_measure(ib, &KOUT as u64) != 0i32 { return 80u64 }
    if cad_oneshot(0u32, (ib + 4096u64) as *u8, 48u64, (&KEXP as u64) as *u8) != 0i32 { return 81u64 }
    let mut km : u64 = 0u64
    while km < 32u64 { if KOUT[km] != KEXP[km] { return 82u64 }   km = km + 1u64 }
    if ks_self_measure(ib, &KOUT2 as u64) != 0i32 { return 83u64 }
    let mut kr : u64 = 0u64
    while kr < 32u64 { if KOUT2[kr] != KEXP[kr] { return 83u64 }   kr = kr + 1u64 }
    let kold : u8 = KSIMG[0x1010u64]
    KSIMG[0x1010u64] = kold + 1u8                               /* flip one measured byte */
    if ks_self_measure(ib, &KOUT2 as u64) != 0i32 { return 84u64 }
    let mut kd : u32 = 0u32
    let mut kc : u64 = 0u64
    while kc < 32u64 { if KOUT2[kc] != KEXP[kc] { kd = kd + 1u32 }   kc = kc + 1u64 }
    if kd == 0u32 { return 85u64 }                              /* content binding */

    return 99u64
}
