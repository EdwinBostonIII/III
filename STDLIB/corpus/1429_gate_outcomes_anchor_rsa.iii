/* 1429_gate_outcomes_anchor_rsa.iii -- GATE BURN-DOWN v2 TRANCHE 2: THE FOUNDERS-ANCHOR
 * VERIFIERS REJECT, THE RSA-PSS CORE REJECTS (4 under-proven gates; 53 -> 49).
 *
 *  fa_verify -- the raw Anchor verifier: a live-signed directive verifies (1) and a
 *      one-byte directive tamper is rejected (0);
 *  fa_drtm_reset_verify -- the directive is rebuilt EXACTLY ("III-FOUNDERS-DRTM-RESET-V1"
 *      || nonce[32] || ts LE8 || reason LE4, 70 bytes), live-signed, accepted (1); a
 *      different reason_code re-derives different bytes and is rejected (0);
 *  fa_catalyst_halt_verify -- same discipline over the 37-byte halt directive; a
 *      different halt_until is rejected;
 *  rsa_pss_verify -- the 8-arg CORE driven directly (mirroring the _x wrapper's bigint
 *      setup over the 1401 baked 544-bit key): det-signed mHash verifies (1); a flipped
 *      sig byte (0) and a wrong sigLen (0) are rejected.
 * Exit 99. */
module corpus_1429

extern @abi(c-msvc-x64) fn ed25519_pubkey(seed: *u8, out_pk: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn fa_sign(seed: *u8, pk: *u8, directive: *u8, dlen: u64, sig_out: *u8) -> u8 from "founders_anchor.iii"
extern @abi(c-msvc-x64) fn fa_verify(pubkey: *u8, directive: *u8, dlen: u64, sig: *u8) -> u8 from "founders_anchor.iii"
extern @abi(c-msvc-x64) fn fa_drtm_reset_verify(pubkey: *u8, nonce: *u8, timestamp: u64, reason_code: u32, sig: *u8) -> u8 from "founders_anchor.iii"
extern @abi(c-msvc-x64) fn fa_catalyst_halt_verify(pubkey: *u8, halt_until: u64, sig: *u8) -> u8 from "founders_anchor.iii"
extern @abi(c-msvc-x64) fn hex_decode(src: u64, src_len: u64, out: u64, out_cap: u64) -> i32 from "hex.iii"
extern @abi(c-msvc-x64) fn iii_rsa_pss_sign_det(modBits: u64, sk: u64, mHash: u64, sig_out: u64) -> i32 from "rsa.iii"
extern @abi(c-msvc-x64) fn rsa_pss_verify(arena: u64, n: u64, e: u64, modBits: u64, mHash: u64, sig: u64, sigLen: u64, sLen: u64) -> u8 from "rsa.iii"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_new(arena_id: u64, cap_limbs: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_set_limb(id: u64, i: u64, v: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_set_len(id: u64, len: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_normalize(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop_arena(arena: u64) -> i32 from "bigint.iii"

var SEED  : [u8; 32]
var PUB   : [u8; 32]
var DIR16 : [u8; 16]
var DIRB  : [u8; 80]
var NONCE : [u8; 32]
var SIG1  : [u8; 64]
var SIG2  : [u8; 64]
var SIG3  : [u8; 64]
var RPK   : [u8; 96]
var RSK   : [u8; 192]
var RMH   : [u8; 32]
var RSIG  : [u8; 80]

/* LE writers for the directive bytes */
fn dw64(p: u64, v: u64) -> i32 {
    let pl : u64 = p
    let vl : u64 = v
    let b : *u8 = pl as *u8
    let mut i : u64 = 0u64
    while i < 8u64 { b[i] = ((vl >> (i * 8u64)) & 0xFFu64) as u8   i = i + 1u64 }
    return 0i32
}
fn dw32(p: u64, v: u32) -> i32 {
    let pl : u64 = p
    let vl : u32 = v
    let b : *u8 = pl as *u8
    b[0u64] = (vl & 0xFFu32) as u8
    b[1u64] = ((vl >> 8u32) & 0xFFu32) as u8
    b[2u64] = ((vl >> 16u32) & 0xFFu32) as u8
    b[3u64] = ((vl >> 24u32) & 0xFFu32) as u8
    return 0i32
}
fn dlit(p: u64, src: u64, n: u64) -> i32 {
    let pl : u64 = p
    let sl : u64 = src
    let nl : u64 = n
    let d : *u8 = pl as *u8
    let s : *u8 = sl as *u8
    let mut i : u64 = 0u64
    while i < nl { d[i] = s[i]   i = i + 1u64 }
    return 0i32
}

/* OS2IP (big-endian octets -> bigint), replicated from rsa.iii's internal via the
 * exported bigint surface: limb j = bytes [len-1-8j .. len-8-8j] LE-folded. */
fn kos2ip(arena: u64, src: u64, len: u64) -> u64 {
    let al : u64 = arena
    let sl : u64 = src
    let nl : u64 = len
    let s : *u8 = sl as *u8
    let nlimbs : u64 = (nl + 7u64) >> 3u64
    let bi : u64 = bigint_new(al, nlimbs + 1u64)
    if bi == 0u64 { return 0u64 }
    let mut j : u64 = 0u64
    while j < nlimbs {
        let mut v : u64 = 0u64
        let mut p : u64 = 0u64
        while p < 8u64 {
            let k : u64 = (j << 3u64) + p
            if k < nl { v = v | ((s[nl - 1u64 - k] as u64) << (p << 3u64)) }
            p = p + 1u64
        }
        bigint_set_limb(bi, j, v)
        j = j + 1u64
    }
    bigint_set_len(bi, nlimbs)
    bigint_normalize(bi)
    return bi
}

fn main() -> u64 {
    /* ---- the Anchor keypair (fixed seed; live signing like 1399) ---- */
    let mut i : u64 = 0u64
    while i < 32u64 { SEED[i] = (0x21u64 + i & 0xFFu64) as u8   NONCE[i] = (0x91u64 + i & 0xFFu64) as u8   i = i + 1u64 }
    if ed25519_pubkey((&SEED as u64) as *u8, (&PUB as u64) as *u8) != 1u8 { return 1u64 }

    /* ---- fa_verify: raw directive, both arms ---- */
    let mut d : u64 = 0u64
    while d < 16u64 { DIR16[d] = (0xD0u64 + d & 0xFFu64) as u8   d = d + 1u64 }
    if fa_sign((&SEED as u64) as *u8, (&PUB as u64) as *u8, (&DIR16 as u64) as *u8, 16u64, (&SIG1 as u64) as *u8) != 1u8 { return 2u64 }
    if fa_verify((&PUB as u64) as *u8, (&DIR16 as u64) as *u8, 16u64, (&SIG1 as u64) as *u8) != 1u8 { return 3u64 }
    DIR16[3u64] = DIR16[3u64] ^ 0x01u8
    if fa_verify((&PUB as u64) as *u8, (&DIR16 as u64) as *u8, 16u64, (&SIG1 as u64) as *u8) != 0u8 { return 4u64 }
    DIR16[3u64] = DIR16[3u64] ^ 0x01u8

    /* ---- fa_drtm_reset_verify: the 70-byte directive rebuilt exactly ---- */
    let db : u64 = &DIRB as u64
    dlit(db, ("III-FOUNDERS-DRTM-RESET-V1" as u64), 26u64)
    dlit(db + 26u64, (&NONCE as u64), 32u64)
    dw64(db + 58u64, 0x1234567890u64)
    dw32(db + 66u64, 7u32)
    if fa_sign((&SEED as u64) as *u8, (&PUB as u64) as *u8, db as *u8, 70u64, (&SIG2 as u64) as *u8) != 1u8 { return 5u64 }
    if fa_drtm_reset_verify((&PUB as u64) as *u8, (&NONCE as u64) as *u8, 0x1234567890u64, 7u32, (&SIG2 as u64) as *u8) != 1u8 { return 6u64 }
    if fa_drtm_reset_verify((&PUB as u64) as *u8, (&NONCE as u64) as *u8, 0x1234567890u64, 8u32, (&SIG2 as u64) as *u8) != 0u8 { return 7u64 }

    /* ---- fa_catalyst_halt_verify: the 37-byte halt directive ---- */
    dlit(db, ("III-FOUNDERS-CATALYST-HALT-V1" as u64), 29u64)
    dw64(db + 29u64, 0xAA55u64)
    if fa_sign((&SEED as u64) as *u8, (&PUB as u64) as *u8, db as *u8, 37u64, (&SIG3 as u64) as *u8) != 1u8 { return 8u64 }
    if fa_catalyst_halt_verify((&PUB as u64) as *u8, 0xAA55u64, (&SIG3 as u64) as *u8) != 1u8 { return 9u64 }
    if fa_catalyst_halt_verify((&PUB as u64) as *u8, 0xAA56u64, (&SIG3 as u64) as *u8) != 0u8 { return 10u64 }

    /* ---- rsa_pss_verify: the 8-arg core over the 1401 baked 544-bit key ---- */
    let mut h : u64 = 0u64
    while h < 32u64 { RMH[h] = (0x5Au64 + h & 0xFFu64) as u8   h = h + 1u64 }
    if hex_decode(("92a81cb23c3a07d40894e9ceeb30e9f80246ccd670319b8995a1bd8bf2692acfe0b229c9c179db07ba1f6c4994241d78ba9d56a5c8ab8999266692ecfbb1d0d7f14538a1" as u64), 136u64, (&RPK as u64), 96u64) != 0i32 { return 11u64 }
    if hex_decode(("92a81cb23c3a07d40894e9ceeb30e9f80246ccd670319b8995a1bd8bf2692acfe0b229c9c179db07ba1f6c4994241d78ba9d56a5c8ab8999266692ecfbb1d0d7f14538a1" as u64), 136u64, (&RSK as u64), 192u64) != 0i32 { return 12u64 }
    if hex_decode(("50443c787ca81232c583a33801d762a6bfb03a5a3f4b9762450821f2df7919da6e9298e5ea79bc50fcdc6de391c5a89ad627750d1243dcde8f1d7e78eb48231dc23464f5" as u64), 136u64, ((&RSK as u64) + 68u64), 124u64) != 0i32 { return 13u64 }
    if iii_rsa_pss_sign_det(544u64, (&RSK as u64), (&RMH as u64), (&RSIG as u64)) != 0i32 { return 14u64 }
    let arena : u64 = arena_new(33554432u64)
    if arena == 0u64 { return 15u64 }
    let n : u64 = kos2ip(arena, (&RPK as u64), 68u64)
    if n == 0u64 { return 19u64 }
    let e : u64 = bigint_from_u64(arena, 65537u64)
    if rsa_pss_verify(arena, n, e, 544u64, (&RMH as u64), (&RSIG as u64), 68u64, 32u64) != 1u8 { return 16u64 }
    RSIG[7u64] = RSIG[7u64] ^ 0x01u8
    if rsa_pss_verify(arena, n, e, 544u64, (&RMH as u64), (&RSIG as u64), 68u64, 32u64) != 0u8 { return 17u64 }
    RSIG[7u64] = RSIG[7u64] ^ 0x01u8
    if rsa_pss_verify(arena, n, e, 544u64, (&RMH as u64), (&RSIG as u64), 67u64, 32u64) != 0u8 { return 18u64 }
    bigint_drop_arena(arena)
    arena_drop(arena)

    return 99u64
}
