/* 1441_gate_outcomes_federation_admit.iii -- GATE BURN-DOWN v2 TRANCHE 14: THE PLANETARY
 * FEDERATION ADMISSION (3 gates; 16 -> 13).
 *
 * The full planetary 3-gate + QC vertical, driven at the exports.  The peer is node_id
 * 0x42 (packed = 0x42 || 31 zero bytes -- exactly what _fed_admit_pack_node_id builds):
 *  fed_admit_planetary_gate_status -- before sybil admission the bits are NOT all set
 *      (no SYBIL bit) so eligibility fails; after a real sybil admission (16-bit PoW
 *      mined live + ed25519 sovereign endorsement; difficulty 16 -> score 16e6 ==
 *      MIN_SCORE; eclipse quiet) the bits are exactly FED_ADMIT_BIT_ALL (0x07);
 *  fed_admit_eligible -- 1 iff the gate bits are ALL: the admitted peer is eligible (1),
 *      an unadmitted peer (0) and null (0) are refused;
 *  fed_admit_with_qc_proof -- the hardened path: PLANETARY tier (32-bit PoW, nonce baked
 *      from a one-time offline mine) + score>=threshold + a REAL 4-peer HotStuff QC ADMITS
 *      (0); every gate's refusal is pinned in its checked order: null qc E_NULL (-1),
 *      unknown tier E_TIER_RANGE (-5), wrong nonce E_POW (-4), over-threshold E_SCORE (-6),
 *      truncated qc E_QC (-7).
 * Exit 99. */
module corpus_1441

extern @abi(c-msvc-x64) fn fed_sybil_clear_all() -> i32 from "fed_sybil.iii"
extern @abi(c-msvc-x64) fn fed_sybil_pow_verify(peer_id_ptr: u64, nonce: u64, bits: u32) -> u8 from "fed_sybil.iii"
extern @abi(c-msvc-x64) fn fed_sybil_admit(peer_id_ptr: u64, nonce: u64, sov_pub_ptr: u64, sov_sig_ptr: u64) -> i32 from "fed_sybil.iii"
extern @abi(c-msvc-x64) fn fed_admit_planetary_gate_status(peer_id_ptr: u64) -> u32 from "fed_admit.iii"
extern @abi(c-msvc-x64) fn fed_admit_eligible(peer_id_ptr: u64) -> u8 from "fed_admit.iii"
extern @abi(c-msvc-x64) fn fed_admit_with_qc_proof(node_id: u64, pow_nonce: u64, packed_meta: u64, qc_ptr: *u8, qc_len: u32) -> i32 from "fed_admit.iii"
extern @abi(c-msvc-x64) fn ed25519_pubkey(seed: *u8, out_pk: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn ed25519_sign(seed: *u8, pk: *u8, msg: *u8, msg_len: u64, sig_out: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn ed25519_sign_seed(seed: *u8, msg: *u8, msg_len: u64, sig_out: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn hs_init(node_id: u32, peers: *u8, n_peers: u32) -> i32 from "hotstuff.iii"
extern @abi(c-msvc-x64) fn hs_compose_qc(block_mhash: *u8, view: u64, sigs: *u8, n_sigs: u32, out_qc: *u8) -> i32 from "hotstuff.iii"

const NONCE32 : u64 = 494012290u64   /* one-time offline SHA3-256 mine: 32 leading-zero bits
                                      * over (0x42 || 31x00) || nonce_LE8 (planetary tier) */

var PEER  : [u8; 32]
var SEED  : [u8; 32]
var PK    : [u8; 32]
var SIG   : [u8; 64]
var PEER2 : [u8; 32]
var HSEEDS: [u8; 128]
var HPEERS: [u8; 128]
var MH    : [u8; 32]
var SIGIN : [u8; 40]
var HSIGS : [u8; 192]
var QC    : [u8; 256]

fn main() -> u64 {
    fed_sybil_clear_all()
    PEER[0u64] = 0x42u8                                  /* node_id 0x42, high 31 bytes zero */
    let mut i : u64 = 0u64
    while i < 32u64 { SEED[i] = (0x80u64 + i & 0xFFu64) as u8   PEER2[i] = (0x33u64 + i & 0xFFu64) as u8   i = i + 1u64 }
    if ed25519_pubkey((&SEED as u64) as *u8, (&PK as u64) as *u8) != 1u8 { return 1u64 }
    if ed25519_sign((&SEED as u64) as *u8, (&PK as u64) as *u8, (&PEER as u64) as *u8, 32u64, (&SIG as u64) as *u8) != 1u8 { return 2u64 }

    /* mine the 16-bit admission nonce live (cheap, deterministic for the fixed peer) */
    let mut nonce : u64 = 0u64
    let mut good : u64 = 0xFFFFFFFFFFFFFFFFu64
    let mut mining : u8 = 1u8
    while mining == 1u8 {
        if fed_sybil_pow_verify((&PEER as u64), nonce, 16u32) == 1u8 { good = nonce   mining = 0u8 }
        else { nonce = nonce + 1u64   if nonce >= 16777216u64 { mining = 0u8 } }
    }
    if good == 0xFFFFFFFFFFFFFFFFu64 { return 3u64 }

    /* ---- before admission: not eligible ---- */
    if fed_admit_eligible((&PEER as u64)) != 0u8 { return 4u64 }
    if fed_admit_planetary_gate_status((&PEER as u64)) == 0x07u32 { return 5u64 }   /* not yet ALL */

    /* ---- sybil admission (the SYBIL + SCORE bits) ---- */
    if fed_sybil_admit((&PEER as u64), good, (&PK as u64), (&SIG as u64)) != 0i32 { return 6u64 }
    if fed_admit_planetary_gate_status((&PEER as u64)) != 0x07u32 { return 7u64 }   /* SYBIL|ECLIPSE|SCORE */
    if fed_admit_eligible((&PEER as u64)) != 1u8 { return 8u64 }                    /* ELIGIBLE */
    if fed_admit_eligible((&PEER2 as u64)) != 0u8 { return 9u64 }                   /* a stranger */
    if fed_admit_eligible(0u64) != 0u8 { return 10u64 }                             /* null */

    /* ---- a real 4-peer HotStuff QC (3 sigs == 2f+1) ---- */
    let mut h : u64 = 0u64
    while h < 128u64 { HSEEDS[h] = ((0x10u64 + h) & 0xFFu64) as u8   h = h + 1u64 }
    let mut pi : u64 = 0u64
    while pi < 4u64 {
        if ed25519_pubkey(((&HSEEDS as u64) + pi * 32u64) as *u8, ((&HPEERS as u64) + pi * 32u64) as *u8) != 1u8 { return 11u64 }
        pi = pi + 1u64
    }
    if hs_init(0u32, (&HPEERS as u64) as *u8, 4u32) != 0i32 { return 12u64 }
    let view : u64 = 5u64
    let mut m : u64 = 0u64
    while m < 32u64 { MH[m] = (0x90u64 + m & 0xFFu64) as u8   SIGIN[m] = MH[m]   m = m + 1u64 }
    let mut v : u64 = 0u64
    while v < 8u64 { SIGIN[32u64 + v] = ((view >> (v * 8u64)) & 0xFFu64) as u8   v = v + 1u64 }
    let mut sg : u64 = 0u64
    while sg < 3u64 {
        if ed25519_sign_seed(((&HSEEDS as u64) + sg * 32u64) as *u8, (&SIGIN as u64) as *u8, 40u64, ((&HSIGS as u64) + sg * 64u64) as *u8) != 1u8 { return 13u64 }
        sg = sg + 1u64
    }
    if hs_compose_qc((&MH as u64) as *u8, view, (&HSIGS as u64) as *u8, 3u32, (&QC as u64) as *u8) != 0i32 { return 14u64 }

    /* ---- with_qc_proof: every refusal in its checked order ---- */
    let planetary : u64 = 0u64                            /* tier 0 << 32 | threshold 0 */
    let np : *u8 = (0u64) as *u8
    if fed_admit_with_qc_proof(0x42u64, NONCE32, planetary, np, 236u32) != -1i32 { return 20u64 }   /* null qc */
    let badtier : u64 = (99u64 << 32u64)
    if fed_admit_with_qc_proof(0x42u64, NONCE32, badtier, (&QC as u64) as *u8, 236u32) != -5i32 { return 21u64 }   /* tier range */
    if fed_admit_with_qc_proof(0x42u64, NONCE32 + 1u64, planetary, (&QC as u64) as *u8, 236u32) != -4i32 { return 22u64 }  /* bad PoW */
    let hithresh : u64 = 0xFFFFFFFFu64                    /* threshold 4.29e9 > score 16e6 */
    if fed_admit_with_qc_proof(0x42u64, NONCE32, hithresh, (&QC as u64) as *u8, 236u32) != -6i32 { return 23u64 }  /* score */
    if fed_admit_with_qc_proof(0x42u64, NONCE32, planetary, (&QC as u64) as *u8, 100u32) != -7i32 { return 24u64 } /* truncated qc */
    if fed_admit_with_qc_proof(0x42u64, NONCE32, planetary, (&QC as u64) as *u8, 236u32) != 0i32 { return 25u64 }  /* ADMITTED */

    return 99u64
}
