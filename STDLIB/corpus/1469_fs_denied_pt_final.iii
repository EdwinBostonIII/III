/* 1469_fs_denied_pt_final.iii -- REFUSAL ARMS I: THE CAPABILITY DENIAL, THE DOUBLE
 * FINALIZE (frontier findings 8/9).  Two documented refusal codes the corpus had
 * never produced:
 *
 *  FS_E_DENIED (-2) -- the capability gate on every mutating fs op: a READ-only cap
 *      cannot delete or rmdir; a cap without CREATE cannot mkdir; a handle opened
 *      without READ rights cannot seek.  NON-VACUITY: the SAME ops succeed under a
 *      fully-righted cap -- the gate is right-specific, not always-deny;
 *  PT_E_ALREADY_FINAL (-6) -- the proof-term finality wall, BOTH sites: finalizing a
 *      finalized term refuses; adding an inference to a finalized term refuses; and
 *      the refusals are NON-DESTRUCTIVE (the term still verifies).
 * Exit 99. */
module corpus_1469

extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn fs_open(cap: u64, path: u64, mode: u32) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_close(h: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_write(h: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_seek(h: u64, off: u64, whence: u32) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_delete(cap: u64, path: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_mkdir(cap: u64, path: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_rmdir(cap: u64, path: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn pt_init() -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_alloc(out_term_id: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_add_inference(args: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_finalize(term_id: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_verify(term_id: *u8) -> i32 from "proof_term.iii"

var FPATH : [u8; 32]
var DPATH : [u8; 32]
var WBUF  : [u8; 8]
var TID   : [u8; 32]
var ARG   : [u8; 64]

fn setp(dst_addr: u64, src_addr: u64, n: u64) {
    let d : *u8 = dst_addr as *u8
    let s : *u8 = src_addr as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]   i = i + 1u64 }
    d[n] = 0u8
}

/* the 1-step AXIOM inference for TID (680/1463's layout) */
fn build_axiom() -> i32 {
    let a : *u8 = (&ARG as u64) as *u8
    let tp : *u8 = (&TID as u64) as *u8
    let mut i : u64 = 0u64
    while i < 32u64 { a[i] = tp[i]   i = i + 1u64 }
    a[32u64] = 0x01u8
    a[33u64] = 0u8   a[34u64] = 0u8   a[35u64] = 0u8
    a[36u64] = 0u8   a[37u64] = 0u8   a[38u64] = 0u8   a[39u64] = 0u8
    a[40u64] = 1u8   a[41u64] = 0u8   a[42u64] = 0u8   a[43u64] = 0u8
    a[44u64] = 0x41u8
    return pt_add_inference(a)
}

fn main() -> u64 {
    /* ==== FS_E_DENIED: every mutating gate, then non-vacuity ==== */
    let env : u64 = cap_env_init()
    setp((&FPATH as u64), ("./iii_1469_f.txt" as u64), 16u64)
    setp((&DPATH as u64), ("./iii_1469_dir" as u64), 14u64)

    let ro : u64 = cap_attenuate(env, 0x02u64, 0u64)                /* READ only */
    if fs_delete(ro, (&FPATH as u64)) != -2i32 { return 1u64 }      /* no WRITE: denied */
    if fs_rmdir(ro, (&DPATH as u64)) != -2i32 { return 2u64 }
    let rw : u64 = cap_attenuate(env, 0x06u64, 0u64)                /* READ|WRITE, no CREATE */
    if fs_mkdir(rw, (&DPATH as u64)) != -2i32 { return 3u64 }
    let wc : u64 = cap_attenuate(env, 0x0Cu64, 0u64)                /* WRITE|CREATE, no READ */
    let hw : u64 = fs_open(wc, (&FPATH as u64), 2u32)
    if hw == 0u64 { return 4u64 }
    if fs_seek(hw, 0u64, 0u32) != -2i32 { return 5u64 }             /* handle lacks READ: denied */
    if fs_close(hw) != 0i32 { return 6u64 }

    /* non-vacuity: the SAME ops succeed under the full cap */
    let full : u64 = cap_attenuate(env, 0x0Eu64, 0u64)
    if fs_mkdir(full, (&DPATH as u64)) != 0i32 { return 7u64 }
    if fs_rmdir(full, (&DPATH as u64)) != 0i32 { return 8u64 }
    let hr : u64 = fs_open(full, (&FPATH as u64), 2u32)
    if hr == 0u64 { return 9u64 }
    WBUF[0u64] = 0x58u8
    fs_write(hr, (&WBUF as u64), 1u64)
    if fs_seek(hr, 0u64, 0u32) != 0i32 { return 10u64 }             /* READ-righted handle seeks */
    if fs_close(hr) != 0i32 { return 11u64 }
    if fs_delete(full, (&FPATH as u64)) != 0i32 { return 12u64 }

    /* ==== PT_E_ALREADY_FINAL: both sites, non-destructive ==== */
    pt_init()
    if pt_alloc((&TID as u64) as *u8) != 0i32 { return 13u64 }
    if build_axiom() != 0i32 { return 14u64 }
    if pt_finalize((&TID as u64) as *u8) != 0i32 { return 15u64 }
    if pt_verify((&TID as u64) as *u8) != 0i32 { return 16u64 }
    if pt_finalize((&TID as u64) as *u8) != -6i32 { return 17u64 }       /* double finalize refused */
    if pt_add_inference((&ARG as u64) as *u8) != -6i32 { return 18u64 }  /* add-after-final refused */
    if pt_verify((&TID as u64) as *u8) != 0i32 { return 19u64 }          /* refusals were non-destructive */

    return 99u64
}
