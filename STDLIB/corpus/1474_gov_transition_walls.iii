/* 1474_gov_transition_walls.iii -- STATE-MACHINE WALLS I: THE GOVERNANCE TRANSITION
 * MATRIX (wave-2 findings 1/2).  governance_promote's NOT_PROVEN wall and the prove
 * gates' SANDBOXED-only wall had never been driven from the wrong states -- corpus 205
 * promotes only from PROVEN and proves only from SANDBOXED, so a guard relaxed to
 * `>` (allowing premature transitions) would have survived the whole corpus:
 *
 *  governance_promote -- refused with EXACTLY -7 (GOV_E_NOT_PROVEN) from PENDING,
 *      SANDBOXED, ACCEPTED (no double promote), and SEALED; from REJECTED the FIRST
 *      promote returns -6 (GOV_E_QUORUM_FAIL, the rejection itself) and the SECOND
 *      returns -7 -- the two codes are distinct and ordered; unknown id -1
 *      (GOV_E_BAD_ID).  Every refusal leaves the status untouched;
 *  governance_prove_equivalence (+_with_count) -- refused (0, GOV_INVALID_ID) from
 *      PENDING and from PROVEN (re-prove), with the status AND the minted cert
 *      unchanged -- the refusal is side-effect-free.
 * Exit 99. */
module corpus_1474

extern @abi(c-msvc-x64) fn resolution_init() -> i32 from "resolution_init.iii"
extern @abi(c-msvc-x64) fn governance_reset() -> i32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_propose(proposer_cap: u64, change_intent: u64, rationale_ptr: u64, rationale_len: u32) -> u64 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_sandbox(proposal_id: u64) -> i32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_prove_equivalence(proposal_id: u64, old_pid: u32, new_pid: u32, corpus_witness_ptr: u64) -> u64 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_prove_equivalence_with_count(proposal_id: u64, old_pid: u32, new_pid_and_count: u64, corpus_witness_ptr: u64) -> u64 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_vote(voter_cap: u64, proposal_id: u64, vote: u8) -> i32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_promote(proposal_id: u64) -> i32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_seal(proposal_id: u64) -> i32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_status(proposal_id: u64) -> u8 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_cert(proposal_id: u64) -> u64 from "governance.iii"

fn main() -> u64 {
    resolution_init()
    governance_reset()

    /* ==== pidP: the full legal ladder, with every illegal promote pinned ==== */
    let pidp : u64 = governance_propose(1u64, 0xA1u64, 0u64, 0u32)
    if pidp == 0u64 { return 1u64 }
    /* PENDING: prove refused (0), promote refused (-7), state untouched */
    if governance_prove_equivalence(pidp, 5u32, 5u32, 0u64) != 0u64 { return 2u64 }
    if governance_status(pidp) != 0u8 { return 3u64 }
    if governance_promote(pidp) != -7i32 { return 4u64 }
    if governance_status(pidp) != 0u8 { return 5u64 }
    /* SANDBOXED: promote still refused (-7) */
    if governance_sandbox(pidp) != 0i32 { return 6u64 }
    if governance_promote(pidp) != -7i32 { return 7u64 }
    if governance_status(pidp) != 1u8 { return 8u64 }
    /* PROVEN: the legal prove; then RE-prove refused through BOTH gates, cert intact */
    let cert : u64 = governance_prove_equivalence(pidp, 5u32, 5u32, 0u64)
    if cert == 0u64 { return 9u64 }
    if governance_status(pidp) != 2u8 { return 10u64 }
    if governance_prove_equivalence(pidp, 5u32, 5u32, 0u64) != 0u64 { return 11u64 }
    if governance_prove_equivalence_with_count(pidp, 5u32, 5u64, 0u64) != 0u64 { return 12u64 }
    if governance_status(pidp) != 2u8 { return 13u64 }
    if governance_cert(pidp) != cert { return 14u64 }               /* refusal is side-effect-free */
    /* ACCEPTED: 4 yes 1 no, promote succeeds; the SECOND promote refused (-7) */
    governance_vote(0x10u64, pidp, 1u8)
    governance_vote(0x11u64, pidp, 1u8)
    governance_vote(0x12u64, pidp, 1u8)
    governance_vote(0x13u64, pidp, 1u8)
    governance_vote(0x14u64, pidp, 0u8)
    if governance_promote(pidp) != 0i32 { return 15u64 }
    if governance_status(pidp) != 3u8 { return 16u64 }
    if governance_promote(pidp) != -7i32 { return 17u64 }           /* no double promote */
    if governance_status(pidp) != 3u8 { return 18u64 }
    /* SEALED: promote refused (-7) */
    if governance_seal(pidp) != 0i32 { return 19u64 }
    if governance_promote(pidp) != -7i32 { return 20u64 }
    if governance_status(pidp) != 5u8 { return 21u64 }

    /* ==== pidR: the rejection ladder -- -6 (the rejection) THEN -7 (not proven) ==== */
    let pidr : u64 = governance_propose(1u64, 0xB2u64, 0u64, 0u32)
    if pidr == 0u64 { return 22u64 }
    if governance_sandbox(pidr) != 0i32 { return 23u64 }
    if governance_prove_equivalence_with_count(pidr, 5u32, 5u64, 0u64) == 0u64 { return 24u64 }
    governance_vote(0x20u64, pidr, 1u8)
    governance_vote(0x21u64, pidr, 0u8)
    governance_vote(0x22u64, pidr, 0u8)
    governance_vote(0x23u64, pidr, 0u8)
    governance_vote(0x24u64, pidr, 0u8)
    governance_vote(0x25u64, pidr, 0u8)
    if governance_promote(pidr) != -6i32 { return 25u64 }           /* QUORUM_FAIL: the rejection */
    if governance_status(pidr) != 4u8 { return 26u64 }              /* REJECTED */
    if governance_promote(pidr) != -7i32 { return 27u64 }           /* now NOT_PROVEN: distinct code */
    if governance_status(pidr) != 4u8 { return 28u64 }

    /* ==== the id wall ==== */
    if governance_promote(9999u64) != -1i32 { return 29u64 }        /* GOV_E_BAD_ID */

    return 99u64
}
