/* 1480_checked_option_unity.iii -- W3.22/COMBINE-8 FALSIFIER: checked.iii's u64 side
 * table IS option.iii's table now (the former private 64-slot duplicate deleted).
 * The unity is pinned IN BOTH DIRECTIONS: a handle minted by checked unwraps and
 * drops through option's API, and vice versa -- plus slot recycling is visible
 * across the two APIs (the freed slot is re-issued to the other module's caller),
 * which is impossible with two tables.  checked's failure contract is preserved:
 * 0 on overflow/underflow/div-zero (option's distinct table-full sentinel maps
 * to checked's 0).
 * Exit 99. */
module corpus_1480

extern @abi(c-msvc-x64) fn checked_u64_add(a: u64, b: u64) -> u64 from "checked.iii"
extern @abi(c-msvc-x64) fn checked_u64_sub(a: u64, b: u64) -> u64 from "checked.iii"
extern @abi(c-msvc-x64) fn checked_u64_mul(a: u64, b: u64) -> u64 from "checked.iii"
extern @abi(c-msvc-x64) fn checked_u64_div(a: u64, b: u64) -> u64 from "checked.iii"
extern @abi(c-msvc-x64) fn checked_u64_unwrap_or(handle: u64, default: u64) -> u64 from "checked.iii"
extern @abi(c-msvc-x64) fn checked_u64_drop(handle: u64) -> u8 from "checked.iii"
extern @abi(c-msvc-x64) fn option_u64_some(v: u64) -> u64 from "option.iii"
extern @abi(c-msvc-x64) fn option_u64_is_some(o: u64) -> u8 from "option.iii"
extern @abi(c-msvc-x64) fn option_u64_unwrap_or(o: u64, default: u64) -> u64 from "option.iii"
extern @abi(c-msvc-x64) fn option_u64_drop(o: u64) -> u8 from "option.iii"

fn main() -> u64 {
    /* ---- checked mints, OPTION reads/drops: the table is one ---- */
    let h : u64 = checked_u64_add(5u64, 7u64)
    if h == 0u64 { return 1u64 }
    if option_u64_is_some(h) != 1u8 { return 2u64 }
    if option_u64_unwrap_or(h, 0u64) != 12u64 { return 3u64 }      /* option READS checked's mint */
    if checked_u64_unwrap_or(h, 0u64) != 12u64 { return 4u64 }
    if option_u64_drop(h) != 1u8 { return 5u64 }                   /* option FREES checked's mint */
    if checked_u64_unwrap_or(h, 9u64) != 9u64 { return 6u64 }      /* the free is visible to checked */

    /* ---- option mints, CHECKED reads/drops ---- */
    let o : u64 = option_u64_some(33u64)
    if o == 0u64 { return 7u64 }
    if checked_u64_unwrap_or(o, 0u64) != 33u64 { return 8u64 }
    if checked_u64_drop(o) != 1u8 { return 9u64 }
    if option_u64_is_some(o) != 0u8 { return 10u64 }

    /* ---- recycling across APIs: the freed lowest slot is re-issued ---- */
    let h2 : u64 = checked_u64_mul(3u64, 4u64)
    if h2 != h { return 11u64 }                                    /* first-free scan: one table */
    if option_u64_unwrap_or(h2, 0u64) != 12u64 { return 12u64 }
    if checked_u64_drop(h2) != 1u8 { return 13u64 }

    /* ---- the failure contract: 0 on any refusal, through every op ---- */
    if checked_u64_add(0xFFFFFFFFFFFFFFFFu64, 1u64) != 0u64 { return 14u64 }
    if checked_u64_sub(3u64, 4u64) != 0u64 { return 15u64 }
    if checked_u64_mul(0x8000000000000000u64, 2u64) != 0u64 { return 16u64 }
    if checked_u64_div(7u64, 0u64) != 0u64 { return 17u64 }

    return 99u64
}
