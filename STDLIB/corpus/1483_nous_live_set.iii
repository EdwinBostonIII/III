/* 1483_nous_live_set.iii -- CUT-10 STRUCTURAL FALSIFIER: the nous proposer emits the
 * LIVE rule set only, in apply_one's EXACT live order.
 *
 * THE STALENESS: route-S retired R001-R004 from xii_rewrite_apply_one (associativity is
 * structural at make_fusion2; the match fns are dead), but the socket cascade table, the
 * ascending probe table, AND the policy R-block all still emitted the retired ids.  The
 * P2 differential gate could never see it: a retired rule has no representable redex, so
 * its presence in a rank order is behaviorally invisible -- only this STRUCTURAL pin
 * (order == the live cascade, element-wise, transcribed from apply_one's text) catches it.
 * Against the pre-fix module this KAT FAILS at arm 1 (n==50, and idx2==R001).
 *
 * Arms: (1) mode-0 count==46 + element-wise mirror of the live cascade + absence of 1..4;
 *       (2) mode-1 count==45 + endpoints + absence; (3) policy (mode-2 source) count==45,
 *       block boundaries, full-permutation over the live set, SEEN[1..4]==0;
 *       (4) both socket orders stay NOL-certified (real-data, as 1090).
 * Exit 99. */
module corpus_1483

extern @abi(c-msvc-x64) fn nous_rank(ctx_term: u32, kind: u32, out_order: *u64, cap: u32) -> u32 from "nous_socket.iii"
extern @abi(c-msvc-x64) fn nous_set_order_mode(mode: u8) -> i32 from "nous_socket.iii"
extern @abi(c-msvc-x64) fn nous_policy_rank(ctx_term: u32, kind: u32, out: *u64, cap: u32) -> u32 from "nous_policy.iii"
extern @abi(c-msvc-x64) fn nol_certify_order(order: *u64, n: u32) -> u8 from "nous_lattice.iii"

var NLS_ORD  : [u64; 64]
var NLS_EXP  : [u64; 64]
var NLS_SEEN : [u8; 128]

/* The live cascade, transcribed LITERALLY from omnia/xii_rewrite.iii apply_one
 * (R038, R040, R005..R012, R041, R013..R023, R043, R044, R024..R032, R042,
 *  R033..R037, R039, R040, trit 101..105) -- NOT generated by the module's own
 * fill loops, so a transcription error there cannot hide here. */
fn _nls_fill_expected() {
    NLS_EXP[0u64] = 38u64   NLS_EXP[1u64] = 40u64
    NLS_EXP[2u64] = 5u64    NLS_EXP[3u64] = 6u64    NLS_EXP[4u64] = 7u64    NLS_EXP[5u64] = 8u64
    NLS_EXP[6u64] = 9u64    NLS_EXP[7u64] = 10u64   NLS_EXP[8u64] = 11u64   NLS_EXP[9u64] = 12u64
    NLS_EXP[10u64] = 41u64
    NLS_EXP[11u64] = 13u64  NLS_EXP[12u64] = 14u64  NLS_EXP[13u64] = 15u64  NLS_EXP[14u64] = 16u64
    NLS_EXP[15u64] = 17u64  NLS_EXP[16u64] = 18u64  NLS_EXP[17u64] = 19u64  NLS_EXP[18u64] = 20u64
    NLS_EXP[19u64] = 21u64  NLS_EXP[20u64] = 22u64  NLS_EXP[21u64] = 23u64
    NLS_EXP[22u64] = 43u64  NLS_EXP[23u64] = 44u64
    NLS_EXP[24u64] = 24u64  NLS_EXP[25u64] = 25u64  NLS_EXP[26u64] = 26u64  NLS_EXP[27u64] = 27u64
    NLS_EXP[28u64] = 28u64  NLS_EXP[29u64] = 29u64  NLS_EXP[30u64] = 30u64  NLS_EXP[31u64] = 31u64
    NLS_EXP[32u64] = 32u64
    NLS_EXP[33u64] = 42u64
    NLS_EXP[34u64] = 33u64  NLS_EXP[35u64] = 34u64  NLS_EXP[36u64] = 35u64  NLS_EXP[37u64] = 36u64
    NLS_EXP[38u64] = 37u64
    NLS_EXP[39u64] = 39u64  NLS_EXP[40u64] = 40u64
    NLS_EXP[41u64] = 101u64 NLS_EXP[42u64] = 102u64 NLS_EXP[43u64] = 103u64 NLS_EXP[44u64] = 104u64
    NLS_EXP[45u64] = 105u64
}

fn main() -> u64 {
    _nls_fill_expected()
    let p : *u64 = (&NLS_ORD as u64) as *u64

    /* ---- arm 1: mode-0 cascade order == the live cascade, element-wise ---- */
    nous_set_order_mode(0u8)
    let n0 : u32 = nous_rank(0u32, 26u32, p, 64u32)
    if n0 != 46u32 { return 1u64 }
    let mut i : u64 = 0u64
    while i < 46u64 {
        if NLS_ORD[i] != NLS_EXP[i] { return 2u64 }
        i = i + 1u64
    }
    /* absence law: no retired id (R001-R004) anywhere */
    i = 0u64
    while i < 46u64 {
        if NLS_ORD[i] >= 1u64 { if NLS_ORD[i] <= 4u64 { return 3u64 } }
        i = i + 1u64
    }
    /* (arm 4a) the live cascade order is NOL-certified */
    if nol_certify_order(p, n0) != 1u8 { return 4u64 }

    /* ---- arm 2: mode-1 ascending == 5..44 then 101..105 ---- */
    nous_set_order_mode(1u8)
    let n1 : u32 = nous_rank(0u32, 26u32, p, 64u32)
    if n1 != 45u32 { return 5u64 }
    if NLS_ORD[0u64]  != 5u64   { return 6u64 }
    if NLS_ORD[39u64] != 44u64  { return 7u64 }
    if NLS_ORD[40u64] != 101u64 { return 8u64 }
    if NLS_ORD[44u64] != 105u64 { return 9u64 }
    i = 0u64
    while i < 45u64 {
        if NLS_ORD[i] >= 1u64 { if NLS_ORD[i] <= 4u64 { return 10u64 } }
        i = i + 1u64
    }
    /* (arm 4b) the ascending probe is NOL-certified */
    if nol_certify_order(p, n1) != 1u8 { return 11u64 }
    nous_set_order_mode(0u8)

    /* ---- arm 3: the policy (mode-2 source) emits the 45 live rules exactly once ---- */
    let np : u32 = nous_policy_rank(0u32, 20u32, p, 64u32)   /* fusion kind: cascade shape */
    if np != 45u32 { return 12u64 }
    if NLS_ORD[0u64]  != 38u64  { return 13u64 }
    if NLS_ORD[1u64]  != 40u64  { return 14u64 }
    if NLS_ORD[2u64]  != 5u64   { return 15u64 }
    if NLS_ORD[40u64] != 101u64 { return 16u64 }
    let mut z : u64 = 0u64
    while z < 128u64 { NLS_SEEN[z] = 0u8  z = z + 1u64 }
    i = 0u64
    while i < 45u64 {
        let rid : u64 = NLS_ORD[i]
        if rid >= 128u64 { return 17u64 }
        if NLS_SEEN[rid] != 0u8 { return 18u64 }
        NLS_SEEN[rid] = 1u8
        i = i + 1u64
    }
    i = 5u64
    while i < 45u64 { if NLS_SEEN[i] != 1u8 { return 19u64 }  i = i + 1u64 }
    i = 101u64
    while i < 106u64 { if NLS_SEEN[i] != 1u8 { return 20u64 }  i = i + 1u64 }
    i = 1u64
    while i < 5u64 { if NLS_SEEN[i] != 0u8 { return 21u64 }  i = i + 1u64 }

    return 99u64
}
