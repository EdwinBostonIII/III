/* 1486_iter_signed_payload.iii -- J-ITER FALSIFIER: the generic iterator's element
 * image obeys the J-RESULT-1 width contract (WIDTH-truncated, ZERO-extended).
 *
 * THE INCONSISTENCY (pre-fix): iter__next returned `v as u64` -- for signed element
 * types a negative element came back SIGN-extended (iter_i16_next over -3 returned
 * 0xFFFFFFFFFFFFFFFD), while result's ok-payload (corpus 1482) is width-truncated and
 * zero-extended (0xFFFD).  Two container organs, one logical "element as u64", two
 * different images -- a caller comparing the raw u64 against the result-law image
 * silently mismatched.  Post-fix both speak ONE payload law; `as T` at the call site
 * re-sign-extends, so truncating round-trips are unchanged.
 *
 * Negative elements are stored as raw LE bytes (two's complement), iterated through
 * each signed width, and the u64 image is pinned.  The 64-bit lane (whose image is
 * already exact -- and where a naive mask would be CATASTROPHIC, since x86 SHL masks
 * the shift count: 1u64<<64 == 1, mask 0) is regression-pinned with full-width values.
 * Against the pre-fix module the first signed assertion FAILS (sign-extended image).
 * Exit 99. */
module corpus_1486

extern @abi(c-msvc-x64) fn iter_i8_new(base: u64, len: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_i8_next(id: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_i8_drop(id: u64) -> u8 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_i16_new(base: u64, len: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_i16_next(id: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_i16_drop(id: u64) -> u8 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_i32_new(base: u64, len: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_i32_next(id: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_i32_drop(id: u64) -> u8 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_i64_new(base: u64, len: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_i64_next(id: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_i64_drop(id: u64) -> u8 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_u64_new(base: u64, len: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_u64_next(id: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_u64_drop(id: u64) -> u8 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_u16_new(base: u64, len: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_u16_next(id: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_u16_remaining(id: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_u16_drop(id: u64) -> u8 from "iter.iii"

var ITS_BUF : [u8; 64]

fn main() -> u64 {
    let base : u64 = &ITS_BUF as u64

    /* ---- i16: elements -3, 7, -1 as raw LE two's complement ---- */
    ITS_BUF[0u64] = 0xFDu8  ITS_BUF[1u64] = 0xFFu8     /* -3i16  */
    ITS_BUF[2u64] = 0x07u8  ITS_BUF[3u64] = 0x00u8     /*  7i16  */
    ITS_BUF[4u64] = 0xFFu8  ITS_BUF[5u64] = 0xFFu8     /* -1i16  */
    let it16 : u64 = iter_i16_new(base, 3u64)
    if it16 == 0u64 { return 1u64 }
    let a : u64 = iter_i16_next(it16)
    if a != 0xFFFDu64 { return 2u64 }                  /* the width-law image (pre-fix: 0xFFFF...FFFD) */
    if (a as i16) != -3i16 { return 3u64 }             /* truncating round-trip unchanged */
    if iter_i16_next(it16) != 7u64 { return 4u64 }
    if iter_i16_next(it16) != 0xFFFFu64 { return 5u64 }
    iter_i16_drop(it16)

    /* ---- i8: -2 -> 0xFE ---- */
    ITS_BUF[0u64] = 0xFEu8
    let it8 : u64 = iter_i8_new(base, 1u64)
    if it8 == 0u64 { return 6u64 }
    let b : u64 = iter_i8_next(it8)
    if b != 0xFEu64 { return 7u64 }
    if (b as i8) != -2i8 { return 8u64 }
    iter_i8_drop(it8)

    /* ---- i32: -5 -> 0xFFFFFFFB ---- */
    ITS_BUF[0u64] = 0xFBu8  ITS_BUF[1u64] = 0xFFu8  ITS_BUF[2u64] = 0xFFu8  ITS_BUF[3u64] = 0xFFu8
    let it32 : u64 = iter_i32_new(base, 1u64)
    if it32 == 0u64 { return 9u64 }
    let c : u64 = iter_i32_next(it32)
    if c != 0xFFFFFFFBu64 { return 10u64 }
    if (c as i32) != -5i32 { return 11u64 }
    iter_i32_drop(it32)

    /* ---- i64: -1 -> the exact 8-byte image (the no-mask lane) ---- */
    let mut z : u64 = 0u64
    while z < 8u64 { ITS_BUF[z] = 0xFFu8  z = z + 1u64 }
    let it64 : u64 = iter_i64_new(base, 1u64)
    if it64 == 0u64 { return 12u64 }
    if iter_i64_next(it64) != 0xFFFFFFFFFFFFFFFFu64 { return 13u64 }
    iter_i64_drop(it64)

    /* ---- u64: a full-width value survives untouched (mask-bypass regression) ---- */
    ITS_BUF[0u64] = 0xEFu8  ITS_BUF[1u64] = 0xBEu8  ITS_BUF[2u64] = 0xADu8  ITS_BUF[3u64] = 0xDEu8
    ITS_BUF[4u64] = 0x78u8  ITS_BUF[5u64] = 0x56u8  ITS_BUF[6u64] = 0x34u8  ITS_BUF[7u64] = 0x12u8
    let itu : u64 = iter_u64_new(base, 1u64)
    if itu == 0u64 { return 14u64 }
    if iter_u64_next(itu) != 0x12345678DEADBEEFu64 { return 15u64 }
    iter_u64_drop(itu)

    /* ---- u16 regression (corpus 397's law still holds through the masked path) ---- */
    ITS_BUF[0u64] = 0x2Cu8  ITS_BUF[1u64] = 0x01u8     /* 300 */
    let itr : u64 = iter_u16_new(base, 1u64)
    if itr == 0u64 { return 16u64 }
    if iter_u16_next(itr) != 300u64 { return 17u64 }
    if iter_u16_remaining(itr) != 0u64 { return 18u64 }
    if iter_u16_next(itr) != 0u64 { return 19u64 }     /* exhausted -> 0 (the documented sentinel) */
    iter_u16_drop(itr)

    return 99u64
}
