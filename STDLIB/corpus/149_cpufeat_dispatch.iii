/* CPU feature detection + sha256 dispatch produce correct results.
 * sha256_dispatch_oneshot must be bit-identical to sha256_oneshot
 * regardless of which path is selected. */
module corpus_149

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn cpufeat_has_sse2() -> u8 from "cpufeat.iii"
extern @abi(c-msvc-x64) fn cpufeat_summary() -> u32 from "cpufeat.iii"
extern @abi(c-msvc-x64) fn sha256_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn sha256_dispatch_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 from "sha256_dispatch.iii"
extern @abi(c-msvc-x64) fn sha256_dispatch_path() -> u32 from "sha256_dispatch.iii"

fn main() -> u64 {
    /* x86-64 always has SSE2. */
    if cpufeat_has_sse2() != 1u8 { return 1u64 }
    /* Summary should at least have the SSE2 bit set. */
    let s : u32 = cpufeat_summary()
    if (s & 1u32) != 1u32 { return 2u64 }

    /* Dispatch path is either 0 (software) or 1 (SHA-NI). */
    let p : u32 = sha256_dispatch_path()
    if p > 1u32 { return 3u64 }

    /* Bit-identical hash for "abc" via both paths. */
    let buf : *u8 = malloc(3u64)
    buf[0] = 97u8   /* a */
    buf[1] = 98u8   /* b */
    buf[2] = 99u8   /* c */
    let direct : *u8 = malloc(32u64)
    let dispatched : *u8 = malloc(32u64)
    sha256_oneshot(buf, 3u64, direct)
    sha256_dispatch_oneshot(buf, 3u64, dispatched)
    let mut i : u64 = 0u64
    let mut diff : u8 = 0u8
    while i < 32u64 {
        if direct[i] != dispatched[i] { diff = 1u8 }
        i = i + 1u64
    }
    if diff != 0u8 { return 4u64 }
    free(buf); free(direct); free(dispatched)

    return 99u64
}
