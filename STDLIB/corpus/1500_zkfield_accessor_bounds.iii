/* 1500_zkfield_accessor_bounds.iii -- W10 FALSIFIER: the BLS12-381 zk-field limb
 * accessors REFUSE out-of-range slot/idx.
 *
 * THE DEFECT: frq_set_limb/frq_get_limb (ZKFR[4096]=512 Fr slots * 8 limbs) and
 * zkf_set_limb/zkf_get_limb (ZKF[49152]=4096 Fp slots * 12 limbs) indexed the
 * arrays with unvalidated u64 slot/idx -- OOB write (set) or read (get).
 *
 * THE GUARD: frq slot>=512 or idx>=8; zkf slot>=4096 or idx>=12 -> set -1, get 0.
 *
 * Teeth: boundaries pinned (Fr slot 511 idx 7 = ZKFR[4095] last valid; Fp slot
 * 4095 idx 11 = ZKF[49151] last valid; one-past refused).  Against the pre-fix
 * lib the OOB set returns 0 (did the 1-past write) -> reddens.  Exit 99. */
module corpus_1500

extern @abi(c-msvc-x64) fn frq_set_limb(slot: u64, idx: u64, v: u32) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn frq_get_limb(slot: u64, idx: u64) -> u32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkf_set_limb(slot: u64, idx: u64, v: u32) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkf_get_limb(slot: u64, idx: u64) -> u32 from "zk_field.iii"

fn main() -> u64 {
    /* ---- Fr (ZKFR[4096]=512*8): boundary-valid round-trip ---- */
    if frq_set_limb(511u64, 7u64, 0x1234u32) != 0i32 { return 1u64 }
    if frq_get_limb(511u64, 7u64) != 0x1234u32 { return 2u64 }
    /* slot 512 -> ZKFR[4096] one past, refused */
    if frq_set_limb(512u64, 0u64, 0xDEADu32) != -1i32 { return 3u64 }
    if frq_get_limb(512u64, 0u64) != 0u32 { return 4u64 }
    if frq_set_limb(0u64, 8u64, 0xBEEFu32) != -1i32 { return 5u64 }   /* idx 8 refused */
    if frq_get_limb(0u64, 8u64) != 0u32 { return 6u64 }
    if frq_get_limb(511u64, 7u64) != 0x1234u32 { return 7u64 }        /* uncorrupted */

    /* ---- Fp (ZKF[49152]=4096*12): boundary-valid round-trip ---- */
    if zkf_set_limb(4095u64, 11u64, 0x5678u32) != 0i32 { return 8u64 }
    if zkf_get_limb(4095u64, 11u64) != 0x5678u32 { return 9u64 }
    /* slot 4096 -> ZKF[49152] one past, refused */
    if zkf_set_limb(4096u64, 0u64, 0xCAFEu32) != -1i32 { return 10u64 }
    if zkf_get_limb(4096u64, 0u64) != 0u32 { return 11u64 }
    if zkf_set_limb(0u64, 12u64, 0xF00Du32) != -1i32 { return 12u64 }  /* idx 12 refused */
    if zkf_get_limb(0u64, 12u64) != 0u32 { return 13u64 }
    if zkf_get_limb(4095u64, 11u64) != 0x5678u32 { return 14u64 }     /* uncorrupted */

    return 99u64
}
