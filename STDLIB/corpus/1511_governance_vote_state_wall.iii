/* 1511_governance_vote_state_wall.iii -- W21 FALSIFIER: governance_vote tallies a vote
 * ONLY in the PROVEN state (the lifecycle's voting window), not in any state.
 *
 * THE DEFECT (a state-machine invariant gap, found by the protocol-invariant discovery):
 * every governance transition checks its exact precondition state -- sandbox requires
 * PENDING, prove requires SANDBOXED, promote requires PROVEN, seal requires ACCEPTED --
 * EXCEPT governance_vote, which checked only the slot id and then incremented the tally
 * + returned GOV_OK for ANY state.  So a vote on a PENDING/SANDBOXED proposal (premature,
 * before the proof) or on an ACCEPTED/REJECTED/SEALED proposal (closed, after promotion)
 * was wrongly accepted -- mutating the tally of a terminal proposal.
 *
 * THE GUARD: GOV_STATUS[s] != GOV_PROVEN -> GOV_E_BAD_STATE, before the tally.  Byte-
 * identical for every legitimate vote (205 + 1474 both vote ONLY in PROVEN, never after
 * promote -- verified).
 *
 * TEETH (clean state differential): arm 3 votes on a PENDING proposal -> fixed lib
 * GOV_E_BAD_STATE (-3), pre-fix lib GOV_OK (0) -> reddens (exit 30).  Arm 1-2 prove a
 * legitimate PROVEN-state vote still tallies (guard not over-tight); arm 4-5 pin the
 * TERMINAL wall: after promote drives the proposal to REJECTED, a further vote is
 * refused on the fixed lib.  Exit 99. */
module corpus_1511

extern @abi(c-msvc-x64) fn resolution_init() -> i32 from "resolution_init.iii"
extern @abi(c-msvc-x64) fn governance_reset() -> i32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_propose(proposer_cap: u64, change_intent: u64, rationale_ptr: u64, rationale_len: u32) -> u64 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_sandbox(proposal_id: u64) -> i32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_prove_equivalence(proposal_id: u64, old_pid: u32, new_pid: u32, corpus_witness_ptr: u64) -> u64 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_vote(voter_cap: u64, proposal_id: u64, vote: u8) -> i32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_promote(proposal_id: u64) -> i32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_status(proposal_id: u64) -> u8 from "governance.iii"

const GOV_OK          : i32 =  0i32
const GOV_E_BAD_STATE : i32 = -3i32
const GOV_VOTE_YES    : u8  =  1u8
const GOV_VOTE_NO     : u8  =  0u8
const GOV_PROVEN      : u8  =  2u8
const GOV_REJECTED    : u8  =  4u8

fn main() -> u64 {
    resolution_init()
    governance_reset()

    /* ---- 1-2. a legitimate vote in the PROVEN window tallies (both libs) ---- */
    let pid1 : u64 = governance_propose(1u64, 0xA1u64, 0u64, 0u32)
    if pid1 == 0u64 { return 1u64 }
    if governance_sandbox(pid1) != 0i32 { return 2u64 }
    if governance_prove_equivalence(pid1, 5u32, 5u32, 0u64) == 0u64 { return 3u64 }   /* -> PROVEN */
    if governance_status(pid1) != GOV_PROVEN { return 4u64 }
    if governance_vote(0x10u64, pid1, GOV_VOTE_YES) != GOV_OK { return 5u64 }          /* valid vote */

    /* ---- 3. THE TEETH: a PREMATURE vote on a PENDING proposal -> fixed REFUSES ---- */
    let pid2 : u64 = governance_propose(1u64, 0xB2u64, 0u64, 0u32)                     /* PENDING */
    if pid2 == 0u64 { return 6u64 }
    if governance_vote(0x20u64, pid2, GOV_VOTE_YES) != GOV_E_BAD_STATE { return 30u64 } /* old returns GOV_OK -> reddens */

    /* ---- 4-5. the TERMINAL wall: drive pid1 to REJECTED, then a vote is refused ---- */
    if governance_vote(0x11u64, pid1, GOV_VOTE_NO) != GOV_OK { return 7u64 }           /* still PROVEN, valid */
    if governance_vote(0x12u64, pid1, GOV_VOTE_NO) != GOV_OK { return 8u64 }
    if governance_vote(0x13u64, pid1, GOV_VOTE_NO) != GOV_OK { return 9u64 }
    if governance_vote(0x14u64, pid1, GOV_VOTE_NO) != GOV_OK { return 10u64 }
    if governance_vote(0x15u64, pid1, GOV_VOTE_NO) != GOV_OK { return 11u64 }          /* 1 yes, 5 no -> quorum fails */
    governance_promote(pid1)                                                          /* -> REJECTED */
    if governance_status(pid1) != GOV_REJECTED { return 12u64 }
    if governance_vote(0x16u64, pid1, GOV_VOTE_YES) != GOV_E_BAD_STATE { return 13u64 } /* terminal -> refused */

    return 99u64
}
