/* 1527_ad_aligned_nonpow2.iii -- W31 FALSIFIER: ad_aligned must answer "x mod w
 * == 0" correctly for a non-power-of-2 width, not the bitmask approximation.
 *
 * THE DEFECT (W30 pattern -- documented-but-unenforced power-of-2): ad_aligned
 * (align_domain.iii line 39, @export) computes `(x & (w-1)) == 0`.  Its doc says
 * "is x aligned to width w?  (x mod w == 0, via mask since w is a power of two)".
 * The mask equals x mod w ONLY for a power-of-two w; for a non-power-of-2 w it is
 * WRONG:
 *   ad_aligned(1, 3): (1 & 2) == 0 -> returns 1 (aligned) but 1 mod 3 = 1 (NOT).
 *   ad_aligned(6, 3): (6 & 2) = 2 != 0 -> returns 0 (not aligned) but 6 mod 3 = 0.
 * Reachable @export, a real (non-vacuous) wrong boolean both ways.
 *
 * THE FIX: use real modulo for a non-power-of-2 w; keep the bitmask fast path for
 * power-of-2 (and w==0/1/2, which stay on the fast path -> no div-by-zero).
 *
 * TEETH (value differential, no crash): the two non-power-of-2 cases above flip.
 *   - arm 1: ad_aligned(1,3) must be 0 -- pre-fix 1 reddens (exit 30).
 *   - arm 2: ad_aligned(6,3) must be 1 -- pre-fix 0 reddens (exit 31).
 * Sanity arms: the power-of-2 fast path is unchanged. */
module corpus_1527

extern @abi(c-msvc-x64) fn ad_aligned(x: u32, w: u32) -> u32 from "align_domain.iii"

fn main() -> u64 {
    /* ---- TEETH (non-power-of-2 w) ---- */
    if ad_aligned(1u32, 3u32) != 0u32 { return 30u64 }    /* 1 mod 3 = 1 -> NOT aligned; pre-fix returns 1 */
    if ad_aligned(6u32, 3u32) != 1u32 { return 31u64 }    /* 6 mod 3 = 0 -> aligned; pre-fix returns 0 */
    if ad_aligned(7u32, 7u32) != 1u32 { return 32u64 }    /* 7 mod 7 = 0 -> aligned; pre-fix (7 & 6)=6 -> 0 */
    if ad_aligned(5u32, 6u32) != 0u32 { return 33u64 }    /* 5 mod 6 = 5 -> NOT aligned */

    /* ---- sanity: power-of-2 fast path unchanged ---- */
    if ad_aligned(8u32, 4u32) != 1u32 { return 34u64 }    /* 8 mod 4 = 0 */
    if ad_aligned(5u32, 4u32) != 0u32 { return 35u64 }    /* 5 mod 4 = 1 */
    if ad_aligned(0u32, 8u32) != 1u32 { return 36u64 }    /* 0 is aligned to anything */
    if ad_aligned(3u32, 1u32) != 1u32 { return 37u64 }    /* everything aligned to width 1 */

    return 99u64
}
