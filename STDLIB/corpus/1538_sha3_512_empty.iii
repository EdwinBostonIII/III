/* 1538_sha3_512_empty.iii -- W42 ENHANCEMENT: FIPS 202 SHA3-512 of the EMPTY message.
 * 156_sha3_512_kat_abc covers only "abc"; the empty-string digest (the canonical first
 * known-answer, exercises the pad-only path) was unasserted.
 *
 * SHA3-512("") = a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a6
 *                15b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26
 * (FIPS 202; cross-verified against Windows CNG SHA3_512 + Python hashlib.sha3_512.)
 * Full 64-byte verify; the tail byte out[63]=0x26 also distinguishes FIPS 202 SHA3-512 from
 * legacy Keccak-512 / a truncated digest.  Exit 99 = match. */
module corpus_1538

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn sha3_512_oneshot(input_ptr: u64, input_len: u64, out_64: u64) -> u32 from "sha3_512.iii"

var EXP : [u8; 64]

fn main() -> u64 {
    EXP[0u64]=0xa6u8  EXP[1u64]=0x9fu8  EXP[2u64]=0x73u8  EXP[3u64]=0xccu8
    EXP[4u64]=0xa2u8  EXP[5u64]=0x3au8  EXP[6u64]=0x9au8  EXP[7u64]=0xc5u8
    EXP[8u64]=0xc8u8  EXP[9u64]=0xb5u8  EXP[10u64]=0x67u8 EXP[11u64]=0xdcu8
    EXP[12u64]=0x18u8 EXP[13u64]=0x5au8 EXP[14u64]=0x75u8 EXP[15u64]=0x6eu8
    EXP[16u64]=0x97u8 EXP[17u64]=0xc9u8 EXP[18u64]=0x82u8 EXP[19u64]=0x16u8
    EXP[20u64]=0x4fu8 EXP[21u64]=0xe2u8 EXP[22u64]=0x58u8 EXP[23u64]=0x59u8
    EXP[24u64]=0xe0u8 EXP[25u64]=0xd1u8 EXP[26u64]=0xdcu8 EXP[27u64]=0xc1u8
    EXP[28u64]=0x47u8 EXP[29u64]=0x5cu8 EXP[30u64]=0x80u8 EXP[31u64]=0xa6u8
    EXP[32u64]=0x15u8 EXP[33u64]=0xb2u8 EXP[34u64]=0x12u8 EXP[35u64]=0x3au8
    EXP[36u64]=0xf1u8 EXP[37u64]=0xf5u8 EXP[38u64]=0xf9u8 EXP[39u64]=0x4cu8
    EXP[40u64]=0x11u8 EXP[41u64]=0xe3u8 EXP[42u64]=0xe9u8 EXP[43u64]=0x40u8
    EXP[44u64]=0x2cu8 EXP[45u64]=0x3au8 EXP[46u64]=0xc5u8 EXP[47u64]=0x58u8
    EXP[48u64]=0xf5u8 EXP[49u64]=0x00u8 EXP[50u64]=0x19u8 EXP[51u64]=0x9du8
    EXP[52u64]=0x95u8 EXP[53u64]=0xb6u8 EXP[54u64]=0xd3u8 EXP[55u64]=0xe3u8
    EXP[56u64]=0x01u8 EXP[57u64]=0x75u8 EXP[58u64]=0x85u8 EXP[59u64]=0x86u8
    EXP[60u64]=0x28u8 EXP[61u64]=0x1du8 EXP[62u64]=0xcdu8 EXP[63u64]=0x26u8

    let out : *u8 = malloc(64u64)
    sha3_512_oneshot(0u64, 0u64, out as u64)               /* empty message */

    let mut i : u64 = 0u64
    while i < 64u64 { if out[i] != EXP[i] { return 1u64 + i }  i = i + 1u64 }

    free(out)
    return 99u64
}
