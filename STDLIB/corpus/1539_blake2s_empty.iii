/* 1539_blake2s_empty.iii -- W42 ENHANCEMENT: BLAKE2s-256 of the EMPTY message.
 * 83_blake2s_kat covers only "abc"; the empty-input digest (exercises the pad-and-finalize
 * path with zero update bytes) was unasserted.
 *
 * This KAT is anchored two ways so it is NOT circular:
 *  (1) ANCHOR -- BLAKE2s("abc") == the published canonical vector
 *      508c5e8c327c14e2e1a72ba34eeb452f37458b209ed63a294d999b4c86675982 (RFC 7693 App.B).
 *      Byte-exact agreement proves III's blake2s is spec-faithful (same single-block,
 *      last-flag finalize path the empty case uses, just counter=3 vs 0).
 *  (2) EXTENSION -- BLAKE2s("") == the canonical empty digest
 *      69217a3079908094e11121d042354a7c1f55b6482ca1a51e1b250dfd1ed0eef9.
 *      (The W41 audit's recalled constant 69217a3049cfe7e8... was WRONG past the 4-byte
 *      prefix -- a spec-faithful impl, proven by (1), yields the value above; run-before-
 *      register caught the bad constant.)
 * Exit 99 = both hold. */
module corpus_1539

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn blake2s_oneshot(input: *u8, len: u64, out: *u8, out_len: u64) -> u32 from "blake2s.iii"

var EXP : [u8; 32]    /* BLAKE2s("") */
var ABC : [u8; 32]    /* BLAKE2s("abc") published anchor */
var IN3 : [u8; 3]

fn main() -> u64 {
    /* BLAKE2s("") canonical */
    EXP[0u64]=0x69u8  EXP[1u64]=0x21u8  EXP[2u64]=0x7au8  EXP[3u64]=0x30u8
    EXP[4u64]=0x79u8  EXP[5u64]=0x90u8  EXP[6u64]=0x80u8  EXP[7u64]=0x94u8
    EXP[8u64]=0xe1u8  EXP[9u64]=0x11u8  EXP[10u64]=0x21u8 EXP[11u64]=0xd0u8
    EXP[12u64]=0x42u8 EXP[13u64]=0x35u8 EXP[14u64]=0x4au8 EXP[15u64]=0x7cu8
    EXP[16u64]=0x1fu8 EXP[17u64]=0x55u8 EXP[18u64]=0xb6u8 EXP[19u64]=0x48u8
    EXP[20u64]=0x2cu8 EXP[21u64]=0xa1u8 EXP[22u64]=0xa5u8 EXP[23u64]=0x1eu8
    EXP[24u64]=0x1bu8 EXP[25u64]=0x25u8 EXP[26u64]=0x0du8 EXP[27u64]=0xfdu8
    EXP[28u64]=0x1eu8 EXP[29u64]=0xd0u8 EXP[30u64]=0xeeu8 EXP[31u64]=0xf9u8

    /* BLAKE2s("abc") published canonical (RFC 7693 App.B) */
    ABC[0u64]=0x50u8  ABC[1u64]=0x8cu8  ABC[2u64]=0x5eu8  ABC[3u64]=0x8cu8
    ABC[4u64]=0x32u8  ABC[5u64]=0x7cu8  ABC[6u64]=0x14u8  ABC[7u64]=0xe2u8
    ABC[8u64]=0xe1u8  ABC[9u64]=0xa7u8  ABC[10u64]=0x2bu8 ABC[11u64]=0xa3u8
    ABC[12u64]=0x4eu8 ABC[13u64]=0xebu8 ABC[14u64]=0x45u8 ABC[15u64]=0x2fu8
    ABC[16u64]=0x37u8 ABC[17u64]=0x45u8 ABC[18u64]=0x8bu8 ABC[19u64]=0x20u8
    ABC[20u64]=0x9eu8 ABC[21u64]=0xd6u8 ABC[22u64]=0x3au8 ABC[23u64]=0x29u8
    ABC[24u64]=0x4du8 ABC[25u64]=0x99u8 ABC[26u64]=0x9bu8 ABC[27u64]=0x4cu8
    ABC[28u64]=0x86u8 ABC[29u64]=0x67u8 ABC[30u64]=0x59u8 ABC[31u64]=0x82u8

    let out : *u8 = malloc(32u64)

    /* (1) ANCHOR: "abc" == published vector */
    IN3[0u64]=0x61u8 IN3[1u64]=0x62u8 IN3[2u64]=0x63u8
    blake2s_oneshot((&IN3 as u64) as *u8, 3u64, out, 32u64)
    let mut a : u64 = 0u64
    while a < 32u64 { if out[a] != ABC[a] { return 1u64 + a }  a = a + 1u64 }

    /* (2) EXTENSION: "" == canonical empty digest */
    let inp : *u8 = malloc(1u64)            /* non-null; len=0 -> never dereferenced */
    blake2s_oneshot(inp, 0u64, out, 32u64)
    let mut i : u64 = 0u64
    while i < 32u64 { if out[i] != EXP[i] { return 40u64 + i }  i = i + 1u64 }

    free(inp) free(out)
    return 99u64
}
