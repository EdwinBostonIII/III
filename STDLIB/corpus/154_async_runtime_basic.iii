/* Step 0055 verification: omnia/async cooperative runtime end-to-end.
 *
 * - Allocate an arena.
 * - Create runtime (max_tasks=4).
 * - Spawn three tasks of kinds 1, 2, 3 with ctx values 100, 200, 300.
 * - Scheduler loop:
 *     - async_next_ready returns READY task in round-robin order.
 *     - User code dispatches on kind (a `when` cascade).
 *     - kind=1: result = ctx + 1, async_complete.
 *     - kind=2: result = ctx + 2, async_complete.
 *     - kind=3: result = ctx + 3, async_complete.
 * - After all three tasks COMPLETE, async_next_ready returns 0.
 * - Verify async_task_result for each task; verify async_select picks
 *   the first COMPLETE task in the vector.
 */
module corpus_154

extern @abi(c-msvc-x64) fn arena_new(cap: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_reset(id: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn vec_u64_new(arena_id: u64, cap: u32) -> u64 from "vec.iii"
extern @abi(c-msvc-x64) fn vec_u64_push(id: u64, v: u64) -> i32 from "vec.iii"

extern @abi(c-msvc-x64) fn async_runtime_new(arena_id: u64, max_tasks: u32) -> u64 from "async.iii"
extern @abi(c-msvc-x64) fn async_runtime_free(rt_id: u64) -> i32 from "async.iii"
extern @abi(c-msvc-x64) fn async_spawn(rt_id: u64, kind: u64, ctx: u64) -> u64 from "async.iii"
extern @abi(c-msvc-x64) fn async_next_ready(rt_id: u64) -> u64 from "async.iii"
extern @abi(c-msvc-x64) fn async_task_kind(rt_id: u64, task_id: u64) -> u64 from "async.iii"
extern @abi(c-msvc-x64) fn async_task_ctx(rt_id: u64, task_id: u64) -> u64 from "async.iii"
extern @abi(c-msvc-x64) fn async_task_state(rt_id: u64, task_id: u64) -> u32 from "async.iii"
extern @abi(c-msvc-x64) fn async_task_result(rt_id: u64, task_id: u64) -> u64 from "async.iii"
extern @abi(c-msvc-x64) fn async_complete(rt_id: u64, task_id: u64, result: u64) -> i32 from "async.iii"
extern @abi(c-msvc-x64) fn async_alive_count(rt_id: u64) -> u32 from "async.iii"
extern @abi(c-msvc-x64) fn async_select(rt_id: u64, tasks_vec: u64) -> u64 from "async.iii"

fn main() -> u64 {
    let arena : u64 = arena_new(4096u64)
    if arena == 0u64 { return 1u64 }

    let rt : u64 = async_runtime_new(arena, 4u32)
    if rt == 0u64 { return 2u64 }

    let t1 : u64 = async_spawn(rt, 1u64, 100u64)
    let t2 : u64 = async_spawn(rt, 2u64, 200u64)
    let t3 : u64 = async_spawn(rt, 3u64, 300u64)
    if t1 == 0u64 { return 3u64 }
    if t2 == 0u64 { return 4u64 }
    if t3 == 0u64 { return 5u64 }

    if async_alive_count(rt) != 3u32 { return 6u64 }

    /* Scheduler loop. */
    let mut iters : u32 = 0u32
    let mut completed : u32 = 0u32
    while iters < 32u32 {
        let tid : u64 = async_next_ready(rt)
        if tid == 0u64 { iters = 32u32 } else {
            let kind : u64 = async_task_kind(rt, tid)
            let ctx  : u64 = async_task_ctx(rt, tid)
            let mut result : u64 = 0u64
            if kind == 1u64 { result = ctx + 1u64 }
            if kind == 2u64 { result = ctx + 2u64 }
            if kind == 3u64 { result = ctx + 3u64 }
            async_complete(rt, tid, result)
            completed = completed + 1u32
            iters = iters + 1u32
        }
    }

    if completed != 3u32 { return 7u64 }

    /* All tasks must be COMPLETE now. */
    if async_task_state(rt, t1) != 2u32 { return 8u64 }
    if async_task_state(rt, t2) != 2u32 { return 9u64 }
    if async_task_state(rt, t3) != 2u32 { return 10u64 }

    /* Verify results: ctx + kind. */
    if async_task_result(rt, t1) != 101u64 { return 11u64 }
    if async_task_result(rt, t2) != 202u64 { return 12u64 }
    if async_task_result(rt, t3) != 303u64 { return 13u64 }

    /* async_select on a vector: should return t1 (first COMPLETE). */
    let v : u64 = vec_u64_new(arena, 4u32)
    if v == 0u64 { return 14u64 }
    vec_u64_push(v, t1)
    vec_u64_push(v, t2)
    vec_u64_push(v, t3)
    let pick : u64 = async_select(rt, v)
    if pick != t1 { return 15u64 }

    /* Idle scheduler now returns 0. */
    if async_next_ready(rt) != 0u64 { return 16u64 }

    async_runtime_free(rt)
    arena_reset(arena)
    return 99u64
}
