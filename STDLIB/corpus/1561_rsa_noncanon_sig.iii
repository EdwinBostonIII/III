/* 1561_rsa_noncanon_sig.iii -- W79 FIX falsifier: rsa_pss_verify must REJECT a non-canonical signature
 * representative per RFC 8017 §8.1.2 step 1 ("If the signature representative s is not between 0 and n-1,
 * output 'invalid signature'").
 *
 * THE DEFECT (false-accept / RSA signature malleability): rsa_pss_verify (@export) computes s = OS2IP(sig)
 * then m = s^e mod n WITHOUT checking s in [0, n-1].  Because RSAVP1 reduces mod n, the non-canonical
 * s' = s_valid + n (when it fits in k bytes) satisfies s' ≡ s_valid (mod n), so s'^e mod n == s_valid^e mod n
 * == the valid EM -- and the signature VERIFIES.  A second, distinct byte-encoding of the same signature is
 * exactly the malleability RFC 8017 §8.1.2 step 1 forbids.
 *
 * THE FIX (rsa_pss_verify, after OS2IP): `if bigint_cmp(s, n) >= 0i32 { return 0u8 }`.  A genuine signature
 * always has s < n, so valid signatures are unaffected.
 *
 * RSA-320 / sLen=0 (the fast bigint-ABI path, as corpus 373).  The seed (i*7+3)&0xFF was probed
 * (_rsa_fit_probe -> exit 100) to yield a key where s_valid + n fits in k=40 bytes.
 *
 * 99 = the canonical signature verifies AND the non-canonical s_valid+n is rejected.  TEETH: this falsifier
 * returns 10 against the PRE-FIX lib (the non-canonical sig is wrongly accepted) and 99 against POST-FIX. */
module corpus_1561

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn rsa_keygen(arena: u64, modBits: u64, seed: u64, slen: u64) -> i32 from "rsa.iii"
extern @abi(c-msvc-x64) fn rsa_gen_n() -> u64 from "rsa.iii"
extern @abi(c-msvc-x64) fn rsa_gen_e() -> u64 from "rsa.iii"
extern @abi(c-msvc-x64) fn rsa_gen_d() -> u64 from "rsa.iii"
extern @abi(c-msvc-x64) fn rsa_pss_sign(arena: u64, n: u64, d: u64, modBits: u64, mHash: u64, salt: u64, sLen: u64, sig_out: u64) -> i32 from "rsa.iii"
extern @abi(c-msvc-x64) fn rsa_pss_verify(arena: u64, n: u64, e: u64, modBits: u64, mHash: u64, sig: u64, sigLen: u64, sLen: u64) -> u8 from "rsa.iii"
extern @abi(c-msvc-x64) fn iii_rsa_keygen_seed(modBits: u64, seed: u64, slen: u64, pk_out: u64, sk_out: u64) -> i32 from "rsa.iii"

var SEED : [u8; 48]
var MH   : [u8; 32]
var SIG  : [u8; 64]
var NB   : [u8; 64]
var SK   : [u8; 128]
var NC   : [u8; 64]

fn main() -> u64 {
    let ar : u64 = arena_new(268435456u64)
    let mut i : u64 = 0u64
    while i < 32u64 { MH[i] = (i & 0xFFu64) as u8 ; i = i + 1u64 }
    i = 0u64
    while i < 48u64 { SEED[i] = ((i * 7u64 + 3u64) & 0xFFu64) as u8 ; i = i + 1u64 }

    /* n bytes (40) from the byte-ABI keygen; the SAME deterministic key as rsa_keygen(seed) */
    if iii_rsa_keygen_seed(320u64, &SEED as u64, 48u64, &NB as u64, &SK as u64) != 0i32 { return 1u64 }
    /* bigint key for sign/verify */
    if rsa_keygen(ar, 320u64, &SEED as u64, 48u64) != 0i32 { return 2u64 }
    let n : u64 = rsa_gen_n()
    let e : u64 = rsa_gen_e()
    let d : u64 = rsa_gen_d()
    if rsa_pss_sign(ar, n, d, 320u64, &MH as u64, &MH as u64, 0u64, &SIG as u64) != 0i32 { return 3u64 }

    /* POSITIVE: the canonical signature verifies */
    if rsa_pss_verify(ar, n, e, 320u64, &MH as u64, &SIG as u64, 40u64, 0u64) != 1u8 { return 4u64 }

    /* build the non-canonical representative NC = SIG + n (big-endian 40-byte add) */
    let mut carry : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 40u64 {
        let idx : u64 = 39u64 - k
        let t : u64 = (SIG[idx] as u64) + (NB[idx] as u64) + carry
        NC[idx] = (t & 0xFFu64) as u8
        carry = t >> 8u64
        k = k + 1u64
    }
    if carry != 0u64 { return 5u64 }   /* setup invariant: s_valid+n must fit in k=40 bytes (probed seed) */

    /* NEGATIVE: the non-canonical s_valid+n (s >= n) MUST be rejected per RFC 8017 §8.1.2 step 1 */
    if rsa_pss_verify(ar, n, e, 320u64, &MH as u64, &NC as u64, 40u64, 0u64) != 0u8 { return 10u64 }

    return 99u64
}
