/* 1563_nfd_canonical_reorder.iii -- W82 FIX falsifier: NFD canonical ordering (UAX #15) + NFD idempotence.
 *
 * THE DEFECT (idempotence/involution lens, ultracode workflow, unanimous 0/3 refute): norm_canonical_reorder
 * (normalise.iii:333-358) is a bubble sort whose post-swap BACKUP is two SEQUENTIAL ifs:
 *     if i > 1u32 { i = i - 1u32 }   if i == 1u32 { i = i + 1u32 }
 * These are NOT mutually exclusive: after a swap at i==2 the first sets i=1, then the second (i==1) bumps it
 * back to 2 -- so the BUF[1]-vs-BUF[0] re-compare is SKIPPED.  On a leading combining run of >=3 marks whose
 * min-CCC mark must travel past index 1, the marks come out in NON-canonical order.  (Harmless for starter-led
 * strings: BUF[0] is a CCC-0 base char and never swaps -- which is why the single existing KAT 78, "cafe"+one
 * mark, misses it.)
 *
 * INPUT: a defective combining sequence (no base) of 3 marks with strictly DESCENDING CCC --
 *   U+0301 acute (CCC 230, UTF-8 CC 81), U+0316 grave-below (CCC 220, CC 96), U+031B horn (CCC 216, CC 9B).
 * All three are in the module's declared support U+0300..U+036F and CCC table -- in-contract.
 * Canonical NFD sorts ascending CCC: 216 (031B=CC 9B), 220 (0316=CC 96), 230 (0301=CC 81) -> CC 9B CC 96 CC 81.
 *
 * THE FIX (normalise.iii:345-346): `if i > 1u32 { i = i - 1u32 } else { i = i + 1u32 }` (changes ONLY the
 * i==2 swap case -- backup to re-check position 1 vs 0).
 *
 * 99 = NFD emits canonical order AND NFD(NFD(x)) == NFD(x) (idempotence).
 * TEETH: against the PRE-FIX lib NFD emits CC 96 CC 9B CC 81 (220 before 216) so out[1]==0x96 -> return 10. */
module corpus_1563

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn builder_new(arena: u64, hint: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_seal(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_len(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn normalise_nfd(builder_id: u64, src_base: u64, src_len: u64) -> i32 from "normalise.iii"

var SRC  : [u8; 6]
var OUT1 : [u8; 6]

fn main() -> u64 {
    let a : u64 = arena_new(1u64 << 16u64)
    /* defective combining sequence, descending CCC: 0301(230), 0316(220), 031B(216) */
    SRC[0u64] = 0xCCu8 ; SRC[1u64] = 0x81u8     /* U+0301 */
    SRC[2u64] = 0xCCu8 ; SRC[3u64] = 0x96u8     /* U+0316 */
    SRC[4u64] = 0xCCu8 ; SRC[5u64] = 0x9Bu8     /* U+031B */

    let b : u64 = builder_new(a, 32u64)
    if b == 0u64 { return 1u64 }
    if normalise_nfd(b, &SRC as u64, 6u64) != 0i32 { return 2u64 }
    if builder_len(b) != 6u64 { return 100u64 + builder_len(b) }
    let out : *u8 = builder_seal(b) as *u8
    let mut k : u64 = 0u64
    while k < 6u64 { OUT1[k] = out[k] ; k = k + 1u64 }

    /* (A) canonical NFD order = CC 9B CC 96 CC 81 (ascending CCC 216,220,230) */
    if OUT1[0u64] != 0xCCu8 { return 13u64 }
    if OUT1[1u64] != 0x9Bu8 { return 10u64 }    /* PRE-FIX: 0x96 (220 emitted before 216) -> TEETH */
    if OUT1[2u64] != 0xCCu8 { return 14u64 }
    if OUT1[3u64] != 0x96u8 { return 11u64 }
    if OUT1[4u64] != 0xCCu8 { return 15u64 }
    if OUT1[5u64] != 0x81u8 { return 12u64 }

    /* (B) NFD idempotence: NFD(NFD(x)) == NFD(x) -- re-normalising canonical output is a no-op */
    let b2 : u64 = builder_new(a, 32u64)
    if b2 == 0u64 { return 3u64 }
    if normalise_nfd(b2, &OUT1 as u64, 6u64) != 0i32 { return 4u64 }
    if builder_len(b2) != 6u64 { return 200u64 + builder_len(b2) }
    let out2 : *u8 = builder_seal(b2) as *u8
    let mut j : u64 = 0u64
    while j < 6u64 { if out2[j] != OUT1[j] { return 30u64 + j } ; j = j + 1u64 }

    return 99u64
}
