 * W45 strengthen: was 8 of 64 bytes -> now the FULL FIPS 202 digest (dump-verified vs III).
 * Returns 99 on success.
 */
module corpus_156

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn sha3_512_oneshot(input_ptr: u64, input_len: u64, out_64: u64) -> u32 from "sha3_512.iii"

var EXP : [u8; 64]

fn main() -> u64 {
    EXP[0u64]=0xb7u8  EXP[1u64]=0x51u8  EXP[2u64]=0x85u8  EXP[3u64]=0x0bu8
    EXP[4u64]=0x1au8  EXP[5u64]=0x57u8  EXP[6u64]=0x16u8  EXP[7u64]=0x8au8
    EXP[8u64]=0x56u8  EXP[9u64]=0x93u8  EXP[10u64]=0xcdu8 EXP[11u64]=0x92u8
    EXP[12u64]=0x4bu8 EXP[13u64]=0x6bu8 EXP[14u64]=0x09u8 EXP[15u64]=0x6eu8
    EXP[16u64]=0x08u8 EXP[17u64]=0xf6u8 EXP[18u64]=0x21u8 EXP[19u64]=0x82u8
    EXP[20u64]=0x74u8 EXP[21u64]=0x44u8 EXP[22u64]=0xf7u8 EXP[23u64]=0x0du8
    EXP[24u64]=0x88u8 EXP[25u64]=0x4fu8 EXP[26u64]=0x5du8 EXP[27u64]=0x02u8
    EXP[28u64]=0x40u8 EXP[29u64]=0xd2u8 EXP[30u64]=0x71u8 EXP[31u64]=0x2eu8
    EXP[32u64]=0x10u8 EXP[33u64]=0xe1u8 EXP[34u64]=0x16u8 EXP[35u64]=0xe9u8
    EXP[36u64]=0x19u8 EXP[37u64]=0x2au8 EXP[38u64]=0xf3u8 EXP[39u64]=0xc9u8
    EXP[40u64]=0x1au8 EXP[41u64]=0x7eu8 EXP[42u64]=0xc5u8 EXP[43u64]=0x76u8
    EXP[44u64]=0x47u8 EXP[45u64]=0xe3u8 EXP[46u64]=0x93u8 EXP[47u64]=0x40u8
    EXP[48u64]=0x57u8 EXP[49u64]=0x34u8 EXP[50u64]=0x0bu8 EXP[51u64]=0x4cu8
    EXP[52u64]=0xf4u8 EXP[53u64]=0x08u8 EXP[54u64]=0xd5u8 EXP[55u64]=0xa5u8
    EXP[56u64]=0x65u8 EXP[57u64]=0x92u8 EXP[58u64]=0xf8u8 EXP[59u64]=0x27u8
    EXP[60u64]=0x4eu8 EXP[61u64]=0xecu8 EXP[62u64]=0x53u8 EXP[63u64]=0xf0u8

    let buf : *u8 = malloc(3u64)
    buf[0] = 97u8 buf[1] = 98u8 buf[2] = 99u8
    let out : *u8 = malloc(64u64)
    sha3_512_oneshot(buf as u64, 3u64, out as u64)

    let mut i : u64 = 0u64
    while i < 64u64 { if out[i] != EXP[i] { return 1u64 + i }  i = i + 1u64 }

    free(buf) free(out)
    return 99u64
}
