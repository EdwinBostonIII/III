/* 1586_basecodec_canonical_bits.iii -- RFC 4648 §3.5/§6 CANONICAL-ENCODING enforcement (false-accept fix).
 * verba/base64 (base64_decode + base64url_decode) and verba/base32 (base32_decode) previously emitted the
 * output bytes of a partial final quantum WITHOUT checking that the trailing bits the final char contributes
 * but does not output are zero -- so two distinct encodings ("AB==" and "AA==", "MZ======" and "MY======")
 * decoded to the SAME bytes (malleability; serious for a content-address/dedup/signature-input pipeline).
 *
 * NEGATIVE ARMS (the discriminators -- a mask-and-emit toy with no trailing-bit check FAILS each):
 *   base64   1-byte "AB==" / 2-byte "AAB="   -> B64_E_BADPAD
 *   base64url 1-byte "AB"  / 2-byte "AAB"     -> B64_E_BADPAD
 *   base32   1-byte "MZ======"               -> B32_E_BADCHAR
 * POSITIVE ARMS (the fix accepts every CANONICAL encoding, unchanged):
 *   "AA==" -> 1B, "AAA=" -> 2B, "AA" -> 1B, "AAA" -> 2B, "MY======" -> 1B.
 * 99 = all canonical accepted with correct length AND every non-canonical sibling rejected.
 * (corpus 949 keeps the base32 positive/pad-count arms; this carries the canonical-bit negatives.) */
module corpus_1586

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn builder_new(arena: u64, hint: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_len(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn base64_decode(builder_id: u64, src_base: u64, src_len: u64) -> i32 from "base64.iii"
extern @abi(c-msvc-x64) fn base64url_decode(builder_id: u64, src_base: u64, src_len: u64) -> i32 from "base64.iii"
extern @abi(c-msvc-x64) fn base32_decode(builder_id: u64, src_base: u64, src_len: u64) -> i32 from "base32.iii"

const B64_OK : i32 = 0i32
const B64_E_BADPAD : i32 = -2i32
const B32_OK : i32 = 0i32
const B32_E_BADCHAR : i32 = -1i32

/* ASCII: 'A'=65 'B'=66 '='=61 'M'=77 'Y'=89 'Z'=90 */
var B64_C1 : [u8; 4] = [65u8, 65u8, 61u8, 61u8]   /* "AA==" 1-byte canonical */
var B64_N1 : [u8; 4] = [65u8, 66u8, 61u8, 61u8]   /* "AB==" 1-byte NON-canonical (B low 4 bits set) */
var B64_C2 : [u8; 4] = [65u8, 65u8, 65u8, 61u8]   /* "AAA=" 2-byte canonical */
var B64_N2 : [u8; 4] = [65u8, 65u8, 66u8, 61u8]   /* "AAB=" 2-byte NON-canonical (B low 2 bits set) */
var URL_C1 : [u8; 2] = [65u8, 65u8]               /* "AA" rem-2 canonical */
var URL_N1 : [u8; 2] = [65u8, 66u8]               /* "AB" rem-2 NON-canonical */
var URL_C2 : [u8; 3] = [65u8, 65u8, 65u8]         /* "AAA" rem-3 canonical */
var URL_N2 : [u8; 3] = [65u8, 65u8, 66u8]         /* "AAB" rem-3 NON-canonical */
var B32_C1 : [u8; 8] = [77u8, 89u8, 61u8, 61u8, 61u8, 61u8, 61u8, 61u8]   /* "MY======" 1-byte canonical */
var B32_N1 : [u8; 8] = [77u8, 90u8, 61u8, 61u8, 61u8, 61u8, 61u8, 61u8]   /* "MZ======" 1-byte NON-canonical */

fn main() -> u64 {
    let ar : u64 = arena_new(65536u64)

    /* base64 1-byte quantum */
    let a1 : u64 = builder_new(ar, 16u64)
    if base64_decode(a1, (&B64_C1) as u64, 4u64) != B64_OK { return 10u64 }
    if builder_len(a1) != 1u64 { return 11u64 }
    let a2 : u64 = builder_new(ar, 16u64)
    if base64_decode(a2, (&B64_N1) as u64, 4u64) != B64_E_BADPAD { return 12u64 }

    /* base64 2-byte quantum */
    let b1 : u64 = builder_new(ar, 16u64)
    if base64_decode(b1, (&B64_C2) as u64, 4u64) != B64_OK { return 20u64 }
    if builder_len(b1) != 2u64 { return 21u64 }
    let b2 : u64 = builder_new(ar, 16u64)
    if base64_decode(b2, (&B64_N2) as u64, 4u64) != B64_E_BADPAD { return 22u64 }

    /* base64url 1-byte tail (rem 2) */
    let c1 : u64 = builder_new(ar, 16u64)
    if base64url_decode(c1, (&URL_C1) as u64, 2u64) != B64_OK { return 30u64 }
    if builder_len(c1) != 1u64 { return 31u64 }
    let c2 : u64 = builder_new(ar, 16u64)
    if base64url_decode(c2, (&URL_N1) as u64, 2u64) != B64_E_BADPAD { return 32u64 }

    /* base64url 2-byte tail (rem 3) */
    let g1 : u64 = builder_new(ar, 16u64)
    if base64url_decode(g1, (&URL_C2) as u64, 3u64) != B64_OK { return 40u64 }
    if builder_len(g1) != 2u64 { return 41u64 }
    let g2 : u64 = builder_new(ar, 16u64)
    if base64url_decode(g2, (&URL_N2) as u64, 3u64) != B64_E_BADPAD { return 42u64 }

    /* base32 1-byte quantum */
    let h1 : u64 = builder_new(ar, 16u64)
    if base32_decode(h1, (&B32_C1) as u64, 8u64) != B32_OK { return 50u64 }
    if builder_len(h1) != 1u64 { return 51u64 }
    let h2 : u64 = builder_new(ar, 16u64)
    if base32_decode(h2, (&B32_N1) as u64, 8u64) != B32_E_BADCHAR { return 52u64 }

    return 99u64
}
