/* SHAKE256("", 32) = 46b9dd2b0ba88d13233b3feb743eeb243fcd52ea62b81b82b50c27646ed5762f
 * First 4 bytes: 46 b9 dd 2b
 */
module corpus_158

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn shake256_oneshot(input_ptr: u64, input_len: u64, out_ptr: u64, out_len: u64) -> u32 from "shake256.iii"

fn main() -> u64 {
    let out : *u8 = malloc(32u64)
    shake256_oneshot(0u64, 0u64, out as u64, 32u64)

    if out[0] != 0x46u8 { return 1u64 }
    if out[1] != 0xb9u8 { return 2u64 }
    if out[2] != 0xddu8 { return 3u64 }
    if out[3] != 0x2bu8 { return 4u64 }

    free(out)
    return 99u64
}
