/* Step 0188 verification: aether/fed_tier basic registration + lookup. */
module corpus_159

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn fed_tier_register(slot: u32, tier_id: u32, peer_root_ptr: u64) -> i32 from "fed_tier.iii"
extern @abi(c-msvc-x64) fn fed_tier_get(slot: u32) -> u32 from "fed_tier.iii"
extern @abi(c-msvc-x64) fn fed_tier_peer_root_byte(slot: u32, i: u32) -> u32 from "fed_tier.iii"
extern @abi(c-msvc-x64) fn fed_tier_count() -> u32 from "fed_tier.iii"
extern @abi(c-msvc-x64) fn fed_tier_clear(slot: u32) -> i32 from "fed_tier.iii"

fn main() -> u64 {
    /* Build a 32-byte peer root with deterministic content. */
    let root : *u8 = malloc(32u64)
    let mut i : u64 = 0u64
    while i < 32u64 {
        root[i] = (0x40u64 + i) as u8
        i = i + 1u64
    }

    /* Register three tiers in distinct slots. */
    if fed_tier_register(0u32, 1u32, root as u64) != 0i32 { return 1u64 }   /* HOST */
    if fed_tier_register(5u32, 4u32, root as u64) != 0i32 { return 2u64 }   /* SOVEREIGN */
    if fed_tier_register(63u32, 5u32, root as u64) != 0i32 { return 3u64 }  /* PLANETARY */

    /* Reject out-of-range tier id. */
    if fed_tier_register(1u32, 9u32, root as u64) != -2i32 { return 4u64 }

    /* Lookup. */
    if fed_tier_get(0u32) != 1u32 { return 5u64 }
    if fed_tier_get(5u32) != 4u32 { return 6u64 }
    if fed_tier_get(63u32) != 5u32 { return 7u64 }
    if fed_tier_get(1u32) != 0u32 { return 8u64 }    /* unset slot */

    /* Peer root retrieval. */
    if fed_tier_peer_root_byte(0u32, 0u32) != 0x40u32 { return 9u64 }
    if fed_tier_peer_root_byte(63u32, 31u32) != 0x5fu32 { return 10u64 }
    if fed_tier_peer_root_byte(2u32, 0u32) != 0x100u32 { return 11u64 }   /* unset */
    if fed_tier_peer_root_byte(0u32, 32u32) != 0x100u32 { return 12u64 }  /* OOB */

    if fed_tier_count() != 3u32 { return 13u64 }

    /* Clear and verify count drops. */
    fed_tier_clear(5u32)
    if fed_tier_count() != 2u32 { return 14u64 }
    if fed_tier_get(5u32) != 0u32 { return 15u64 }

    return 99u64
}
