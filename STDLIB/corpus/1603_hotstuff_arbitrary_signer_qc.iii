/* 1603_hotstuff_arbitrary_signer_qc.iii -- aether::hotstuff [T1b] arbitrary-signer QC (genuine BFT).
 *
 * The QC format gained an 8-byte signer bitmap at [44..52): a quorum certificate now names WHICH peers signed
 * (any 2f+1 subset), not just a prefix peers 0..n-1.  This is real Byzantine fault tolerance -- when the faulty
 * node is a LOW-index peer (e.g. peer 0), an honest 2f+1 quorum {1,2,3} must still form a valid QC; the old
 * prefix-only format (sig[i] == peer i) would have rejected it.  99 =
 *   (1) a {1,2,3} QC composed by hs_compose_qc_bitmap VERIFIES (peer 0 abstains) -- the new capability;
 *   (2) tampering a member signature drops the count below quorum -> reject;
 *   (3) a bitmap whose popcount != n_sigs is rejected (anti-forgery);
 *   (4) the prefix path (hs_compose_qc, peers 0,1,2) still verifies (backward compatible). */
module corpus_1603

extern @abi(c-msvc-x64) fn ed25519_pubkey(seed: *u8, out_pk: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn ed25519_sign(seed: *u8, pk: *u8, msg: *u8, msg_len: u64, sig_out: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn hs_init(node_id: u32, peers: *u8, n_peers: u32) -> i32 from "hotstuff.iii"
extern @abi(c-msvc-x64) fn hs_compose_qc(block_mhash: *u8, view: u64, sigs: *u8, n_sigs: u32, out_qc: *u8) -> i32 from "hotstuff.iii"
extern @abi(c-msvc-x64) fn hs_compose_qc_bitmap(block_mhash: *u8, view: u64, signer_bitmap: u64, sigs: *u8, out_qc: *u8) -> i32 from "hotstuff.iii"
extern @abi(c-msvc-x64) fn hs_verify_qc(qc: *u8, qc_len: u32) -> u8 from "hotstuff.iii"

var K_SEED : [u8; 128]
var K_PK   : [u8; 128]
var K_BMH  : [u8; 32]
var K_SI   : [u8; 40]
var K_SIGS : [u8; 192]
var K_QC   : [u8; 256]

fn sign_subset(a: u64, b: u64, c: u64) -> u32 {
    /* sign K_SI with seeds a,b,c into K_SIGS[0..64),[64..128),[128..192) (ascending signer order) */
    if ed25519_sign(((&K_SEED as u64) + a * 32u64) as *u8, ((&K_PK as u64) + a * 32u64) as *u8, (&K_SI as u64) as *u8, 40u64, ((&K_SIGS as u64) + 0u64) as *u8) != 1u8 { return 1u32 }
    if ed25519_sign(((&K_SEED as u64) + b * 32u64) as *u8, ((&K_PK as u64) + b * 32u64) as *u8, (&K_SI as u64) as *u8, 40u64, ((&K_SIGS as u64) + 64u64) as *u8) != 1u8 { return 1u32 }
    if ed25519_sign(((&K_SEED as u64) + c * 32u64) as *u8, ((&K_PK as u64) + c * 32u64) as *u8, (&K_SI as u64) as *u8, 40u64, ((&K_SIGS as u64) + 128u64) as *u8) != 1u8 { return 1u32 }
    return 0u32
}

fn main() -> u64 {
    let mut i : u64 = 0u64
    while i < 4u64 {
        let mut j : u64 = 0u64
        while j < 32u64 { K_SEED[i * 32u64 + j] = (i * 13u64 + j + 3u64) as u8  j = j + 1u64 }
        i = i + 1u64
    }
    i = 0u64
    while i < 4u64 {
        if ed25519_pubkey(((&K_SEED as u64) + i * 32u64) as *u8, ((&K_PK as u64) + i * 32u64) as *u8) != 1u8 { return 1u64 }
        i = i + 1u64
    }
    hs_init(0u32, (&K_PK as u64) as *u8, 4u32)       /* 4 peers -> quorum 3 */

    /* block_mhash + sig_input (block_mhash || view 1) */
    let mut b : u64 = 0u64
    while b < 32u64 { K_BMH[b] = (b + 7u64) as u8  K_SI[b] = K_BMH[b]  b = b + 1u64 }
    K_SI[32u64] = 1u8
    b = 33u64
    while b < 40u64 { K_SI[b] = 0u8  b = b + 1u64 }

    /* (1) ARBITRARY subset {1,2,3} (peer 0 abstains -- it is the faulty low-index node) */
    if sign_subset(1u64, 2u64, 3u64) != 0u32 { return 2u64 }
    if hs_compose_qc_bitmap((&K_BMH as u64) as *u8, 1u64, 14u64, (&K_SIGS as u64) as *u8, (&K_QC as u64) as *u8) != 0i32 { return 3u64 }   /* bitmap 0b1110 = peers {1,2,3} */
    if hs_verify_qc((&K_QC as u64) as *u8, 244u32) != 1u8 { return 4u64 }       /* the non-prefix quorum VERIFIES */

    /* (2) tamper member sig 0 (peer 1's, at [52]) -> 2 valid < quorum -> reject */
    K_QC[52u64] = K_QC[52u64] ^ 0x01u8
    if hs_verify_qc((&K_QC as u64) as *u8, 244u32) == 1u8 { return 5u64 }
    K_QC[52u64] = K_QC[52u64] ^ 0x01u8
    if hs_verify_qc((&K_QC as u64) as *u8, 244u32) != 1u8 { return 6u64 }

    /* (3) bitmap popcount != n_sigs (forge bitmap to {1,2}=0b110 while n_sigs stays 3) -> reject */
    K_QC[44u64] = 6u8
    if hs_verify_qc((&K_QC as u64) as *u8, 244u32) == 1u8 { return 7u64 }
    K_QC[44u64] = 14u8
    if hs_verify_qc((&K_QC as u64) as *u8, 244u32) != 1u8 { return 8u64 }

    /* (4) the prefix path is backward compatible: peers {0,1,2} via hs_compose_qc still verifies */
    if sign_subset(0u64, 1u64, 2u64) != 0u32 { return 9u64 }
    if hs_compose_qc((&K_BMH as u64) as *u8, 1u64, (&K_SIGS as u64) as *u8, 3u32, (&K_QC as u64) as *u8) != 0i32 { return 10u64 }
    if hs_verify_qc((&K_QC as u64) as *u8, 244u32) != 1u8 { return 11u64 }

    return 99u64
}
