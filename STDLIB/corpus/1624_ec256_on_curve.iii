/* 1624 -- numera.ec256 on-curve validation (closes the ECDSA invalid-curve attack).
 *
 * ec256_set_affine loaded a public key as a projective point WITHOUT checking it
 * lies on P-256, and iii_ecdsa_p256_verify consumed it directly. A malicious
 * off-curve public key could be fed to verify. ec256_is_on_curve (Y^2==X^3-3X+b)
 * now gates the verify path. This proves: the validator discriminates on/off
 * curve, the valid path still verifies (no regression), and an off-curve key is
 * rejected by verify. 99 = all arms. */
module corpus_1624

extern @abi(c-msvc-x64) fn iii_ecdsa_p256_keygen(d: u64, pub_out: u64) -> i32 from "ecdsa_p256.iii"
extern @abi(c-msvc-x64) fn iii_ecdsa_p256_sign(d: u64, z: u64, k: u64, sig_out: u64) -> i32 from "ecdsa_p256.iii"
extern @abi(c-msvc-x64) fn iii_ecdsa_p256_verify_x(qx: u64, qy: u64, z: u64, sig: u64) -> u8 from "ecdsa_p256.iii"
extern @abi(c-msvc-x64) fn ec256_set_affine(p: u64, x_bytes: u64, y_bytes: u64) -> i32 from "ec256.iii"
extern @abi(c-msvc-x64) fn ec256_is_on_curve(p: u64) -> u8 from "ec256.iii"

var D : [u8; 32]
var Z : [u8; 32]
var K : [u8; 32]
var PUB : [u8; 64]
var SIG : [u8; 64]
var PUB_BAD : [u8; 64]

fn main() -> u64 {
    let mut i : u64 = 0u64
    while i < 32u64 { D[i] = ((i + 1u64) & 0xFFu64) as u8 ; i = i + 1u64 }
    i = 0u64
    while i < 32u64 { K[i] = ((i + 0x21u64) & 0xFFu64) as u8 ; i = i + 1u64 }
    i = 0u64
    while i < 32u64 { Z[i] = ((i + 0x41u64) & 0xFFu64) as u8 ; i = i + 1u64 }

    iii_ecdsa_p256_keygen((&D) as u64, (&PUB) as u64)
    iii_ecdsa_p256_sign((&D) as u64, (&Z) as u64, (&K) as u64, (&SIG) as u64)

    /* (1) the valid pubkey + signature still verifies -- no regression. */
    if iii_ecdsa_p256_verify_x((&PUB) as u64, ((&PUB) as u64) + 32u64, (&Z) as u64, (&SIG) as u64) != 1u8 { return 1u64 }

    /* (2) ON-CURVE arm: the genuine pubkey lies on P-256. */
    ec256_set_affine(33u64, (&PUB) as u64, ((&PUB) as u64) + 32u64)
    if ec256_is_on_curve(33u64) != 1u8 { return 2u64 }

    /* (3) OFF-CURVE arm: a 1-bit flip of Qy yields an off-curve point. */
    i = 0u64
    while i < 64u64 { PUB_BAD[i] = PUB[i] ; i = i + 1u64 }
    PUB_BAD[63] = PUB_BAD[63] ^ 0x01u8
    ec256_set_affine(33u64, (&PUB_BAD) as u64, ((&PUB_BAD) as u64) + 32u64)
    if ec256_is_on_curve(33u64) != 0u8 { return 3u64 }

    /* (4) wiring: verify REJECTS the off-curve public key. */
    if iii_ecdsa_p256_verify_x((&PUB_BAD) as u64, ((&PUB_BAD) as u64) + 32u64, (&Z) as u64, (&SIG) as u64) != 0u8 { return 4u64 }

    return 99u64
}
