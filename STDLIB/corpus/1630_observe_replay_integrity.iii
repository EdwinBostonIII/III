/* 1630 -- sanctus.observe: replay commit-integrity (W3400 hardening).
 *
 * The REPLAY branch validated ONLY the re-injected length, never that the bytes
 * still content-address to the recorded out_commit -- so a redacted/tampered
 * fragment (wh_redact zeros the payload, keeps the length + out_commit) replayed
 * silently as zeros. Now obs_observe recomputes cad over the re-injected bytes and
 * rejects on mismatch. This makes @safety(UNREPLAYABLE) executable. 99 = all arms. */
module corpus_1630

extern @abi(c-msvc-x64) fn obs_init() -> i32 from "observe.iii"
extern @abi(c-msvc-x64) fn obs_set_mode(m: u8) -> i32 from "observe.iii"
extern @abi(c-msvc-x64) fn obs_observe(source_id: u32, live_ptr: u64, len: u32, out_ptr: u64) -> u64 from "observe.iii"
extern @abi(c-msvc-x64) fn obs_count() -> u64 from "observe.iii"
extern @abi(c-msvc-x64) fn wh_redact(idx: u64) -> i32 from "witness_hook.iii"

var VAL : [u8; 16]
var OUT : [u8; 16]

fn main() -> u64 {
    obs_init()
    let mut i : u64 = 0u64
    while i < 16u64 { VAL[i] = ((i + 0xA0u64) & 0xFFu64) as u8  OUT[i] = 0u8  i = i + 1u64 }

    /* LIVE: observe records + passes through. */
    let h : u64 = obs_observe(7u32, (&VAL) as u64, 16u32, (&OUT) as u64)
    if h == 0xFFFFFFFFFFFFFFFFu64 { return 1u64 }
    if obs_count() != 1u64 { return 2u64 }
    i = 0u64
    while i < 16u64 { if OUT[i] != VAL[i] { return 3u64 }  i = i + 1u64 }

    /* faithful REPLAY: integrity passes, re-injects the original bytes. */
    obs_set_mode(1u8)
    i = 0u64
    while i < 16u64 { OUT[i] = 0u8  i = i + 1u64 }
    let h2 : u64 = obs_observe(7u32, (&VAL) as u64, 16u32, (&OUT) as u64)
    if h2 == 0xFFFFFFFFFFFFFFFFu64 { return 4u64 }
    i = 0u64
    while i < 16u64 { if OUT[i] != VAL[i] { return 5u64 }  i = i + 1u64 }

    /* TEETH: redact the fragment (zeros payload, keeps length + out_commit), replay
     * -> cad(zeros) != recorded out_commit -> OBS_SENTINEL (was: silent zeros). */
    wh_redact(h)
    obs_set_mode(1u8)
    let h3 : u64 = obs_observe(7u32, (&VAL) as u64, 16u32, (&OUT) as u64)
    if h3 != 0xFFFFFFFFFFFFFFFFu64 { return 6u64 }
    return 99u64
}
