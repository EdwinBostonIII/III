/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\1633_hip_locative_destination.iii
 *
 * III conformance corpus 1633 -- HIP locative-as-destination recovery.
 *
 * THE CAPABILITY DELTA (enhance W1, lens hip-intent):
 *   The CONVEY-family verbs (send/put/store/write/copy/move/dispatch) take
 *   a (src, dst, byte_count) triple.  The destination was sourced ONLY from
 *   the DESTINATION role (a "to"/"into" NP).  A locative complement -- the
 *   LOCATION role from an "in"/"on"/"at"/"within" NP -- was GATHERED by
 *   nl_parse but DROPPED by hip: "store the packet in the channel" lost the
 *   channel and conveyed to dst=0.  hip now falls back to the LOCATION head
 *   as the conveyance target WHEN (and only when) no explicit DESTINATION is
 *   present -- so "store X in Y" recovers Y, while "send X to A in B" keeps A.
 *
 * Discriminator (RED on the old lib, GREEN after the hip.iii edit):
 *   Case A "store the packet in the channel"  -> convey dst slot == 52
 *          (channel's word_id; nl_lex registers channel=52, packet=50,
 *           store=verb 6, in=prep 92 -> NLP_ROLE_LOCATION).
 *          OLD lib: dst slot == 0   -> exit 13 (RED)
 *          NEW lib: dst slot == 52  -> proceeds
 *   Case B "store the packet" (no locative) -> convey dst slot == 0
 *          (the fallback must NOT fire without a LOCATION) -> guards against
 *          a spurious-fire regression; identical on old + new.
 *
 * intent_convey writes dst_cap to partial_arg slot 1 (intent.iii:329);
 * goal_kind of a convey intent is PRIMITIVE_CONVEY = 3.
 *
 * Exit code: 99 on full pass; a distinct code per failed assertion.
 *
 * Hexad: kind_compose. Ring: R3. K: 1.00.
 */

module corpus_1633

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn hip_resolve(text_ptr: u64, text_len: u32, out_cands_ptr: u64, out_meta_ptr: u64) -> i32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_class_unique() -> u32 from "hip.iii"

extern @abi(c-msvc-x64) fn intent_goal_kind(intent_ptr: u64) -> u8 from "intent.iii"
extern @abi(c-msvc-x64) fn intent_partial_arg(intent_ptr: u64, slot: u32) -> u64 from "intent.iii"

const C1633_CONVEY : u8 = 3u8

fn _read_u32(buf: *u8, off: u64) -> u32 {
    let b0 : u32 = (buf[off] as u32) & 0xFFu32
    let b1 : u32 = ((buf[off + 1u64] as u32) & 0xFFu32) << 8u32
    let b2 : u32 = ((buf[off + 2u64] as u32) & 0xFFu32) << 16u32
    let b3 : u32 = ((buf[off + 3u64] as u32) & 0xFFu32) << 24u32
    return b0 | b1 | b2 | b3
}

fn _read_u64(buf: *u8, off: u64) -> u64 {
    let lo : u64 = (_read_u32(buf, off) as u64) & 0xFFFFFFFFu64
    let hi : u64 = (_read_u32(buf, off + 4u64) as u64) & 0xFFFFFFFFu64
    return lo | (hi << 32u64)
}

fn _put(buf: *u8, off: u64, b: u8) -> u64 {
    buf[off] = b
    return off + 1u64
}

/* "store the packet in the channel" */
fn _phrase_a(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 115u8); o = _put(buf, o, 116u8); o = _put(buf, o, 111u8); o = _put(buf, o, 114u8); o = _put(buf, o, 101u8)   /* store */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 116u8); o = _put(buf, o, 104u8); o = _put(buf, o, 101u8)   /* the */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 112u8); o = _put(buf, o, 97u8); o = _put(buf, o, 99u8); o = _put(buf, o, 107u8); o = _put(buf, o, 101u8); o = _put(buf, o, 116u8)   /* packet */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 105u8); o = _put(buf, o, 110u8)   /* in */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 116u8); o = _put(buf, o, 104u8); o = _put(buf, o, 101u8)   /* the */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 99u8); o = _put(buf, o, 104u8); o = _put(buf, o, 97u8); o = _put(buf, o, 110u8); o = _put(buf, o, 110u8); o = _put(buf, o, 101u8); o = _put(buf, o, 108u8)   /* channel */
    return o as u32
}

/* "store the packet" (no locative complement) */
fn _phrase_b(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 115u8); o = _put(buf, o, 116u8); o = _put(buf, o, 111u8); o = _put(buf, o, 114u8); o = _put(buf, o, 101u8)   /* store */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 116u8); o = _put(buf, o, 104u8); o = _put(buf, o, 101u8)   /* the */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 112u8); o = _put(buf, o, 97u8); o = _put(buf, o, 99u8); o = _put(buf, o, 107u8); o = _put(buf, o, 101u8); o = _put(buf, o, 116u8)   /* packet */
    return o as u32
}

fn _zero(buf: *u8, n: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < n { buf[i] = 0u8; i = i + 1u64 }
    return 0i32
}

fn main() -> u64 {
    let text  : *u8 = malloc(256u64)
    let cands : *u8 = malloc(64u64)
    let meta  : *u8 = malloc(16u64)
    if text  as u64 == 0u64 { return 3u64 }
    if cands as u64 == 0u64 { return 4u64 }
    if meta  as u64 == 0u64 { return 5u64 }

    let unique : u32 = hip_class_unique()

    /* === Case A: "store the packet in the channel" -> convey dst == channel(52) === */
    _zero(meta, 16u64)
    _zero(cands, 64u64)
    let len_a : u32 = _phrase_a(text)
    let rc_a : i32 = hip_resolve(text as u64, len_a, cands as u64, meta as u64)
    if rc_a != 0i32 { return 1u64 }
    let cnt_a : u32 = _read_u32(meta, 0u64)
    let cls_a : u32 = _read_u32(meta, 4u64)
    if cnt_a != 1u32   { return 10u64 }
    if cls_a != unique { return 11u64 }
    let cand0 : u64 = _read_u64(cands, 0u64)
    if (intent_goal_kind(cand0) as u32) != (C1633_CONVEY as u32) { return 12u64 }
    let dst_a : u64 = intent_partial_arg(cand0, 1u32)
    if dst_a != 52u64 { return 13u64 }   /* RED on old lib (dst==0); GREEN after (dst==52) */

    /* === Case B: "store the packet" (control) -> convey dst == 0 (no spurious fire) === */
    _zero(meta, 16u64)
    _zero(cands, 64u64)
    let len_b : u32 = _phrase_b(text)
    let rc_b : i32 = hip_resolve(text as u64, len_b, cands as u64, meta as u64)
    if rc_b != 0i32 { return 2u64 }
    let cnt_b : u32 = _read_u32(meta, 0u64)
    if cnt_b != 1u32 { return 20u64 }
    let cand0b : u64 = _read_u64(cands, 0u64)
    if (intent_goal_kind(cand0b) as u32) != (C1633_CONVEY as u32) { return 21u64 }
    let dst_b : u64 = intent_partial_arg(cand0b, 1u32)
    if dst_b != 0u64 { return 22u64 }

    free(text)
    free(cands)
    free(meta)
    return 99u64
}
