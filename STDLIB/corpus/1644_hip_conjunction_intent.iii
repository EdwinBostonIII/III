/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\1644_hip_conjunction_intent.iii
 *
 * III conformance corpus 1644 -- HIP conjunction composition (the NL-surface finale).
 *
 * THE CAPABILITY DELTA (enhance W3, recover-the-discarded):
 *   nl_parse recognises a coordinating conjunction ("send X and close Y"),
 *   recurses into the second clause, and emits a CONJ fragment (role 14, quant=
 *   the conjunction word_id) plus the second clause's VERB/PATIENT -- but hip
 *   projected ONLY the first clause, dropping the second action.  hip now
 *   projects the second clause (scanning roles AFTER the conjunction via the new
 *   HIP_PROJ_FRAG_START offset that makes _hip_role_of position-aware) and
 *   composes: "and" -> intent_with, "then" -> intent_then, else intent_compose.
 *
 * Discriminator (RED on the old lib, GREEN after the hip.iii edit):
 *   Case A "send the packet and close the socket"
 *     -> top candidate goal_kind == PRIMITIVE_WITH (13)
 *        OLD: PRIMITIVE_CONVEY (3, only the send)          -> exit 11 (RED)
 *        NEW: WITH{ left = CONVEY(send), right = ACT(close) }
 *   Case B "send the packet" (no conjunction)
 *     -> top candidate goal_kind == PRIMITIVE_CONVEY (3); compose must NOT fire.
 *
 * intent_with stores left at partial_arg 0, right at 1.  PRIMITIVE_WITH=13,
 * CONVEY=3, ACT=5.  All KAT words (send/packet/and/close/socket/the) registered.
 *
 * Exit: 99 full pass; distinct code per failed assertion.
 * Hexad: kind_compose. Ring: R3. K: 1.00.
 */

module corpus_1644

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn hip_resolve(text_ptr: u64, text_len: u32, out_cands_ptr: u64, out_meta_ptr: u64) -> i32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_class_unique() -> u32 from "hip.iii"
extern @abi(c-msvc-x64) fn intent_goal_kind(intent_ptr: u64) -> u8 from "intent.iii"
extern @abi(c-msvc-x64) fn intent_partial_arg(intent_ptr: u64, slot: u32) -> u64 from "intent.iii"

const C1644_CONVEY : u32 = 3u32
const C1644_ACT    : u32 = 5u32
const C1644_WITH   : u32 = 13u32

fn _read_u32(buf: *u8, off: u64) -> u32 {
    let b0 : u32 = (buf[off] as u32) & 0xFFu32
    let b1 : u32 = ((buf[off + 1u64] as u32) & 0xFFu32) << 8u32
    let b2 : u32 = ((buf[off + 2u64] as u32) & 0xFFu32) << 16u32
    let b3 : u32 = ((buf[off + 3u64] as u32) & 0xFFu32) << 24u32
    return b0 | b1 | b2 | b3
}
fn _read_u64(buf: *u8, off: u64) -> u64 {
    let lo : u64 = (_read_u32(buf, off) as u64) & 0xFFFFFFFFu64
    let hi : u64 = (_read_u32(buf, off + 4u64) as u64) & 0xFFFFFFFFu64
    return lo | (hi << 32u64)
}
fn _put(buf: *u8, off: u64, b: u8) -> u64 { buf[off] = b; return off + 1u64 }
fn _zero(buf: *u8, n: u64) -> i32 { let mut i : u64 = 0u64  while i < n { buf[i] = 0u8  i = i + 1u64 }  return 0i32 }

/* "send the packet and close the socket" */
fn _phrase_a(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o=_put(buf,o,115u8);o=_put(buf,o,101u8);o=_put(buf,o,110u8);o=_put(buf,o,100u8);o=_put(buf,o,32u8)   /* send */
    o=_put(buf,o,116u8);o=_put(buf,o,104u8);o=_put(buf,o,101u8);o=_put(buf,o,32u8)   /* the */
    o=_put(buf,o,112u8);o=_put(buf,o,97u8);o=_put(buf,o,99u8);o=_put(buf,o,107u8);o=_put(buf,o,101u8);o=_put(buf,o,116u8);o=_put(buf,o,32u8)   /* packet */
    o=_put(buf,o,97u8);o=_put(buf,o,110u8);o=_put(buf,o,100u8);o=_put(buf,o,32u8)   /* and */
    o=_put(buf,o,99u8);o=_put(buf,o,108u8);o=_put(buf,o,111u8);o=_put(buf,o,115u8);o=_put(buf,o,101u8);o=_put(buf,o,32u8)   /* close */
    o=_put(buf,o,116u8);o=_put(buf,o,104u8);o=_put(buf,o,101u8);o=_put(buf,o,32u8)   /* the */
    o=_put(buf,o,115u8);o=_put(buf,o,111u8);o=_put(buf,o,99u8);o=_put(buf,o,107u8);o=_put(buf,o,101u8);o=_put(buf,o,116u8)   /* socket */
    return o as u32
}
/* "send the packet" (no conjunction) */
fn _phrase_b(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o=_put(buf,o,115u8);o=_put(buf,o,101u8);o=_put(buf,o,110u8);o=_put(buf,o,100u8);o=_put(buf,o,32u8)   /* send */
    o=_put(buf,o,116u8);o=_put(buf,o,104u8);o=_put(buf,o,101u8);o=_put(buf,o,32u8)   /* the */
    o=_put(buf,o,112u8);o=_put(buf,o,97u8);o=_put(buf,o,99u8);o=_put(buf,o,107u8);o=_put(buf,o,101u8);o=_put(buf,o,116u8)   /* packet */
    return o as u32
}

fn main() -> u64 {
    let text  : *u8 = malloc(256u64)
    let cands : *u8 = malloc(64u64)
    let meta  : *u8 = malloc(16u64)
    if text  as u64 == 0u64 { return 3u64 }
    if cands as u64 == 0u64 { return 4u64 }
    if meta  as u64 == 0u64 { return 5u64 }

    /* === Case A: conjunction -> WITH{ CONVEY(send), ACT(close) } === */
    _zero(meta, 16u64); _zero(cands, 64u64)
    let len_a : u32 = _phrase_a(text)
    let rc_a : i32 = hip_resolve(text as u64, len_a, cands as u64, meta as u64)
    if rc_a != 0i32 { return 1u64 }
    let cnt_a : u32 = _read_u32(meta, 0u64)
    if cnt_a != 1u32 { return 10u64 }
    let cand0 : u64 = _read_u64(cands, 0u64)
    if (intent_goal_kind(cand0) as u32) != C1644_WITH { return 11u64 }    /* RED on old lib (==CONVEY 3) */
    let left  : u64 = intent_partial_arg(cand0, 0u32)
    if (intent_goal_kind(left) as u32) != C1644_CONVEY { return 12u64 }   /* first clause: send-CONVEY */
    let right : u64 = intent_partial_arg(cand0, 1u32)
    if (intent_goal_kind(right) as u32) != C1644_ACT { return 13u64 }     /* second clause: close-ACT */

    /* === Case B: no conjunction -> bare CONVEY, compose must NOT fire === */
    _zero(meta, 16u64); _zero(cands, 64u64)
    let len_b : u32 = _phrase_b(text)
    let rc_b : i32 = hip_resolve(text as u64, len_b, cands as u64, meta as u64)
    if rc_b != 0i32 { return 2u64 }
    let cnt_b : u32 = _read_u32(meta, 0u64)
    if cnt_b != 1u32 { return 20u64 }
    let cand0b : u64 = _read_u64(cands, 0u64)
    if (intent_goal_kind(cand0b) as u32) != C1644_CONVEY { return 21u64 }

    free(text); free(cands); free(meta)
    return 99u64
}
