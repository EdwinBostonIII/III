/* 1653_proof_symmetry_swap.iii -- W7 SOUNDNESS falsifier: the SYMMETRY inference rule now checks
 * that its conclusion is the byte-SWAPPED relation of its premise.
 *
 * THE DEFECT (numera/proof_term.iii): pt_verify_step dispatched PT_RULE_SYMMETRY to pt_arity1 --
 * an ARITY-ONLY check (premise count == 1).  MODUS_PONENS and TRANSITIVITY replay their conclusions
 * (pt_check_mp/pt_check_trans), but SYMMETRY did NOT, so a step claiming SYMMETRY whose conclusion
 * EQUALS its premise ("a=b" -> "a=b", sides NOT swapped) certified as a valid inference -- an unsound
 * proof step a verifier must reject.
 *
 * THE FIX: pt_check_symmetry splits premise and conclusion on the relation byte '=' (0x3D) and
 * requires conclusion-LHS == premise-RHS and conclusion-RHS == premise-LHS.
 *
 * Discriminator (RED on the old lib, GREEN after):
 *   - VALID symmetry: premise "a=b", conclusion "b=a"  -> pt_verify == PT_OK (a correct swap still
 *     verifies; a stub that always rejects fails this arm).
 *   - INVALID symmetry: premise "a=b", conclusion "a=b" -> OLD lib pt_verify == PT_OK (accepts the
 *     unsound step); NEW lib == PT_E_INVALID_INFERENCE.
 * Exit 99 full pass; distinct code per failed assertion. */
module corpus_1653

extern @abi(c-msvc-x64) fn pt_init() -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_alloc(out_term_id: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_add_inference(args: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_finalize(term_id: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_verify(term_id: *u8) -> i32 from "proof_term.iii"

const PT_RULE_AXIOM          : u8  = 0x01u8
const PT_RULE_SYMMETRY       : u8  = 0x09u8
const PT_OK                  : i32 =  0i32
const PT_E_INVALID_INFERENCE : i32 = -4i32

var ARG  : [u8; 128]
var TIDV : [u8; 32]    /* valid term */
var TIDI : [u8; 32]    /* invalid term */

fn wr_u32(addr: u64, off: u64, v: u32) -> i32 {
    let p : *u8 = (addr + off) as *u8
    p[0u64] = (v & 0xFFu32) as u8
    p[1u64] = ((v >> 8u32) & 0xFFu32) as u8
    p[2u64] = ((v >> 16u32) & 0xFFu32) as u8
    p[3u64] = ((v >> 24u32) & 0xFFu32) as u8
    return 0i32
}

/* Build a step into ARG: term_id @[0..32], kind @[32], pcount @[36], clen @[40],
 * premise[0] @[44] (when pcount==1), conclusion bytes after the premises. */
fn build_step(tid_addr: u64, kind: u8, pcount: u32, prem0: u32, c0: u8, c1: u8, c2: u8) -> i32 {
    let a : u64 = (&ARG) as u64
    let ap : *u8 = a as *u8
    let tp : *u8 = tid_addr as *u8
    let mut i : u64 = 0u64
    while i < 128u64 { ap[i] = 0u8  i = i + 1u64 }
    i = 0u64
    while i < 32u64 { ap[i] = tp[i]  i = i + 1u64 }
    ap[32u64] = kind
    wr_u32(a, 36u64, pcount)
    wr_u32(a, 40u64, 3u32)               /* clen = 3 ("x=y") */
    let mut coff : u64 = 44u64
    if pcount == 1u32 { wr_u32(a, 44u64, prem0)  coff = 48u64 }
    ap[coff + 0u64] = c0
    ap[coff + 1u64] = 0x3Du8             /* '=' */
    ap[coff + 2u64] = c2
    /* (c1 is unused -- the middle byte is always the relation '=') */
    return pt_add_inference(a as *u8)
}

fn main() -> u64 {
    pt_init()

    /* ---- VALID: premise "a=b", SYMMETRY conclusion "b=a" -> verifies ---- */
    if pt_alloc((&TIDV) as *u8) != PT_OK { return 1u64 }
    if build_step((&TIDV) as u64, PT_RULE_AXIOM, 0u32, 0u32, 0x61u8, 0x3Du8, 0x62u8) != PT_OK { return 2u64 }   /* a=b */
    if build_step((&TIDV) as u64, PT_RULE_SYMMETRY, 1u32, 0u32, 0x62u8, 0x3Du8, 0x61u8) != PT_OK { return 3u64 } /* b=a */
    if pt_finalize((&TIDV) as *u8) != PT_OK { return 4u64 }
    if pt_verify((&TIDV) as *u8) != PT_OK { return 5u64 }              /* the correct swap must verify */

    /* ---- INVALID: premise "a=b", SYMMETRY conclusion "a=b" (NOT swapped) -> rejected ---- */
    if pt_alloc((&TIDI) as *u8) != PT_OK { return 6u64 }
    if build_step((&TIDI) as u64, PT_RULE_AXIOM, 0u32, 0u32, 0x61u8, 0x3Du8, 0x62u8) != PT_OK { return 7u64 }   /* a=b */
    if build_step((&TIDI) as u64, PT_RULE_SYMMETRY, 1u32, 0u32, 0x61u8, 0x3Du8, 0x62u8) != PT_OK { return 8u64 } /* a=b (no swap) */
    if pt_finalize((&TIDI) as *u8) != PT_OK { return 9u64 }
    if pt_verify((&TIDI) as *u8) != PT_E_INVALID_INFERENCE { return 10u64 }   /* OLD lib: PT_OK -> RED */

    return 99u64
}
