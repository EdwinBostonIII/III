/* 1665_proof_equality_leibniz.iii -- FIRST-ORDER LOGIC WITH EQUALITY (FOL=): Leibniz's law.
 *
 * The prover already has equality as a RELATION with reflexivity / symmetry / transitivity -- but those
 * treat "a=b" as an opaque atom.  LEIBNIZ (substitution of equals, 0x1B) is what gives equality its
 * MEANING: from a=b and any formula φ mentioning the term a, conclude φ with some occurrences of a
 * replaced by b.  This single rule lifts first-order logic to FOL= -- the logic of essentially all of
 * mathematics (the "indiscernibility of identicals").
 *
 * Soundness: a=b licenses replacing ANY individual occurrence of a by b (each swap preserves truth), so
 * the conclusion may replace SOME (not necessarily all) a's.  The match predicate is therefore, at every
 * position i: c[i]==φ[i]  OR  (φ[i]==a AND c[i]==b) -- permissive on which a's swap, strict that nothing
 * else may change.  The equality premise must be a top-level relation t1=t2 of single-byte terms.
 *
 * Discriminator (RED on the old lib -- LEIBNIZ 0x1B unknown -> the proofs fail to verify; GREEN after):
 *   (A) a=b, P(a) |- P(b)                  (basic substitution of equals)
 *   (B) a=b, a=a  |- b=a                    (PARTIAL replacement -- only the first a swapped)
 *   (C) TEETH: a=b, P(a) |- P(c)  (c≠b)     -> reject (a's image must be b, not c)
 *   (D) TEETH: a=b, P(a) |- Q(b)            -> reject (a NON-a position changed: P->Q)
 *   (E) TEETH: P(a), P(a) |- P(b)           -> reject (first premise is not an equality relation)
 * Exit 99 full pass; distinct code per failed assertion. */
module corpus_1665

extern @abi(c-msvc-x64) fn pt_init() -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_alloc(out_term_id: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_add_inference(args: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_finalize(term_id: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_verify(term_id: *u8) -> i32 from "proof_term.iii"

const PT_RULE_AXIOM          : u8  = 0x01u8
const PT_RULE_LEIBNIZ        : u8  = 0x1Bu8
const PT_OK                  : i32 =  0i32
const PT_E_INVALID_INFERENCE : i32 = -4i32

var ARG   : [u8; 128]
var PREMS : [u32; 8]
var CB    : [u8; 16]
var T_A : [u8; 32]
var T_B : [u8; 32]
var T_C : [u8; 32]
var T_D : [u8; 32]
var T_E : [u8; 32]

fn wr_u32(off: u64, v: u32) -> i32 {
    let p : *u8 = ((&ARG) as u64 + off) as *u8
    p[0u64] = (v & 0xFFu32) as u8   p[1u64] = ((v >> 8u32) & 0xFFu32) as u8
    p[2u64] = ((v >> 16u32) & 0xFFu32) as u8   p[3u64] = ((v >> 24u32) & 0xFFu32) as u8
    return 0i32
}

fn build(tid_addr: u64, kind: u8, pcount: u32, clen: u32) -> i32 {
    let ap : *u8 = (&ARG) as *u8
    let tp : *u8 = tid_addr as *u8
    let mut i : u64 = 0u64
    while i < 128u64 { ap[i] = 0u8  i = i + 1u64 }
    i = 0u64
    while i < 32u64 { ap[i] = tp[i]  i = i + 1u64 }
    ap[32u64] = kind
    wr_u32(36u64, pcount)   wr_u32(40u64, clen)
    let mut k : u64 = 0u64
    while k < (pcount as u64) { wr_u32(44u64 + k * 4u64, PREMS[k])  k = k + 1u64 }
    let coff : u64 = 44u64 + 4u64 * (pcount as u64)
    let mut j : u64 = 0u64
    while j < (clen as u64) { ap[coff + j] = CB[j]  j = j + 1u64 }
    return pt_add_inference((&ARG) as *u8)
}

/* byte vocab: a=0x61 b=0x62 c=0x63 ; P=0x50 Q=0x51 ; '='=0x3D (relation op) */
fn cb_eq_ab() -> i32 { CB[0u64]=0x61u8 CB[1u64]=0x3Du8 CB[2u64]=0x62u8 return 0i32 }  /* a=b */
fn cb_Pa()    -> i32 { CB[0u64]=0x50u8 CB[1u64]=0x61u8 return 0i32 }                  /* P(a) */

fn main() -> u64 {
    pt_init()

    /* (A) a=b, P(a) |- P(b). */
    if pt_alloc((&T_A) as *u8) != PT_OK { return 1u64 }
    cb_eq_ab()
    if build((&T_A) as u64, PT_RULE_AXIOM, 0u32, 3u32) != PT_OK { return 2u64 }       /* 0: a=b */
    cb_Pa()
    if build((&T_A) as u64, PT_RULE_AXIOM, 0u32, 2u32) != PT_OK { return 3u64 }       /* 1: P(a) */
    PREMS[0u64]=0u32  PREMS[1u64]=1u32   CB[0u64]=0x50u8 CB[1u64]=0x62u8              /* P(b) */
    if build((&T_A) as u64, PT_RULE_LEIBNIZ, 2u32, 2u32) != PT_OK { return 4u64 }
    if pt_finalize((&T_A) as *u8) != PT_OK { return 5u64 }
    if pt_verify((&T_A) as *u8) != PT_OK { return 6u64 }    /* OLD: rule unknown -> RED */

    /* (B) a=b, a=a |- b=a  (only the FIRST a swapped -- partial replacement is sound). */
    if pt_alloc((&T_B) as *u8) != PT_OK { return 7u64 }
    cb_eq_ab()
    if build((&T_B) as u64, PT_RULE_AXIOM, 0u32, 3u32) != PT_OK { return 8u64 }       /* 0: a=b */
    CB[0u64]=0x61u8 CB[1u64]=0x3Du8 CB[2u64]=0x61u8
    if build((&T_B) as u64, PT_RULE_AXIOM, 0u32, 3u32) != PT_OK { return 9u64 }       /* 1: a=a */
    PREMS[0u64]=0u32  PREMS[1u64]=1u32   CB[0u64]=0x62u8 CB[1u64]=0x3Du8 CB[2u64]=0x61u8  /* b=a */
    if build((&T_B) as u64, PT_RULE_LEIBNIZ, 2u32, 3u32) != PT_OK { return 10u64 }
    if pt_finalize((&T_B) as *u8) != PT_OK { return 11u64 }
    if pt_verify((&T_B) as *u8) != PT_OK { return 12u64 }

    /* (C) TEETH: a=b, P(a) |- P(c)  -> reject (a must map to b, not c). */
    if pt_alloc((&T_C) as *u8) != PT_OK { return 13u64 }
    cb_eq_ab()
    if build((&T_C) as u64, PT_RULE_AXIOM, 0u32, 3u32) != PT_OK { return 14u64 }      /* 0: a=b */
    cb_Pa()
    if build((&T_C) as u64, PT_RULE_AXIOM, 0u32, 2u32) != PT_OK { return 15u64 }      /* 1: P(a) */
    PREMS[0u64]=0u32  PREMS[1u64]=1u32   CB[0u64]=0x50u8 CB[1u64]=0x63u8              /* P(c) -- wrong image */
    if build((&T_C) as u64, PT_RULE_LEIBNIZ, 2u32, 2u32) != PT_OK { return 16u64 }
    if pt_finalize((&T_C) as *u8) != PT_OK { return 17u64 }
    if pt_verify((&T_C) as *u8) != PT_E_INVALID_INFERENCE { return 18u64 }

    /* (D) TEETH: a=b, P(a) |- Q(b)  -> reject (the non-a position P was changed to Q). */
    if pt_alloc((&T_D) as *u8) != PT_OK { return 19u64 }
    cb_eq_ab()
    if build((&T_D) as u64, PT_RULE_AXIOM, 0u32, 3u32) != PT_OK { return 20u64 }      /* 0: a=b */
    cb_Pa()
    if build((&T_D) as u64, PT_RULE_AXIOM, 0u32, 2u32) != PT_OK { return 21u64 }      /* 1: P(a) */
    PREMS[0u64]=0u32  PREMS[1u64]=1u32   CB[0u64]=0x51u8 CB[1u64]=0x62u8              /* Q(b) -- changed predicate */
    if build((&T_D) as u64, PT_RULE_LEIBNIZ, 2u32, 2u32) != PT_OK { return 22u64 }
    if pt_finalize((&T_D) as *u8) != PT_OK { return 23u64 }
    if pt_verify((&T_D) as *u8) != PT_E_INVALID_INFERENCE { return 24u64 }

    /* (E) TEETH: P(a), P(a) |- P(b)  -> reject (first premise is not an equality). */
    if pt_alloc((&T_E) as *u8) != PT_OK { return 25u64 }
    cb_Pa()
    if build((&T_E) as u64, PT_RULE_AXIOM, 0u32, 2u32) != PT_OK { return 26u64 }      /* 0: P(a) (not eq) */
    cb_Pa()
    if build((&T_E) as u64, PT_RULE_AXIOM, 0u32, 2u32) != PT_OK { return 27u64 }      /* 1: P(a) */
    PREMS[0u64]=0u32  PREMS[1u64]=1u32   CB[0u64]=0x50u8 CB[1u64]=0x62u8              /* P(b) */
    if build((&T_E) as u64, PT_RULE_LEIBNIZ, 2u32, 2u32) != PT_OK { return 28u64 }
    if pt_finalize((&T_E) as *u8) != PT_OK { return 29u64 }
    if pt_verify((&T_E) as *u8) != PT_E_INVALID_INFERENCE { return 30u64 }

    return 99u64
}
