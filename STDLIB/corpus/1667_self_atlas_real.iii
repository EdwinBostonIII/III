/* 1667_self_atlas_real.iii -- load III's ACTUAL module-dependency self-model and verify it.
 *
 * omnia/self_atlas_data.iii is generated by STDLIB/scripts/gen_self_atlas.py from III's own
 * source (the cartographer brought INSIDE III).  This test loads it into omnia/self_atlas and
 * asserts structural truths about III itself -- proving the self-model is faithful and live:
 *
 *   - node/edge counts match the generated data (a stale data file is caught);
 *   - the two known intentional co-recursions are SEEN as cycles:
 *       ccl <-> typecheck  (the CIC kernel <-> beta-eta reducer)
 *       constitution <-> temporal_logic  (LTL over constitutional predicates);
 *   - cad (content-addressing) is the structural hub it is (fan-in 58);
 *   - the steepest hub (largest blast radius) is a real node with non-zero impact;
 *   - the content commitment over the whole self-model is reproducible.
 *
 * main() returns 99 on full pass; a distinct small code identifies the first failing check.
 */
module corpus_1667

extern @abi(c-msvc-x64) fn satlas_data_load() -> i32 from "self_atlas_data.iii"
extern @abi(c-msvc-x64) fn satlas_data_node_count() -> u32 from "self_atlas_data.iii"
extern @abi(c-msvc-x64) fn satlas_data_edge_count() -> u32 from "self_atlas_data.iii"

extern @abi(c-msvc-x64) fn satlas_find(name_ptr: u64, len: u64) -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_node_count() -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_edge_count() -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_fanin(n: u32) -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_in_cycle(n: u32) -> u8 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_same_cycle(a: u32, b: u32) -> u8 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_impact_count(n: u32) -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_steepest_hub() -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_commit(out32: u64) -> i32 from "self_atlas.iii"

const SENT : u32 = 0xFFFFFFFFu32

var RC1 : [u8; 32]
var RC2 : [u8; 32]

fn fid(p: u64, l: u64) -> u32 { return satlas_find(p, l) }

fn beq32(p: u64, q: u64) -> u8 {
    let a : *u8 = p as *u8
    let b : *u8 = q as *u8
    let mut i : u64 = 0u64
    let mut eq : u8 = 1u8
    while i < 32u64 {
        if a[i] != b[i] { eq = 0u8 }
        i = i + 1u64
    }
    return eq
}

fn main() -> u64 {
    satlas_data_load()

    if satlas_node_count() != satlas_data_node_count() { return 1u64 }
    if satlas_edge_count() != satlas_data_edge_count() { return 2u64 }

    let ccl : u32 = fid(("ccl" as *u8) as u64, 3u64)
    let tc  : u32 = fid(("typecheck" as *u8) as u64, 9u64)
    if ccl == SENT { return 3u64 }
    if tc == SENT { return 4u64 }
    if satlas_same_cycle(ccl, tc) != 1u8 { return 5u64 }
    if satlas_in_cycle(ccl) != 1u8 { return 6u64 }

    let con : u32 = fid(("constitution" as *u8) as u64, 12u64)
    let tl  : u32 = fid(("temporal_logic" as *u8) as u64, 14u64)
    if con == SENT { return 7u64 }
    if tl == SENT { return 8u64 }
    if satlas_same_cycle(con, tl) != 1u8 { return 9u64 }

    let cad : u32 = fid(("cad" as *u8) as u64, 3u64)
    if cad == SENT { return 10u64 }
    if satlas_fanin(cad) != 58u32 { return 11u64 }
    if satlas_impact_count(cad) == 0u32 { return 12u64 }

    let hub : u32 = satlas_steepest_hub()
    if hub == SENT { return 13u64 }
    if hub >= satlas_node_count() { return 14u64 }
    if satlas_impact_count(hub) == 0u32 { return 15u64 }

    satlas_commit((&RC1 as u64))
    satlas_data_load()
    satlas_commit((&RC2 as u64))
    if beq32((&RC1 as u64), (&RC2 as u64)) != 1u8 { return 16u64 }

    return 99u64
}
