/* 1668_self_atlas_lens.iii -- omnia::self_atlas_lens: III's emergence-analysis faculty.
 *
 * Builds the same hand-verified graph as 1666 and asserts every lens signal:
 *     a->b a->c b->d c->d d->e a->d(redundant) x->y y->z z->x   (8 nodes, 9 edges)
 *
 * Hand-checked expectations:
 *   coupling      = 9*1000/8 = 1125
 *   orphans       = 0   (no node has fanin==0 AND fanout==0)
 *   roots         = 1   (only a)
 *   leaves        = 1   (only e)
 *   cycle_nodes   = 3   (x,y,z)
 *   redundant     = 1   (only a->d; a still reaches d via a->b->d)
 *   first_redund  = [a,d] = [0,3]
 *   top_hub       = e (id 4) ; top_hub_impact = 4
 *   argmax_fanin  = d (id 3) ; max_fanin = 3
 *
 * main() returns 99 on full pass; a distinct small code identifies the first failing check.
 */
module corpus_1668

extern @abi(c-msvc-x64) fn satlas_reset() -> i32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_link(fp: u64, fl: u64, tp: u64, tl: u64) -> i32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_find(name_ptr: u64, len: u64) -> u32 from "self_atlas.iii"

extern @abi(c-msvc-x64) fn salens_coupling() -> u32 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_count_orphans() -> u32 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_count_roots() -> u32 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_count_leaves() -> u32 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_count_cycle_nodes() -> u32 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_count_redundant() -> u32 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_first_redundant(out_ptr: u64) -> u8 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_top_hub() -> u32 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_top_hub_impact() -> u32 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_argmax_fanin() -> u32 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_max_fanin() -> u32 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_deepest_integrator() -> u32 from "self_atlas_lens.iii"
extern @abi(c-msvc-x64) fn salens_max_depends() -> u32 from "self_atlas_lens.iii"

var T_A : [u8; 1]
var T_B : [u8; 1]
var FR  : [u32; 2]

fn lk(c1: u32, c2: u32) -> i32 {
    let pa : *u8 = (&T_A as u64) as *u8
    let pb : *u8 = (&T_B as u64) as *u8
    pa[0u64] = c1 as u8
    pb[0u64] = c2 as u8
    return satlas_link((&T_A as u64), 1u64, (&T_B as u64), 1u64)
}

fn id1(c: u32) -> u32 {
    let pa : *u8 = (&T_A as u64) as *u8
    pa[0u64] = c as u8
    return satlas_find((&T_A as u64), 1u64)
}

fn main() -> u64 {
    satlas_reset()
    lk(97u32, 98u32)    /* a->b */
    lk(97u32, 99u32)    /* a->c */
    lk(98u32, 100u32)   /* b->d */
    lk(99u32, 100u32)   /* c->d */
    lk(100u32, 101u32)  /* d->e */
    lk(97u32, 100u32)   /* a->d (redundant) */
    lk(120u32, 121u32)  /* x->y */
    lk(121u32, 122u32)  /* y->z */
    lk(122u32, 120u32)  /* z->x */

    let a : u32 = id1(97u32)
    let d : u32 = id1(100u32)
    let e : u32 = id1(101u32)

    if salens_coupling() != 1125u32 { return 1u64 }
    if salens_count_orphans() != 0u32 { return 2u64 }
    if salens_count_roots() != 1u32 { return 3u64 }
    if salens_count_leaves() != 1u32 { return 4u64 }
    if salens_count_cycle_nodes() != 3u32 { return 5u64 }
    if salens_count_redundant() != 1u32 { return 6u64 }

    if salens_first_redundant((&FR as u64)) != 1u8 { return 7u64 }
    if FR[0u64] != a { return 8u64 }
    if FR[1u64] != d { return 9u64 }

    if salens_top_hub() != e { return 10u64 }
    if salens_top_hub_impact() != 4u32 { return 11u64 }
    if salens_argmax_fanin() != d { return 12u64 }
    if salens_max_fanin() != 3u32 { return 13u64 }
    if salens_max_depends() != 4u32 { return 14u64 }
    if salens_deepest_integrator() != a { return 15u64 }

    return 99u64
}
