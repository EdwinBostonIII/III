/* 1670_self_cartographer.iii -- III maps a source tree NATIVELY (omnia::self_cartographer).
 *
 * Hermetic, like 1124: build a tiny tree of .iii files with known `from "X.iii"` edges, have
 * scarto_map walk it (via aether/fs) and populate omnia/self_atlas, verify the recovered graph,
 * then clean up -- proving III extracts its OWN dependency graph in III, with no external tool.
 *
 *   ./iii_carto_kat/alpha.iii      from "beta.iii"  from "gamma.iii"
 *   ./iii_carto_kat/beta.iii       from "gamma.iii"
 *   ./iii_carto_kat/gamma.iii      (leaf -- no deps)
 *   ./iii_carto_kat/sub/delta.iii  from "alpha.iii"   (proves recursion into subdirs)
 *
 * Expected: 4 nodes {alpha,beta,gamma,delta}; 4 edges; reaches(delta,gamma)=1.
 * rc 99 = pass; a distinct small code marks each failed step.
 */
module corpus_1670

extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn fs_open(cap: u64, path: u64, mode: u32) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_close(h: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_write(h: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_delete(cap: u64, path: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_mkdir(cap: u64, path: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_rmdir(cap: u64, path: u64) -> i32 from "fs.iii"

extern @abi(c-msvc-x64) fn scarto_map(cap: u64, root_ptr: u64, root_len: u64) -> u32 from "self_cartographer.iii"

extern @abi(c-msvc-x64) fn satlas_node_count() -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_edge_count() -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_find(name_ptr: u64, len: u64) -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_depends_direct(src: u32, tgt: u32) -> u8 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_reaches(src: u32, tgt: u32) -> u8 from "self_atlas.iii"

const SENT : u32 = 0xFFFFFFFFu32
const MWRITE : u32 = 2u32

var P_DIR   : [u8; 64]
var P_SUB   : [u8; 64]
var P_ALPHA : [u8; 64]
var P_BETA  : [u8; 64]
var P_GAMMA : [u8; 64]
var P_DELTA : [u8; 64]
var C_ALPHA : [u8; 48]
var C_BETA  : [u8; 24]
var C_GAMMA : [u8; 8]
var C_DELTA : [u8; 24]
var NM      : [u8; 16]

fn bcopy(dst: u64, src: u64, n: u64) -> u64 {
    let d : *u8 = dst as *u8
    let s : *u8 = src as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]  i = i + 1u64 }
    d[n] = 0u8
    return n
}

/* write content_len bytes to a freshly created file at path */
fn wfile(cap: u64, path: u64, content: u64, clen: u64) -> i32 {
    let h : u64 = fs_open(cap, path, MWRITE)
    if h == 0u64 { return -1i32 }
    let w : u64 = fs_write(h, content, clen)
    fs_close(h)
    if w != clen { return -2i32 }
    return 0i32
}

/* node id of a name held in NM (len bytes) */
fn fid(len: u64) -> u32 { return satlas_find((&NM as u64), len) }

fn setnm(src: u64, n: u64) -> u64 {
    let d : *u8 = (&NM as u64) as *u8
    let s : *u8 = src as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]  i = i + 1u64 }
    return n
}

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)

    bcopy((&P_DIR as u64),   ("./iii_carto_kat" as u64),               15u64)
    bcopy((&P_SUB as u64),   ("./iii_carto_kat/sub" as u64),           19u64)
    bcopy((&P_ALPHA as u64), ("./iii_carto_kat/alpha.iii" as u64),     25u64)
    bcopy((&P_BETA as u64),  ("./iii_carto_kat/beta.iii" as u64),      24u64)
    bcopy((&P_GAMMA as u64), ("./iii_carto_kat/gamma.iii" as u64),     25u64)
    bcopy((&P_DELTA as u64), ("./iii_carto_kat/sub/delta.iii" as u64), 29u64)

    bcopy((&C_ALPHA as u64), ("from \"beta.iii\" from \"gamma.iii\"" as u64), 32u64)
    bcopy((&C_BETA as u64),  ("from \"gamma.iii\"" as u64),                   16u64)
    bcopy((&C_GAMMA as u64), ("leaf" as u64),                                 4u64)
    bcopy((&C_DELTA as u64), ("from \"alpha.iii\"" as u64),                   16u64)

    if fs_mkdir(cap, (&P_DIR as u64)) != 0i32 { return 1u64 }
    if fs_mkdir(cap, (&P_SUB as u64)) != 0i32 { return 2u64 }
    if wfile(cap, (&P_ALPHA as u64), (&C_ALPHA as u64), 32u64) != 0i32 { return 3u64 }
    if wfile(cap, (&P_BETA as u64),  (&C_BETA as u64),  16u64) != 0i32 { return 4u64 }
    if wfile(cap, (&P_GAMMA as u64), (&C_GAMMA as u64), 4u64)  != 0i32 { return 5u64 }
    if wfile(cap, (&P_DELTA as u64), (&C_DELTA as u64), 16u64) != 0i32 { return 6u64 }

    let nc : u32 = scarto_map(cap, (&P_DIR as u64), 15u64)

    /* cleanup BEFORE assertions so no early return leaks residue */
    fs_delete(cap, (&P_ALPHA as u64))
    fs_delete(cap, (&P_BETA as u64))
    fs_delete(cap, (&P_GAMMA as u64))
    fs_delete(cap, (&P_DELTA as u64))
    fs_rmdir(cap, (&P_SUB as u64))
    fs_rmdir(cap, (&P_DIR as u64))

    if nc != 4u32 { return 10u64 }
    if satlas_node_count() != 4u32 { return 11u64 }
    if satlas_edge_count() != 4u32 { return 12u64 }

    setnm(("alpha" as u64), 5u64)
    let a : u32 = fid(5u64)
    setnm(("beta" as u64), 4u64)
    let b : u32 = fid(4u64)
    setnm(("gamma" as u64), 5u64)
    let g : u32 = fid(5u64)
    setnm(("delta" as u64), 5u64)
    let d : u32 = fid(5u64)
    if a == SENT { return 13u64 }
    if b == SENT { return 14u64 }
    if g == SENT { return 15u64 }
    if d == SENT { return 16u64 }

    if satlas_depends_direct(a, b) != 1u8 { return 17u64 }
    if satlas_depends_direct(a, g) != 1u8 { return 18u64 }
    if satlas_depends_direct(b, g) != 1u8 { return 19u64 }
    if satlas_depends_direct(d, a) != 1u8 { return 20u64 }
    if satlas_depends_direct(a, d) != 0u8 { return 21u64 }
    if satlas_reaches(d, g) != 1u8 { return 22u64 }

    return 99u64
}
