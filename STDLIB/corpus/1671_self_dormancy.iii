/* 1671_self_dormancy.iii -- III finds TRULY dead modules natively (the accurate dead signal).
 *
 * A production-graph leaf that a corpus test exercises is NOT dead.  This proves the accurate
 * detector: map a production tree, then MARK every module the corpus references, and only a
 * module with no production importer AND no corpus reference counts as dormant.
 *
 * Production ./iii_dorm_kat:   alpha->beta, gamma->beta, ghost (nothing imports it)
 * Corpus     ./iii_dorm_kat_c: t1 references alpha + gamma (marks them)
 * => beta has importers (not dormant); alpha/gamma are corpus-referenced (not dormant);
 *    ONLY ghost is truly dormant.  salens_count_dormant() must be exactly 1.
 *
 * Hermetic (builds + cleans its own trees).  rc 99 = pass; a distinct code marks each step.
 */
module corpus_1671

extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn fs_open(cap: u64, path: u64, mode: u32) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_close(h: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_write(h: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_delete(cap: u64, path: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_mkdir(cap: u64, path: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_rmdir(cap: u64, path: u64) -> i32 from "fs.iii"

extern @abi(c-msvc-x64) fn scarto_map(cap: u64, root_ptr: u64, root_len: u64) -> u32 from "self_cartographer.iii"
extern @abi(c-msvc-x64) fn scarto_mark_corpus(cap: u64, root_ptr: u64, root_len: u64) -> i32 from "self_cartographer.iii"

extern @abi(c-msvc-x64) fn satlas_node_count() -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_edge_count() -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_find(name_ptr: u64, len: u64) -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_fanin(n: u32) -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_is_marked(n: u32) -> u8 from "self_atlas.iii"

extern @abi(c-msvc-x64) fn salens_count_dormant() -> u32 from "self_atlas_lens.iii"

const SENT : u32 = 0xFFFFFFFFu32
const MWRITE : u32 = 2u32

var P_PD  : [u8; 32]
var P_CD  : [u8; 32]
var P_AL  : [u8; 40]
var P_BE  : [u8; 40]
var P_GA  : [u8; 40]
var P_GH  : [u8; 40]
var P_T1  : [u8; 40]
var C_DEP : [u8; 24]
var C_LF  : [u8; 8]
var C_T1  : [u8; 40]
var NM    : [u8; 16]

fn bcopy(dst: u64, src: u64, n: u64) -> u64 {
    let d : *u8 = dst as *u8
    let s : *u8 = src as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]  i = i + 1u64 }
    d[n] = 0u8
    return n
}

fn wfile(cap: u64, path: u64, content: u64, clen: u64) -> i32 {
    let h : u64 = fs_open(cap, path, MWRITE)
    if h == 0u64 { return -1i32 }
    let w : u64 = fs_write(h, content, clen)
    fs_close(h)
    if w != clen { return -2i32 }
    return 0i32
}

fn setnm(src: u64, n: u64) -> u64 {
    let d : *u8 = (&NM as u64) as *u8
    let s : *u8 = src as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]  i = i + 1u64 }
    return n
}

fn fid(len: u64) -> u32 { return satlas_find((&NM as u64), len) }

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)

    bcopy((&P_PD as u64), ("./iii_dorm_kat" as u64),         14u64)
    bcopy((&P_CD as u64), ("./iii_dorm_kat_c" as u64),       16u64)
    bcopy((&P_AL as u64), ("./iii_dorm_kat/alpha.iii" as u64), 24u64)
    bcopy((&P_BE as u64), ("./iii_dorm_kat/beta.iii" as u64),  23u64)
    bcopy((&P_GA as u64), ("./iii_dorm_kat/gamma.iii" as u64), 24u64)
    bcopy((&P_GH as u64), ("./iii_dorm_kat/ghost.iii" as u64), 24u64)
    bcopy((&P_T1 as u64), ("./iii_dorm_kat_c/t1.iii" as u64),  23u64)

    bcopy((&C_DEP as u64), ("from \"beta.iii\"" as u64), 16u64)
    bcopy((&C_LF as u64),  ("leaf" as u64),              4u64)
    bcopy((&C_T1 as u64),  ("from \"alpha.iii\" from \"gamma.iii\"" as u64), 33u64)

    if fs_mkdir(cap, (&P_PD as u64)) != 0i32 { return 1u64 }
    if fs_mkdir(cap, (&P_CD as u64)) != 0i32 { return 2u64 }
    if wfile(cap, (&P_AL as u64), (&C_DEP as u64), 16u64) != 0i32 { return 3u64 }
    if wfile(cap, (&P_BE as u64), (&C_LF as u64),  4u64)  != 0i32 { return 4u64 }
    if wfile(cap, (&P_GA as u64), (&C_DEP as u64), 16u64) != 0i32 { return 5u64 }
    if wfile(cap, (&P_GH as u64), (&C_LF as u64),  4u64)  != 0i32 { return 6u64 }
    if wfile(cap, (&P_T1 as u64), (&C_T1 as u64),  33u64) != 0i32 { return 7u64 }

    let nc : u32 = scarto_map(cap, (&P_PD as u64), 14u64)
    scarto_mark_corpus(cap, (&P_CD as u64), 16u64)

    fs_delete(cap, (&P_AL as u64))
    fs_delete(cap, (&P_BE as u64))
    fs_delete(cap, (&P_GA as u64))
    fs_delete(cap, (&P_GH as u64))
    fs_delete(cap, (&P_T1 as u64))
    fs_rmdir(cap, (&P_CD as u64))
    fs_rmdir(cap, (&P_PD as u64))

    if nc != 4u32 { return 10u64 }
    if satlas_node_count() != 4u32 { return 11u64 }
    if satlas_edge_count() != 2u32 { return 12u64 }

    setnm(("alpha" as u64), 5u64)
    let a : u32 = fid(5u64)
    setnm(("beta" as u64), 4u64)
    let b : u32 = fid(4u64)
    setnm(("gamma" as u64), 5u64)
    let g : u32 = fid(5u64)
    setnm(("ghost" as u64), 5u64)
    let gh : u32 = fid(5u64)
    if a == SENT { return 13u64 }
    if gh == SENT { return 14u64 }

    if salens_count_dormant() != 1u32 { return 15u64 }
    if satlas_is_marked(a) != 1u8 { return 16u64 }
    if satlas_is_marked(g) != 1u8 { return 17u64 }
    if satlas_is_marked(gh) != 0u8 { return 18u64 }
    if satlas_fanin(gh) != 0u32 { return 19u64 }
    if satlas_fanin(b) != 2u32 { return 20u64 }

    return 99u64
}
