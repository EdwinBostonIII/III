/* 1674_self_emit.iii -- III emits its OWN self-model fixture, in III (omnia::self_emit).
 *
 * Build a known graph, have III render a complete self_atlas_data.iii via satlas_emit_data,
 * read it back, and verify it is well-formed: it begins "module omnia_self_atlas_data" and
 * contains "satlas_data_load".  (The emitted source's COMPILABILITY + load-equivalence is the
 * job of the regeneration step; here we prove the native renderer runs and shapes the file.)
 * Hermetic (writes + cleans its own file).  rc 99 = pass; a distinct code marks each step.
 */
module corpus_1674

extern @abi(c-msvc-x64) fn satlas_reset() -> i32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_link(fp: u64, fl: u64, tp: u64, tl: u64) -> i32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_emit_data(cap: u64, path: u64) -> i32 from "self_emit.iii"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn fs_open(cap: u64, path: u64, mode: u32) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_read(h: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_close(h: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_delete(cap: u64, path: u64) -> i32 from "fs.iii"

const MREAD : u32 = 1u32

var P_OUT : [u8; 32]
var RB    : [u8; 8192]

fn bcopy(dst: u64, src: u64, n: u64) -> u64 {
    let d : *u8 = dst as *u8
    let s : *u8 = src as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]  i = i + 1u64 }
    d[n] = 0u8
    return n
}

/* 1 if needle[0..nlen) occurs in hay[0..haylen). */
fn contains(hay: u64, haylen: u64, needle: u64, nlen: u64) -> u8 {
    if nlen > haylen { return 0u8 }
    let h : *u8 = hay as *u8
    let nd : *u8 = needle as *u8
    let mut i : u64 = 0u64
    let lim : u64 = haylen - nlen
    let mut hit : u8 = 0u8
    while i <= lim {
        let mut k : u64 = 0u64
        let mut ok : u8 = 1u8
        while k < nlen {
            if h[i + k] != nd[k] { ok = 0u8 }
            k = k + 1u64
        }
        if ok == 1u8 { hit = 1u8 }
        i = i + 1u64
    }
    return hit
}

fn main() -> u64 {
    satlas_reset()
    satlas_link(("alpha" as u64), 5u64, ("beta" as u64), 4u64)
    satlas_link(("alpha" as u64), 5u64, ("gamma" as u64), 5u64)
    satlas_link(("beta" as u64), 4u64, ("gamma" as u64), 5u64)
    satlas_link(("delta" as u64), 5u64, ("alpha" as u64), 5u64)

    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)
    bcopy((&P_OUT as u64), ("./iii_emit_kat.iii" as u64), 18u64)
    if satlas_emit_data(cap, (&P_OUT as u64)) != 0i32 { return 1u64 }

    let h : u64 = fs_open(cap, (&P_OUT as u64), MREAD)
    if h == 0u64 { return 2u64 }
    let got : u64 = fs_read(h, (&RB as u64), 8192u64)
    fs_close(h)
    fs_delete(cap, (&P_OUT as u64))

    if got < 400u64 { return 3u64 }
    if contains((&RB as u64), got, ("module omnia_self_atlas_data" as u64), 28u64) != 1u8 { return 4u64 }
    if contains((&RB as u64), got, ("satlas_data_load" as u64), 16u64) != 1u8 { return 5u64 }
    if contains((&RB as u64), got, ("satlas_intern(" as u64), 14u64) != 1u8 { return 6u64 }
    if contains((&RB as u64), got, ("satlas_data_expect_emergence" as u64), 28u64) != 1u8 { return 7u64 }

    return 99u64
}
