/* STDLIB/corpus/1703_cegar_refine.iii
 *
 * Falsifier KAT for numera::cegar_refine (III-PHASE3-WALLS, Campaign I, organ 3) -- CEGAR over the sound
 * interval lattice.  99 = every arm holds; 1..14 = the failing arm.  Independent oracle: the concrete
 * disjoint reachable set [0,2] U [8,10] and interval_lattice's lattice order (il_leq) -- a stub with an
 * unsound hull, or one that refines a real counterexample away, is caught.
 *
 *   (1) the coarse hull is the convex hull [0,10] of the disjoint pieces.
 *   (2) SOUNDNESS (biting): every piece is contained in the hull (il_leq) -- abstract absent => concrete absent.
 *   (3) CEGAR PROGRESS (biting): target 5 (in the hull gap) is NOT provable by the coarse hull but IS by
 *       refinement -- precision recovered exactly where a single interval loses it.
 *   (4) REAL CE PRESERVED (biting): target 1 (genuinely reachable, in [0,2]) is provable-absent by NEITHER
 *       coarse NOR refined -- refinement does not spuriously eliminate a real counterexample.
 *   (5) a target outside the hull (20) is proved absent by the coarse abstraction alone (no refinement).
 */
module corpus_1703_cegar_refine

extern @abi(c-msvc-x64) fn cr_init() -> i32 from "cegar_refine.iii"
extern @abi(c-msvc-x64) fn cr_hull_lo() -> u32 from "cegar_refine.iii"
extern @abi(c-msvc-x64) fn cr_hull_hi() -> u32 from "cegar_refine.iii"
extern @abi(c-msvc-x64) fn cr_sound() -> u8 from "cegar_refine.iii"
extern @abi(c-msvc-x64) fn cr_coarse_proves_absent(target: u32) -> u8 from "cegar_refine.iii"
extern @abi(c-msvc-x64) fn cr_refined_proves_absent(target: u32) -> u8 from "cegar_refine.iii"
extern @abi(c-msvc-x64) fn cr_spurious(target: u32) -> u8 from "cegar_refine.iii"
extern @abi(c-msvc-x64) fn cr_prove_absent(target: u32) -> u8 from "cegar_refine.iii"

fn main() -> u64 {
    cr_init()

    /* (1) coarse hull = convex hull [0,10] */
    if cr_hull_lo() != 0u32 { return 1u64 }
    if cr_hull_hi() != 10u32 { return 2u64 }

    /* (2) SOUNDNESS (biting): every piece <= hull (il_leq) */
    if cr_sound() != 1u8 { return 3u64 }

    /* (3) CEGAR PROGRESS (biting): 5 is in the hull gap -- coarse stuck, refinement proves */
    if cr_coarse_proves_absent(5u32) != 0u8 { return 4u64 }
    if cr_refined_proves_absent(5u32) != 1u8 { return 5u64 }
    if cr_spurious(5u32) != 1u8 { return 6u64 }
    if cr_prove_absent(5u32) != 1u8 { return 7u64 }

    /* (4) REAL CE PRESERVED (biting): 1 is genuinely reachable -- neither coarse nor refined proves absent */
    if cr_coarse_proves_absent(1u32) != 0u8 { return 8u64 }
    if cr_refined_proves_absent(1u32) != 0u8 { return 9u64 }
    if cr_spurious(1u32) != 0u8 { return 10u64 }
    if cr_prove_absent(1u32) != 0u8 { return 11u64 }

    /* (5) outside the hull -> coarse alone proves absent */
    if cr_coarse_proves_absent(20u32) != 1u8 { return 12u64 }
    if cr_prove_absent(20u32) != 1u8 { return 13u64 }

    /* determinism */
    if cr_hull_hi() != 10u32 { return 14u64 }

    return 99u64
}
