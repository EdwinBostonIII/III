/* STDLIB/corpus/1707_proof_jit.iii
 *
 * Falsifier KAT for numera::proof_jit (III-PHASE3-WALLS, Campaign II, organ 2) -- the verdict-identical
 * kernel JIT.  99 = every arm holds; 1..8 = the failing arm.  Independent oracles: the kernel's tc_conv /
 * tc_eval (a verdict-changing rewrite is refused and diverges) and the real ISA emitter.
 *
 *   (1) the JIT rewrite x*8 -> x<<3 is KERNEL-CERTIFIED verdict-identical (tc_conv == 1).
 *   (2) BITING: a WRONG rewrite x*8 -> x<<2 is REFUSED by the kernel (tc_conv == 0) -- the JIT cannot
 *       substitute a non-equivalent op.
 *   (3) value-differential: the optimized op computes the same value as the reference at concrete inputs;
 *       (4) BITING: the wrong rewrite DIVERGES in value.
 *   (5) the kernel-ISA emitter produces a non-empty fragment, deterministically (byte-identical).
 */
module corpus_1707_proof_jit

extern @abi(c-msvc-x64) fn pj_opt_certified() -> u8 from "proof_jit.iii"
extern @abi(c-msvc-x64) fn pj_bad_rejected() -> u8 from "proof_jit.iii"
extern @abi(c-msvc-x64) fn pj_value_identical(v: u64) -> u8 from "proof_jit.iii"
extern @abi(c-msvc-x64) fn pj_bad_value_diverges(v: u64) -> u8 from "proof_jit.iii"
extern @abi(c-msvc-x64) fn pj_emit_deterministic(kind: u8) -> u8 from "proof_jit.iii"
extern @abi(c-msvc-x64) fn pj_fragment_count() -> u32 from "proof_jit.iii"

fn main() -> u64 {
    /* (1) the rewrite is kernel-certified verdict-identical */
    if pj_opt_certified() != 1u8 { return 1u64 }

    /* (2) BITING: a wrong rewrite is refused by the kernel */
    if pj_bad_rejected() != 1u8 { return 2u64 }

    /* (3) value-identical at concrete inputs */
    if pj_value_identical(1u64) != 1u8 { return 3u64 }
    if pj_value_identical(7u64) != 1u8 { return 4u64 }
    if pj_value_identical(255u64) != 1u8 { return 5u64 }

    /* (4) BITING: the wrong rewrite diverges in value */
    if pj_bad_value_diverges(1u64) != 1u8 { return 6u64 }

    /* (5) the ISA emitter is real and deterministic */
    if pj_fragment_count() == 0u32 { return 7u64 }
    if pj_emit_deterministic(0u8) != 1u8 { return 8u64 }

    return 99u64
}
