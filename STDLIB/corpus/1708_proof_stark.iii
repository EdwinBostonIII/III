/* STDLIB/corpus/1708_proof_stark.iii
 *
 * Falsifier KAT for numera::proof_stark (III-PHASE3-WALLS, Campaign II, organ 3) -- a succinct proof of
 * proof-checking.  99 = every arm holds; 1..9 = the failing arm.  Independent oracles: zk_air's STARK+FRI
 * (a valid trace ACCEPTs, proof tampers REJECT) and the kernel's tc_eval (the certified arithmetic).
 *
 *   (1) the underlying STARK is sound (zk_air_stark_selftest: valid ACCEPTs, four proof tampers REJECT).
 *   (2) a VALID kernel-relevant trace is certified (ACCEPT) through the full STARK+FRI.
 *   (3) BITING: the AIR has teeth -- constraints HOLD on the honest trace, are VIOLATED on a corrupted
 *       cell, so a false computation cannot be the certified statement.
 *   (4) BITING: the STARK certifies the SAME arithmetic the kernel checks -- the trace's first product
 *       equals the kernel's BV product (2*3=6); the succinct certificate stands in for re-running the kernel.
 *   (5) the succinct certificate is produced, non-zero, and deterministic.
 */
module corpus_1708_proof_stark

extern @abi(c-msvc-x64) fn ps_prove_valid() -> u64 from "proof_stark.iii"
extern @abi(c-msvc-x64) fn ps_constraints_valid() -> u8 from "proof_stark.iii"
extern @abi(c-msvc-x64) fn ps_constraints_invalid() -> u8 from "proof_stark.iii"
extern @abi(c-msvc-x64) fn ps_cert(out32: u64) -> i32 from "proof_stark.iii"
extern @abi(c-msvc-x64) fn ps_trace_product() -> u32 from "proof_stark.iii"
extern @abi(c-msvc-x64) fn ps_kernel_product() -> u32 from "proof_stark.iii"
extern @abi(c-msvc-x64) fn ps_stark_sound() -> u64 from "proof_stark.iii"
extern @abi(c-msvc-x64) fn cad_is_zero(a: *u8) -> u8 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_eq(a: *u8, b: *u8) -> u8 from "cad.iii"

var SEAL1 : [u8; 32]
var SEAL2 : [u8; 32]

fn main() -> u64 {
    /* (1) the underlying STARK is sound */
    if ps_stark_sound() != 99u64 { return 1u64 }

    /* (2) a valid kernel-relevant trace is certified */
    if ps_prove_valid() != 0u64 { return 2u64 }

    /* (3) BITING: the AIR has teeth */
    if ps_constraints_valid() != 1u8 { return 3u64 }
    if ps_constraints_invalid() != 0u8 { return 4u64 }

    /* (4) BITING: the certified arithmetic equals the kernel's */
    if ps_trace_product() != ps_kernel_product() { return 5u64 }
    if ps_trace_product() != 6u32 { return 6u64 }

    /* (5) the succinct certificate is produced, non-zero, deterministic */
    let z1 : i32 = ps_cert((&SEAL1 as u64))
    if z1 != 0i32 { return 7u64 }
    if cad_is_zero((&SEAL1 as u64) as *u8) != 0u8 { return 8u64 }
    ps_cert((&SEAL2 as u64))
    if cad_eq((&SEAL1 as u64) as *u8, (&SEAL2 as u64) as *u8) != 1u8 { return 9u64 }

    return 99u64
}
