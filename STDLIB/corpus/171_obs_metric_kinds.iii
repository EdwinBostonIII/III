/* Phase 14c Step 0140 verification: obs_metric counter/gauge/histogram. */
module corpus_171

extern @abi(c-msvc-x64) fn obs_metric_clear_all() -> i32 from "obs_metric.iii"
extern @abi(c-msvc-x64) fn obs_metric_register(slot: u32, kind: u32) -> i32 from "obs_metric.iii"
extern @abi(c-msvc-x64) fn obs_metric_kind(slot: u32) -> u32 from "obs_metric.iii"
extern @abi(c-msvc-x64) fn obs_metric_inc_counter(slot: u32, delta: u64) -> i32 from "obs_metric.iii"
extern @abi(c-msvc-x64) fn obs_metric_set_gauge(slot: u32, v: u64) -> i32 from "obs_metric.iii"
extern @abi(c-msvc-x64) fn obs_metric_observe_histogram(slot: u32, v: u64) -> i32 from "obs_metric.iii"
extern @abi(c-msvc-x64) fn obs_metric_value(slot: u32) -> u64 from "obs_metric.iii"
extern @abi(c-msvc-x64) fn obs_metric_secondary(slot: u32) -> u64 from "obs_metric.iii"
extern @abi(c-msvc-x64) fn obs_metric_count() -> u32 from "obs_metric.iii"

fn main() -> u64 {
    obs_metric_clear_all()
    if obs_metric_count() != 0u32 { return 1u64 }

    /* Register one of each kind. */
    if obs_metric_register(0u32, 1u32) != 0i32 { return 2u64 }   /* counter */
    if obs_metric_register(1u32, 2u32) != 0i32 { return 3u64 }   /* gauge */
    if obs_metric_register(2u32, 3u32) != 0i32 { return 4u64 }   /* histogram */
    /* Reject bad kind. */
    if obs_metric_register(3u32, 0u32) != -2i32 { return 5u64 }
    if obs_metric_register(3u32, 9u32) != -2i32 { return 6u64 }
    /* Reject bad slot. */
    if obs_metric_register(99u32, 1u32) != -1i32 { return 7u64 }

    if obs_metric_count() != 3u32 { return 8u64 }
    if obs_metric_kind(0u32) != 1u32 { return 9u64 }
    if obs_metric_kind(1u32) != 2u32 { return 10u64 }
    if obs_metric_kind(2u32) != 3u32 { return 11u64 }

    /* Counter: monotonic increment. */
    obs_metric_inc_counter(0u32, 5u64)
    obs_metric_inc_counter(0u32, 7u64)
    obs_metric_inc_counter(0u32, 1u64)
    if obs_metric_value(0u32) != 13u64 { return 12u64 }
    if obs_metric_secondary(0u32) != 3u64 { return 13u64 }

    /* Counter rejects gauge/histogram updates. */
    if obs_metric_set_gauge(0u32, 100u64) != -2i32 { return 14u64 }
    if obs_metric_observe_histogram(0u32, 100u64) != -2i32 { return 15u64 }

    /* Gauge: last-write-wins. */
    obs_metric_set_gauge(1u32, 50u64)
    obs_metric_set_gauge(1u32, 75u64)
    obs_metric_set_gauge(1u32, 60u64)
    if obs_metric_value(1u32) != 60u64 { return 16u64 }
    if obs_metric_secondary(1u32) != 3u64 { return 17u64 }

    /* Gauge rejects counter/histogram updates. */
    if obs_metric_inc_counter(1u32, 1u64) != -2i32 { return 18u64 }

    /* Histogram: sum + count. */
    obs_metric_observe_histogram(2u32, 100u64)
    obs_metric_observe_histogram(2u32, 200u64)
    obs_metric_observe_histogram(2u32, 50u64)
    obs_metric_observe_histogram(2u32, 250u64)
    if obs_metric_value(2u32) != 600u64 { return 19u64 }
    if obs_metric_secondary(2u32) != 4u64 { return 20u64 }

    return 99u64
}
