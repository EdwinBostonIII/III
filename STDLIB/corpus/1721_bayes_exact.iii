/* STDLIB/corpus/1721_bayes_exact.iii
 *
 * Falsifier KAT for numera::bayes_exact (III-PHASE4-PROBABILITY, Layer 4) -- exact Bayesian inference.
 * 99 = every arm holds; 1..8 = the failing arm.  Oracle: exact integer arithmetic + posterior normalization.
 *
 *   prior (1,1), likelihood (3,1) -> posterior P(H0|E) = 3/4; the posteriors sum to 1 exactly.
 *   a different prior (1,3) shifts the posterior EXACTLY to 1/2 (biting: a wrong update diverges).
 */
module corpus_1721_bayes_exact

extern @abi(c-msvc-x64) fn bx_set(a: u64, b: u64, l0: u64, l1: u64) -> i32 from "bayes_exact.iii"
extern @abi(c-msvc-x64) fn bx_posterior_num(i: u32) -> u64 from "bayes_exact.iii"
extern @abi(c-msvc-x64) fn bx_marginal() -> u64 from "bayes_exact.iii"
extern @abi(c-msvc-x64) fn bx_normalized() -> u8 from "bayes_exact.iii"

fn main() -> u64 {
    bx_set(1u64, 1u64, 3u64, 1u64)
    if bx_posterior_num(0u32) != 3u64 { return 1u64 }
    if bx_posterior_num(1u32) != 1u64 { return 2u64 }
    if bx_marginal() != 4u64 { return 3u64 }
    if bx_normalized() != 1u8 { return 4u64 }                                   /* posteriors sum to 1 */
    if (bx_posterior_num(0u32) * 4u64) != (3u64 * bx_marginal()) { return 5u64 }  /* P(H0|E) = 3/4 */

    /* a different prior shifts the posterior exactly to 1/2 */
    bx_set(1u64, 3u64, 3u64, 1u64)
    if bx_posterior_num(0u32) != 3u64 { return 6u64 }
    if bx_marginal() != 6u64 { return 7u64 }
    if (bx_posterior_num(0u32) * 2u64) != (1u64 * bx_marginal()) { return 8u64 }  /* P(H0|E) = 1/2 */

    return 99u64
}
