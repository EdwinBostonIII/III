/* KAT for numera::pctl (Phase IV Layer 6) -- probabilistic model checking. 99=pass; 1..5=failing arm.
 * chain p=1(fail), q=2(goal) -> P[reach goal]=2/3. PCTL P>=thr decided exactly. */
module corpus_1727_pctl
extern @abi(c-msvc-x64) fn pctl_set(p: u64, q: u64) -> i32 from "pctl.iii"
extern @abi(c-msvc-x64) fn pctl_reach_num() -> u64 from "pctl.iii"
extern @abi(c-msvc-x64) fn pctl_reach_den() -> u64 from "pctl.iii"
extern @abi(c-msvc-x64) fn pctl_satisfies_geq(tn: u64, td: u64) -> u8 from "pctl.iii"
fn main() -> u64 {
    pctl_set(1u64, 2u64)
    if pctl_reach_num() != 2u64 { return 1u64 }
    if pctl_reach_den() != 3u64 { return 2u64 }
    if pctl_satisfies_geq(1u64, 2u64) != 1u8 { return 3u64 }   /* 2/3 >= 1/2 */
    if pctl_satisfies_geq(3u64, 4u64) != 0u8 { return 4u64 }   /* 2/3 >= 3/4 FALSE (biting) */
    if pctl_satisfies_geq(2u64, 3u64) != 1u8 { return 5u64 }   /* 2/3 >= 2/3 boundary */
    return 99u64
}
