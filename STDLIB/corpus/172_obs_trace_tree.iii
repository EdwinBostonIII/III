/* Phase 14c Step 0141 verification: obs_trace span tree + duration. */
module corpus_172

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn obs_trace_clear_all() -> i32 from "obs_trace.iii"
extern @abi(c-msvc-x64) fn obs_trace_span_begin(parent_id: u64, trace_id: u64, name_hash_32_ptr: u64) -> u64 from "obs_trace.iii"
extern @abi(c-msvc-x64) fn obs_trace_span_end(span_id: u64) -> i32 from "obs_trace.iii"
extern @abi(c-msvc-x64) fn obs_trace_span_parent(span_id: u64) -> u64 from "obs_trace.iii"
extern @abi(c-msvc-x64) fn obs_trace_span_trace_id(span_id: u64) -> u64 from "obs_trace.iii"
extern @abi(c-msvc-x64) fn obs_trace_span_start_seq(span_id: u64) -> u64 from "obs_trace.iii"
extern @abi(c-msvc-x64) fn obs_trace_span_end_seq(span_id: u64) -> u64 from "obs_trace.iii"
extern @abi(c-msvc-x64) fn obs_trace_span_duration(span_id: u64) -> u64 from "obs_trace.iii"
extern @abi(c-msvc-x64) fn obs_trace_span_name_byte(span_id: u64, i: u32) -> u32 from "obs_trace.iii"
extern @abi(c-msvc-x64) fn obs_trace_count() -> u32 from "obs_trace.iii"

fn main() -> u64 {
    obs_trace_clear_all()
    if obs_trace_count() != 0u32 { return 1u64 }

    let nh : *u8 = malloc(32u64)
    let mut i : u64 = 0u64
    while i < 32u64 { nh[i] = (0x40u64 + i) as u8; i = i + 1u64 }

    /* Reject null name_hash. */
    if obs_trace_span_begin(0u64, 0xABCDu64, 0u64) != 0u64 { return 2u64 }

    /* Build root span. */
    let root_id : u64 = obs_trace_span_begin(0u64, 0xABCDu64, nh as u64)
    if root_id == 0u64 { return 3u64 }
    if obs_trace_span_parent(root_id) != 0u64 { return 4u64 }
    if obs_trace_span_trace_id(root_id) != 0xABCDu64 { return 5u64 }
    if obs_trace_span_start_seq(root_id) != 0u64 { return 6u64 }
    if obs_trace_span_name_byte(root_id, 0u32) != 0x40u32 { return 7u64 }

    /* Build child span. */
    let child_id : u64 = obs_trace_span_begin(root_id, 0xABCDu64, nh as u64)
    if child_id == 0u64 { return 8u64 }
    if obs_trace_span_parent(child_id) != root_id { return 9u64 }
    if obs_trace_span_start_seq(child_id) != 1u64 { return 10u64 }
    /* Duration is 0 while end_seq is unset. */
    if obs_trace_span_duration(child_id) != 0u64 { return 11u64 }

    /* End child, then root. */
    if obs_trace_span_end(child_id) != 0i32 { return 12u64 }
    if obs_trace_span_end_seq(child_id) != 2u64 { return 13u64 }
    if obs_trace_span_duration(child_id) != 1u64 { return 14u64 }

    /* Double-end refuses. */
    if obs_trace_span_end(child_id) != -4i32 { return 15u64 }

    if obs_trace_span_end(root_id) != 0i32 { return 16u64 }
    if obs_trace_span_duration(root_id) != 3u64 { return 17u64 }   /* 3 - 0 */

    if obs_trace_count() != 2u32 { return 18u64 }

    /* Bad span_id. */
    if obs_trace_span_parent(0u64) != 0u64 { return 19u64 }
    if obs_trace_span_end(99999u64) != -1i32 { return 20u64 }

    free(nh)
    return 99u64
}
