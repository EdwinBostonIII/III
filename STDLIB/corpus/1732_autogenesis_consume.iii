/* STDLIB/corpus/1732_autogenesis_consume.iii
 *
 * Falsifier KAT: THE AUTOGENESIS LOOP CONSUMES THE PHASE III/IV ORGANS in its LIVE body.
 * 99 = every arm holds; 1..13 = the failing arm.  This exercises the UNCHANGED-signature ag_cycle/ag_commit
 * path (as corpus 1406/1409 do) and proves its behaviour now depends on the consumed organs:
 *
 *   (1) lemma_forge CONSUMED: the real cycle grew the kernel-certified commons (tg_count rose).
 *   (2) PROPOSER MARKET CONSUMED: the real cycle ran pm_step -- bayes_search allocated the certify budget
 *       and proof_replay_cache served checks (ag_certified > 0, ag_cache_hits > 0, a valid lead proposer).
 *   (3,4) the risk metric (deterministic, measure_status-typed PROVISIONAL) reflects a flagged candidate.
 *   (5) BITING: with the candidate flagged high-risk, the FULLY AUTHORIZED commit is REFUSED.
 *   (6) clearing the risk lets the authorized commit proceed.
 *
 * Independent oracle: the commit authorization is fully present (cap_commit), so only the new probabilistic
 * risk gate can explain the refusal; and the market observables are zero unless the live cycle ran it.
 */
module corpus_1732_autogenesis_consume

extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn ag_cycle(cap: u64) -> i32 from "autogenesis.iii"
extern @abi(c-msvc-x64) fn ag_commit(cap: u64, sig: u64) -> i32 from "autogenesis.iii"
extern @abi(c-msvc-x64) fn ag_inflight() -> u32 from "autogenesis.iii"
extern @abi(c-msvc-x64) fn ag_valid() -> u32 from "autogenesis.iii"
extern @abi(c-msvc-x64) fn ag_risk() -> u64 from "autogenesis.iii"
extern @abi(c-msvc-x64) fn ag_force_risk(r: u64) -> i32 from "autogenesis.iii"
extern @abi(c-msvc-x64) fn ag_risk_acceptable() -> u8 from "autogenesis.iii"
extern @abi(c-msvc-x64) fn ag_certified() -> u64 from "autogenesis.iii"
extern @abi(c-msvc-x64) fn ag_cache_hits() -> u64 from "autogenesis.iii"
extern @abi(c-msvc-x64) fn ag_lead_proposer() -> u32 from "autogenesis.iii"
extern @abi(c-msvc-x64) fn tg_count() -> u64 from "theorem_grow.iii"

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap_auto : u64 = cap_attenuate(env, 0x80000u64, 0u64)      /* AUTOGENESIS */
    let cap_commit : u64 = cap_attenuate(env, 0x180000u64, 0u64)   /* AUTOGENESIS | COMMIT (full authority) */

    let before : u64 = tg_count()
    if ag_cycle(cap_auto) != 0i32 { return 1u64 }
    /* (1) lemma_forge consumed: the live cycle grew the commons */
    if tg_count() <= before { return 2u64 }
    /* (2) proposer market consumed in the LIVE cycle: bayes allocated + cache served */
    if ag_certified() == 0u64 { return 3u64 }
    if ag_cache_hits() == 0u64 { return 4u64 }
    if ag_lead_proposer() > 1u32 { return 5u64 }
    /* the low-risk cycle validates (the risk gate is transparent for a safe change) */
    if ag_valid() != 99u32 { return 6u64 }
    if ag_risk_acceptable() != 1u8 { return 7u64 }

    /* (3) flag the candidate high-risk; ag_risk reflects it */
    ag_force_risk(1000u64)
    if ag_risk() < 1000u64 { return 8u64 }
    /* (4) the measure_status-typed risk is now unacceptable */
    if ag_risk_acceptable() != 0u8 { return 9u64 }
    /* (5) BITING: the FULLY AUTHORIZED commit is refused (AG_E_INVALID = -6), not for lack of authority */
    if ag_commit(cap_commit, 0u64) != -6i32 { return 10u64 }
    if ag_inflight() != 1u32 { return 11u64 }

    /* (6) clear the risk -> the authorized commit proceeds */
    ag_force_risk(0u64)
    if ag_commit(cap_commit, 0u64) != 0i32 { return 12u64 }
    if ag_inflight() != 0u32 { return 13u64 }
    return 99u64
}
