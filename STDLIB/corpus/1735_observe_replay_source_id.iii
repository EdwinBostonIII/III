/* STDLIB/corpus/1735_observe_replay_source_id.iii
 *
 * sanctus.observe: replay SEQUENCE integrity (W3400 hardening, part 2).
 *
 * The replay branch already rejects a tampered payload (cad re-hash vs recorded out_commit, corpus 1630).
 * But it ignored the source_id entirely -- a payload re-injected under the WRONG source replayed as if it
 * came from the right one.  Now obs_observe fetches the recorded producer (wh_get_producer) and rejects if
 * its low 4 bytes (the source_id) diverge from the caller's.  Replay now binds WHAT and WHO.  99 = all arms.
 */
module corpus_1735_observe_replay_source_id

extern @abi(c-msvc-x64) fn obs_init() -> i32 from "observe.iii"
extern @abi(c-msvc-x64) fn obs_set_mode(m: u8) -> i32 from "observe.iii"
extern @abi(c-msvc-x64) fn obs_observe(source_id: u32, live_ptr: u64, len: u32, out_ptr: u64) -> u64 from "observe.iii"

var VAL : [u8; 16]
var OUT : [u8; 16]

fn main() -> u64 {
    obs_init()
    let mut i : u64 = 0u64
    while i < 16u64 { VAL[i] = ((i + 0xA0u64) & 0xFFu64) as u8  OUT[i] = 0u8  i = i + 1u64 }

    /* LIVE: observe under source_id 7 */
    let h : u64 = obs_observe(7u32, (&VAL) as u64, 16u32, (&OUT) as u64)
    if h == 0xFFFFFFFFFFFFFFFFu64 { return 1u64 }

    /* faithful REPLAY with the SAME source_id 7 -> passes and re-injects the bytes */
    obs_set_mode(1u8)
    i = 0u64
    while i < 16u64 { OUT[i] = 0u8  i = i + 1u64 }
    let h2 : u64 = obs_observe(7u32, (&VAL) as u64, 16u32, (&OUT) as u64)
    if h2 == 0xFFFFFFFFFFFFFFFFu64 { return 2u64 }
    i = 0u64
    while i < 16u64 { if OUT[i] != VAL[i] { return 3u64 }  i = i + 1u64 }

    /* BITING: replay the SAME (hash-valid) bytes under a DIFFERENT source_id (9).  obs_set_mode resets the
     * cursor to 0, so the only thing that has changed vs the faithful arm is the source_id -> the payload
     * content-addresses correctly but the producer mismatches -> SEQUENCE DIVERGENCE -> SENTINEL. */
    obs_set_mode(1u8)
    let h3 : u64 = obs_observe(9u32, (&VAL) as u64, 16u32, (&OUT) as u64)
    if h3 != 0xFFFFFFFFFFFFFFFFu64 { return 4u64 }

    /* and the correct source_id still replays after the rejection (cursor reset, gate transparent) */
    obs_set_mode(1u8)
    let h4 : u64 = obs_observe(7u32, (&VAL) as u64, 16u32, (&OUT) as u64)
    if h4 == 0xFFFFFFFFFFFFFFFFu64 { return 5u64 }

    return 99u64
}
