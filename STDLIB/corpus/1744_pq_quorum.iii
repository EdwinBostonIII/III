/* STDLIB/corpus/1744_pq_quorum.iii -- POST-QUANTUM FEDERATION QUORUM CERTIFICATES.
 *
 * aether/pq_quorum gives the federation a BFT quorum certificate whose votes are ML-DSA (FIPS-204)
 * signatures instead of Ed25519, so the planetary seal survives a quantum adversary that could forge the
 * classical votes.  4-peer federation (f=1, BFT threshold 2f+1 = 3).  99 = all arms; 1..16 = the arm.
 *
 *   keygen 4 ML-DSA peers; 3 cast valid votes -> the quorum (2f+1) is reached.
 *   BITING: tampering one vote drops the valid count below threshold -> no quorum (forged vote rejected).
 *   2 votes on a fresh block is below threshold; the 3rd vote reaches it.
 */
module corpus_1744_pq_quorum

extern @abi(c-msvc-x64) fn pqq_keygen(i: u64, seed_byte: u8) -> i32 from "pq_quorum.iii"
extern @abi(c-msvc-x64) fn pqq_set_block(block_mhash: u64, view: u64) -> i32 from "pq_quorum.iii"
extern @abi(c-msvc-x64) fn pqq_vote(i: u64) -> i32 from "pq_quorum.iii"
extern @abi(c-msvc-x64) fn pqq_valid_count(n_peers: u64) -> u64 from "pq_quorum.iii"
extern @abi(c-msvc-x64) fn pqq_verify(n_peers: u64, threshold: u64) -> u8 from "pq_quorum.iii"
extern @abi(c-msvc-x64) fn pqq_tamper(i: u64) -> i32 from "pq_quorum.iii"

var MHASH : [u8; 32]

fn main() -> u64 {
    if pqq_keygen(0u64, 0x10u8) != 0i32 { return 1u64 }
    if pqq_keygen(1u64, 0x20u8) != 0i32 { return 2u64 }
    if pqq_keygen(2u64, 0x30u8) != 0i32 { return 3u64 }
    if pqq_keygen(3u64, 0x40u8) != 0i32 { return 4u64 }

    let mut i : u64 = 0u64
    while i < 32u64 { MHASH[i] = ((i * 5u64 + 1u64) & 0xFFu64) as u8  i = i + 1u64 }
    pqq_set_block((&MHASH as u64), 7u64)

    /* 3 valid ML-DSA votes -> the BFT quorum (2f+1 = 3) is reached */
    if pqq_vote(0u64) != 0i32 { return 5u64 }
    if pqq_vote(1u64) != 0i32 { return 6u64 }
    if pqq_vote(2u64) != 0i32 { return 7u64 }
    if pqq_valid_count(4u64) != 3u64 { return 8u64 }
    if pqq_verify(4u64, 3u64) != 1u8 { return 9u64 }

    /* BITING: tamper peer 2's signature -> only 2 valid -> quorum NOT reached (the forged vote is rejected) */
    pqq_tamper(2u64)
    if pqq_valid_count(4u64) != 2u64 { return 10u64 }
    if pqq_verify(4u64, 3u64) != 0u8 { return 11u64 }

    /* a fresh block with only 2 votes is below the BFT threshold -> no quorum */
    pqq_set_block((&MHASH as u64), 8u64)
    if pqq_vote(0u64) != 0i32 { return 12u64 }
    if pqq_vote(1u64) != 0i32 { return 13u64 }
    if pqq_verify(4u64, 3u64) != 0u8 { return 14u64 }

    /* the 3rd valid vote reaches quorum again */
    if pqq_vote(2u64) != 0i32 { return 15u64 }
    if pqq_verify(4u64, 3u64) != 1u8 { return 16u64 }

    return 99u64
}
