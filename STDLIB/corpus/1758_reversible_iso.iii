/* STDLIB/corpus/1758_reversible_iso.iii -- THE REVERSIBLE-COMPUTATION ISOMORPHISM (the provable reach of III).
 *
 * Is III's logic isomorphic to physical reality?  The honest, proven answer: it is a PERFECT model of the
 * discrete-reversible computation class (the continuous remains a typed approximation -- the calculus wall,
 * not claimed).  Proven on the existing bv_bits judge via the Toffoli/CCNOT gate, the universal reversible
 * primitive.  99 = all arms.
 *
 *   (1) Toffoli is SELF-INVERSE: (a,b,c) -> (a,b,c^(a&b)) applied twice returns c -- nothing is erased
 *       (Landauer: ~zero-heat), and III's algebra reverses it exactly.  III CONTAINS reversible computation.
 *   (2) UNIVERSAL: Toffoli(a,b,1) third output == NAND(a,b), and NAND is functionally complete.
 *   (3) BITING: the Toffoli is NOT the identity -- one application flips c when a&b=1 (does real work).
 */
module corpus_1758_reversible_iso

extern @abi(c-msvc-x64) fn pw_toffoli_self_inverse() -> u8 from "primweb.iii"
extern @abi(c-msvc-x64) fn pw_toffoli_is_nand() -> u8 from "primweb.iii"
extern @abi(c-msvc-x64) fn pw_toffoli_nontrivial() -> u8 from "primweb.iii"

fn main() -> u64 {
    /* (1) the universal reversible gate is self-inverse -> III contains reversible computation */
    if pw_toffoli_self_inverse() != 1u8 { return 1u64 }

    /* (2) it computes NAND -> reversible computation is functionally complete (universal) */
    if pw_toffoli_is_nand() != 1u8 { return 2u64 }

    /* (3) biting: it is not the identity -- it does real work (self-inverse is non-vacuous) */
    if pw_toffoli_nontrivial() != 0u8 { return 3u64 }

    return 99u64
}
