/* 1768_weave_totality.iii -- THE ONE SUBSTRATE, MADE TOTAL: every weave_blocks primitive CLASS executes as its
 * own bv_bits circuit (bb_eval), byte-identical to the borrowed native form.  1765 proved the collapse for the
 * representative cases; this closes it with no partial -- one definition per primitive, proven AND executed,
 * across the rotation, Boolean-mux, Boolean-majority, Galois-multiply, and ARX-round families.
 *
 *   (1) wvb_rotl64  == bb_eval(or(shl,shr)) at w=64
 *   (2) wvb_ch64    == bb_eval(xor(and(e,f),and(~e,g))) at w=64
 *   (3) wvb_maj64   == bb_eval(maj circuit) at w=64
 *   (4) wvb_gf8_mul == bb_eval( the 8-round carryless GF(2^8) multiply-reduce circuit ) at w=8  (~100 nodes:
 *       the evaluator handles a non-trivial DAG, not just a toy)
 *   (5) wvb_arx_mix == bb_eval of the 4 ARX output lanes at w=32 (ChaCha quarter-round amounts)
 * Exit 99 = the whole weave is one substrate -- nothing authored twice. */
module corpus_1768

extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_and(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_or(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_xor(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_not(a: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shl(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shr(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_add(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_sub(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_set_input(v: u32, val: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_eval(t: u32) -> u64 from "bv_bits.iii"

extern @abi(c-msvc-x64) fn wvb_rotl64(x: u64, n: u64) -> u64 from "weave_blocks.iii"
extern @abi(c-msvc-x64) fn wvb_ch64(e: u64, f: u64, g: u64) -> u64 from "weave_blocks.iii"
extern @abi(c-msvc-x64) fn wvb_maj64(a: u64, b: u64, c: u64) -> u64 from "weave_blocks.iii"
extern @abi(c-msvc-x64) fn wvb_gf8_mul(a: u32, b: u32) -> u32 from "weave_blocks.iii"
extern @abi(c-msvc-x64) fn wvb_arx_mix(va: u32, vb: u32, vc: u32, vd: u32, x: u32, y: u32, r0: u32, r1: u32, r2: u32, r3: u32) -> i32 from "weave_blocks.iii"
extern @abi(c-msvc-x64) fn wvb_a(i: u64) -> u32 from "weave_blocks.iii"

/* rotl at width w over var 0: or(shl(x,k), shr(x,w-k)). */
fn rotl_circ(x: u32, k: u64, w: u64) -> u32 { return bb_or(bb_shl(x, k), bb_shr(x, w - k)) }

/* the 8-round carryless GF(2^8) multiply-reduce as a bv circuit (matches wvb_gf8_mul exactly). */
fn gf8_circ(a: u32, b: u32, c0: u32, c1: u32, c1b: u32, cff: u32) -> u32 {
    let mut p  : u32 = c0
    let mut ac : u32 = bb_and(a, cff)
    let mut i  : u64 = 0u64
    while i < 8u64 {
        let bit : u32 = bb_and(bb_shr(b, i), c1)            /* bit i of b */
        let m   : u32 = bb_sub(c0, bit)                     /* 0 - bit = 0x00 or 0xFF (branch-free mask) */
        p = bb_xor(p, bb_and(ac, m))                        /* conditional accumulate */
        let sh    : u32 = bb_shl(ac, 1u64)
        let xmask : u32 = bb_sub(c0, bb_and(bb_shr(ac, 7u64), c1))   /* -(high bit) */
        ac = bb_and(bb_xor(sh, bb_and(c1b, xmask)), cff)    /* xtime: <<1 then conditional ^0x1B */
        i = i + 1u64
    }
    return p
}

fn main() -> u64 {
    /* (1) rotl64 */
    bb_reset(64u64)
    let x1 : u32 = bb_var(0u32)
    let r1 : u32 = rotl_circ(x1, 40u64, 64u64)
    bb_set_input(0u32, 0x0123456789ABCDEFu64)
    if bb_eval(r1) != wvb_rotl64(0x0123456789ABCDEFu64, 40u64) { return 1u64 }

    /* (2) ch64 */
    bb_reset(64u64)
    let e2 : u32 = bb_var(0u32)
    let f2 : u32 = bb_var(1u32)
    let g2 : u32 = bb_var(2u32)
    let ch2 : u32 = bb_xor(bb_and(e2, f2), bb_and(bb_not(e2), g2))
    bb_set_input(0u32, 0xF0F0F0F0F0F0F0F0u64)
    bb_set_input(1u32, 0x0123456789ABCDEFu64)
    bb_set_input(2u32, 0xFEDCBA9876543210u64)
    if bb_eval(ch2) != wvb_ch64(0xF0F0F0F0F0F0F0F0u64, 0x0123456789ABCDEFu64, 0xFEDCBA9876543210u64) { return 2u64 }

    /* (3) maj64 */
    bb_reset(64u64)
    let a3 : u32 = bb_var(0u32)
    let b3 : u32 = bb_var(1u32)
    let c3 : u32 = bb_var(2u32)
    let maj3 : u32 = bb_xor(bb_xor(bb_and(a3, b3), bb_and(a3, c3)), bb_and(b3, c3))
    bb_set_input(0u32, 0xCCCCCCCCCCCCCCCCu64)
    bb_set_input(1u32, 0xAAAAAAAAAAAAAAAAu64)
    bb_set_input(2u32, 0xF0F0F0F0F0F0F0F0u64)
    if bb_eval(maj3) != wvb_maj64(0xCCCCCCCCCCCCCCCCu64, 0xAAAAAAAAAAAAAAAAu64, 0xF0F0F0F0F0F0F0F0u64) { return 3u64 }

    /* (4) gf8_mul: the non-trivial Galois circuit, executed -- two vectors */
    bb_reset(8u64)
    let ga : u32 = bb_var(0u32)
    let gb : u32 = bb_var(1u32)
    let c0 : u32 = bb_const(0u64)
    let c1 : u32 = bb_const(1u64)
    let c1b : u32 = bb_const(0x1Bu64)
    let cff : u32 = bb_const(0xFFu64)
    let gp : u32 = gf8_circ(ga, gb, c0, c1, c1b, cff)
    bb_set_input(0u32, 0x57u64)
    bb_set_input(1u32, 0x83u64)
    if bb_eval(gp) != (wvb_gf8_mul(0x57u32, 0x83u32) as u64) { return 4u64 }
    bb_set_input(0u32, 0xCAu64)
    bb_set_input(1u32, 0x53u64)
    if bb_eval(gp) != (wvb_gf8_mul(0xCAu32, 0x53u32) as u64) { return 5u64 }    /* same circuit, new inputs -> re-eval */

    /* (5) arx_mix: the ChaCha quarter-round (x=y=0; amounts 16,12,8,7), all 4 output lanes */
    bb_reset(32u64)
    let va : u32 = bb_var(0u32)
    let vb : u32 = bb_var(1u32)
    let vc : u32 = bb_var(2u32)
    let vd : u32 = bb_var(3u32)
    let a1 : u32 = bb_add(va, vb)
    let d1 : u32 = rotl_circ(bb_xor(vd, a1), 16u64, 32u64)
    let c1c : u32 = bb_add(vc, d1)
    let b1 : u32 = rotl_circ(bb_xor(vb, c1c), 12u64, 32u64)
    let a2 : u32 = bb_add(a1, b1)
    let d2 : u32 = rotl_circ(bb_xor(d1, a2), 8u64, 32u64)
    let c2 : u32 = bb_add(c1c, d2)
    let b2 : u32 = rotl_circ(bb_xor(b1, c2), 7u64, 32u64)
    bb_set_input(0u32, 0x11111111u64)
    bb_set_input(1u32, 0x01020304u64)
    bb_set_input(2u32, 0x9B8D6F2Au64)
    bb_set_input(3u32, 0x12345678u64)
    wvb_arx_mix(0x11111111u32, 0x01020304u32, 0x9B8D6F2Au32, 0x12345678u32, 0u32, 0u32, 16u32, 12u32, 8u32, 7u32)
    if bb_eval(a2) != (wvb_a(0u64) as u64) { return 6u64 }
    if bb_eval(b2) != (wvb_a(1u64) as u64) { return 7u64 }
    if bb_eval(c2) != (wvb_a(2u64) as u64) { return 8u64 }
    if bb_eval(d2) != (wvb_a(3u64) as u64) { return 9u64 }

    return 99u64
}
