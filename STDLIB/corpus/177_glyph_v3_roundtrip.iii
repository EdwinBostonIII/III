/* Phase 14h verification: Glyph V3 canonical 192-byte encoding for 8
 * representative forms (u8, u32, u64, i64, f64, str, bytes, crystal).
 * Verifies pack → unpack round-trip + mhash integrity tampering rejection. */
module corpus_177

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn gv3_total_bytes() -> u32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_payload_cap() -> u32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_form_id(p_192: u64) -> u32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_payload_len(p_192: u64) -> u32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_validate(p_192: u64) -> u8 from "glyph_core.iii"

extern @abi(c-msvc-x64) fn glyph_u8_form_id() -> u32 from "glyph_u8.iii"
extern @abi(c-msvc-x64) fn glyph_u8_pack(v: u8, out_192: u64) -> i32 from "glyph_u8.iii"
extern @abi(c-msvc-x64) fn glyph_u8_unpack(in_192: u64) -> u32 from "glyph_u8.iii"

extern @abi(c-msvc-x64) fn glyph_u32_pack(v: u32, out_192: u64) -> i32 from "glyph_u32.iii"
extern @abi(c-msvc-x64) fn glyph_u32_unpack(in_192: u64) -> u32 from "glyph_u32.iii"

extern @abi(c-msvc-x64) fn glyph_u64_pack(v: u64, out_192: u64) -> i32 from "glyph_u64.iii"
extern @abi(c-msvc-x64) fn glyph_u64_unpack(in_192: u64) -> u64 from "glyph_u64.iii"

extern @abi(c-msvc-x64) fn glyph_i64_pack(v: i64, out_192: u64) -> i32 from "glyph_i64.iii"
extern @abi(c-msvc-x64) fn glyph_i64_unpack(in_192: u64) -> i64 from "glyph_i64.iii"

extern @abi(c-msvc-x64) fn glyph_f64_pack_bits(bits: u64, out_192: u64) -> i32 from "glyph_f64.iii"
extern @abi(c-msvc-x64) fn glyph_f64_unpack_bits(in_192: u64) -> u64 from "glyph_f64.iii"

extern @abi(c-msvc-x64) fn glyph_str_pack(src_ptr: u64, src_len: u32, out_192: u64) -> i32 from "glyph_str.iii"
extern @abi(c-msvc-x64) fn glyph_str_unpack(in_192: u64, dst_ptr: u64, dst_cap: u32) -> i32 from "glyph_str.iii"

extern @abi(c-msvc-x64) fn glyph_bytes_pack(src_ptr: u64, src_len: u32, out_192: u64) -> i32 from "glyph_bytes.iii"
extern @abi(c-msvc-x64) fn glyph_bytes_unpack(in_192: u64, dst_ptr: u64, dst_cap: u32) -> i32 from "glyph_bytes.iii"

extern @abi(c-msvc-x64) fn glyph_crystal_pack(crystal_id: u64, parent_id: u64, packed_err_edge: u64, out_192: u64) -> i32 from "glyph_crystal.iii"
extern @abi(c-msvc-x64) fn glyph_crystal_pack_meta(error_code: u32, edge_count: u32) -> u64 from "glyph_crystal.iii"
extern @abi(c-msvc-x64) fn glyph_crystal_unpack_id(in_192: u64) -> u64 from "glyph_crystal.iii"
extern @abi(c-msvc-x64) fn glyph_crystal_unpack_parent(in_192: u64) -> u64 from "glyph_crystal.iii"
extern @abi(c-msvc-x64) fn glyph_crystal_unpack_error_code(in_192: u64) -> u32 from "glyph_crystal.iii"
extern @abi(c-msvc-x64) fn glyph_crystal_unpack_edge_count(in_192: u64) -> u32 from "glyph_crystal.iii"

fn main() -> u64 {
    /* Sanity. */
    if gv3_total_bytes() != 192u32 { return 1u64 }
    if gv3_payload_cap() != 152u32 { return 2u64 }
    if glyph_u8_form_id() != 0x10u32 { return 3u64 }

    let g : *u8 = malloc(192u64)

    /* u8 round-trip. */
    glyph_u8_pack(0xABu8, g as u64)
    if gv3_form_id(g as u64) != 0x10u32 { return 4u64 }
    if gv3_payload_len(g as u64) != 1u32 { return 5u64 }
    if gv3_validate(g as u64) != 1u8 { return 6u64 }
    if glyph_u8_unpack(g as u64) != 0xABu32 { return 7u64 }

    /* u32 round-trip. */
    glyph_u32_pack(0xCAFEBABEu32, g as u64)
    if gv3_form_id(g as u64) != 0x11u32 { return 8u64 }
    if gv3_payload_len(g as u64) != 4u32 { return 9u64 }
    if glyph_u32_unpack(g as u64) != 0xCAFEBABEu32 { return 10u64 }

    /* u64 round-trip. */
    glyph_u64_pack(0xDEADBEEF12345678u64, g as u64)
    if gv3_form_id(g as u64) != 0x12u32 { return 11u64 }
    if glyph_u64_unpack(g as u64) != 0xDEADBEEF12345678u64 { return 12u64 }

    /* i64 round-trip with negative value. */
    glyph_i64_pack(-42i64, g as u64)
    if gv3_form_id(g as u64) != 0x13u32 { return 13u64 }
    if glyph_i64_unpack(g as u64) != -42i64 { return 14u64 }

    /* f64 bits round-trip. 0x3FF0000000000000 = 1.0 IEEE 754. */
    glyph_f64_pack_bits(0x3FF0000000000000u64, g as u64)
    if gv3_form_id(g as u64) != 0x14u32 { return 15u64 }
    if glyph_f64_unpack_bits(g as u64) != 0x3FF0000000000000u64 { return 16u64 }

    /* str round-trip. */
    let s : *u8 = malloc(16u64)
    s[0] = 72u8     /* H */
    s[1] = 101u8    /* e */
    s[2] = 108u8    /* l */
    s[3] = 108u8    /* l */
    s[4] = 111u8    /* o */
    glyph_str_pack(s as u64, 5u32, g as u64)
    if gv3_form_id(g as u64) != 0x20u32 { return 17u64 }
    if gv3_payload_len(g as u64) != 5u32 { return 18u64 }
    let dst : *u8 = malloc(16u64)
    if glyph_str_unpack(g as u64, dst as u64, 16u32) != 5i32 { return 19u64 }
    if dst[0] != 72u8 { return 20u64 }
    if dst[4] != 111u8 { return 21u64 }

    /* bytes round-trip with 32-byte payload. */
    let b : *u8 = malloc(32u64)
    let mut i : u64 = 0u64
    while i < 32u64 { b[i] = (i + 0x80u64) as u8; i = i + 1u64 }
    glyph_bytes_pack(b as u64, 32u32, g as u64)
    if gv3_form_id(g as u64) != 0x21u32 { return 22u64 }
    if gv3_payload_len(g as u64) != 32u32 { return 23u64 }
    let bdst : *u8 = malloc(32u64)
    if glyph_bytes_unpack(g as u64, bdst as u64, 32u32) != 32i32 { return 24u64 }
    if bdst[0] != 0x80u8 { return 25u64 }
    if bdst[31] != 0x9Fu8 { return 26u64 }   /* 0x80 + 31 */

    /* crystal round-trip. */
    let pee : u64 = glyph_crystal_pack_meta(0xE100u32, 5u32)
    glyph_crystal_pack(0xC1u64, 0xC0u64, pee, g as u64)
    if glyph_crystal_unpack_id(g as u64) != 0xC1u64 { return 27u64 }
    if glyph_crystal_unpack_parent(g as u64) != 0xC0u64 { return 28u64 }
    if glyph_crystal_unpack_error_code(g as u64) != 0xE100u32 { return 29u64 }
    if glyph_crystal_unpack_edge_count(g as u64) != 5u32 { return 30u64 }

    /* Tamper test: flip a payload byte; validate must reject. */
    glyph_u32_pack(0x12345678u32, g as u64)
    if gv3_validate(g as u64) != 1u8 { return 31u64 }
    g[8] = g[8] ^ 0xFFu8
    if gv3_validate(g as u64) != 0u8 { return 32u64 }
    g[8] = g[8] ^ 0xFFu8   /* restore */
    if gv3_validate(g as u64) != 1u8 { return 33u64 }

    /* Tamper mhash byte: must reject. */
    g[160] = g[160] ^ 0xFFu8
    if gv3_validate(g as u64) != 0u8 { return 34u64 }

    /* Cross-form rejection: u64 unpack on a u32 glyph returns 0u64. */
    glyph_u32_pack(0x42u32, g as u64)
    if glyph_u64_unpack(g as u64) != 0u64 { return 35u64 }

    /* Pack with null buf rejected. */
    if glyph_u32_pack(0x42u32, 0u64) != -1i32 { return 36u64 }

    free(g); free(s); free(dst); free(b); free(bdst)
    return 99u64
}
