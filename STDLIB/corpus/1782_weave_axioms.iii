/* 1782_weave_axioms.iii -- III DISCOVERS THE AXIOMS OF BOOLEAN ALGEBRA (and a theorem, and a group law).
 *
 * The weave's structural floor now reaches the full axiomatic basis of Boolean algebra -- associativity,
 * commutativity, complement, identity/annihilator -- PLUS the consensus THEOREM (a non-trivial derived
 * identity) and the rotation-GROUP composition law.  Each is searched/built over the bv substrate and proven
 * by the SAT judge for ALL inputs.  Together with De Morgan, absorption, distributivity (1778), III has
 * discovered the complete elementary theory of its own logic.
 *
 *   associativity (and/or/xor), commutativity (and/or/xor), complement (a&~a=0, a|~a=1s, ~~a=a),
 *   identity+annihilator (a&0=0, a|0=a, a^0=a, a|1s=1s, a&1s=a), the CONSENSUS theorem, rotation composition.
 * Exit 99 = III autonomously discovered + proved the axioms (and more) of Boolean algebra. */
module corpus_1782

extern @abi(c-msvc-x64) fn gild_assoc() -> u8 from "invent.iii"
extern @abi(c-msvc-x64) fn gild_comm() -> u8 from "invent.iii"
extern @abi(c-msvc-x64) fn gild_complement() -> u8 from "invent.iii"
extern @abi(c-msvc-x64) fn gild_identity() -> u8 from "invent.iii"
extern @abi(c-msvc-x64) fn gild_consensus() -> u8 from "invent.iii"
extern @abi(c-msvc-x64) fn gild_rotcompose(a: u64, b: u64) -> u8 from "invent.iii"

fn main() -> u64 {
    if gild_assoc() != 1u8 { return 1u64 }                    /* associativity */
    if gild_comm() != 1u8 { return 2u64 }                    /* commutativity */
    if gild_complement() != 1u8 { return 3u64 }              /* complement + double negation */
    if gild_identity() != 1u8 { return 4u64 }                /* identity + annihilator */
    if gild_consensus() != 1u8 { return 5u64 }               /* the consensus theorem */
    if gild_rotcompose(7u64, 12u64) != 1u8 { return 6u64 }   /* rotation group: rotl(rotl(x,7),12)=rotl(x,19) */
    if gild_rotcompose(20u64, 20u64) != 1u8 { return 7u64 }  /* wraps: 40 mod 32 = 8 */
    return 99u64
}
