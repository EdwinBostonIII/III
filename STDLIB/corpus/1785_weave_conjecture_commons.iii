/* 1785_weave_conjecture_commons.iii -- III's SELF-CONJECTURED laws JOIN the persistent commons.
 *
 * The conjecture engine discovered 12 three-variable identities de-novo (1784).  Here they are ACCUMULATED into
 * the content-addressed commons -- the laws III CONJECTURED sitting beside the named-family laws it proved --
 * and the COMPLETE self-discovered body is sealed + reloaded byte-identical.  One commons, named-and-found alike.
 *
 *   (1) present_conjecture3 admits the 12 discovered identities -> commons grows to 12 (idempotent: re-run = 12)
 *   (2) present_weave_complete adds the 13 named-family laws -> the complete body = 25 distinct laws
 *   (3) persist -> wipe -> reload restores 25 with the rolling root byte-identical
 * Exit 99 = III's conjectured + named mathematics live together in one persistent commons. */
module corpus_1785

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn fs_delete(cap: u64, path: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn present_conjecture3() -> u64 from "present.iii"
extern @abi(c-msvc-x64) fn present_weave_complete() -> u64 from "present.iii"
extern @abi(c-msvc-x64) fn pres_nlaw() -> u64 from "present.iii"
extern @abi(c-msvc-x64) fn pres_root_byte(i: u64) -> u32 from "present.iii"
extern @abi(c-msvc-x64) fn pres_commons_persist(cap: u64, path: u64) -> i32 from "present.iii"
extern @abi(c-msvc-x64) fn pres_commons_reset() -> i32 from "present.iii"
extern @abi(c-msvc-x64) fn pres_commons_reload(cap: u64, path: u64) -> i32 from "present.iii"

var ROOTSNAP : [u32; 32]

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)
    let path : *u8 = malloc(24u64)                          /* "./iii_weave_cmpl.tmp" */
    path[0u64] = 46u8   path[1u64] = 47u8   path[2u64] = 105u8  path[3u64] = 105u8
    path[4u64] = 105u8  path[5u64] = 95u8   path[6u64] = 119u8  path[7u64] = 101u8
    path[8u64] = 97u8   path[9u64] = 118u8  path[10u64] = 101u8 path[11u64] = 95u8
    path[12u64] = 99u8  path[13u64] = 109u8 path[14u64] = 112u8 path[15u64] = 108u8
    path[16u64] = 46u8  path[17u64] = 116u8 path[18u64] = 109u8 path[19u64] = 112u8
    path[20u64] = 0u8

    /* (1) accumulate the self-conjectured identities */
    if present_conjecture3() != 12u64 { return 1u64 }
    if present_conjecture3() != 12u64 { return 2u64 }       /* idempotent: content-addressed, no double-count */

    /* (2) the complete body = conjectured + named */
    if present_weave_complete() != 25u64 { return 3u64 }
    let mut i : u64 = 0u64
    while i < 32u64 { ROOTSNAP[i] = pres_root_byte(i)  i = i + 1u64 }

    /* (3) persist the complete body, reload byte-identical */
    if pres_commons_persist(cap, path as u64) != 0i32 { return 4u64 }
    pres_commons_reset()
    if pres_nlaw() != 0u64 { return 5u64 }
    if pres_commons_reload(cap, path as u64) != 25i32 { return 6u64 }
    if pres_nlaw() != 25u64 { return 7u64 }
    i = 0u64
    while i < 32u64 { if pres_root_byte(i) != ROOTSNAP[i] { return 8u64 }  i = i + 1u64 }

    fs_delete(cap, path as u64)
    return 99u64
}
