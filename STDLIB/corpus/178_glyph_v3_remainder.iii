/* Phase 14h completion verification: glyph_v3 forms vec, map, set,
 * enum, record, witness, proof, glyph_recursive.  Pack/unpack round-
 * trip + mhash integrity for each.  Cross-form rejection sanity. */
module corpus_178

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn gv3_form_id(p_192: u64) -> u32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_validate(p_192: u64) -> u8 from "glyph_core.iii"

extern @abi(c-msvc-x64) fn glyph_vec_form_id() -> u32 from "glyph_vec.iii"
extern @abi(c-msvc-x64) fn glyph_vec_pack(packed_meta: u64, src_ptr: u64, out_192: u64) -> i32 from "glyph_vec.iii"
extern @abi(c-msvc-x64) fn glyph_vec_pack_meta(elem_form_id: u32, elem_count: u32, elem_size: u32) -> u64 from "glyph_vec.iii"
extern @abi(c-msvc-x64) fn glyph_vec_unpack_count(in_192: u64) -> u32 from "glyph_vec.iii"
extern @abi(c-msvc-x64) fn glyph_vec_unpack_elem_form_id(in_192: u64) -> u32 from "glyph_vec.iii"
extern @abi(c-msvc-x64) fn glyph_vec_unpack_elements(in_192: u64, dst_ptr: u64, dst_cap_bytes: u32) -> i32 from "glyph_vec.iii"

extern @abi(c-msvc-x64) fn glyph_map_pack(packed_forms: u64, packed_sizes: u64, src_packed_ptr: u64, out_192: u64) -> i32 from "glyph_map.iii"
extern @abi(c-msvc-x64) fn glyph_map_pack_forms(key_form_id: u32, val_form_id: u32) -> u64 from "glyph_map.iii"
extern @abi(c-msvc-x64) fn glyph_map_pack_sizes(pair_count: u32, key_size: u32, val_size: u32) -> u64 from "glyph_map.iii"
extern @abi(c-msvc-x64) fn glyph_map_unpack_count(in_192: u64) -> u32 from "glyph_map.iii"
extern @abi(c-msvc-x64) fn glyph_map_unpack_pairs(in_192: u64, dst_ptr: u64, dst_cap_bytes: u32) -> i32 from "glyph_map.iii"

extern @abi(c-msvc-x64) fn glyph_set_pack(packed_meta: u64, src_ptr: u64, out_192: u64) -> i32 from "glyph_set.iii"
extern @abi(c-msvc-x64) fn glyph_set_pack_meta(elem_form_id: u32, elem_count: u32, elem_size: u32) -> u64 from "glyph_set.iii"
extern @abi(c-msvc-x64) fn glyph_set_unpack_count(in_192: u64) -> u32 from "glyph_set.iii"

extern @abi(c-msvc-x64) fn glyph_enum_pack(packed_meta: u64, src_ptr: u64, out_192: u64) -> i32 from "glyph_enum.iii"
extern @abi(c-msvc-x64) fn glyph_enum_pack_meta(tag: u32, variant_form_id: u32, variant_len: u32) -> u64 from "glyph_enum.iii"
extern @abi(c-msvc-x64) fn glyph_enum_unpack_tag(in_192: u64) -> u32 from "glyph_enum.iii"
extern @abi(c-msvc-x64) fn glyph_enum_unpack_variant_form(in_192: u64) -> u32 from "glyph_enum.iii"
extern @abi(c-msvc-x64) fn glyph_enum_unpack_variant_len(in_192: u64) -> u32 from "glyph_enum.iii"
extern @abi(c-msvc-x64) fn glyph_enum_unpack_variant_bytes(in_192: u64, dst_ptr: u64, dst_cap: u32) -> i32 from "glyph_enum.iii"

extern @abi(c-msvc-x64) fn glyph_record_pack_begin(out_192: u64) -> i32 from "glyph_record.iii"
extern @abi(c-msvc-x64) fn glyph_record_pack_field(out_192: u64, slot: u32, field_id: u32, value: u64) -> i32 from "glyph_record.iii"
extern @abi(c-msvc-x64) fn glyph_record_pack_finalise(out_192: u64, field_count: u32) -> i32 from "glyph_record.iii"
extern @abi(c-msvc-x64) fn glyph_record_unpack_count(in_192: u64) -> u32 from "glyph_record.iii"
extern @abi(c-msvc-x64) fn glyph_record_unpack_field_id(in_192: u64, slot: u32) -> u32 from "glyph_record.iii"
extern @abi(c-msvc-x64) fn glyph_record_unpack_field_value(in_192: u64, slot: u32) -> u64 from "glyph_record.iii"

extern @abi(c-msvc-x64) fn glyph_witness_pack(args_ptr: u64, mhash_32_ptr: u64, out_192: u64) -> i32 from "glyph_witness.iii"
extern @abi(c-msvc-x64) fn glyph_witness_set_args(args_ptr: u64, witness_idx: u64, cap_id: u64, k_fixed: u64) -> i32 from "glyph_witness.iii"
extern @abi(c-msvc-x64) fn glyph_witness_unpack_idx(in_192: u64) -> u64 from "glyph_witness.iii"
extern @abi(c-msvc-x64) fn glyph_witness_unpack_mhash_byte(in_192: u64, i: u32) -> u32 from "glyph_witness.iii"
extern @abi(c-msvc-x64) fn glyph_witness_unpack_cap_id(in_192: u64) -> u64 from "glyph_witness.iii"
extern @abi(c-msvc-x64) fn glyph_witness_unpack_k_fixed(in_192: u64) -> u64 from "glyph_witness.iii"

extern @abi(c-msvc-x64) fn glyph_proof_pack(args_ptr: u64, equiv_kind: u32, out_192: u64) -> i32 from "glyph_proof.iii"
extern @abi(c-msvc-x64) fn glyph_proof_set_args(args_ptr: u64, cert_id: u64, target_crystal_id: u64, source_crystal_id: u64) -> i32 from "glyph_proof.iii"
extern @abi(c-msvc-x64) fn glyph_proof_unpack_cert_id(in_192: u64) -> u64 from "glyph_proof.iii"
extern @abi(c-msvc-x64) fn glyph_proof_unpack_equiv_kind(in_192: u64) -> u32 from "glyph_proof.iii"
extern @abi(c-msvc-x64) fn glyph_proof_unpack_target(in_192: u64) -> u64 from "glyph_proof.iii"
extern @abi(c-msvc-x64) fn glyph_proof_unpack_source(in_192: u64) -> u64 from "glyph_proof.iii"

extern @abi(c-msvc-x64) fn glyph_recursive_pack(inner_mhash_32_ptr: u64, arena_id: u64, packed_offset_form: u64, out_192: u64) -> i32 from "glyph_recursive.iii"
extern @abi(c-msvc-x64) fn glyph_recursive_pack_offset_form(arena_offset: u32, inner_form_id: u32) -> u64 from "glyph_recursive.iii"
extern @abi(c-msvc-x64) fn glyph_recursive_unpack_mhash_byte(in_192: u64, i: u32) -> u32 from "glyph_recursive.iii"
extern @abi(c-msvc-x64) fn glyph_recursive_unpack_arena_id(in_192: u64) -> u64 from "glyph_recursive.iii"
extern @abi(c-msvc-x64) fn glyph_recursive_unpack_offset(in_192: u64) -> u64 from "glyph_recursive.iii"
extern @abi(c-msvc-x64) fn glyph_recursive_unpack_inner_form(in_192: u64) -> u32 from "glyph_recursive.iii"

fn main() -> u64 {
    if glyph_vec_form_id() != 0x30u32 { return 1u64 }

    let g : *u8 = malloc(192u64)

    /* vec of u32: pack 4 elements of size 4. */
    let elems_u32 : *u8 = malloc(16u64)
    elems_u32[ 0] = 0xAAu8 ; elems_u32[ 1] = 0u8 ; elems_u32[ 2] = 0u8 ; elems_u32[ 3] = 0u8 /* 0xAA */
    elems_u32[ 4] = 0xBBu8 ; elems_u32[ 5] = 0u8 ; elems_u32[ 6] = 0u8 ; elems_u32[ 7] = 0u8 /* 0xBB */
    elems_u32[ 8] = 0xCCu8 ; elems_u32[ 9] = 0u8 ; elems_u32[10] = 0u8 ; elems_u32[11] = 0u8 /* 0xCC */
    elems_u32[12] = 0xDDu8 ; elems_u32[13] = 0u8 ; elems_u32[14] = 0u8 ; elems_u32[15] = 0u8 /* 0xDD */
    let vec_meta : u64 = glyph_vec_pack_meta(0x11u32, 4u32, 4u32)
    glyph_vec_pack(vec_meta, elems_u32 as u64, g as u64)
    if gv3_form_id(g as u64) != 0x30u32 { return 2u64 }
    if gv3_validate(g as u64) != 1u8 { return 3u64 }
    if glyph_vec_unpack_count(g as u64) != 4u32 { return 4u64 }
    if glyph_vec_unpack_elem_form_id(g as u64) != 0x11u32 { return 5u64 }
    let dst : *u8 = malloc(16u64)
    if glyph_vec_unpack_elements(g as u64, dst as u64, 16u32) != 16i32 { return 6u64 }
    if dst[0] != 0xAAu8 { return 7u64 }
    if dst[12] != 0xDDu8 { return 8u64 }

    /* set: same encoding, different form_id. */
    let set_meta : u64 = glyph_set_pack_meta(0x11u32, 4u32, 4u32)
    glyph_set_pack(set_meta, elems_u32 as u64, g as u64)
    if gv3_form_id(g as u64) != 0x32u32 { return 9u64 }
    if glyph_set_unpack_count(g as u64) != 4u32 { return 10u64 }

    /* map u32→u32: 3 pairs.  Layout (k0, v0, k1, v1, k2, v2). */
    let pairs : *u8 = malloc(24u64)
    let mut k : u64 = 0u64
    while k < 24u64 { pairs[k] = 0u8; k = k + 1u64 }
    pairs[0]  = 0x10u8   /* k0 = 0x10 */
    pairs[4]  = 0x20u8   /* v0 = 0x20 */
    pairs[8]  = 0x11u8   /* k1 = 0x11 */
    pairs[12] = 0x21u8   /* v1 = 0x21 */
    pairs[16] = 0x12u8   /* k2 = 0x12 */
    pairs[20] = 0x22u8   /* v2 = 0x22 */
    let map_forms : u64 = glyph_map_pack_forms(0x11u32, 0x11u32)
    let map_sizes : u64 = glyph_map_pack_sizes(3u32, 4u32, 4u32)
    glyph_map_pack(map_forms, map_sizes, pairs as u64, g as u64)
    if gv3_form_id(g as u64) != 0x31u32 { return 11u64 }
    if glyph_map_unpack_count(g as u64) != 3u32 { return 12u64 }
    let pdst : *u8 = malloc(24u64)
    if glyph_map_unpack_pairs(g as u64, pdst as u64, 24u32) != 24i32 { return 13u64 }
    if pdst[0]  != 0x10u8 { return 14u64 }
    if pdst[20] != 0x22u8 { return 15u64 }

    /* enum: tag=7, variant_form=u32 (0x11), variant_len=4. */
    let var_buf : *u8 = malloc(4u64)
    var_buf[0] = 0x99u8
    var_buf[1] = 0u8
    var_buf[2] = 0u8
    var_buf[3] = 0u8
    let enum_meta : u64 = glyph_enum_pack_meta(7u32, 0x11u32, 4u32)
    glyph_enum_pack(enum_meta, var_buf as u64, g as u64)
    if gv3_form_id(g as u64) != 0x33u32 { return 16u64 }
    if glyph_enum_unpack_tag(g as u64) != 7u32 { return 17u64 }
    if glyph_enum_unpack_variant_form(g as u64) != 0x11u32 { return 18u64 }
    if glyph_enum_unpack_variant_len(g as u64) != 4u32 { return 19u64 }
    let vdst : *u8 = malloc(8u64)
    if glyph_enum_unpack_variant_bytes(g as u64, vdst as u64, 8u32) != 4i32 { return 20u64 }
    if vdst[0] != 0x99u8 { return 21u64 }

    /* record: 3 fields. */
    glyph_record_pack_begin(g as u64)
    glyph_record_pack_field(g as u64, 0u32, 100u32, 0xAAAAAAAAAAAAAAAAu64)
    glyph_record_pack_field(g as u64, 1u32, 200u32, 0xBBBBBBBBBBBBBBBBu64)
    glyph_record_pack_field(g as u64, 2u32, 300u32, 0xCCCCCCCCCCCCCCCCu64)
    glyph_record_pack_finalise(g as u64, 3u32)
    if gv3_form_id(g as u64) != 0x34u32 { return 22u64 }
    if glyph_record_unpack_count(g as u64) != 3u32 { return 23u64 }
    if glyph_record_unpack_field_id(g as u64, 0u32) != 100u32 { return 24u64 }
    if glyph_record_unpack_field_value(g as u64, 0u32) != 0xAAAAAAAAAAAAAAAAu64 { return 25u64 }
    if glyph_record_unpack_field_id(g as u64, 2u32) != 300u32 { return 26u64 }
    if glyph_record_unpack_field_value(g as u64, 2u32) != 0xCCCCCCCCCCCCCCCCu64 { return 27u64 }
    if glyph_record_unpack_field_id(g as u64, 99u32) != 0u32 { return 28u64 }   /* OOB */

    /* witness: idx=42, mhash=all 0x55, cap=0x1234, k=0xABCDEF. */
    let mh : *u8 = malloc(32u64)
    let mut i : u64 = 0u64
    while i < 32u64 { mh[i] = 0x55u8; i = i + 1u64 }
    let wargs : *u8 = malloc(24u64)
    glyph_witness_set_args(wargs as u64, 42u64, 0x1234u64, 0xABCDEFu64)
    glyph_witness_pack(wargs as u64, mh as u64, g as u64)
    if gv3_form_id(g as u64) != 0x41u32 { return 29u64 }
    if glyph_witness_unpack_idx(g as u64) != 42u64 { return 30u64 }
    if glyph_witness_unpack_mhash_byte(g as u64, 0u32) != 0x55u32 { return 31u64 }
    if glyph_witness_unpack_mhash_byte(g as u64, 31u32) != 0x55u32 { return 32u64 }
    if glyph_witness_unpack_cap_id(g as u64) != 0x1234u64 { return 33u64 }
    if glyph_witness_unpack_k_fixed(g as u64) != 0xABCDEFu64 { return 34u64 }

    /* proof: cert=0xC1, equiv=0xE004, target=0x7777, source=0x8888. */
    let pargs : *u8 = malloc(24u64)
    glyph_proof_set_args(pargs as u64, 0xC1u64, 0x7777u64, 0x8888u64)
    glyph_proof_pack(pargs as u64, 0xE004u32, g as u64)
    if gv3_form_id(g as u64) != 0x42u32 { return 35u64 }
    if glyph_proof_unpack_cert_id(g as u64) != 0xC1u64 { return 36u64 }
    if glyph_proof_unpack_equiv_kind(g as u64) != 0xE004u32 { return 37u64 }
    if glyph_proof_unpack_target(g as u64) != 0x7777u64 { return 38u64 }
    if glyph_proof_unpack_source(g as u64) != 0x8888u64 { return 39u64 }

    /* glyph_recursive: inner_mhash=all 0x77, arena_id=5, offset=192. */
    let inner_mh : *u8 = malloc(32u64)
    let mut j : u64 = 0u64
    while j < 32u64 { inner_mh[j] = 0x77u8; j = j + 1u64 }
    let rec_pof : u64 = glyph_recursive_pack_offset_form(192u32, 0x40u32)
    glyph_recursive_pack(inner_mh as u64, 5u64, rec_pof, g as u64)
    if gv3_form_id(g as u64) != 0x50u32 { return 40u64 }
    if glyph_recursive_unpack_mhash_byte(g as u64, 0u32) != 0x77u32 { return 41u64 }
    if glyph_recursive_unpack_arena_id(g as u64) != 5u64 { return 42u64 }
    if glyph_recursive_unpack_offset(g as u64) != 192u64 { return 43u64 }
    if glyph_recursive_unpack_inner_form(g as u64) != 0x40u32 { return 44u64 }

    /* Tamper test on enum: flip mhash byte -> validate fails -> unpack returns 0. */
    let enum_meta2 : u64 = glyph_enum_pack_meta(99u32, 0x11u32, 4u32)
    glyph_enum_pack(enum_meta2, var_buf as u64, g as u64)
    if glyph_enum_unpack_tag(g as u64) != 99u32 { return 45u64 }
    g[160] = g[160] ^ 0xFFu8
    if glyph_enum_unpack_tag(g as u64) != 0u32 { return 46u64 }   /* validate fails -> 0 */

    /* Out-of-cap rejection on vec. */
    let vec_meta_oor : u64 = glyph_vec_pack_meta(0x11u32, 100u32, 4u32)
    if glyph_vec_pack(vec_meta_oor, elems_u32 as u64, g as u64) != -3i32 { return 47u64 }
    /* (100 * 4 = 400 bytes > 144 cap -> -3) */

    free(g); free(elems_u32); free(dst); free(pairs); free(pdst); free(var_buf); free(vdst); free(mh); free(inner_mh); free(wargs); free(pargs)
    return 99u64
}
