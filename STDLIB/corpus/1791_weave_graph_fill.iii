/* 1791_weave_graph_fill.iii -- III FILLS ITS OWN SPIDERWEB, and the typed web persists.
 *
 * The founding chat: the weave is "capable of following its own logic to fill out its own spiderweb perfectly."
 * Here III does exactly that: present_weave_graph enumerates every strand of the primitive proof-graph
 * (numera/weave_graph), lets bb_equal TYPE each by its six-state proof-status, and ADMITS the PROVEN strands --
 * universal (ALL) and conditional (BOTH) -- into the content-addressed commons.  Refuted strands are not kept.
 *
 *   (1) III fills the web: 4 proven strands admitted (2 universal SHA-2 Ch/Maj laws + 2 conditional rotation strands)
 *   (2) idempotent: re-filling admits nothing new (the strands are content-addressed)
 *   (3) the typed web persists -> wipe -> reloads byte-identical (4 strands, rolling root intact)
 * Exit 99 = the proof-graph of III's primitives is a self-filled, persistent, six-state-typed body -- the weave. */
module corpus_1791

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn fs_delete(cap: u64, path: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn present_weave_graph() -> u64 from "present.iii"
extern @abi(c-msvc-x64) fn pres_nlaw() -> u64 from "present.iii"
extern @abi(c-msvc-x64) fn pres_root_byte(i: u64) -> u32 from "present.iii"
extern @abi(c-msvc-x64) fn pres_commons_persist(cap: u64, path: u64) -> i32 from "present.iii"
extern @abi(c-msvc-x64) fn pres_commons_reset() -> i32 from "present.iii"
extern @abi(c-msvc-x64) fn pres_commons_reload(cap: u64, path: u64) -> i32 from "present.iii"

var ROOTSNAP : [u32; 32]

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)
    let path : *u8 = malloc(16u64)                         /* "./iii_wg.tmp" */
    path[0u64] = 46u8   path[1u64] = 47u8   path[2u64] = 105u8  path[3u64] = 105u8
    path[4u64] = 105u8  path[5u64] = 95u8   path[6u64] = 119u8  path[7u64] = 103u8
    path[8u64] = 46u8   path[9u64] = 116u8  path[10u64] = 109u8 path[11u64] = 112u8
    path[12u64] = 0u8

    /* (1) III fills its own spiderweb: 4 proven strands (2 universal SHA-2 laws + 2 conditional rotation strands) */
    if present_weave_graph() != 4u64 { return 1u64 }

    /* (2) idempotent: re-filling admits nothing new */
    if present_weave_graph() != 4u64 { return 2u64 }

    /* (3) the typed web persists + reloads byte-identical */
    let mut i : u64 = 0u64
    while i < 32u64 { ROOTSNAP[i] = pres_root_byte(i)  i = i + 1u64 }
    if pres_commons_persist(cap, path as u64) != 0i32 { return 3u64 }
    pres_commons_reset()
    if pres_nlaw() != 0u64 { return 4u64 }
    if pres_commons_reload(cap, path as u64) != 4i32 { return 5u64 }
    if pres_nlaw() != 4u64 { return 6u64 }
    i = 0u64
    while i < 32u64 { if pres_root_byte(i) != ROOTSNAP[i] { return 7u64 }  i = i + 1u64 }

    fs_delete(cap, path as u64)
    return 99u64
}
