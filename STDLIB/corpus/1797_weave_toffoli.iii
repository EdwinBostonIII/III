/* 1797_weave_toffoli.iii -- THE UNIVERSAL REVERSIBLE PRIMITIVE, integrated into the MELTED weave.
 *
 * The Toffoli / CCNOT gate (a,b,c) -> (a, b, c ^ (a&b)) is the universal reversible primitive -- the gate that
 * makes III's logic isomorphic to reversible (Landauer ~zero-heat) computation.  Its third output c ^ (a&b) is
 * BIT-INDEPENDENT, so the melt handles it WITHOUT SAT: its defining properties are truth-table SIGNATURE facts.
 * The weave now holds the Toffoli as a node, typed by the melted signature judge, indexing primweb's SAT proofs.
 *
 *   (1) REVERSIBILITY by signature: applying the Toffoli third-output twice returns c (self-inverse) -- proven by
 *       signature identity over 3 inputs, ZERO SAT clauses.  The universal gate's reversibility is a truth-table fact.
 *   (2) UNIVERSALITY by signature: Toffoli(a,b,1) == NAND(a,b) (functionally complete) -- proven by signature, no SAT.
 *   (3) it is bit-independent -> the melt's signature route correctly applies (no bit-coupling).
 *   (4) the signature melt AGREES with primweb's SAT proofs (pw_toffoli_self_inverse / pw_toffoli_is_nand) -- the
 *       melt and the judge reach the same truth, the melt for free.
 * Exit 99 = the universal reversible gate lives in the weave, its reversibility + universality proven by the
 * melted signature, sound against primweb. */
module corpus_1797

extern @abi(c-msvc-x64) fn ws_toffoli_selfinverse() -> u8 from "weave_graph.iii"
extern @abi(c-msvc-x64) fn ws_toffoli_is_nand() -> u8 from "weave_graph.iii"
extern @abi(c-msvc-x64) fn ws_toffoli_bit_independent() -> u8 from "weave_graph.iii"
extern @abi(c-msvc-x64) fn ws_toffoli_agrees_primweb() -> u8 from "weave_graph.iii"

fn main() -> u64 {
    /* (1) reversibility (self-inverse) proven by the melted signature, no SAT */
    if ws_toffoli_selfinverse() != 1u8 { return 1u64 }

    /* (2) universality (Toffoli(a,b,1) == NAND) proven by the melted signature, no SAT */
    if ws_toffoli_is_nand() != 1u8 { return 2u64 }

    /* (3) the Toffoli is bit-independent -> the signature route applies */
    if ws_toffoli_bit_independent() != 1u8 { return 3u64 }

    /* (4) the melt agrees with primweb's SAT proofs (sound + anti-island) */
    if ws_toffoli_agrees_primweb() != 1u8 { return 4u64 }

    return 99u64
}
