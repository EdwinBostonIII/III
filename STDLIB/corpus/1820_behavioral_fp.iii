/* 1820_behavioral_fp.iii -- BEHAVIORAL FINGERPRINT + DRIFT (production / evergreen): comprehensive proof.
 * Proves: the 24-bit + 48-bit fingerprints are deterministic + non-degenerate (48-bit uses high bits); a faithful
 * claim is consistent; a divergent claim is drift (negative); drift detection is stable on the live value and fires
 * on a changed sealed expectation (negative).  Exit 99. */
module corpus_1820

extern @abi(c-msvc-x64) fn bfp_compute() -> u32 from "behavioral_fp.iii"
extern @abi(c-msvc-x64) fn bfp_compute48() -> u64 from "behavioral_fp.iii"
extern @abi(c-msvc-x64) fn bfp_consistent(claimed: u32, behavioral: u32) -> u8 from "behavioral_fp.iii"
extern @abi(c-msvc-x64) fn bfp_drift(sealed_expected: u32) -> u8 from "behavioral_fp.iii"

fn main() -> u64 {
    let f1 : u32 = bfp_compute()
    let f2 : u32 = bfp_compute()
    if f1 != f2 { return 11u64 }                        /* deterministic */
    if f1 == 0u32 { return 12u64 }                      /* non-degenerate */
    let w : u64 = bfp_compute48()
    if w != bfp_compute48() { return 13u64 }            /* 48-bit deterministic */
    if (w & 0xFFFFFF000000u64) == 0u64 { return 14u64 } /* uses the high 24 bits (genuinely 48-bit) */

    if bfp_consistent(f1, f2) != 1u8 { return 15u64 }   /* a faithful claim matches behavior */
    if bfp_consistent(f1 ^ 1u32, f1) != 0u8 { return 16u64 }   /* NEGATIVE: a divergent claim is drift */

    if bfp_drift(f1) != 0u8 { return 17u64 }            /* sealed == live -> stable */
    if bfp_drift(f1 ^ 1u32) != 1u8 { return 18u64 }     /* NEGATIVE: a changed expectation -> drift detected */
    return 99u64
}
