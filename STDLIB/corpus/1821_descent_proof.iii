/* 1821_descent_proof.iii -- PROOF-CARRYING DESCENT (POC).
 * Proves: a rung with a valid proof is admitted; a forged proof is rejected (negative); the proof is BOUND to the
 * precondition (same action, different precondition -> rejected); re-proving under the new precondition admits.
 * Exit 99. */
module corpus_1821

extern @abi(c-msvc-x64) fn dp_proof(action: u32, precond: u32) -> u32 from "descent_proof.iii"
extern @abi(c-msvc-x64) fn dp_admit(action: u32, precond: u32, claimed_proof: u32) -> u8 from "descent_proof.iii"

fn main() -> u64 {
    let action  : u32 = 0x2Au32
    let precond : u32 = 0x13u32
    let proof : u32 = dp_proof(action, precond)
    if dp_admit(action, precond, proof) != 1u8 { return 11u64 }              /* valid rung admitted */
    if dp_admit(action, precond, proof ^ 1u32) != 0u8 { return 12u64 }       /* NEGATIVE: forged proof rejected */
    if dp_admit(action, precond + 1u32, proof) != 0u8 { return 13u64 }       /* NEGATIVE: proof bound to precondition */
    let proof2 : u32 = dp_proof(action, precond + 1u32)
    if dp_admit(action, precond + 1u32, proof2) != 1u8 { return 14u64 }      /* re-proven under new precond admits */
    return 99u64
}
