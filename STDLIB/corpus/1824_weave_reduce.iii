/* 1824_weave_reduce.iii -- THE FINAL WEAVE, Step 1 (CONVERGED): the codegen's reductions are III's OWN EXISTING
 * substrate -- nothing authored.  After three steers ("different logics / different primitives / authored not
 * discovered") the answer is: there was no reducer to build and no gap to absorb.  III ALREADY
 *   - canonicalises the bit-independent regime at construction (bb_intern: idempotence/involution/annihilation/
 *     identity, zero SAT),
 *   - DISCOVERS strength reduction itself (invent's gil_forge: searches shl / (x<<a)-x / (x<<a)+x / two-shift,
 *     SAT-PROVES each at the deployment width 64, sieves by cost -- finding NON-power-of-two forms my hand rule
 *     never could, e.g. 7x = (x<<3)-x), and refuses false reductions,
 *   - executes any concrete sub-expression (bb_eval).
 * This KAT proves the codegen draws on those EXISTING faculties across all regimes.  The cg_r3 folds dissolve INTO
 * these; no sibling module, no dual, no hand-authored law.  exit 99. */
module m1824

extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_intern_and(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_intern_or(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_intern_xor(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_intern_not(a: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_is_const0(n: u32) -> u8 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_is_ones(n: u32) -> u8 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_eval(t: u32) -> u64 from "bv_bits.iii"
/* III's OWN discovered strength-reduction forge (numera/invent) -- the codegen's strength source, not a hand rule. */
extern @abi(c-msvc-x64) fn gil_forge(k: u64) -> u32 from "invent.iii"
extern @abi(c-msvc-x64) fn gil_best_kind() -> u32 from "invent.iii"
extern @abi(c-msvc-x64) fn gil_best_a() -> u64 from "invent.iii"
extern @abi(c-msvc-x64) fn gil_refutes_false(k: u64, a: u64) -> u8 from "invent.iii"

const GIL_MUL_COST : u32 = 4u32          /* a multiply is the cost baseline; "beats it" = strictly cheaper */

fn main() -> u64 {
    /* (1) bit-independent regime -- III's construction-time canon (bb_intern), zero SAT */
    bb_reset(8u64)
    let x : u32 = bb_var(0u32)
    let z : u32 = bb_const(0u64)
    let o : u32 = bb_const(0xFFu64)
    if bb_intern_and(x, x) != x { return 11u64 }                  /* x & x = x */
    if bb_intern_or(x, x)  != x { return 12u64 }                  /* x | x = x */
    if bb_is_const0(bb_intern_xor(x, x)) != 1u8 { return 13u64 }  /* x ^ x = 0 */
    if bb_intern_not(bb_intern_not(x)) != x { return 14u64 }      /* ~~x = x */
    if bb_is_const0(bb_intern_and(x, z)) != 1u8 { return 15u64 }  /* x & 0 = 0 */
    if bb_intern_or(x, z)  != x { return 16u64 }                  /* x | 0 = x */
    if bb_intern_and(x, o) != x { return 17u64 }                  /* x & ones = x */
    if bb_is_ones(bb_intern_or(x, o)) != 1u8 { return 18u64 }     /* x | ones = ones */

    /* (2) strength reduction -- III's OWN discovered forge (gil_forge), SAT-proven at width 64, cost-searched.
     *     The three cg_r3 folds (and far more) are EMERGENT here: discovered, not authored. */
    if gil_forge(8u64) >= GIL_MUL_COST { return 21u64 }           /* 8x beats the multiply ... */
    if gil_best_kind() != 1u32 { return 22u64 }                  /* ... as shl */
    if gil_best_a() != 3u64 { return 23u64 }                     /* 8x = x<<3 */
    if gil_forge(7u64) >= GIL_MUL_COST { return 24u64 }          /* 7x beats the multiply ... */
    if gil_best_kind() != 2u32 { return 25u64 }                  /* ... as (x<<a)-x -- NON-power-of-two, beyond any pow2 rule */
    if gil_best_a() != 3u64 { return 26u64 }                     /* 7x = (x<<3) - x */
    if gil_forge(9u64) >= GIL_MUL_COST { return 27u64 }
    if gil_best_kind() != 3u32 { return 28u64 }                  /* 9x = (x<<a)+x */
    if gil_best_a() != 3u64 { return 29u64 }                     /* 9x = (x<<3) + x */
    if gil_refutes_false(7u64, 4u64) != 1u8 { return 30u64 }     /* (x<<4)-x != 7x -> the SAT judge REFUSES it */

    /* (3) execution -- const-fold any concrete sub-expression through the one substrate (bb_eval) */
    bb_reset(8u64)
    let cF0 : u32 = bb_const(0xF0u64)
    let c3C : u32 = bb_const(0x3Cu64)
    if bb_eval(bb_intern_and(cF0, c3C)) != 0x30u64 { return 31u64 }

    return 99u64
}
