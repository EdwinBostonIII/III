/* 1841_grail_vj_strategy_improvement.iii -- GRAIL L8: the COMPLETE strategy-improvement solver.
 * The greedy region-size SI (1840) was INCOMPLETE: 77/80 vs the Zielonka oracle, stuck in LOCAL OPTIMA -- because
 * region size throws away the quantitative play profile.  This is the fix the literature prescribes: the
 * VOGE-JURDZINSKI discrete play-profile VALUATION.  Each vertex, under Even's strategy sigma and Odd's BEST RESPONSE
 * tau, gets a valuation (anchor, set, len):
 *   anchor = the highest priority on the loop the play reaches (its parity decides the winner),
 *   set    = the priorities > anchor seen on the path to the anchor vertex (the "more significant" detours),
 *   len    = steps to the anchor vertex.
 * Reward order (Even maximises): even anchors beat odd; among even higher is better, among odd lower is better;
 * ties broken by the symmetric-difference of sets (most significant differing priority: even -> the side that HAS it
 * wins, odd -> the side that LACKS it), then by length (even anchor: shorter better; odd: longer better).
 * SI: improve sigma against Odd's best response to a fixpoint -- PROVABLY no local optima (Voge-Jurdzinski 2000).
 * Run on the SAME 80 random games as 1840 (same seed) and validated against the verified Zielonka oracle (1839).
 * exit 99 = COMPLETE: VJ SI matches the oracle on ALL 80 games (the local optima of greedy SI are removed).
 * Otherwise exit = number matched (honest).  Open question deferred to a follow-up probe: improvement-step counts. */
module mvj
var OWN : [u8; 16]
var PRI : [u32; 16]
var SUC0 : [u32; 16]   /* original successors (bitmask) */
var SUC : [u32; 16]    /* working bitmask for the oracle */
var NV : [u32; 1]
var RNG : [u32; 1]
var STRAT : [u32; 16]  /* current deterministic profile: chosen successor INDEX per vertex */
var CHOICE : [u32; 16] /* sigma (Even) */
var TAU : [u32; 16]    /* tau (Odd, best response) */
var NEWCH : [u32; 16]
var NEWTAU : [u32; 16]
var VAL_A : [u32; 16]  /* anchor */
var VAL_S : [u32; 16]  /* set bitmask over priorities */
var VAL_L : [u32; 16]  /* length */
var VOUT_A : [u32; 1]
var VOUT_S : [u32; 1]
var VOUT_L : [u32; 1]
var SEEN : [u32; 16]
var WALK : [u32; 16]
var ROUNDS : [u32; 1]

fn nv() -> u32 { return NV[0u64] }
fn rnd() -> u32 { let mut x : u32 = RNG[0u64]  x = x ^ (x << 13u32)  x = x ^ (x >> 17u32)  x = x ^ (x << 5u32)  RNG[0u64] = x  return x }
fn fullmask() -> u32 { return (1u32 << nv()) - 1u32 }
fn low_succ(v: u32) -> u32 { let mut w : u32 = 0u32  let n : u32 = nv()  while w < n { if (SUC0[v as u64] & (1u32 << w)) != 0u32 { return w }  w = w + 1u32 }  return 0u32 }

/* ---- the verified Zielonka oracle (copied byte-for-byte from 1839, the GROUND TRUTH) ---- */
fn max_prio(region: u32) -> u32 { let mut m : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()  while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] > m { m = PRI[v as u64] } }  v = v + 1u32 }  return m }
fn attractor(region: u32, player: u32, target: u32) -> u32 {
    let mut a : u32 = target & region  let mut done : u8 = 0u8  let n : u32 = nv()
    while done == 0u8 { let mut added : u8 = 0u8  let mut v : u32 = 0u32
        while v < n { let bit : u32 = 1u32 << v
            if (region & bit) != 0u32 { if (a & bit) == 0u32 {
                if OWN[v as u64] == (player as u8) { if (SUC[v as u64] & a & region) != 0u32 { a = a | bit  added = 1u8 } }
                else { let sir : u32 = SUC[v as u64] & region  if sir != 0u32 { if (sir & (a ^ 0xFFFFFFFFu32)) == 0u32 { a = a | bit  added = 1u8 } } } } }
            v = v + 1u32 }
        if added == 0u8 { done = 1u8 } }
    return a
}
fn zielonka(region: u32) -> u64 {
    if region == 0u32 { return 0u64 }
    let d : u32 = max_prio(region)  let p : u32 = d & 1u32  let mut u : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()
    while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] == d { u = u | (1u32 << v) } }  v = v + 1u32 }
    let a : u32 = attractor(region, p, u)  let r1 : u64 = zielonka(region & (a ^ 0xFFFFFFFFu32))
    let w0a : u32 = (r1 & 0xFFFFFFFFu64) as u32  let w1a : u32 = (r1 >> 32u64) as u32
    let mut wopp : u32 = w1a  if p != 0u32 { wopp = w0a }
    if wopp == 0u32 { if p == 0u32 { return region as u64 }  return (region as u64) << 32u64 }
    let opp : u32 = 1u32 - p  let b : u32 = attractor(region, opp, wopp)  let r2 : u64 = zielonka(region & (b ^ 0xFFFFFFFFu32))
    let w0b : u32 = (r2 & 0xFFFFFFFFu64) as u32  let w1b : u32 = (r2 >> 32u64) as u32
    if p == 0u32 { return (w0b as u64) | (((w1b | b) as u64) << 32u64) }
    return ((w0b | b) as u64) | ((w1b as u64) << 32u64)
}
fn gen_game(n: u32) -> i32 {
    NV[0u64] = n  let mut v : u32 = 0u32
    while v < n { OWN[v as u64] = (rnd() & 1u32) as u8  PRI[v as u64] = rnd() % n
        let mut s : u32 = 0u32  let k : u32 = 1u32 + (rnd() % 3u32)  let mut j : u32 = 0u32
        while j < k { s = s | (1u32 << (rnd() % n))  j = j + 1u32 }
        if s == 0u32 { s = 1u32 << ((v + 1u32) % n) }
        SUC0[v as u64] = s  v = v + 1u32 }
    return 0i32
}

/* ---- the VJ valuation ---- */
/* valuate(start): follow the deterministic profile STRAT from start to its loop; write (anchor,set,len) to VOUT_*. */
fn valuate(start: u32) -> i32 {
    let n : u32 = nv()  let mut i : u32 = 0u32
    while i < n { SEEN[i as u64] = 254u32  i = i + 1u32 }
    let mut cur : u32 = start  let mut step : u32 = 0u32
    while SEEN[cur as u64] == 254u32 { SEEN[cur as u64] = step  WALK[step as u64] = cur  cur = STRAT[cur as u64]  step = step + 1u32 }
    let cs : u32 = SEEN[cur as u64]            /* cycle starts here in WALK */
    let mut l : u32 = WALK[cs as u64]  let mut j : u32 = cs
    while j < step { let vtx : u32 = WALK[j as u64]  if PRI[vtx as u64] > PRI[l as u64] { l = vtx }  j = j + 1u32 }
    let anchor : u32 = PRI[l as u64]
    let mut c2 : u32 = start  let mut len : u32 = 0u32  let mut set : u32 = 0u32
    while c2 != l { if PRI[c2 as u64] > anchor { set = set | (1u32 << PRI[c2 as u64]) }  c2 = STRAT[c2 as u64]  len = len + 1u32 }
    VOUT_A[0u64] = anchor  VOUT_S[0u64] = set  VOUT_L[0u64] = len
    return 0i32
}
fn rrank(p: u32) -> u32 { if (p & 1u32) == 0u32 { return 100u32 + p }  return 100u32 - p }
fn hibit(x: u32) -> i32 { let mut i : i32 = 31i32  while i >= 0i32 { if (x & (1u32 << (i as u32))) != 0u32 { return i }  i = i - 1i32 }  return -1i32 }
/* cmp_even: +1 if valuation a is strictly BETTER for Even than b, -1 if worse, 0 equal. */
fn cmp_even(aA: u32, aS: u32, aL: u32, bA: u32, bS: u32, bL: u32) -> i32 {
    let ra : u32 = rrank(aA)  let rb : u32 = rrank(bA)
    if ra > rb { return 1i32 }
    if ra < rb { return -1i32 }
    let dif : u32 = aS ^ bS
    if dif != 0u32 {
        let d : i32 = hibit(dif)  let dp : u32 = d as u32
        let mut inA : u8 = 0u8  if (aS & (1u32 << dp)) != 0u32 { inA = 1u8 }
        if (dp & 1u32) == 0u32 { if inA == 1u8 { return 1i32 }  return -1i32 }
        if inA == 1u8 { return -1i32 }
        return 1i32
    }
    if (aA & 1u32) == 0u32 { if aL < bL { return 1i32 }  if aL > bL { return -1i32 }  return 0i32 }
    if aL > bL { return 1i32 }  if aL < bL { return -1i32 }  return 0i32
}
fn set_profile() -> i32 { let n : u32 = nv()  let mut v : u32 = 0u32
    while v < n { if OWN[v as u64] == 0u8 { STRAT[v as u64] = CHOICE[v as u64] } else { STRAT[v as u64] = TAU[v as u64] }  v = v + 1u32 }  return 0i32 }

/* evaluate_sigma: compute Odd's BEST RESPONSE tau to the current sigma (CHOICE), filling VAL_* with the
 * play-profile valuation of every vertex under (sigma, best-response tau). */
fn evaluate_sigma() -> i32 {
    let n : u32 = nv()  let mut v : u32 = 0u32
    while v < n { if OWN[v as u64] == 1u8 { TAU[v as u64] = low_succ(v) }  v = v + 1u32 }
    let mut improving : u8 = 1u8
    while improving == 1u8 {
        set_profile()
        let mut a : u32 = 0u32
        while a < n { valuate(a)  VAL_A[a as u64] = VOUT_A[0u64]  VAL_S[a as u64] = VOUT_S[0u64]  VAL_L[a as u64] = VOUT_L[0u64]  a = a + 1u32 }
        improving = 0u8
        let mut u : u32 = 0u32
        while u < n {
            if OWN[u as u64] == 1u8 {
                let base : u32 = TAU[u as u64]
                let mut bw : u32 = base  let mut bA : u32 = VAL_A[u as u64]  let mut bS : u32 = VAL_S[u as u64]  let mut bL : u32 = VAL_L[u as u64]
                let mut w : u32 = 0u32
                while w < n {
                    if (SUC0[u as u64] & (1u32 << w)) != 0u32 {
                        STRAT[u as u64] = w  valuate(u)
                        if cmp_even(VOUT_A[0u64], VOUT_S[0u64], VOUT_L[0u64], bA, bS, bL) < 0i32 { bw = w  bA = VOUT_A[0u64]  bS = VOUT_S[0u64]  bL = VOUT_L[0u64] }
                    }
                    w = w + 1u32
                }
                STRAT[u as u64] = base
                NEWTAU[u as u64] = bw
            }
            u = u + 1u32
        }
        let mut k : u32 = 0u32
        while k < n { if OWN[k as u64] == 1u8 { if NEWTAU[k as u64] != TAU[k as u64] { TAU[k as u64] = NEWTAU[k as u64]  improving = 1u8 } }  k = k + 1u32 }
    }
    set_profile()
    let mut b2 : u32 = 0u32
    while b2 < n { valuate(b2)  VAL_A[b2 as u64] = VOUT_A[0u64]  VAL_S[b2 as u64] = VOUT_S[0u64]  VAL_L[b2 as u64] = VOUT_L[0u64]  b2 = b2 + 1u32 }
    return 0i32
}

/* improve_sigma: VJ outer loop -- improve Even's sigma against Odd's best response until no Even switch helps.
 * returns Even's winning region (vertices whose final valuation anchor is EVEN). */
fn improve_sigma() -> u32 {
    let n : u32 = nv()  let mut v : u32 = 0u32
    while v < n { if OWN[v as u64] == 0u8 { CHOICE[v as u64] = low_succ(v) }  v = v + 1u32 }
    ROUNDS[0u64] = 0u32
    let mut improving : u8 = 1u8
    while improving == 1u8 {
        evaluate_sigma()
        improving = 0u8
        let mut x : u32 = 0u32
        while x < n {
            if OWN[x as u64] == 0u8 {
                let base : u32 = CHOICE[x as u64]
                let mut bw : u32 = base  let mut bA : u32 = VAL_A[x as u64]  let mut bS : u32 = VAL_S[x as u64]  let mut bL : u32 = VAL_L[x as u64]
                let mut w : u32 = 0u32
                while w < n {
                    if (SUC0[x as u64] & (1u32 << w)) != 0u32 {
                        STRAT[x as u64] = w  valuate(x)
                        if cmp_even(VOUT_A[0u64], VOUT_S[0u64], VOUT_L[0u64], bA, bS, bL) > 0i32 { bw = w  bA = VOUT_A[0u64]  bS = VOUT_S[0u64]  bL = VOUT_L[0u64] }
                    }
                    w = w + 1u32
                }
                STRAT[x as u64] = base
                NEWCH[x as u64] = bw
            }
            x = x + 1u32
        }
        let mut k : u32 = 0u32
        while k < n { if OWN[k as u64] == 0u8 { if NEWCH[k as u64] != CHOICE[k as u64] { CHOICE[k as u64] = NEWCH[k as u64]  improving = 1u8 } }  k = k + 1u32 }
        ROUNDS[0u64] = ROUNDS[0u64] + 1u32
    }
    evaluate_sigma()
    let mut reg : u32 = 0u32  let mut v2 : u32 = 0u32
    while v2 < n { if (VAL_A[v2 as u64] & 1u32) == 0u32 { reg = reg | (1u32 << v2) }  v2 = v2 + 1u32 }
    return reg
}

fn main() -> u64 {
    RNG[0u64] = 0x12345678u32
    let n : u32 = 8u32
    let mut trials : u32 = 0u32
    let mut matched : u32 = 0u32
    let mut maxr : u32 = 0u32
    while trials < 80u32 {
        gen_game(n)
        let mut v : u32 = 0u32
        while v < n { SUC[v as u64] = SUC0[v as u64]  v = v + 1u32 }
        let r : u64 = zielonka(fullmask())
        let truth : u32 = (r & 0xFFFFFFFFu64) as u32
        let got : u32 = improve_sigma()
        if got == truth { matched = matched + 1u32 }
        if ROUNDS[0u64] > maxr { maxr = ROUNDS[0u64] }
        trials = trials + 1u32
    }
    if matched == 80u32 { return 99u64 }   /* VJ SI is COMPLETE -- the local optima of greedy SI (1840) are gone */
    return matched as u64
}
