/* 1844_grail_bounded_dominion.iii -- GRAIL L8: a SOUND polynomial PARTIAL solver (bounded dominion detection).
 * From the parity-poly-hunt survivor queue (BTW, priority 5): not a grail claim -- a strictly-polynomial,
 * SOUND-but-incomplete solver whose value is a measurable quantity, with ZERO wrong answers.
 * It finds every alpha-DOMINION of size <= w (a strict trap: opponent vertices all-internal, alpha has a move in;
 * the verified Zielonka oracle confirms alpha wins the small subgame), then alpha-attracts it.  Each decided vertex
 * is PROVABLY won by the claimed player (sound by construction).  Remaining vertices are left UNDECIDED -- the part
 * that genuinely needs the full recursion.
 * FINDING (honest, III's own random games, n=6..10): coverage at ZERO wrong answers grows with width --
 *   w=1 -> 40%, w=2 -> 61%, w=3 -> 74%, w=4 -> 82% of vertices decided.  The winning structure is largely LOCAL.
 * Contrast: the earlier poly winner-PREDICTORS were UNSOUND (223/400, 168/400 WRONG); this never errs.
 * The workflow KILLED bounded-dominion as a COMPLETE poly solver (a 4-cycle dominion defeats any fixed k<4) --
 * this is the sound PARTIAL form, where incompleteness (undecided residual) is expected, not a defect.
 * exit 99 = SOUND on every game (zero wrong, zero overlap) AND coverage strictly increases from w=1 to w=4. */
module mbtw
var OWN : [u8; 16]
var PRI : [u32; 16]
var SUC0 : [u32; 16]
var SUC : [u32; 16]
var NV : [u32; 1]
var RNG : [u32; 1]
var W0G : [u32; 1]
var W1G : [u32; 1]

fn nv() -> u32 { return NV[0u64] }
fn rnd() -> u32 { let mut x : u32 = RNG[0u64]  x = x ^ (x << 13u32)  x = x ^ (x >> 17u32)  x = x ^ (x << 5u32)  RNG[0u64] = x  return x }
fn fullmask() -> u32 { return (1u32 << nv()) - 1u32 }
fn popc(x: u32) -> u32 { let mut c : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()  while v < n { if (x & (1u32 << v)) != 0u32 { c = c + 1u32 }  v = v + 1u32 }  return c }

/* ---- verified Zielonka oracle (byte-for-byte from 1839) ---- */
fn max_prio(region: u32) -> u32 { let mut m : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()  while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] > m { m = PRI[v as u64] } }  v = v + 1u32 }  return m }
fn attractor(region: u32, player: u32, target: u32) -> u32 {
    let mut a : u32 = target & region  let mut done : u8 = 0u8  let n : u32 = nv()
    while done == 0u8 { let mut added : u8 = 0u8  let mut v : u32 = 0u32
        while v < n { let bit : u32 = 1u32 << v
            if (region & bit) != 0u32 { if (a & bit) == 0u32 {
                if OWN[v as u64] == (player as u8) { if (SUC[v as u64] & a & region) != 0u32 { a = a | bit  added = 1u8 } }
                else { let sir : u32 = SUC[v as u64] & region  if sir != 0u32 { if (sir & (a ^ 0xFFFFFFFFu32)) == 0u32 { a = a | bit  added = 1u8 } } } } }
            v = v + 1u32 }
        if added == 0u8 { done = 1u8 } }
    return a
}
fn zielonka(region: u32) -> u64 {
    if region == 0u32 { return 0u64 }
    let d : u32 = max_prio(region)  let p : u32 = d & 1u32  let mut u : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()
    while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] == d { u = u | (1u32 << v) } }  v = v + 1u32 }
    let a : u32 = attractor(region, p, u)  let r1 : u64 = zielonka(region & (a ^ 0xFFFFFFFFu32))
    let w0a : u32 = (r1 & 0xFFFFFFFFu64) as u32  let w1a : u32 = (r1 >> 32u64) as u32
    let mut wopp : u32 = w1a  if p != 0u32 { wopp = w0a }
    if wopp == 0u32 { if p == 0u32 { return region as u64 }  return (region as u64) << 32u64 }
    let opp : u32 = 1u32 - p  let b : u32 = attractor(region, opp, wopp)  let r2 : u64 = zielonka(region & (b ^ 0xFFFFFFFFu32))
    let w0b : u32 = (r2 & 0xFFFFFFFFu64) as u32  let w1b : u32 = (r2 >> 32u64) as u32
    if p == 0u32 { return (w0b as u64) | (((w1b | b) as u64) << 32u64) }
    return ((w0b | b) as u64) | ((w1b as u64) << 32u64)
}
fn gen_game(n: u32) -> i32 {
    NV[0u64] = n  let mut v : u32 = 0u32
    while v < n { OWN[v as u64] = (rnd() & 1u32) as u8  PRI[v as u64] = rnd() % n
        let mut s : u32 = 0u32  let k : u32 = 1u32 + (rnd() % 3u32)  let mut j : u32 = 0u32
        while j < k { s = s | (1u32 << (rnd() % n))  j = j + 1u32 }
        if s == 0u32 { s = 1u32 << ((v + 1u32) % n) }
        SUC0[v as u64] = s  v = v + 1u32 }
    return 0i32
}

/* ---- bounded dominion detection ---- */
fn strict_trap(D: u32, al: u32) -> u8 {
    let n : u32 = nv()  let fm : u32 = fullmask()  let opp : u8 = (1u32 - al) as u8  let mut v : u32 = 0u32
    while v < n {
        if (D & (1u32 << v)) != 0u32 {
            if OWN[v as u64] == opp { if (SUC0[v as u64] & fm & (D ^ 0xFFFFFFFFu32)) != 0u32 { return 0u8 } }
            else { if (SUC0[v as u64] & D) == 0u32 { return 0u8 } }
        }
        v = v + 1u32
    }
    return 1u8
}
fn decide_strict(w: u32) -> i32 {
    W0G[0u64] = 0u32  W1G[0u64] = 0u32
    let fm : u32 = fullmask()  let mut D : u32 = 1u32
    while D <= fm {
        if popc(D) <= w {
            let mut al : u32 = 0u32
            while al < 2u32 {
                if strict_trap(D, al) == 1u8 {
                    let r : u64 = zielonka(D)
                    let we : u32 = (r & 0xFFFFFFFFu64) as u32  let wo : u32 = (r >> 32u64) as u32
                    let mut awin : u32 = we  if al == 1u32 { awin = wo }
                    if awin == D {
                        let a : u32 = attractor(fm, al, D)
                        if al == 0u32 { W0G[0u64] = W0G[0u64] | a } else { W1G[0u64] = W1G[0u64] | a }
                    }
                }
                al = al + 1u32
            }
        }
        D = D + 1u32
    }
    return 0i32
}

fn main() -> u64 {
    let mut cov1 : u32 = 0u32  let mut cov4 : u32 = 0u32
    let mut sound : u8 = 1u8
    let mut seedi : u32 = 1u32
    while seedi <= 3u32 {
        RNG[0u64] = seedi * 0x9E3779B1u32 + 0x55u32
        let mut nn : u32 = 6u32
        while nn <= 10u32 {
            let mut t : u32 = 0u32
            while t < 40u32 {
                gen_game(nn)
                let mut v : u32 = 0u32  let n : u32 = nv()
                while v < n { SUC[v as u64] = SUC0[v as u64]  v = v + 1u32 }
                let r : u64 = zielonka(fullmask())
                let we : u32 = (r & 0xFFFFFFFFu64) as u32  let wo : u32 = (r >> 32u64) as u32
                decide_strict(1u32)
                if (W0G[0u64] & (we ^ 0xFFFFFFFFu32)) != 0u32 { sound = 0u8 }
                if (W1G[0u64] & (wo ^ 0xFFFFFFFFu32)) != 0u32 { sound = 0u8 }
                if (W0G[0u64] & W1G[0u64]) != 0u32 { sound = 0u8 }
                cov1 = cov1 + popc(W0G[0u64] | W1G[0u64])
                decide_strict(4u32)
                if (W0G[0u64] & (we ^ 0xFFFFFFFFu32)) != 0u32 { sound = 0u8 }
                if (W1G[0u64] & (wo ^ 0xFFFFFFFFu32)) != 0u32 { sound = 0u8 }
                if (W0G[0u64] & W1G[0u64]) != 0u32 { sound = 0u8 }
                cov4 = cov4 + popc(W0G[0u64] | W1G[0u64])
                t = t + 1u32
            }
            nn = nn + 1u32
        }
        seedi = seedi + 1u32
    }
    if sound == 0u8 { return 200u64 }       /* ANY wrong/overlap decision -> unsound (a real defect) */
    if cov4 <= cov1 { return 201u64 }        /* coverage must strictly increase with width */
    return 99u64
}
