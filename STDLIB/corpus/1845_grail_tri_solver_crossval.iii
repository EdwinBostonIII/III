/* 1845_grail_tri_solver_crossval.iii -- GRAIL L8: a standing CROSS-FAMILY agreement guard.
 * Runs THREE independent complete parity-game solvers from DIFFERENT algorithmic families on the same games and
 * asserts all three compute the identical Even-winning region:
 *   (1) ZIELONKA  -- recursive attractor decomposition (1839)
 *   (2) VJ SI     -- Voge-Jurdzinski play-profile strategy improvement (1841)
 *   (3) SPM       -- Jurdzinski small progress measures, mixed-radix encoded (1843)
 * Three independent algorithms agreeing on every game is strong evidence all three (and the oracle role they share)
 * are correct -- a regression guard far stronger than any single solver's self-test.
 * exit 99 = all three agree on EVERY game across the sweep (3 seeds x sizes 5..11). A disagreement returns the
 * offending pair code (10 = SI != Zielonka, 11 = SPM != Zielonka). */
module mxv
var OWN : [u8; 16]
var PRI : [u32; 16]
var SUC0 : [u32; 16]
var SUC : [u32; 16]
var NV : [u32; 1]
var RNG : [u32; 1]
/* SI state */
var STRAT : [u32; 16]
var CHOICE : [u32; 16]
var TAU : [u32; 16]
var NEWCH : [u32; 16]
var NEWTAU : [u32; 16]
var VAL_A : [u32; 16]
var VAL_S : [u32; 16]
var VAL_L : [u32; 16]
var VOUT_A : [u32; 1]
var VOUT_S : [u32; 1]
var VOUT_L : [u32; 1]
var SEEN : [u32; 16]
var WALK : [u32; 16]
var ROUNDS : [u32; 1]
var STUCK : [u32; 1]
/* SPM state */
var M : [u64; 16]
var BOUND : [u32; 16]
var WEIGHT : [u64; 16]
var KEEPW : [u64; 16]
var TOPM : [u64; 1]
var LIFTS : [u32; 1]

fn nv() -> u32 { return NV[0u64] }
fn rnd() -> u32 { let mut x : u32 = RNG[0u64]  x = x ^ (x << 13u32)  x = x ^ (x >> 17u32)  x = x ^ (x << 5u32)  RNG[0u64] = x  return x }
fn fullmask() -> u32 { return (1u32 << nv()) - 1u32 }
fn low_succ(v: u32) -> u32 { let mut w : u32 = 0u32  let n : u32 = nv()  while w < n { if (SUC0[v as u64] & (1u32 << w)) != 0u32 { return w }  w = w + 1u32 }  return 0u32 }

/* ---- (1) Zielonka oracle ---- */
fn max_prio(region: u32) -> u32 { let mut m : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()  while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] > m { m = PRI[v as u64] } }  v = v + 1u32 }  return m }
fn attractor(region: u32, player: u32, target: u32) -> u32 {
    let mut a : u32 = target & region  let mut done : u8 = 0u8  let n : u32 = nv()
    while done == 0u8 { let mut added : u8 = 0u8  let mut v : u32 = 0u32
        while v < n { let bit : u32 = 1u32 << v
            if (region & bit) != 0u32 { if (a & bit) == 0u32 {
                if OWN[v as u64] == (player as u8) { if (SUC[v as u64] & a & region) != 0u32 { a = a | bit  added = 1u8 } }
                else { let sir : u32 = SUC[v as u64] & region  if sir != 0u32 { if (sir & (a ^ 0xFFFFFFFFu32)) == 0u32 { a = a | bit  added = 1u8 } } } } }
            v = v + 1u32 }
        if added == 0u8 { done = 1u8 } }
    return a
}
fn zielonka(region: u32) -> u64 {
    if region == 0u32 { return 0u64 }
    let d : u32 = max_prio(region)  let p : u32 = d & 1u32  let mut u : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()
    while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] == d { u = u | (1u32 << v) } }  v = v + 1u32 }
    let a : u32 = attractor(region, p, u)  let r1 : u64 = zielonka(region & (a ^ 0xFFFFFFFFu32))
    let w0a : u32 = (r1 & 0xFFFFFFFFu64) as u32  let w1a : u32 = (r1 >> 32u64) as u32
    let mut wopp : u32 = w1a  if p != 0u32 { wopp = w0a }
    if wopp == 0u32 { if p == 0u32 { return region as u64 }  return (region as u64) << 32u64 }
    let opp : u32 = 1u32 - p  let b : u32 = attractor(region, opp, wopp)  let r2 : u64 = zielonka(region & (b ^ 0xFFFFFFFFu32))
    let w0b : u32 = (r2 & 0xFFFFFFFFu64) as u32  let w1b : u32 = (r2 >> 32u64) as u32
    if p == 0u32 { return (w0b as u64) | (((w1b | b) as u64) << 32u64) }
    return ((w0b | b) as u64) | ((w1b as u64) << 32u64)
}
fn gen_game(n: u32) -> i32 {
    NV[0u64] = n  let mut v : u32 = 0u32
    while v < n { OWN[v as u64] = (rnd() & 1u32) as u8  PRI[v as u64] = rnd() % n
        let mut s : u32 = 0u32  let k : u32 = 1u32 + (rnd() % 3u32)  let mut j : u32 = 0u32
        while j < k { s = s | (1u32 << (rnd() % n))  j = j + 1u32 }
        if s == 0u32 { s = 1u32 << ((v + 1u32) % n) }
        SUC0[v as u64] = s  v = v + 1u32 }
    return 0i32
}

/* ---- (2) VJ strategy improvement ---- */
fn more_relevant(a: u32, b: u32) -> u8 {
    if PRI[a as u64] > PRI[b as u64] { return 1u8 }
    if PRI[a as u64] < PRI[b as u64] { return 0u8 }
    if a > b { return 1u8 }
    return 0u8
}
fn most_relevant_in_mask(mask: u32) -> u32 {
    let n : u32 = nv()  let mut best : u32 = 0u32  let mut have : u8 = 0u8  let mut v : u32 = 0u32
    while v < n { if (mask & (1u32 << v)) != 0u32 { if have == 0u8 { best = v  have = 1u8 } else { if more_relevant(v, best) == 1u8 { best = v } } }  v = v + 1u32 }
    return best
}
fn valuate(start: u32) -> i32 {
    let n : u32 = nv()  let mut i : u32 = 0u32
    while i < n { SEEN[i as u64] = 254u32  i = i + 1u32 }
    let mut cur : u32 = start  let mut step : u32 = 0u32
    while SEEN[cur as u64] == 254u32 { SEEN[cur as u64] = step  WALK[step as u64] = cur  cur = STRAT[cur as u64]  step = step + 1u32 }
    let cs : u32 = SEEN[cur as u64]
    let mut l : u32 = WALK[cs as u64]  let mut j : u32 = cs
    while j < step { let vtx : u32 = WALK[j as u64]  if more_relevant(vtx, l) == 1u8 { l = vtx }  j = j + 1u32 }
    let mut c2 : u32 = start  let mut len : u32 = 0u32  let mut set : u32 = 0u32
    while c2 != l { if more_relevant(c2, l) == 1u8 { set = set | (1u32 << c2) }  c2 = STRAT[c2 as u64]  len = len + 1u32 }
    VOUT_A[0u64] = l  VOUT_S[0u64] = set  VOUT_L[0u64] = len
    return 0i32
}
fn cmp_even(aL: u32, aS: u32, aLen: u32, bL: u32, bS: u32, bLen: u32) -> i32 {
    if aL != bL {
        let mut m : u32 = bL  let mut m_is_a : u8 = 0u8
        if more_relevant(aL, bL) == 1u8 { m = aL  m_is_a = 1u8 }
        if (PRI[m as u64] & 1u32) == 0u32 { if m_is_a == 1u8 { return 1i32 }  return -1i32 }
        if m_is_a == 1u8 { return -1i32 }
        return 1i32
    }
    let dif : u32 = aS ^ bS
    if dif != 0u32 {
        let d : u32 = most_relevant_in_mask(dif)
        let mut inA : u8 = 0u8  if (aS & (1u32 << d)) != 0u32 { inA = 1u8 }
        if (PRI[d as u64] & 1u32) == 0u32 { if inA == 1u8 { return 1i32 }  return -1i32 }
        if inA == 1u8 { return -1i32 }
        return 1i32
    }
    if (PRI[aL as u64] & 1u32) == 0u32 { if aLen < bLen { return 1i32 }  if aLen > bLen { return -1i32 }  return 0i32 }
    if aLen > bLen { return 1i32 }  if aLen < bLen { return -1i32 }  return 0i32
}
fn set_profile() -> i32 { let n : u32 = nv()  let mut v : u32 = 0u32
    while v < n { if OWN[v as u64] == 0u8 { STRAT[v as u64] = CHOICE[v as u64] } else { STRAT[v as u64] = TAU[v as u64] }  v = v + 1u32 }  return 0i32 }
fn evaluate_sigma() -> i32 {
    let n : u32 = nv()  let mut v : u32 = 0u32
    while v < n { if OWN[v as u64] == 1u8 { TAU[v as u64] = low_succ(v) }  v = v + 1u32 }
    let mut improving : u8 = 1u8  let mut guard : u32 = 0u32
    while improving == 1u8 {
        guard = guard + 1u32  if guard > 4096u32 { STUCK[0u64] = 1u32  improving = 0u8 }
        if improving == 1u8 {
            set_profile()
            let mut a : u32 = 0u32
            while a < n { valuate(a)  VAL_A[a as u64] = VOUT_A[0u64]  VAL_S[a as u64] = VOUT_S[0u64]  VAL_L[a as u64] = VOUT_L[0u64]  a = a + 1u32 }
            improving = 0u8
            let mut u : u32 = 0u32
            while u < n {
                if OWN[u as u64] == 1u8 {
                    let base : u32 = TAU[u as u64]
                    let mut bw : u32 = base  let mut bA : u32 = VAL_A[u as u64]  let mut bS : u32 = VAL_S[u as u64]  let mut bL : u32 = VAL_L[u as u64]
                    let mut w : u32 = 0u32
                    while w < n {
                        if (SUC0[u as u64] & (1u32 << w)) != 0u32 {
                            STRAT[u as u64] = w  valuate(u)
                            if cmp_even(VOUT_A[0u64], VOUT_S[0u64], VOUT_L[0u64], bA, bS, bL) < 0i32 { bw = w  bA = VOUT_A[0u64]  bS = VOUT_S[0u64]  bL = VOUT_L[0u64] }
                        }
                        w = w + 1u32
                    }
                    STRAT[u as u64] = base
                    NEWTAU[u as u64] = bw
                }
                u = u + 1u32
            }
            let mut k : u32 = 0u32
            while k < n { if OWN[k as u64] == 1u8 { if NEWTAU[k as u64] != TAU[k as u64] { TAU[k as u64] = NEWTAU[k as u64]  improving = 1u8 } }  k = k + 1u32 }
        }
    }
    set_profile()
    let mut b2 : u32 = 0u32
    while b2 < n { valuate(b2)  VAL_A[b2 as u64] = VOUT_A[0u64]  VAL_S[b2 as u64] = VOUT_S[0u64]  VAL_L[b2 as u64] = VOUT_L[0u64]  b2 = b2 + 1u32 }
    return 0i32
}
fn improve_sigma() -> u32 {
    let n : u32 = nv()  let mut v : u32 = 0u32
    while v < n { if OWN[v as u64] == 0u8 { CHOICE[v as u64] = low_succ(v) }  v = v + 1u32 }
    ROUNDS[0u64] = 0u32
    let mut improving : u8 = 1u8
    while improving == 1u8 {
        if ROUNDS[0u64] > 4096u32 { STUCK[0u64] = 1u32  improving = 0u8 }
        if improving == 1u8 {
            evaluate_sigma()
            improving = 0u8
            let mut x : u32 = 0u32
            while x < n {
                if OWN[x as u64] == 0u8 {
                    let base : u32 = CHOICE[x as u64]
                    let mut bw : u32 = base  let mut bA : u32 = VAL_A[x as u64]  let mut bS : u32 = VAL_S[x as u64]  let mut bL : u32 = VAL_L[x as u64]
                    let mut w : u32 = 0u32
                    while w < n {
                        if (SUC0[x as u64] & (1u32 << w)) != 0u32 {
                            STRAT[x as u64] = w  valuate(x)
                            if cmp_even(VOUT_A[0u64], VOUT_S[0u64], VOUT_L[0u64], bA, bS, bL) > 0i32 { bw = w  bA = VOUT_A[0u64]  bS = VOUT_S[0u64]  bL = VOUT_L[0u64] }
                        }
                        w = w + 1u32
                    }
                    STRAT[x as u64] = base
                    NEWCH[x as u64] = bw
                }
                x = x + 1u32
            }
            let mut k : u32 = 0u32
            while k < n { if OWN[k as u64] == 0u8 { if NEWCH[k as u64] != CHOICE[k as u64] { CHOICE[k as u64] = NEWCH[k as u64]  improving = 1u8 } }  k = k + 1u32 }
            ROUNDS[0u64] = ROUNDS[0u64] + 1u32
        }
    }
    evaluate_sigma()
    let mut reg : u32 = 0u32  let mut v2 : u32 = 0u32
    while v2 < n { if (PRI[VAL_A[v2 as u64] as u64] & 1u32) == 0u32 { reg = reg | (1u32 << v2) }  v2 = v2 + 1u32 }
    return reg
}

/* ---- (3) Small Progress Measures ---- */
fn spm_setup() -> i32 {
    let n : u32 = nv()
    let mut q : u32 = 0u32
    while q < 16u32 { BOUND[q as u64] = 0u32  WEIGHT[q as u64] = 0u64  KEEPW[q as u64] = 0u64  q = q + 1u32 }
    let mut v : u32 = 0u32
    while v < n { let p : u32 = PRI[v as u64]  BOUND[p as u64] = BOUND[p as u64] + 1u32  v = v + 1u32 }
    let d : u32 = max_prio(fullmask())
    let mut acc : u64 = 1u64
    let mut oq : u32 = 1u32
    while oq <= d { WEIGHT[oq as u64] = acc  acc = acc * ((BOUND[oq as u64] as u64) + 1u64)  oq = oq + 2u32 }
    TOPM[0u64] = acc
    let mut qq : u32 = 0u32
    while qq <= d {
        let mut kw : u64 = TOPM[0u64]
        let mut o : u32 = qq + 1u32
        if (o & 1u32) == 0u32 { o = o + 1u32 }
        let mut foundo : u8 = 0u8
        while o <= d { if foundo == 0u8 { kw = WEIGHT[o as u64]  foundo = 1u8 }  o = o + 2u32 }
        KEEPW[qq as u64] = kw
        qq = qq + 1u32
    }
    return 0i32
}
fn prog(mw: u64, p: u32) -> u64 {
    if mw >= TOPM[0u64] { return TOPM[0u64] }
    if (p & 1u32) == 0u32 {
        let kw : u64 = KEEPW[p as u64]
        return (mw / kw) * kw
    }
    let wp : u64 = WEIGHT[p as u64]
    let base : u64 = (mw / wp) * wp
    let res : u64 = base + wp
    if res >= TOPM[0u64] { return TOPM[0u64] }
    return res
}
fn spm_solve() -> u32 {
    let n : u32 = nv()  let mut v : u32 = 0u32
    while v < n { M[v as u64] = 0u64  v = v + 1u32 }
    LIFTS[0u64] = 0u32
    let mut changed : u8 = 1u8
    while changed == 1u8 {
        changed = 0u8
        let mut x : u32 = 0u32
        while x < n {
            let p : u32 = PRI[x as u64]
            let mut first : u8 = 1u8  let mut best : u64 = 0u64
            let mut w : u32 = 0u32
            while w < n {
                if (SUC0[x as u64] & (1u32 << w)) != 0u32 {
                    let pr : u64 = prog(M[w as u64], p)
                    if first == 1u8 { best = pr  first = 0u8 } else {
                        if OWN[x as u64] == 0u8 { if pr < best { best = pr } } else { if pr > best { best = pr } }
                    }
                }
                w = w + 1u32
            }
            if best > M[x as u64] { M[x as u64] = best  changed = 1u8  LIFTS[0u64] = LIFTS[0u64] + 1u32 }
            x = x + 1u32
        }
    }
    let mut reg : u32 = 0u32  let mut v2 : u32 = 0u32
    while v2 < n { if M[v2 as u64] < TOPM[0u64] { reg = reg | (1u32 << v2) }  v2 = v2 + 1u32 }
    return reg
}

fn main() -> u64 {
    STUCK[0u64] = 0u32
    let mut seedi : u32 = 1u32
    while seedi <= 3u32 {
        RNG[0u64] = seedi * 0x9E3779B1u32 + 0x99u32
        let mut nn : u32 = 5u32
        while nn <= 11u32 {
            let mut t : u32 = 0u32
            while t < 60u32 {
                gen_game(nn)
                let mut v : u32 = 0u32  let n : u32 = nv()
                while v < n { SUC[v as u64] = SUC0[v as u64]  v = v + 1u32 }
                let r : u64 = zielonka(fullmask())
                let zwin : u32 = (r & 0xFFFFFFFFu64) as u32
                let siwin : u32 = improve_sigma()
                if siwin != zwin { return 10u64 }
                spm_setup()
                let spmwin : u32 = spm_solve()
                if spmwin != zwin { return 11u64 }
                t = t + 1u32
            }
            nn = nn + 1u32
        }
        seedi = seedi + 1u32
    }
    if STUCK[0u64] != 0u32 { return 12u64 }
    return 99u64
}
