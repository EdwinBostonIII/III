/* SHA-256 message-schedule bit-identity: scalar == AVX-512.
 *
 * RITCHIE §3.5 kernel 9/10.  SHA-256("abc") runs the full 48-word
 * message schedule.  Computes the digest twice -- force scalar sigma0
 * (sha256_sched_force(1)) and force AVX-512 sigma0 (force(2)) -- and
 * asserts the two digests are byte-identical AND equal the FIPS 180-4
 * SHA-256("abc") vector.
 *
 * Exit = 88 on full success.
 */
module corpus_184

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn sha256_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn sha256_sched_force(p: u32) -> u32 from "sha256.iii"

fn check_abc(r: *u8) -> u64 {
    /* SHA-256("abc") = ba7816bf 8f01cfea 414140de 5dae2223
     *                  b00361a3 96177a9c b410ff61 f20015ad */
    if r[0]  != 0xBAu8 { return 1u64 }
    if r[1]  != 0x78u8 { return 2u64 }
    if r[2]  != 0x16u8 { return 3u64 }
    if r[3]  != 0xBFu8 { return 4u64 }
    if r[4]  != 0x8Fu8 { return 5u64 }
    if r[5]  != 0x01u8 { return 6u64 }
    if r[6]  != 0xCFu8 { return 7u64 }
    if r[7]  != 0xEAu8 { return 8u64 }
    if r[8]  != 0x41u8 { return 9u64 }
    if r[9]  != 0x41u8 { return 10u64 }
    if r[10] != 0x40u8 { return 11u64 }
    if r[11] != 0xDEu8 { return 12u64 }
    if r[12] != 0x5Du8 { return 13u64 }
    if r[13] != 0xAEu8 { return 14u64 }
    if r[14] != 0x22u8 { return 15u64 }
    if r[15] != 0x23u8 { return 16u64 }
    if r[16] != 0xB0u8 { return 17u64 }
    if r[17] != 0x03u8 { return 18u64 }
    if r[18] != 0x61u8 { return 19u64 }
    if r[19] != 0xA3u8 { return 20u64 }
    if r[20] != 0x96u8 { return 21u64 }
    if r[21] != 0x17u8 { return 22u64 }
    if r[22] != 0x7Au8 { return 23u64 }
    if r[23] != 0x9Cu8 { return 24u64 }
    if r[24] != 0xB4u8 { return 25u64 }
    if r[25] != 0x10u8 { return 26u64 }
    if r[26] != 0xFFu8 { return 27u64 }
    if r[27] != 0x61u8 { return 28u64 }
    if r[28] != 0xF2u8 { return 29u64 }
    if r[29] != 0x00u8 { return 30u64 }
    if r[30] != 0x15u8 { return 31u64 }
    if r[31] != 0xADu8 { return 32u64 }
    return 0u64
}

fn main() -> u64 {
    let msg   : *u8 = malloc(3u64)
    let out_s : *u8 = malloc(32u64)
    let out_a : *u8 = malloc(32u64)
    msg[0] = 0x61u8  /* 'a' */
    msg[1] = 0x62u8  /* 'b' */
    msg[2] = 0x63u8  /* 'c' */

    sha256_sched_force(1u32)
    sha256_oneshot(msg, 3u64, out_s)
    sha256_sched_force(2u32)
    sha256_oneshot(msg, 3u64, out_a)
    sha256_sched_force(0u32)

    let mut i : u64 = 0u64
    while i < 32u64 {
        if out_s[i] != out_a[i] { return 1u64 + i }
        i = i + 1u64
    }
    let kat_err : u64 = check_abc(out_s)
    if kat_err != 0u64 { return 40u64 + kat_err }

    free(msg); free(out_s); free(out_a)
    return 88u64
}
