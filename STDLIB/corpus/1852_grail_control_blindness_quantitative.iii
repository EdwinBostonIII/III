/* 1852_grail_control_blindness_quantitative.iii -- FORMAL WALL, T2' (quantitative control-blindness; EMPIRICAL).
 *
 * OBSERVATION (T2', empirical -- NOT a proven asymptotic theorem; honest tagging).  A fixed CONTROL-FREE graph
 * invariant -- here the "max reachable-cycle priority" predictor f(v) = [max priority on a cycle reachable from v is
 * even] (a function of (V,E,pr) ALONE, the honest poly degenerate of the homology/zeta/spectral/Euler/cocycle family)
 * -- has per-vertex agreement with the true parity winner that DECREASES monotonically as the game grows: measured
 * 82% (n=4) -> 70% (n=10) -> 65% (n=14) on this sample.  SCOPE: this is ONE predictor, three sizes, one RNG seed; it
 * establishes a monotone DECREASE of accuracy with size, NOT that the limit is exactly 1/2 (65% at n=14 could
 * plausibly asymptote above 50%).  The exact-witness barrier (T2, KAT 1848) carries the actual proof; T2' is the
 * empirical decay that accompanies it.
 *
 * SIGNIFICANCE.  Quantitative colour on the Class-I death (DOCS/III-PARITY-WALL-FORMAL.md, Sec 4): a graph-invariant
 * is not only wrong on a witness (T2) but loses accuracy as branching grows -- consistent with the parity-novel-invent
 * referees' (un-reproven) claim that the control-free signed zeta self-decays toward ~50%.
 *
 * VERIFICATION.  For n = 4,10,14, over many random games each: measure the predictor's per-vertex agreement with the
 * Zielonka oracle (1839).  Assert MONOTONE DECREASE (a4 > a10 > a14) with a strong signal at small n (a4 >= 75) and
 * clear decay at scale (a14 <= 68).  No claim is made about the n->infinity limit.
 * exit 99 = the control-free invariant's accuracy decreases monotonically with n on this sample. */
module mcbq
var OWN : [u8; 16]
var PRI : [u32; 16]
var SUC0 : [u32; 16]
var SUC : [u32; 16]
var NV : [u32; 1]
var RNG : [u32; 1]

fn nv() -> u32 { return NV[0u64] }
fn rnd() -> u32 { let mut x : u32 = RNG[0u64]  x = x ^ (x << 13u32)  x = x ^ (x >> 17u32)  x = x ^ (x << 5u32)  RNG[0u64] = x  return x }
fn fullmask() -> u32 { return (1u32 << nv()) - 1u32 }

/* ---- Zielonka oracle (1839) ---- */
fn max_prio(region: u32) -> u32 { let mut m : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()  while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] > m { m = PRI[v as u64] } }  v = v + 1u32 }  return m }
fn attractor(region: u32, player: u32, target: u32) -> u32 {
    let mut a : u32 = target & region  let mut done : u8 = 0u8  let n : u32 = nv()
    while done == 0u8 { let mut added : u8 = 0u8  let mut v : u32 = 0u32
        while v < n { let bit : u32 = 1u32 << v
            if (region & bit) != 0u32 { if (a & bit) == 0u32 {
                if OWN[v as u64] == (player as u8) { if (SUC[v as u64] & a & region) != 0u32 { a = a | bit  added = 1u8 } }
                else { let sir : u32 = SUC[v as u64] & region  if sir != 0u32 { if (sir & (a ^ 0xFFFFFFFFu32)) == 0u32 { a = a | bit  added = 1u8 } } } } }
            v = v + 1u32 }
        if added == 0u8 { done = 1u8 } }
    return a
}
fn zielonka(region: u32) -> u64 {
    if region == 0u32 { return 0u64 }
    let d : u32 = max_prio(region)  let p : u32 = d & 1u32  let mut u : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()
    while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] == d { u = u | (1u32 << v) } }  v = v + 1u32 }
    let a : u32 = attractor(region, p, u)  let r1 : u64 = zielonka(region & (a ^ 0xFFFFFFFFu32))
    let w0a : u32 = (r1 & 0xFFFFFFFFu64) as u32  let w1a : u32 = (r1 >> 32u64) as u32
    let mut wopp : u32 = w1a  if p != 0u32 { wopp = w0a }
    if wopp == 0u32 { if p == 0u32 { return region as u64 }  return (region as u64) << 32u64 }
    let opp : u32 = 1u32 - p  let b : u32 = attractor(region, opp, wopp)  let r2 : u64 = zielonka(region & (b ^ 0xFFFFFFFFu32))
    let w0b : u32 = (r2 & 0xFFFFFFFFu64) as u32  let w1b : u32 = (r2 >> 32u64) as u32
    if p == 0u32 { return (w0b as u64) | (((w1b | b) as u64) << 32u64) }
    return ((w0b | b) as u64) | ((w1b as u64) << 32u64)
}
fn reach_from(start: u32) -> u32 {
    let n : u32 = nv()  let mut R : u32 = start  let mut done : u8 = 0u8
    while done == 0u8 { let mut add : u32 = 0u32  let mut v : u32 = 0u32
        while v < n { if (R & (1u32 << v)) != 0u32 { add = add | SUC0[v as u64] }  v = v + 1u32 }
        let nr : u32 = R | add  if nr == R { done = 1u8 } else { R = nr } }
    return R
}
fn on_cycle(u: u32) -> u8 { let r : u32 = reach_from(SUC0[u as u64])  if (r & (1u32 << u)) != 0u32 { return 1u8 }  return 0u8 }
/* control-free predictor f(v): 1 iff max priority on a cycle reachable from v is EVEN */
fn predict_even(r: u32) -> u8 {
    let reach : u32 = reach_from(1u32 << r)  let n : u32 = nv()  let mut m : u32 = 0u32  let mut v : u32 = 0u32
    while v < n { if (reach & (1u32 << v)) != 0u32 { if on_cycle(v) == 1u8 { if PRI[v as u64] > m { m = PRI[v as u64] } } }  v = v + 1u32 }
    if (m & 1u32) == 0u32 { return 1u8 }  return 0u8
}
fn gen_game(n: u32) -> i32 {
    NV[0u64] = n  let mut v : u32 = 0u32
    while v < n { OWN[v as u64] = (rnd() & 1u32) as u8  PRI[v as u64] = rnd() % n
        let mut s : u32 = 0u32  let kk : u32 = 1u32 + (rnd() % 3u32)  let mut j : u32 = 0u32
        while j < kk { s = s | (1u32 << (rnd() % n))  j = j + 1u32 }
        if s == 0u32 { s = 1u32 << ((v + 1u32) % n) }
        SUC0[v as u64] = s  v = v + 1u32 }
    return 0i32
}
/* per-vertex agreement percentage of the control-free predictor vs the oracle, over G games at size n */
fn accuracy_pct(n: u32, games: u32) -> u32 {
    let mut agree : u32 = 0u32  let mut total : u32 = 0u32  let mut g : u32 = 0u32
    while g < games {
        gen_game(n)
        let mut v : u32 = 0u32  let nn : u32 = nv()
        while v < nn { SUC[v as u64] = SUC0[v as u64]  v = v + 1u32 }
        let r : u64 = zielonka(fullmask())
        let we : u32 = (r & 0xFFFFFFFFu64) as u32
        let mut u : u32 = 0u32
        while u < nn {
            let truth : u8 = ((we >> u) & 1u32) as u8
            if predict_even(u) == truth { agree = agree + 1u32 }
            total = total + 1u32
            u = u + 1u32
        }
        g = g + 1u32
    }
    return agree * 100u32 / total
}

fn main() -> u64 {
    RNG[0u64] = 0xC0B11D5u32
    let a4 : u32 = accuracy_pct(4u32, 600u32)
    let a10 : u32 = accuracy_pct(10u32, 600u32)
    let a14 : u32 = accuracy_pct(14u32, 400u32)
    /* measured decay (this seed): 82% (n=4) -> 70% (n=10) -> 65% (n=14), monotone toward 1/2 */
    if a4 <= a10 { return 10u64 }       /* must decay 4 -> 10 */
    if a10 <= a14 { return 11u64 }       /* must decay 10 -> 14 */
    if a4 < 75u32 { return 12u64 }       /* strong signal at small n (so the decay is real signal being lost) */
    if a14 > 68u32 { return 13u64 }      /* decayed well below the small-n level, heading to chance */
    return 99u64
}
