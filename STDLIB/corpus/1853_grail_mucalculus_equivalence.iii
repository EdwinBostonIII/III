/* 1853_grail_mucalculus_equivalence.iii -- FORMAL WALL, the GAMES <=> LOGIC face (VERIFIED), 4th independent solver.
 *
 * THEOREM (Games = Logic, instantiated).  Even's winning region is EXACTLY the value of the parity mu-calculus
 * formula evaluated on the game graph -- a nested fixpoint over the CONTROLLED-PREDECESSOR operator:
 *     W0 = sigma_d Z_d. sigma_{d-1} Z_{d-1}. ... sigma_0 Z_0.  { v : v in cpre(Z_{pr(v)}) }
 * where sigma_p = nu (greatest fixpoint) for p even, mu (least) for p odd, and
 *     cpre(S) = { v in V0 : SOME successor in S } U { v in V1 : ALL successors in S }   (Even can force into S).
 * This is the Emerson-Lei / Walukiewicz characterization, here EVALUATED naively (a recursion completely different
 * from Zielonka's attractor decomposition) and verified == the Zielonka oracle (1839) on every sampled game.
 *
 * SIGNIFICANCE.  This makes the equivalence-web face "parity games <=> full modal mu-calculus model-checking"
 * (DOCS/III-PARITY-WALL-FORMAL.md Sec 5) CONCRETE and oracle-checked: the game-theoretic winner and the logical
 * formula value are literally the same object, computed by two unrelated algorithms.  Hence "parity games in P?"
 * and "mu-calculus MC in P?" are one and the same wall, not two.  (This naive evaluation is exponential -- it is the
 * straightforward fixpoint iteration, not a poly algorithm; correctness, not complexity, is the point here.)
 * exit 99 = the mu-calculus nested-fixpoint value == the Zielonka oracle on every sampled game. */
module mmce
var OWN : [u8; 16]
var PRI : [u32; 16]
var SUC0 : [u32; 16]
var SUC : [u32; 16]
var NV : [u32; 1]
var RNG : [u32; 1]
var Z : [u32; 16]    /* Z[p] = current set for priority-p fixpoint variable */

fn nv() -> u32 { return NV[0u64] }
fn rnd() -> u32 { let mut x : u32 = RNG[0u64]  x = x ^ (x << 13u32)  x = x ^ (x >> 17u32)  x = x ^ (x << 5u32)  RNG[0u64] = x  return x }
fn fullmask() -> u32 { return (1u32 << nv()) - 1u32 }

/* ---- Zielonka oracle (1839) ---- */
fn max_prio(region: u32) -> u32 { let mut m : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()  while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] > m { m = PRI[v as u64] } }  v = v + 1u32 }  return m }
fn attractor(region: u32, player: u32, target: u32) -> u32 {
    let mut a : u32 = target & region  let mut done : u8 = 0u8  let n : u32 = nv()
    while done == 0u8 { let mut added : u8 = 0u8  let mut v : u32 = 0u32
        while v < n { let bit : u32 = 1u32 << v
            if (region & bit) != 0u32 { if (a & bit) == 0u32 {
                if OWN[v as u64] == (player as u8) { if (SUC[v as u64] & a & region) != 0u32 { a = a | bit  added = 1u8 } }
                else { let sir : u32 = SUC[v as u64] & region  if sir != 0u32 { if (sir & (a ^ 0xFFFFFFFFu32)) == 0u32 { a = a | bit  added = 1u8 } } } } }
            v = v + 1u32 }
        if added == 0u8 { done = 1u8 } }
    return a
}
fn zielonka(region: u32) -> u64 {
    if region == 0u32 { return 0u64 }
    let d : u32 = max_prio(region)  let p : u32 = d & 1u32  let mut u : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()
    while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] == d { u = u | (1u32 << v) } }  v = v + 1u32 }
    let a : u32 = attractor(region, p, u)  let r1 : u64 = zielonka(region & (a ^ 0xFFFFFFFFu32))
    let w0a : u32 = (r1 & 0xFFFFFFFFu64) as u32  let w1a : u32 = (r1 >> 32u64) as u32
    let mut wopp : u32 = w1a  if p != 0u32 { wopp = w0a }
    if wopp == 0u32 { if p == 0u32 { return region as u64 }  return (region as u64) << 32u64 }
    let opp : u32 = 1u32 - p  let b : u32 = attractor(region, opp, wopp)  let r2 : u64 = zielonka(region & (b ^ 0xFFFFFFFFu32))
    let w0b : u32 = (r2 & 0xFFFFFFFFu64) as u32  let w1b : u32 = (r2 >> 32u64) as u32
    if p == 0u32 { return (w0b as u64) | (((w1b | b) as u64) << 32u64) }
    return ((w0b | b) as u64) | ((w1b as u64) << 32u64)
}

/* ---- the mu-calculus nested fixpoint ---- */
/* cpre body: { v : v in cpre(Z[pr(v)]) } -- Even can force in one step into the priority-stratum approximation */
fn body() -> u32 {
    let n : u32 = nv()  let fm : u32 = fullmask()  let mut res : u32 = 0u32  let mut v : u32 = 0u32
    while v < n {
        let s : u32 = Z[PRI[v as u64] as u64]
        if OWN[v as u64] == 0u8 { if (SUC0[v as u64] & s) != 0u32 { res = res | (1u32 << v) } }    /* Even: SOME successor in s */
        else { if (SUC0[v as u64] & fm & (s ^ 0xFFFFFFFFu32)) == 0u32 { res = res | (1u32 << v) } } /* Odd: ALL successors in s */
        v = v + 1u32
    }
    return res
}
/* solve the fixpoint of Z[level] (Z[level+1..d] fixed): nu (full) for even level, mu (empty) for odd; iterate to fixpoint */
fn eval(level: u32) -> u32 {
    let fm : u32 = fullmask()
    if (level & 1u32) == 0u32 { Z[level as u64] = fm } else { Z[level as u64] = 0u32 }   /* nu starts full, mu starts empty */
    let mut done : u8 = 0u8
    while done == 0u8 {
        let mut nz : u32 = 0u32
        if level == 0u32 { nz = body() } else { nz = eval(level - 1u32) }
        if nz == Z[level as u64] { done = 1u8 } else { Z[level as u64] = nz }
    }
    return Z[level as u64]
}
fn mu_even_region() -> u32 {
    let d : u32 = max_prio(fullmask())
    return eval(d)
}
fn gen_game(n: u32) -> i32 {
    NV[0u64] = n  let mut v : u32 = 0u32
    while v < n { OWN[v as u64] = (rnd() & 1u32) as u8  PRI[v as u64] = rnd() % n
        let mut s : u32 = 0u32  let kk : u32 = 1u32 + (rnd() % 3u32)  let mut j : u32 = 0u32
        while j < kk { s = s | (1u32 << (rnd() % n))  j = j + 1u32 }
        if s == 0u32 { s = 1u32 << ((v + 1u32) % n) }
        SUC0[v as u64] = s  v = v + 1u32 }
    return 0i32
}
fn oracle_even() -> u32 {
    let n : u32 = nv()  let mut v : u32 = 0u32
    while v < n { SUC[v as u64] = SUC0[v as u64]  v = v + 1u32 }
    let r : u64 = zielonka(fullmask())
    return (r & 0xFFFFFFFFu64) as u32
}

fn main() -> u64 {
    RNG[0u64] = 0x3CA1Cu32
    let mut t : u32 = 0u32  let mut checked : u32 = 0u32
    while t < 3000u32 {
        let n : u32 = 3u32 + (rnd() % 5u32)            /* n in 3..7 */
        gen_game(n)
        let orac : u32 = oracle_even()
        let mu : u32 = mu_even_region()
        if mu != orac { return 10u64 }                 /* mu-calculus formula value must equal the game winner */
        checked = checked + 1u32
        t = t + 1u32
    }
    if checked < 1000u32 { return 60u64 }
    return 99u64
}
