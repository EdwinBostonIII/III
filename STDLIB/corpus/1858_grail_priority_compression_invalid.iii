/* 1858_grail_priority_compression_invalid.iii -- RESIDUAL-HOPE CLOSURE (avenue C): "just COMPRESS the priorities to a
 * bounded number, then bounded-d parity is in P (1857)."  This hope dies two ways, both verified against the Zielonka
 * oracle (1839):
 *
 *  (1) The NATURAL parity-preserving collapse to two priorities -- pr'(v) = (pr(v) even ? 2 : 1) -- does NOT preserve
 *      the winner.  It keeps every vertex's PARITY but destroys the ORDERING, and the winner depends on the order.
 *      EXPLICIT WITNESS: the 2-cycle 0<->1 with pr(0)=3, pr(1)=2.  Original max-inf priority = 3 (ODD) => Even wins
 *      NOTHING (W_even = {}).  After collapse (3->1, 2->2): max-inf = 2 (EVEN) => Even wins EVERYTHING (W_even = all).
 *      The winner flips from none to all while every vertex's parity is unchanged.
 *  (2) Over random games, this naive collapse flips the winner of >=1 vertex on a LARGE fraction -- it is the typical
 *      case, not a corner case.
 *
 * THE CONSEQUENCE (math-olympiad #4 honest tag).  A WINNER-PRESERVING poly-time reduction from general parity to
 * bounded-d parity would put general parity in P, because bounded-d parity IS in P (1857 / n^{O(d)}, Jurdzinski 1998).
 * No such reduction is known; the natural one provably fails (here).  So "just reduce the priority count" is not a
 * shortcut -- it is EXACTLY the open problem restated.  This CLOSES the avenue without claiming anything about P
 * (a refutation of a shortcut cannot, and does not, put parity in P).
 * exit 99 = the explicit collapse flips the winner (none->all) AND the sweep shows it flips on a large fraction. */
module mpci
var OWN : [u8; 16]
var PRI : [u32; 16]
var SUC0 : [u32; 16]
var SUC : [u32; 16]
var NV : [u32; 1]
var RNG : [u32; 1]

fn nv() -> u32 { return NV[0u64] }
fn rnd() -> u32 { let mut x : u32 = RNG[0u64]  x = x ^ (x << 13u32)  x = x ^ (x >> 17u32)  x = x ^ (x << 5u32)  RNG[0u64] = x  return x }
fn fullmask() -> u32 { return (1u32 << nv()) - 1u32 }

/* ---- Zielonka oracle (1839) ---- */
fn max_prio(region: u32) -> u32 { let mut m : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()  while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] > m { m = PRI[v as u64] } }  v = v + 1u32 }  return m }
fn attractor(region: u32, player: u32, target: u32) -> u32 {
    let mut a : u32 = target & region  let mut done : u8 = 0u8  let n : u32 = nv()
    while done == 0u8 { let mut added : u8 = 0u8  let mut v : u32 = 0u32
        while v < n { let bit : u32 = 1u32 << v
            if (region & bit) != 0u32 { if (a & bit) == 0u32 {
                if OWN[v as u64] == (player as u8) { if (SUC[v as u64] & a & region) != 0u32 { a = a | bit  added = 1u8 } }
                else { let sir : u32 = SUC[v as u64] & region  if sir != 0u32 { if (sir & (a ^ 0xFFFFFFFFu32)) == 0u32 { a = a | bit  added = 1u8 } } } } }
            v = v + 1u32 }
        if added == 0u8 { done = 1u8 } }
    return a
}
fn zielonka(region: u32) -> u64 {
    if region == 0u32 { return 0u64 }
    let d : u32 = max_prio(region)  let p : u32 = d & 1u32  let mut u : u32 = 0u32  let mut v : u32 = 0u32  let n : u32 = nv()
    while v < n { if (region & (1u32 << v)) != 0u32 { if PRI[v as u64] == d { u = u | (1u32 << v) } }  v = v + 1u32 }
    let a : u32 = attractor(region, p, u)  let r1 : u64 = zielonka(region & (a ^ 0xFFFFFFFFu32))
    let w0a : u32 = (r1 & 0xFFFFFFFFu64) as u32  let w1a : u32 = (r1 >> 32u64) as u32
    let mut wopp : u32 = w1a  if p != 0u32 { wopp = w0a }
    if wopp == 0u32 { if p == 0u32 { return region as u64 }  return (region as u64) << 32u64 }
    let opp : u32 = 1u32 - p  let b : u32 = attractor(region, opp, wopp)  let r2 : u64 = zielonka(region & (b ^ 0xFFFFFFFFu32))
    let w0b : u32 = (r2 & 0xFFFFFFFFu64) as u32  let w1b : u32 = (r2 >> 32u64) as u32
    if p == 0u32 { return (w0b as u64) | (((w1b | b) as u64) << 32u64) }
    return ((w0b | b) as u64) | ((w1b as u64) << 32u64)
}
fn oracle_even() -> u32 {
    let n : u32 = nv()  let mut v : u32 = 0u32
    while v < n { SUC[v as u64] = SUC0[v as u64]  v = v + 1u32 }
    let r : u64 = zielonka(fullmask())  return (r & 0xFFFFFFFFu64) as u32
}
/* collapse priorities in place to {1,2} by parity: even->2, odd->1 (parity-preserving, order-destroying) */
fn collapse_by_parity() -> i32 {
    let n : u32 = nv()  let mut v : u32 = 0u32
    while v < n { if (PRI[v as u64] & 1u32) == 0u32 { PRI[v as u64] = 2u32 } else { PRI[v as u64] = 1u32 }  v = v + 1u32 }
    return 0i32
}
fn gen_game(n: u32) -> i32 {
    NV[0u64] = n  let mut v : u32 = 0u32
    while v < n { OWN[v as u64] = (rnd() & 1u32) as u8  PRI[v as u64] = rnd() % n
        let mut s : u32 = 0u32  let kk : u32 = 1u32 + (rnd() % 3u32)  let mut j : u32 = 0u32
        while j < kk { s = s | (1u32 << (rnd() % n))  j = j + 1u32 }
        if s == 0u32 { s = 1u32 << ((v + 1u32) % n) }
        SUC0[v as u64] = s  v = v + 1u32 }
    return 0i32
}

fn main() -> u64 {
    /* (1) EXPLICIT WITNESS: 2-cycle 0<->1, pr(0)=3, pr(1)=2 */
    NV[0u64] = 2u32
    OWN[0u64] = 0u8  OWN[1u64] = 0u8
    PRI[0u64] = 3u32  PRI[1u64] = 2u32
    SUC0[0u64] = 1u32 << 1u32   /* 0 -> 1 */
    SUC0[1u64] = 1u32 << 0u32   /* 1 -> 0 */
    let before : u32 = oracle_even()                 /* max-inf = 3 (odd) -> Even wins NOTHING */
    if before != 0u32 { return 10u64 }               /* expect W_even = {} */
    /* both vertices' parities: pr(0)=3 odd, pr(1)=2 even */
    collapse_by_parity()                              /* 3->1, 2->2 */
    if PRI[0u64] != 1u32 { return 14u64 }
    if PRI[1u64] != 2u32 { return 15u64 }
    let after : u32 = oracle_even()                  /* max-inf = 2 (even) -> Even wins EVERYTHING */
    if after != fullmask() { return 11u64 }          /* expect W_even = all */
    if before == after { return 12u64 }              /* the winner MUST have flipped */

    /* (2) SWEEP: how often does the naive collapse flip >=1 vertex's winner over random games? */
    RNG[0u64] = 0x9A1B2C3u32
    let mut trials : u32 = 0u32  let mut flips : u32 = 0u32
    while trials < 2000u32 {
        let n : u32 = 4u32 + (rnd() % 5u32)
        gen_game(n)
        let w0 : u32 = oracle_even()
        collapse_by_parity()
        let w1 : u32 = oracle_even()
        if w0 != w1 { flips = flips + 1u32 }
        trials = trials + 1u32
    }
    /* must flip on a substantial fraction (not a corner case): require >= 20% of 2000 */
    if flips < 400u32 { return (50u64 + (flips / 40u32) as u64) }
    return 99u64
}
