/* SHA-512 message-schedule bit-identity: scalar == AVX-512.
 *
 * RITCHIE §3.5 kernel 10/10.  SHA-512("abc") runs the full 64-word
 * message schedule.  Computes the digest twice -- force scalar sigma0
 * (sha512_sched_force(1)) and force AVX-512 sigma0 (force(2)) -- and
 * asserts the two digests are byte-identical AND equal the FIPS 180-4
 * SHA-512("abc") vector.
 *
 * Exit = 88 on full success.
 */
module corpus_185

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn sha512_oneshot(input: *u8, len: u64, out_64: *u8) -> u32 from "sha512.iii"
extern @abi(c-msvc-x64) fn sha512_sched_force(p: u32) -> u32 from "sha512.iii"

fn check_abc(r: *u8) -> u64 {
    /* SHA-512("abc") = ddaf35a193617aba cc417349ae204131 12e6fa4e89a97ea2 0a9eeee64b55d39a
     *                  2192992a274fc1a8 36ba3c23a3feebbd 454d4423643ce80e 2a9ac94fa54ca49f */
    if r[0]  != 0xDDu8 { return 1u64 }
    if r[1]  != 0xAFu8 { return 2u64 }
    if r[2]  != 0x35u8 { return 3u64 }
    if r[3]  != 0xA1u8 { return 4u64 }
    if r[4]  != 0x93u8 { return 5u64 }
    if r[5]  != 0x61u8 { return 6u64 }
    if r[6]  != 0x7Au8 { return 7u64 }
    if r[7]  != 0xBAu8 { return 8u64 }
    if r[8]  != 0xCCu8 { return 9u64 }
    if r[9]  != 0x41u8 { return 10u64 }
    if r[10] != 0x73u8 { return 11u64 }
    if r[11] != 0x49u8 { return 12u64 }
    if r[12] != 0xAEu8 { return 13u64 }
    if r[13] != 0x20u8 { return 14u64 }
    if r[14] != 0x41u8 { return 15u64 }
    if r[15] != 0x31u8 { return 16u64 }
    if r[16] != 0x12u8 { return 17u64 }
    if r[17] != 0xE6u8 { return 18u64 }
    if r[18] != 0xFAu8 { return 19u64 }
    if r[19] != 0x4Eu8 { return 20u64 }
    if r[20] != 0x89u8 { return 21u64 }
    if r[21] != 0xA9u8 { return 22u64 }
    if r[22] != 0x7Eu8 { return 23u64 }
    if r[23] != 0xA2u8 { return 24u64 }
    if r[24] != 0x0Au8 { return 25u64 }
    if r[25] != 0x9Eu8 { return 26u64 }
    if r[26] != 0xEEu8 { return 27u64 }
    if r[27] != 0xE6u8 { return 28u64 }
    if r[28] != 0x4Bu8 { return 29u64 }
    if r[29] != 0x55u8 { return 30u64 }
    if r[30] != 0xD3u8 { return 31u64 }
    if r[31] != 0x9Au8 { return 32u64 }
    if r[32] != 0x21u8 { return 33u64 }
    if r[33] != 0x92u8 { return 34u64 }
    if r[34] != 0x99u8 { return 35u64 }
    if r[35] != 0x2Au8 { return 36u64 }
    if r[36] != 0x27u8 { return 37u64 }
    if r[37] != 0x4Fu8 { return 38u64 }
    if r[38] != 0xC1u8 { return 39u64 }
    if r[39] != 0xA8u8 { return 40u64 }
    if r[40] != 0x36u8 { return 41u64 }
    if r[41] != 0xBAu8 { return 42u64 }
    if r[42] != 0x3Cu8 { return 43u64 }
    if r[43] != 0x23u8 { return 44u64 }
    if r[44] != 0xA3u8 { return 45u64 }
    if r[45] != 0xFEu8 { return 46u64 }
    if r[46] != 0xEBu8 { return 47u64 }
    if r[47] != 0xBDu8 { return 48u64 }
    if r[48] != 0x45u8 { return 49u64 }
    if r[49] != 0x4Du8 { return 50u64 }
    if r[50] != 0x44u8 { return 51u64 }
    if r[51] != 0x23u8 { return 52u64 }
    if r[52] != 0x64u8 { return 53u64 }
    if r[53] != 0x3Cu8 { return 54u64 }
    if r[54] != 0xE8u8 { return 55u64 }
    if r[55] != 0x0Eu8 { return 56u64 }
    if r[56] != 0x2Au8 { return 57u64 }
    if r[57] != 0x9Au8 { return 58u64 }
    if r[58] != 0xC9u8 { return 59u64 }
    if r[59] != 0x4Fu8 { return 60u64 }
    if r[60] != 0xA5u8 { return 61u64 }
    if r[61] != 0x4Cu8 { return 62u64 }
    if r[62] != 0xA4u8 { return 63u64 }
    if r[63] != 0x9Fu8 { return 64u64 }
    return 0u64
}

fn main() -> u64 {
    let msg   : *u8 = malloc(3u64)
    let out_s : *u8 = malloc(64u64)
    let out_a : *u8 = malloc(64u64)
    msg[0] = 0x61u8  /* 'a' */
    msg[1] = 0x62u8  /* 'b' */
    msg[2] = 0x63u8  /* 'c' */

    sha512_sched_force(1u32)
    sha512_oneshot(msg, 3u64, out_s)
    sha512_sched_force(2u32)
    sha512_oneshot(msg, 3u64, out_a)
    sha512_sched_force(0u32)

    let mut i : u64 = 0u64
    while i < 64u64 {
        if out_s[i] != out_a[i] { return 1u64 + i }
        i = i + 1u64
    }
    let kat_err : u64 = check_abc(out_s)
    if kat_err != 0u64 { return 100u64 + kat_err }

    free(msg); free(out_s); free(out_a)
    return 88u64
}
