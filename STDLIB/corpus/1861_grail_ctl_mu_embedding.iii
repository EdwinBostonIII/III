/* 1861_grail_ctl_mu_embedding.iii -- BROADER REACH (grounding "mu-calculus is the mother of all logics").
 * The modal mu-calculus subsumes the standard branching-time temporal logic CTL (and LTL/CTL* via automata) -- CITED,
 * Emerson-Lei.  Here we GROUND that embedding concretely in III: each CTL operator is computed BOTH by its mu/nu
 * fixpoint AND by an INDEPENDENT path-semantics algorithm, and the two agree on every random Kripke structure.
 *
 *   EF p  ("p reachable")     = mu X. (P or <>X)        [least fixpoint]   vs.  per-vertex FORWARD search hits P
 *   EG p  ("p invariant on a path") = nu X. (P and <>X) [greatest fixpoint] vs.  in P and reaches a P-CYCLE (within P)
 *   E[p U q]                  = mu X. (Q or (P and <>X)) [least fixpoint]  vs.  per-vertex P-constrained search to Q
 *  where <>X (EX) = { v : some successor in X } = the modal diamond.
 *
 * WHY THIS IS THE REACH (honest tags):
 *  - (CITED) the mu-calculus subsumes CTL, CTL*, LTL, PDL -- it is the canonical specification logic for reactive
 *    systems; model-checking a temporal property IS evaluating a mu-formula.
 *  - (VERIFIED here) each CTL operator's mu/nu fixpoint == its path semantics -> the embedding is real, not nominal.
 *  - (VERIFIED here) every CTL operator is a SINGLE fixpoint -- NO mu/nu alternation -- so it converges in <= n
 *    iterations (POLYNOMIAL): CTL lives in the ALTERNATION-FREE fragment, strictly BELOW the wall.
 *  - (THEOREM, via 1853) the WALL is exactly the ALTERNATION that full mu adds: the parity mu-formula nests mu inside
 *    nu (1853), and THAT is parity-game-equivalent (O1).  So: branching-time verification (CTL) is poly; the open
 *    frontier of verification is precisely the alternating mu-calculus = parity.  The parity wall IS the
 *    software-verification frontier, not a separate puzzle.
 * exit 99 = all three CTL operators' fixpoints == their path semantics on every Kripke structure, each single-fixpoint. */
module mctl
var SUC0 : [u32; 16]
var PSET : [u32; 1]
var QSET : [u32; 1]
var NV : [u32; 1]
var RNG : [u32; 1]

fn nv() -> u32 { return NV[0u64] }
fn rnd() -> u32 { let mut x : u32 = RNG[0u64]  x = x ^ (x << 13u32)  x = x ^ (x >> 17u32)  x = x ^ (x << 5u32)  RNG[0u64] = x  return x }
fn fullmask() -> u32 { return (1u32 << nv()) - 1u32 }
fn pre(x: u32) -> u32 {  /* <>X = { v : some successor in X } */
    let n : u32 = nv()  let mut r : u32 = 0u32  let mut v : u32 = 0u32
    while v < n { if (SUC0[v as u64] & x) != 0u32 { r = r | (1u32 << v) }  v = v + 1u32 }
    return r
}
fn reach_fwd(start: u32, within: u32) -> u32 {
    let n : u32 = nv()  let mut R : u32 = start & within  let mut done : u8 = 0u8
    while done == 0u8 { let mut add : u32 = 0u32  let mut v : u32 = 0u32
        while v < n { if (R & (1u32 << v)) != 0u32 { add = add | (SUC0[v as u64] & within) }  v = v + 1u32 }
        let nr : u32 = R | add  if nr == R { done = 1u8 } else { R = nr } }
    return R
}
fn backreach_within(target: u32, within: u32) -> u32 {
    let n : u32 = nv()  let mut B : u32 = target & within  let mut done : u8 = 0u8
    while done == 0u8 { let mut add : u32 = 0u32  let mut v : u32 = 0u32
        while v < n { if (within & (1u32 << v)) != 0u32 { if (B & (1u32 << v)) == 0u32 { if (SUC0[v as u64] & B) != 0u32 { add = add | (1u32 << v) } } }  v = v + 1u32 }
        let nb : u32 = B | add  if nb == B { done = 1u8 } else { B = nb } }
    return B
}

/* ---- mu/nu fixpoints (the mu-calculus evaluation) ---- */
fn ef_fix() -> u32 {           /* mu X. (P | pre(X)) */
    let p : u32 = PSET[0u64]  let mut x : u32 = 0u32  let mut done : u8 = 0u8  let mut iters : u32 = 0u32
    while done == 0u8 { let nx : u32 = p | pre(x)  iters = iters + 1u32  if nx == x { done = 1u8 } else { x = nx } }
    if iters > nv() + 1u32 { return 0xFFFFFFFFu32 }   /* single-fixpoint convergence bound (alternation-free) */
    return x
}
fn eg_fix() -> u32 {           /* nu X. (P & pre(X)) */
    let p : u32 = PSET[0u64]  let mut x : u32 = fullmask()  let mut done : u8 = 0u8  let mut iters : u32 = 0u32
    while done == 0u8 { let nx : u32 = p & pre(x)  iters = iters + 1u32  if nx == x { done = 1u8 } else { x = nx } }
    if iters > nv() + 2u32 { return 0xFFFFFFFFu32 }
    return x
}
fn eu_fix() -> u32 {           /* mu X. (Q | (P & pre(X))) */
    let p : u32 = PSET[0u64]  let q : u32 = QSET[0u64]  let mut x : u32 = 0u32  let mut done : u8 = 0u8
    while done == 0u8 { let nx : u32 = q | (p & pre(x))  if nx == x { done = 1u8 } else { x = nx } }
    return x
}

/* ---- independent PATH-SEMANTICS algorithms ---- */
fn ef_path() -> u32 {          /* v can reach a P-state by a forward walk */
    let n : u32 = nv()  let p : u32 = PSET[0u64]  let mut r : u32 = 0u32  let mut v : u32 = 0u32
    while v < n { if (reach_fwd(1u32 << v, fullmask()) & p) != 0u32 { r = r | (1u32 << v) }  v = v + 1u32 }
    return r
}
fn eg_path() -> u32 {          /* v in P and reaches (within P) a P-cycle */
    let n : u32 = nv()  let p : u32 = PSET[0u64]  let mut pcyc : u32 = 0u32  let mut v : u32 = 0u32
    while v < n { if (p & (1u32 << v)) != 0u32 { if (reach_fwd(SUC0[v as u64] & p, p) & (1u32 << v)) != 0u32 { pcyc = pcyc | (1u32 << v) } }  v = v + 1u32 }
    return backreach_within(pcyc, p)
}
fn eu_reaches(v: u32) -> u8 {  /* P-constrained forward search from v to a Q-state */
    let q : u32 = QSET[0u64]  let p : u32 = PSET[0u64]
    if (q & (1u32 << v)) != 0u32 { return 1u8 }
    if (p & (1u32 << v)) == 0u32 { return 0u8 }
    let n : u32 = nv()  let mut R : u32 = 1u32 << v  let mut done : u8 = 0u8
    while done == 0u8 {
        let mut add : u32 = 0u32  let mut u : u32 = 0u32
        while u < n { if (R & (1u32 << u)) != 0u32 { let s : u32 = SUC0[u as u64]  if (s & q) != 0u32 { return 1u8 }  add = add | (s & p) }  u = u + 1u32 }
        let nr : u32 = R | add  if nr == R { done = 1u8 } else { R = nr }
    }
    return 0u8
}
fn eu_path() -> u32 { let n : u32 = nv()  let mut r : u32 = 0u32  let mut v : u32 = 0u32  while v < n { if eu_reaches(v) == 1u8 { r = r | (1u32 << v) }  v = v + 1u32 }  return r }

fn gen_kripke(n: u32) -> i32 {
    NV[0u64] = n  let mut v : u32 = 0u32  let mut pp : u32 = 0u32  let mut qq : u32 = 0u32
    while v < n {
        let mut s : u32 = 0u32  let kk : u32 = 1u32 + (rnd() % 3u32)  let mut j : u32 = 0u32
        while j < kk { s = s | (1u32 << (rnd() % n))  j = j + 1u32 }
        if s == 0u32 { s = 1u32 << ((v + 1u32) % n) }
        SUC0[v as u64] = s
        if (rnd() % 10u32) < 6u32 { pp = pp | (1u32 << v) }   /* ~60% labelled P */
        if (rnd() % 10u32) < 3u32 { qq = qq | (1u32 << v) }   /* ~30% labelled Q */
        v = v + 1u32 }
    PSET[0u64] = pp  QSET[0u64] = qq
    return 0i32
}

fn main() -> u64 {
    RNG[0u64] = 0xC71E55u32
    let mut t : u32 = 0u32
    while t < 4000u32 {
        let n : u32 = 4u32 + (rnd() % 5u32)            /* n in 4..8 */
        gen_kripke(n)
        let ef1 : u32 = ef_fix()  if ef1 == 0xFFFFFFFFu32 { return 20u64 }   /* EF must be single-fixpoint */
        if ef1 != ef_path() { return 10u64 }                                  /* EF fixpoint == path semantics */
        let eg1 : u32 = eg_fix()  if eg1 == 0xFFFFFFFFu32 { return 21u64 }   /* EG must be single-fixpoint */
        if eg1 != eg_path() { return 11u64 }                                  /* EG fixpoint == path semantics */
        if eu_fix() != eu_path() { return 12u64 }                             /* EU fixpoint == path semantics */
        t = t + 1u32
    }
    return 99u64
}
