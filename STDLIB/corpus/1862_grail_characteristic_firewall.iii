/* 1862_grail_characteristic_firewall.iii -- BROADER REACH (generalizing M1, the logic<->crypto obstruction).
 * M1 (1851) closed the canonical algebraic bridge from the lattice-logic Boolean-ring face (characteristic 2) to
 * ML-KEM's ring Z_3329.  Here we show the load-bearing reason is the CHARACTERISTIC, and it is GENERIC across the whole
 * deployed crypto stack -- not a 3329 coincidence.
 *
 * THE FIREWALL (A) -- CHARACTERISTIC, target-specific, load-bearing.  A unital ring homomorphism h : R -> Z_m from a
 * char-2 ring R forces 0 = h(1+1) = h(1)+h(1) = 1+1 = 2 in Z_m.  For every odd modulus m > 2, 2 != 0 (and gcd(2,m)=1),
 * so NO such h exists.  Equivalently: the Boolean field F_2 = {0,1} is NOT a subring of Z_m, because 1+1 = 0 in F_2 but
 * 1+1 = 2 != 0 in Z_m.  This is the SAME obstruction whether phrased as "no unital hom," "F_2 not a subring," or "the
 * principled Stone bridge fails" -- and it depends ENTIRELY on the target's odd characteristic: it VANISHES at char 2
 * (2 = 0 in F_2 itself), which we check, confirming it is characteristic-specific, not generic.
 *
 * NOT a firewall (B) -- the idempotency point is GENERIC (demoted, advisor-audited).  "The only additive idempotent of
 * Z_m (2a = a) is a = 0" is TRUE but holds in EVERY ring -- including the char-2 Boolean ring itself -- because
 * a+a=a => a=0 in ANY additive group.  It is target-INDEPENDENT, says nothing about crypto or characteristic, and the
 * 7-modulus sweep adds zero information to it.  It only explains why the NAIVE map OR |-> + is trivially wrong (join is
 * idempotent, + is not).  We verify it for the small moduli ONLY to record the triviality, explicitly NOT as a firewall.
 *
 * MODULI (all deployed, all odd): 3329 (ML-KEM/Kyber), 12289 (Falcon/NTRU), 8380417 (ML-DSA/Dilithium), 2147483647
 *   (M31), 2305843009213693951 (M61), 18446744069414584321 (STARK Goldilocks 2^64-2^32+1), and 3233 = 61*53 (RSA --
 *   odd COMPOSITE, to show the firewall is characteristic/parity, not primality).
 *
 * HONEST SCOPE (as M1): rules out the canonical algebraic-key hope -- it does NOT claim NO relation exists (the weave
 * SIMULATES Z_q as char-2 circuits, a non-canonical relation; char-2 hardware computes char-q arithmetic every day).
 * exit 99 = the CHARACTERISTIC firewall (A) holds for every deployed modulus, vanishes at char 2, and (B-generic) the
 *           sole additive idempotent is 0 for the small moduli. */
module mcfw
var MOD : [u64; 8]
var SMALL : [u8; 8]

fn gcd(a: u64, b: u64) -> u64 { let mut x : u64 = a  let mut y : u64 = b  while y != 0u64 { let t : u64 = x % y  x = y  y = t }  return x }
fn addmod(a: u64, b: u64, m: u64) -> u64 { if a >= m - b { return a - (m - b) }  return a + b }

fn main() -> u64 {
    MOD[0u64] = 3329u64                  SMALL[0u64] = 1u8   /* ML-KEM / Kyber */
    MOD[1u64] = 12289u64                 SMALL[1u64] = 1u8   /* Falcon / NTRU */
    MOD[2u64] = 8380417u64               SMALL[2u64] = 0u8   /* ML-DSA / Dilithium */
    MOD[3u64] = 2147483647u64            SMALL[3u64] = 0u8   /* M31 */
    MOD[4u64] = 2305843009213693951u64   SMALL[4u64] = 0u8   /* M61 */
    MOD[5u64] = 18446744069414584321u64  SMALL[5u64] = 0u8   /* STARK Goldilocks */
    MOD[6u64] = 3233u64                  SMALL[6u64] = 1u8   /* RSA 61*53 (odd composite) */

    /* (A) the CHARACTERISTIC firewall, uniform across the deployed stack */
    let mut i : u32 = 0u32
    while i < 7u32 {
        let m : u64 = MOD[i as u64]
        if m <= 2u64 { return (10u64 + i as u64) }
        if (m & 1u64) != 1u64 { return (20u64 + i as u64) }      /* odd */
        if (2u64 % m) == 0u64 { return (30u64 + i as u64) }      /* 2 != 0 in Z_m: no unital ring hom from char-2 */
        if gcd(2u64, m) != 1u64 { return (40u64 + i as u64) }    /* coprime characteristics */
        /* F_2 = {0,1} not a subring of Z_m: 1+1 differs (0 in F_2 vs 2!=0 here) -- the same characteristic fact */
        if addmod(1u64, 1u64, m) == 0u64 { return (45u64 + i as u64) }   /* 1+1 must be nonzero (=2) for odd m */
        i = i + 1u32
    }
    /* (A) is characteristic-SPECIFIC: it VANISHES at char 2 (the firewall does not exist into F_2 itself) */
    if (2u64 % 2u64) != 0u64 { return 70u64 }                    /* in F_2, 2 = 0, so a char-2 -> char-2 hom is fine */

    /* (B, GENERIC, NOT a firewall) only additive idempotent is 0 -- holds in every ring; recorded for the small moduli */
    let mut j : u32 = 0u32
    while j < 7u32 {
        if SMALL[j as u64] == 1u8 {
            let m : u64 = MOD[j as u64]
            let mut idem : u64 = 0u64  let mut a : u64 = 0u64
            while a < m { if addmod(a, a, m) == a { idem = idem + 1u64 }  a = a + 1u64 }
            if idem != 1u64 { return (80u64 + j as u64) }         /* exactly {0}; true in F_2 too -- generic, not a firewall */
        }
        j = j + 1u32
    }
    return 99u64
}
