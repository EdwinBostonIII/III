/* 1865_grail_sat_xor_island.iii -- THE SAT / P-vs-NP WALL, island (3): XOR-SAT is in P, EXACTLY.
 *
 * ISLAND (CITED: a special case of Schaefer's "affine" tractable class).  A formula whose clauses are XOR (parity)
 * constraints  x_{i1} (+) x_{i2} (+) ... = b  over GF(2) is a system of LINEAR EQUATIONS over GF(2); it is decided in
 * polynomial time by GAUSSIAN ELIMINATION (here pure bit-XOR row reduction -- no field library needed).  The system is
 * SAT iff it is consistent (reduction never yields a row "0 = 1"); else UNSAT.  Poly -- no 2^n search.
 *
 * VERIFICATION: on random GF(2) linear systems, the Gaussian-elimination solver agrees with the brute-force oracle
 * (every assignment checked) on SAT/UNSAT every time.
 *
 * WHERE THIS SITS (honest tag).  XOR-SAT in P is Schaefer's "affine" island.  Crucially it is *fragile to mixing*:
 * AND-of-XOR-and-OR is NP-complete, and the moment clauses leave the linear (affine) class the problem can become
 * NP-complete.  It GROUNDS the third edge of the SAT wall's tractable boundary; it says NOTHING about P vs NP.
 * exit 99 = the poly Gaussian-elimination XOR solver == the brute-force oracle on every sampled GF(2) system. */
module mxor
var RVARS : [u32; 64]   /* equation: variable mask */
var RRHS : [u8; 64]     /* equation: right-hand side bit */
var NC : [u32; 1]
var NVAR : [u32; 1]
var RNG : [u32; 1]

fn rnd() -> u32 { let mut x : u32 = RNG[0u64]  x = x ^ (x << 13u32)  x = x ^ (x >> 17u32)  x = x ^ (x << 5u32)  RNG[0u64] = x  return x }
fn popc(x: u32) -> u32 { let mut c : u32 = 0u32  let mut v : u32 = 0u32  while v < 16u32 { if (x & (1u32 << v)) != 0u32 { c = c + 1u32 }  v = v + 1u32 }  return c }

fn brute_sat() -> u8 {
    let nv : u32 = NVAR[0u64]  let nc : u32 = NC[0u64]  let lim : u32 = 1u32 << nv
    let mut a : u32 = 0u32
    while a < lim {
        let mut ok : u8 = 1u8  let mut c : u32 = 0u32
        while c < nc {
            let par : u32 = popc(a & RVARS[c as u64]) & 1u32
            if par != (RRHS[c as u64] as u32) { ok = 0u8  c = nc }
            c = c + 1u32
        }
        if ok == 1u8 { return 1u8 }
        a = a + 1u32
    }
    return 0u8
}
fn xorsat() -> u8 {
    let nv : u32 = NVAR[0u64]  let m : u32 = NC[0u64]
    /* copy into working rows */
    let mut i : u32 = 0u32
    /* (work in place on RVARS/RRHS; the formula is regenerated each trial so destruction is fine) */
    let mut rank : u32 = 0u32  let mut col : u32 = 0u32
    while col < nv {
        /* find a pivot row at index >= rank with bit col set */
        let mut piv : u32 = m  let mut r : u32 = rank
        while r < m { if (RVARS[r as u64] & (1u32 << col)) != 0u32 { piv = r  r = m } else { r = r + 1u32 } }
        if piv < m {
            /* swap rows rank <-> piv */
            let tv : u32 = RVARS[rank as u64]  RVARS[rank as u64] = RVARS[piv as u64]  RVARS[piv as u64] = tv
            let th : u8 = RRHS[rank as u64]  RRHS[rank as u64] = RRHS[piv as u64]  RRHS[piv as u64] = th
            /* eliminate col from all other rows */
            let mut j : u32 = 0u32
            while j < m {
                if j != rank { if (RVARS[j as u64] & (1u32 << col)) != 0u32 {
                    RVARS[j as u64] = RVARS[j as u64] ^ RVARS[rank as u64]
                    RRHS[j as u64] = RRHS[j as u64] ^ RRHS[rank as u64]
                } }
                j = j + 1u32
            }
            rank = rank + 1u32
        }
        col = col + 1u32
    }
    /* consistency: any row "0 = 1" -> UNSAT */
    let mut k : u32 = 0u32
    while k < m { if RVARS[k as u64] == 0u32 { if RRHS[k as u64] == 1u8 { return 0u8 } }  k = k + 1u32 }
    return 1u8
}
fn gen_xor(nv: u32, nc: u32) -> i32 {
    NVAR[0u64] = nv  NC[0u64] = nc  let vm : u32 = (1u32 << nv) - 1u32
    let mut c : u32 = 0u32
    while c < nc {
        let mut b : u32 = 0u32  let mut v : u32 = 0u32
        while v < nv { if (rnd() % 3u32) == 0u32 { b = b | (1u32 << v) }  v = v + 1u32 }
        if b == 0u32 { b = 1u32 << (rnd() % nv) }
        RVARS[c as u64] = b  RRHS[c as u64] = (rnd() & 1u32) as u8
        c = c + 1u32
    }
    return 0i32
}

fn main() -> u64 {
    RNG[0u64] = 0x303A11u32
    let mut t : u32 = 0u32  let mut sat_seen : u32 = 0u32  let mut unsat_seen : u32 = 0u32
    while t < 4000u32 {
        let nv : u32 = 4u32 + (rnd() % 7u32)
        let nc : u32 = nv + (rnd() % (2u32 * nv))
        gen_xor(nv, nc)
        let o : u8 = brute_sat()        /* brute FIRST (reads RVARS/RRHS before xorsat destroys them) */
        let s : u8 = xorsat()
        if o != s { return 10u64 }
        if o == 1u8 { sat_seen = sat_seen + 1u32 } else { unsat_seen = unsat_seen + 1u32 }
        t = t + 1u32
    }
    if sat_seen < 100u32 { return 60u64 }
    if unsat_seen < 100u32 { return 61u64 }
    return 99u64
}
