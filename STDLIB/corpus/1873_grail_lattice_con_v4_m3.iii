/* 1873_grail_lattice_con_v4_m3.iii -- THE LATTICE-REPRESENTATION WALL (Finite Lattice Representation Problem), island:
 * a NON-distributive lattice IS realizable as a congruence lattice of a finite algebra.  (Fifth wall; user-named.)
 *
 * THE WALL.  Finite Lattice Representation Problem (FLRP, open since the 1960s): is EVERY finite lattice the congruence
 * lattice Con(A) of some FINITE algebra A?  (Gratzer-Schmidt 1963: every finite -- indeed algebraic -- lattice is Con
 * of an INFINITE algebra; so the obstruction is exactly FINITENESS.)  The core is OPEN.
 *
 * THE ISLAND (VERIFIED here).  Con(A) is always a lattice (a sublattice of the partition lattice of A), and many
 * lattices -- including NON-distributive ones -- are realized.  We compute the congruence lattice of the Klein four-
 * group V4 = (Z2 x Z2, XOR) and show it is exactly M3, the 5-element diamond (the smallest non-distributive lattice):
 *   - a congruence of V4 = an equivalence theta on {0,1,2,3} compatible with XOR (a~a', b~b' => a^b ~ a'^b');
 *   - EXACTLY 5 congruences exist: BOTTOM (all singletons), TOP (all equal), and 3 incomparable ATOMS -- the cosets of
 *     the three order-2 subgroups: {01|23}, {02|13}, {03|12};
 *   - they form M3: each atom strictly between bottom and top, atoms pairwise incomparable, meet(Ai,Aj)=bottom and
 *     join(Ai,Aj)=top for i!=j -- a NON-DISTRIBUTIVE lattice (M3 violates distributivity).
 * So a non-distributive lattice is a congruence lattice of a finite algebra: the FLRP island is non-trivial; the open
 * question is whether ALL finite lattices can be so realized.
 *
 * HONEST TAG (math-olympiad #4): realizing one lattice (and the standard families) is the ISLAND; it does NOT settle
 * FLRP (the open core).  Computing Con(V4)=M3 grounds representability, not universality.
 * exit 99 = Con(V4) has exactly 5 congruences forming M3 (non-distributive). */
module mconv4
var CSB : [u32; 16]    /* congruence same-block relations (4x4, packed in 16 bits) */
var PART : [u32; 4]    /* current partition as block ids a[0..3] */
var ATOMS : [u32; 4]   /* the 3 atom congruences (module-level: indexed by a runtime loop var) */

fn bit(rel: u32, i: u32, j: u32) -> u32 { return (rel >> (i * 4u32 + j)) & 1u32 }
fn build_sb() -> u32 {   /* same-block relation from PART[]: bit(i,j) iff a[i]==a[j] */
    let mut sb : u32 = 0u32  let mut i : u32 = 0u32
    while i < 4u32 { let mut j : u32 = 0u32  while j < 4u32 { if PART[i as u64] == PART[j as u64] { sb = sb | (1u32 << (i * 4u32 + j)) }  j = j + 1u32 }  i = i + 1u32 }
    return sb
}
fn is_congruence() -> u8 {   /* compatible with XOR: a[p]==a[q] & a[r]==a[s] => a[p^r]==a[q^s] */
    let mut p : u32 = 0u32
    while p < 4u32 { let mut q : u32 = 0u32
        while q < 4u32 { if PART[p as u64] == PART[q as u64] { let mut r : u32 = 0u32
            while r < 4u32 { let mut s : u32 = 0u32
                while s < 4u32 { if PART[r as u64] == PART[s as u64] {
                    if PART[(p ^ r) as u64] != PART[(q ^ s) as u64] { return 0u8 }
                }  s = s + 1u32 }
                r = r + 1u32 }
        }  q = q + 1u32 }
        p = p + 1u32 }
    return 1u8
}
fn trans_closure(rel: u32) -> u32 {
    let mut r : u32 = rel  let mut done : u8 = 0u8
    while done == 0u8 {
        let mut nr : u32 = r  let mut i : u32 = 0u32
        while i < 4u32 { let mut k : u32 = 0u32
            while k < 4u32 { if bit(r, i, k) == 1u32 { let mut j : u32 = 0u32
                while j < 4u32 { if bit(r, k, j) == 1u32 { nr = nr | (1u32 << (i * 4u32 + j)) }  j = j + 1u32 }
            }  k = k + 1u32 }
            i = i + 1u32 }
        if nr == r { done = 1u8 } else { r = nr }
    }
    return r
}
fn meet(a: u32, b: u32) -> u32 { return a & b }                          /* intersection of equivalences */
fn join(a: u32, b: u32) -> u32 { return trans_closure(a | b) }           /* transitive closure of the union */
fn refines(p: u32, q: u32) -> u8 { if (p & q) == p { return 1u8 } return 0u8 }  /* p finer than q */

fn main() -> u64 {
    /* enumerate all set partitions of {0,1,2,3} via restricted-growth strings; collect congruences */
    let mut ncong : u32 = 0u32
    let bottom : u32 = (1u32<<0u32)|(1u32<<5u32)|(1u32<<10u32)|(1u32<<15u32)   /* diagonal only */
    let top : u32 = 0xFFFFu32
    PART[0u64] = 0u32
    let mut a1 : u32 = 0u32
    while a1 < 2u32 {
        let mut a2 : u32 = 0u32
        while a2 <= a1 + 1u32 {                         /* a2 <= 1 + max(a0,a1) = a1+1 */
            let mut mx : u32 = a1  if a2 > a1 { mx = a2 }
            let m2 : u32 = mx + 1u32                    /* a3 <= 1 + max(a0,a1,a2) = mx+1 */
            let mut a3 : u32 = 0u32
            while a3 <= m2 {
                PART[1u64] = a1  PART[2u64] = a2  PART[3u64] = a3
                if is_congruence() == 1u8 {
                    let sb : u32 = build_sb()
                    /* dedup */
                    let mut seen : u8 = 0u8  let mut t : u32 = 0u32
                    while t < ncong { if CSB[t as u64] == sb { seen = 1u8 }  t = t + 1u32 }
                    if seen == 0u8 { CSB[ncong as u64] = sb  ncong = ncong + 1u32 }
                }
                a3 = a3 + 1u32
            }
            a2 = a2 + 1u32
        }
        a1 = a1 + 1u32
    }
    /* EXACTLY 5 congruences */
    if ncong != 5u32 { return (20u64 + ncong as u64) }
    /* bottom and top present */
    let mut has_bot : u8 = 0u8  let mut has_top : u8 = 0u8  let mut k : u32 = 0u32
    while k < 5u32 { if CSB[k as u64] == bottom { has_bot = 1u8 }  if CSB[k as u64] == top { has_top = 1u8 }  k = k + 1u32 }
    if has_bot != 1u8 { return 10u64 }
    if has_top != 1u8 { return 11u64 }
    /* the 3 atoms = the non-bottom, non-top congruences */
    let mut na : u32 = 0u32  let mut w : u32 = 0u32
    while w < 5u32 { if CSB[w as u64] != bottom { if CSB[w as u64] != top { ATOMS[na as u64] = CSB[w as u64]  na = na + 1u32 } }  w = w + 1u32 }
    if na != 3u32 { return 12u64 }
    /* M3: each atom strictly between bottom and top; pairwise incomparable; meet=bottom, join=top */
    let mut i : u32 = 0u32
    while i < 3u32 {
        if refines(bottom, ATOMS[i as u64]) != 1u8 { return 30u64 }
        if refines(ATOMS[i as u64], top) != 1u8 { return 31u64 }
        if ATOMS[i as u64] == bottom { return 32u64 }
        if ATOMS[i as u64] == top { return 33u64 }
        let mut j : u32 = 0u32
        while j < 3u32 {
            if i != j {
                if refines(ATOMS[i as u64], ATOMS[j as u64]) == 1u8 { return 34u64 }   /* incomparable */
                if meet(ATOMS[i as u64], ATOMS[j as u64]) != bottom { return 35u64 }
                if join(ATOMS[i as u64], ATOMS[j as u64]) != top { return 36u64 }
            }
            j = j + 1u32
        }
        i = i + 1u32
    }
    return 99u64
}
