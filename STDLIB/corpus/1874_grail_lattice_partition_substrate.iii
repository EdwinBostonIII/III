/* 1874_grail_lattice_partition_substrate.iii -- THE LATTICE-REPRESENTATION WALL, the substrate: the PARTITION LATTICE
 * is a lattice, which is WHY congruences always form a lattice (Con(A) is a sublattice of the partition lattice of A).
 *
 * FOUNDATION (VERIFIED here).  The partitions of a finite set, ordered by refinement, form a lattice Pi_n: meet = the
 * common refinement (intersection of the equivalence relations), join = the finest common coarsening (transitive
 * closure of the union).  We verify, on ALL 15 partitions of {0,1,2,3}, the full lattice axioms:
 *   - meet/join produce valid equivalence relations (reflexive, symmetric, TRANSITIVE);
 *   - idempotent (p^p=p, p v p=p), commutative, ASSOCIATIVE (over all triples), and ABSORPTION
 *     (p ^ (p v q) = p and p v (p ^ q) = p).
 * The congruences of any finite algebra are exactly the partitions compatible with its operations -- a subset closed
 * under meet and join -- so Con(A) is a SUBLATTICE of Pi_n (and is itself a lattice).  This is the substrate under
 * 1873 (Con(V4)=M3 sits inside Pi_4) and under the whole Finite Lattice Representation Problem.
 *
 * HONEST TAG: the partition lattice being a lattice is the foundational fact (Birkhoff/Ore); grounding it underpins the
 * wall and says nothing about the open FLRP (whether every finite lattice is some Con(finite algebra)).
 * exit 99 = all lattice axioms hold for the partition lattice Pi_4 (15 partitions), and meet/join stay equivalences. */
module mpisub
var PARTS : [u32; 16]   /* the 15 partition same-block relations (4x4 packed in 16 bits) */
var NP : [u32; 1]
var TMP : [u32; 4]

fn bit(rel: u32, i: u32, j: u32) -> u32 { return (rel >> (i * 4u32 + j)) & 1u32 }
fn build_sb() -> u32 { let mut sb : u32 = 0u32  let mut i : u32 = 0u32  while i < 4u32 { let mut j : u32 = 0u32  while j < 4u32 { if TMP[i as u64] == TMP[j as u64] { sb = sb | (1u32 << (i * 4u32 + j)) }  j = j + 1u32 }  i = i + 1u32 }  return sb }
fn trans_closure(rel: u32) -> u32 {
    let mut r : u32 = rel  let mut done : u8 = 0u8
    while done == 0u8 { let mut nr : u32 = r  let mut i : u32 = 0u32
        while i < 4u32 { let mut k : u32 = 0u32
            while k < 4u32 { if bit(r, i, k) == 1u32 { let mut j : u32 = 0u32
                while j < 4u32 { if bit(r, k, j) == 1u32 { nr = nr | (1u32 << (i * 4u32 + j)) }  j = j + 1u32 }
            }  k = k + 1u32 }
            i = i + 1u32 }
        if nr == r { done = 1u8 } else { r = nr } }
    return r
}
fn meet(a: u32, b: u32) -> u32 { return a & b }
fn join(a: u32, b: u32) -> u32 { return trans_closure(a | b) }
fn is_equivalence(r: u32) -> u8 {
    let mut i : u32 = 0u32
    while i < 4u32 {
        if bit(r, i, i) != 1u32 { return 0u8 }                                   /* reflexive */
        let mut j : u32 = 0u32
        while j < 4u32 {
            if bit(r, i, j) != bit(r, j, i) { return 0u8 }                        /* symmetric */
            if bit(r, i, j) == 1u32 { let mut k : u32 = 0u32
                while k < 4u32 { if bit(r, j, k) == 1u32 { if bit(r, i, k) != 1u32 { return 0u8 } }  k = k + 1u32 } }  /* transitive */
            j = j + 1u32
        }
        i = i + 1u32
    }
    return 1u8
}
fn gen_partitions() -> i32 {
    NP[0u64] = 0u32  TMP[0u64] = 0u32
    let mut a1 : u32 = 0u32
    while a1 < 2u32 {
        let mut a2 : u32 = 0u32
        while a2 <= a1 + 1u32 {
            let mut mx : u32 = a1  if a2 > a1 { mx = a2 }  let m2 : u32 = mx + 1u32
            let mut a3 : u32 = 0u32
            while a3 <= m2 {
                TMP[1u64] = a1  TMP[2u64] = a2  TMP[3u64] = a3
                PARTS[NP[0u64]] = build_sb()  NP[0u64] = NP[0u64] + 1u32
                a3 = a3 + 1u32
            }
            a2 = a2 + 1u32
        }
        a1 = a1 + 1u32
    }
    return 0i32
}

fn main() -> u64 {
    gen_partitions()
    let n : u32 = NP[0u64]
    if n != 15u32 { return (20u64 + n as u64) }                                   /* Bell(4) = 15 partitions */
    /* axioms over pairs */
    let mut ix : u32 = 0u32
    while ix < n {
        let p : u32 = PARTS[ix as u64]
        if meet(p, p) != p { return 30u64 }                                       /* idempotent */
        if join(p, p) != p { return 31u64 }
        let mut jx : u32 = 0u32
        while jx < n {
            let q : u32 = PARTS[jx as u64]
            let mpq : u32 = meet(p, q)  let jpq : u32 = join(p, q)
            if is_equivalence(mpq) != 1u8 { return 40u64 }                        /* meet is an equivalence */
            if is_equivalence(jpq) != 1u8 { return 41u64 }                        /* join is an equivalence */
            if mpq != meet(q, p) { return 32u64 }                                 /* commutative */
            if jpq != join(q, p) { return 33u64 }
            if meet(p, jpq) != p { return 34u64 }                                 /* absorption p ^ (p v q) = p */
            if join(p, mpq) != p { return 35u64 }                                 /* absorption p v (p ^ q) = p */
            jx = jx + 1u32
        }
        ix = ix + 1u32
    }
    /* associativity over triples */
    let mut a : u32 = 0u32
    while a < n { let mut b : u32 = 0u32
        while b < n { let mut c : u32 = 0u32
            while c < n {
                let pa : u32 = PARTS[a as u64]  let pb : u32 = PARTS[b as u64]  let pc : u32 = PARTS[c as u64]
                if meet(meet(pa, pb), pc) != meet(pa, meet(pb, pc)) { return 36u64 }
                if join(join(pa, pb), pc) != join(pa, join(pb, pc)) { return 37u64 }
                c = c + 1u32 }
            b = b + 1u32 }
        a = a + 1u32 }
    return 99u64
}
