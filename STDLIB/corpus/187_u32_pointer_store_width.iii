/* III conformance corpus 187 -- Stage 3.13: u32-pointer store width.
 *
 * The CLAUDE.md trap registry documented an "iiis-0 u32-pointer store
 * width bug": `p[i] = v_u32` through a *u32 pointer could emit an 8-byte
 * movq (overwriting the adjacent 4-byte slot) when v originated from a u32
 * local in an 8-byte stack slot; the workaround was byte-by-byte *u8 stores.
 *
 * Stage 3.13 verified (probe + iiis-0 disassembly) that the bug is GONE:
 * the store emits `mov %edx,(%rax,%rcx,4)` -- a 4-byte movl with scale-4
 * indexing, exactly 4 bytes, no adjacent-slot clobber.  This pins it: a
 * u32 stored through a *u32 pointer must NOT disturb the neighbouring slot.
 *
 * Exit = 99 on success; 1..6 = the specific slot that was clobbered.
 */
module corpus_187

var BUF : [u32; 4]

fn store_u32(p_base: u64, idx: u64, v: u32) -> i32 {
    let p : *u32 = p_base as *u32
    p[idx] = v
    return 0i32
}

fn main() -> u64 {
    BUF[0u32] = 0xDEADBEEFu32
    BUF[1u32] = 0xCAFEBABEu32
    BUF[2u32] = 0xF00DD00Du32
    BUF[3u32] = 0x12345678u32
    let base : u64 = (&BUF[0u32]) as u64
    let p : *u32 = base as *u32
    store_u32(base, 0u64, 0xAAAAAAAAu32)
    if p[0u64] != 0xAAAAAAAAu32 { return 1u64 }
    if p[1u64] != 0xCAFEBABEu32 { return 2u64 }
    store_u32(base, 2u64, 0xBBBBBBBBu32)
    if p[2u64] != 0xBBBBBBBBu32 { return 3u64 }
    if p[3u64] != 0x12345678u32 { return 4u64 }
    p[1u64] = 0x99999999u32
    if p[1u64] != 0x99999999u32 { return 5u64 }
    if p[2u64] != 0xBBBBBBBBu32 { return 6u64 }
    return 99u64
}
