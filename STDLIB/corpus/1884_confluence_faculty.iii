/* 1884_confluence_faculty.iii -- GATES the production numera::confluence faculty.
 *
 * On random TERMINATING abstract rewriting systems (acyclic relations), the three Newman-equivalent computations the
 * faculty exposes -- direct global confluence (cf_confluent, all reach-pairs), local confluence (cf_locally_confluent,
 * one-step peaks only), and unique normal forms (cf_count_nf==1 for every state) -- must ALL agree.  Three different
 * computations coinciding on every system = Newman's Lemma + Church-Rosser, the production gate.
 * exit 99 = cf_kat()==99 AND the three predicates agree on every terminating system, both confluent/non-confluent seen. */
module mcff
extern @abi(c-msvc-x64) fn cf_reset(n: u32) -> i32 from "confluence.iii"
extern @abi(c-msvc-x64) fn cf_step(a: u32, b: u32) -> i32 from "confluence.iii"
extern @abi(c-msvc-x64) fn cf_terminating() -> u8 from "confluence.iii"
extern @abi(c-msvc-x64) fn cf_locally_confluent() -> u8 from "confluence.iii"
extern @abi(c-msvc-x64) fn cf_confluent() -> u8 from "confluence.iii"
extern @abi(c-msvc-x64) fn cf_count_nf(a: u32) -> u32 from "confluence.iii"
extern @abi(c-msvc-x64) fn cf_kat() -> u64 from "confluence.iii"

var RNG : [u32; 1]
fn rnd() -> u32 { let mut x : u32 = RNG[0u64]  x = x ^ (x << 13u32)  x = x ^ (x >> 17u32)  x = x ^ (x << 5u32)  RNG[0u64] = x  return x }

fn main() -> u64 {
    if cf_kat() != 99u64 { return 50u64 }
    RNG[0u64] = 0xC0F11Eu32
    let mut t : u32 = 0u32  let mut conf : u32 = 0u32  let mut nonconf : u32 = 0u32
    while t < 6000u32 {
        let n : u32 = 3u32 + (rnd() % 8u32)            /* 3..10 states */
        cf_reset(n)
        /* acyclic generator: edges a->b only for b<a => terminating */
        let mut a : u32 = 0u32
        while a < n {
            let mut b : u32 = 0u32
            while b < a { if (rnd() % 3u32) == 0u32 { cf_step(a, b) }  b = b + 1u32 }
            a = a + 1u32
        }
        if cf_terminating() != 1u8 { return 10u64 }    /* acyclic must be terminating */
        let g : u8 = cf_confluent()
        let l : u8 = cf_locally_confluent()
        if g != l { return 11u64 }                     /* Newman: terminating => (global <=> local) */
        /* unique-NF characterisation: confluent <=> every state has exactly one normal form */
        let mut alluniq : u8 = 1u8  let mut v : u32 = 0u32
        while v < n { if cf_count_nf(v) != 1u32 { alluniq = 0u8  v = n } else { v = v + 1u32 } }
        if (g == 1u8) != (alluniq == 1u8) { return 12u64 }   /* confluent <=> unique NFs (terminating) */
        if g == 1u8 { conf = conf + 1u32 } else { nonconf = nonconf + 1u32 }
        t = t + 1u32
    }
    if conf < 100u32 { return 60u64 }
    if nonconf < 100u32 { return 61u64 }
    return 99u64
}
