/* 1885_graph_refine_faculty.iii -- GATES the production numera::graph_refine faculty (graph fingerprint + exact iso)
 * against a brute-force permutation isomorphism oracle.
 * exit 99 = gr_kat()==99 AND gr_iso() == brute permutation iso on every random pair, both outcomes, AND isomorphic
 *           pairs share a fingerprint (soundness). */
module mgrf
extern @abi(c-msvc-x64) fn gr_reset_a(n: u32) -> i32 from "graph_refine.iii"
extern @abi(c-msvc-x64) fn gr_reset_b(n: u32) -> i32 from "graph_refine.iii"
extern @abi(c-msvc-x64) fn gr_edge_a(u: u32, w: u32) -> i32 from "graph_refine.iii"
extern @abi(c-msvc-x64) fn gr_edge_b(u: u32, w: u32) -> i32 from "graph_refine.iii"
extern @abi(c-msvc-x64) fn gr_iso() -> u8 from "graph_refine.iii"
extern @abi(c-msvc-x64) fn gr_fingerprint_a() -> u64 from "graph_refine.iii"
extern @abi(c-msvc-x64) fn gr_kat() -> u64 from "graph_refine.iii"
var QGA : [u32; 8]
var QGB : [u32; 8]
var QPERM : [u32; 8]
var QNV : [u32; 1]
var QRNG : [u32; 1]
fn rnd() -> u32 { let mut x : u32 = QRNG[0u64]  x = x ^ (x << 13u32)  x = x ^ (x >> 17u32)  x = x ^ (x << 5u32)  QRNG[0u64] = x  return x }
fn next_perm(n: u32) -> u8 {
    if n < 2u32 { return 0u8 }
    let mut i : u32 = n - 1u32  let mut fi : u8 = 0u8
    while fi == 0u8 { if i == 0u32 { fi = 2u8 } else { if QPERM[(i-1u32) as u64] < QPERM[i as u64] { fi = 1u8 } else { i = i - 1u32 } } }
    if fi == 2u8 { return 0u8 }
    let piv : u32 = i - 1u32  let mut j : u32 = n - 1u32
    while QPERM[j as u64] <= QPERM[piv as u64] { j = j - 1u32 }
    let t : u32 = QPERM[piv as u64]  QPERM[piv as u64] = QPERM[j as u64]  QPERM[j as u64] = t
    let mut lo : u32 = i  let mut hi : u32 = n - 1u32
    while lo < hi { let tt : u32 = QPERM[lo as u64]  QPERM[lo as u64] = QPERM[hi as u64]  QPERM[hi as u64] = tt  lo = lo + 1u32  hi = hi - 1u32 }
    return 1u8
}
fn brute_iso(n: u32) -> u8 {
    let mut i : u32 = 0u32  while i < n { QPERM[i as u64] = i  i = i + 1u32 }
    let mut more : u8 = 1u8
    while more == 1u8 {
        let mut ok : u8 = 1u8  let mut u : u32 = 0u32
        while u < n { let mut v : u32 = 0u32
            while v < n { let e1 : u32 = (QGA[u as u64] >> v) & 1u32  let e2 : u32 = (QGB[QPERM[u as u64] as u64] >> QPERM[v as u64]) & 1u32  if e1 != e2 { ok = 0u8  v = n  u = n } else { v = v + 1u32 } }
            u = u + 1u32 }
        if ok == 1u8 { return 1u8 }
        more = next_perm(n)
    }
    return 0u8
}
fn main() -> u64 {
    if gr_kat() != 99u64 { return 50u64 }
    QRNG[0u64] = 0x6841CEu32
    let mut t : u32 = 0u32  let mut iso : u32 = 0u32  let mut non : u32 = 0u32
    while t < 3000u32 {
        let n : u32 = 4u32 + (rnd() % 3u32)
        QNV[0u64] = n
        let mut i : u32 = 0u32  while i < n { QGA[i as u64] = 0u32  QGB[i as u64] = 0u32  i = i + 1u32 }
        gr_reset_a(n)  gr_reset_b(n)
        /* random graph A */
        let mut u : u32 = 0u32
        while u < n { let mut v : u32 = u + 1u32  while v < n { if (rnd() & 1u32) == 0u32 { QGA[u as u64] = QGA[u as u64]|(1u32<<v)  QGA[v as u64] = QGA[v as u64]|(1u32<<u)  gr_edge_a(u,v) }  v = v + 1u32 }  u = u + 1u32 }
        /* B: 50% a random relabelling of A (iso), 50% a fresh random graph */
        if (rnd() & 1u32) == 0u32 {
            let mut p : u32 = 0u32  while p < n { QPERM[p as u64] = p  p = p + 1u32 }
            let mut q : u32 = n  while q > 1u32 { let r : u32 = rnd() % q  let tt : u32 = QPERM[(q-1u32) as u64]  QPERM[(q-1u32) as u64] = QPERM[r as u64]  QPERM[r as u64] = tt  q = q - 1u32 }
            let mut a : u32 = 0u32
            while a < n { let mut b : u32 = a + 1u32 while b < n { if ((QGA[a as u64]>>b)&1u32)==1u32 { let pa : u32 = QPERM[a as u64]  let pb : u32 = QPERM[b as u64]  QGB[pa as u64]=QGB[pa as u64]|(1u32<<pb)  QGB[pb as u64]=QGB[pb as u64]|(1u32<<pa)  gr_edge_b(pa,pb) }  b = b + 1u32 }  a = a + 1u32 }
        } else {
            let mut a : u32 = 0u32
            while a < n { let mut b : u32 = a + 1u32 while b < n { if (rnd() & 1u32)==0u32 { QGB[a as u64]=QGB[a as u64]|(1u32<<b)  QGB[b as u64]=QGB[b as u64]|(1u32<<a)  gr_edge_b(a,b) }  b = b + 1u32 }  a = a + 1u32 }
        }
        let fac : u8 = gr_iso()
        let bru : u8 = brute_iso(n)
        if fac != bru { return 10u64 }
        if bru == 1u8 { iso = iso + 1u32 } else { non = non + 1u32 }
        t = t + 1u32
    }
    if iso < 200u32 { return 60u64 }
    if non < 200u32 { return 61u64 }
    return 99u64
}
