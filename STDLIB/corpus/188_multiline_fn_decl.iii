/* III conformance corpus 188 -- Stage 3.14: multi-line fn declarations.
 *
 * The CLAUDE.md trap registry documented "multi-line function declarations
 * NOT supported": a wrapped `fn name(params) -> ret @attr {` prefix would
 * either bail with `expected top-level declaration` OR (worse) parse
 * successfully but bind parameters to WRONG stack offsets -- a silent
 * miscompile producing "close but wrong" output.
 *
 * Stage 3.14 verified (probe, iiis-0 + iiis-2) that the bug is GONE:
 * multi-line signatures (params wrapped across lines, the `-> ret @attr {`
 * on its own line, 3- and 5-param forms, @export) all parse AND bind
 * parameters to the correct offsets -- no parse failure, no silent
 * corruption.  This pins it.
 *
 * Exit = 99 on success; 1..3 = the specific multi-line form that regressed.
 */
module corpus_188

fn ml3(
    a: u32,
    b: u32,
    c: u32
) -> u32 {
    return a + b * 10u32 + c * 100u32
}

fn ml5(
    a: u32, b: u32,
    c: u32, d: u32,
    e: u32
) -> u32 {
    return a + b * 2u32 + c * 3u32 + d * 4u32 + e * 5u32
}

fn ml_attr(
    x: u32,
    y: u32
) -> u32 @export {
    return x * 1000u32 + y
}

fn main() -> u64 {
    if ml3(3u32, 4u32, 5u32) != 543u32 { return 1u64 }
    if ml5(1u32, 2u32, 3u32, 4u32, 5u32) != 55u32 { return 2u64 }
    if ml_attr(7u32, 42u32) != 7042u32 { return 3u64 }
    return 99u64
}
