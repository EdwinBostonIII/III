/* 1890_comm_lb_faculty.iii -- GATES numera::comm_lb against an independent GF(2) rank computation.
 * exit 99 = cml_kat()==99 AND cml_rank_gf2 == independent rank on random matrices AND cml_lb == ceil(log2 rank). */
module mcmlf
extern @abi(c-msvc-x64) fn cml_reset(n: u32) -> i32 from "comm_lb.iii"
extern @abi(c-msvc-x64) fn cml_set(r: u32, c: u32, v: u8) -> i32 from "comm_lb.iii"
extern @abi(c-msvc-x64) fn cml_rank_gf2() -> u32 from "comm_lb.iii"
extern @abi(c-msvc-x64) fn cml_lb() -> u32 from "comm_lb.iii"
extern @abi(c-msvc-x64) fn cml_kat() -> u64 from "comm_lb.iii"
var QR : [u64; 32]
var QN : [u32; 1]
var RNG : [u32; 1]
fn rnd() -> u32 { let mut x : u32 = RNG[0u64]  x = x ^ (x << 13u32)  x = x ^ (x >> 17u32)  x = x ^ (x << 5u32)  RNG[0u64] = x  return x }
fn qrank() -> u32 {     /* independent GF(2) rank over QR */
    let n : u32 = QN[0u64]  let mut rank : u32 = 0u32  let mut col : u32 = 0u32
    while col < n {
        let mut piv : u32 = n  let mut r : u32 = rank
        while r < n { if (QR[r as u64] & (1u64 << (col as u64))) != 0u64 { piv = r  r = n } else { r = r + 1u32 } }
        if piv < n {
            let t : u64 = QR[rank as u64]  QR[rank as u64] = QR[piv as u64]  QR[piv as u64] = t
            let mut j : u32 = 0u32  while j < n { if j != rank { if (QR[j as u64] & (1u64 << (col as u64))) != 0u64 { QR[j as u64] = QR[j as u64] ^ QR[rank as u64] } }  j = j + 1u32 }
            rank = rank + 1u32
        }
        col = col + 1u32
    }
    return rank
}
fn ceil_log2(r: u32) -> u32 { if r <= 1u32 { return 0u32 }  let mut c : u32 = 0u32  while (1u32 << c) < r { c = c + 1u32 }  return c }
fn main() -> u64 {
    if cml_kat() != 99u64 { return 50u64 }
    RNG[0u64] = 0xC0117Bu32
    let mut t : u32 = 0u32  let mut varied : u32 = 0u32
    while t < 4000u32 {
        let n : u32 = 3u32 + (rnd() % 10u32)           /* 3..12 */
        QN[0u64] = n  cml_reset(n)
        let mut r : u32 = 0u32 while r < n { QR[r as u64] = 0u64  r = r + 1u32 }
        let mut a : u32 = 0u32
        while a < n { let mut b : u32 = 0u32 while b < n { if (rnd() & 1u32) == 0u32 { cml_set(a,b,1u8)  QR[a as u64] = QR[a as u64] | (1u64 << b) } else { cml_set(a,b,0u8) }  b = b + 1u32 }  a = a + 1u32 }
        let fac : u32 = cml_rank_gf2()
        let lb : u32 = cml_lb()
        let ind : u32 = qrank()                        /* destroys QR; do AFTER feeding */
        if fac != ind { return 10u64 }
        if lb != ceil_log2(fac) { return 11u64 }
        if fac > 1u32 { varied = varied + 1u32 }
        t = t + 1u32
    }
    if varied < 100u32 { return 60u64 }
    return 99u64
}
