/* 1903_dome_deliberate.iii  --  omnia::dome, the inverse-form society performing the thing determinism
 * structurally cannot: REVERSIBLE, PROVENANCE-CARRYING deliberation (evade a bad choice by living it).
 *
 * The trap (a butterfly-effect trap): move A is TEMPTING up front (immediate 6) but its consequence
 * RECURS to 5 (odd = loss); move B is humbler (immediate 4) but its consequence recurs to 4 (even = win).
 * A deterministic greedy decider judges the IMMEDIATE, commits to A, and is trapped in the recurrent 5 it
 * could neither foresee nor undo.  The Dome society CHOOSES A too -- then LIVES it (WAVE ripples the
 * consequence, EYE sees it recur, the lived parity is odd/bad), so TIDE REWINDS and ECHO re-chooses B,
 * with A's failed branch RETAINED as provenance and the lesson kept live to inform the re-choice.
 *
 * Codes 11-16: the Dome evades where determinism is trapped, carrying provenance.
 * Codes 21-22: TEETH -- the SAME exploration WITHOUT TIDE's rewind cannot evade (proves reversal IS the
 *              mechanism, not luck or B dominating).  exit 99 = the inverse form wins on its home turf.
 */
module m1903

extern @abi(c-msvc-x64) fn dome_reset() -> i32 from "dome.iii"
extern @abi(c-msvc-x64) fn dome_emit(participant: u64, kind: u64, value: u64, payload: u64) -> u64 from "dome.iii"
extern @abi(c-msvc-x64) fn dome_count() -> u32 from "dome.iii"
extern @abi(c-msvc-x64) fn dome_mark() -> u32 from "dome.iii"
extern @abi(c-msvc-x64) fn dome_rewind(bp: u32) -> i32 from "dome.iii"
extern @abi(c-msvc-x64) fn dome_active_max(participant: u64) -> u64 from "dome.iii"
extern @abi(c-msvc-x64) fn dome_active_parity(participant: u64) -> u64 from "dome.iii"
extern @abi(c-msvc-x64) fn dome_recurred(participant: u64, payload: u64, upto: u32) -> u32 from "dome.iii"
extern @abi(c-msvc-x64) fn dome_provenance_count() -> u32 from "dome.iii"
extern @abi(c-msvc-x64) fn dome_live_kind_count(participant: u64, kind: u64) -> u32 from "dome.iii"

const EYE  : u64 = 0u64
const WAVE : u64 = 1u64
const ECHO : u64 = 2u64
const TIDE : u64 = 3u64
const K_MOVE   : u64 = 0u64
const K_RIPPLE : u64 = 1u64
const K_LESSON : u64 = 3u64
const DNULL : u32 = 0xFFFFFFFFu32

fn main() -> u64 {
    /* ===== the deterministic twin: greedy on the IMMEDIATE, commits, cannot rewind ===== */
    let imm_a : u64 = 6u64   /* A is tempting up front */
    let imm_b : u64 = 4u64
    let rec_a : u64 = 5u64   /* ...but A's lived consequence recurs to 5 (odd = loss) */
    let rec_b : u64 = 4u64   /* B's recurs to 4 (even = win) */
    let mut det_out : u64 = rec_b
    if imm_a > imm_b { det_out = rec_a }     /* greedy commits to A -> stuck with recurrent 5 */
    let det_parity : u64 = det_out & 1u64
    if det_parity != 1u64 { return 11u64 }   /* determinism is TRAPPED: odd = loss */

    /* ===== the Dome society: choose A, LIVE it, evade it ===== */
    dome_reset()
    dome_emit(EYE, K_MOVE, 0u64, 100u64)     /* EYE perceives the start */
    let bp : u32 = dome_mark()               /* TIDE's branch-point */
    dome_emit(ECHO, K_MOVE, 6u64, 200u64)    /* ECHO proposes A (greedy immediate 6) */
    dome_emit(WAVE, K_RIPPLE, 5u64, 201u64)  /* WAVE ripples A's consequence... */
    dome_emit(WAVE, K_RIPPLE, 5u64, 201u64)  /* ...which recurs (a lasso): the butterfly closes */
    let n1 : u32 = dome_count()
    let recA : u32 = dome_recurred(WAVE, 201u64, n1)
    if recA == DNULL { return 12u64 }                 /* the consequence RECURRED (lived, not predicted) */
    if dome_active_parity(WAVE) != 1u64 { return 12u64 }   /* the lived outcome is odd = bad */
    dome_rewind(bp)                          /* TIDE evades: A's exploration becomes provenance */
    dome_emit(ECHO, K_LESSON, 5u64, 200u64)  /* the retained lesson (survives the rewind) */
    dome_emit(ECHO, K_MOVE, 4u64, 300u64)    /* ECHO re-chooses B, informed */
    dome_emit(WAVE, K_RIPPLE, 4u64, 301u64)
    dome_emit(WAVE, K_RIPPLE, 4u64, 301u64)
    if dome_active_parity(WAVE) != 0u64 { return 13u64 }   /* the Dome's LIVE outcome is now even = WIN */
    if dome_active_parity(WAVE) == det_parity { return 13u64 }  /* it evaded what determinism could not */
    if dome_provenance_count() == 0u32 { return 14u64 }   /* A's failed branch RETAINED (the debug trail) */
    if dome_live_kind_count(ECHO, K_LESSON) != 1u32 { return 15u64 }  /* the re-choice was informed */
    if dome_active_max(WAVE) != 4u64 { return 16u64 }     /* live outcome = B's 4 (A's 5 is provenance) */

    /* ===== TEETH: the SAME exploration WITHOUT TIDE cannot evade ===== */
    dome_reset()
    dome_emit(EYE, K_MOVE, 0u64, 100u64)
    dome_emit(ECHO, K_MOVE, 6u64, 200u64)
    dome_emit(WAVE, K_RIPPLE, 5u64, 201u64)
    dome_emit(WAVE, K_RIPPLE, 5u64, 201u64)
    dome_emit(ECHO, K_MOVE, 4u64, 300u64)    /* re-choose B, but NEVER rewind A */
    dome_emit(WAVE, K_RIPPLE, 4u64, 301u64)
    dome_emit(WAVE, K_RIPPLE, 4u64, 301u64)
    if dome_active_parity(WAVE) != 1u64 { return 21u64 }  /* A's 5 still LIVE -> max 5 -> odd -> LOSS */
    if dome_active_max(WAVE) != 5u64 { return 22u64 }     /* reversal IS the evasion mechanism */

    return 99u64
}
