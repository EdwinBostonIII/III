/* 1904_dome_society_compare.iii  --  the COMPARISON DOME: the same butterfly-trap run through a
 * deterministic faculty AND the inverse-form society (omnia::dome_society), with the asymmetry MEASURED
 * on every axis.  This is the evil-twins-in-a-dome comparison, instrumented.
 *
 * Society wiring (an explicit, inspectable topology of who perceives whom):
 *   ECHO --ripple--> WAVE      (a choice is felt by the consequence-layer)
 *   WAVE --ripple--> EYE,TIDE  (the consequence is perceived + evaluable)
 * Each twin holds its OWN log; a ripple is DELIVERED into the subscriber's log.
 *
 * The trap: move A immediate 6 (tempting) recurs to 5 (odd=loss); move B immediate 4 recurs to 4 (even=win).
 *
 * Measured axes (codes 11-19): outcome, rewinds, provenance retained, choices explored, cross-perception,
 *   witnessed root.  Code 21: TEETH -- without TIDE the society cannot evade.  exit 99 = the asymmetry holds.
 */
module m1904

extern @abi(c-msvc-x64) fn soc_reset() -> i32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_subscribe(frm: u64, to: u64) -> i32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_emit(twin: u64, kind: u64, value: u64, payload: u64) -> u64 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_count(twin: u64) -> u32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_mark() -> i32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_rewind() -> i32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_active_max(twin: u64) -> u64 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_active_parity(twin: u64) -> u64 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_recurred(twin: u64, payload: u64, upto: u32) -> u32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_provenance_count() -> u32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_rewind_count() -> u32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_kind_total(twin: u64, kind: u64) -> u32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_perceived_count(twin: u64) -> u32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_witness_global() -> u64 from "dome_society.iii"

const EYE  : u64 = 0u64
const WAVE : u64 = 1u64
const ECHO : u64 = 2u64
const TIDE : u64 = 3u64
const K_MOVE   : u64 = 0u64
const K_RIPPLE : u64 = 1u64
const K_LESSON : u64 = 3u64
const DNULL : u32 = 0xFFFFFFFFu32

fn main() -> u64 {
    /* ===== the deterministic faculty: greedy on the immediate, commit, no rewind, no provenance ===== */
    let imm_a : u64 = 6u64
    let imm_b : u64 = 4u64
    let rec_a : u64 = 5u64
    let rec_b : u64 = 4u64
    let mut det_out : u64 = rec_b
    if imm_a > imm_b { det_out = rec_a }       /* greedy commits to A -> stuck with recurrent 5 */
    let det_parity : u64 = det_out & 1u64
    let det_rewinds : u32 = 0u32
    let det_provenance : u32 = 0u32
    let det_choices : u32 = 1u32               /* committed exactly one */
    if det_parity != 1u64 { return 11u64 }     /* determinism LOSES (odd) */

    /* ===== the society: wire it, then live-and-evade ===== */
    soc_reset()
    soc_subscribe(ECHO, WAVE)                  /* ECHO's choices ripple to WAVE */
    soc_subscribe(WAVE, EYE)                   /* WAVE's consequences ripple to EYE */
    soc_subscribe(WAVE, TIDE)                  /* ...and to TIDE (for evaluation) */
    soc_emit(EYE, K_MOVE, 0u64, 100u64)        /* EYE perceives the start (its own) */
    soc_mark()                                 /* branch-point */
    soc_emit(ECHO, K_MOVE, 6u64, 200u64)       /* ECHO chooses A (6) -> felt by WAVE */
    soc_emit(WAVE, K_RIPPLE, 5u64, 201u64)     /* A's consequence -> perceived by EYE+TIDE */
    soc_emit(WAVE, K_RIPPLE, 5u64, 201u64)     /* ...recurs (the butterfly closes) */
    let nE : u32 = soc_count(EYE)
    let recA : u32 = soc_recurred(EYE, 201u64, nE)
    if recA == DNULL { return 12u64 }                   /* EYE PERCEIVED the recurrence in its own log */
    if soc_active_parity(EYE) != 1u64 { return 12u64 }  /* lived outcome odd = bad */
    soc_rewind()                               /* TIDE evades; A's branch -> provenance, per twin */
    soc_emit(ECHO, K_LESSON, 5u64, 200u64)     /* retained lesson (survives the rewind) */
    soc_emit(ECHO, K_MOVE, 4u64, 300u64)       /* ECHO re-chooses B */
    soc_emit(WAVE, K_RIPPLE, 4u64, 301u64)
    soc_emit(WAVE, K_RIPPLE, 4u64, 301u64)
    if soc_active_parity(EYE) != 0u64 { return 13u64 }  /* the society's LIVE outcome is even = WIN */

    /* ===== the measured asymmetry, axis by axis ===== */
    let soc_parity : u64 = soc_active_parity(EYE)
    let soc_rew    : u32 = soc_rewind_count()
    let soc_prov   : u32 = soc_provenance_count()
    let soc_choices: u32 = soc_kind_total(ECHO, K_MOVE)
    let perc_wave  : u32 = soc_perceived_count(WAVE)
    let perc_eye   : u32 = soc_perceived_count(EYE)
    let soc_live   : u64 = soc_active_max(EYE)
    let wroot      : u64 = soc_witness_global()

    if soc_parity == det_parity { return 14u64 }   /* OUTCOME: society wins where determinism loses */
    if soc_rew != 1u32 { return 15u64 }            /* REVERSAL: society rewound once... */
    if det_rewinds != 0u32 { return 15u64 }        /* ...determinism cannot rewind at all */
    if soc_prov == 0u32 { return 16u64 }           /* PROVENANCE: society retains the failed branch... */
    if det_provenance != 0u32 { return 16u64 }     /* ...determinism erased its alternative */
    if soc_choices != 2u32 { return 17u64 }        /* EXPLORATION: society tried A then B... */
    if det_choices != 1u32 { return 17u64 }        /* ...determinism committed to one */
    if perc_wave == 0u32 { return 18u64 }          /* PERCEPTION: WAVE heard ECHO (subscription live) */
    if perc_eye == 0u32 { return 18u64 }           /* ...EYE heard WAVE */
    if soc_live != 4u64 { return 19u64 }           /* society's live value = B's 4 (A's 5 is provenance) */
    if wroot == 0u64 { return 19u64 }              /* a witnessed root over the FULL history (provenance sealed) */

    /* ===== TEETH: without TIDE, the same exploration cannot evade ===== */
    soc_reset()
    soc_subscribe(ECHO, WAVE)
    soc_subscribe(WAVE, EYE)
    soc_emit(EYE, K_MOVE, 0u64, 100u64)
    soc_emit(ECHO, K_MOVE, 6u64, 200u64)
    soc_emit(WAVE, K_RIPPLE, 5u64, 201u64)
    soc_emit(WAVE, K_RIPPLE, 5u64, 201u64)
    soc_emit(ECHO, K_MOVE, 4u64, 300u64)
    soc_emit(WAVE, K_RIPPLE, 4u64, 301u64)
    soc_emit(WAVE, K_RIPPLE, 4u64, 301u64)
    if soc_active_parity(EYE) != 1u64 { return 21u64 }  /* A's 5 still live -> max 5 -> odd -> LOSS */

    return 99u64
}
