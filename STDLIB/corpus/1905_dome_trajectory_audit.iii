/* 1905_dome_trajectory_audit.iii  --  the evil-twins of XII + nous, assured by TRAJECTORY AUDIT (not KAT).
 *
 * The task is REAL rewriting, not a toy trap.  A small rewrite system:  R1: t1->t2 ;  from t2 either
 * RBAD: t2->t1 (loops) or RGOOD: t2->t3 (normal form t3).  The deterministic XII-committer (Twin A) is
 * greedy on the rule order, prefers RBAD, and LOOPS t1->t2->t1->t2 forever -- FATAL (never normalises).
 *
 * The inverse society (Twin B): ECHO is the inverse-NOUS (proposes the next rule by folding lived
 * outcomes); WAVE+EYE are the inverse-XII rewrite explorer (apply a rule, perceive the resulting term,
 * detect when a term RECURS = a rewrite loop); TIDE rewinds the looping branch and ECHO re-proposes
 * RGOOD -> reaches t3 -- ALIVE.  A reversible rewrite-strategy explorer: it evades a non-terminating
 * rule order a committed decider cannot escape.
 *
 * Assurance is by TRAJECTORY AUDIT (omnia::dome_audit), NOT by `result == 42`:
 *   codes 12-16  A provenance / B shadow-race survival / C lasso-resonance / divergence signature / full audit.
 * Plus the STUBBORN-DETERMINISM claim (21-22): the frozen witnessed history re-folds byte-identical
 * (deterministic), and any single-event tamper moves the witness (assurance).  Code 11 = loop undetected.
 * Code 21/22 = determinism/tamper-detection broken.  exit 99 = the trajectory is sound.
 */
module m1905

extern @abi(c-msvc-x64) fn soc_reset() -> i32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_subscribe(frm: u64, to: u64) -> i32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_emit(twin: u64, kind: u64, value: u64, payload: u64) -> u64 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_count(twin: u64) -> u32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_mark() -> i32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_rewind() -> i32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_active_max(twin: u64) -> u64 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_recurred(twin: u64, payload: u64, upto: u32) -> u32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_provenance_count() -> u32 from "dome_society.iii"
extern @abi(c-msvc-x64) fn soc_witness_global() -> u64 from "dome_society.iii"

extern @abi(c-msvc-x64) fn ta_provenance_ok(prov: u32) -> u32 from "dome_audit.iii"
extern @abi(c-msvc-x64) fn ta_shadow_race_ok(a: u32, b: u32) -> u32 from "dome_audit.iii"
extern @abi(c-msvc-x64) fn ta_lasso_resonance_ok(recurred: u32, active: u64, immediate: u64) -> u32 from "dome_audit.iii"
extern @abi(c-msvc-x64) fn ta_divergence_sig(dome_witness: u64, prov: u32) -> u64 from "dome_audit.iii"
extern @abi(c-msvc-x64) fn ta_divergence_ok(dome_witness: u64, classical_witness: u64, prov: u32) -> u32 from "dome_audit.iii"
extern @abi(c-msvc-x64) fn ta_audit_pass(prov: u32, a: u32, b: u32, recurred: u32, active: u64, immediate: u64, dome_w: u64, classical_w: u64) -> u32 from "dome_audit.iii"

const EYE  : u64 = 0u64
const WAVE : u64 = 1u64
const ECHO : u64 = 2u64
const TIDE : u64 = 3u64
const K_MOVE   : u64 = 0u64
const K_RIPPLE : u64 = 1u64
const K_LESSON : u64 = 3u64
const R1    : u64 = 10u64
const RBAD  : u64 = 20u64
const RGOOD : u64 = 30u64
const DNULL : u32 = 0xFFFFFFFFu32

fn main() -> u64 {
    /* ===== Twin A: the deterministic XII-committer (greedy rule order RBAD) -- LOOPS ===== */
    let budget : u32 = 8u32
    let mut det_term : u64 = 1u64
    let mut det_steps : u32 = 0u32
    let mut det_alive : u32 = 0u32
    while det_steps < budget {
        if det_term == 3u64 { det_alive = 1u32  det_steps = budget }
        else {
            if det_term == 1u64 { det_term = 2u64 }     /* R1: t1->t2 */
            else { det_term = 1u64 }                    /* greedy RBAD: t2->t1 (loops) */
            det_steps = det_steps + 1u32
        }
    }
    /* det_alive stays 0 -- it loops t1->t2->t1->t2, never reaching the normal form t3 (FATAL) */

    /* ===== Twin B: the inverse society -- live the loop, evade it, normalise ===== */
    soc_reset()
    soc_subscribe(ECHO, WAVE)            /* inverse-nous proposals felt by the rewrite engine */
    soc_subscribe(WAVE, EYE)             /* resulting terms perceived by EYE */
    soc_subscribe(WAVE, TIDE)
    soc_emit(EYE, K_MOVE, 1u64, 1u64)    /* EYE perceives the start term t1 */
    soc_emit(ECHO, K_MOVE, R1, 1u64)     /* inverse-nous proposes R1 */
    soc_emit(WAVE, K_RIPPLE, 2u64, 2u64) /* inverse-xii applies R1 -> t2 */
    soc_mark()                           /* branch-point at t2 */
    soc_emit(ECHO, K_MOVE, RBAD, 2u64)   /* greedy proposes RBAD (the bait) */
    soc_emit(WAVE, K_RIPPLE, 1u64, 1u64) /* applies RBAD -> t1 : the term RECURS */
    let ce : u32 = soc_count(EYE)
    let prior : u32 = ce - 1u32
    let rec : u32 = soc_recurred(EYE, 1u64, prior)   /* did t1 appear before this? -> a loop */
    let mut recurred : u32 = 0u32
    if rec != DNULL { recurred = 1u32 }
    if recurred != 1u32 { return 11u64 }             /* the rewrite loop MUST be detected */
    soc_rewind()                         /* TIDE evades the looping branch (-> provenance) */
    soc_emit(ECHO, K_LESSON, RBAD, 2u64) /* inverse-nous records: RBAD loops */
    soc_emit(ECHO, K_MOVE, RGOOD, 2u64)  /* ...and re-proposes RGOOD */
    soc_emit(WAVE, K_RIPPLE, 3u64, 3u64) /* applies RGOOD -> t3 = NORMAL FORM */
    let active : u64 = soc_active_max(EYE)            /* live terms t1,t2,t3 -> max 3 (normalised) */
    let mut soc_alive : u32 = 0u32
    if active == 3u64 { soc_alive = 1u32 }

    /* capture the trajectory's audit inputs BEFORE the classical re-run clears the log */
    let dome_w : u64 = soc_witness_global()
    let dome_prov : u32 = soc_provenance_count()

    /* the classical deterministic trace's witness (the looping run, no rewind, no provenance) */
    soc_reset()
    soc_emit(EYE, K_MOVE, 1u64, 1u64)
    soc_emit(WAVE, K_RIPPLE, 2u64, 2u64)
    soc_emit(WAVE, K_RIPPLE, 1u64, 1u64)
    soc_emit(WAVE, K_RIPPLE, 2u64, 2u64)
    soc_emit(WAVE, K_RIPPLE, 1u64, 1u64)
    let classical_w : u64 = soc_witness_global()

    /* ===== TRAJECTORY AUDIT -- assert the geometry of the execution, not the answer ===== */
    if ta_provenance_ok(dome_prov) != 1u32 { return 12u64 }                       /* A: it bled */
    if ta_shadow_race_ok(det_alive, soc_alive) != 1u32 { return 13u64 }           /* B: A FATAL, B ALIVE */
    if ta_lasso_resonance_ok(recurred, active, 1u64) != 1u32 { return 14u64 }     /* C: lasso + saw past bait */
    if ta_divergence_ok(dome_w, classical_w, dome_prov) != 1u32 { return 15u64 }  /* divergence signature valid */
    if ta_audit_pass(dome_prov, det_alive, soc_alive, recurred, active, 1u64, dome_w, classical_w) != 1u32 { return 16u64 }
    let sig : u64 = ta_divergence_sig(dome_w, dome_prov)
    if sig == 0u64 { return 16u64 }

    /* ===== STUBBORN DETERMINISM from a static history (the deep claim) ===== */
    /* re-fold the SAME frozen evade-history -> byte-identical witness (deterministic, every time) */
    soc_reset()
    soc_subscribe(ECHO, WAVE)  soc_subscribe(WAVE, EYE)  soc_subscribe(WAVE, TIDE)
    soc_emit(EYE, K_MOVE, 1u64, 1u64)
    soc_emit(ECHO, K_MOVE, R1, 1u64)
    soc_emit(WAVE, K_RIPPLE, 2u64, 2u64)
    soc_mark()
    soc_emit(ECHO, K_MOVE, RBAD, 2u64)
    soc_emit(WAVE, K_RIPPLE, 1u64, 1u64)
    soc_rewind()
    soc_emit(ECHO, K_LESSON, RBAD, 2u64)
    soc_emit(ECHO, K_MOVE, RGOOD, 2u64)
    soc_emit(WAVE, K_RIPPLE, 3u64, 3u64)
    let dome_w2 : u64 = soc_witness_global()
    if dome_w2 != dome_w { return 21u64 }            /* STUBBORN: same frozen history => same witness */
    /* TAMPER: change ONE event (the start term 1 -> 9) -> the witness MUST move (assurance) */
    soc_reset()
    soc_subscribe(ECHO, WAVE)  soc_subscribe(WAVE, EYE)  soc_subscribe(WAVE, TIDE)
    soc_emit(EYE, K_MOVE, 9u64, 1u64)                /* tampered start value */
    soc_emit(ECHO, K_MOVE, R1, 1u64)
    soc_emit(WAVE, K_RIPPLE, 2u64, 2u64)
    soc_mark()
    soc_emit(ECHO, K_MOVE, RBAD, 2u64)
    soc_emit(WAVE, K_RIPPLE, 1u64, 1u64)
    soc_rewind()
    soc_emit(ECHO, K_LESSON, RBAD, 2u64)
    soc_emit(ECHO, K_MOVE, RGOOD, 2u64)
    soc_emit(WAVE, K_RIPPLE, 3u64, 3u64)
    let dome_w3 : u64 = soc_witness_global()
    if dome_w3 == dome_w { return 22u64 }            /* any single-event mutation is DETECTED */

    return 99u64
}
