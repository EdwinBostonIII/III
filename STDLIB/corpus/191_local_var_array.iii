/* III conformance corpus 191 -- Stage 3.17: local `var` declarations.
 *
 * The CLAUDE.md trap registry documented "local var array declarations NOT
 * supported": `var foo : [u8; N]` only parsed at module scope; in a fn
 * body it errored ("expected expression").  The codegen already reserved
 * ceil(N*width/8) slots for an array-typed STMT_LET, so the gap was purely
 * the parser not dispatching `var` in statement position.
 *
 * Stage 3.17 fix: parse_stmt now routes `var` to iiip_parse_let, which
 * accepts `let` or `var` (var = a mutable local; var name : T ~ let mut
 * name : T).  This enables local `var` arrays AND local `var` scalars.
 * Verified iiis-0(C) and iiis-1(.iii) emit byte-identical .o for var
 * programs.  `let` semantics are unchanged.
 *
 * Exit = 99 on success; 1..5 = the specific local-var form that regressed.
 */
module corpus_191

fn main() -> u64 {
    /* local var byte array */
    var buf : [u8; 8]
    buf[0u32] = 0xAAu8
    buf[3u32] = 0xBBu8
    buf[7u32] = 0xCCu8
    if buf[0u32] != 0xAAu8 { return 1u64 }
    if buf[3u32] != 0xBBu8 { return 2u64 }
    if buf[7u32] != 0xCCu8 { return 3u64 }
    /* a local after the array must not overlap its slots */
    var n : u32 = 5u32
    n = n + 10u32
    if n != 15u32 { return 4u64 }
    if buf[0u32] != 0xAAu8 { return 5u64 }
    return 99u64
}
