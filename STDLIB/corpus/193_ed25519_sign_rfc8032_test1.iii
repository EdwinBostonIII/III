    s[20] = 0xB8u8
    s[21] = 0xE5u8
    s[22] = 0xD9u8
    s[23] = 0x74u8
    s[24] = 0xD8u8
    s[25] = 0x73u8
    s[26] = 0xE0u8
    s[27] = 0x65u8
    s[28] = 0x22u8
    s[29] = 0x49u8
    s[30] = 0x01u8
    s[31] = 0x55u8
    return 0i32
}

fn fill_expected_hi32(s: *u8) -> i32 {
    s[32] = 0x5Fu8
    s[33] = 0xB8u8
    s[34] = 0x82u8
    s[35] = 0x15u8
    s[36] = 0x90u8
    s[37] = 0xA3u8
    s[38] = 0x3Bu8
    s[39] = 0xACu8
    s[40] = 0xC6u8
    s[41] = 0x1Eu8
    s[42] = 0x39u8
    s[43] = 0x70u8
    s[44] = 0x1Cu8
    s[45] = 0xF9u8
    s[46] = 0xB4u8
    s[47] = 0x6Bu8
    s[48] = 0xD2u8
    s[49] = 0x5Bu8
    s[50] = 0xF5u8
    s[51] = 0xF0u8
    s[52] = 0x59u8
    s[53] = 0x5Bu8
    s[54] = 0xBEu8
    s[55] = 0x24u8
    s[56] = 0x65u8
    s[57] = 0x51u8
    s[58] = 0x41u8
    s[59] = 0x43u8
    s[60] = 0x8Eu8
    s[61] = 0x7Au8
    s[62] = 0x10u8
    s[63] = 0x0Bu8
    return 0i32
}

fn main() -> u64 {
    let seed     : *u8 = malloc(32u64)
    let pubkey   : *u8 = malloc(32u64)
    let expected : *u8 = malloc(64u64)
    let sig      : *u8 = malloc(64u64)
    let msg      : *u8 = malloc(1u64)
    fill_seed(seed)
    fill_pubkey(pubkey)
    fill_expected_lo32(expected)
    fill_expected_hi32(expected)
    /* sign */
    let src : u8 = ed25519_sign(seed, pubkey, msg, 0u64, sig)
    if src != 1u8 { free(seed) ; free(pubkey) ; free(expected) ; free(sig) ; free(msg) ; return 1u64 }
    /* sig must equal the RFC signature byte-for-byte */
    let mut i : u64 = 0u64
    let mut mism : u64 = 0u64
    while i < 64u64 {
        if sig[i] != expected[i] { mism = mism + 1u64 }
        i = i + 1u64
    }
    if mism != 0u64 { free(seed) ; free(pubkey) ; free(expected) ; free(sig) ; free(msg) ; return 2u64 }
    /* the produced signature must verify (valid round-trip) */
    let v : u8 = ed25519_verify(pubkey, msg, 0u64, sig)
    if v != 1u8 { free(seed) ; free(pubkey) ; free(expected) ; free(sig) ; free(msg) ; return 3u64 }
    /* a 1-bit tamper must NOT verify (forgery rejected) */
    sig[0] = sig[0] ^ 0x01u8
    let v2 : u8 = ed25519_verify(pubkey, msg, 0u64, sig)
    free(seed)
    free(pubkey)
    free(expected)
    free(sig)
    free(msg)
    if v2 == 1u8 { return 4u64 }
    return 99u64
}
