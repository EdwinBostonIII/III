/* 1982_dome_accessor_coverage.iii  --  COVERAGE: the two omnia::dome exports the 1903/1904/1905 tests don't
 * exercise (dome_abandoned, dome_mix).  Behavioural, non-tautological:
 *   - dome_mix(h,x) is the provenance hash-mix h*FNV_prime + x: exact values pin the formula (and that it is
 *     sensitive to BOTH operands), not a self-equality.
 *   - dome_abandoned(i): after dome_reset clears all spans, NO event is inside an abandoned span (0).
 * exit 99 = both accessors behave correctly.
 */
module m1982

extern @abi(c-msvc-x64) fn dome_reset() -> i32 from "dome.iii"
extern @abi(c-msvc-x64) fn dome_abandoned(i: u32) -> u32 from "dome.iii"
extern @abi(c-msvc-x64) fn dome_mix(h: u64, x: u64) -> u64 from "dome.iii"

fn main() -> u64 {
    /* dome_mix = h * 1099511628211 + x */
    if dome_mix(0u64, 0u64) != 0u64 { return 10u64 }
    if dome_mix(1u64, 0u64) != 1099511628211u64 { return 11u64 }              /* 1 * prime */
    if dome_mix(0u64, 42u64) != 42u64 { return 12u64 }                       /* sensitive to x */
    if dome_mix(2u64, 3u64) != 2199023256425u64 { return 13u64 }             /* 2*prime + 3 (sensitive to h) */

    /* dome_abandoned: after reset (no spans), nothing is abandoned */
    dome_reset()
    if dome_abandoned(0u32) != 0u32 { return 20u64 }
    if dome_abandoned(99u32) != 0u32 { return 21u64 }

    return 99u64
}
