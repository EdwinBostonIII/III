/* 1985_eidos_display.iii -- III RENDERS ITS OWN BATCAVE, natively, and proves the picture sound.
 *
 * Drives the eidos display stack over the REAL self_atlas (self_cartographer walks the live iii/
 * tree -- never a hand-built demo web; ADR-5).  Gates on INVARIANTS that cannot go stale as the
 * tree grows, each proving a negative:
 *   10  the atlas is non-empty            (catches a vacuous render over an empty registry)
 *   11  two renders are byte-identical    (determinism: canvas_sig equal)
 *   12  two renders iterate equally
 *   13  render iterates EVERY node         (render_iterated == satlas_node_count: no silent cap)
 *   14  render's return == node count
 *   15  on-plane + off-plane == iterated   (accounting closes; nothing vanishes)
 *   16  no node lands off-plane            (projection is total by construction)
 *   17  distinct identities -> distinct colours   (colour is the content-address, FR-2)
 *   18  palette recomputes to its documented FNV fold (not a stub -- prove the law)
 *   19  the .ans artifact is written       (the SEEN deliverable; cat build/eidos_map.ans)
 *   99  all hold.
 */
module corpus_1985

extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"

extern @abi(c-msvc-x64) fn scarto_map(cap: u64, root_ptr: u64, root_len: u64) -> u32 from "self_cartographer.iii"
extern @abi(c-msvc-x64) fn satlas_node_count() -> u32 from "self_atlas.iii"

extern @abi(c-msvc-x64) fn render_atlas() -> u32 from "render.iii"
extern @abi(c-msvc-x64) fn render_iterated() -> u32 from "render.iii"
extern @abi(c-msvc-x64) fn render_on_plane() -> u32 from "render.iii"
extern @abi(c-msvc-x64) fn render_off_plane() -> u32 from "render.iii"
extern @abi(c-msvc-x64) fn render_collisions() -> u32 from "render.iii"

extern @abi(c-msvc-x64) fn canvas_sig() -> u64 from "canvas.iii"

extern @abi(c-msvc-x64) fn palette_rgb(p32: u64) -> u32 from "palette.iii"
extern @abi(c-msvc-x64) fn isub_cav_into(verb: u32, a: u32, b: u32, out32: *u8) -> i32 from "isub.iii"

extern @abi(c-msvc-x64) fn eidos_cli_write(cap: u64, path_ptr: u64) -> u32 from "cli.iii"

const FNV_OFF   : u64 = 0xcbf29ce484222325u64
const FNV_PRIME : u64 = 0x100000001b3u64
const FLOOR     : u32 = 0x40u32

var P_ROOT : [u8; 16]
var P_OUT  : [u8; 64]
var CAV1   : [u8; 32]
var CAV2   : [u8; 32]

fn bcopy(dst: u64, src: u64, n: u64) -> u64 {
    let d : *u8 = dst as *u8
    let s : *u8 = src as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]  i = i + 1u64 }
    d[n] = 0u8
    return n
}

/* recompute the palette colour of CAV1 by the DOCUMENTED law (FNV-1a fold + |0x40 floor),
 * independently of eidos/palette -- so step 18 proves the law, not a constant stub. */
fn kat_expected_rgb() -> u32 {
    let p : *u8 = (&CAV1 as u64) as *u8
    let mut h : u64 = FNV_OFF
    let mut i : u64 = 0u64
    while i < 32u64 {
        h = h ^ (p[i] as u64)
        h = h * FNV_PRIME
        i = i + 1u64
    }
    let r : u32 = (((h >> 16u64) as u32) & 0xFFu32) | FLOOR
    let g : u32 = (((h >> 8u64)  as u32) & 0xFFu32) | FLOOR
    let b : u32 = ((h as u32)            & 0xFFu32) | FLOOR
    return (r << 16u32) | (g << 8u32) | b
}

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)

    /* CWD-independent walk root (whole-tree sweep 2026-07-02): the corpus is invoked from the
     * repo root (where the tree is STDLIB/iii) or from STDLIB/ (where it is iii) -- a KAT's
     * verdict must not depend on the invoker's directory.  Probe the first, fall back. */
    bcopy((&P_OUT as u64),  ("build/eidos_map.ans" as u64), 19u64)
    bcopy((&P_ROOT as u64), ("STDLIB/iii" as u64), 10u64)
    let mut nc : u32 = scarto_map(cap, (&P_ROOT as u64), 10u64)
    if nc == 0u32 {
        bcopy((&P_ROOT as u64), ("iii" as u64), 3u64)
        nc = scarto_map(cap, (&P_ROOT as u64), 3u64)
    }
    if nc == 0u32 { return 10u64 }

    let r1 : u32 = render_atlas()
    let s1 : u64 = canvas_sig()
    let r2 : u32 = render_atlas()
    let s2 : u64 = canvas_sig()
    if s1 != s2 { return 11u64 }
    if r1 != r2 { return 12u64 }

    if render_iterated() != satlas_node_count() { return 13u64 }
    if r1 != satlas_node_count() { return 14u64 }
    let on  : u32 = render_on_plane()
    let off : u32 = render_off_plane()
    let it  : u32 = render_iterated()
    if (on + off) != it { return 15u64 }
    if off != 0u32 { return 16u64 }

    isub_cav_into(0u32, 5u32, 7u32, (&CAV1 as u64) as *u8)
    isub_cav_into(1u32, 5u32, 7u32, (&CAV2 as u64) as *u8)
    let c1 : u32 = palette_rgb(&CAV1 as u64)
    let c2 : u32 = palette_rgb(&CAV2 as u64)
    if c1 == c2 { return 17u64 }
    let exp : u32 = kat_expected_rgb()
    if c1 != exp { return 18u64 }

    let w : u32 = eidos_cli_write(cap, (&P_OUT as u64))
    if w == 0u32 { return 19u64 }

    return 99u64
}
