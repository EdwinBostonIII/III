/* 1989_eidos_web_weave.iii -- THE DISPLAY RENDERS WEAVE'S EXECUTED PLAN (weave's first live consumer).
 *
 * eidos/web.web_render_weave routes start->target over a REAL ripple graph via the Composer's ripple half
 * (eidos/weave: plan over real eidos/ripple quanta with rf-geometry costs), EXECUTES the plan (the planned
 * ripples are witnessed onto the isub bus), then renders that bus.  So the rendered web IS weave's executed
 * plan -- making the read-only display a LIVE CONSUMER of weave_plan/weave_execute (another of the §12 ledger's
 * "zero live consumers" closed, safely -- no self-host).  The ripple fixture is SCANNED from the live sealed
 * tables (rf_rank/rf_edge_field), never hardcoded (same evergreen discipline as 1936).
 *   10  the sealed tables lack 3 distinct-rank hexads / a savings>0 prim triple, or weave rejected the ripples
 *   11  web_render_weave did not render the executed plan length (the 2-ripple path S->M->T)
 *   12  the rendered bus is NOT weave's executed plan (the witnessed ripples != S->M, M->T)
 *   13  render did not iterate every executed ripple (silent cap)
 *   14  the render is not deterministic
 *   15  the .ans artifact was not written (cat build/eidos_web_weave.ans)
 *   99  the display faithfully renders weave's executed plan -- weave is display-consumed.
 */
module corpus_1989

extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"

extern @abi(c-msvc-x64) fn weave_reset() -> i32 from "weave.iii"
extern @abi(c-msvc-x64) fn weave_order_direct() -> u32 from "weave.iii"
extern @abi(c-msvc-x64) fn weave_add_ripple(prim_a: u8, prim_b: u8, hex_a: u8, hex_b: u8) -> i32 from "weave.iii"
extern @abi(c-msvc-x64) fn rf_edge_field(prim_from: u8, prim_to: u8, hex_from: u8, hex_to: u8) -> i64 from "ripple_field.iii"
extern @abi(c-msvc-x64) fn rf_rank(h: u8) -> u32 from "ripple_field.iii"

extern @abi(c-msvc-x64) fn isub_count() -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_a(i: u32) -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_b(i: u32) -> u32 from "isub.iii"

extern @abi(c-msvc-x64) fn web_render_weave(start_prim: u32, target_prim: u32, order_slot: u32) -> u32 from "web.iii"
extern @abi(c-msvc-x64) fn web_iterated() -> u32 from "web.iii"
extern @abi(c-msvc-x64) fn eidos_web_write(cap: u64, path_ptr: u64) -> u32 from "web.iii"

extern @abi(c-msvc-x64) fn canvas_sig() -> u64 from "canvas.iii"

var P_OUT : [u8; 64]

fn bcopy(dst: u64, src: u64, n: u64) -> u64 {
    let d : *u8 = dst as *u8
    let s : *u8 = src as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]  i = i + 1u64 }
    d[n] = 0u8
    return n
}

fn mag(pa: u8, pb: u8, ha: u8, hb: u8) -> u64 {
    let g : i64 = rf_edge_field(pa, pb, ha, hb)
    if g < 0i64 { return (0i64 - g) as u64 }
    return g as u64
}

/* the scan state (module scope -- the scanned fixture). */
var FX_hA : u8 = 0u8
var FX_hB : u8 = 0u8
var FX_hC : u8 = 0u8
var FX_S  : u8 = 0u8
var FX_M  : u8 = 0u8
var FX_T  : u8 = 0u8

/* scan 3 pairwise-distinct-rank hexads + an S,M,T prim triple whose 2-hop ripples both have savings>0. */
fn scan_fixture() -> u32 {
    let mut foundh : u32 = 0u32
    let mut i : u8 = 1u8
    while i <= 7u8 {
        let mut j : u8 = 1u8
        while j <= 7u8 {
            let mut k : u8 = 1u8
            while k <= 7u8 {
                if foundh == 0u32 {
                    let ri : u32 = rf_rank(i)
                    let rj : u32 = rf_rank(j)
                    let rk : u32 = rf_rank(k)
                    if ri != rj { if ri != rk { if rj != rk { FX_hA = i  FX_hB = j  FX_hC = k  foundh = 1u32 } } }
                }
                k = k + 1u8
            }
            j = j + 1u8
        }
        i = i + 1u8
    }
    if foundh == 0u32 { return 0u32 }
    let mut foundp : u32 = 0u32
    let mut a : u8 = 0u8
    while a < 24u8 {
        let mut b : u8 = 0u8
        while b < 24u8 {
            let mut c : u8 = 0u8
            while c < 24u8 {
                if foundp == 0u32 {
                    if a != b { if a != c { if b != c {
                        let m1 : u64 = mag(a, b, FX_hA, FX_hC)
                        let m2 : u64 = mag(b, c, FX_hC, FX_hB)
                        if m1 > 0u64 { if m2 > 0u64 { FX_S = a  FX_M = b  FX_T = c  foundp = 1u32 } }
                    } } }
                }
                c = c + 1u8
            }
            b = b + 1u8
        }
        a = a + 1u8
    }
    return foundp
}

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)

    /* ===== code 10: scan the real fixture + register the real S->M, M->T ripple graph ===== */
    weave_reset()
    if scan_fixture() == 0u32 { return 10u64 }
    let DIRECT : u32 = weave_order_direct()
    if weave_add_ripple(FX_S, FX_M, FX_hA, FX_hC) != 0i32 { return 10u64 }   /* qid 0: S->M */
    if weave_add_ripple(FX_M, FX_T, FX_hC, FX_hB) != 1i32 { return 10u64 }   /* qid 1: M->T */

    /* ===== code 11: the display renders weave's executed plan (the composed 2-ripple path) ===== */
    let n : u32 = web_render_weave(FX_S as u32, FX_T as u32, DIRECT)
    if n != 2u32 { return 11u64 }

    /* ===== code 12: the rendered bus IS weave's executed plan -- the witnessed S->M, M->T ripples ===== */
    if isub_count() != 2u32 { return 12u64 }
    if isub_a(0u32) != (FX_S as u32) { return 12u64 }
    if isub_b(0u32) != (FX_M as u32) { return 12u64 }
    if isub_a(1u32) != (FX_M as u32) { return 12u64 }
    if isub_b(1u32) != (FX_T as u32) { return 12u64 }

    /* ===== code 13: render iterated every executed ripple ===== */
    if web_iterated() != 2u32 { return 13u64 }

    /* ===== code 14: determinism ===== */
    let sig1 : u64 = canvas_sig()
    web_render_weave(FX_S as u32, FX_T as u32, DIRECT)
    let sig2 : u64 = canvas_sig()
    if sig1 != sig2 { return 14u64 }

    /* ===== code 15: the SEEN artifact (cat build/eidos_web_weave.ans) ===== */
    bcopy((&P_OUT as u64), ("build/eidos_web_weave.ans" as u64), 25u64)
    if eidos_web_write(cap, (&P_OUT as u64)) == 0u32 { return 15u64 }

    return 99u64
}
