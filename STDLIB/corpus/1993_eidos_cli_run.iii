/* 1993_eidos_cli_run.iii -- THE IN-HOUSE CLI, EVERY VIEW (display arch Phase 4: the one command).
 *
 * eidos/cli.eidos_cli_run(verb, cap, path) is the single entry point composing the WHOLE display stack:
 *   MAP   (0): the batcave module graph (self_cartographer -> self_atlas -> layout -> render)
 *   WEB   (1): the live isub content-addressed web (a real trace -> eidos/web)
 *   PLAN  (2): the web + the Composer's geodesic overlaid (eidos/web's desc_plan highlight)
 *   FIELD (3): the temporal flipbook (eidos/temporal)
 * This gate proves the negative -- every verb produces a real artifact, AND an unknown verb is REJECTED
 * (returns 0, never a silent wrong render).  The "in-house CLI that takes advantage of every primitive."
 *   10  MAP produced nothing (the batcave did not render/write)
 *   11  WEB produced nothing (the live isub web did not render/write)
 *   12  PLAN produced nothing (web + planner overlay did not render/write)
 *   13  FIELD produced nothing (the temporal flipbook did not write)
 *   14  an UNKNOWN verb was NOT rejected (it must return 0)
 *   99  one command renders every view of III, and rejects the unknown -- end to end.
 */
module corpus_1993

extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn eidos_cli_run(verb: u32, cap: u64, path_ptr: u64) -> u32 from "cli.iii"

var P_OUT : [u8; 64]

fn bcopy(dst: u64, src: u64, n: u64) -> u64 {
    let d : *u8 = dst as *u8
    let s : *u8 = src as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]  i = i + 1u64 }
    d[n] = 0u8
    return n
}

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)

    /* ===== code 10: MAP -- the batcave module graph ===== */
    bcopy((&P_OUT as u64), ("build/eidos_cli_map.ans" as u64), 23u64)
    if eidos_cli_run(0u32, cap, (&P_OUT as u64)) == 0u32 { return 10u64 }

    /* ===== code 11: WEB -- the live isub content-addressed web ===== */
    bcopy((&P_OUT as u64), ("build/eidos_cli_web.ans" as u64), 23u64)
    if eidos_cli_run(1u32, cap, (&P_OUT as u64)) == 0u32 { return 11u64 }

    /* ===== code 12: PLAN -- the web + the planner's geodesic ===== */
    bcopy((&P_OUT as u64), ("build/eidos_cli_plan.ans" as u64), 24u64)
    if eidos_cli_run(2u32, cap, (&P_OUT as u64)) == 0u32 { return 12u64 }

    /* ===== code 13: FIELD -- the temporal flipbook ===== */
    bcopy((&P_OUT as u64), ("build/eidos_cli_field.ans" as u64), 25u64)
    if eidos_cli_run(3u32, cap, (&P_OUT as u64)) == 0u32 { return 13u64 }

    /* ===== code 14: an UNKNOWN verb is REJECTED ===== */
    bcopy((&P_OUT as u64), ("build/eidos_cli_x.ans" as u64), 21u64)
    if eidos_cli_run(99u32, cap, (&P_OUT as u64)) != 0u32 { return 14u64 }

    return 99u64
}
