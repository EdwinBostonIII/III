/* III conformance corpus 200 -- Stage 4.4.3: native .iii SLH-DSA (FIPS 205 /
 * SPHINCS+) round-trip.  SLH-DSA-128S (lv 0): keygen(seed) -> sign(msg) ->
 * verify must ACCEPT (rc 0); a 1-bit signature tamper must be REJECTED.
 * The substrate's third (and final) native .iii post-quantum primitive --
 * hash-based (WOTS+/FORS/XMSS/hypertree over SHA-256 + SHAKE-256).  Exit 99.
 *
 * NOTE: the "S" parameter set is deliberately slow to sign (naive treehash,
 * millions of SHA-256 calls); this test takes ~15-20s by design.
 */
module corpus_200

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn iii_slhdsa_keygen(lv: u64, seed: u64, pk: u64, sk: u64) -> i32 from "slhdsa.iii"
extern @abi(c-msvc-x64) fn iii_slhdsa_sign(lv: u64, sk: u64, msg: u64, msglen: u64, sig: u64, siglen: u64) -> i32 from "slhdsa.iii"
extern @abi(c-msvc-x64) fn iii_slhdsa_verify(lv: u64, pk: u64, msg: u64, msglen: u64, sig: u64, siglen: u64) -> i32 from "slhdsa.iii"

fn main() -> u64 {
    let seed : *u8 = malloc(64u64)
    let pk   : *u8 = malloc(128u64)
    let sk   : *u8 = malloc(256u64)
    let sig  : *u8 = malloc(16384u64)
    let slb  : *u8 = malloc(16u64)
    let msg  : *u8 = malloc(64u64)
    let mut i : u64 = 0u64
    while i < 48u64 { seed[i] = ((0x21u64 + i) & 0xFFu64) as u8 ; i = i + 1u64 }
    i = 0u64
    while i < 32u64 { msg[i] = ((i * 5u64 + 9u64) & 0xFFu64) as u8 ; i = i + 1u64 }
    iii_slhdsa_keygen(0u64, seed as u64, pk as u64, sk as u64)
    let sr : i32 = iii_slhdsa_sign(0u64, sk as u64, msg as u64, 32u64, sig as u64, slb as u64)
    if sr != 0i32 { free(seed) ; free(pk) ; free(sk) ; free(sig) ; free(slb) ; free(msg) ; return 1u64 }
    let sl : u64 = (slb[0] as u64) | ((slb[1] as u64) << 8u64) | ((slb[2] as u64) << 16u64) | ((slb[3] as u64) << 24u64)
    let v : i32 = iii_slhdsa_verify(0u64, pk as u64, msg as u64, 32u64, sig as u64, sl)
    if v != 0i32 { free(seed) ; free(pk) ; free(sk) ; free(sig) ; free(slb) ; free(msg) ; return 2u64 }
    sig[0] = sig[0] ^ 0x01u8
    let v2 : i32 = iii_slhdsa_verify(0u64, pk as u64, msg as u64, 32u64, sig as u64, sl)
    free(seed)
    free(pk)
    free(sk)
    free(sig)
    free(slb)
    free(msg)
    if v2 == 0i32 { return 3u64 }
    return 99u64
}
