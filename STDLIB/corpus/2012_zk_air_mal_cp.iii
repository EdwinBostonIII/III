/* 2012_zk_air_mal_cp.iii -- REGRESSION KAT for the air_stark vacuous-FRI soundness fix (DOCS/III-ZK-SOUNDNESS-GAP.md).
 *
 * air_stark's FRI used to fold the CP all the way to size 1 (VACUOUS -- proves nothing about degree).  air_build_cp
 * builds the TRUE degree-<n quotient, so the HONEST prover is sound; but a MALICIOUS prover (air_set_cp_mode(1) ->
 * air_build_cp_highdeg) commits a HIGH-degree CP = combine*(x-omega^{n-1})*inv(Z_H) pointwise at non-H points, which
 * satisfies line-755 at every (H-skipping) query BY CONSTRUCTION and slipped through the vacuous FRI -> a FORGED trace
 * ACCEPTED.  FIX: fold to AIR_B + require a CONSTANT final layer (air_stark_prove/air_stark_verify), so a high-degree
 * CP folds to a NON-constant final -> REJECT.  Returns 99 iff honest ACCEPTS and the malicious high-degree CP on a
 * forged interior trace is REJECTED (was rc=2 = ACCEPT before the fix). */
module zk_air_mal_cp

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_boundary_reset() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_boundary(col: u32, row: u32, value: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_prove() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_verify() -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_cp_mode(m: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_add(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"

const NEG1 : u32 = 998244352u32

fn setup() {
    air_reset(2u32, 8u32)
    air_boundary_reset()
    air_add_boundary(0u32, 0u32, 2u32)
    air_add_boundary(1u32, 0u32, 3u32)
    air_add_term(0u32, 1u32, 3u32, 0u32)
    air_add_term(0u32, NEG1, 1u32, 2u32)
    air_add_term(1u32, 1u32, 4u32, 0u32)
    air_add_term(1u32, NEG1, 2u32, 0u32)
    air_add_term(1u32, NEG1, 1u32, 0u32)
    air_set_alpha(0u64, 7u32)
    air_set_alpha(1u64, 13u32)
}
fn fill() {
    let mut c0 : u32 = 2u32  let mut c1 : u32 = 3u32  let mut t : u64 = 0u64
    while t < 8u64 {
        air_set_trace(t, 0u64, c0)  air_set_trace(t, 1u64, c1)
        let n0 : u32 = sf_mul(c0, c1)  let n1 : u32 = sf_add(c1, c0)
        c0 = n0  c1 = n1  t = t + 1u64
    }
}

fn main() -> u64 {
    air_set_cp_mode(0u32)
    setup()  fill()  air_stark_prove()
    if air_stark_verify() != 0u64 { return 10u64 }                       /* honest must ACCEPT */
    air_set_cp_mode(1u32)
    setup()  fill()  air_set_trace(4u64, 0u64, 12345u32)  air_stark_prove()
    let mal : u64 = air_stark_verify()
    air_set_cp_mode(0u32)
    if mal == 0u64 { return 2u64 }                                       /* malicious high-deg CP ACCEPTED = the hole */
    return 99u64
}
