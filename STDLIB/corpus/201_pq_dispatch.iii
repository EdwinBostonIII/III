/* III conformance corpus 201 -- Stage 4.4.4: native .iii PQ dispatch surface.
 * Routes FIPS suite ids through numera/pq_dispatch.iii to mldsa/mlkem/slhdsa:
 *   ML-DSA-44 (0x0111) keygen->sign->verify ACCEPT
 *   ML-KEM-512 (0x0101) keygen->encaps->decaps shared-secret AGREE
 *   sign on a KEM suite (0x0101) -> -1 (family mismatch rejected)
 *   SLH-DSA-128S (0x0121) keygen->sign->verify ACCEPT  (~18s slow-sign)
 * Exit 99.
 */
module corpus_201

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn iii_pq_keygen(suite: u64, seed: u64, pk: u64, sk: u64) -> i32 from "pq_dispatch.iii"
extern @abi(c-msvc-x64) fn iii_pq_sign(suite: u64, sk: u64, msg: u64, msglen: u64, sig: u64, siglen: u64) -> i32 from "pq_dispatch.iii"
extern @abi(c-msvc-x64) fn iii_pq_verify(suite: u64, pk: u64, msg: u64, msglen: u64, sig: u64, siglen: u64) -> i32 from "pq_dispatch.iii"
extern @abi(c-msvc-x64) fn iii_pq_encaps(suite: u64, pk: u64, coins: u64, ct: u64, ss: u64) -> i32 from "pq_dispatch.iii"
extern @abi(c-msvc-x64) fn iii_pq_decaps(suite: u64, sk: u64, ct: u64, ss: u64) -> i32 from "pq_dispatch.iii"

fn main() -> u64 {
    let seed  : *u8 = malloc(128u64)
    let pk    : *u8 = malloc(4096u64)
    let sk    : *u8 = malloc(8192u64)
    let sig   : *u8 = malloc(16384u64)
    let slb   : *u8 = malloc(16u64)
    let msg   : *u8 = malloc(64u64)
    let ct    : *u8 = malloc(2048u64)
    let coins : *u8 = malloc(32u64)
    let s1    : *u8 = malloc(32u64)
    let s2    : *u8 = malloc(32u64)
    let mut i : u64 = 0u64
    while i < 96u64 { seed[i] = ((0x11u64 + i) & 0xFFu64) as u8 ; i = i + 1u64 }
    i = 0u64
    while i < 32u64 { msg[i] = ((i * 3u64 + 1u64) & 0xFFu64) as u8 ; i = i + 1u64 }
    i = 0u64
    while i < 32u64 { coins[i] = ((i * 9u64 + 2u64) & 0xFFu64) as u8 ; i = i + 1u64 }
    /* ML-DSA-44 via dispatch */
    iii_pq_keygen(0x0111u64, seed as u64, pk as u64, sk as u64)
    let sr : i32 = iii_pq_sign(0x0111u64, sk as u64, msg as u64, 32u64, sig as u64, slb as u64)
    if sr != 0i32 { return 1u64 }
    let mut sl : u64 = (slb[0] as u64) | ((slb[1] as u64) << 8u64) | ((slb[2] as u64) << 16u64) | ((slb[3] as u64) << 24u64)
    if iii_pq_verify(0x0111u64, pk as u64, msg as u64, 32u64, sig as u64, sl) != 0i32 { return 2u64 }
    /* ML-KEM-512 via dispatch */
    iii_pq_keygen(0x0101u64, seed as u64, pk as u64, sk as u64)
    iii_pq_encaps(0x0101u64, pk as u64, coins as u64, ct as u64, s1 as u64)
    iii_pq_decaps(0x0101u64, sk as u64, ct as u64, s2 as u64)
    i = 0u64
    while i < 32u64 { if s1[i] != s2[i] { return 3u64 } i = i + 1u64 }
    /* family mismatch: sign on a KEM suite must reject */
    if iii_pq_sign(0x0101u64, sk as u64, msg as u64, 32u64, sig as u64, slb as u64) == 0i32 { return 4u64 }
    /* SLH-DSA-128S via dispatch */
    iii_pq_keygen(0x0121u64, seed as u64, pk as u64, sk as u64)
    let sr2 : i32 = iii_pq_sign(0x0121u64, sk as u64, msg as u64, 32u64, sig as u64, slb as u64)
    if sr2 != 0i32 { return 5u64 }
    sl = (slb[0] as u64) | ((slb[1] as u64) << 8u64) | ((slb[2] as u64) << 16u64) | ((slb[3] as u64) << 24u64)
    let vv : i32 = iii_pq_verify(0x0121u64, pk as u64, msg as u64, 32u64, sig as u64, sl)
    free(seed) free(pk) free(sk) free(sig) free(slb) free(msg) free(ct) free(coins) free(s1) free(s2)
    if vv != 0i32 { return 6u64 }
    return 99u64
}
