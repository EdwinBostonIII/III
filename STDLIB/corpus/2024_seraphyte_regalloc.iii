/* STDLIB/corpus/2024_seraphyte_regalloc.iii -- register reallocation as the next cascade pass, gated.
 *
 * The cascade collapses instructions; DCE kills a value; the dead value frees a register; a spill the
 * original block REQUIRED is eliminated.  99 = the cascade propagates into the register file.
 *
 *   ARM 1-2  HIGH PRESSURE: a block with 3 simultaneously-live values needs 3 registers; with K=2 it SPILLS 1.
 *   ARM 3-5  THE CASCADE: DCE kills the dead value (the *1 / +0 result the fixpoint proved unused) -> register
 *            pressure drops 3->2 -> with K=2 the spill is ELIMINATED (0 spills).  One collapse, one fewer spill.
 *   ARM 6    SANITY: with only K=1 a spill remains (pressure 2 > 1); with K=3 there was never a spill.
 */
module corpus_2024_seraphyte_regalloc

extern @abi(c-msvc-x64) fn ra_reset() -> i32 from "ser_regalloc.iii"
extern @abi(c-msvc-x64) fn ra_push(start: u64, end: u64) -> i32 from "ser_regalloc.iii"
extern @abi(c-msvc-x64) fn ra_kill(i: u32) -> i32 from "ser_regalloc.iii"
extern @abi(c-msvc-x64) fn ra_pressure() -> u32 from "ser_regalloc.iii"
extern @abi(c-msvc-x64) fn ra_spills(k: u32) -> u32 from "ser_regalloc.iii"

fn main() -> u64 {
    /* three overlapping live values (all live over points 2..5) -> pressure 3 */
    ra_reset()
    ra_push(0u64, 5u64)   /* value 0 */
    ra_push(1u64, 5u64)   /* value 1 */
    ra_push(2u64, 5u64)   /* value 2 -- the one the cascade's DCE will prove dead */

    /* ARM 1-2: high pressure, a spill with K=2 */
    if ra_pressure() != 3u32 { return 1u64 }
    if ra_spills(2u32) != 1u32 { return 2u64 }
    if ra_spills(3u32) != 0u32 { return 3u64 }   /* 3 registers fit */

    /* ARM 3-5: the cascade kills the dead value -> pressure drops -> the K=2 spill is eliminated */
    ra_kill(2u32)
    if ra_pressure() != 2u32 { return 4u64 }
    if ra_spills(2u32) != 0u32 { return 5u64 }   /* the spill is GONE */

    /* ARM 6: sanity -- K=1 still spills one (pressure 2 > 1) */
    if ra_spills(1u32) != 1u32 { return 6u64 }

    return 99u64
}
