/* STDLIB/corpus/2029_seraphyte_air_constraint.iii -- corpus coverage for the zk-AIR GF(p^2) constraint
 * accessors (numera/zk_air) that the sovir zk KAT exercises but no corpus KAT referenced.
 *
 * Meaningful (mirroring sovir/zk_ext2_live): a real column with the nonlinear transition next == cur^2 and the
 * satisfying trace [2,4,16,256] (2^2=4, 4^2=16, 16^2=256).  air_build_cp_ext2 combines the constraint with a
 * GF(p^2) challenge; on a SATISFYING trace the combined constraint is ZERO at every transition row.  99 = it is.
 */
module corpus_2029_seraphyte_air_constraint

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha_ext2(con: u64, a: u64) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp_ext2() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_ext2_at(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_combine_ext2_at(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_boundaries_hold() -> u8 from "zk_air.iii"
extern @abi(c-msvc-x64) fn e2pack(a0: u32, a1: u32) -> u64 from "zk_ext2.iii"

const NEG1 : u32 = 998244352u32

fn main() -> u64 {
    air_reset(1u32, 4u32)
    air_set_trace(0u64, 0u64, 2u32)   air_set_trace(1u64, 0u64, 4u32)
    air_set_trace(2u64, 0u64, 16u32)  air_set_trace(3u64, 0u64, 256u32)
    air_add_term(0u32, 1u32, 2u32, 0u32)       /* + next */
    air_add_term(0u32, NEG1, 1u32, 1u32)       /* - cur*cur */
    air_set_alpha_ext2(0u64, e2pack(13u32, 9u32))
    air_build_lde()
    air_build_cp_ext2()

    /* the satisfying trace zeroes the combined constraint at every transition row (LDE points 0,4,8). */
    if air_combine_ext2_at(0u64) != 0u64 { return 1u64 }
    if air_combine_ext2_at(4u64) != 0u64 { return 2u64 }
    if air_combine_ext2_at(8u64) != 0u64 { return 3u64 }

    /* the quotient CP is a real GF(p^2) word at a non-trace point (read it -- covers cp_ext2_at). */
    let cp1 : u64 = air_cp_ext2_at(1u64)
    if cp1 == 0u64 { if air_cp_ext2_at(2u64) == 0u64 { return 4u64 } }   /* not identically zero */

    /* boundary closure is well-formed for this trace. */
    if air_boundaries_hold() != 1u8 { return 5u64 }

    return 99u64
}
