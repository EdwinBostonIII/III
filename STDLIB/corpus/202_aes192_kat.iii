/* III conformance corpus 202 -- Stage 4.5: AES-192 (Nk=6, Nr=12).
 * FIPS 197 Appendix C.2 known-answer test:
 *   key = 000102030405060708090a0b0c0d0e0f1011121314151617
 *   pt  = 00112233445566778899aabbccddeeff
 *   ct  = dda97ca4864cdfe06eaf70a0ec0d7191
 * Verifies aes192_set_key + aes_encrypt_block (== ct) + aes_decrypt_block
 * (round-trips to pt).  Exit 99.
 */
module corpus_202

extern @abi(c-msvc-x64) fn aes192_set_key(key: u64) -> i32 from "aes.iii"
extern @abi(c-msvc-x64) fn aes_encrypt_block(in_block: u64, out_block: u64) -> i32 from "aes.iii"
extern @abi(c-msvc-x64) fn aes_decrypt_block(in_block: u64, out_block: u64) -> i32 from "aes.iii"

var K   : [u8; 24]
var PT  : [u8; 16]
var CT  : [u8; 16]
var OUT : [u8; 16]
var EXP : [u8; 16]

fn main() -> u64 {
    let mut i : u64 = 0u64
    while i < 24u64 { K[i] = (i & 0xFFu64) as u8 ; i = i + 1u64 }
    i = 0u64
    while i < 16u64 { PT[i] = ((i * 17u64) & 0xFFu64) as u8 ; i = i + 1u64 }
    EXP[0]=0xddu8 EXP[1]=0xa9u8 EXP[2]=0x7cu8 EXP[3]=0xa4u8
    EXP[4]=0x86u8 EXP[5]=0x4cu8 EXP[6]=0xdfu8 EXP[7]=0xe0u8
    EXP[8]=0x6eu8 EXP[9]=0xafu8 EXP[10]=0x70u8 EXP[11]=0xa0u8
    EXP[12]=0xecu8 EXP[13]=0x0du8 EXP[14]=0x71u8 EXP[15]=0x91u8
    aes192_set_key(&K as u64)
    aes_encrypt_block(&PT as u64, &CT as u64)
    i = 0u64
    while i < 16u64 { if CT[i] != EXP[i] { return 1u64 } i = i + 1u64 }
    aes_decrypt_block(&CT as u64, &OUT as u64)
    i = 0u64
    while i < 16u64 { if OUT[i] != PT[i] { return 2u64 } i = i + 1u64 }
    return 99u64
}
