/* STDLIB/corpus/2038_seraphyte_2sub.iii -- the 2-shift-SUBTRACT rule (the SECOND emitter-produced family),
 * gated by VALUE.  cg_r3 now emits  x*(2^j-2^m) -> (x<<j)-(x<<m)  (e.g. x*14 -> shl $4;shl $1;sub) instead of
 * imul, for contiguous-run factors -- discovered+proved+emitted+applied by seraphyte_add_2sub.sh, the REUSE
 * of the 2-shift-add spine.  Gates the VALUE: the literal multiply (two shifts + sub) == an IMUL REFERENCE
 * (x*memory-load) over random + overflow edges; regresses 2-add (x*10), subk (x*7), non-optimised (x*11);
 * and asserts the standing cor_2ss certifier.  99 = bit-exact to the reference on every edge.
 */
module corpus_2038_seraphyte_2sub

extern @abi(c-msvc-x64) fn cor_2ss_certify_all() -> u64 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cor_2ss_rejects_unsound() -> u8 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cor_2ss_boot_agrees() -> u8 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cor_2ss_rule_count() -> u64 from "cg_opt_rules.iii"

var MULS : [u64; 10] = [14u64, 28u64, 30u64, 56u64, 60u64, 1022u64, 240u64, 7u64, 10u64, 11u64]
fn refmul(x: u64, i: u64) -> u64 { return x * MULS[i] }

fn chk(x: u64) -> u32 {
    if (x * 14u64)   != refmul(x, 0u64) { return 1u32 }    /* 2-sub  (2^4-2^1) */
    if (x * 28u64)   != refmul(x, 1u64) { return 2u32 }    /* 2-sub  (2^5-2^2) */
    if (x * 30u64)   != refmul(x, 2u64) { return 3u32 }    /* 2-sub  (2^5-2^1) */
    if (x * 56u64)   != refmul(x, 3u64) { return 4u32 }    /* 2-sub  (2^6-2^3) */
    if (x * 60u64)   != refmul(x, 4u64) { return 5u32 }    /* 2-sub  (2^6-2^2) */
    if (x * 1022u64) != refmul(x, 5u64) { return 6u32 }    /* 2-sub  (2^10-2^1, long run) */
    if (x * 240u64)  != refmul(x, 6u64) { return 7u32 }    /* 2-sub  (2^8-2^4) */
    if (x * 7u64)    != refmul(x, 7u64) { return 8u32 }    /* subk regression  */
    if (x * 10u64)   != refmul(x, 8u64) { return 9u32 }    /* 2-add regression */
    if (x * 11u64)   != refmul(x, 9u64) { return 10u32 }   /* non-optimised (imul == imul) */
    return 0u32
}

fn main() -> u64 {
    /* the 2-shift-sub rule is multi-engine CERTIFIED (bv_ring over a representative table) + the negative arm
     * bites + the BOOT emitter agrees -- the same standing gate as the other four families. */
    if cor_2ss_rule_count() == 0u64 { return 20u64 }
    if cor_2ss_certify_all() != 99u64 { return 21u64 }
    if cor_2ss_rejects_unsound() != 1u8 { return 22u64 }
    if cor_2ss_boot_agrees() != 1u8 { return 23u64 }

    if chk(0u64) != 0u32 { return 1u64 }
    if chk(1u64) != 0u32 { return 2u64 }
    if chk(3u64) != 0u32 { return 3u64 }
    if chk(255u64) != 0u32 { return 4u64 }
    if chk(123456789u64) != 0u32 { return 5u64 }
    if chk(9999999999u64) != 0u32 { return 6u64 }
    if chk(2305843009213693952u64) != 0u32 { return 7u64 }    /* 2^61 */
    if chk(9223372036854775808u64) != 0u32 { return 8u64 }    /* 2^63 */
    if chk(18446744073709551615u64) != 0u32 { return 9u64 }   /* 2^64-1 */
    if chk(13835058055282163712u64) != 0u32 { return 10u64 }  /* 3*2^62 */
    return 99u64
}
