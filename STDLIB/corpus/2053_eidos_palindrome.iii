/* STDLIB/corpus/2053_eidos_palindrome.iii -- INTUITION on the e-graph: the inverse-LOOKUP (the e-graph's
 * backward read).  The palindrome LAW (the checksum + paradox) lives on the real substrate -- eidos/ripple's
 * V_REFLECT involution and event_substrate's evt_detect_cycle (corpus 2054).  Here we only prove the e-graph
 * can read an origin back out of a class, and that the recovered origin is REAL (it computes the multiply).
 */
module corpus_2053_eidos_palindrome

extern @abi(c-msvc-x64) fn seg_intuit(v: u64) -> u64 from "ser_egraph.iii"
extern @abi(c-msvc-x64) fn seg_eval_mul(v: u64, x: u64) -> u64 from "ser_egraph.iii"

fn main() -> u64 {
    /* the e-graph reads the ORIGIN back out of the synthesized form's class (inverse-lookup, not recompute). */
    if seg_intuit(7u64)    != 7u64    { return 1u64 }
    if seg_intuit(10u64)   != 10u64   { return 2u64 }
    if seg_intuit(14u64)   != 14u64   { return 3u64 }
    if seg_intuit(11u64)   != 11u64   { return 4u64 }
    if seg_intuit(100u64)  != 100u64  { return 5u64 }
    if seg_intuit(1000u64) != 1000u64 { return 6u64 }

    /* the recovered origin is REAL (not a no-op): it then COMPUTES the multiply, over the wrap edge. */
    if seg_eval_mul(seg_intuit(10u64), 123456789u64) != 10u64 * 123456789u64 { return 7u64 }
    if seg_eval_mul(seg_intuit(14u64), 9223372036854775808u64) != 14u64 * 9223372036854775808u64 { return 8u64 }
    return 99u64
}
