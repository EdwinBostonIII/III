/* STDLIB/corpus/2062_egraph_mul_plan.iii -- the e-graph's emit PLAN that DRIVES cg_r3 (DOCS/III-EIDOS Phase 2).
 *
 * seg_mul_plan(v) saturates x*v, extracts the cost-optimal form, PROVES it == x*v over all 2^64 (bv_ring),
 * and classifies the proven form into the byte-faithful descriptor cg_r3 emits: kind | j<<8 | m<<16, kinds
 * IMUL=0 POW2=1 SHLADD=2 SUBK=3 2SH=4 2SS=5 IDENT=6.  This KAT pins the classification cg_r3 relies on AND
 * cross-checks (seg_eval_mul) that each synthesized form actually computes v*x on the metal over the wrap
 * edge.  99 = the plan is correct + proven + executes, for the families AND the imul-fallback.
 */
module corpus_2062_egraph_mul_plan

extern @abi(c-msvc-x64) fn seg_mul_plan(v: u64) -> u64 from "ser_egraph.iii"
extern @abi(c-msvc-x64) fn seg_eval_mul(v: u64, x: u64) -> u64 from "ser_egraph.iii"

fn kind(p: u64) -> u64 { return p & 255u64 }
fn jof(p: u64) -> u64 { return (p >> 8u64) & 255u64 }
fn mof(p: u64) -> u64 { return (p >> 16u64) & 255u64 }

fn main() -> u64 {
    /* IDENTITY: x*1 = x. */
    if seg_mul_plan(1u64) != 6u64 { return 1u64 }
    /* POW2: x*8 = x<<3 ; x*16 = x<<4 (the byte-checked stage1 shape). */
    if kind(seg_mul_plan(8u64)) != 1u64 { return 2u64 }
    if jof(seg_mul_plan(8u64)) != 3u64 { return 3u64 }
    if kind(seg_mul_plan(16u64)) != 1u64 { return 4u64 }
    if jof(seg_mul_plan(16u64)) != 4u64 { return 5u64 }
    /* SUBK: x*7 = (x<<3)-x. */
    if kind(seg_mul_plan(7u64)) != 3u64 { return 6u64 }
    if jof(seg_mul_plan(7u64)) != 3u64 { return 7u64 }
    /* SHLADD: x*9 = (x<<3)+x. */
    if kind(seg_mul_plan(9u64)) != 2u64 { return 8u64 }
    if jof(seg_mul_plan(9u64)) != 3u64 { return 9u64 }
    /* 2SH: x*10 = (x<<3)+(x<<1). */
    if kind(seg_mul_plan(10u64)) != 4u64 { return 10u64 }
    /* 2SS: x*14 = (x<<4)-(x<<1). */
    if kind(seg_mul_plan(14u64)) != 5u64 { return 11u64 }
    /* IMUL fallback: x*11 / x*100 cost >= imul -> not reduced (the math refuses a fake win). */
    if seg_mul_plan(11u64) != 0u64 { return 12u64 }
    if seg_mul_plan(100u64) != 0u64 { return 13u64 }
    /* TEETH: every synthesized form actually computes v*x over the wrap edge (executed, not asserted). */
    let e : u64 = 9223372036854775808u64   /* 2^63 */
    if seg_eval_mul(7u64, e) != 7u64 * e { return 14u64 }
    if seg_eval_mul(8u64, e) != 8u64 * e { return 15u64 }
    if seg_eval_mul(9u64, e) != 9u64 * e { return 16u64 }
    if seg_eval_mul(10u64, e) != 10u64 * e { return 17u64 }
    if seg_eval_mul(14u64, e) != 14u64 * e { return 18u64 }
    return 99u64
}
