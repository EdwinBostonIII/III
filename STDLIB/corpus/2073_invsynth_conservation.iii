/* STDLIB/corpus/2073_invsynth_conservation.iii -- THE RELATIONAL "AHA!", FULLY AUTOMATED: ser_petri FUZZES a
 * COUPLED transition to concrete (x,y) traces, ser_antiunify GENERALIZES them to a linear CONSERVATION law
 * w0*x + w1*y == c, and ser_kinduct_sym PROVES it over ALL 2^128 -- the invariant class III's single-scalar
 * templates (modular / interval / bit-pattern) CANNOT express (they bound one component; this is a RELATION
 * between components).  It is the sound, in-domain image of "the fractional charges +2/3,-1/3,-1/3 sum to
 * exactly zero": a conserved quantity, proven over the whole state space -- NOT an O(1) physics oracle.
 *
 * Two INDEPENDENT prover engines (closed-form kernel test + a genuine 2-var bit-blast miter) must AGREE; the
 * CONSCIENCE LINE refuses a non-conserving candidate with a checkable nonzero drift; the VACUITY guard rejects
 * the degenerate (0,0) "everything conserved".  99 = the law is synthesized end-to-end, PROVEN by both engines,
 * the false candidate refused (two arms, DIFFERENT verdicts -- not a tautology), and vacuity guarded. */
module corpus_2073_invsynth_conservation

extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_add(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_sub(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn sp_obs2_reset() -> i32 from "ser_petri.iii"
extern @abi(c-msvc-x64) fn sp_obs2_push(vx: u64, vy: u64) -> i32 from "ser_petri.iii"
extern @abi(c-msvc-x64) fn sp_obs_y_at(i: u32) -> u64 from "ser_petri.iii"
extern @abi(c-msvc-x64) fn sp_fuzz_det2(tx: u32, ty: u32, xv: u32, yv: u32, x0: u64, y0: u64, n: u32) -> u32 from "ser_petri.iii"
extern @abi(c-msvc-x64) fn au_consv_found() -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_consv_w0() -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_consv_w1() -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_consv_c() -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn sks_consv_step(w0: u64, w1: u64, a: u64, b: u64) -> u8 from "ser_kinduct_sym.iii"
extern @abi(c-msvc-x64) fn sks_consv_base(w0: u64, w1: u64, c: u64, x0: u64, y0: u64) -> u8 from "ser_kinduct_sym.iii"
extern @abi(c-msvc-x64) fn sks_consv_prove(w0: u64, w1: u64, c: u64, a: u64, b: u64, x0: u64, y0: u64) -> u8 from "ser_kinduct_sym.iii"
extern @abi(c-msvc-x64) fn sks_consv_step_sym(w0: u64, w1: u64, a: u64, b: u64) -> u8 from "ser_kinduct_sym.iii"
extern @abi(c-msvc-x64) fn sks_consv_drift(w0: u64, w1: u64, a: u64, b: u64) -> u64 from "ser_kinduct_sym.iii"

fn main() -> u64 {
    let bneg1 : u64 = 0u64 - 1u64    /* -1 mod 2^64 */
    let bneg2 : u64 = 0u64 - 2u64    /* -2 mod 2^64 */

    /* (a) FUZZ the coupled counter x'=x+1, y'=y-1 from (3,7) -> {(3,7),(4,6),(5,5),...}; x+y == 10 conserved.
     *     No human-supplied observation: the trace is generated by walking the real bv_bits transition. */
    bb_reset(64u64)
    let xv : u32 = bb_var(0u32)
    let yv : u32 = bb_var(1u32)
    let tx : u32 = bb_add(xv, bb_const(1u64))
    let ty : u32 = bb_sub(yv, bb_const(1u64))
    if sp_fuzz_det2(tx, ty, 0u32, 1u32, 3u64, 7u64, 16u32) != 16u32 { return 1u64 }

    /* (b) GENERALIZE: the relational lgg discovers a linear conservation law fitting EVERY observed pair. */
    if au_consv_found() != 1u32 { return 2u64 }
    let w0 : u64 = au_consv_w0()
    let w1 : u64 = au_consv_w1()
    let c  : u64 = au_consv_c()

    /* (c) PROVE the DISCOVERED kernel conserved over ALL 2^128 under (a,b)=(+1,-1) -- base AND step. */
    if sks_consv_base(w0, w1, c, 3u64, 7u64) != 1u8 { return 3u64 }
    if sks_consv_step(w0, w1, 1u64, bneg1) != 1u8 { return 4u64 }
    if sks_consv_prove(w0, w1, c, 1u64, bneg1, 3u64, 7u64) != 1u8 { return 5u64 }

    /* (d) THE CLEAN REPRESENTATIVE: x+y (weights 1,1, constant 10) is the SAME 1-D conserved quantity; both the
     *     closed form AND the INDEPENDENT bit-blast miter PROVE it (two engines agree on the TRUE law). */
    if sks_consv_prove(1u64, 1u64, 10u64, 1u64, bneg1, 3u64, 7u64) != 1u8 { return 6u64 }
    if sks_consv_step_sym(1u64, 1u64, 1u64, bneg1) != 1u8 { return 7u64 }
    if sks_consv_drift(1u64, 1u64, 1u64, bneg1) != 0u64 { return 8u64 }    /* the true law: zero drift */

    /* (e) THE CONSCIENCE LINE: under x'=x+1, y'=y-2 the candidate x+y is NOT conserved (1*1 + 1*(-2) = -1 != 0).
     *     BOTH engines REFUSE it, and the drift is exactly the nonzero defect -1 (a checkable counterexample) --
     *     synthesis proposes, only the proof disposes (two arms, DIFFERENT verdicts: this is not a tautology). */
    if sks_consv_step(1u64, 1u64, 1u64, bneg2) != 0u8 { return 9u64 }
    if sks_consv_step_sym(1u64, 1u64, 1u64, bneg2) != 0u8 { return 10u64 }
    if sks_consv_drift(1u64, 1u64, 1u64, bneg2) != bneg1 { return 11u64 } /* defect == -1, nonzero */
    /* the END-TO-END prover REFUSES the non-conserving candidate too (base x+y==10 holds at (3,7), but the
     * step under (+1,-2) drifts) -- so sks_consv_prove exhibits BOTH outcomes across the corpus, not just accept. */
    if sks_consv_prove(1u64, 1u64, 10u64, 1u64, bneg2, 3u64, 7u64) != 0u8 { return 16u64 }

    /* (f) THE VACUITY GUARD: a (0,0) kernel ("everything conserved") is REFUSED -- never reported proven. */
    if sks_consv_step(0u64, 0u64, 1u64, bneg1) != 0u8 { return 12u64 }

    /* (g) MANUAL-PUSH path (2065-style): hand-supply a coupled trace {(0,100),(1,99),(2,98),(3,97)} on the
     *     two-stream obs buffer, confirm the y-stream accessor, and prove the discovered law (x+y == 100). */
    sp_obs2_reset()
    sp_obs2_push(0u64, 100u64)  sp_obs2_push(1u64, 99u64)  sp_obs2_push(2u64, 98u64)  sp_obs2_push(3u64, 97u64)
    if sp_obs_y_at(0u32) != 100u64 { return 13u64 }
    if au_consv_found() != 1u32 { return 14u64 }
    let w0b : u64 = au_consv_w0()
    let w1b : u64 = au_consv_w1()
    let cb  : u64 = au_consv_c()
    if sks_consv_prove(w0b, w1b, cb, 1u64, bneg1, 0u64, 100u64) != 1u8 { return 15u64 }

    return 99u64
}
