/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\209_idoc_roundtrip.iii
 *
 * III conformance corpus 209 -- Phase D.4: IDoc roundtrip + facet
 * resolution.
 *
 * Asserts:
 *   1. idoc_pack_payload writes 4 facet records back-to-back.
 *   2. idoc_finalize wraps payload in babel_wire envelope (CRC OK).
 *   3. idoc_resolve_facet returns the FIRST facet matching the
 *      caller's capability mask.
 *   4. idoc_validate confirms structural sanity.
 *
 * Exit code: 99 on full pass; 1..N for specific failures.
 */

module corpus_209

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn babel_wire_init(out_buf: u64) -> i32 from "babel_wire.iii"
extern @abi(c-msvc-x64) fn babel_wire_set_seal_id(out_buf: u64, seal_id: u64) -> i32 from "babel_wire.iii"
extern @abi(c-msvc-x64) fn babel_wire_set_intent_id(out_buf: u64, intent_id: u64) -> i32 from "babel_wire.iii"
extern @abi(c-msvc-x64) fn babel_wire_set_ctx_digest(out_buf: u64, digest_ptr: u64) -> i32 from "babel_wire.iii"
extern @abi(c-msvc-x64) fn babel_wire_set_facet(out_buf: u64, facet_id: u8) -> i32 from "babel_wire.iii"
extern @abi(c-msvc-x64) fn babel_wire_header_bytes() -> u32 from "babel_wire.iii"

extern @abi(c-msvc-x64) fn idoc_pack_payload(facet_ids_ptr: u64, facet_data_ptrs_ptr: u64, facet_lens_ptr: u64, out_payload_ptr: u64) -> u32 from "idoc.iii"
extern @abi(c-msvc-x64) fn idoc_finalize(out_buf: u64, payload_len: u32) -> u32 from "idoc.iii"
extern @abi(c-msvc-x64) fn idoc_resolve_facet(idoc_buf: u64, my_caps: u8, out_facet_data_ptr: u64, out_facet_len_ptr: u64) -> u8 from "idoc.iii"
extern @abi(c-msvc-x64) fn idoc_validate(idoc_buf: u64, idoc_len: u32) -> u8 from "idoc.iii"
extern @abi(c-msvc-x64) fn idoc_facet_count(idoc_buf: u64) -> u32 from "idoc.iii"

fn main() -> u64 {
    /* Allocate envelope buffer. Header 68 + payload 60 + slack = 512. */
    let buf : *u8 = malloc(512u64)
    if buf as u64 == 0u64 { return 1u64 }
    let bptr : u64 = buf as u64

    babel_wire_init(bptr)
    babel_wire_set_seal_id(bptr, 0xDEADBEEFu64)
    babel_wire_set_intent_id(bptr, 0x1234u64)

    /* ctx_digest: 32 bytes of 0xC0..0xDF. */
    let dig : *u8 = malloc(32u64)
    let mut i : u64 = 0u64
    while i < 32u64 {
        dig[i] = ((0xC0u64 + i) & 0xFFu64) as u8
        i = i + 1u64
    }
    babel_wire_set_ctx_digest(bptr, dig as u64)

    /* facets_mask in the wire's facet field: 0x0F = all 4. */
    babel_wire_set_facet(bptr, 0x0Fu8)

    /* Build 4 facet payloads. */
    let render_data   : *u8 = malloc(8u64)
    let extract_data  : *u8 = malloc(12u64)
    let exec_data     : *u8 = malloc(4u64)
    let validate_data : *u8 = malloc(16u64)

    /* Render facet "RENDER!!" (8 bytes). */
    render_data[0u64] = 82u8
    render_data[1u64] = 69u8
    render_data[2u64] = 78u8
    render_data[3u64] = 68u8
    render_data[4u64] = 69u8
    render_data[5u64] = 82u8
    render_data[6u64] = 33u8
    render_data[7u64] = 33u8

    /* Extract facet "JSON_PAYLOAD" (12 bytes). */
    extract_data[0u64]  = 74u8
    extract_data[1u64]  = 83u8
    extract_data[2u64]  = 79u8
    extract_data[3u64]  = 78u8
    extract_data[4u64]  = 95u8
    extract_data[5u64]  = 80u8
    extract_data[6u64]  = 65u8
    extract_data[7u64]  = 89u8
    extract_data[8u64]  = 76u8
    extract_data[9u64]  = 79u8
    extract_data[10u64] = 65u8
    extract_data[11u64] = 68u8

    /* Execute facet "EXEC" (4 bytes). */
    exec_data[0u64] = 69u8
    exec_data[1u64] = 88u8
    exec_data[2u64] = 69u8
    exec_data[3u64] = 67u8

    /* Validate facet 16 bytes filler 0xAA. */
    let mut m : u64 = 0u64
    while m < 16u64 {
        validate_data[m] = 0xAAu8
        m = m + 1u64
    }

    /* facet_ids[4], data ptrs[4*8=32], lens[4*4=16]. */
    let fids : *u8 = malloc(4u64)
    let fdpa : *u8 = malloc(32u64)
    let flna : *u8 = malloc(16u64)
    fids[0u64] = 0x01u8
    fids[1u64] = 0x02u8
    fids[2u64] = 0x04u8
    fids[3u64] = 0x08u8

    /* Pack ptrs as u64 LE via typed locals. */
    let fdpa_u : u64 = fdpa as u64
    let dp0 : *u64 = fdpa_u as *u64
    let dp1 : *u64 = (fdpa_u + 8u64) as *u64
    let dp2 : *u64 = (fdpa_u + 16u64) as *u64
    let dp3 : *u64 = (fdpa_u + 24u64) as *u64
    dp0[0u64] = render_data as u64
    dp1[0u64] = extract_data as u64
    dp2[0u64] = exec_data as u64
    dp3[0u64] = validate_data as u64

    /* Pack lens as u32 LE via typed locals. */
    let flna_u : u64 = flna as u64
    let lp0 : *u32 = flna_u as *u32
    let lp1 : *u32 = (flna_u + 4u64) as *u32
    let lp2 : *u32 = (flna_u + 8u64) as *u32
    let lp3 : *u32 = (flna_u + 12u64) as *u32
    lp0[0u64] = 8u32
    lp1[0u64] = 12u32
    lp2[0u64] = 4u32
    lp3[0u64] = 16u32

    /* Pack payload at wire's payload region. */
    let hb : u32 = babel_wire_header_bytes()
    let payload_base : u64 = bptr + (hb as u64)
    let plen : u32 = idoc_pack_payload(fids as u64, fdpa as u64, flna as u64, payload_base)
    /* Expected: 4*5 + 8 + 12 + 4 + 16 = 60. */
    if plen != 60u32 { return 2u64 }

    /* Finalize -> total wire length. */
    let total : u32 = idoc_finalize(bptr, plen)
    if total != (hb + plen) { return 3u64 }

    /* Validate. */
    if idoc_validate(bptr, total) != 1u8 { return 4u64 }

    /* Facet count. */
    if idoc_facet_count(bptr) != 4u32 { return 5u64 }

    /* Out-buffers for resolve. */
    let ofd_p : *u8 = malloc(8u64)
    let ofl_p : *u8 = malloc(4u64)
    let ofd_u : u64 = ofd_p as u64
    let ofl_u : u64 = ofl_p as u64
    let ofd_pp : *u64 = ofd_u as *u64
    let ofl_pp : *u32 = ofl_u as *u32

    /* Resolve as render-only client (caps = 0x01). */
    if idoc_resolve_facet(bptr, 0x01u8, ofd_u, ofl_u) != 1u8 { return 6u64 }
    let rd_ptr : u64 = ofd_pp[0u64]
    let rd_len : u32 = ofl_pp[0u64]
    if rd_len != 8u32 { return 7u64 }
    let rb : *u8 = rd_ptr as *u8
    if rb[0u64] != 82u8 { return 8u64 }
    if rb[7u64] != 33u8 { return 9u64 }

    /* Resolve as data-only client (caps = 0x02). */
    if idoc_resolve_facet(bptr, 0x02u8, ofd_u, ofl_u) != 1u8 { return 10u64 }
    let ed_ptr : u64 = ofd_pp[0u64]
    let ed_len : u32 = ofl_pp[0u64]
    if ed_len != 12u32 { return 11u64 }
    let eb : *u8 = ed_ptr as *u8
    if eb[0u64] != 74u8 { return 12u64 }
    if eb[11u64] != 68u8 { return 13u64 }

    /* Resolve as combined client (caps = 0x06 = extract + execute).
     * idoc_resolve_facet returns FIRST match -- which is extract (0x02)
     * because the iteration hits it before execute (0x04). */
    if idoc_resolve_facet(bptr, 0x06u8, ofd_u, ofl_u) != 1u8 { return 14u64 }
    let cd_len : u32 = ofl_pp[0u64]
    if cd_len != 12u32 { return 15u64 }

    /* Resolve as no-cap client (caps = 0x00). No match. */
    if idoc_resolve_facet(bptr, 0x00u8, ofd_u, ofl_u) != 0u8 { return 16u64 }

    /* Resolve as exec-only (caps = 0x04). */
    if idoc_resolve_facet(bptr, 0x04u8, ofd_u, ofl_u) != 1u8 { return 17u64 }
    let xc_len : u32 = ofl_pp[0u64]
    if xc_len != 4u32 { return 18u64 }

    free(buf)
    free(dig)
    free(render_data)
    free(extract_data)
    free(exec_data)
    free(validate_data)
    free(fids)
    free(fdpa)
    free(flna)
    free(ofd_p)
    free(ofl_p)
    return 99u64
}
