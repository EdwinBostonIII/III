/* STDLIB/corpus/2101_hausdorff_dim.iii -- THE TOPOLOGICAL WINDOWING SYSTEM, Phase 12: CONTINUOUS HAUSDORFF DIMENSION.
 *
 * The metric that makes the UI "mathematically alive": a boundary with 1<d<2 has infinite length but bounded area,
 * so SEMANTIC ZOOM is TOPOLOGY (the dimension unfolds new state at each scale), not if/then.  Two exact grounds:
 *  (1) a SMOOTH (rectifiable) curve has box-counting dimension EXACTLY 1: N(eps) is LINEAR in 1/eps.  A straight
 *      segment (0,0)->(a,b) covers scl*(a+b-gcd(a,b)) cells at scale 1/scl -- N/scl is CONSTANT => d=1.
 *  (2) a SELF-SIMILAR IFS (M copies at scale 1/n, open-set condition) has box=Hausdorff dimension log M / log n;
 *      when rational it is an exact integer relation (Minkowski 8-at-1/4 -> 3/2, since 8^2 = 4^3).
 * 99 = a smooth curve measures d=1 exactly (linear scaling) AND every self-similar dimension is exact. */
module corpus_2101_hausdorff_dim

extern @abi(c-msvc-x64) fn ui_boxcount_seg(a: i64, b: i64, scl: i64) -> i64 from "ui_exact.iii"
extern @abi(c-msvc-x64) fn ui_dim_selfsim(M: i64, invScale: i64) -> u32 from "ui_exact.iii"
extern @abi(c-msvc-x64) fn ui_dim_p() -> i64 from "ui_exact.iii"
extern @abi(c-msvc-x64) fn ui_dim_q() -> i64 from "ui_exact.iii"
extern @abi(c-msvc-x64) fn ui_zoom_detail(M: i64, n: i64, zoom: i64) -> i64 from "ui_exact.iii"

fn main() -> u64 {
    /* === (1) SMOOTH curve -> d = 1 EXACTLY (box-count LINEAR in 1/eps) === */
    /* diagonal (0,0)->(3,3): cells = 3+3-gcd(3,3)=3 per unit scale -> N(scl)=3*scl, perfectly linear => d=1 */
    if ui_boxcount_seg(3i64, 3i64, 1i64) != 3i64 { return 1u64 }
    if ui_boxcount_seg(3i64, 3i64, 2i64) != 6i64 { return 2u64 }     /* refine eps by 2x -> N doubles (d=1) */
    if ui_boxcount_seg(3i64, 3i64, 4i64) != 12i64 { return 3u64 }    /* and by 4x -> N x4 (still linear, d=1) */
    /* coprime (0,0)->(3,5): cells = 3+5-1 = 7 per unit, linear => d=1 */
    if ui_boxcount_seg(3i64, 5i64, 1i64) != 7i64 { return 4u64 }
    if ui_boxcount_seg(3i64, 5i64, 10i64) != 70i64 { return 5u64 }

    /* === (2) SELF-SIMILAR FRACTALS -> exact box=Hausdorff dimension === */
    /* Minkowski sausage: 8 copies at scale 1/4 -> d = log8/log4 = 3/2 (8^2 = 64 = 4^3), the canonical 1<d<2 boundary */
    if ui_dim_selfsim(8i64, 4i64) != 1u32 { return 6u64 }
    if ui_dim_p() != 3i64 { return 7u64 }
    if ui_dim_q() != 2i64 { return 8u64 }                            /* d = 3/2 EXACTLY */
    /* a straight line AS an IFS: 2 copies at scale 1/2 -> d = log2/log2 = 1 */
    if ui_dim_selfsim(2i64, 2i64) != 1u32 { return 9u64 }
    if ui_dim_p() != 1i64 { return 10u64 }
    if ui_dim_q() != 1i64 { return 11u64 }
    /* a 16-at-1/8 fractal -> d = log16/log8 = 4/3 (16^3 = 4096 = 8^4) */
    if ui_dim_selfsim(16i64, 8i64) != 1u32 { return 12u64 }
    if ui_dim_p() != 4i64 { return 13u64 }
    if ui_dim_q() != 3i64 { return 14u64 }
    /* Koch curve: 4 copies at scale 1/3 -> d = log4/log3 is IRRATIONAL (2 and 3 coprime) -> reported as such */
    if ui_dim_selfsim(4i64, 3i64) != 0u32 { return 15u64 }
    /* Sierpinski-ish: 3 copies at scale 1/2 -> d = log3/log2 IRRATIONAL */
    if ui_dim_selfsim(3i64, 2i64) != 0u32 { return 16u64 }

    /* === SEMANTIC ZOOM AS TOPOLOGY: the dimension drives the unfolding rate, detail = z^d === */
    if ui_zoom_detail(8i64, 4i64, 16i64) != 64i64 { return 17u64 }    /* Minkowski d=3/2 at zoom 16 -> 16^(3/2) = 64 */
    if ui_zoom_detail(8i64, 4i64, 64i64) != 512i64 { return 18u64 }   /* at zoom 64 -> 64^(3/2) = 512 */
    if ui_zoom_detail(2i64, 2i64, 16i64) != 16i64 { return 19u64 }    /* smooth line d=1 at zoom 16 -> 16^1 = 16 */
    /* the topological heart: at the SAME zoom, the fractal boundary reveals strictly MORE state than the smooth one */
    if ui_zoom_detail(8i64, 4i64, 16i64) <= ui_zoom_detail(2i64, 2i64, 16i64) { return 20u64 }

    return 99u64
}
