/* STDLIB/corpus/2105_field_color.iii -- THE UNIFIED FIELD, faculty 7: STRUCTURAL COLOR.
 * A boundary's complexity-dimension d (faculty 1) maps to a physical wavelength (d=1->700nm red, d=2->380nm violet),
 * and the wavelength becomes spectral RGB.  Color is generated by topology, not assigned by a hex code.
 * 99 = the dimension Doppler-shifts through the spectrum: predictable=red, complex=violet, mid=green. */
module corpus_2105_field_color

extern @abi(c-msvc-x64) fn ui_wavelength_rgb(lam: i64) -> u32 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_dim_to_rgb(d_milli: i64) -> u32 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_grating_wavelength(p_nm: i64, sin_num: i64, sin_den: i64, order: i64) -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_struct_color(p_nm: i64, sin_num: i64, sin_den: i64, order: i64) -> u32 from "ui_field.iii"

fn main() -> u64 {
    /* d=1.0 (predictable line) -> 700nm -> pure RED */
    let c1 : u32 = ui_dim_to_rgb(1000i64)
    if ((c1 >> 16u32) & 255u32) != 255u32 { return 1u64 }
    if ((c1 >> 8u32) & 255u32) != 0u32 { return 2u64 }
    if (c1 & 255u32) != 0u32 { return 3u64 }

    /* d=1.5 -> 540nm -> GREEN band (G saturated) */
    let c2 : u32 = ui_dim_to_rgb(1500i64)
    if ((c2 >> 8u32) & 255u32) != 255u32 { return 4u64 }

    /* d=2.0 (max complexity) -> 380nm -> violet (blue present) */
    let c3 : u32 = ui_dim_to_rgb(2000i64)
    if (c3 & 255u32) != 255u32 { return 5u64 }
    if ((c3 >> 8u32) & 255u32) != 0u32 { return 6u64 }

    /* the spectrum itself: 460nm -> blue (B saturated), 620nm -> red-orange (R saturated) */
    let bl : u32 = ui_wavelength_rgb(460i64)
    if (bl & 255u32) != 255u32 { return 7u64 }
    let rd : u32 = ui_wavelength_rgb(620i64)
    if ((rd >> 16u32) & 255u32) != 255u32 { return 8u64 }

    /* === THE EXACT STRUCTURAL-COLOR IDENTITY: lambda = p*sin(theta)/m, EXACT from the geometry (no color table) === */
    if ui_grating_wavelength(1000i64, 1i64, 2i64, 1i64) != 500i64 { return 9u64 }    /* period 1000nm, 30deg -> 500nm green */
    if ui_grating_wavelength(1400i64, 1i64, 2i64, 1i64) != 700i64 { return 10u64 }   /* a wider period -> 700nm red */
    if ui_grating_wavelength(760i64, 1i64, 2i64, 1i64) != 380i64 { return 11u64 }    /* a tighter period -> 380nm violet */
    if ui_grating_wavelength(2000i64, 1i64, 2i64, 2i64) != 500i64 { return 12u64 }   /* 2nd order halves it -> 500nm again */
    /* and the structural color of a 1400nm-period boundary is pure red, a proven identity of its geometry */
    let sc : u32 = ui_struct_color(1400i64, 1i64, 2i64, 1i64)
    if ((sc >> 16u32) & 255u32) != 255u32 { return 13u64 }
    if ((sc >> 8u32) & 255u32) != 0u32 { return 14u64 }

    return 99u64
}

