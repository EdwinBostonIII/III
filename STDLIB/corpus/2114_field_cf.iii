/* STDLIB/corpus/2114_field_cf.iii -- THE UNIFIED FIELD, faculty N: SELF-POPULATING NUMBERS.
 * "Numbers are too dumb" -- a stored float implies a false absolute background and is lossy.  Store the RULE instead:
 * a periodic continued fraction is a finite seed that self-populates the EXACT convergents of a quadratic irrational
 * to any precision.  The Pell residue p^2 - D q^2 staying exactly +-1 forever is the PROOF the seed IS sqrt(D).
 * 99 = a handful of symbols self-generate exact irrationals, proven by Pell -- a number that grows itself. */
module corpus_2114_field_cf

extern @abi(c-msvc-x64) fn ui_cf_run(a0: i64, period: u64, period_len: i64, n_terms: i64) -> i32 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_cf_p() -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_cf_q() -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_cf_pell(d: i64) -> i64 from "ui_field.iii"

var PER : [i64; 2]

fn main() -> u64 {
    /* THE GOLDEN RATIO  phi = [1; 1,1,1,...] -- a 2-symbol seed; its convergents are the Fibonacci ratios */
    PER[0u64] = 1i64
    ui_cf_run(1i64, &PER as u64, 1i64, 5i64)
    if ui_cf_p() != 8i64 { return 1u64 }                  /* 8/5 -- the 5th Fibonacci convergent of phi */
    if ui_cf_q() != 5i64 { return 2u64 }

    /* sqrt(2) = [1; 2,2,2,...] -- the seed self-populates the exact convergents */
    PER[0u64] = 2i64
    ui_cf_run(1i64, &PER as u64, 1i64, 5i64)
    if ui_cf_p() != 41i64 { return 3u64 }                 /* 41/29 */
    if ui_cf_q() != 29i64 { return 4u64 }
    if ui_cf_pell(2i64) != (0i64 - 1i64) { return 5u64 }  /* 41^2 - 2*29^2 = -1 EXACTLY -- proof the seed is sqrt(2) */

    /* self-populate FURTHER -- 10 terms gives a far better convergent, STILL exactly Pell +-1 (any precision, exact) */
    ui_cf_run(1i64, &PER as u64, 1i64, 10i64)
    if ui_cf_pell(2i64) != 1i64 { return 6u64 }           /* still exactly +-1, sign alternating -- never drifts */

    /* sqrt(5) = [2; 4,4,4,...] -- another quadratic irrational from a tiny seed */
    PER[0u64] = 4i64
    ui_cf_run(2i64, &PER as u64, 1i64, 5i64)
    if ui_cf_pell(5i64) != (0i64 - 1i64) { return 7u64 }  /* 682^2 - 5*305^2 = -1 EXACTLY */

    return 99u64
}
