/* STDLIB/corpus/2116_field_hash.iii -- THE UNIFIED FIELD, faculty H: FRACTAL HASH (geometry as a tamper seal).
 * The data is walked as a turtle path; the seal is the path's exact signed area + endpoint.  A single bit-flip
 * translates the whole downstream path, so the seal provably shears -- tamper is detected exactly, never a false
 * "valid", and an untampered document re-seals identically.  99 = tamper shears the seal; the clean copy is exact. */
module corpus_2116_field_hash

extern @abi(c-msvc-x64) fn ui_fractal_hash(buf: u64, n: u64) -> i32 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_hash_a2() -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_hash_ex() -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_hash_ey() -> i64 from "ui_field.iii"

var BUF : [u8; 16]

fn main() -> u64 {
    let b : u64 = &BUF as u64
    /* a 16-byte "document" */
    let mut i : u64 = 0u64
    while i < 16u64 { BUF[i] = ((i * 13u64) + 7u64) as u8   i = i + 1u64 }
    BUF[5u64] = 53u8                                          /* pin a known byte we will tamper (low nibble 5) */

    /* SEAL the original */
    ui_fractal_hash(b, 16u64)
    let a0 : i64 = ui_hash_a2()
    let ex0 : i64 = ui_hash_ex()
    let ey0 : i64 = ui_hash_ey()

    /* TAMPER one byte -> the downstream path translates -> the endpoint provably shifts (tamper detected) */
    BUF[5u64] = 54u8
    ui_fractal_hash(b, 16u64)
    if ui_hash_ex() == ex0 { if ui_hash_ey() == ey0 { if ui_hash_a2() == a0 { return 1u64 } } }  /* unchanged = undetected */
    if ui_hash_ex() == ex0 { return 2u64 }                   /* the endpoint MUST move (low-nibble change -> dx shifts) */

    /* RESTORE -> the seal re-derives identically (deterministic, exact) */
    BUF[5u64] = 53u8
    ui_fractal_hash(b, 16u64)
    if ui_hash_a2() != a0 { return 3u64 }
    if ui_hash_ex() != ex0 { return 4u64 }
    if ui_hash_ey() != ey0 { return 5u64 }

    return 99u64
}
