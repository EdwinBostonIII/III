/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\211_hip_resolve.iii
 *
 * III conformance corpus 211 -- Phase E: HIP NL surface end-to-end.
 *
 * Asserts:
 *   1. Unambiguous utterance "send 32 bytes from buffer to handle"
 *      -> HIP_CLASS_UNIQUE, 1 candidate.
 *   2. Ambiguous utterance "encrypt buffer with key"
 *      -> HIP_CLASS_AMBIGUOUS, 2 candidates.
 *   3. No-match utterance "xyzzy plugh foobar"
 *      -> HIP_CLASS_NO_MATCH, 0 candidates.
 *   4. Determinism: re-resolve same input -> identical
 *      (class, count) two times in a row.
 *
 * Exit code: 99 on full pass; 1..N for specific failure point.
 */

module corpus_211

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn hip_resolve(text_ptr: u64, text_len: u32, out_cands_ptr: u64, out_meta_ptr: u64) -> i32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_class_unique() -> u32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_class_ambiguous() -> u32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_class_no_match() -> u32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_last_kind() -> u32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_last_frag_count() -> u32 from "hip.iii"

fn _store_str(buf: *u8, off: u64, b: u8) -> u64 {
    buf[off] = b
    return off + 1u64
}

/* Byte-wise u32 reader -- iiis-0 *u32 indexing emits 8-byte movq, which
 * loads adjacent slots; mask via byte assembly to dodge it. */
fn _read_u32(buf: *u8, off: u64) -> u32 {
    let b0 : u32 = (buf[off] as u32) & 0xFFu32
    let b1 : u32 = ((buf[off + 1u64] as u32) & 0xFFu32) << 8u32
    let b2 : u32 = ((buf[off + 2u64] as u32) & 0xFFu32) << 16u32
    let b3 : u32 = ((buf[off + 3u64] as u32) & 0xFFu32) << 24u32
    return b0 | b1 | b2 | b3
}

fn main() -> u64 {
    /* Allocate text buffer + candidate buffer + meta (count|class).
     * Meta is 16 bytes (not 8) because iiis-0's *u32 index reads
     * emit 8-byte movq -- offset 4 + 8 = 12 reads OOB on an 8-byte
     * allocation. Pad to 16, zero the tail. */
    let text  : *u8 = malloc(256u64)
    let cands : *u8 = malloc(8u64 * 8u64)
    let meta  : *u8 = malloc(16u64)
    if text  as u64 == 0u64 { return 1u64 }
    if cands as u64 == 0u64 { return 2u64 }
    if meta  as u64 == 0u64 { return 3u64 }

    /* Zero the meta buffer fully. */
    let mut zi : u64 = 0u64
    while zi < 16u64 { meta[zi] = 0u8; zi = zi + 1u64 }

    let meta_u : u64 = meta as u64
    let cnt_pp : *u32 = meta_u as *u32
    let cls_pp : *u32 = (meta_u + 4u64) as *u32

    /* === Test 1: unique ===
     * "send 32 bytes from buffer to handle" */
    let s1 : *u8 = text
    let mut o : u64 = 0u64
    o = _store_str(s1, o, 115u8)   /* s */
    o = _store_str(s1, o, 101u8)   /* e */
    o = _store_str(s1, o, 110u8)   /* n */
    o = _store_str(s1, o, 100u8)   /* d */
    o = _store_str(s1, o, 32u8)    /* space */
    o = _store_str(s1, o, 51u8)    /* 3 */
    o = _store_str(s1, o, 50u8)    /* 2 */
    o = _store_str(s1, o, 32u8)
    o = _store_str(s1, o, 98u8)    /* b */
    o = _store_str(s1, o, 121u8)   /* y */
    o = _store_str(s1, o, 116u8)   /* t */
    o = _store_str(s1, o, 101u8)   /* e */
    o = _store_str(s1, o, 115u8)   /* s */
    o = _store_str(s1, o, 32u8)
    o = _store_str(s1, o, 102u8)   /* f */
    o = _store_str(s1, o, 114u8)   /* r */
    o = _store_str(s1, o, 111u8)   /* o */
    o = _store_str(s1, o, 109u8)   /* m */
    o = _store_str(s1, o, 32u8)
    o = _store_str(s1, o, 98u8)    /* b */
    o = _store_str(s1, o, 117u8)   /* u */
    o = _store_str(s1, o, 102u8)   /* f */
    o = _store_str(s1, o, 102u8)   /* f */
    o = _store_str(s1, o, 101u8)   /* e */
    o = _store_str(s1, o, 114u8)   /* r */
    o = _store_str(s1, o, 32u8)
    o = _store_str(s1, o, 116u8)   /* t */
    o = _store_str(s1, o, 111u8)   /* o */
    o = _store_str(s1, o, 32u8)
    o = _store_str(s1, o, 104u8)   /* h */
    o = _store_str(s1, o, 97u8)    /* a */
    o = _store_str(s1, o, 110u8)   /* n */
    o = _store_str(s1, o, 100u8)   /* d */
    o = _store_str(s1, o, 108u8)   /* l */
    o = _store_str(s1, o, 101u8)   /* e */
    let len1 : u32 = o as u32

    let rc1 : i32 = hip_resolve(s1 as u64, len1, cands as u64, meta_u)
    if rc1 == -1i32 { return 101u64 }
    if rc1 == -2i32 { return 102u64 }
    if rc1 == -3i32 { return 103u64 }
    if rc1 != 0i32 { return 5u64 }
    if _read_u32(meta, 4u64) != hip_class_unique() { return 6u64 }
    if _read_u32(meta, 0u64) != 1u32 { return 7u64 }
    /* Sanity: parse identified IMPERATIVE and emitted at least 4 fragments
     * (verb + patient + source + destination). */
    if hip_last_kind() != 1u32 { return 8u64 }
    if hip_last_frag_count() < 4u32 { return 9u64 }

    /* Determinism: re-resolve identical input -> identical class+count. */
    let rc1b : i32 = hip_resolve(s1 as u64, len1, cands as u64, meta_u)
    if rc1b != 0i32 { return 10u64 }
    if _read_u32(meta, 4u64) != hip_class_unique() { return 11u64 }
    if _read_u32(meta, 0u64) != 1u32 { return 12u64 }

    /* === Test 2: ambiguous ===
     * "encrypt buffer with key" -> 2 candidates (CONVEY + FORM). */
    let mut p : u64 = 0u64
    p = _store_str(s1, p, 101u8)  /* e */
    p = _store_str(s1, p, 110u8)  /* n */
    p = _store_str(s1, p, 99u8)   /* c */
    p = _store_str(s1, p, 114u8)  /* r */
    p = _store_str(s1, p, 121u8)  /* y */
    p = _store_str(s1, p, 112u8)  /* p */
    p = _store_str(s1, p, 116u8)  /* t */
    p = _store_str(s1, p, 32u8)
    p = _store_str(s1, p, 98u8)   /* b */
    p = _store_str(s1, p, 117u8)  /* u */
    p = _store_str(s1, p, 102u8)  /* f */
    p = _store_str(s1, p, 102u8)  /* f */
    p = _store_str(s1, p, 101u8)  /* e */
    p = _store_str(s1, p, 114u8)  /* r */
    p = _store_str(s1, p, 32u8)
    p = _store_str(s1, p, 119u8)  /* w */
    p = _store_str(s1, p, 105u8)  /* i */
    p = _store_str(s1, p, 116u8)  /* t */
    p = _store_str(s1, p, 104u8)  /* h */
    p = _store_str(s1, p, 32u8)
    p = _store_str(s1, p, 107u8)  /* k */
    p = _store_str(s1, p, 101u8)  /* e */
    p = _store_str(s1, p, 121u8)  /* y */
    let len2 : u32 = p as u32

    let rc2 : i32 = hip_resolve(s1 as u64, len2, cands as u64, meta_u)
    if rc2 != 0i32 { return 13u64 }
    if _read_u32(meta, 4u64) != hip_class_ambiguous() { return 14u64 }
    if _read_u32(meta, 0u64) != 2u32 { return 15u64 }

    /* === Test 3: no-match ===
     * "xyzzy plugh foobar" -> all IDENT, no VERB -> NO_MATCH. */
    let mut q : u64 = 0u64
    q = _store_str(s1, q, 120u8)   /* x */
    q = _store_str(s1, q, 121u8)   /* y */
    q = _store_str(s1, q, 122u8)   /* z */
    q = _store_str(s1, q, 122u8)   /* z */
    q = _store_str(s1, q, 121u8)   /* y */
    q = _store_str(s1, q, 32u8)
    q = _store_str(s1, q, 112u8)   /* p */
    q = _store_str(s1, q, 108u8)   /* l */
    q = _store_str(s1, q, 117u8)   /* u */
    q = _store_str(s1, q, 103u8)   /* g */
    q = _store_str(s1, q, 104u8)   /* h */
    q = _store_str(s1, q, 32u8)
    q = _store_str(s1, q, 102u8)   /* f */
    q = _store_str(s1, q, 111u8)   /* o */
    q = _store_str(s1, q, 111u8)   /* o */
    q = _store_str(s1, q, 98u8)    /* b */
    q = _store_str(s1, q, 97u8)    /* a */
    q = _store_str(s1, q, 114u8)   /* r */
    let len3 : u32 = q as u32

    let rc3 : i32 = hip_resolve(s1 as u64, len3, cands as u64, meta_u)
    if rc3 != 0i32 { return 16u64 }
    if _read_u32(meta, 4u64) != hip_class_no_match() { return 17u64 }
    if _read_u32(meta, 0u64) != 0u32 { return 18u64 }

    free(text)
    free(cands)
    free(meta)
    return 99u64
}
