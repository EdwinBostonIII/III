/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\212_hip_verb_coverage.iii
 *
 * III conformance corpus 212 -- Phase E: HIP verb coverage.
 *
 * Verifies HIP correctly classifies and projects intents for a wider
 * spread of verbs, including edge cases that should fail loudly:
 *
 *  Cases:
 *    A: "open the file"               -> AMBIGUOUS (FORM + ACT)   count=2
 *    B: "close socket"                -> UNIQUE (ACT)             count=1
 *    C: "free buffer"                 -> UNIQUE (ACT)             count=1
 *    D: "create channel"              -> UNIQUE (FORM)            count=1
 *    E: "sign message"                -> UNIQUE (FORM)            count=1
 *    F: "verify signature"            -> UNIQUE (FORM)            count=1
 *    G: "decrypt buffer with key"     -> AMBIGUOUS                count=2
 *    H: "destroy socket"              -> UNIQUE (ACT)             count=1
 *    I: ""                            -> NO_MATCH                 count=0
 *    J: "the the the"                 -> NO_MATCH                 count=0
 *    K: "buffer"                      -> NO_MATCH                 count=0   (DECLARATIVE without verb)
 *
 * Determinism: every case re-tested twice to confirm same outcome.
 *
 * Exit code: 99 on full pass; 100+N on the Nth case failure
 * (e.g., 110 = case J unexpected outcome).
 */

module corpus_212

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn hip_resolve(text_ptr: u64, text_len: u32, out_cands_ptr: u64, out_meta_ptr: u64) -> i32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_class_unique() -> u32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_class_ambiguous() -> u32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_class_no_match() -> u32 from "hip.iii"

fn _read_u32(buf: *u8, off: u64) -> u32 {
    let b0 : u32 = (buf[off] as u32) & 0xFFu32
    let b1 : u32 = ((buf[off + 1u64] as u32) & 0xFFu32) << 8u32
    let b2 : u32 = ((buf[off + 2u64] as u32) & 0xFFu32) << 16u32
    let b3 : u32 = ((buf[off + 3u64] as u32) & 0xFFu32) << 24u32
    return b0 | b1 | b2 | b3
}

fn _put(buf: *u8, off: u64, b: u8) -> u64 {
    buf[off] = b
    return off + 1u64
}

/* Write a bounded ASCII string (lowercase letters, spaces, digits) to
 * buf and return the new length. */
fn _put_word(buf: *u8, off: u64, c0: u8, c1: u8, c2: u8, c3: u8) -> u64 {
    let mut o : u64 = off
    o = _put(buf, o, c0)
    if c1 != 0u8 { o = _put(buf, o, c1) }
    if c2 != 0u8 { o = _put(buf, o, c2) }
    if c3 != 0u8 { o = _put(buf, o, c3) }
    return o
}

/* Run a single hip_resolve and check the (class, count) tuple.
 * 4-arg signature avoids the iiis-0 5+ param trap.
 *   packed_expect = (expect_count << 32) | expect_class
 */
fn _check(text: *u8, text_len: u32, meta: *u8, packed_expect: u64) -> u32 {
    let cands_local : *u8 = (&_CHECK_CANDS) as *u8
    let rc : i32 = hip_resolve(text as u64, text_len, cands_local as u64, meta as u64)
    if rc != 0i32 { return 1u32 }
    let cls : u32 = _read_u32(meta, 4u64)
    let cnt : u32 = _read_u32(meta, 0u64)
    let expect_cls : u32 = (packed_expect & 0xFFFFFFFFu64) as u32
    let expect_cnt : u32 = ((packed_expect >> 32u64) & 0xFFFFFFFFu64) as u32
    if cls != expect_cls { return 2u32 }
    if cnt != expect_cnt { return 3u32 }
    return 0u32
}

fn _check_pack(expect_class: u32, expect_count: u32) -> u64 {
    let c_l : u64 = (expect_class as u64) & 0xFFFFFFFFu64
    let n_l : u64 = ((expect_count as u64) & 0xFFFFFFFFu64) << 32u64
    return c_l | n_l
}

var _CHECK_CANDS : [u8; 64]   /* 8 candidate slots × 8 bytes each */

/* Encode a phrase by ASCII byte storage. Returns final length. */
fn _phrase_open_the_file(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 111u8)  /* o */
    o = _put(buf, o, 112u8)  /* p */
    o = _put(buf, o, 101u8)  /* e */
    o = _put(buf, o, 110u8)  /* n */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 116u8)  /* t */
    o = _put(buf, o, 104u8)  /* h */
    o = _put(buf, o, 101u8)  /* e */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 102u8)  /* f */
    o = _put(buf, o, 105u8)  /* i */
    o = _put(buf, o, 108u8)  /* l */
    o = _put(buf, o, 101u8)  /* e */
    return o as u32
}

fn _phrase_close_socket(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 99u8)
    o = _put(buf, o, 108u8)
    o = _put(buf, o, 111u8)
    o = _put(buf, o, 115u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 115u8)
    o = _put(buf, o, 111u8)
    o = _put(buf, o, 99u8)
    o = _put(buf, o, 107u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 116u8)
    return o as u32
}

fn _phrase_free_buffer(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 102u8)  /* f */
    o = _put(buf, o, 114u8)  /* r */
    o = _put(buf, o, 101u8)  /* e */
    o = _put(buf, o, 101u8)  /* e */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 98u8)
    o = _put(buf, o, 117u8)
    o = _put(buf, o, 102u8)
    o = _put(buf, o, 102u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 114u8)
    return o as u32
}

fn _phrase_create_channel(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 99u8)
    o = _put(buf, o, 114u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 97u8)
    o = _put(buf, o, 116u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 99u8)
    o = _put(buf, o, 104u8)
    o = _put(buf, o, 97u8)
    o = _put(buf, o, 110u8)
    o = _put(buf, o, 110u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 108u8)
    return o as u32
}

fn _phrase_sign_message(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 115u8)
    o = _put(buf, o, 105u8)
    o = _put(buf, o, 103u8)
    o = _put(buf, o, 110u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 109u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 115u8)
    o = _put(buf, o, 115u8)
    o = _put(buf, o, 97u8)
    o = _put(buf, o, 103u8)
    o = _put(buf, o, 101u8)
    return o as u32
}

fn _phrase_verify_signature(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 118u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 114u8)
    o = _put(buf, o, 105u8)
    o = _put(buf, o, 102u8)
    o = _put(buf, o, 121u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 115u8)
    o = _put(buf, o, 105u8)
    o = _put(buf, o, 103u8)
    o = _put(buf, o, 110u8)
    o = _put(buf, o, 97u8)
    o = _put(buf, o, 116u8)
    o = _put(buf, o, 117u8)
    o = _put(buf, o, 114u8)
    o = _put(buf, o, 101u8)
    return o as u32
}

fn _phrase_decrypt_buffer_with_key(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 100u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 99u8)
    o = _put(buf, o, 114u8)
    o = _put(buf, o, 121u8)
    o = _put(buf, o, 112u8)
    o = _put(buf, o, 116u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 98u8)
    o = _put(buf, o, 117u8)
    o = _put(buf, o, 102u8)
    o = _put(buf, o, 102u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 114u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 119u8)
    o = _put(buf, o, 105u8)
    o = _put(buf, o, 116u8)
    o = _put(buf, o, 104u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 107u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 121u8)
    return o as u32
}

fn _phrase_destroy_socket(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 100u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 115u8)
    o = _put(buf, o, 116u8)
    o = _put(buf, o, 114u8)
    o = _put(buf, o, 111u8)
    o = _put(buf, o, 121u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 115u8)
    o = _put(buf, o, 111u8)
    o = _put(buf, o, 99u8)
    o = _put(buf, o, 107u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 116u8)
    return o as u32
}

fn _phrase_the_the_the(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 116u8)
    o = _put(buf, o, 104u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 116u8)
    o = _put(buf, o, 104u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 116u8)
    o = _put(buf, o, 104u8)
    o = _put(buf, o, 101u8)
    return o as u32
}

fn _phrase_buffer_only(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 98u8)
    o = _put(buf, o, 117u8)
    o = _put(buf, o, 102u8)
    o = _put(buf, o, 102u8)
    o = _put(buf, o, 101u8)
    o = _put(buf, o, 114u8)
    return o as u32
}

fn main() -> u64 {
    let text  : *u8 = malloc(256u64)
    let cands : *u8 = malloc(64u64)
    let meta  : *u8 = malloc(16u64)
    if text  as u64 == 0u64 { return 1u64 }
    if cands as u64 == 0u64 { return 2u64 }
    if meta  as u64 == 0u64 { return 3u64 }

    let unique : u32 = hip_class_unique()
    let ambig  : u32 = hip_class_ambiguous()
    let nomatch: u32 = hip_class_no_match()

    /* === Case A: "open the file" -> AMBIGUOUS (FORM + ACT) === */
    let len_a : u32 = _phrase_open_the_file(text)
    let rcA : i32 = hip_resolve(text as u64, len_a, cands as u64, meta as u64)
    if rcA != 0i32 { return 200u64 }
    let clsA : u32 = _read_u32(meta, 4u64)
    let cntA : u32 = _read_u32(meta, 0u64)
    /* Diagnostic: encode (class, count) into exit so we can see it. */
    if clsA != ambig {
        if clsA == hip_class_unique() { return 201u64 }
        if clsA == hip_class_no_match() { return 202u64 }
        return 203u64
    }
    if cntA != 2u32 {
        /* Encode count into exit. */
        if cntA == 0u32 { return 220u64 }
        if cntA == 1u32 { return 221u64 }
        if cntA == 3u32 { return 223u64 }
        if cntA > 50u32 { return 250u64 }
        return (224u64 + (cntA as u64)) as u64
    }

    /* === Case B: "close socket" -> UNIQUE (ACT) === */
    let len_b : u32 = _phrase_close_socket(text)
    let rcB : i32 = hip_resolve(text as u64, len_b, cands as u64, meta as u64)
    if rcB != 0i32 { return 230u64 }
    let clsB : u32 = _read_u32(meta, 4u64)
    let cntB : u32 = _read_u32(meta, 0u64)
    if clsB != unique {
        if clsB == ambig { return 231u64 }
        if clsB == nomatch { return 232u64 }
        return 233u64
    }
    if cntB != 1u32 {
        if cntB == 0u32 { return 240u64 }
        if cntB == 2u32 { return 242u64 }
        return 244u64
    }

    /* === Case C: "free buffer" -> UNIQUE (ACT) === */
    let len_c : u32 = _phrase_free_buffer(text)
    if _check(text, len_c, meta, _check_pack(unique, 1u32)) != 0u32 { return 103u64 }

    /* === Case D: "create channel" -> UNIQUE (FORM) === */
    let len_d : u32 = _phrase_create_channel(text)
    if _check(text, len_d, meta, _check_pack(unique, 1u32)) != 0u32 { return 104u64 }

    /* === Case E: "sign message" -> UNIQUE (FORM) === */
    let len_e : u32 = _phrase_sign_message(text)
    if _check(text, len_e, meta, _check_pack(unique, 1u32)) != 0u32 { return 105u64 }

    /* === Case F: "verify signature" -> UNIQUE (FORM) === */
    let len_f : u32 = _phrase_verify_signature(text)
    if _check(text, len_f, meta, _check_pack(unique, 1u32)) != 0u32 { return 106u64 }

    /* === Case G: "decrypt buffer with key" -> AMBIGUOUS === */
    let len_g : u32 = _phrase_decrypt_buffer_with_key(text)
    if _check(text, len_g, meta, _check_pack(ambig, 2u32)) != 0u32 { return 107u64 }

    /* === Case H: "destroy socket" -> UNIQUE (ACT) === */
    let len_h : u32 = _phrase_destroy_socket(text)
    if _check(text, len_h, meta, _check_pack(unique, 1u32)) != 0u32 { return 108u64 }

    /* === Case I: empty -> NO_MATCH === */
    /* hip_resolve treats text_len=0 as empty; nl_parse returns NL_PARSE_E_EMPTY. */
    if _check(text, 0u32, meta, _check_pack(nomatch, 0u32)) != 0u32 { return 109u64 }

    /* === Case J: "the the the" (only DETs, no VERB) -> NO_MATCH === */
    let len_j : u32 = _phrase_the_the_the(text)
    if _check(text, len_j, meta, _check_pack(nomatch, 0u32)) != 0u32 { return 110u64 }

    /* === Case K: "buffer" (declarative without VERB) -> NO_MATCH === */
    let len_k : u32 = _phrase_buffer_only(text)
    if _check(text, len_k, meta, _check_pack(nomatch, 0u32)) != 0u32 { return 111u64 }

    free(text)
    free(cands)
    free(meta)
    return 99u64
}
