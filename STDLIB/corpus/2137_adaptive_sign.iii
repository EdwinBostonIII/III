/* 2137_adaptive_sign.iii -- GATE for sqrtsum_adaptive_sign (Tier 2.5: linear-independence + adaptive precision).
 *
 * THE ATTACK ON THE EXPONENTIAL SEPARATION BOUND, gated.  sqrtsum_adaptive_sign decides sign(Σ a_i √b_i) by
 * canonicalizing to distinct squarefree radicands (ℚ-linearly independent ⇒ zero iff coeffs cancel, FREE) and then
 * doubling interval precision only to the instance's true need p~log(1/|E|) -- never the a-priori M^(2ⁿ⁻¹).
 *
 * This KAT proves, per case:  (1) SOUND -- identical answer to the exact separation-bound oracle ui_sqrt_sum_sign,
 * on exact zeros, positives, negatives, and near-degenerate inputs;  (2) BYPASS -- the precision actually used is far
 * below the separation-bound precision the oracle must pay;  (3) DISCRIMINATOR -- on a continued-fraction convergent
 * of √2 the SHIPPED sqrtsum_lazy3 escalates to its exponential Tier-3, while adaptive resolves it and agrees.
 *   exit 99 = all sound AND every nonzero multi-surd case bypassed the bound AND the discriminator held.
 *   10 a case DISAGREED with the exact oracle (soundness broken)         31 discriminator: adaptive != oracle
 *   20 a nonzero multi-surd case did NOT beat the separation bound       32 discriminator: shipped lazy3 != oracle
 *   30 a nonzero multi-surd case resolved via the fallback, not adaptive 33 discriminator: lazy3 did NOT escalate */
module corpus_2137_adaptive_sign

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn sqrtsum_adaptive_sign(a_ptr: u64, b_ptr: u64, n: u64) -> i32 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn sqrtsum_last_p() -> u64 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn ui_sqrt_sum_sign(a_ptr: u64, b_ptr: u64, n: u64) -> i32 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn sqrtsum_lazy3(a_ptr: u64, b_ptr: u64, n: u64) -> i32 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn lazy_reset_counts() -> i32 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn lazy_exact_count() -> u64 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(arena: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_add(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mul(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_shl_bits(arena: u64, a: u64, bits: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_len_limbs(id: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_get_limb(id: u64, i: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_isqrt(ar: u64, N: u64) -> u64 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn bigint_drop(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop_arena(arena: u64) -> i32 from "bigint.iii"

fn k_emit(v: u64) -> i32 { if v >= 10u64 { k_emit(v / 10u64) }   putchar(((v % 10u64) + 48u64) as i32)   return 0i32 }
fn k_sp() -> i32 { putchar(32i32)   return 0i32 }
fn k_nl() -> i32 { putchar(10i32)   return 0i32 }
fn k_sgn(s: i32) -> i32 { if s > 0i32 { putchar(43i32) }   if s < 0i32 { putchar(45i32) }   if s == 0i32 { putchar(48i32) }   return 0i32 }
fn k_iabs(x: i64) -> u64 { if x < 0i64 { return (0i64 - x) as u64 }   return x as u64 }

fn k_bitlen(N: u64) -> u64 {
    let len : u64 = bigint_len_limbs(N)
    let mut i : u64 = len
    while i > 0u64 {
        let limb : u64 = bigint_get_limb(N, i - 1u64)
        if limb != 0u64 {
            let mut bl : u64 = 0u64   let mut t : u64 = limb
            while t > 0u64 { t = t >> 1u64   bl = bl + 1u64 }
            return ((i - 1u64) * 64u64) + bl
        }
        i = i - 1u64
    }
    return 0u64
}

/* the separation-bound precision the exact oracle must pay: bitlen(2*A*M^(2ⁿ-1)). */
fn k_sep_bits(a_ptr: u64, b_ptr: u64, n: u64) -> u64 {
    let pa : *i64 = a_ptr as *i64   let pb : *i64 = b_ptr as *i64
    let ar : u64 = arena_new(4194304u64)
    let one : u64 = bigint_from_u64(ar, 1u64)
    let mut A : u64 = bigint_from_u64(ar, 0u64)   let mut M : u64 = bigint_from_u64(ar, 0u64)
    let mut i : u64 = 0u64
    while i < n {
        let aa : u64 = k_iabs(pa[i])
        if aa != 0u64 {
            let ab : u64 = bigint_from_u64(ar, aa)
            let nA : u64 = bigint_add(ar, A, ab)   bigint_drop(A)   A = nA
            let bb : u64 = bigint_from_u64(ar, pb[i] as u64)
            let si : u64 = bigint_isqrt(ar, bb)   bigint_drop(bb)
            let si1 : u64 = bigint_add(ar, si, one)   bigint_drop(si)
            let tm : u64 = bigint_mul(ar, ab, si1)   bigint_drop(ab)   bigint_drop(si1)
            let nM : u64 = bigint_add(ar, M, tm)   bigint_drop(M)   bigint_drop(tm)   M = nM
        }
        i = i + 1u64
    }
    let e : u64 = (1u64 << n) - 1u64
    let mut T : u64 = bigint_from_u64(ar, 1u64)   let mut j : u64 = 0u64
    while j < e { let nT : u64 = bigint_mul(ar, T, M)   bigint_drop(T)   T = nT   j = j + 1u64 }
    let AT : u64 = bigint_mul(ar, A, T)
    let two_at : u64 = bigint_add(ar, AT, AT)
    let bits : u64 = k_bitlen(two_at) + 1u64
    bigint_drop(AT)   bigint_drop(two_at)   bigint_drop(T)   bigint_drop(M)   bigint_drop(A)   bigint_drop(one)
    bigint_drop_arena(ar)   arena_drop(ar)
    return bits
}

var AV : [i64; 8]   var BV : [i64; 8]
var FAILC : u64   var NOBYP : u64   var FELL : u64

/* run one case: adaptive vs oracle; print  n p_used p_sep sgnAdaptive sgnOracle ; tally soundness + bypass. */
fn krun(n: u64) -> i32 {
    let sa : i32 = sqrtsum_adaptive_sign((&AV) as u64, (&BV) as u64, n)
    let pu : u64 = sqrtsum_last_p()
    let so : i32 = ui_sqrt_sum_sign((&AV) as u64, (&BV) as u64, n)
    let ps : u64 = k_sep_bits((&AV) as u64, (&BV) as u64, n)
    k_emit(n) k_sp() k_emit(pu) k_sp() k_emit(ps) k_sp() k_sgn(sa) k_sp() k_sgn(so) k_nl()
    if sa != so { FAILC = FAILC + 1u64 }
    if pu > 0u64 {
        if pu >= ps { NOBYP = NOBYP + 1u64 }
        if pu > 100000u64 { FELL = FELL + 1u64 }
    }
    return 0i32
}

fn main() -> u64 {
    FAILC = 0u64   NOBYP = 0u64   FELL = 0u64

    /* A: n=6 generic non-degenerate (six independent primes, mixed signs). */
    AV[0u64]=7i64 BV[0u64]=2i64   AV[1u64]=0i64-5i64 BV[1u64]=3i64   AV[2u64]=11i64 BV[2u64]=5i64
    AV[3u64]=0i64-9i64 BV[3u64]=7i64   AV[4u64]=13i64 BV[4u64]=11i64   AV[5u64]=0i64-8i64 BV[5u64]=13i64
    krun(6u64)

    /* B: n=6 with embedded cancellations (+√5-√5, +3√7-3√7) and a near-degenerate pair. */
    AV[0u64]=2i64 BV[0u64]=1000000i64   AV[1u64]=0i64-1i64 BV[1u64]=3999999i64   AV[2u64]=1i64 BV[2u64]=5i64
    AV[3u64]=0i64-1i64 BV[3u64]=5i64   AV[4u64]=3i64 BV[4u64]=7i64   AV[5u64]=0i64-3i64 BV[5u64]=7i64
    krun(6u64)

    /* C: EXACT zero that float cancels: 2√2 - √8 + √18 - 3√2 = 0. */
    AV[0u64]=2i64 BV[0u64]=2i64   AV[1u64]=0i64-1i64 BV[1u64]=8i64   AV[2u64]=1i64 BV[2u64]=18i64   AV[3u64]=0i64-3i64 BV[3u64]=2i64
    krun(4u64)

    /* D: negative, distinct squarefree {6,10,15}: 5√6 + 3√10 - 7√15 < 0. */
    AV[0u64]=5i64 BV[0u64]=6i64   AV[1u64]=3i64 BV[1u64]=10i64   AV[2u64]=0i64-7i64 BV[2u64]=15i64
    krun(3u64)

    /* E: n=6 large-radicand near cancellation. */
    AV[0u64]=1000i64 BV[0u64]=1000003i64   AV[1u64]=0i64-1000i64 BV[1u64]=1000000i64   AV[2u64]=1i64 BV[2u64]=2i64
    AV[3u64]=1i64 BV[3u64]=3i64   AV[4u64]=1i64 BV[4u64]=5i64   AV[5u64]=0i64-1i64 BV[5u64]=7i64
    krun(6u64)

    if FAILC != 0u64 { return 10u64 }
    if NOBYP != 0u64 { return 20u64 }
    if FELL  != 0u64 { return 30u64 }

    /* F: THE DISCRIMINATOR -- 665857 - 470832√2 ~ +1.6e-6 (a CF convergent of √2).  The shipped sqrtsum_lazy3
     * straddles at fixed precision and abstains on 2 distinct surds => escalates to the exponential Tier-3.
     * adaptive resolves it and agrees.  Prove: adaptive==oracle, lazy3==oracle, AND lazy3 actually escalated. */
    AV[0u64]=665857i64 BV[0u64]=1i64   AV[1u64]=0i64-470832i64 BV[1u64]=2i64
    let fad : i32 = sqrtsum_adaptive_sign((&AV) as u64, (&BV) as u64, 2u64)
    let for_ : i32 = ui_sqrt_sum_sign((&AV) as u64, (&BV) as u64, 2u64)
    lazy_reset_counts()
    let flz : i32 = sqrtsum_lazy3((&AV) as u64, (&BV) as u64, 2u64)
    let ec : u64 = lazy_exact_count()
    putchar(70i32) putchar(58i32) k_sp() k_emit(ec) k_sp() k_emit(sqrtsum_last_p()) k_sp() k_sgn(fad) k_sp() k_sgn(flz) k_sp() k_sgn(for_) k_nl()
    if fad != for_ { return 31u64 }
    if flz != for_ { return 32u64 }
    if ec == 0u64 { return 33u64 }

    return 99u64
}
