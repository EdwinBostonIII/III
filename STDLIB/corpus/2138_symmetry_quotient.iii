/* 2138_symmetry_quotient.iii -- THE SYMMETRY QUOTIENT, generalized past 2276 to real Euclidean geometry + the shipped
 * adaptive sign engine.  A stream of triangle-perimeter comparisons sign(perim(A) - perim(B)) -- each a 6-term Σ√ over
 * integer squared side lengths -- is decided in the QUOTIENT: the SIMILARITY group (integer scaling), VERTEX RELABELING,
 * and comparison-direction SWAP produce many different-looking queries that share ONE sign-abstracted SHAPE.  Pay the
 * exact sign (sqrtsum_adaptive_sign, the PosSLP-family wall op) ONCE per distinct shape; reconstruct every instance from
 * the representative sign times its cheap orientation bit -- never a second wall touch.  This is 2276 (reflect = the
 * orientation bit; shape = the analogy address) made GENERAL-n, REAL-geometry, and wired to the real engine.  It is the
 * honest answer to "the 50-joint arm": exploit the repeated/scaled structure real problems have -- it does NOT beat
 * PosSLP in general, it collapses the instances that are the same predicate wearing different labels.
 *
 * Soundness is judged by the INDEPENDENT separation-bound oracle ui_sqrt_sum_sign (a different code path than the
 * adaptive representative), so the quotient + adaptive tier are BOTH validated here.
 *
 * exit 99 = quotient is SOUND and DEFERS the wall.
 *  10 SOUNDNESS: a query's reconstructed sign (o * representative) != its independent exact sign
 *  20 wall touches != number of distinct shapes                       23 no o=+1 orientation occurred
 *  21 distinct-shape count != expected (construction sanity)          24 no o=-1 orientation occurred (swap not exercised)
 *  22 no saving (wall touches >= number of queries) */
module corpus_2138_symmetry_quotient

extern @abi(c-msvc-x64) fn sqrtsum_adaptive_sign(a_ptr: u64, b_ptr: u64, n: u64) -> i32 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn ui_sqrt_sum_sign(a_ptr: u64, b_ptr: u64, n: u64) -> i32 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

fn e_u64(v: u64) -> i32 { if v >= 10u64 { e_u64(v / 10u64) }   putchar(((v % 10u64) + 48u64) as i32)   return 0i32 }
fn e_sp() -> i32 { putchar(32i32)   return 0i32 }
fn e_nl() -> i32 { putchar(10i32)   return 0i32 }

fn sq_iabs(x: i64) -> i64 { if x < 0i64 { return 0i64 - x }   return x }
fn sq_gcd(a: i64, b: i64) -> i64 { let mut x : i64 = sq_iabs(a)   let mut y : i64 = sq_iabs(b)   while y != 0i64 { let t : i64 = x % y   x = y   y = t }   return x }

var SQ_SFS : i64   var SQ_SFD : i64
fn sq_sqfree(n: i64) -> i32 {
    let mut d : i64 = n   let mut s : i64 = 1i64   let mut k : i64 = 2i64
    while k * k <= d {
        let kk : i64 = k * k   let q : i64 = d / kk
        if d - q * kk == 0i64 { d = q   s = s * k } else { k = k + 1i64 }
    }
    SQ_SFS = s   SQ_SFD = d   return 0i32
}

/* the current normalized shape (radicand, primitive+leading-positive coeff) and its term count. */
var TD : [i64; 16]   var TC : [i64; 16]   var TN : u64

/* canonicalize a query (coeffs, rads, n): squarefree-collect -> distinct-d sort -> divide by coeff gcd (quotients out
 * every POSITIVE scale, incl geometric similarity) -> flip so the largest-radicand coeff is positive (quotients out
 * global negation).  Fills TD/TC/TN with the shape; returns the orientation bit o (+1 kept / -1 flipped). */
fn canonize(cptr: u64, rptr: u64, n: u64) -> i32 {
    let pc : *i64 = cptr as *i64   let pr : *i64 = rptr as *i64
    let mut m : u64 = 0u64   let mut i : u64 = 0u64
    while i < n {
        let ci : i64 = pc[i]   let ri : i64 = pr[i]
        if ci != 0i64 { if ri != 0i64 {
            sq_sqfree(ri)
            let d : i64 = SQ_SFD   let coeff : i64 = ci * SQ_SFS
            let mut hit : u8 = 0u8   let mut fj : u64 = 0u64   let mut j : u64 = 0u64
            while j < m { if TD[j] == d { fj = j   hit = 1u8 }   j = j + 1u64 }
            if hit == 1u8 { TC[fj] = TC[fj] + coeff } else { TD[m] = d   TC[m] = coeff   m = m + 1u64 }
        } }
        i = i + 1u64
    }
    /* drop zeroed coefficients */
    let mut w : u64 = 0u64   let mut r : u64 = 0u64
    while r < m { let cr : i64 = TC[r]   if cr != 0i64 { TD[w] = TD[r]   TC[w] = cr   w = w + 1u64 }   r = r + 1u64 }
    m = w   TN = m
    if m == 0u64 { return 1i32 }
    /* insertion-sort by radicand ascending (hoist array elems before ordering compares -- iii trap) */
    let mut p : u64 = 1u64
    while p < m {
        let dv : i64 = TD[p]   let cv : i64 = TC[p]
        let mut q : u64 = p   let mut go : u8 = 1u8
        while go == 1u8 {
            if q == 0u64 { go = 0u8 }
            if go == 1u8 { let tq : i64 = TD[q - 1u64]   if tq <= dv { go = 0u8 } }
            if go == 1u8 { TD[q] = TD[q - 1u64]   TC[q] = TC[q - 1u64]   q = q - 1u64 }
        }
        TD[q] = dv   TC[q] = cv
        p = p + 1u64
    }
    /* divide out the positive content (gcd of coefficients) -- quotients out scale/similarity */
    let mut g : i64 = 0i64   let mut k : u64 = 0u64
    while k < m { g = sq_gcd(g, TC[k])   k = k + 1u64 }
    if g <= 0i64 { g = 1i64 }
    k = 0u64   while k < m { TC[k] = TC[k] / g   k = k + 1u64 }
    /* normalize global sign: make the largest-radicand coefficient positive */
    let lead : i64 = TC[m - 1u64]
    let mut o : i32 = 1i32
    if lead < 0i64 {
        o = 0i32 - 1i32
        k = 0u64   while k < m { TC[k] = 0i64 - TC[k]   k = k + 1u64 }
    }
    return o
}

/* the shape cache: up to 32 shapes x 8 terms.  representative sign per shape; WALL = distinct wall touches. */
var SH_D : [i64; 256]   var SH_C : [i64; 256]   var SH_N : [i64; 32]   var SH_SGN : [i32; 32]
var NSH : u64   var WALL : u64

/* look up the current shape (TD/TC/TN); return its representative sign R.  On a MISS, touch the wall ONCE:
 * R = sqrtsum_adaptive_sign(normalized form), cache it, WALL++. */
fn shape_lookup() -> i32 {
    let mut s : u64 = 0u64
    while s < NSH {
        let sn : i64 = SH_N[s]
        if (sn as u64) == TN {
            let base : u64 = s * 8u64
            let mut eq : u8 = 1u8   let mut j : u64 = 0u64
            while j < TN {
                if SH_D[base + j] != TD[j] { eq = 0u8 }
                if SH_C[base + j] != TC[j] { eq = 0u8 }
                j = j + 1u64
            }
            if eq == 1u8 { return SH_SGN[s] }
        }
        s = s + 1u64
    }
    let R : i32 = sqrtsum_adaptive_sign((&TC) as u64, (&TD) as u64, TN)   /* THE WALL TOUCH */
    let base : u64 = NSH * 8u64
    let mut j : u64 = 0u64
    while j < TN { SH_D[base + j] = TD[j]   SH_C[base + j] = TC[j]   j = j + 1u64 }
    SH_N[NSH] = TN as i64   SH_SGN[NSH] = R
    NSH = NSH + 1u64   WALL = WALL + 1u64
    return R
}

/* ── geometry ── */
fn sqd(x1: i64, y1: i64, x2: i64, y2: i64) -> i64 { let dx : i64 = x2 - x1   let dy : i64 = y2 - y1   return dx * dx + dy * dy }

var QC : [i64; 16]   var QR : [i64; 16]

/* build the perimeter-comparison query for triangles A(a*) and B(b*) (already scaled).  relabel cyclically shifts A's
 * side order (same multiset, different appearance); swap compares B-vs-A (negates the whole query). n=6. */
fn build_query(ax0: i64, ay0: i64, ax1: i64, ay1: i64, ax2: i64, ay2: i64,
               bx0: i64, by0: i64, bx1: i64, by1: i64, bx2: i64, by2: i64,
               relabel: u64, swap: u64) -> u64 {
    let sa0 : i64 = sqd(ax0, ay0, ax1, ay1)
    let sa1 : i64 = sqd(ax1, ay1, ax2, ay2)
    let sa2 : i64 = sqd(ax2, ay2, ax0, ay0)
    let sb0 : i64 = sqd(bx0, by0, bx1, by1)
    let sb1 : i64 = sqd(bx1, by1, bx2, by2)
    let sb2 : i64 = sqd(bx2, by2, bx0, by0)
    if relabel == 0u64 { QR[0u64] = sa0   QR[1u64] = sa1   QR[2u64] = sa2 }
    if relabel == 1u64 { QR[0u64] = sa1   QR[1u64] = sa2   QR[2u64] = sa0 }
    if relabel == 2u64 { QR[0u64] = sa2   QR[1u64] = sa0   QR[2u64] = sa1 }
    QR[3u64] = sb0   QR[4u64] = sb1   QR[5u64] = sb2
    let mut sgn : i64 = 1i64
    if swap == 1u64 { sgn = 0i64 - 1i64 }
    QC[0u64] = sgn   QC[1u64] = sgn   QC[2u64] = sgn
    QC[3u64] = 0i64 - sgn   QC[4u64] = 0i64 - sgn   QC[5u64] = 0i64 - sgn
    return 6u64
}

var BASE : [i64; 36]
var FAILC : u64   var NQ : u64   var ORP : u64   var ORN : u64

fn process(n: u64) -> i32 {
    let o : i32 = canonize((&QC) as u64, (&QR) as u64, n)
    let R : i32 = shape_lookup()
    let recon : i32 = o * R
    let brute : i32 = ui_sqrt_sum_sign((&QC) as u64, (&QR) as u64, n)   /* INDEPENDENT separation-bound oracle */
    if recon != brute { FAILC = FAILC + 1u64 }
    if o > 0i32 { ORP = ORP + 1u64 } else { ORN = ORN + 1u64 }
    NQ = NQ + 1u64
    return 0i32
}

fn run_base(b: u64) -> i32 {
    let off : u64 = b * 12u64
    let mut sc : i64 = 1i64
    while sc <= 3i64 {
        let mut rl : u64 = 0u64
        while rl < 2u64 {
            let mut sw : u64 = 0u64
            while sw < 2u64 {
                build_query(BASE[off + 0u64] * sc, BASE[off + 1u64] * sc, BASE[off + 2u64] * sc, BASE[off + 3u64] * sc,
                            BASE[off + 4u64] * sc, BASE[off + 5u64] * sc, BASE[off + 6u64] * sc, BASE[off + 7u64] * sc,
                            BASE[off + 8u64] * sc, BASE[off + 9u64] * sc, BASE[off + 10u64] * sc, BASE[off + 11u64] * sc,
                            rl, sw)
                process(6u64)
                sw = sw + 1u64
            }
            rl = rl + 1u64
        }
        sc = sc + 1i64
    }
    return 0i32
}

fn main() -> u64 {
    NSH = 0u64   WALL = 0u64   FAILC = 0u64   NQ = 0u64   ORP = 0u64   ORN = 0u64

    /* base 1: A=(0,0),(3,1),(1,3) sides²{10,8,10} ; B=(0,0),(2,0),(1,2) sides²{4,5,5} */
    BASE[0u64]=0i64  BASE[1u64]=0i64  BASE[2u64]=3i64  BASE[3u64]=1i64  BASE[4u64]=1i64  BASE[5u64]=3i64
    BASE[6u64]=0i64  BASE[7u64]=0i64  BASE[8u64]=2i64  BASE[9u64]=0i64  BASE[10u64]=1i64 BASE[11u64]=2i64
    /* base 2: A=(0,0),(5,1),(2,4) ; B=(0,0),(1,1),(4,0) */
    BASE[12u64]=0i64 BASE[13u64]=0i64 BASE[14u64]=5i64 BASE[15u64]=1i64 BASE[16u64]=2i64 BASE[17u64]=4i64
    BASE[18u64]=0i64 BASE[19u64]=0i64 BASE[20u64]=1i64 BASE[21u64]=1i64 BASE[22u64]=4i64 BASE[23u64]=0i64
    /* base 3: A=(0,0),(4,2),(1,5) ; B=(0,0),(3,1),(2,3) */
    BASE[24u64]=0i64 BASE[25u64]=0i64 BASE[26u64]=4i64 BASE[27u64]=2i64 BASE[28u64]=1i64 BASE[29u64]=5i64
    BASE[30u64]=0i64 BASE[31u64]=0i64 BASE[32u64]=3i64 BASE[33u64]=1i64 BASE[34u64]=2i64 BASE[35u64]=3i64

    run_base(0u64)
    run_base(1u64)
    run_base(2u64)

    /* two CONTROL queries with genuinely distinct shapes (must NOT collapse into the base orbits). */
    build_query(0i64,0i64, 7i64,0i64, 0i64,1i64,  0i64,0i64, 1i64,1i64, 2i64,2i64, 0u64, 0u64)   /* control 1 */
    process(6u64)
    build_query(0i64,0i64, 1i64,6i64, 5i64,5i64,  0i64,0i64, 2i64,1i64, 1i64,4i64, 0u64, 0u64)   /* control 2 */
    process(6u64)

    /* evidence:  queries  wall_touches  distinct_shapes */
    e_u64(NQ) e_sp() e_u64(WALL) e_sp() e_u64(NSH) e_nl()

    if FAILC != 0u64 { return 10u64 }
    if WALL != NSH { return 20u64 }
    if NSH != 5u64 { return 21u64 }
    if WALL >= NQ { return 22u64 }
    if ORP == 0u64 { return 23u64 }
    if ORN == 0u64 { return 24u64 }
    return 99u64
}
