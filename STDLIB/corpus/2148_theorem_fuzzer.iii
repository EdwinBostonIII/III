/* 2148_theorem_fuzzer.iii -- PROOF OF CONCEPT: a generative coincidence-fuzzer over the REAL quotient tools (kfield +
 * coincidence.iii).  It constructs exact algebraic values in K = ℚ(√2,√3,√5) via DIFFERENT construction PATHS, content-
 * addresses each with kf_point_addr (the Eidolon), and feeds the addresses to the coincidence engine.  When two DIFFERENT
 * paths yield the SAME address, an EXACT identity is detected -- sound, because on K the canonical form is exact (equal
 * address <=> equal value, by linear independence of the surd basis; no separation bound, no false coincidence).
 *
 * HONEST FRAMING (per prior eidolon-novelty adjudication = NONE): this is a SOUND coincidence DETECTOR / theorem VERIFIER
 * and candidate finder -- NOT an autonomous novel-theorem prover.  A collision certifies a TRUE identity, but novelty
 * (trivial vs known vs new) is a separate, unautomated judgment.  What is PROVEN here: (a) SOUNDNESS -- every collision is
 * a real identity (independently re-verified by kf_sign(A−B)==0) and every non-collision is a real distinction, zero
 * false positives; (b) DISCOVERY -- enumerating products of the field surds and content-addressing them SURFACES an
 * unplanted 3-way identity (√30 = √2·√15 = √3·√10 = √5·√6) with no target named; (c) FLOAT-FOOL -- a fixed-precision
 * engine false-positives on a near-coincidence the exact fuzzer correctly REJECTS (the reason exact > float for discovery).
 *
 * exit 99 = the three identity pairs collide (a2/a3/a4 == "already seen"), the control does NOT, every collision is a true
 * identity (kf_sign(diff)==0) and the control is truly distinct (kf_sign != 0), the enumeration surfaces 16 classes / 5
 * collisions with one 3-way identity (all Galois-verified, engine seen-bit == independent classing), AND the float-fool holds (exact addresses
 * differ while fixed-point collides).
 *   10 an identity pair did NOT collide (detector missed a real identity)     20 the control FALSE-collided (unsound)
 *   30 a collision was NOT a true identity, or the control was not truly distinct (kf_sign disagrees with the address)
 *   40 the float-fool did not hold (exact addresses equal, or fixed-point did not collide)
 *   50/53 enumeration surfaced the wrong number of collisions/distinct-classes    51 no >=3-way identity was discovered
 *   52 a discovered-class member was NOT a true identity (unsound)    54 engine "seen" bit disagreed with our address classing */
module corpus_2148_theorem_fuzzer

extern @abi(c-msvc-x64) fn kf_radix(sa: i64, sb: i64, sc: i64) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_zero(p: u64) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_mul(out: u64, x: u64, y: u64) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_point_addr(nx: u64, ny: u64, den: u64, out32: *u8) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_sign(x: u64) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn coin_reset() -> i32 from "coincidence.iii"
extern @abi(c-msvc-x64) fn coin_observe_concrete(addr: *u8, faculty: u32, result: u64) -> u8 from "coincidence.iii"

var ZV : [i64; 8]   var OV : [i64; 8]
var A1 : [i64; 8]   var B1 : [i64; 8]   var A2 : [i64; 8]   var B2 : [i64; 8]   var A3 : [i64; 8]   var B3 : [i64; 8]
var CTL : [i64; 8]   var DIFF : [i64; 8]   var TMP : [i64; 8]
var SQ6 : [i64; 8]   var RAT : [i64; 8]   var D89 : [i64; 8]
var ADX : [u8; 32]   var ADY : [u8; 32]
var RV : [i64; 168]   var RA : [u8; 672]   var CLASS : [i64; 21]   var SEEN : [u8; 21]   var UX : [i64; 8]   var UY : [i64; 8]

fn v8(p: u64, c0: i64, c1: i64, c2: i64, c3: i64, c4: i64, c5: i64, c6: i64, c7: i64) -> i32 {
    let v : *i64 = p as *i64
    v[0u64]=c0 v[1u64]=c1 v[2u64]=c2 v[3u64]=c3 v[4u64]=c4 v[5u64]=c5 v[6u64]=c6 v[7u64]=c7
    return 0i32
}
fn subv(dp: u64, ap: u64, bp: u64) -> i32 { let d : *i64 = dp as *i64   let a : *i64 = ap as *i64   let b : *i64 = bp as *i64   let mut i : u64 = 0u64   while i < 8u64 { d[i] = a[i] - b[i]   i = i + 1u64 }   return 0i32 }
fn addr_scalar(vp: u64, out: *u8) -> i32 { kf_point_addr(vp, (&ZV) as u64, (&OV) as u64, out)   return 0i32 }
fn addr_eq(x: *u8, y: *u8) -> u32 { let mut i : u64 = 0u64   while i < 32u64 { if x[i] != y[i] { return 0u32 }   i = i + 1u64 }   return 1u32 }
fn unit(p: u64, idx: u64) -> i32 { let v : *i64 = p as *i64   let mut m : u64 = 0u64   while m < 8u64 { v[m] = 0i64   m = m + 1u64 }   v[idx] = 1i64   return 0i32 }

/* simple i64 floor-sqrt for the fixed-point float-fool contrast. */
fn isq(n: i64) -> i64 { if n <= 0i64 { return 0i64 }   let mut r : i64 = 0i64   let mut b : i64 = 1i64 << 30i64   while b > n { b = b >> 2i64 }   let mut x : i64 = n   while b != 0i64 { let rb : i64 = r + b   if x >= rb { x = x - rb   r = (r >> 1i64) + b } else { r = r >> 1i64 }   b = b >> 2i64 }   return r }

/* STAGE 2 -- GENUINE DISCOVERY BY ENUMERATION (nothing planted): enumerate all 21 products √dᵢ·√dⱼ
 * (1<=i<j<=7) of the field surds through the REAL kf_mul, content-address each, and let the coincidence
 * engine partition them into identity classes.  NO target is named -- the engine SURFACES the coincidences.
 * Proven: 16 distinct classes, 5 collisions, ONE class of size 3 (√30 = √2·√15 = √3·√10 = √5·√6), every
 * member re-proved identical by the Galois sign oracle, and the engine's "already seen" bit matches an
 * independent content-address classing on every one of the 21 products.  Returns 0 = all held, else 50..54. */
fn fuzz_enumerate() -> u64 {
    v8((&ZV) as u64, 0i64,0i64,0i64,0i64,0i64,0i64,0i64,0i64)    /* keep ZV/OV pristine for addr_scalar */
    v8((&OV) as u64, 1i64,0i64,0i64,0i64,0i64,0i64,0i64,0i64)
    coin_reset()
    let mut kk : u64 = 0u64
    let mut gi : u64 = 1u64
    while gi < 7u64 {
        let mut gj : u64 = gi + 1u64
        while gj < 8u64 {
            unit((&UX) as u64, gi)   unit((&UY) as u64, gj)
            let rp : u64 = ((&RV) as u64) + kk * 64u64
            kf_mul(rp, (&UX) as u64, (&UY) as u64)
            let ap : u64 = ((&RA) as u64) + kk * 32u64
            addr_scalar(rp, ap as *u8)
            SEEN[kk] = coin_observe_concrete(ap as *u8, 2u32, 0u64)
            kk = kk + 1u64
            gj = gj + 1u64
        }
        gi = gi + 1u64
    }
    let total : u64 = kk
    let mut ca : u64 = 0u64
    while ca < total {                                          /* CLASS[a] = earliest equal-address index (a if new) */
        let mut rep : u64 = ca
        let mut found : u8 = 0u8
        let mut cb : u64 = 0u64
        while cb < ca {
            if found == 0u8 {
                if addr_eq((((&RA) as u64) + cb * 32u64) as *u8, (((&RA) as u64) + ca * 32u64) as *u8) == 1u32 { rep = cb   found = 1u8 }
            }
            cb = cb + 1u64
        }
        CLASS[ca] = rep as i64
        ca = ca + 1u64
    }
    let mut distinct : u64 = 0u64   let mut collisions : u64 = 0u64
    ca = 0u64
    while ca < total {                                          /* counts + engine cross-check */
        let repv : u64 = CLASS[ca] as u64
        let mut mine_seen : u8 = 1u8
        if repv == ca { mine_seen = 0u8   distinct = distinct + 1u64 } else { collisions = collisions + 1u64 }
        if SEEN[ca] != mine_seen { return 54u64 }
        ca = ca + 1u64
    }
    if distinct != 16u64 { return 53u64 }
    if collisions != 5u64 { return 50u64 }
    let mut best : u64 = 0u64   let mut bestrep : u64 = 0u64
    ca = 0u64
    while ca < total {                                          /* the discovery: largest surfaced class */
        let repv : u64 = CLASS[ca] as u64
        if repv == ca {
            let mut cnt : u64 = 0u64   let mut cb : u64 = 0u64
            while cb < total { let rb : u64 = CLASS[cb] as u64   if rb == ca { cnt = cnt + 1u64 }   cb = cb + 1u64 }
            if cnt > best { best = cnt   bestrep = ca }
        }
        ca = ca + 1u64
    }
    if best < 3u64 { return 51u64 }
    ca = 0u64
    while ca < total {                                          /* SOUNDNESS: every class member is a TRUE identity */
        let repa : u64 = CLASS[ca] as u64
        if repa == bestrep {
            let mut cb : u64 = ca + 1u64
            while cb < total {
                let repb : u64 = CLASS[cb] as u64
                if repb == bestrep {
                    subv((&DIFF) as u64, ((&RV) as u64) + ca * 64u64, ((&RV) as u64) + cb * 64u64)
                    if kf_sign((&DIFF) as u64) != 0i32 { return 52u64 }
                }
                cb = cb + 1u64
            }
        }
        ca = ca + 1u64
    }
    return 0u64
}

fn main() -> u64 {
    kf_radix(2i64, 3i64, 5i64)                                   /* K = ℚ(√2,√3,√5); basis idx: 1=√2 2=√3 3=√6 4=√5 */
    v8((&ZV) as u64, 0i64,0i64,0i64,0i64,0i64,0i64,0i64,0i64)
    v8((&OV) as u64,  1i64,0i64,0i64,0i64,0i64,0i64,0i64,0i64)

    /* IDENTITY 1: (√2+√3)²  ==  5 + 2√6.   path A = kf_mul(√2+√3, √2+√3); path B = direct. */
    v8((&TMP) as u64, 0i64,1i64,1i64,0i64,0i64,0i64,0i64,0i64)   /* √2+√3 */
    kf_mul((&A1) as u64, (&TMP) as u64, (&TMP) as u64)
    v8((&B1) as u64, 5i64,0i64,0i64,2i64,0i64,0i64,0i64,0i64)    /* 5+2√6 */

    /* IDENTITY 2: √2·√3  ==  √6.   path A = kf_mul(√2, √3); path B = direct √6. */
    v8((&TMP) as u64, 0i64,1i64,0i64,0i64,0i64,0i64,0i64,0i64)   /* √2 */
    v8((&DIFF) as u64, 0i64,0i64,1i64,0i64,0i64,0i64,0i64,0i64)  /* √3 (DIFF used as scratch here) */
    kf_mul((&A2) as u64, (&TMP) as u64, (&DIFF) as u64)
    v8((&B2) as u64, 0i64,0i64,0i64,1i64,0i64,0i64,0i64,0i64)    /* √6 */

    /* IDENTITY 3: (1+√2)²  ==  3 + 2√2.   path A = kf_mul(1+√2, 1+√2); path B = direct. */
    v8((&TMP) as u64, 1i64,1i64,0i64,0i64,0i64,0i64,0i64,0i64)   /* 1+√2 */
    kf_mul((&A3) as u64, (&TMP) as u64, (&TMP) as u64)
    v8((&B3) as u64, 3i64,2i64,0i64,0i64,0i64,0i64,0i64,0i64)    /* 3+2√2 */

    /* CONTROL: √2+√5 -- must NOT collide with anything above. */
    v8((&CTL) as u64, 0i64,1i64,0i64,0i64,1i64,0i64,0i64,0i64)

    /* ===== DISCOVERY: feed all addresses to the coincidence engine; the 2nd of each pair must be "already seen". ===== */
    coin_reset()
    addr_scalar((&A1) as u64, (&ADX) as *u8)   let s1a : u8 = coin_observe_concrete((&ADX) as *u8, 1u32, 0u64)
    addr_scalar((&B1) as u64, (&ADX) as *u8)   let s1b : u8 = coin_observe_concrete((&ADX) as *u8, 1u32, 0u64)
    addr_scalar((&A2) as u64, (&ADX) as *u8)   let s2a : u8 = coin_observe_concrete((&ADX) as *u8, 1u32, 0u64)
    addr_scalar((&B2) as u64, (&ADX) as *u8)   let s2b : u8 = coin_observe_concrete((&ADX) as *u8, 1u32, 0u64)
    addr_scalar((&A3) as u64, (&ADX) as *u8)   let s3a : u8 = coin_observe_concrete((&ADX) as *u8, 1u32, 0u64)
    addr_scalar((&B3) as u64, (&ADX) as *u8)   let s3b : u8 = coin_observe_concrete((&ADX) as *u8, 1u32, 0u64)
    addr_scalar((&CTL) as u64, (&ADX) as *u8)  let sc  : u8 = coin_observe_concrete((&ADX) as *u8, 1u32, 0u64)

    /* each pair's 2nd element must be a COLLISION (1); the 1st elements + control must be NEW (0). */
    if s1b != 1u8 { return 10u64 }   if s2b != 1u8 { return 10u64 }   if s3b != 1u8 { return 10u64 }
    if s1a != 0u8 { return 10u64 }   if s2a != 0u8 { return 10u64 }   if s3a != 0u8 { return 10u64 }
    if sc != 0u8 { return 20u64 }                                /* control FALSE-collided -> unsound */

    /* ===== SOUNDNESS: independently verify each collision is a TRUE identity, and the control is truly distinct. ===== */
    subv((&DIFF) as u64, (&A1) as u64, (&B1) as u64)   if kf_sign((&DIFF) as u64) != 0i32 { return 30u64 }
    subv((&DIFF) as u64, (&A2) as u64, (&B2) as u64)   if kf_sign((&DIFF) as u64) != 0i32 { return 30u64 }
    subv((&DIFF) as u64, (&A3) as u64, (&B3) as u64)   if kf_sign((&DIFF) as u64) != 0i32 { return 30u64 }
    subv((&DIFF) as u64, (&CTL) as u64, (&B1) as u64)   if kf_sign((&DIFF) as u64) == 0i32 { return 30u64 }   /* control != 5+2√6 */

    /* ===== STAGE 2 -- genuine discovery by enumeration (nothing planted); returns 0 or an error code 50..54. ===== */
    let dc : u64 = fuzz_enumerate()   if dc != 0u64 { return dc }

    /* ===== FLOAT-FOOL: √6 vs 218/89 are DISTINCT (exact) but EQUAL at 3-decimal fixed point. ===== */
    v8((&SQ6) as u64, 0i64,0i64,0i64,1i64,0i64,0i64,0i64,0i64)   /* √6, den 1 */
    v8((&RAT) as u64, 218i64,0i64,0i64,0i64,0i64,0i64,0i64,0i64) /* 218 */
    v8((&D89) as u64, 89i64,0i64,0i64,0i64,0i64,0i64,0i64,0i64)  /* den 89 -> 218/89 */
    addr_scalar((&SQ6) as u64, (&ADX) as *u8)
    kf_point_addr((&RAT) as u64, (&ZV) as u64, (&D89) as u64, (&ADY) as *u8)
    if addr_eq((&ADX) as *u8, (&ADY) as *u8) != 0u32 { return 40u64 }   /* exact: addresses MUST differ (no false collision) */
    /* 89√6 − 218: kf_sign must be nonzero (truly distinct). */
    v8((&DIFF) as u64, 0i64-218i64,0i64,0i64,89i64,0i64,0i64,0i64,0i64)
    if kf_sign((&DIFF) as u64) == 0i32 { return 40u64 }
    /* fixed-point at ×1000: floor(√6·1000) == floor(218000/89) -> a FALSE collision a float fuzzer would make. */
    let fp_sq6 : i64 = isq(6000000i64)                          /* floor(√6 · 1000) */
    let fp_rat : i64 = 218000i64 / 89i64                        /* floor(218/89 · 1000) */
    if fp_sq6 != fp_rat { return 40u64 }                        /* the fixed-point engine MUST collide them */

    return 99u64
}
