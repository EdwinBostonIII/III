/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\214_hip_intent_validation.iii
 *
 * III conformance corpus 214 -- HIP output intent validation.
 *
 * Asserts that intent_ids emitted by hip_resolve are well-formed
 * calculus intents with goal_kind matching the verb's primitive
 * mapping:
 *
 *   send / put / store / write / load / get / read / copy / move
 *      -> C214_CONVEY (3)
 *   open                                 -> FORM (1) + ACT (5)   [ambiguous]
 *   create / allocate                    -> FORM (1)
 *   close / free / destroy / connect / listen -> ACT (5)
 *   sign / hash / verify / prove / query / parse / seal
 *      -> FORM (1)
 *   encrypt / decrypt                    -> CONVEY (3) + FORM (1) [ambiguous]
 *
 * Strategy: for each test phrase, resolve, then for each candidate
 * intent_id read its goal_kind via intent_goal_kind() and compare
 * against expected.
 *
 * Exit code: 99 on full pass; 100+caseN on case failure.
 */

module corpus_214

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn hip_resolve(text_ptr: u64, text_len: u32, out_cands_ptr: u64, out_meta_ptr: u64) -> i32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_class_unique() -> u32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_class_ambiguous() -> u32 from "hip.iii"

extern @abi(c-msvc-x64) fn intent_goal_kind(p: u64) -> u8 from "intent.iii"

const C214_FORM    : u8 = 1u8
const C214_CONVEY  : u8 = 3u8
const C214_ACT     : u8 = 5u8

fn _read_u32(buf: *u8, off: u64) -> u32 {
    let b0 : u32 = (buf[off] as u32) & 0xFFu32
    let b1 : u32 = ((buf[off + 1u64] as u32) & 0xFFu32) << 8u32
    let b2 : u32 = ((buf[off + 2u64] as u32) & 0xFFu32) << 16u32
    let b3 : u32 = ((buf[off + 3u64] as u32) & 0xFFu32) << 24u32
    return b0 | b1 | b2 | b3
}

fn _read_u64(buf: *u8, off: u64) -> u64 {
    let mut v : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 8u64 {
        v = v | (((buf[off + i] as u64) & 0xFFu64) << (i * 8u64))
        i = i + 1u64
    }
    return v
}

fn _put(buf: *u8, off: u64, b: u8) -> u64 {
    buf[off] = b
    return off + 1u64
}

/* "send" -> CONVEY single candidate. */
fn _phrase_send_buffer(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 115u8); o = _put(buf, o, 101u8); o = _put(buf, o, 110u8); o = _put(buf, o, 100u8)   /* send */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 98u8); o = _put(buf, o, 117u8); o = _put(buf, o, 102u8); o = _put(buf, o, 102u8); o = _put(buf, o, 101u8); o = _put(buf, o, 114u8)   /* buffer */
    return o as u32
}

/* "create channel" -> FORM single candidate. */
fn _phrase_create_channel(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 99u8); o = _put(buf, o, 114u8); o = _put(buf, o, 101u8); o = _put(buf, o, 97u8); o = _put(buf, o, 116u8); o = _put(buf, o, 101u8)   /* create */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 99u8); o = _put(buf, o, 104u8); o = _put(buf, o, 97u8); o = _put(buf, o, 110u8); o = _put(buf, o, 110u8); o = _put(buf, o, 101u8); o = _put(buf, o, 108u8)   /* channel */
    return o as u32
}

/* "free buffer" -> ACT single candidate. */
fn _phrase_free_buffer(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 102u8); o = _put(buf, o, 114u8); o = _put(buf, o, 101u8); o = _put(buf, o, 101u8)   /* free */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 98u8); o = _put(buf, o, 117u8); o = _put(buf, o, 102u8); o = _put(buf, o, 102u8); o = _put(buf, o, 101u8); o = _put(buf, o, 114u8)   /* buffer */
    return o as u32
}

/* "open the file" -> FORM + ACT (ambiguous). */
fn _phrase_open_the_file(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 111u8); o = _put(buf, o, 112u8); o = _put(buf, o, 101u8); o = _put(buf, o, 110u8)   /* open */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 116u8); o = _put(buf, o, 104u8); o = _put(buf, o, 101u8)   /* the */
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 102u8); o = _put(buf, o, 105u8); o = _put(buf, o, 108u8); o = _put(buf, o, 101u8)   /* file */
    return o as u32
}

fn main() -> u64 {
    let text  : *u8 = malloc(256u64)
    let cands : *u8 = malloc(64u64)
    let meta  : *u8 = malloc(16u64)
    if text  as u64 == 0u64 { return 1u64 }
    if cands as u64 == 0u64 { return 2u64 }
    if meta  as u64 == 0u64 { return 3u64 }
    let mut zi : u64 = 0u64
    while zi < 16u64 { meta[zi] = 0u8; zi = zi + 1u64 }

    /* === Case A: "send buffer" -> single CONVEY === */
    let len_a : u32 = _phrase_send_buffer(text)
    let rcA : i32 = hip_resolve(text as u64, len_a, cands as u64, meta as u64)
    if rcA != 0i32 { return 100u64 }
    let cntA : u32 = _read_u32(meta, 0u64)
    if cntA != 1u32 { return 101u64 }
    let id_a : u64 = _read_u64(cands, 0u64)
    if id_a == 0u64 { return 102u64 }
    if intent_goal_kind(id_a) != C214_CONVEY { return 103u64 }

    /* === Case B: "create channel" -> single FORM === */
    let len_b : u32 = _phrase_create_channel(text)
    let rcB : i32 = hip_resolve(text as u64, len_b, cands as u64, meta as u64)
    if rcB != 0i32 { return 110u64 }
    let cntB : u32 = _read_u32(meta, 0u64)
    if cntB != 1u32 { return 111u64 }
    let id_b : u64 = _read_u64(cands, 0u64)
    if id_b == 0u64 { return 112u64 }
    if intent_goal_kind(id_b) != C214_FORM { return 113u64 }

    /* === Case C: "free buffer" -> single ACT === */
    let len_c : u32 = _phrase_free_buffer(text)
    let rcC : i32 = hip_resolve(text as u64, len_c, cands as u64, meta as u64)
    if rcC != 0i32 { return 120u64 }
    let cntC : u32 = _read_u32(meta, 0u64)
    if cntC != 1u32 { return 121u64 }
    let id_c : u64 = _read_u64(cands, 0u64)
    if id_c == 0u64 { return 122u64 }
    if intent_goal_kind(id_c) != C214_ACT { return 123u64 }

    /* === Case D: "open the file" -> FORM + ACT (ambiguous) === */
    let len_d : u32 = _phrase_open_the_file(text)
    let rcD : i32 = hip_resolve(text as u64, len_d, cands as u64, meta as u64)
    if rcD != 0i32 { return 130u64 }
    let cntD : u32 = _read_u32(meta, 0u64)
    if cntD != 2u32 { return 131u64 }
    if _read_u32(meta, 4u64) != hip_class_ambiguous() { return 132u64 }
    let id_d0 : u64 = _read_u64(cands, 0u64)
    let id_d1 : u64 = _read_u64(cands, 8u64)
    if id_d0 == 0u64 { return 133u64 }
    if id_d1 == 0u64 { return 134u64 }
    /* First candidate: FORM. Second candidate: ACT. */
    if intent_goal_kind(id_d0) != C214_FORM { return 135u64 }
    if intent_goal_kind(id_d1) != C214_ACT  { return 136u64 }

    /* Determinism: re-resolve "send buffer" -> same intent_id (intent
     * pool is content-addressed, so identical inputs yield identical
     * intent_ids on a fresh resolver state). */
    let rcA2 : i32 = hip_resolve(text as u64, len_a, cands as u64, meta as u64)
    if rcA2 != 0i32 { return 140u64 }
    /* The text buffer was overwritten; re-write "send buffer". */
    let len_a2 : u32 = _phrase_send_buffer(text)
    let rcA3 : i32 = hip_resolve(text as u64, len_a2, cands as u64, meta as u64)
    if rcA3 != 0i32 { return 141u64 }
    let id_a3 : u64 = _read_u64(cands, 0u64)
    if intent_goal_kind(id_a3) != C214_CONVEY { return 142u64 }

    free(text)
    free(cands)
    free(meta)
    return 99u64
}
