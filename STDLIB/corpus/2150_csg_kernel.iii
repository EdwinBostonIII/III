/* 2150_csg_kernel.iii -- GATE for csg_kernel.iii: the exact "unshatterable" quadric-CSG predicate layer.
 *
 * Proves the CSG COMPOSITION of the two proven organs -- sqrtsum_lazy3 (Sum-sqrt sign) and denest_r1 (tower denest) --
 * with each arm driving a DIFFERENT rule (no tautology).  It also PRINTS the exact z=0 cross-section of a real
 * sphere-minus-cylinder solid: every cell classified by the integer-exact membership predicate (no float => no tear).
 *
 * ARMS:
 *   A  certified ON-SURFACE zero via LINEARLY-DEPENDENT surds (z-2y at (0,√2,√8) = 0) -> canon tier certifies it;
 *   A' same incidence with coefficients >= 2^20 -> EXACT bigint tier certifies the zero (Tier-3 coverage);
 *   B  near-tie SIGN 577-408√2 (Pell): a FIXED precision f=10 STRADDLES 0 (cannot decide -> the float tear), while
 *      sqrtsum_lazy3 adapts and returns the definite +1 (=sign(577^2 - 2*408^2) = sign(+1));  the float-breaks witness;
 *   C  strictly-outside boundary point (y+z at (0,√2,√3) = √2+√3 > 0) -> fast i64 interval tier, verdict +1;
 *   D  sphere-cylinder tangency by INTEGER comparison |a|=R±r (denest NOT needed) -- transverse/tangent/disjoint/nested,
 *      with the two TANGENT codes flagging genuine (non-float) non-manifold pinches;
 *   E  triple-point CORNER coordinate sqrt(p+q√Δ) from S∩C∩plane -> denest_r1 COLLAPSE (exact coord 4+√19) vs EXTENSION;
 *   F  out-of-envelope corner -> honest ABSTAIN (2), never a silent wrong answer.
 *   TIER-COVERAGE guard: across A/A'/B/C the fast, canon AND exact counters must all be nonzero (anti-tautology proof
 *   that inputs really traversed the exact machinery, not an i64 short-circuit).
 *
 *   exit 99 = every arm correct.  10 incidence  20 near-tie/straddle  30 tangency  40 corner-denest  50 abstain  60 tiers */
module corpus_2150_csg_kernel

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

extern @abi(c-msvc-x64) fn csg_quadric_eval_sign(qa: i64, qb: i64, qc: i64, qd: i64, qe: i64, qf: i64, qg: i64, qh: i64, qi: i64, qj: i64, x: i64, y: i64, z: i64) -> i32 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_inside(qa: i64, qb: i64, qc: i64, qd: i64, qe: i64, qf: i64, qg: i64, qh: i64, qi: i64, qj: i64, x: i64, y: i64, z: i64) -> i32 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_surf_point_side(qa: i64, qb: i64, qc: i64, qd: i64, qe: i64, qf: i64, qg: i64, qh: i64, qi: i64, qj: i64, x0: i64, beta: i64, gamma: i64, sy: i64, sz: i64) -> i32 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_sphere_cyl_class(R: i64, a: i64, r: i64) -> i32 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_sc_plane_corner(R2: i64, a: i64, r2: i64) -> i32 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_corner_p() -> i64 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_corner_q() -> i64 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_corner_delta() -> i64 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_corner_rank(p: i64, q: i64, delta: i64) -> i32 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_corner_x() -> i64 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_corner_y() -> i64 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_difference(in_a: i32, in_b: i32) -> i32 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_union(in_a: i32, in_b: i32) -> i32 from "csg_kernel.iii"
extern @abi(c-msvc-x64) fn csg_intersect(in_a: i32, in_b: i32) -> i32 from "csg_kernel.iii"

extern @abi(c-msvc-x64) fn lazy_fast_count() -> u64 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn lazy_canon_count() -> u64 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn lazy_exact_count() -> u64 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn lazy_reset_counts() -> i32 from "sqrt_sum_sign.iii"

fn e_i64(v: i64) -> i32 { if v < 0i64 { putchar(45i32)   return e_i64(0i64 - v) }   if v >= 10i64 { e_i64(v / 10i64) }   putchar(((v % 10i64) + 48i64) as i32)   return 0i32 }
fn sp() -> i32 { putchar(32i32)   return 0i32 }
fn nl() -> i32 { putchar(10i32)   return 0i32 }
fn pstr2(a: i32, b: i32) -> i32 { putchar(a)   putchar(b)   return 0i32 }

/* floor(sqrt n), bit-by-bit -- for the Arm-B fixed-precision interval emulation. */
fn kisqrt(n: i64) -> i64 {
    if n <= 0i64 { return 0i64 }
    let mut bl : i64 = 0i64   let mut t : i64 = n
    while t > 0i64 { t = t >> 1i64   bl = bl + 1i64 }
    let k : i64 = (bl - 1i64) / 2i64
    let mut bit : i64 = 1i64 << (2i64 * k)
    let mut res : i64 = 0i64   let mut x : i64 = n
    while bit != 0i64 {
        let rb : i64 = res + bit
        if x >= rb { x = x - rb   res = (res >> 1i64) + bit } else { res = res >> 1i64 }
        bit = bit >> 2i64
    }
    return res
}

var FAILA : u64   var FAILB : u64   var FAILD : u64   var FAILE : u64   var FAILF : u64

/* ─── The exact sphere-minus-cylinder cross-section (z=0).  Big disk radius 16 with a circular bite radius 6 at x=10.
 * Sphere x^2+y^2+z^2<=256 ; cylinder (x-10)^2+y^2<=36 -> x^2+y^2-20x+64<=0.  Each cell integer-exact: unshatterable raster. */
fn draw_cross_section() -> i32 {
    pstr2(61i32, 61i32)   pstr2(61i32, 61i32)   putchar(32i32)
    putchar(83i32) putchar(112i32) putchar(104i32) putchar(101i32) putchar(114i32) putchar(101i32)   /* "Sphere" */
    putchar(32i32) putchar(45i32) putchar(32i32)                                                       /* " - " */
    putchar(67i32) putchar(121i32) putchar(108i32)                                                     /* "Cyl" */
    putchar(32i32) pstr2(61i32, 61i32) pstr2(61i32, 61i32)   nl()
    let mut yy : i64 = 14i64
    while yy > (0i64 - 15i64) {
        let mut xx : i64 = 0i64 - 16i64
        while xx < 17i64 {
            let ins : i32 = csg_inside(1i64,1i64,1i64,0i64,0i64,0i64,0i64,0i64,0i64,0i64 - 256i64, xx, yy, 0i64)
            let inc : i32 = csg_inside(1i64,1i64,0i64,0i64,0i64,0i64,0i64 - 20i64,0i64,0i64, 64i64, xx, yy, 0i64)
            let d : i32 = csg_difference(ins, inc)
            if d == 1i32 { putchar(35i32) } else { putchar(46i32) }   /* '#' solid  '.' empty */
            xx = xx + 1i64
        }
        nl()
        yy = yy - 2i64
    }
    return 0i32
}

/* Arm A / A' / C helper: assert csg_surf_point_side(...) == want. */
fn side_is(want: i32, qa: i64, qb: i64, qc: i64, qd: i64, qe: i64, qf: i64, qg: i64, qh: i64, qi: i64, qj: i64, x0: i64, beta: i64, gamma: i64, sy: i64, sz: i64) -> i32 {
    let got : i32 = csg_surf_point_side(qa, qb, qc, qd, qe, qf, qg, qh, qi, qj, x0, beta, gamma, sy, sz)
    if got != want { FAILA = FAILA + 1u64 }
    return got
}

fn main() -> u64 {
    FAILA = 0u64   FAILB = 0u64   FAILD = 0u64   FAILE = 0u64   FAILF = 0u64

    draw_cross_section()
    nl()

    lazy_reset_counts()

    /* ── Arm A: certified ON-SURFACE zero via dependent surds.  p=(0,√2,√8); Q3 = z - 2y ; Q3(p) = 2√2 - 2√2 = 0. */
    side_is(0i32,   0i64,0i64,0i64,0i64,0i64,0i64,0i64, 0i64 - 2i64, 1i64, 0i64,   0i64, 2i64, 8i64, 1i64, 1i64)

    /* ── Arm A': same incidence, coefficients scaled by 2^20 (>=2^20) -> forced onto the EXACT bigint tier, still 0. */
    side_is(0i32,   0i64,0i64,0i64,0i64,0i64,0i64,0i64, 0i64 - 2097152i64, 1048576i64, 0i64,   0i64, 2i64, 8i64, 1i64, 1i64)

    /* ── Arm C: strictly OUTSIDE.  p=(0,√2,√3); Q3 = y + z ; Q3(p) = √2+√3 > 0 -> fast tier, +1. */
    side_is(1i32,   0i64,0i64,0i64,0i64,0i64,0i64,0i64, 1i64, 1i64, 0i64,   0i64, 2i64, 3i64, 1i64, 1i64)

    /* ── Arm B: the FLOAT-BREAKS witness.  V = 577 - 408√2  (577^2 - 2*408^2 = +1, so V > 0 but ~8.7e-4). */
    /*    Fixed precision f=10 : the interval [elo,ehi] STRADDLES 0 -> a fixed float CANNOT decide the sign (the tear). */
    let s1 : i64 = kisqrt(1i64 << 20i64)            /* floor(sqrt(1) * 2^10) = 1024   */
    let s2 : i64 = kisqrt(2i64 << 20i64)            /* floor(sqrt(2) * 2^10) = 1448   */
    let elo : i64 = 577i64 * s1 - 408i64 * (s2 + 1i64)     /* a<0 term uses the HIGH sqrt-bound for the low sum-bound */
    let ehi : i64 = 577i64 * (s1 + 1i64) - 408i64 * s2
    let mut straddle : u8 = 0u8
    if elo < 0i64 { if ehi > 0i64 { straddle = 1u8 } }
    if straddle == 0u8 { FAILB = FAILB + 1u64 }     /* fixed precision MUST fail to decide, else the witness is void */
    /*    sqrtsum_lazy3 (adaptive) MUST return the definite +1 where the fixed precision straddled. */
    let vsign : i32 = csg_surf_point_side(0i64,0i64,0i64,0i64,0i64,0i64,0i64, 0i64 - 408i64, 0i64, 577i64,   0i64, 2i64, 0i64, 1i64, 1i64)
    if vsign != 1i32 { FAILB = FAILB + 1u64 }
    putchar(66i32) putchar(58i32) sp()             /* "B: " */
    putchar(101i32) putchar(108i32) putchar(111i32) sp() e_i64(elo) sp()   /* elo <val> */
    putchar(101i32) putchar(104i32) putchar(105i32) sp() e_i64(ehi) sp()   /* ehi <val> */
    putchar(101i32) putchar(120i32) putchar(97i32) putchar(99i32) putchar(116i32) sp() e_i64(vsign as i64) nl()

    /* tier-coverage guard: fast, canon AND exact must all have fired across A/A'/B/C. */
    let fc : u64 = lazy_fast_count()   let cc : u64 = lazy_canon_count()   let ec : u64 = lazy_exact_count()
    let mut tiers_ok : u8 = 1u8
    if fc == 0u64 { tiers_ok = 0u8 }
    if cc == 0u64 { tiers_ok = 0u8 }
    if ec == 0u64 { tiers_ok = 0u8 }

    /* ── Arm D: sphere-cylinder degeneracy by INTEGER comparison. */
    if csg_sphere_cyl_class(5i64, 3i64, 3i64) != 1i32 { FAILD = FAILD + 1u64 }   /* transverse (smooth loop) */
    if csg_sphere_cyl_class(5i64, 8i64, 3i64) != 3i32 { FAILD = FAILD + 1u64 }   /* external tangent (pinch)  */
    if csg_sphere_cyl_class(5i64, 2i64, 3i64) != 4i32 { FAILD = FAILD + 1u64 }   /* internal tangent (pinch)  */
    if csg_sphere_cyl_class(5i64, 9i64, 3i64) != 2i32 { FAILD = FAILD + 1u64 }   /* disjoint                  */
    if csg_sphere_cyl_class(5i64, 1i64, 3i64) != 0i32 { FAILD = FAILD + 1u64 }   /* nested (no seam)          */

    /* ── Arm D'': the remaining CSG-tree combinators over membership flags (difference is exercised above);
     *    union/intersect truth tables -- the boolean face of the exact-membership substrate. */
    if csg_union(1i32, 0i32) != 1i32 { FAILD = FAILD + 1u64 }
    if csg_union(0i32, 1i32) != 1i32 { FAILD = FAILD + 1u64 }
    if csg_union(0i32, 0i32) != 0i32 { FAILD = FAILD + 1u64 }
    if csg_intersect(1i32, 0i32) != 0i32 { FAILD = FAILD + 1u64 }
    if csg_intersect(1i32, 1i32) != 1i32 { FAILD = FAILD + 1u64 }
    if csg_intersect(0i32, 0i32) != 0i32 { FAILD = FAILD + 1u64 }

    /* ── Arm E: triple-point CORNER coordinate via denest.  COLLAPSE: (R2,a,r2)=(81,2,70) -> y^2 = 35 + 8√19 = (4+√19)^2. */
    csg_sc_plane_corner(81i64, 2i64, 70i64)
    let cp : i64 = csg_corner_p()   let cq : i64 = csg_corner_q()   let cd : i64 = csg_corner_delta()
    if cp != 35i64 { FAILE = FAILE + 1u64 }   if cq != 8i64 { FAILE = FAILE + 1u64 }   if cd != 19i64 { FAILE = FAILE + 1u64 }
    let rk : i32 = csg_corner_rank(cp, cq, cd)
    if rk != 1i32 { FAILE = FAILE + 1u64 } else {
        let cx : i64 = csg_corner_x()   let cy : i64 = csg_corner_y()
        if cx * cx + cd * (cy * cy) != cp { FAILE = FAILE + 1u64 }     /* squares back: x^2 + d y^2 == p */
        if 2i64 * cx * cy != cq { FAILE = FAILE + 1u64 }              /* and 2xy == q                   */
        putchar(69i32) putchar(58i32) sp()                            /* "E: " */
        putchar(52i32) putchar(43i32)                                 /* "4+" — corner y-coord is 4+√19 */
        putchar(226i32) putchar(136i32) putchar(154i32)               /* '√' (utf-8) */
        e_i64(cd) sp() putchar(61i32) sp() e_i64(cx) sp() e_i64(cy) nl()
    }
    /* EXTENSION: (R2,a,r2)=(100,2,89) -> y^2 = 54 + 8√19, NOT a square in Q(√19) -> genuine rank-2 corner. */
    csg_sc_plane_corner(100i64, 2i64, 89i64)
    let ep : i64 = csg_corner_p()   let eq : i64 = csg_corner_q()   let ed : i64 = csg_corner_delta()
    if csg_corner_rank(ep, eq, ed) != 0i32 { FAILE = FAILE + 1u64 }

    /* ── Arm F: out of the exact envelope -> honest abstain (2). */
    if csg_corner_rank(2000000000i64, 8i64, 19i64) != 2i32 { FAILF = FAILF + 1u64 }

    if FAILA != 0u64 { return 10u64 }
    if FAILB != 0u64 { return 20u64 }
    if FAILD != 0u64 { return 30u64 }
    if FAILE != 0u64 { return 40u64 }
    if FAILF != 0u64 { return 50u64 }
    if tiers_ok == 0u8 { return 60u64 }
    return 99u64
}
