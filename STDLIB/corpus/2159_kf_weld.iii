/* 2159_kf_weld.iii -- THE WELD GATE: kfield's Galois-tower sign as Tier 3 of sqrt_sum_sign's ladder.
 *
 * DIFFERENTIAL (optimizer-must-match-replaced-path): the dispatcher (sqrtsum_lazy3) and the direct tower entries
 * (kf_multiquadratic_sign / kf_sign_checked) against the INDEPENDENT separation-bound oracle ui_sqrt_sum_sign --
 * identical wherever the tower ANSWERS; the tower MUST answer on the in-envelope bounded-rank cases (positive arm,
 * not negative-only) and MUST abstain -- never silently wrong -- on the out-of-envelope family that falsified raw
 * i64 kf_sign (19 of 39 silently wrong pre-guard; the same 39-case shape now yields 39/39 abstains, 0/39 wrong).
 *
 * THE THEOREM this gate carries (III-EXACT-SUBSTRATE-INTEGRATION section 3): on the bounded-rank multiquadratic
 * domain, the GALOIS-TOWER sign == the SEPARATION-BOUND sign.  Two mathematically independent exact deciders (a
 * tower of quadratic conjugations vs an algebraic-integer norm bound) certify one predicate; mutating either engine
 * reddens this gate.  A third independent exact-sign faculty joins the agreement web (Sturm == Sigma-sqrt was 2157).
 *
 * ARMS: 1 rank-collapse {sqrt6,sqrt10,sqrt15} (F2 rank 2, NOT 3: sqrt6*sqrt10 = 2*sqrt15) + full rank-3 depth;
 *       2 Pell/CF-convergent near-ties DISPATCHED through lazy3 -- the interval straddles, canon abstains, and the
 *         kf tier decides in pure i64 what previously escalated to bigint (lazy_kf_count proves the tier is LIVE);
 *       3 the overflow regression: 39 dense rank-2 cases at the falsifier's scale (radicands ~2e5, coeffs ~1.5e5,
 *         sign(p) != sign(q) forces the squaring cascade whose level-1 combine overflows i64) -> all 39 ABSTAIN;
 *         + the embed-path guard (coeffs ~3e9) -> abstain;  + in-envelope dense controls that must ANSWER == oracle;
 *       4 exact zeros float cancels (sqrt2+sqrt8-sqrt18, sqrt12+sqrt27-5sqrt3, rational 3-3) -> 0 everywhere;
 *       5 rank-4 abstain->fallback liveness: four summed Pell near-ties over {2,3,5,7} straddle Tier 1, canon
 *         abstains, kf REFUSES (rank 4 leaves the multiquadratic island), the adaptive tier decides == oracle.
 *
 *       6 the SURD-VALUE identity law: gestate(1,8) == gestate(2,2) as BITS (sqrt8 = 2sqrt2) <=> the kernel
 *         certifies sign(sqrt8 - 2sqrt2) == 0 -- IDENTIFY <=> DECIDE at the single-surd level; MUL collapses
 *         sqrt2*sqrt8 to the RATIONAL 4; the overflow sentinel is never identity-equal; + the remaining kfield
 *         verbs exercised directly (kf_embed on the rank-collapse set; the sticky guard flag get/clear).
 *
 *       7 the folded low-surd Tier 0 (T3 reconciliation): big-radicand and big-coefficient <=2-surd queries
 *         decided by the O(1) bi-quadratic squaring IN the dispatcher (lazy_biq_count proves the rung is live).
 *
 * exit 99 = pass
 *   10 dispatcher != oracle            14 exact-zero case wrong          17 39-family: a non-abstain differed
 *   11 direct tower != oracle          15 lazy_kf_count wrong (tier dead) 18 surd-value law / kf verb arm failed
 *   12 in-envelope tower ABSTAINED     16 abstain->fallback path never exercised
 *   13 out-of-envelope tower ANSWERED (guard dead)                       19 lazy_biq_count wrong (Tier 0 dead) */
module corpus_2159_kf_weld

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn sqrtsum_lazy3(a_ptr: u64, b_ptr: u64, n: u64) -> i32 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn ui_sqrt_sum_sign(a_ptr: u64, b_ptr: u64, n: u64) -> i32 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn lazy_reset_counts() -> i32 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn lazy_kf_count() -> u64 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn lazy_kf_abstain_count() -> u64 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn lazy_biq_count() -> u64 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn kf_multiquadratic_sign(a_ptr: u64, b_ptr: u64, n: u64) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_sign_checked(x: u64) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_radix(sa: i64, sb: i64, sc: i64) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_embed(a_ptr: u64, b_ptr: u64, n: u64) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_ovf_get() -> u32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_ovf_clear() -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn ep_gestate(c: i64, d: u64) -> u64 from "exact_surd_value.iii"
extern @abi(c-msvc-x64) fn ep_form(e: u64) -> u64 from "exact_surd_value.iii"
extern @abi(c-msvc-x64) fn ep_ratio(e: u64) -> u64 from "exact_surd_value.iii"
extern @abi(c-msvc-x64) fn ep_verb(e: u64) -> u64 from "exact_surd_value.iii"
extern @abi(c-msvc-x64) fn ep_is_overflow(e: u64) -> u32 from "exact_surd_value.iii"
extern @abi(c-msvc-x64) fn ep_ingest_coeff(e: u64) -> i64 from "exact_surd_value.iii"
extern @abi(c-msvc-x64) fn ep_ingest_rad(e: u64) -> u64 from "exact_surd_value.iii"
extern @abi(c-msvc-x64) fn ep_same(e1: u64, e2: u64) -> u32 from "exact_surd_value.iii"
extern @abi(c-msvc-x64) fn ep_mul(e1: u64, e2: u64) -> u64 from "exact_surd_value.iii"
extern @abi(c-msvc-x64) fn ep_is_rational(e: u64) -> u32 from "exact_surd_value.iii"
extern @abi(c-msvc-x64) fn ep_unit() -> u64 from "exact_surd_value.iii"

fn w_emit(v: u64) -> i32 { if v >= 10u64 { w_emit(v / 10u64) }   putchar(((v % 10u64) + 48u64) as i32)   return 0i32 }
fn w_sp() -> i32 { putchar(32i32)   return 0i32 }
fn w_nl() -> i32 { putchar(10i32)   return 0i32 }
fn w_sgn(s: i32) -> i32 { if s > 0i32 { putchar(43i32) }   if s < 0i32 { putchar(45i32) }   if s == 0i32 { putchar(48i32) }   if s == 2i32 { putchar(65i32) }   return 0i32 }

var WA : [i64; 16]   var WB : [i64; 16]           /* flat-sum scratch (coeffs, radicands) */
var WV : [i64; 8]                                 /* direct K-vector scratch for kf_sign_checked */
var WVB : [i64; 8]                                /* mask -> radicand map for the kf_radix(5,8,13) control field */
var WRC : u64                                     /* running failure code (first failure wins) */

fn wfail(code: u64) -> i32 { if WRC == 0u64 { WRC = code }   return 0i32 }

/* direct tower vs oracle on the flat sum in WA/WB: tower must ANSWER (else 12) and MATCH (else 11). */
fn w_direct_must(n: u64) -> i32 {
    let s : i32 = kf_multiquadratic_sign((&WA) as u64, (&WB) as u64, n)
    let o : i32 = ui_sqrt_sum_sign((&WA) as u64, (&WB) as u64, n)
    if s == 2i32 { wfail(12u64)   return 0i32 }
    if s != o { wfail(11u64) }
    return 0i32
}

/* dispatcher vs oracle on WA/WB (else 10). */
fn w_disp(n: u64) -> i32 {
    let s : i32 = sqrtsum_lazy3((&WA) as u64, (&WB) as u64, n)
    let o : i32 = ui_sqrt_sum_sign((&WA) as u64, (&WB) as u64, n)
    if s != o { wfail(10u64) }
    return s
}

/* Lehmer LCG (deterministic, no wrap needed: s*48271 < 2^47). */
var WSEED : u64
fn w_rand() -> u64 { WSEED = (WSEED * 48271u64) % 2147483647u64   return WSEED }

fn main() -> u64 {
    WRC = 0u64

    /* ══ ARM 1: rank-collapse {6,10,15} (F2 rank 2) + full rank-3 {2,3,5,30} depth -- direct tower == oracle. */
    WA[0u64]=1i64 WA[1u64]=1i64 WA[2u64]=0i64-1i64   WB[0u64]=6i64 WB[1u64]=10i64 WB[2u64]=15i64   w_direct_must(3u64)
    WA[0u64]=1i64 WA[1u64]=0i64-1i64 WA[2u64]=1i64   w_direct_must(3u64)
    WA[0u64]=3i64 WA[1u64]=0i64-4i64 WA[2u64]=1i64   w_direct_must(3u64)
    WA[0u64]=2i64 WA[1u64]=2i64 WA[2u64]=0i64-3i64   w_direct_must(3u64)
    WA[0u64]=1i64 WA[1u64]=1i64 WA[2u64]=1i64 WA[3u64]=0i64-1i64   WB[0u64]=2i64 WB[1u64]=3i64 WB[2u64]=5i64 WB[3u64]=30i64   w_direct_must(4u64)   /* rank-3, mask-7 basis element, depth-3 tower */
    WA[3u64]=0i64-2i64   w_direct_must(4u64)
    putchar(49i32) w_sp() w_emit(WRC) w_nl()                                        /* "1 <rc>" */

    /* ══ ARM 4: exact zeros float cancels -- direct tower AND dispatcher both 0 (canon eats the dispatched ones). */
    WA[0u64]=1i64 WA[1u64]=1i64 WA[2u64]=0i64-1i64   WB[0u64]=2i64 WB[1u64]=8i64 WB[2u64]=18i64
    if kf_multiquadratic_sign((&WA) as u64, (&WB) as u64, 3u64) != 0i32 { wfail(14u64) }
    if sqrtsum_lazy3((&WA) as u64, (&WB) as u64, 3u64) != 0i32 { wfail(14u64) }
    if ui_sqrt_sum_sign((&WA) as u64, (&WB) as u64, 3u64) != 0i32 { wfail(14u64) }
    WA[0u64]=1i64 WA[1u64]=1i64 WA[2u64]=0i64-5i64   WB[0u64]=12i64 WB[1u64]=27i64 WB[2u64]=3i64
    if kf_multiquadratic_sign((&WA) as u64, (&WB) as u64, 3u64) != 0i32 { wfail(14u64) }
    WA[0u64]=3i64 WA[1u64]=0i64-1i64   WB[0u64]=1i64 WB[1u64]=9i64
    if kf_multiquadratic_sign((&WA) as u64, (&WB) as u64, 2u64) != 0i32 { wfail(14u64) }   /* pure-rational zero (m=0 path) */
    putchar(52i32) w_sp() w_emit(WRC) w_nl()                                        /* "4 <rc>" */

    /* ══ ARM 3a: the 19/39 OVERFLOW REGRESSION, reconstructed at the falsifier's scale.  Dense rank-2 vectors,
     * radicands (199999, 200003), coeffs in [1e5, 2e5], v0,v1 > 0 and v2,v3 < 0 so sign(p) != sign(q) at level 1
     * and the squaring cascade fires; its combine (B * q^2 ~ 2e5 * 4.5e15) provably exceeds i64, so the GUARDED
     * tower must abstain on ALL 39 (raw kf_sign was silently wrong on 19).  A non-abstain answer must == oracle. */
    kf_radix(199999i64, 200003i64, 1i64)
    WSEED = 20260701u64
    let mut abst : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 39u64 {
        WV[0u64] = (100000u64 + (w_rand() % 100000u64)) as i64
        WV[1u64] = (100000u64 + (w_rand() % 100000u64)) as i64
        WV[2u64] = 0i64 - ((100000u64 + (w_rand() % 100000u64)) as i64)
        WV[3u64] = 0i64 - ((100000u64 + (w_rand() % 100000u64)) as i64)
        WV[4u64]=0i64 WV[5u64]=0i64 WV[6u64]=0i64 WV[7u64]=0i64
        let s : i32 = kf_sign_checked((&WV) as u64)
        if s == 2i32 { abst = abst + 1u64 }
        if s != 2i32 {
            /* it answered: the answer must equal the oracle on the equivalent flat sum v0 + v1*sqrtA + v2*sqrtB + v3*sqrt(AB) */
            WA[0u64]=WV[0u64] WA[1u64]=WV[1u64] WA[2u64]=WV[2u64] WA[3u64]=WV[3u64]
            WB[0u64]=1i64 WB[1u64]=199999i64 WB[2u64]=200003i64 WB[3u64]=199999i64*200003i64
            let o : i32 = ui_sqrt_sum_sign((&WA) as u64, (&WB) as u64, 4u64)
            if s != o { wfail(17u64) }
        }
        i = i + 1u64
    }
    putchar(51i32) w_sp() w_emit(abst) w_nl()                                       /* "3 <abstains>" (expect 39) */
    if abst != 39u64 { wfail(13u64) }                                               /* the envelope is deterministic: all must abstain */

    /* ══ ARM 3b: embed-path guard -- coeffs ~3e9 overflow inside the tower even for a sparse rank-2 embed. */
    WA[0u64]=3000000000i64 WA[1u64]=0i64-3000000000i64   WB[0u64]=199999i64 WB[1u64]=200003i64
    if kf_multiquadratic_sign((&WA) as u64, (&WB) as u64, 2u64) != 2i32 { wfail(13u64) }

    /* ══ ARM 3c: in-envelope dense controls on the SAME direct path (triangle scale, radix (5,8,13)) -- the guard
     * must NOT abstain here (prove-positive-arms) and every answer must equal the oracle over the mask radicands
     * [1,5,8,40,13,65,104,520]. */
    kf_radix(5i64, 8i64, 13i64)
    WVB[0u64]=1i64 WVB[1u64]=5i64 WVB[2u64]=8i64 WVB[3u64]=40i64 WVB[4u64]=13i64 WVB[5u64]=65i64 WVB[6u64]=104i64 WVB[7u64]=520i64
    let mut cc : u64 = 0u64
    while cc < 3u64 {
        if cc == 0u64 { WV[0u64]=1i64 WV[1u64]=2i64 WV[2u64]=0i64-1i64 WV[3u64]=1i64 WV[4u64]=0i64 WV[5u64]=0i64 WV[6u64]=0i64 WV[7u64]=0i64 }
        if cc == 1u64 { WV[0u64]=0i64-9i64 WV[1u64]=2i64 WV[2u64]=2i64 WV[3u64]=1i64 WV[4u64]=0i64 WV[5u64]=0i64 WV[6u64]=0i64 WV[7u64]=0i64 }
        if cc == 2u64 { WV[0u64]=0i64 WV[1u64]=0i64 WV[2u64]=0i64 WV[3u64]=0i64 WV[4u64]=1i64 WV[5u64]=0i64-1i64 WV[6u64]=0i64 WV[7u64]=0i64 }
        let s : i32 = kf_sign_checked((&WV) as u64)
        if s == 2i32 { wfail(12u64) }
        if s != 2i32 {
            let mut m : u64 = 0u64
            while m < 8u64 { WA[m] = WV[m]   WB[m] = WVB[m]   m = m + 1u64 }
            let o : i32 = ui_sqrt_sum_sign((&WA) as u64, (&WB) as u64, 8u64)
            if s != o { wfail(11u64) }
        }
        cc = cc + 1u64
    }
    putchar(51i32) putchar(99i32) w_sp() w_emit(WRC) w_nl()                         /* "3c <rc>" */

    /* ══ ARM 2: Pell/CF-convergent near-ties THROUGH THE DISPATCHER.  Each straddles Tier 1 (|E| ~ 1e-6 vs interval
     * width ~1e-3), canon abstains (2 independent classes), and the kf tier must DECIDE (count == 4) -- the case
     * family the shipped ladder previously escalated to bigint. */
    lazy_reset_counts()
    WA[0u64]=665857i64 WA[1u64]=0i64-470832i64   WB[0u64]=1i64 WB[1u64]=2i64
    let p1 : i32 = w_disp(2u64)                                                     /* 665857 - 470832*sqrt2 = +7.5e-7 */
    WA[0u64]=0i64-665857i64 WA[1u64]=470832i64
    let p2 : i32 = w_disp(2u64)                                                     /* mirrored: -1 */
    WA[0u64]=262087i64 WA[1u64]=0i64-151316i64   WB[0u64]=1i64 WB[1u64]=3i64
    let p3 : i32 = w_disp(2u64)                                                     /* Pell sqrt3: +1.9e-6 */
    WA[0u64]=470449i64 WA[1u64]=0i64-192060i64   WB[0u64]=1i64 WB[1u64]=6i64
    let p4 : i32 = w_disp(2u64)                                                     /* Pell sqrt6: +1.1e-6 */
    let kc : u64 = lazy_kf_count()
    putchar(50i32) w_sp() w_sgn(p1) w_sgn(p2) w_sgn(p3) w_sgn(p4) w_sp() w_emit(kc) w_nl()   /* "2 +-++ 4" */
    if kc != 4u64 { wfail(15u64) }

    /* ══ ARM 5: rank-4 abstain -> fallback liveness.  Four summed Pell near-ties over {2,3,5,7}: straddles Tier 1,
     * canon abstains, kf REFUSES (rank 4 > 3 leaves the multiquadratic island), the adaptive tier decides == oracle. */
    WA[0u64]=665857i64 WA[1u64]=0i64-470832i64 WA[2u64]=262087i64 WA[3u64]=0i64-151316i64
    WA[4u64]=930249i64 WA[5u64]=0i64-416020i64 WA[6u64]=514088i64 WA[7u64]=0i64-194307i64
    WB[0u64]=1i64 WB[1u64]=2i64 WB[2u64]=1i64 WB[3u64]=3i64 WB[4u64]=1i64 WB[5u64]=5i64 WB[6u64]=1i64 WB[7u64]=7i64
    let p5 : i32 = w_disp(8u64)                                                     /* sum of four positive near-ties: +1 */
    let ab5 : u64 = lazy_kf_abstain_count()
    putchar(53i32) w_sp() w_sgn(p5) w_sp() w_emit(ab5) w_nl()                       /* "5 + 1" */
    if ab5 != 1u64 { wfail(16u64) }

    /* ══ ARM 7: the folded low-surd Tier 0 (T3 reconciliation).  A big-radicand 2-surd near-tie and a
     * big-coefficient (bad-screen) 2-surd query both decide by the O(1) bi-quadratic squaring rung, == oracle. */
    WA[0u64]=1i64 WA[1u64]=0i64-1i64   WB[0u64]=10000000000000000i64 WB[1u64]=9999999999999999i64
    let q1 : i32 = w_disp(2u64)                                                     /* sqrt(1e16)-sqrt(1e16-1) ~ +5e-9 */
    WA[0u64]=5000000000i64 WA[1u64]=0i64-3000000000i64   WB[0u64]=1i64 WB[1u64]=2i64
    let q2 : i32 = w_disp(2u64)                                                     /* 5e9 - 3e9*sqrt2 > 0 (coeffs past the 2^20 screen) */
    let bq : u64 = lazy_biq_count()
    putchar(55i32) w_sp() w_sgn(q1) w_sgn(q2) w_sp() w_emit(bq) w_nl()              /* "7 ++ 2" */
    if bq != 2u64 { wfail(19u64) }

    /* ══ ARM 6: the SURD-VALUE identity law <=> the kernel (IDENTIFY <=> DECIDE at the single-surd level), plus
     * the remaining kfield verbs.  gestate canonicalizes, so sqrt8 and 2sqrt2 are the SAME 64 bits; the kernel
     * independently certifies sign(sqrt8 - 2sqrt2) == 0.  One identity, two exact deciders. */
    let e1 : u64 = ep_gestate(1i64, 8u64)
    let e2 : u64 = ep_gestate(2i64, 2u64)
    if ep_same(e1, e2) != 1u32 { wfail(18u64) }                                     /* IDENTIFY: one self-name */
    WA[0u64]=1i64 WA[1u64]=0i64-2i64   WB[0u64]=8i64 WB[1u64]=2i64
    if kf_multiquadratic_sign((&WA) as u64, (&WB) as u64, 2u64) != 0i32 { wfail(18u64) }   /* DECIDE: exact zero */
    if ep_form(e1) != 2u64 { wfail(18u64) }                                         /* canonical axis sqrt2 */
    if ep_ratio(e1) != 2u64 { wfail(18u64) }                                        /* canonical proportion 2 */
    if ep_verb(e1) != 1u64 { wfail(18u64) }                                         /* BELOW (+) */
    let em : u64 = ep_mul(ep_gestate(1i64, 2u64), e1)                               /* sqrt2 * sqrt8 = 4 exactly */
    if ep_is_rational(em) != 1u32 { wfail(18u64) }
    if ep_ingest_coeff(em) != 4i64 { wfail(18u64) }
    if ep_ingest_rad(em) != 1u64 { wfail(18u64) }
    /* NB 2^38 itself is a PERFECT SQUARE, so gestate canonicalizes it IN-domain (form 1, ratio 2^19) -- the
     * deterministic out-of-domain witness is a coefficient at the Ratio bound. */
    let ov : u64 = ep_gestate(16777216i64, 2u64)                                    /* Ratio 2^24 out of domain -> sentinel */
    if ep_is_overflow(ov) != 1u32 { wfail(18u64) }
    if ep_same(ov, ov) != 0u32 { wfail(18u64) }                                     /* a sentinel is NOT a value */
    let un : u64 = ep_unit()
    if ep_ingest_coeff(un) != 1i64 { wfail(18u64) }
    if ep_ingest_rad(un) != 1u64 { wfail(18u64) }
    /* remaining kfield verbs: embed accepts the rank-collapse set; the sticky guard flag reads and clears. */
    WA[0u64]=1i64 WA[1u64]=1i64 WA[2u64]=0i64-1i64   WB[0u64]=6i64 WB[1u64]=10i64 WB[2u64]=15i64
    if kf_embed((&WA) as u64, (&WB) as u64, 3u64) != 1i32 { wfail(18u64) }
    kf_radix(199999i64, 200003i64, 1i64)
    WV[0u64]=150000i64 WV[1u64]=150001i64 WV[2u64]=0i64-150002i64 WV[3u64]=0i64-150003i64
    WV[4u64]=0i64 WV[5u64]=0i64 WV[6u64]=0i64 WV[7u64]=0i64
    if kf_sign_checked((&WV) as u64) != 2i32 { wfail(18u64) }                       /* deterministic overflow */
    if kf_ovf_get() != 1u32 { wfail(18u64) }                                        /* the sticky flag is SET */
    kf_ovf_clear()
    if kf_ovf_get() != 0u32 { wfail(18u64) }
    putchar(54i32) w_sp() w_emit(WRC) w_nl()                                        /* "6 <rc>" */

    if WRC != 0u64 { return WRC }
    return 99u64
}
