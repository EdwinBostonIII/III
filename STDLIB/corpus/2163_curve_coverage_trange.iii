/* STDLIB/corpus/2163_curve_coverage_trange.iii -- proves the t-RANGE CLAMP of the general coverage engine is EXACT:
 * ui_arc_cover2d_sym_big_t restricted to a parameter sub-interval [t0,t1] matches an x-CLIPPED independent subsampler.
 * This is the unit proof under ui_arc_cover_full (which splits a full arc at its y-extremum and sums the sub-arcs):
 * a sub-range bound enters the degree-4 assembly as a DEGENERATE crossing, and a full-piece cut by the bound ends at
 * the RATIONAL x(t_bound).  Cases exercise all three clamp modes: t1 KILLING the full-piece (x_m before the band-top
 * crossing), the RATIONAL full-piece edge (x_m inside the full-piece), and t0 clamping the lower bound (right part).
 * arc monomial ax=0,8,4 ay=0,2,6 (x,y both increasing on [0,1]); column px=2 spans y~0.75->1.25 over row py=0, so the
 * y=1 (band-top) crossing sits at x~2.49 -- t_m=1/4 (x_m=2.25) lands before it, t_m=3/10 (x_m=2.76) inside the full piece. */
module corpus_2163_curve_coverage_trange

extern @abi(c-msvc-x64) fn ui_arc_cover2d_sym_big_t(ax0: i64, ax1: i64, ax2: i64, ay0: i64, ay1: i64, ay2: i64, px: i64, py: i64, sa: i64, t0n: i64, t0d: i64, t1n: i64, t1d: i64) -> i64 from "ui_exact_sym.iii"
extern @abi(c-msvc-x64) fn ui_pt_below_arc(ax0: i64, ax1: i64, ax2: i64, ay0: i64, ay1: i64, ay2: i64, xval: i64, yval: i64) -> u32 from "ui_exact.iii"

const SA : i64 = 255i64
const NN : i64 = 32i64
const BOUND : i64 = 12i64

fn iabs(x: i64) -> i64 { if x < 0i64 { return 0i64 - x }   return x }

/* x-CLIPPED independent oracle: fraction of pixel (px,py) with {y < y_arc(x)} AND (side 0: x < x_m | side 1: x >= x_m),
 * x_m = XN/XD.  Scaled coords (m=2NN); sub-pixel centre x = (m*px + 2i+1)/m, so the clip is (m*px+2i+1)*XD vs XN*m. */
fn subclip(ax0: i64, ax1: i64, ax2: i64, ay0: i64, ay1: i64, ay2: i64, px: i64, py: i64, XN: i64, XD: i64, side: i64) -> i64 {
    let m : i64 = 2i64 * NN
    let mx0 : i64 = m*ax0   let mx1 : i64 = m*ax1   let mx2 : i64 = m*ax2
    let my0 : i64 = m*ay0   let my1 : i64 = m*ay1   let my2 : i64 = m*ay2
    let bx : i64 = m*px     let by : i64 = m*py
    let rhs : i64 = XN * m
    let mut count : i64 = 0i64
    let mut i : i64 = 0i64
    while i < NN {
        let cx : i64 = bx + ((2i64*i)+1i64)
        let lhs : i64 = cx * XD
        let mut inx : u32 = 0u32
        if side == 0i64 { if lhs < rhs { inx = 1u32 } }
        if side == 1i64 { if lhs >= rhs { inx = 1u32 } }
        if inx == 1u32 {
            let mut j : i64 = 0i64
            while j < NN {
                let cy : i64 = by + ((2i64*j)+1i64)
                let bel : u32 = ui_pt_below_arc(mx0,mx1,mx2,my0,my1,my2, cx, cy)
                if bel == 0u32 { count = count + 1i64 }
                j = j + 1i64
            }
        }
        i = i + 1i64
    }
    let nn2 : i64 = NN*NN
    return ((2i64*count*SA)+nn2)/(2i64*nn2)
}

/* x(t_m) numerator for monomial ax at rational t=tn/td: x = (ax0*td^2 + ax1*tn*td + ax2*tn^2)/td^2. */
fn xm_num(ax0: i64, ax1: i64, ax2: i64, tn: i64, td: i64) -> i64 { return (ax0*(td*td)) + ((ax1*tn)*td) + (ax2*(tn*tn)) }

/* one t-range piece vs its x-clipped oracle. lohi=0 => left [0,tm] clipped x<x_m ; lohi=1 => right [tm,1] clipped x>=x_m. */
fn chkpiece(ax0: i64, ax1: i64, ax2: i64, ay0: i64, ay1: i64, ay2: i64, px: i64, py: i64, tn: i64, td: i64, lohi: i64) -> u32 {
    let XN : i64 = xm_num(ax0, ax1, ax2, tn, td)
    let XD : i64 = td*td
    let mut s : i64 = 0i64
    let mut u : i64 = 0i64
    if lohi == 0i64 { s = ui_arc_cover2d_sym_big_t(ax0,ax1,ax2,ay0,ay1,ay2, px, py, SA, 0i64,1i64, tn,td)   u = subclip(ax0,ax1,ax2,ay0,ay1,ay2, px, py, XN, XD, 0i64) }
    if lohi == 1i64 { s = ui_arc_cover2d_sym_big_t(ax0,ax1,ax2,ay0,ay1,ay2, px, py, SA, tn,td, 1i64,1i64)   u = subclip(ax0,ax1,ax2,ay0,ay1,ay2, px, py, XN, XD, 1i64) }
    if s == 0i64 - 2i64 { if u <= BOUND { return 1u32 }   return 0u32 }   /* column outside the sub-arc range -> -2; clip must be ~0 */
    if s < 0i64 { return 0u32 }
    let d : i64 = iabs(s - u)
    if d > BOUND { return 0u32 }
    return 1u32
}

fn main() -> u64 {
    let ax0:i64=0i64   let ax1:i64=8i64   let ax2:i64=4i64
    let ay0:i64=0i64   let ay1:i64=2i64   let ay2:i64=6i64

    /* CASE 1 -- t_m = 1/4 (x_m = 2.25, BEFORE the y=1 crossing ~2.49): left part [0,1/4] -> t1 KILLS the full-piece. */
    if chkpiece(ax0,ax1,ax2,ay0,ay1,ay2, 2i64, 0i64, 1i64, 4i64, 0i64) != 1u32 { return 11u64 }
    if chkpiece(ax0,ax1,ax2,ay0,ay1,ay2, 2i64, 0i64, 1i64, 4i64, 1i64) != 1u32 { return 12u64 }

    /* CASE 2 -- t_m = 3/10 (x_m = 2.76, INSIDE the full-piece [2.49,3]): left part [0,3/10] -> RATIONAL full-piece edge. */
    if chkpiece(ax0,ax1,ax2,ay0,ay1,ay2, 2i64, 0i64, 3i64, 10i64, 0i64) != 1u32 { return 21u64 }
    if chkpiece(ax0,ax1,ax2,ay0,ay1,ay2, 2i64, 0i64, 3i64, 10i64, 1i64) != 1u32 { return 22u64 }

    /* CASE 3 -- a gentle column (px=0): t_m=1/16 -> x_m=x(1/16)=0.516 strictly INSIDE column 0, so both the left
     * [0,1/16] (x<x_m) and right [1/16,1] (x>=x_m) pieces genuinely overlap the column and are strict-AA. */
    if chkpiece(ax0,ax1,ax2,ay0,ay1,ay2, 0i64, 0i64, 1i64, 16i64, 0i64) != 1u32 { return 31u64 }
    if chkpiece(ax0,ax1,ax2,ay0,ay1,ay2, 0i64, 0i64, 1i64, 16i64, 1i64) != 1u32 { return 32u64 }

    /* CASE 4 -- PARTITION consistency: left-clip + right-clip oracle == full oracle (a sanity check on the clip itself). */
    let tn:i64=3i64   let td:i64=10i64
    let XN:i64 = xm_num(ax0,ax1,ax2,tn,td)   let XD:i64 = td*td
    let ul:i64 = subclip(ax0,ax1,ax2,ay0,ay1,ay2, 2i64,0i64, XN,XD, 0i64)
    let ur:i64 = subclip(ax0,ax1,ax2,ay0,ay1,ay2, 2i64,0i64, XN,XD, 1i64)
    let uf:i64 = subclip(ax0,ax1,ax2,ay0,ay1,ay2, 2i64,0i64, 1000000i64,1i64, 0i64)
    if iabs((ul+ur) - uf) > 2i64 { return 40u64 }

    /* CASE 5 -- a t-range fully containing the column ([0,1]) equals the un-ranged full coverage (round-trip). */
    let sfull:i64 = ui_arc_cover2d_sym_big_t(ax0,ax1,ax2,ay0,ay1,ay2, 2i64,0i64, SA, 0i64,1i64, 1i64,1i64)
    let ufull:i64 = subclip(ax0,ax1,ax2,ay0,ay1,ay2, 2i64,0i64, 1000000i64,1i64, 0i64)
    if sfull < 0i64 { return 50u64 }
    if iabs(sfull - ufull) > BOUND { return 51u64 }

    return 99u64
}
