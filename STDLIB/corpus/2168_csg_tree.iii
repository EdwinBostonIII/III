/* 2168_csg_tree.iii -- GATE for csg_tree.iii: the ALGEBRAIC CSG DAG (charter Phase 5).
 *
 * THE CLAIM WITH TEETH: a thousand successive boolean subtractions on one volume, and the 1000th operation
 * is EXACTLY as precise as the 1st -- because depth composes BOOLEANS over exact leaf signs, never arithmetic.
 *   - 1000 drills: base sphere minus 1000 small spheres (a left-deep 1000-deep chain, nodes shared as a DAG);
 *     probes at the FIRST and the LAST drill centers classify OUTSIDE identically; an undrilled interior
 *     point stays INSIDE; a far point is OUTSIDE.
 *   - THE ON-CERTIFICATE AT DEPTH 1000: a point exactly on drill 0's boundary evaluates to ON (0) through
 *     the entire 1000-op chain -- an exact tangency carried through a thousand booleans.
 *   - DEPTH INDEPENDENCE: the same probe through a depth-1 tree and the depth-1000 tree gives the same sign.
 *   - THE LEAF-EXACTNESS WITNESS (the float failure this kills): sphere R^2 = 2^62; probes at squared
 *     distance 2^62 - 2^32 + 1 / 2^62 / 2^62 + 1 classify -1 / 0 / +1 EXACTLY; a 53-bit-mantissa twin
 *     (IEEE-double emulation: round every operand to its top 53 bits) COLLAPSES R^2 and R^2 + 1 into one
 *     value and misclassifies the outside probe as ON.
 *
 * exit 99 = pass;  10 build fail;  11 drilled probes not OUTSIDE;  12 interior probe not INSIDE;
 * 13 far probe not OUTSIDE;  14 depth-1 vs depth-1000 disagree;  15 the ON-certificate broke;
 * 20 exact magnitude probes wrong;  21 the twin failed to collapse (witness void) */
module corpus_2168_csg_tree

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn ct_reset() -> i32 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_sphere(cx: i64, cy: i64, cz: i64, r2: i64) -> i64 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_difference(l: i64, r: i64) -> i64 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_union(l: i64, r: i64) -> i64 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_intersect(l: i64, r: i64) -> i64 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_side(node: i64, x: i64, y: i64, z: i64) -> i32 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_count() -> u64 from "csg_tree.iii"

fn e_i64(v: i64) -> i32 { if v < 0i64 { putchar(45i32)   return e_i64(0i64 - v) }   if v >= 10i64 { e_i64(v / 10i64) }   putchar(((v % 10i64) + 48i64) as i32)   return 0i32 }
fn sp() -> i32 { putchar(32i32)   return 0i32 }   fn nl() -> i32 { putchar(10i32)   return 0i32 }

/* IEEE-double emulation: round an integer to its top 53 bits (deterministic truncation of the mantissa). */
fn r53(v: i64) -> i64 {
    let mut u : u64 = v as u64
    let mut neg : u8 = 0u8
    if v < 0i64 { neg = 1u8   u = (0i64 - v) as u64 }
    let mut bl : u64 = 0u64   let mut t : u64 = u
    while t > 0u64 { t = t >> 1u64   bl = bl + 1u64 }
    if bl > 53u64 {
        let sh : u64 = bl - 53u64
        u = (u >> sh) << sh
    }
    if neg == 1u8 { return 0i64 - (u as i64) }
    return u as i64
}

fn main() -> u64 {
    ct_reset()

    /* ══ the 1000-drill object: base sphere R^2 = 1e8 minus holes r^2 = 1 at (4i - 2000, 0, 0), i < 1000. */
    let base : i64 = ct_sphere(0i64, 0i64, 0i64, 100000000i64)
    if base < 0i64 { return 10u64 }
    let mut solid : i64 = base
    let mut h0 : i64 = 0i64 - 1i64
    let mut i : i64 = 0i64
    while i < 1000i64 {
        let h : i64 = ct_sphere((4i64 * i) - 2000i64, 0i64, 0i64, 1i64)
        if h < 0i64 { return 10u64 }
        if i == 0i64 { h0 = h }
        solid = ct_difference(solid, h)
        if solid < 0i64 { return 10u64 }
        i = i + 1i64
    }
    /* drilled-away probes: the FIRST and the LAST hole centers are OUTSIDE the solid, identically. */
    let s_first : i32 = ct_side(solid, 0i64 - 2000i64, 0i64, 0i64)
    let s_last  : i32 = ct_side(solid, 1996i64, 0i64, 0i64)
    putchar(68i32) putchar(58i32) sp() e_i64(s_first as i64) sp() e_i64(s_last as i64) sp() e_i64(ct_count() as i64) nl()   /* "D: 1 1 2001" */
    if s_first != 1i32 { return 11u64 }
    if s_last != 1i32 { return 11u64 }
    /* an undrilled interior point stays INSIDE; a far point is OUTSIDE. */
    if ct_side(solid, 2i64, 0i64, 0i64) != (0i32 - 1i32) { return 12u64 }
    if ct_side(solid, 20000i64, 0i64, 0i64) != 1i32 { return 13u64 }
    /* depth independence: the same probe through a depth-1 tree equals the depth-1000 answer. */
    let shallow : i64 = ct_difference(base, h0)
    if shallow < 0i64 { return 10u64 }
    if ct_side(shallow, 0i64 - 2000i64, 0i64, 0i64) != s_first { return 14u64 }
    /* THE ON-CERTIFICATE AT DEPTH 1000: exactly on drill 0's boundary -> ON through all 1000 operations. */
    let s_on : i32 = ct_side(solid, 0i64 - 1999i64, 0i64, 0i64)
    putchar(79i32) putchar(58i32) sp() e_i64(s_on as i64) nl()                                                 /* "O: 0" */
    if s_on != 0i32 { return 15u64 }

    /* ══ the leaf-exactness witness: R^2 = 2^62; x = 2^31 is EXACTLY on; +-1 in squared distance resolves. */
    let big : i64 = ct_sphere(0i64, 0i64, 0i64, 4611686018427387904i64)
    if big < 0i64 { return 10u64 }
    let x0 : i64 = 2147483648i64                                               /* 2^31: x^2 = 2^62 exactly */
    let s_on2 : i32 = ct_side(big, x0, 0i64, 0i64)
    let s_out : i32 = ct_side(big, x0, 1i64, 0i64)                             /* dist^2 = 2^62 + 1 */
    let s_in  : i32 = ct_side(big, x0 - 1i64, 0i64, 0i64)                      /* dist^2 = 2^62 - 2^32 + 1 */
    putchar(77i32) putchar(58i32) sp() e_i64(s_in as i64) sp() e_i64(s_on2 as i64) sp() e_i64(s_out as i64) nl()   /* "M: -1 0 1" */
    if s_in != (0i32 - 1i32) { return 20u64 }
    if s_on2 != 0i32 { return 20u64 }
    if s_out != 1i32 { return 20u64 }
    /* the 53-bit twin collapses R^2 and R^2 + 1 (Q_twin = r53(dist^2) - r53(R^2) = 0 -> it calls OUTSIDE "on"). */
    let d2out : i64 = 4611686018427387904i64 + 1i64
    let tq : i64 = r53(d2out) - r53(4611686018427387904i64)
    putchar(84i32) putchar(58i32) sp() e_i64(tq) nl()                                                          /* "T: 0" */
    if tq != 0i64 { return 21u64 }

    return 99u64
}
