/* 2170_swept_leaf.iii -- GATE for the SWEPT-SPHERE leaf (charter Program II, Phase II / Vector I base):
 * the CSG leaf as a continuous spacetime volume -- a ball-nose tool pass A->B -- decided EXACTLY at any t.
 *
 * ARM S -- THE SLOT: base sphere minus one swept pass.  Probes: mid-slot (drilled), exactly ON the slot wall
 *   (the ON-certificate: tangency THROUGH a boolean difference), just outside the slot (material), both
 *   END-CAPS (the clamped t=0 / t=1 branches), and beyond the pass (untouched material).
 * ARM Z -- THE ZIGZAG: 100 passes unioned (a 100-deep chain) subtracted from a block; the 1st and 100th
 *   pass classify identically (depth independence for KINEMATIC leaves); a probe exactly BETWEEN two
 *   adjacent passes (distance == radius to BOTH axes) is ON -- a certified two-pass tangency.
 * ARM T -- THE PHANTOM-MATERIAL WITNESS: the industry-standard snapshot approximation (sample the tool at
 *   t = 0, 1/4, 1/2, 3/4, 1 and union the static spheres) says the point (25,0,0) was NEVER cut (min sample
 *   distance 25 > radius 5); the EXACT swept leaf proves the tool center PASSES THROUGH it at t* = 5/8.
 *   Snapshot CAM leaves phantom material exactly here; the continuous leaf does not.
 *
 * exit 99 = pass;  10 build failed;  11 S-arm probe wrong;  12 Z-arm probe wrong;  13 depth-independence broke;
 * 15 ON-certificates broke;  20 T-arm exact side wrong;  21 the snapshot twin AGREED (witness void) */
module corpus_2170_swept_leaf

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn ct_reset() -> i32 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_sphere(cx: i64, cy: i64, cz: i64, r2: i64) -> i64 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_swept(ax: i64, ay: i64, az: i64, bx: i64, by: i64, bz: i64, r2: i64) -> i64 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_union(l: i64, r: i64) -> i64 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_difference(l: i64, r: i64) -> i64 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_side(node: i64, x: i64, y: i64, z: i64) -> i32 from "csg_tree.iii"
extern @abi(c-msvc-x64) fn ct_count() -> u64 from "csg_tree.iii"

fn e_i64(v: i64) -> i32 { if v < 0i64 { putchar(45i32)   return e_i64(0i64 - v) }   if v >= 10i64 { e_i64(v / 10i64) }   putchar(((v % 10i64) + 48i64) as i32)   return 0i32 }
fn sp() -> i32 { putchar(32i32)   return 0i32 }   fn nl() -> i32 { putchar(10i32)   return 0i32 }

fn main() -> u64 {
    ct_reset()

    /* ══ ARM S: one slot.  Block r^2 = 1e6; pass (-100,0,0) -> (100,0,0), tool r^2 = 25 (radius 5). */
    let blk : i64 = ct_sphere(0i64, 0i64, 0i64, 1000000i64)
    let slot : i64 = ct_swept(0i64 - 100i64, 0i64, 0i64, 100i64, 0i64, 0i64, 25i64)
    if blk < 0i64 { return 10u64 }
    if slot < 0i64 { return 10u64 }
    let part : i64 = ct_difference(blk, slot)
    if part < 0i64 { return 10u64 }
    if ct_side(part, 0i64, 0i64, 0i64) != 1i32 { return 11u64 }                    /* mid-slot: drilled away  */
    if ct_side(part, 0i64, 6i64, 0i64) != (0i32 - 1i32) { return 11u64 }           /* beside the slot: material */
    if ct_side(part, 0i64 - 104i64, 0i64, 0i64) != 1i32 { return 11u64 }           /* A end-cap (t=0 clamp)   */
    if ct_side(part, 103i64, 0i64, 0i64) != 1i32 { return 11u64 }                  /* B end-cap (t=1 clamp)   */
    if ct_side(part, 150i64, 0i64, 0i64) != (0i32 - 1i32) { return 11u64 }         /* beyond the pass: material */
    let on1 : i32 = ct_side(part, 0i64, 5i64, 0i64)                                /* exactly ON the slot wall */
    let on2 : i32 = ct_side(part, 105i64, 0i64, 0i64)                              /* exactly ON the B end-cap */
    putchar(83i32) putchar(58i32) sp() e_i64(on1 as i64) sp() e_i64(on2 as i64) nl()   /* "S: 0 0" */
    if on1 != 0i32 { return 15u64 }
    if on2 != 0i32 { return 15u64 }

    /* ══ ARM Z: 100 zigzag passes at y = 0,2,4,...,198 (radius 1), unioned, subtracted from a block. */
    let blk2 : i64 = ct_sphere(0i64, 0i64, 0i64, 1000000i64)
    if blk2 < 0i64 { return 10u64 }
    let mut cuts : i64 = 0i64 - 1i64
    let mut first : i64 = 0i64 - 1i64
    let mut i : i64 = 0i64
    while i < 100i64 {
        let s : i64 = ct_swept(0i64 - 50i64, 2i64 * i, 0i64, 50i64, 2i64 * i, 0i64, 1i64)
        if s < 0i64 { return 10u64 }
        if i == 0i64 { first = s   cuts = s }
        if i > 0i64 { cuts = ct_union(cuts, s)   if cuts < 0i64 { return 10u64 } }
        i = i + 1i64
    }
    let part2 : i64 = ct_difference(blk2, cuts)
    if part2 < 0i64 { return 10u64 }
    let z1 : i32 = ct_side(part2, 0i64, 0i64, 0i64)                                /* on pass 1's axis: drilled */
    let z100 : i32 = ct_side(part2, 0i64, 198i64, 0i64)                            /* on pass 100's axis: drilled */
    if z1 != 1i32 { return 12u64 }
    if z100 != 1i32 { return 12u64 }
    if z1 != z100 { return 13u64 }                                                 /* the 100th == the 1st */
    if ct_side(part2, 0i64, 250i64, 0i64) != (0i32 - 1i32) { return 12u64 }        /* past the zigzag: material */
    let zon : i32 = ct_side(part2, 0i64, 1i64, 0i64)                               /* exactly between passes 1,2 */
    putchar(90i32) putchar(58i32) sp() e_i64(z1 as i64) sp() e_i64(z100 as i64) sp() e_i64(zon as i64) sp() e_i64(ct_count() as i64) nl()   /* "Z: 1 1 0 203" */
    if zon != 0i32 { return 15u64 }

    /* ══ ARM T: the snapshot twin.  Probe (25,0,0) vs the ARM-S pass: samples t=0,1/4,1/2,3/4,1 give centers
     * x = -100,-50,0,50,100 -- every sample distance >= 25 > 5, so the SNAPSHOT union says NEVER CUT (-1,
     * phantom material); the exact leaf: the center passes through x=25 at t* = 5/8 -> distance 0 -> CUT. */
    let exact_cut : i32 = ct_side(slot, 25i64, 0i64, 0i64)                         /* the swept leaf itself */
    let mut twin : i32 = 1i32                                                      /* +1 = outside every sampled tool = "never cut" */
    let mut k : i64 = 0i64
    while k < 5i64 {
        let cx : i64 = (0i64 - 100i64) + (50i64 * k)
        let dx : i64 = 25i64 - cx
        if ((dx * dx) - 25i64) < 0i64 { twin = 0i32 - 1i32 }                       /* inside a sampled tool */
        k = k + 1i64
    }
    putchar(84i32) putchar(58i32) sp() e_i64(exact_cut as i64) sp() e_i64(twin as i64) nl()   /* "T: -1 1" */
    if exact_cut != (0i32 - 1i32) { return 20u64 }                                 /* EXACT: inside the swept volume */
    if twin == exact_cut { return 21u64 }                                          /* the snapshot twin must leave phantom material */

    return 99u64
}
