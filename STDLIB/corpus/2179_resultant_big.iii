/* 2179_resultant_big.iii -- GATE for the modular-CRT determinant engine (rs_sum_big): the resultant
 * envelope LIFTED, with the v1 refusals as the certified floor.
 *
 * ARM A -- MAGNITUDE: gamma = cbrt(2^31) + sqrt(3).  The closed form (machine-derived, verified at a=2
 *   against the classical polynomial) is t^6 - 9t^4 - 2a*t^3 + 27t^2 - 18a*t + (a^2 - 27).  v1's guarded
 *   i64 Bareiss REFUSES (intermediate products overflow); v2 derives all seven coefficients EXACTLY,
 *   including a^2 - 27 = 4611686018427387877 = 2^62 - 27.
 * ARM B -- DEGREE: gamma = 2^(1/4) + 3^(1/3), D = 12 > v1's guard.  v1 refuses; v2 returns the degree-12
 *   polynomial with the THEOREM pins: monic (lead 1), t^11 coefficient 0 (sum of the 12 conjugates), t^10
 *   coefficient 0 (second symmetric function), constant 73 = Res(x^4-2, -x^3-3) (derived by hand-check:
 *   prod(alpha^3+3) = -146/-2).  THE COMPOSITION: exact integer Horner on the DERIVED polynomial pins
 *   R(0)=73, R(1)=-958, R(2)=-12391, R(3)=218098 (machine-derived) -- the sign pattern +,-,-,+ BRACKETS
 *   both real roots -2^(1/4)+3^(1/3) in (0,1) and 2^(1/4)+3^(1/3) in (2,3).  (Sturm's i64 PRS chain
 *   honestly overflows at degree 12 -- its own envelope; the derived object still locates its roots.)
 * ARM C -- THE TWIN WELD: on the shared envelope (cbrt2 + sqrt3) v2 must equal v1 COEFFICIENT-FOR-
 *   COEFFICIENT: two utterly different determinant engines (exact-division Bareiss vs 16-prime CRT),
 *   one answer.
 * ARM D -- CERTIFIED OUTPUT REFUSAL: a = 2^40 makes a^2 - 27 exceed i64; v2 must refuse (-1), never round.
 *
 * exit 99 = pass;  10 A v1 failed to refuse;  11 A v2 wrong;  12 B refusal/degree wrong;  13 B pins wrong;
 * 14 B sturm count wrong;  15 C twin mismatch;  16 D refusal missing */
module corpus_2179_resultant_big

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn rs_sum(fp: u64, degf: i64, gp: u64, degg: i64, outp: u64) -> i64 from "resultant.iii"
extern @abi(c-msvc-x64) fn rs_sum_big(fp: u64, degf: i64, gp: u64, degg: i64, outp: u64) -> i64 from "resultant.iii"

var QF : [i64; 10]   var QG : [i64; 10]   var QO : [i64; 20]   var QO2 : [i64; 10]

/* exact integer Horner on the ARM-B derived degree-12 polynomial in QO */
fn horner(t: i64) -> i64 {
    let mut v : i64 = 0i64
    let mut i : i64 = 12i64
    while i >= 0i64 { v = (v * t) + QO[i as u64]   i = i - 1i64 }
    return v
}

fn e_i64(v: i64) -> i32 { if v < 0i64 { putchar(45i32)   return e_i64(0i64 - v) }   if v >= 10i64 { e_i64(v / 10i64) }   putchar(((v % 10i64) + 48i64) as i32)   return 0i32 }
fn sp() -> i32 { putchar(32i32)   return 0i32 }   fn nl() -> i32 { putchar(10i32)   return 0i32 }

fn main() -> u64 {
    /* ══ ARM A: cbrt(2^31) + sqrt(3) -- v1 refuses, v2 exact. */
    QF[0u64] = 0i64 - 2147483648i64   QF[1u64] = 0i64   QF[2u64] = 0i64   QF[3u64] = 1i64   /* x^3 - 2^31 */
    QG[0u64] = 0i64 - 3i64   QG[1u64] = 0i64   QG[2u64] = 1i64                              /* x^2 - 3 */
    let a1 : i64 = rs_sum((&QF) as u64, 3i64, (&QG) as u64, 2i64, (&QO2) as u64)
    let a2 : i64 = rs_sum_big((&QF) as u64, 3i64, (&QG) as u64, 2i64, (&QO) as u64)
    putchar(65i32) putchar(58i32) sp() e_i64(a1) sp() e_i64(a2)
    let mut i : u64 = 0u64
    while i <= 6u64 { sp() e_i64(QO[i])   i = i + 1u64 }
    nl()                                             /* "A: -1 6 4611686018427387877 -38654705664 27 -4294967296 -9 0 1" */
    if a1 != (0i64 - 1i64) { return 10u64 }
    if a2 != 6i64 { return 11u64 }
    if QO[0u64] != 4611686018427387877i64 { return 11u64 }
    if QO[1u64] != (0i64 - 38654705664i64) { return 11u64 }
    if QO[2u64] != 27i64 { return 11u64 }
    if QO[3u64] != (0i64 - 4294967296i64) { return 11u64 }
    if QO[4u64] != (0i64 - 9i64) { return 11u64 }
    if QO[5u64] != 0i64 { return 11u64 }
    if QO[6u64] != 1i64 { return 11u64 }

    /* ══ ARM B: 2^(1/4) + 3^(1/3), D = 12 -- v1 guard-refuses, v2 derives; theorem pins + sturm. */
    QF[0u64] = 0i64 - 2i64   QF[1u64] = 0i64   QF[2u64] = 0i64   QF[3u64] = 0i64   QF[4u64] = 1i64   /* x^4 - 2 */
    QG[0u64] = 0i64 - 3i64   QG[1u64] = 0i64   QG[2u64] = 0i64   QG[3u64] = 1i64                     /* x^3 - 3 */
    let b1 : i64 = rs_sum((&QF) as u64, 4i64, (&QG) as u64, 3i64, (&QO2) as u64)
    let b2 : i64 = rs_sum_big((&QF) as u64, 4i64, (&QG) as u64, 3i64, (&QO) as u64)
    putchar(66i32) putchar(58i32) sp() e_i64(b1) sp() e_i64(b2)
    i = 0u64
    while i <= 12u64 { sp() e_i64(QO[i])   i = i + 1u64 }
    nl()
    if b1 != (0i64 - 1i64) { return 12u64 }
    if b2 != 12i64 { return 12u64 }
    if QO[12u64] != 1i64 { return 13u64 }
    if QO[11u64] != 0i64 { return 13u64 }
    if QO[10u64] != 0i64 { return 13u64 }
    if QO[0u64] != 73i64 { return 13u64 }
    let r0 : i64 = horner(0i64)   let r1 : i64 = horner(1i64)
    let r2v : i64 = horner(2i64)  let r3 : i64 = horner(3i64)
    putchar(83i32) putchar(58i32) sp() e_i64(r0) sp() e_i64(r1) sp() e_i64(r2v) sp() e_i64(r3) nl()   /* "S: 73 -958 -12391 218098" */
    if r0 != 73i64 { return 14u64 }
    if r1 != (0i64 - 958i64) { return 14u64 }
    if r2v != (0i64 - 12391i64) { return 14u64 }
    if r3 != 218098i64 { return 14u64 }

    /* ══ ARM C: the twin weld -- Bareiss and 16-prime CRT agree coefficient-for-coefficient. */
    QF[0u64] = 0i64 - 2i64   QF[1u64] = 0i64   QF[2u64] = 0i64   QF[3u64] = 1i64          /* x^3 - 2 */
    QG[0u64] = 0i64 - 3i64   QG[1u64] = 0i64   QG[2u64] = 1i64                            /* x^2 - 3 */
    let c1 : i64 = rs_sum((&QF) as u64, 3i64, (&QG) as u64, 2i64, (&QO2) as u64)
    let c2 : i64 = rs_sum_big((&QF) as u64, 3i64, (&QG) as u64, 2i64, (&QO) as u64)
    if c1 != 6i64 { return 15u64 }
    if c2 != 6i64 { return 15u64 }
    let mut ok : i64 = 1i64
    i = 0u64
    while i <= 6u64 { if QO[i] != QO2[i] { ok = 0i64 }   i = i + 1u64 }
    putchar(67i32) putchar(58i32) sp() e_i64(ok) nl()                                    /* "C: 1" */
    if ok != 1i64 { return 15u64 }

    /* ══ ARM D: a = 2^40 -- the constant term exceeds i64; v2 must REFUSE. */
    QF[0u64] = 0i64 - 1099511627776i64   QF[1u64] = 0i64   QF[2u64] = 0i64   QF[3u64] = 1i64
    let d2 : i64 = rs_sum_big((&QF) as u64, 3i64, (&QG) as u64, 2i64, (&QO) as u64)
    putchar(68i32) putchar(58i32) sp() e_i64(d2) nl()                                    /* "D: -1" */
    if d2 != (0i64 - 1i64) { return 16u64 }

    return 99u64
}
