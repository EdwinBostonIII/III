/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\217_e2e_hip_idoc.iii
 *
 * III conformance corpus 217 -- end-to-end Intent Calculus v1.0 stack:
 * NL utterance -> HIP -> intent -> IDoc envelope -> validate -> resolve
 * facet -> recover intent.
 *
 * Pipeline:
 *   1. hip_resolve("send buffer") -> single CONVEY intent_id.
 *   2. Pack the 8-byte intent_id as the EXTRACT_DATA facet of an IDoc.
 *   3. babel_wire_finalize -> verifiable envelope.
 *   4. idoc_validate confirms structure + CRC.
 *   5. idoc_resolve_facet for caps=0x02 -> recovers intent_id pointer.
 *   6. Re-read intent_id; intent_goal_kind verifies CONVEY.
 *
 * This exercises every layer of the wire stack + NL surface + calculus
 * primitives in a single integration test.
 *
 * Exit code: 99 on full pass; 1..N on specific failure.
 */

module corpus_217

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn hip_resolve(text_ptr: u64, text_len: u32, out_cands_ptr: u64, out_meta_ptr: u64) -> i32 from "hip.iii"
extern @abi(c-msvc-x64) fn intent_goal_kind(p: u64) -> u8 from "intent.iii"

extern @abi(c-msvc-x64) fn babel_wire_init(out_buf: u64) -> i32 from "babel_wire.iii"
extern @abi(c-msvc-x64) fn babel_wire_set_seal_id(out_buf: u64, seal_id: u64) -> i32 from "babel_wire.iii"
extern @abi(c-msvc-x64) fn babel_wire_set_intent_id(out_buf: u64, intent_id: u64) -> i32 from "babel_wire.iii"
extern @abi(c-msvc-x64) fn babel_wire_set_ctx_digest(out_buf: u64, digest_ptr: u64) -> i32 from "babel_wire.iii"
extern @abi(c-msvc-x64) fn babel_wire_set_facet(out_buf: u64, facet_id: u8) -> i32 from "babel_wire.iii"
extern @abi(c-msvc-x64) fn babel_wire_header_bytes() -> u32 from "babel_wire.iii"

extern @abi(c-msvc-x64) fn idoc_pack_payload(facet_ids_ptr: u64, facet_data_ptrs_ptr: u64, facet_lens_ptr: u64, out_payload_ptr: u64) -> u32 from "idoc.iii"
extern @abi(c-msvc-x64) fn idoc_finalize(out_buf: u64, payload_len: u32) -> u32 from "idoc.iii"
extern @abi(c-msvc-x64) fn idoc_resolve_facet(idoc_buf: u64, my_caps: u8, out_facet_data_ptr: u64, out_facet_len_ptr: u64) -> u8 from "idoc.iii"
extern @abi(c-msvc-x64) fn idoc_validate(idoc_buf: u64, idoc_len: u32) -> u8 from "idoc.iii"

const C217_CONVEY : u8 = 3u8

fn _read_u32(buf: *u8, off: u64) -> u32 {
    let b0 : u32 = (buf[off] as u32) & 0xFFu32
    let b1 : u32 = ((buf[off + 1u64] as u32) & 0xFFu32) << 8u32
    let b2 : u32 = ((buf[off + 2u64] as u32) & 0xFFu32) << 16u32
    let b3 : u32 = ((buf[off + 3u64] as u32) & 0xFFu32) << 24u32
    return b0 | b1 | b2 | b3
}

fn _read_u64(buf: *u8, off: u64) -> u64 {
    let mut v : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 8u64 {
        v = v | (((buf[off + i] as u64) & 0xFFu64) << (i * 8u64))
        i = i + 1u64
    }
    return v
}

fn _put(buf: *u8, off: u64, b: u8) -> u64 {
    buf[off] = b
    return off + 1u64
}

fn _phrase_send_buffer(buf: *u8) -> u32 {
    let mut o : u64 = 0u64
    o = _put(buf, o, 115u8); o = _put(buf, o, 101u8); o = _put(buf, o, 110u8); o = _put(buf, o, 100u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 98u8); o = _put(buf, o, 117u8); o = _put(buf, o, 102u8); o = _put(buf, o, 102u8); o = _put(buf, o, 101u8); o = _put(buf, o, 114u8)
    return o as u32
}

fn main() -> u64 {
    /* === Stage 1: HIP resolve === */
    let text  : *u8 = malloc(64u64)
    let cands : *u8 = malloc(64u64)
    let meta  : *u8 = malloc(16u64)
    if text  as u64 == 0u64 { return 1u64 }
    if cands as u64 == 0u64 { return 2u64 }
    if meta  as u64 == 0u64 { return 3u64 }
    let mut zi : u64 = 0u64
    while zi < 16u64 { meta[zi] = 0u8; zi = zi + 1u64 }

    let len_t : u32 = _phrase_send_buffer(text)
    let rc_h : i32 = hip_resolve(text as u64, len_t, cands as u64, meta as u64)
    if rc_h != 0i32 { return 4u64 }
    if _read_u32(meta, 0u64) != 1u32 { return 5u64 }   /* one candidate */

    let intent_id : u64 = _read_u64(cands, 0u64)
    if intent_id == 0u64 { return 6u64 }
    if intent_goal_kind(intent_id) != C217_CONVEY { return 7u64 }

    /* === Stage 2: Pack intent_id as IDoc EXTRACT_DATA facet === */
    let env : *u8 = malloc(512u64)
    if env as u64 == 0u64 { return 8u64 }
    let env_u : u64 = env as u64

    babel_wire_init(env_u)
    babel_wire_set_seal_id(env_u, 0xE2EBABE0u64)
    babel_wire_set_intent_id(env_u, intent_id)

    /* ctx_digest: zero-filled. */
    let dig : *u8 = malloc(32u64)
    let mut di : u64 = 0u64
    while di < 32u64 { dig[di] = 0u8; di = di + 1u64 }
    babel_wire_set_ctx_digest(env_u, dig as u64)

    babel_wire_set_facet(env_u, 0x02u8)   /* EXTRACT_DATA in mask */

    /* Facet payload: 8 bytes of intent_id (LE). */
    let facet_data : *u8 = malloc(8u64)
    let mut bi : u64 = 0u64
    while bi < 8u64 {
        facet_data[bi] = ((intent_id >> (bi * 8u64)) & 0xFFu64) as u8
        bi = bi + 1u64
    }

    let fids : *u8 = malloc(4u64)
    let fdpa : *u8 = malloc(32u64)
    let flna : *u8 = malloc(16u64)
    fids[0u64] = 0x02u8
    fids[1u64] = 0u8
    fids[2u64] = 0u8
    fids[3u64] = 0u8
    /* fdpa[0] = facet_data ptr; rest = 0. Manual byte-wise u64 store. */
    let fd_u : u64 = facet_data as u64
    let mut fp : u64 = 0u64
    while fp < 8u64 {
        fdpa[fp] = ((fd_u >> (fp * 8u64)) & 0xFFu64) as u8
        fp = fp + 1u64
    }
    let mut fp2 : u64 = 8u64
    while fp2 < 32u64 { fdpa[fp2] = 0u8; fp2 = fp2 + 1u64 }
    /* flna[0..4] = 8u32 LE (facet length). */
    flna[0u64] = 8u8
    flna[1u64] = 0u8; flna[2u64] = 0u8; flna[3u64] = 0u8
    let mut fl2 : u64 = 4u64
    while fl2 < 16u64 { flna[fl2] = 0u8; fl2 = fl2 + 1u64 }

    let hb : u32 = babel_wire_header_bytes()
    let payload_addr : u64 = env_u + (hb as u64)
    let plen : u32 = idoc_pack_payload(fids as u64, fdpa as u64, flna as u64, payload_addr)
    /* expected: 1 facet * (5 header + 8 payload) = 13 bytes. */
    if plen != 13u32 { return 9u64 }

    let total : u32 = idoc_finalize(env_u, plen)
    if total != (hb + plen) { return 10u64 }

    /* === Stage 3: validate === */
    if idoc_validate(env_u, total) != 1u8 { return 11u64 }

    /* === Stage 4: resolve facet (consumer caps include EXTRACT_DATA) === */
    let ofd_p : *u8 = malloc(8u64)
    let ofl_p : *u8 = malloc(4u64)
    let ofd_u : u64 = ofd_p as u64
    let ofl_u : u64 = ofl_p as u64
    if idoc_resolve_facet(env_u, 0x02u8, ofd_u, ofl_u) != 1u8 { return 12u64 }

    /* === Stage 5: recover intent_id and verify === */
    let ofd_pp : *u64 = ofd_u as *u64
    /* iiis-0's u32 and u64 pointer indexing emits 8-byte movq -- reads inside the
     * wire buffer are safe because the buffer has plenty of slack. */
    let recovered_addr : u64 = ofd_pp[0u64]
    let rb : *u8 = recovered_addr as *u8
    let mut recovered : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        recovered = recovered | (((rb[k] as u64) & 0xFFu64) << (k * 8u64))
        k = k + 1u64
    }
    if recovered != intent_id { return 13u64 }
    if intent_goal_kind(recovered) != C217_CONVEY { return 14u64 }

    free(text)
    free(cands)
    free(meta)
    free(env)
    free(dig)
    free(facet_data)
    free(fids)
    free(fdpa)
    free(flna)
    free(ofd_p)
    free(ofl_p)
    return 99u64
}
