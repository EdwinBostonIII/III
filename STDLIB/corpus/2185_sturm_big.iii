/* 2185_sturm_big.iii -- GATE for the BIGINT PRS (Turing-substrate charter V-I.1): root counting past
 * the i64 chain wall, with the i64 organ's honest garbage as the twin.
 *
 * A -- THE WALL, CROSSED: the exact degree-12 polynomial of 2179 (min poly of 2^(1/4)+3^(1/3)).  The
 *   i64 Sturm chain OVERFLOWS silently (root_count != 2 -- the 2179 finding, now the pinned twin);
 *   sturm2 counts EXACTLY 2 real roots in [-4,4] and isolates them in (0,1] and (2,3] -- agreeing with
 *   the independent exact-Horner sign brackets gated in 2179.
 * B -- THE CRT->PRS WELD: rs_sum_big derives the DEGREE-16 defining polynomial of 2^(1/4) + 3^(1/4)
 *   in-KAT; sturm2 counts its 4 real roots (+-2^(1/4) +- 3^(1/4)) and isolates 2^(1/4)+3^(1/4) in
 *   (25/10, 26/10] and 3^(1/4)-2^(1/4) in (1/10, 2/10].  Two charter increments, one pipeline.
 * C -- MULTIPLICITY AT DEPTH: (x^4-10x^2+1)^2 -- the squared chain overflows i64 (v1 root_mult is
 *   garbage there, printed); root_mult2 certifies multiplicity 2 at sqrt2+sqrt3 in (31/10, 32/10].
 * D -- refusal at the WIDENED envelope: degree 481 refused (-1), never garbage.
 * E -- the old boundary now DELIVERS: x^25 - 2 counted (1 root in (1,2], 1 in (-2,2] -- odd degree,
 *   ONE real root) -- degree 25 was the refusal arm before the pool went past stride 32.
 * F -- a former boundary: x^60 - 2 counted (1 root in (1,2], 2 in (-2,2]).
 * G -- the CURRENT boundary itself: x^120 - 2 counted through a degree-120 chain (1 in (1,2],
 *   2 in (-2,2]).
 * H -- THE HANDLE DOOR, SELF-VERIFYING: chain evaluation at dyadic rationals with BIGINT
 *   numerators (root_count2_h).  (2^70/2^70, 2^71/2^70] counts like (1,2] (equivalence);
 *   the negative mirror counts -sqrt2; then sqrt2 is refined 100 DEEP through the door and the
 *   final window (L/2^100, (L+1)/2^100] is verified by EXACT SQUARING (L^2 < 2*4^100 <= (L+1)^2)
 *   -- the gate carries NO transcribed 100-bit constant; the certificate is computed.
 *
 * exit 99 = pass;  10 A twin failed to diverge;  11 A count/brackets;  12 B;  13 C;  14 D;
 * 15 E;  16 F;  17 G;  18 H */
module corpus_2185_sturm_big

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn sturm_build(coeffs_ptr: u64, deg: i64) -> i64 from "sturm.iii"
extern @abi(c-msvc-x64) fn root_count(an: i64, ad: i64, bn: i64, bd: i64) -> i64 from "sturm.iii"
extern @abi(c-msvc-x64) fn sturm2_build(coeffs_ptr: u64, deg: i64) -> i64 from "sturm_big.iii"
extern @abi(c-msvc-x64) fn root_count2(an: i64, ad: i64, bn: i64, bd: i64) -> i64 from "sturm_big.iii"
extern @abi(c-msvc-x64) fn root_mult2(coeffs_ptr: u64, deg: i64, an: i64, ad: i64, bn: i64, bd: i64) -> i64 from "sturm_big.iii"
extern @abi(c-msvc-x64) fn root_count2_h(lh: u64, lsgn: i64, hh: u64, hsgn: i64, kd: i64) -> i64 from "sturm_big.iii"
extern @abi(c-msvc-x64) fn root_count2_q(lnh: u64, lsgn: i64, ldh: u64, hnh: u64, hsgn: i64, hdh: u64) -> i64 from "sturm_big.iii"
extern @abi(c-msvc-x64) fn root_mult2_cur_h(lh: u64, lsgn: i64, hh: u64, hsgn: i64, kd: i64) -> i64 from "sturm_big.iii"
extern @abi(c-msvc-x64) fn sturm2_in_begin(deg: i64) -> i32 from "sturm_big.iii"
extern @abi(c-msvc-x64) fn sturm2_in_limb(i: i64, j: i64, v: u64) -> i32 from "sturm_big.iii"
extern @abi(c-msvc-x64) fn sturm2_in_set(i: i64, sgn: i64, nlimbs: i64) -> i32 from "sturm_big.iii"
extern @abi(c-msvc-x64) fn rs_sum_big(fp: u64, degf: i64, gp: u64, degg: i64, outp: u64) -> i64 from "resultant.iii"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(arena: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_add(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mul(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mul_u64(arena: u64, a: u64, scalar: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_cmp(a: u64, b: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop_arena(arena: u64) -> i32 from "bigint.iii"

fn e_i64(v: i64) -> i32 { if v < 0i64 { putchar(45i32)   return e_i64(0i64 - v) }   if v >= 10i64 { e_i64(v / 10i64) }   putchar(((v % 10i64) + 48i64) as i32)   return 0i32 }
fn sp() -> i32 { putchar(32i32)   return 0i32 }   fn nl() -> i32 { putchar(10i32)   return 0i32 }

var BP : [i64; 512]   var BF : [i64; 10]   var BG : [i64; 10]

fn main() -> u64 {
    /* ══ A: the degree-12 wall. */
    BP[0u64] = 73i64    BP[1u64] = 0i64 - 144i64   BP[2u64] = 0i64 - 540i64   BP[3u64] = 0i64 - 108i64
    BP[4u64] = 12i64    BP[5u64] = 0i64 - 288i64   BP[6u64] = 54i64           BP[7u64] = 0i64
    BP[8u64] = 0i64 - 6i64   BP[9u64] = 0i64 - 12i64   BP[10u64] = 0i64   BP[11u64] = 0i64   BP[12u64] = 1i64
    sturm_build((&BP) as u64, 12i64)
    let n1 : i64 = root_count(0i64 - 4i64, 1i64, 4i64, 1i64)
    if sturm2_build((&BP) as u64, 12i64) < 0i64 { return 11u64 }
    let n2 : i64 = root_count2(0i64 - 4i64, 1i64, 4i64, 1i64)
    let b1 : i64 = root_count2(0i64, 1i64, 1i64, 1i64)
    let b2 : i64 = root_count2(2i64, 1i64, 3i64, 1i64)
    putchar(65i32) putchar(58i32) sp() e_i64(n1) sp() e_i64(n2) sp() e_i64(b1) sp() e_i64(b2) nl()   /* "A: <garbage> 2 1 1" */
    if n1 == 2i64 { return 10u64 }                          /* the i64 chain must FAIL here (2179 finding) */
    if n2 != 2i64 { return 11u64 }
    if b1 != 1i64 { return 11u64 }
    if b2 != 1i64 { return 11u64 }

    /* ══ B: the CRT -> bigint-PRS pipeline at degree 16. */
    BF[0u64] = 0i64 - 2i64   BF[1u64] = 0i64   BF[2u64] = 0i64   BF[3u64] = 0i64   BF[4u64] = 1i64
    BG[0u64] = 0i64 - 3i64   BG[1u64] = 0i64   BG[2u64] = 0i64   BG[3u64] = 0i64   BG[4u64] = 1i64
    let d16 : i64 = rs_sum_big((&BF) as u64, 4i64, (&BG) as u64, 4i64, (&BP) as u64)
    if d16 != 16i64 { return 12u64 }
    if sturm2_build((&BP) as u64, 16i64) < 0i64 { return 12u64 }
    let m4 : i64 = root_count2(0i64 - 4i64, 1i64, 4i64, 1i64)
    let g1 : i64 = root_count2(25i64, 10i64, 26i64, 10i64)
    let g2 : i64 = root_count2(1i64, 10i64, 2i64, 10i64)
    putchar(66i32) putchar(58i32) sp() e_i64(d16) sp() e_i64(m4) sp() e_i64(g1) sp() e_i64(g2) nl()   /* "B: 16 4 1 1" */
    if m4 != 4i64 { return 12u64 }
    if g1 != 1i64 { return 12u64 }
    if g2 != 1i64 { return 12u64 }

    /* ══ C: multiplicity past the wall -- (x^4-10x^2+1)^2. */
    BP[0u64] = 1i64   BP[1u64] = 0i64   BP[2u64] = 0i64 - 20i64   BP[3u64] = 0i64   BP[4u64] = 102i64
    BP[5u64] = 0i64   BP[6u64] = 0i64 - 20i64   BP[7u64] = 0i64   BP[8u64] = 1i64
    let mb : i64 = root_mult2((&BP) as u64, 8i64, 31i64, 10i64, 32i64, 10i64)
    putchar(67i32) putchar(58i32) sp() e_i64(mb) nl()                                                /* "C: 2" */
    if mb != 2i64 { return 13u64 }

    /* ══ D: the WIDENED envelope refuses at its true boundary. */
    let rd : i64 = sturm2_build((&BP) as u64, 481i64)
    putchar(68i32) putchar(58i32) sp() e_i64(rd) nl()                                                /* "D: -1" */
    if rd != (0i64 - 1i64) { return 14u64 }

    /* ══ E: the OLD boundary (degree 25, the former refusal arm) now delivers. */
    let mut z : i64 = 0i64
    while z <= 480i64 { BP[z as u64] = 0i64   z = z + 1i64 }
    BP[0u64] = 0i64 - 2i64   BP[25u64] = 1i64
    if sturm2_build((&BP) as u64, 25i64) < 0i64 { return 15u64 }
    let e1 : i64 = root_count2(1i64, 1i64, 2i64, 1i64)
    let e2 : i64 = root_count2(0i64 - 2i64, 1i64, 2i64, 1i64)
    putchar(69i32) putchar(58i32) sp() e_i64(e1) sp() e_i64(e2) nl()                                 /* "E: 1 1" */
    if e1 != 1i64 { return 15u64 }
    if e2 != 1i64 { return 15u64 }                       /* odd degree: ONE real root */

    /* ══ F: a former boundary -- degree 60. */
    BP[25u64] = 0i64   BP[60u64] = 1i64
    if sturm2_build((&BP) as u64, 60i64) < 0i64 { return 16u64 }
    let f1 : i64 = root_count2(1i64, 1i64, 2i64, 1i64)
    let f2 : i64 = root_count2(0i64 - 2i64, 1i64, 2i64, 1i64)
    putchar(70i32) putchar(58i32) sp() e_i64(f1) sp() e_i64(f2) nl()                                 /* "F: 1 2" */
    if f1 != 1i64 { return 16u64 }
    if f2 != 2i64 { return 16u64 }

    /* ══ G: the current boundary itself -- degree 120. */
    BP[60u64] = 0i64   BP[120u64] = 1i64
    if sturm2_build((&BP) as u64, 120i64) < 0i64 { return 17u64 }
    let ga : i64 = root_count2(1i64, 1i64, 2i64, 1i64)
    let gb : i64 = root_count2(0i64 - 2i64, 1i64, 2i64, 1i64)
    putchar(71i32) putchar(58i32) sp() e_i64(ga) sp() e_i64(gb) nl()                                 /* "G: 1 2" */
    if ga != 1i64 { return 17u64 }
    if gb != 2i64 { return 17u64 }

    /* ══ G2: a former boundary -- degree 240. */
    BP[120u64] = 0i64   BP[240u64] = 1i64
    if sturm2_build((&BP) as u64, 240i64) < 0i64 { return 17u64 }
    let g2a : i64 = root_count2(1i64, 1i64, 2i64, 1i64)
    let g2b : i64 = root_count2(0i64 - 2i64, 1i64, 2i64, 1i64)
    putchar(71i32) putchar(50i32) putchar(58i32) sp() e_i64(g2a) sp() e_i64(g2b) nl()                /* "G2: 1 2" */
    if g2a != 1i64 { return 17u64 }
    if g2b != 2i64 { return 17u64 }

    /* ══ G3: the CURRENT boundary -- degree 480. */
    BP[240u64] = 0i64   BP[480u64] = 1i64
    if sturm2_build((&BP) as u64, 480i64) < 0i64 { return 17u64 }
    let g3a : i64 = root_count2(1i64, 1i64, 2i64, 1i64)
    let g3b : i64 = root_count2(0i64 - 2i64, 1i64, 2i64, 1i64)
    putchar(71i32) putchar(51i32) putchar(58i32) sp() e_i64(g3a) sp() e_i64(g3b) nl()                /* "G3: 1 2" */
    if g3a != 1i64 { return 17u64 }
    if g3b != 2i64 { return 17u64 }

    /* ══ H: the handle door, self-verifying.  Chain of x^2 - 2. */
    BP[480u64] = 0i64   BP[0u64] = 0i64 - 2i64   BP[2u64] = 1i64
    if sturm2_build((&BP) as u64, 2i64) < 0i64 { return 18u64 }
    let ar : u64 = arena_new(16777216u64)
    if ar == 0u64 { return 18u64 }
    /* H1: (2^70/2^70, 2^71/2^70] counts EXACTLY like (1,2]. */
    let mut lh : u64 = bigint_from_u64(ar, 1u64)
    let mut hh : u64 = bigint_from_u64(ar, 1u64)
    let mut q : i64 = 0i64
    while q < 70i64 { let t : u64 = bigint_mul_u64(ar, lh, 2u64)   bigint_drop(lh)   lh = t   q = q + 1i64 }
    q = 0i64
    while q < 71i64 { let t : u64 = bigint_mul_u64(ar, hh, 2u64)   bigint_drop(hh)   hh = t   q = q + 1i64 }
    let h1 : i64 = root_count2_h(lh, 1i64, hh, 1i64, 70i64)
    /* H2: the negative mirror (-2^71/2^70, -2^70/2^70] holds -sqrt2. */
    let h2 : i64 = root_count2_h(hh, 0i64 - 1i64, lh, 0i64 - 1i64, 70i64)
    bigint_drop(lh)   bigint_drop(hh)
    /* H3: refine sqrt2 100 DEEP through the door; window numerators stay width 1. */
    let mut wl : u64 = bigint_from_u64(ar, 1u64)
    let mut wh : u64 = bigint_from_u64(ar, 2u64)
    let mut k : i64 = 0i64
    let mut hok : i64 = 1i64
    while k < 100i64 {
        let l2 : u64 = bigint_mul_u64(ar, wl, 2u64)
        let mid : u64 = bigint_add(ar, wl, wh)
        if l2 == 0u64 { hok = 0i64 }
        if mid == 0u64 { hok = 0i64 }
        if hok == 1i64 {
            let c : i64 = root_count2_h(l2, 1i64, mid, 1i64, k + 1i64)
            if c < 0i64 { hok = 0i64   bigint_drop(l2)   bigint_drop(mid) }
            else { if c == 1i64 {
                bigint_drop(wl)   bigint_drop(wh)
                wl = l2   wh = mid
            } else {
                let h2x : u64 = bigint_mul_u64(ar, wh, 2u64)
                bigint_drop(wl)   bigint_drop(wh)   bigint_drop(l2)
                wl = mid   wh = h2x
            } }
        }
        if hok == 0i64 { k = 100i64 } else { k = k + 1i64 }
    }
    let mut h3 : i64 = 0i64
    let mut h4 : i64 = 0i64
    let mut h5 : i64 = 0i64
    if hok == 1i64 {
        h3 = root_count2_h(wl, 1i64, wh, 1i64, 100i64)
        /* the SQUARING CERTIFICATE: wl^2 < 2*4^100 <= wh^2, and wh == wl + 1 (width one). */
        let one : u64 = bigint_from_u64(ar, 1u64)
        let wl1 : u64 = bigint_add(ar, wl, one)
        if bigint_cmp(wl1, wh) == 0i32 { h4 = 1i64 }
        let sq_l : u64 = bigint_mul(ar, wl, wl)
        let sq_h : u64 = bigint_mul(ar, wh, wh)
        let mut two : u64 = bigint_from_u64(ar, 2u64)
        q = 0i64
        while q < 200i64 { let t : u64 = bigint_mul_u64(ar, two, 2u64)   bigint_drop(two)   two = t   q = q + 1i64 }
        if bigint_cmp(sq_l, two) < 0i32 { if bigint_cmp(sq_h, two) >= 0i32 { h5 = 1i64 } }
        bigint_drop(one)   bigint_drop(wl1)   bigint_drop(sq_l)   bigint_drop(sq_h)   bigint_drop(two)
    }
    bigint_drop(wl)   bigint_drop(wh)
    bigint_drop_arena(ar)
    arena_drop(ar)
    putchar(72i32) putchar(58i32) sp() e_i64(h1) sp() e_i64(h2) sp() e_i64(hok) sp() e_i64(h3) sp() e_i64(h4) sp() e_i64(h5) nl()
    /* "H: 1 1 1 1 1 1" */
    if h1 != 1i64 { return 18u64 }
    if h2 != 1i64 { return 18u64 }
    if hok != 1i64 { return 18u64 }
    if h3 != 1i64 { return 18u64 }
    if h4 != 1i64 { return 18u64 }
    if h5 != 1i64 { return 18u64 }

    /* ══ I: the GENERAL-RATIONAL door + the DEEP MULTIPLICITY door.  x^2 - 2's chain queried at
     * NON-DYADIC rationals (denominator 3): sqrt2 in (4/3, 3/2] but not in (2/3, 4/3]; then
     * (x^2-2)^2 through root_mult2_cur_h: multiplicity 2 at the dyadic handle window (1, 3/2]. */
    BP[240u64] = 0i64   BP[0u64] = 0i64 - 2i64   BP[2u64] = 1i64
    if sturm2_build((&BP) as u64, 2i64) < 0i64 { return 19u64 }
    let ar2 : u64 = arena_new(1048576u64)
    if ar2 == 0u64 { return 19u64 }
    let qn4 : u64 = bigint_from_u64(ar2, 4u64)
    let qd3 : u64 = bigint_from_u64(ar2, 3u64)
    let qn3 : u64 = bigint_from_u64(ar2, 3u64)
    let qd2 : u64 = bigint_from_u64(ar2, 2u64)
    let qn2 : u64 = bigint_from_u64(ar2, 2u64)
    let i1 : i64 = root_count2_q(qn4, 1i64, qd3, qn3, 1i64, qd2)     /* (4/3, 3/2] -> 1 */
    let i2 : i64 = root_count2_q(qn2, 1i64, qd3, qn4, 1i64, qd3)     /* (2/3, 4/3] -> 0 */
    /* (x^2-2)^2 = 4 0 -4 0 1 through the deep multiplicity door at (2/2, 3/2] */
    if sturm2_in_begin(4i64) != 0i32 { return 19u64 }
    sturm2_in_limb(0i64, 0i64, 4u64)   sturm2_in_set(0i64, 1i64, 1i64)
    sturm2_in_set(1i64, 0i64, 0i64)
    sturm2_in_limb(2i64, 0i64, 4u64)   sturm2_in_set(2i64, 0i64 - 1i64, 1i64)
    sturm2_in_set(3i64, 0i64, 0i64)
    sturm2_in_limb(4i64, 0i64, 1u64)   sturm2_in_set(4i64, 1i64, 1i64)
    let i3 : i64 = root_mult2_cur_h(qn2, 1i64, qn3, 1i64, 1i64)
    bigint_drop(qn4)   bigint_drop(qd3)   bigint_drop(qn3)   bigint_drop(qd2)   bigint_drop(qn2)
    bigint_drop_arena(ar2)
    arena_drop(ar2)
    putchar(73i32) putchar(58i32) sp() e_i64(i1) sp() e_i64(i2) sp() e_i64(i3) nl()                  /* "I: 1 0 2" */
    if i1 != 1i64 { return 19u64 }
    if i2 != 0i64 { return 19u64 }
    if i3 != 2i64 { return 19u64 }

    return 99u64
}
