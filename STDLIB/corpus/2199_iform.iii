/* 2199_iform.iii -- GATE for iform.iii: the sovereign .ixr image container PROVABLY supersedes .bmp.
 *
 * ARMS (each a different, falsifiable rule -- red if the property fails):
 *   RT     LOSSLESS ROUND-TRIP: a framebuffer with VARYING ALPHA -> .ixr -> read back is BIT-FOR-BIT identical
 *          (every 0xAARRGGBB word, alpha included).  The 24-bit BMP writer physically cannot carry these alpha bytes.
 *   SV     SELF-VERIFY: iform_verify on a freshly-written file == 0 (embedded sig matches a fresh payload hash).
 *   TAMPER INTEGRITY: flip ONE payload byte on disk -> iform_verify == 2 (detected).  BMP has no integrity field.
 *   HDR    SELF-DESCRIBING: read back reports the exact width/height (no top-down/bottom-up or palette ambiguity).
 *   BIND   GENERATOR-BOUND: a raster written with a generator signature reads that signature back intact.
 *   DET    DETERMINISM: the payload signature is a pure function of the pixels (stable + pinned KAT value).
 *   SUP    SUPERIORITY WITNESS: the round-tripped image contains a pixel whose alpha is neither 0 nor 255 -- a value
 *          the legacy 24-bit BMP path cannot represent, yet .ixr preserved it exactly.
 *
 *   exit 99 = all correct.  10 RT  20 SV  30 TAMPER  40 HDR  50 BIND  60 DET  70 SUP */
module corpus_2199_iform

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

extern @abi(c-msvc-x64) fn iform_write(fb: u64, w: u32, h: u32, path: u64) -> i32 from "iform.iii"
extern @abi(c-msvc-x64) fn iform_write_bound(fb: u64, w: u32, h: u32, bind: u64, path: u64) -> i32 from "iform.iii"
extern @abi(c-msvc-x64) fn iform_read(path: u64, fb_out: u64, maxwords: u64) -> i64 from "iform.iii"
extern @abi(c-msvc-x64) fn iform_verify(path: u64) -> i32 from "iform.iii"
extern @abi(c-msvc-x64) fn iform_last_w() -> u32 from "iform.iii"
extern @abi(c-msvc-x64) fn iform_last_h() -> u32 from "iform.iii"
extern @abi(c-msvc-x64) fn iform_last_bind() -> u64 from "iform.iii"
extern @abi(c-msvc-x64) fn iform_sig_words(base: u64, n: u64) -> u64 from "iform.iii"

/* raw file access for the on-disk TAMPER arm */
extern @abi(c-msvc-x64) fn CreateFileA(name: u64, access: u32, share: u32, sec: u64, disp: u32, flags: u32, tmpl: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn WriteFile(h: u64, buf: u64, n: u32, written: u64, ov: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn ReadFile(h: u64, buf: u64, n: u32, red: u64, ov: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> i32 from "kernel32"

const W : u64 = 64u64
const H : u64 = 48u64
const N : u64 = 3072u64                 /* W*H */

var FB   : [u32; 3072]
var FB2  : [u32; 3072]
var TBUF : [u8; 20000]
var TCNT : [u32; 1]
var PATH : [u8; 16]

fn e_u64(v: u64) -> i32 { if v >= 10u64 { e_u64(v / 10u64) }   putchar(((v % 10u64) + 48u64) as i32)   return 0i32 }
fn sp() -> i32 { putchar(32i32)   return 0i32 }
fn nl() -> i32 { putchar(10i32)   return 0i32 }
fn lab(a: i32, b: i32, c: i32) -> i32 { putchar(a) putchar(b) putchar(c) putchar(58i32) sp()   return 0i32 }

fn set_path() -> i32 {
    PATH[0u64]=105u8 PATH[1u64]=102u8 PATH[2u64]=111u8 PATH[3u64]=114u8 PATH[4u64]=109u8    /* iform */
    PATH[5u64]=95u8  PATH[6u64]=107u8 PATH[7u64]=97u8  PATH[8u64]=116u8                      /* _kat */
    PATH[9u64]=46u8  PATH[10u64]=105u8 PATH[11u64]=120u8 PATH[12u64]=114u8 PATH[13u64]=0u8   /* .ixr\0 */
    return 0i32
}

/* fill FB with a deterministic pattern whose alpha byte VARIES across 0,1..255 (many mid values). */
fn fill() -> i32 {
    let mut i : u64 = 0u64
    while i < N {
        let a : u32 = ((i * 7u64) & 255u64) as u32
        let r : u32 = ((i * 5u64) & 255u64) as u32
        let g : u32 = ((i * 3u64) & 255u64) as u32
        let b : u32 = (i & 255u64) as u32
        FB[i] = (a << 24u32) | (r << 16u32) | (g << 8u32) | b
        i = i + 1u64
    }
    return 0i32
}

fn main() -> u64 {
    set_path()
    fill()
    let mut FRT : u64 = 0u64   let mut FSV : u64 = 0u64   let mut FTM : u64 = 0u64
    let mut FHD : u64 = 0u64   let mut FBD : u64 = 0u64   let mut FDT : u64 = 0u64   let mut FSU : u64 = 0u64

    /* ── DET: payload signature is a pure function of the pixels, and pinned. */
    let d1 : u64 = iform_sig_words((&FB) as u64, N)
    let d2 : u64 = iform_sig_words((&FB) as u64, N)
    if d1 != d2 { FDT = FDT + 1u64 }
    if d1 == 0u64 { FDT = FDT + 1u64 }
    if d1 != 15838609909650423589u64 { FDT = FDT + 1u64 }   /* PINNED: any pattern/hash change reddens this */
    lab(68i32,69i32,84i32) e_u64(d1) nl()

    /* ── RT + BIND: write bound, read back, compare bit-for-bit. */
    let wrc : i32 = iform_write_bound((&FB) as u64, W as u32, H as u32, 12345678901234u64, (&PATH) as u64)
    if wrc != 0i32 { FRT = FRT + 1u64 }
    let rr : i64 = iform_read((&PATH) as u64, (&FB2) as u64, N)
    if rr < 0i64 { FRT = FRT + 1u64 }
    let mut diff : u64 = 0u64   let mut mid_alpha : u64 = 0u64
    let mut i : u64 = 0u64
    while i < N {
        if FB[i] != FB2[i] { diff = diff + 1u64 }
        let a : u32 = FB2[i] >> 24u32
        if a != 0u32 { if a != 255u32 { mid_alpha = mid_alpha + 1u64 } }
        i = i + 1u64
    }
    if diff != 0u64 { FRT = FRT + 1u64 }
    lab(82i32,84i32,68i32) e_u64(diff) nl()                          /* RTD: <mismatches> (want 0) */

    /* ── HDR: exact dimensions recovered. */
    if iform_last_w() != W as u32 { FHD = FHD + 1u64 }
    if iform_last_h() != H as u32 { FHD = FHD + 1u64 }
    if rr != (((W as i64) << 32i64) | (H as i64)) { FHD = FHD + 1u64 }
    lab(72i32,68i32,82i32) e_u64(iform_last_w()) sp() e_u64(iform_last_h()) nl()

    /* ── BIND: generator signature survives. */
    if iform_last_bind() != 12345678901234u64 { FBD = FBD + 1u64 }
    lab(66i32,78i32,68i32) e_u64(iform_last_bind()) nl()

    /* ── SV: a good file verifies. */
    let v0 : i32 = iform_verify((&PATH) as u64)
    if v0 != 0i32 { FSV = FSV + 1u64 }
    lab(83i32,86i32,58i32) e_u64(v0 as u64) nl()

    /* ── TAMPER: read the file raw, flip one payload byte, write it back, re-verify -> must be detected (==2). */
    let hf : u64 = CreateFileA((&PATH) as u64, 2147483648u32, 1u32, 0u64, 3u32, 128u32, 0u64)
    if hf == 18446744073709551615u64 { FTM = FTM + 1u64 }
    ReadFile(hf, (&TBUF) as u64, 20000u32, (&TCNT) as u64, 0u64)
    CloseHandle(hf)
    let bp : *u8 = ((&TBUF) as u64 + 100u64) as *u8               /* a byte inside the payload (offset 100 > header 40) */
    bp[0u64] = bp[0u64] ^ 255u8
    let hf2 : u64 = CreateFileA((&PATH) as u64, 1073741824u32, 0u32, 0u64, 2u32, 128u32, 0u64)
    WriteFile(hf2, (&TBUF) as u64, TCNT[0u64], (&TCNT) as u64, 0u64)
    CloseHandle(hf2)
    let v1 : i32 = iform_verify((&PATH) as u64)
    if v1 != 2i32 { FTM = FTM + 1u64 }
    lab(84i32,77i32,58i32) e_u64(v1 as u64) nl()

    /* ── SUP: the losslessly round-tripped image held a mid-range alpha (not 0, not 255) -- unrepresentable in 24-bit BMP. */
    if mid_alpha == 0u64 { FSU = FSU + 1u64 }
    lab(83i32,85i32,80i32) e_u64(mid_alpha) nl()

    if FRT != 0u64 { return 10u64 }
    if FSV != 0u64 { return 20u64 }
    if FTM != 0u64 { return 30u64 }
    if FHD != 0u64 { return 40u64 }
    if FBD != 0u64 { return 50u64 }
    if FDT != 0u64 { return 60u64 }
    if FSU != 0u64 { return 70u64 }
    return 99u64
}
