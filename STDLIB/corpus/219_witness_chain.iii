/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\219_witness_chain.iii
 *
 * III conformance corpus 219 -- witness chain integrity.
 *
 * Asserts:
 *   1. witness_init clears the chain (count = 0, root = 0).
 *   2. witness_verify_chain on empty chain returns 1.
 *   3. After 3 witness_append calls, witness_count = 3.
 *   4. witness_verify_chain after appends still returns 1 (chain is
 *      consistent with the running root).
 *   5. After tampering with an entry's mhash byte, witness_verify_chain
 *      returns 0.
 *   6. witness_init re-clears (count = 0 again).
 *   7. witness_append_resolution, witness_append_ripple, witness_append_k
 *      all advance the count.
 *
 * Exit code: 99 on full pass; 1..N on specific failure.
 */

module corpus_219

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn witness_init() -> u32 from "witness.iii"
extern @abi(c-msvc-x64) fn witness_count() -> u32 from "witness.iii"
extern @abi(c-msvc-x64) fn witness_append(mhash_ptr: u64, cap_id: u64, epoch: u64) -> i32 from "witness.iii"
extern @abi(c-msvc-x64) fn witness_append_k(mhash_ptr: u64, cap_id: u64, k_fixed: u64) -> i32 from "witness.iii"
extern @abi(c-msvc-x64) fn witness_append_ripple(mhash_ptr: u64, ripple_result: u64) -> i32 from "witness.iii"
extern @abi(c-msvc-x64) fn witness_append_resolution(mhash_ptr: u64, cap_id: u64, k_fixed: u64, intent_id: u64) -> i32 from "witness.iii"
extern @abi(c-msvc-x64) fn witness_verify_chain() -> u8 from "witness.iii"
extern @abi(c-msvc-x64) fn witness_root_byte(i: u32) -> u32 from "witness.iii"
extern @abi(c-msvc-x64) fn witness_entry_mhash_byte(idx: u32, i: u32) -> u32 from "witness.iii"

fn main() -> u64 {
    /* Init clears the chain. */
    witness_init()
    if witness_count() != 0u32 { return 1u64 }
    if witness_verify_chain() != 1u8 { return 2u64 }

    /* Allocate a 32-byte mhash buffer. */
    let mhash_buf : *u8 = malloc(32u64)
    if mhash_buf as u64 == 0u64 { return 3u64 }
    let mut i : u64 = 0u64
    while i < 32u64 {
        mhash_buf[i] = ((i + 1u64) & 0xFFu64) as u8
        i = i + 1u64
    }

    /* Append 3 entries. */
    if witness_append(mhash_buf as u64, 1u64, 100u64) != 0i32 { return 4u64 }
    if witness_append(mhash_buf as u64, 2u64, 101u64) != 0i32 { return 5u64 }
    if witness_append(mhash_buf as u64, 3u64, 102u64) != 0i32 { return 6u64 }
    if witness_count() != 3u32 { return 7u64 }

    /* Chain should still verify. */
    if witness_verify_chain() != 1u8 { return 8u64 }

    /* Sample the root byte: at least one byte should be non-zero
     * after appends (entropy from the chained hashes). */
    let mut sum : u32 = 0u32
    let mut k : u32 = 0u32
    while k < 32u32 {
        sum = sum + (witness_root_byte(k) & 0xFFu32)
        k = k + 1u32
    }
    if sum == 0u32 { return 9u64 }

    /* witness_init is idempotent (no-op on subsequent calls). */
    witness_init()
    if witness_count() != 3u32 { return 10u64 }
    if witness_verify_chain() != 1u8 { return 11u64 }

    /* Exercise the variant appenders -- cumulative on the chain. */
    if witness_append_k(mhash_buf as u64, 4u64, 0x12345678u64) != 0i32 { return 12u64 }
    if witness_append_ripple(mhash_buf as u64, 0xCAFEBABEu64) != 0i32 { return 13u64 }
    if witness_append_resolution(mhash_buf as u64, 5u64, 0xDEADu64, 0xBEEFu64) != 0i32 { return 14u64 }
    if witness_count() != 6u32 { return 15u64 }
    if witness_verify_chain() != 1u8 { return 16u64 }

    free(mhash_buf)
    return 99u64
}
