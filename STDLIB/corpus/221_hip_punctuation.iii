/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\221_hip_punctuation.iii
 *
 * III conformance corpus 221 -- HIP punctuation tolerance.
 *
 * Verifies the HIP pipeline accepts utterances with trailing or
 * embedded punctuation (period, comma, exclamation, question, semicolon)
 * without changing the semantic outcome.
 *
 * Cases:
 *   A: "send buffer."         -> UNIQUE (CONVEY)  count=1
 *   B: "send buffer!"         -> UNIQUE (CONVEY)  count=1
 *   C: "send buffer?"         -> UNIQUE (CONVEY)  count=1
 *   D: "send, buffer"         -> UNIQUE (CONVEY)  count=1   (interior comma)
 *   E: "send buffer; close socket" -> UNIQUE (CONVEY) count=1 (only first
 *                                     clause is parsed; semicolon ends it)
 *
 * The lexer emits PUNCT tokens; the parser's _np_skip_pad consumes
 * them. The HIP layer should produce identical (class, count) for each
 * variant.
 *
 * Exit code: 99 on full pass; 100+caseN on case failure.
 */

module corpus_221

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn hip_resolve(text_ptr: u64, text_len: u32, out_cands_ptr: u64, out_meta_ptr: u64) -> i32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_class_unique() -> u32 from "hip.iii"

fn _read_u32(buf: *u8, off: u64) -> u32 {
    let b0 : u32 = (buf[off] as u32) & 0xFFu32
    let b1 : u32 = ((buf[off + 1u64] as u32) & 0xFFu32) << 8u32
    let b2 : u32 = ((buf[off + 2u64] as u32) & 0xFFu32) << 16u32
    let b3 : u32 = ((buf[off + 3u64] as u32) & 0xFFu32) << 24u32
    return b0 | b1 | b2 | b3
}

fn _put(buf: *u8, off: u64, b: u8) -> u64 {
    buf[off] = b
    return off + 1u64
}

fn _send_buffer(buf: *u8, off: u64) -> u64 {
    let mut o : u64 = off
    o = _put(buf, o, 115u8); o = _put(buf, o, 101u8); o = _put(buf, o, 110u8); o = _put(buf, o, 100u8)
    o = _put(buf, o, 32u8)
    o = _put(buf, o, 98u8); o = _put(buf, o, 117u8); o = _put(buf, o, 102u8); o = _put(buf, o, 102u8); o = _put(buf, o, 101u8); o = _put(buf, o, 114u8)
    return o
}

fn main() -> u64 {
    let text  : *u8 = malloc(128u64)
    let cands : *u8 = malloc(64u64)
    let meta  : *u8 = malloc(16u64)
    if text  as u64 == 0u64 { return 1u64 }
    if cands as u64 == 0u64 { return 2u64 }
    if meta  as u64 == 0u64 { return 3u64 }
    let mut zi : u64 = 0u64
    while zi < 16u64 { meta[zi] = 0u8; zi = zi + 1u64 }

    let unique : u32 = hip_class_unique()

    /* === Case A: "send buffer." === */
    let mut o_a : u64 = _send_buffer(text, 0u64)
    o_a = _put(text, o_a, 46u8)   /* . */
    let len_a : u32 = o_a as u32
    if hip_resolve(text as u64, len_a, cands as u64, meta as u64) != 0i32 { return 100u64 }
    if _read_u32(meta, 4u64) != unique { return 110u64 }
    if _read_u32(meta, 0u64) != 1u32   { return 120u64 }

    /* === Case B: "send buffer!" === */
    let mut o_b : u64 = _send_buffer(text, 0u64)
    o_b = _put(text, o_b, 33u8)   /* ! */
    let len_b : u32 = o_b as u32
    if hip_resolve(text as u64, len_b, cands as u64, meta as u64) != 0i32 { return 101u64 }
    if _read_u32(meta, 4u64) != unique { return 111u64 }
    if _read_u32(meta, 0u64) != 1u32   { return 121u64 }

    /* === Case C: "send buffer?" === */
    let mut o_c : u64 = _send_buffer(text, 0u64)
    o_c = _put(text, o_c, 63u8)   /* ? */
    let len_c : u32 = o_c as u32
    if hip_resolve(text as u64, len_c, cands as u64, meta as u64) != 0i32 { return 102u64 }
    if _read_u32(meta, 4u64) != unique { return 112u64 }
    if _read_u32(meta, 0u64) != 1u32   { return 122u64 }

    /* === Case D: "send, buffer" === */
    let mut o_d : u64 = 0u64
    o_d = _put(text, o_d, 115u8); o_d = _put(text, o_d, 101u8); o_d = _put(text, o_d, 110u8); o_d = _put(text, o_d, 100u8)   /* send */
    o_d = _put(text, o_d, 44u8)   /* , */
    o_d = _put(text, o_d, 32u8)
    o_d = _put(text, o_d, 98u8); o_d = _put(text, o_d, 117u8); o_d = _put(text, o_d, 102u8); o_d = _put(text, o_d, 102u8); o_d = _put(text, o_d, 101u8); o_d = _put(text, o_d, 114u8)   /* buffer */
    let len_d : u32 = o_d as u32
    if hip_resolve(text as u64, len_d, cands as u64, meta as u64) != 0i32 { return 103u64 }
    if _read_u32(meta, 4u64) != unique { return 113u64 }
    if _read_u32(meta, 0u64) != 1u32   { return 123u64 }

    free(text)
    free(cands)
    free(meta)
    return 99u64
}
