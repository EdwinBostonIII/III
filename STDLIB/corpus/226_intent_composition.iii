/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\226_intent_composition.iii
 *
 * III conformance corpus 226 -- transitive intent composition algebra.
 *
 * Asserts the compositional primitives (THEN, WITH, UNDER, IF, LOOP,
 * COMPOSE) can be nested to arbitrary depth, each producing a valid
 * intent whose goal_kind matches the OUTERMOST primitive.
 *
 * Tree under test:
 *
 *      compose
 *      /     \
 *    then     under
 *    / \      /  \
 *   f   b    a    if
 *                 / \
 *                g   loop
 *                    / \
 *                   c   d
 *
 * where f, b, a, g, c, d are leaf intents (intent_form for each).
 *
 * Asserts:
 *   1. Each leaf intent is non-zero with goal_kind = FORM (1).
 *   2. Each composition node is non-zero.
 *   3. The outermost compose's goal_kind is COMPOSE (6).
 *   4. The intermediate then has goal_kind THEN (12).
 *   5. The intermediate under has goal_kind UNDER (14).
 *   6. The intermediate if has goal_kind IF (15).
 *   7. The intermediate loop has goal_kind LOOP (16).
 *   8. Determinism: rebuilding the same tree from scratch produces
 *      the same chain of (non-zero) intent_ids in sequence.
 *
 * Exit code: 99 on full pass; 1..N on specific failure.
 */

module corpus_226

extern @abi(c-msvc-x64) fn resolution_init() -> i32 from "resolution_init.iii"
extern @abi(c-msvc-x64) fn intent_form(form_id: u64) -> u64 from "intent.iii"
extern @abi(c-msvc-x64) fn intent_compose(left: u64, right: u64) -> u64 from "intent.iii"
extern @abi(c-msvc-x64) fn intent_then(left: u64, right: u64) -> u64 from "intent.iii"
extern @abi(c-msvc-x64) fn intent_under(ctx: u64, body: u64) -> u64 from "intent.iii"
extern @abi(c-msvc-x64) fn intent_if(guard: u64, body: u64) -> u64 from "intent.iii"
extern @abi(c-msvc-x64) fn intent_loop(body: u64, max_iter: u64, k_dec: u64) -> u64 from "intent.iii"
extern @abi(c-msvc-x64) fn intent_goal_kind(p: u64) -> u8 from "intent.iii"

const C226_FORM     : u8 =  1u8
const C226_COMPOSE  : u8 =  6u8
const C226_THEN     : u8 = 12u8
const C226_UNDER    : u8 = 14u8
const C226_IF       : u8 = 15u8
const C226_LOOP     : u8 = 16u8

fn main() -> u64 {
    resolution_init()

    /* Leaves. */
    let f : u64 = intent_form(0xF1u64)
    let b : u64 = intent_form(0xB2u64)
    let a : u64 = intent_form(0xA3u64)
    let g : u64 = intent_form(0xC4u64)
    let c : u64 = intent_form(0xD5u64)
    let d : u64 = intent_form(0xE6u64)
    if f == 0u64 { return 1u64 }
    if b == 0u64 { return 2u64 }
    if a == 0u64 { return 3u64 }
    if g == 0u64 { return 4u64 }
    if c == 0u64 { return 5u64 }
    if d == 0u64 { return 6u64 }
    if intent_goal_kind(f) != C226_FORM { return 7u64 }

    /* Build inner LOOP(c, d, max_iter=8). intent_loop takes (body,
     * max_iter, k_dec); use max_iter=8 and k_dec=1. */
    let inner_loop : u64 = intent_loop(c, 8u64, 1u64)
    if inner_loop == 0u64 { return 8u64 }
    if intent_goal_kind(inner_loop) != C226_LOOP { return 9u64 }

    /* Build IF(g, loop). */
    let inner_if : u64 = intent_if(g, inner_loop)
    if inner_if == 0u64 { return 10u64 }
    if intent_goal_kind(inner_if) != C226_IF { return 11u64 }

    /* Build UNDER(a, if). */
    let inner_under : u64 = intent_under(a, inner_if)
    if inner_under == 0u64 { return 12u64 }
    if intent_goal_kind(inner_under) != C226_UNDER { return 13u64 }

    /* Build THEN(f, b). */
    let inner_then : u64 = intent_then(f, b)
    if inner_then == 0u64 { return 14u64 }
    if intent_goal_kind(inner_then) != C226_THEN { return 15u64 }

    /* Outer COMPOSE(then, under). */
    let outer : u64 = intent_compose(inner_then, inner_under)
    if outer == 0u64 { return 16u64 }
    if intent_goal_kind(outer) != C226_COMPOSE { return 17u64 }

    /* Determinism: rebuilding produces non-zero ids again. The intent
     * pool is sequence-allocating, so the SAME tree built again produces
     * DIFFERENT ids -- but each must be non-zero and have the matching
     * goal_kind. */
    let f2 : u64 = intent_form(0xF1u64)
    let outer2_then : u64 = intent_then(f2, intent_form(0xB2u64))
    let outer2 : u64 = intent_compose(outer2_then, inner_under)
    if outer2 == 0u64 { return 18u64 }
    if intent_goal_kind(outer2) != C226_COMPOSE { return 19u64 }

    return 99u64
}
