/* Queue FIFO: push 1,2,3,4,5; pop must return 1,2,3,4,5 */
module corpus_b23

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn queue_u32_new(arena: u64, hard: u64) -> u64 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u32_push(id: u64, v: u32) -> i32 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u32_pop(id: u64) -> u64 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u32_len(id: u64) -> u64 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u32_drop(id: u64) -> i32 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u32_peek(id: u64) -> u64 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u32_capacity(id: u64) -> u64 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u32_clear(id: u64) -> i32 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u64_new(arena: u64, hard: u64) -> u64 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u64_push(id: u64, v: u64) -> i32 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u64_pop(id: u64) -> u8 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u64_pop_value() -> u64 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u64_len(id: u64) -> u64 from "queue.iii"
extern @abi(c-msvc-x64) fn queue_u64_drop(id: u64) -> i32 from "queue.iii"

fn main() -> u64 {
    let a : u64 = arena_new(4096u64)
    let q : u64 = queue_u32_new(a, 8u64)
    if q == 0u64 { return 1u64 }
    let mut i : u32 = 1u32
    while i <= 5u32 {
        if queue_u32_push(q, i) != 0i32 { return 2u64 }
        i = i + 1u32
    }
    if queue_u32_len(q) != 5u64 { return 3u64 }
    let mut expect : u32 = 1u32
    while expect <= 5u32 {
        let r : u64 = queue_u32_pop(q)
        if (r & 1u64) != 1u64 { return 4u64 }
        let v : u32 = ((r >> 1u64) & 0xFFFFFFFFu64) as u32
        if v != expect { return 5u64 }
        expect = expect + 1u32
    }
    if queue_u32_len(q) != 0u64 { return 6u64 }
    /* pop on empty returns 0 (none) */
    let empty : u64 = queue_u32_pop(q)
    if (empty & 1u64) != 0u64 { return 7u64 }
    queue_u32_drop(q)

    /* gap #77: capacity + FULL + ring-wraparound FIFO + peek + clear (fresh cap-4 queue) */
    let q2 : u64 = queue_u32_new(a, 4u64)
    if queue_u32_capacity(q2) != 4u64 { return 10u64 }
    let mut j : u32 = 1u32
    while j <= 4u32 { if queue_u32_push(q2, j) != 0i32 { return 11u64 } j = j + 1u32 }
    if queue_u32_push(q2, 99u32) != -1i32 { return 12u64 }          /* QUEUE_E_FULL */
    let pk : u64 = queue_u32_peek(q2)                                /* peek head without consuming */
    if (pk & 1u64) != 1u64 { return 13u64 }
    if (((pk >> 1u64) & 0xFFFFFFFFu64) as u32) != 1u32 { return 14u64 }
    if queue_u32_len(q2) != 4u64 { return 15u64 }                   /* peek did not consume */
    queue_u32_pop(q2)  queue_u32_pop(q2)                             /* drop 1,2 -> head advances */
    if queue_u32_push(q2, 5u32) != 0i32 { return 16u64 }            /* tail wraps the cap-4 ring */
    if queue_u32_push(q2, 6u32) != 0i32 { return 17u64 }
    let mut ex : u32 = 3u32                                          /* remaining FIFO: 3,4,5,6 */
    while ex <= 6u32 {
        let rr : u64 = queue_u32_pop(q2)
        if (((rr >> 1u64) & 0xFFFFFFFFu64) as u32) != ex { return 18u64 }
        ex = ex + 1u32
    }
    queue_u32_push(q2, 7u32)
    if queue_u32_clear(q2) != 0i32 { return 19u64 }
    if queue_u32_len(q2) != 0u64 { return 20u64 }
    queue_u32_drop(q2)

    /* gap #77: queue_u64 FULL + len + pop/pop_value */
    let qu : u64 = queue_u64_new(a, 2u64)
    if queue_u64_push(qu, 100u64) != 0i32 { return 21u64 }
    if queue_u64_push(qu, 200u64) != 0i32 { return 22u64 }
    if queue_u64_push(qu, 300u64) != -1i32 { return 23u64 }         /* FULL */
    if queue_u64_len(qu) != 2u64 { return 24u64 }
    if queue_u64_pop(qu) != 1u8 { return 25u64 }                    /* present */
    if queue_u64_pop_value() != 100u64 { return 26u64 }            /* FIFO head */
    queue_u64_drop(qu)
    arena_drop(a)
    return 99u64
}
