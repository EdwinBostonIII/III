/* III conformance corpus 203 -- Stage 4.8: HMAC-SHA-512 (128-byte block,
 * 64-byte tag).  RFC 4231 Test Case 2:
 *   key  = "Jefe"
 *   data = "what do ya want for nothing?"
 *   HMAC-SHA-512 = 164b7a7bfcf819e2e395fbe73b56e0a387bd64222e831fd6
 *                  10270cd7ea2505549758bf75c05a994a6d034f65f8f0e6fd
 *                  caeab1a34d4a6b4b636e070a38bce737
 * (The impl already existed in numera/hmac.iii; this is its KAT.)  Exit 99.
 */
module corpus_2404

extern @abi(c-msvc-x64) fn hmac_sha512(key: u64, key_len: u64, msg: u64, msg_len: u64) -> i32 from "hmac.iii"
extern @abi(c-msvc-x64) fn hmac_sha512_tag(out_64: u64) -> i32 from "hmac.iii"

var K   : [u8; 4]
var D   : [u8; 28]
var OUT : [u8; 64]
var EXP : [u8; 64]

fn main() -> u64 {
    K[0]=0x4au8 K[1]=0x65u8 K[2]=0x66u8 K[3]=0x65u8
    D[0]=0x77u8 D[1]=0x68u8 D[2]=0x61u8 D[3]=0x74u8 D[4]=0x20u8 D[5]=0x64u8 D[6]=0x6fu8
    D[7]=0x20u8 D[8]=0x79u8 D[9]=0x61u8 D[10]=0x20u8 D[11]=0x77u8 D[12]=0x61u8 D[13]=0x6eu8
    D[14]=0x74u8 D[15]=0x20u8 D[16]=0x66u8 D[17]=0x6fu8 D[18]=0x72u8 D[19]=0x20u8 D[20]=0x6eu8
    D[21]=0x6fu8 D[22]=0x74u8 D[23]=0x68u8 D[24]=0x69u8 D[25]=0x6eu8 D[26]=0x67u8 D[27]=0x3fu8
    EXP[0]=0x16u8 EXP[1]=0x4bu8 EXP[2]=0x7au8 EXP[3]=0x7bu8 EXP[4]=0xfcu8 EXP[5]=0xf8u8 EXP[6]=0x19u8 EXP[7]=0xe2u8
    EXP[8]=0xe3u8 EXP[9]=0x95u8 EXP[10]=0xfbu8 EXP[11]=0xe7u8 EXP[12]=0x3bu8 EXP[13]=0x56u8 EXP[14]=0xe0u8 EXP[15]=0xa3u8
    EXP[16]=0x87u8 EXP[17]=0xbdu8 EXP[18]=0x64u8 EXP[19]=0x22u8 EXP[20]=0x2eu8 EXP[21]=0x83u8 EXP[22]=0x1fu8 EXP[23]=0xd6u8
    EXP[24]=0x10u8 EXP[25]=0x27u8 EXP[26]=0x0cu8 EXP[27]=0xd7u8 EXP[28]=0xeau8 EXP[29]=0x25u8 EXP[30]=0x05u8 EXP[31]=0x54u8
    EXP[32]=0x97u8 EXP[33]=0x58u8 EXP[34]=0xbfu8 EXP[35]=0x75u8 EXP[36]=0xc0u8 EXP[37]=0x5au8 EXP[38]=0x99u8 EXP[39]=0x4au8
    EXP[40]=0x6du8 EXP[41]=0x03u8 EXP[42]=0x4fu8 EXP[43]=0x65u8 EXP[44]=0xf8u8 EXP[45]=0xf0u8 EXP[46]=0xe6u8 EXP[47]=0xfdu8
    EXP[48]=0xcau8 EXP[49]=0xeau8 EXP[50]=0xb1u8 EXP[51]=0xa3u8 EXP[52]=0x4du8 EXP[53]=0x4au8 EXP[54]=0x6bu8 EXP[55]=0x4bu8
    EXP[56]=0x63u8 EXP[57]=0x6eu8 EXP[58]=0x07u8 EXP[59]=0x0au8 EXP[60]=0x38u8 EXP[61]=0xbcu8 EXP[62]=0xe7u8 EXP[63]=0x37u8
    hmac_sha512(&K as u64, 4u64, &D as u64, 28u64)
    hmac_sha512_tag(&OUT as u64)
    let mut i : u64 = 0u64
    while i < 64u64 { if OUT[i] != EXP[i] { return 1u64 } i = i + 1u64 }
    return 99u64
}
