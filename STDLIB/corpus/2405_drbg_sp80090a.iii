/* III conformance corpus 204 -- Stage 4.6: HMAC-DRBG-SHA-512 (SP 800-90A).
 * Cross-checked against an independent C-ref HMAC-DRBG over the same SHA-512:
 *   instantiate(entropy=0x00..0x2F[48], nonce=0x80..0x8F[16], no perso)
 *   generate(128) [discard] ; generate(128) [KAT output]
 * Expected gen2: [0..8]=53 50 68 116 220 210 156 82; [126,127]=237 136;
 * position-weighted checksum (Σ b[i]*(i+1)) = 1083073.
 * (NIST ACVP vectors are multi-MiB / not hand-transcribable offline; this is
 * the in-tree cross-check vs a reference impl of the identical algorithm.)
 * Exit 99.
 */
module corpus_2405

extern @abi(c-msvc-x64) fn iii_drbg_instantiate(entropy: u64, elen: u64, nonce: u64, nlen: u64, perso: u64, plen: u64) -> i32 from "drbg.iii"
extern @abi(c-msvc-x64) fn iii_drbg_generate(out: u64, n_bytes: u64, addl: u64, alen: u64) -> i32 from "drbg.iii"

var E  : [u8; 48]
var NO : [u8; 16]
var G1 : [u8; 128]
var G2 : [u8; 128]

fn main() -> u64 {
    let mut i : u64 = 0u64
    while i < 48u64 { E[i] = (i & 0xFFu64) as u8 ; i = i + 1u64 }
    i = 0u64
    while i < 16u64 { NO[i] = ((0x80u64 + i) & 0xFFu64) as u8 ; i = i + 1u64 }
    iii_drbg_instantiate(&E as u64, 48u64, &NO as u64, 16u64, 0u64, 0u64)
    iii_drbg_generate(&G1 as u64, 128u64, 0u64, 0u64)
    iii_drbg_generate(&G2 as u64, 128u64, 0u64, 0u64)
    if G2[0] != 53u8  { return 1u64 }
    if G2[1] != 50u8  { return 2u64 }
    if G2[2] != 68u8  { return 3u64 }
    if G2[7] != 82u8  { return 4u64 }
    if G2[126] != 237u8 { return 5u64 }
    if G2[127] != 136u8 { return 6u64 }
    let mut sum : u64 = 0u64
    i = 0u64
    while i < 128u64 { sum = sum + (G2[i] as u64) * (i + 1u64) ; i = i + 1u64 }
    if (sum & 0xFFFFFFFFu64) != 1083073u64 { return 7u64 }
    return 99u64
}
