/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\208_cap_handshake.iii
 *
 * III conformance corpus 208 -- Phase D.2: capability handshake.
 *
 * Asserts:
 *   1. cap_offer_pattern_set produces a valid wire envelope.
 *   2. cap_accept_offer returns 1 when the peer's digest matches mine.
 *   3. cap_accept_offer returns 0 when digests differ or CRC fails.
 *   4. cap_negotiate_session returns a deterministic non-zero cap_id
 *      for matching digests; same inputs -> same cap_id.
 *   5. cap_session_verify confirms the binding.
 *   6. cap_session_drop reclaims the slot.
 *   7. cap_negotiate_session refuses incompatible peers (digest mismatch).
 *
 * Exit code: 99 on full pass; 1..N for specific failures.
 */

module corpus_2409

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"

extern @abi(c-msvc-x64) fn cap_handshake_reset() -> i32 from "cap_handshake.iii"
extern @abi(c-msvc-x64) fn cap_offer_pattern_set(my_pset_digest_ptr: u64, out_offer_buf: u64) -> u32 from "cap_handshake.iii"
extern @abi(c-msvc-x64) fn cap_accept_offer(offer_buf: u64, offer_len: u32, my_pset_digest_ptr: u64) -> u8 from "cap_handshake.iii"
extern @abi(c-msvc-x64) fn cap_negotiate_session(my_pset_digest_ptr: u64, peer_pset_digest_ptr: u64) -> u64 from "cap_handshake.iii"
extern @abi(c-msvc-x64) fn cap_session_verify(session_cap_id: u64, peer_pset_digest_ptr: u64) -> u8 from "cap_handshake.iii"
extern @abi(c-msvc-x64) fn cap_session_drop(session_cap_id: u64) -> i32 from "cap_handshake.iii"
extern @abi(c-msvc-x64) fn cap_session_count() -> u32 from "cap_handshake.iii"
extern @abi(c-msvc-x64) fn cap_session_capacity() -> u32 from "cap_handshake.iii"

fn fill_dig(dig: *u8, base: u8) -> u32 {
    let mut i : u64 = 0u64
    while i < 32u64 {
        dig[i] = base + (i as u8)
        i = i + 1u64
    }
    return 0u32
}

fn main() -> u64 {
    cap_handshake_reset()
    if cap_session_count() != 0u32 { return 1u64 }
    if cap_session_capacity() != 64u32 { return 2u64 }

    let dig_alice : *u8 = malloc(32u64)
    let dig_bob   : *u8 = malloc(32u64)
    let dig_carol : *u8 = malloc(32u64)
    if dig_alice as u64 == 0u64 { return 3u64 }
    if dig_bob   as u64 == 0u64 { free(dig_alice); return 4u64 }
    if dig_carol as u64 == 0u64 { free(dig_alice); free(dig_bob); return 5u64 }

    fill_dig(dig_alice, 0x10u8)
    fill_dig(dig_bob,   0x10u8)   /* same as alice -> compatible */
    fill_dig(dig_carol, 0x99u8)   /* different -> incompatible */

    /* Allocate offer buffer (header + 32B payload = 100). */
    let offer : *u8 = malloc(128u64)
    if offer as u64 == 0u64 {
        free(dig_alice); free(dig_bob); free(dig_carol); return 6u64
    }

    /* ---- 1. Alice offers her pattern set. ---- */
    let off_len : u32 = cap_offer_pattern_set(dig_alice as u64, offer as u64)
    if off_len == 0u32 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 7u64
    }

    /* ---- 2. Bob accepts (matching digest). ---- */
    if cap_accept_offer(offer as u64, off_len, dig_bob as u64) != 1u8 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 8u64
    }

    /* ---- 3a. Carol rejects (digest mismatch). ---- */
    if cap_accept_offer(offer as u64, off_len, dig_carol as u64) != 0u8 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 9u64
    }

    /* ---- 3b. Tampered offer -> CRC fails. ---- */
    let tamper : *u8 = (offer as u64 + 8u64) as *u8
    let saved : u8 = tamper[0u64]
    tamper[0u64] = saved ^ 0xFFu8
    if cap_accept_offer(offer as u64, off_len, dig_bob as u64) != 0u8 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 10u64
    }
    tamper[0u64] = saved
    if cap_accept_offer(offer as u64, off_len, dig_bob as u64) != 1u8 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 11u64
    }

    /* ---- 4. Negotiate Alice<->Bob. ---- */
    let cap1 : u64 = cap_negotiate_session(dig_alice as u64, dig_bob as u64)
    if cap1 == 0u64 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 12u64
    }
    if cap_session_count() != 1u32 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 13u64
    }

    /* Determinism: same inputs -> same cap_id. Note: a SECOND call
     * allocates a SECOND slot (no dedup); but the derived cap_id is
     * the same. */
    let cap2 : u64 = cap_negotiate_session(dig_alice as u64, dig_bob as u64)
    if cap2 != cap1 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 14u64
    }
    /* Two slots used now since negotiate doesn't dedup -- expected. */

    /* ---- 5. Verify session. ---- */
    if cap_session_verify(cap1, dig_bob as u64) != 1u8 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 15u64
    }
    /* Verify with WRONG peer digest fails. */
    if cap_session_verify(cap1, dig_carol as u64) != 0u8 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 16u64
    }

    /* ---- 6. Drop reclaims. ---- */
    if cap_session_drop(cap1) != 0i32 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 17u64
    }
    /* The 2nd slot still exists with the same cap_id, so drop succeeds again. */
    if cap_session_drop(cap1) != 0i32 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 18u64
    }
    /* Now dropping a third time (no slots remaining) returns error. */
    if cap_session_drop(cap1) == 0i32 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 19u64
    }
    if cap_session_count() != 0u32 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 20u64
    }

    /* ---- 7. Incompatible peer -> negotiate returns 0. ---- */
    if cap_negotiate_session(dig_alice as u64, dig_carol as u64) != 0u64 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 21u64
    }
    if cap_session_count() != 0u32 {
        free(offer); free(dig_alice); free(dig_bob); free(dig_carol); return 22u64
    }

    free(offer)
    free(dig_alice)
    free(dig_bob)
    free(dig_carol)
    return 99u64
}
