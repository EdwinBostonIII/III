/* 1402_gov_charter_hexad.iii -- GOVERNANCE LEDGER, CHARTER VERDICTS, HEXAD ALGEBRA,
 * OFFLOAD/HIP/VAULT ACCESSORS (burn-down tranche 11; ~13 census orphans).
 *
 *  GOVERNANCE (4): governance_capacity (the pinned 256), governance_drop (a live proposal
 *      dies once: accessors go to sentinels, double-drop refuses GOV_E_BAD_ID),
 *      governance_rationale_hash_byte (32 readable bytes, OOB/dead -> 0x100),
 *      governance_observe_history_pid (mandate-7: observe_and_propose returns 0 ALWAYS --
 *      no auto-proposals; the history accessor reads back exactly what was recorded,
 *      OOB -> 0);
 *  CHARTERS (2): h13_verdict / h2_verdict -- after a GREEN run (99) the sealed 32-byte
 *      verdict copies out, is nonzero, reproduces on a re-run, refuses null (-1);
 *  HEXAD (3): iii_hexad_eq6 (reflexive + discriminating), iii_hexad_dynamic_count
 *      (deterministic), iii_hexad_bitmap_sha256 (rc 0, nonzero digest, reproducible);
 *  HW-OFFLOAD (1): hw_offload_blob_used -- deterministic and within the 16384 blob cap;
 *  HIP (1): hip_last_token_count -- a real resolve tokenizes (>0), identical input
 *      re-resolves to the identical count;
 *  VAULT (2): tv_blen (== the sealed blob length), tv_keyshare_ptr (nonzero, 32-stride
 *      distinct pointers).
 * Exit 99. */
module corpus_2422

extern @abi(c-msvc-x64) fn governance_propose(proposer_cap: u64, change_intent: u64, rationale_ptr: u64, rationale_len: u32) -> u64 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_capacity() -> u32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_proposal_count() -> u32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_drop(proposal_id: u64) -> i32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_rationale_hash_byte(proposal_id: u64, i: u32) -> u32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_intent(proposal_id: u64) -> u64 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_observe_and_propose(replay_count: u32) -> u32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_observe_history_pid(idx: u32) -> u64 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_observe_history_len() -> u32 from "governance.iii"
extern @abi(c-msvc-x64) fn governance_observe_reset() -> i32 from "governance.iii"
extern @abi(c-msvc-x64) fn h13_run_charter() -> u64 from "h13_charter.iii"
extern @abi(c-msvc-x64) fn h13_verdict(out: *u8) -> i32 from "h13_charter.iii"
extern @abi(c-msvc-x64) fn h2_run_charter() -> u64 from "h2_charter.iii"
extern @abi(c-msvc-x64) fn h2_verdict(out: *u8) -> i32 from "h2_charter.iii"
extern @abi(c-msvc-x64) fn iii_hexad_eq6(a: u16, b: u16) -> u8 from "hexad_algebra.iii"
extern @abi(c-msvc-x64) fn iii_hexad_dynamic_count() -> u64 from "hexad_dynamic.iii"
extern @abi(c-msvc-x64) fn iii_hexad_bitmap_sha256(out_addr: u64) -> i32 from "hexad_reach.iii"
extern @abi(c-msvc-x64) fn hw_offload_blob_used() -> u32 from "hw_offload.iii"
extern @abi(c-msvc-x64) fn hip_resolve(text_ptr: u64, text_len: u32, out_cands_ptr: u64, out_meta_ptr: u64) -> i32 from "hip.iii"
extern @abi(c-msvc-x64) fn hip_last_token_count() -> u32 from "hip.iii"
extern @abi(c-msvc-x64) fn tv_seal(blob_ptr: u64, blen: u32, kthr: u32, nshard: u32, kkey: u32, nkey: u32, key_ptr: u64, nonce_ptr: u64, keycoeff_ptr: u64) -> i32 from "threshold_vault.iii"
extern @abi(c-msvc-x64) fn tv_blen() -> u32 from "threshold_vault.iii"
extern @abi(c-msvc-x64) fn tv_keyshare_ptr(i: u32) -> u64 from "threshold_vault.iii"

var RAT  : [u8; 32]
var V1   : [u8; 32]
var V2   : [u8; 32]
var HX1  : [u8; 32]
var HX2  : [u8; 32]
var TXT  : [u8; 64]
var CAND : [u8; 1024]
var META : [u8; 64]
var VB   : [u8; 48]
var VK   : [u8; 32]
var VN   : [u8; 12]
var VC   : [u8; 64]

fn main() -> u64 {
    /* ---- GOVERNANCE: propose -> read -> drop-once ---- */
    if governance_capacity() != 256u32 { return 1u64 }
    let mut r : u64 = 0u64
    while r < 32u64 { RAT[r] = (0x11u64 + r & 0xFFu64) as u8   r = r + 1u64 }
    let c0 : u32 = governance_proposal_count()
    let pid : u64 = governance_propose(0x77u64, 0x88u64, (&RAT as u64), 32u32)
    if pid == 0u64 { return 2u64 }
    if governance_proposal_count() != c0 + 1u32 { return 3u64 }
    if governance_intent(pid) != 0x88u64 { return 4u64 }
    /* the rationale hash: 32 readable bytes, at least one nonzero */
    let mut nz : u32 = 0u32
    let mut i : u32 = 0u32
    while i < 32u32 {
        let b : u32 = governance_rationale_hash_byte(pid, i)
        if b > 0xFFu32 { return 5u64 }
        if b != 0u32 { nz = nz + 1u32 }
        i = i + 1u32
    }
    if nz == 0u32 { return 6u64 }
    if governance_rationale_hash_byte(pid, 32u32) != 0x100u32 { return 7u64 }   /* OOB */
    if governance_drop(pid) != 0i32 { return 8u64 }
    if governance_intent(pid) != 0u64 { return 9u64 }                            /* dead */
    if governance_rationale_hash_byte(pid, 0u32) != 0x100u32 { return 10u64 }
    if governance_drop(pid) != -1i32 { return 11u64 }                            /* GOV_E_BAD_ID */
    /* mandate-7 observation: returns 0 ALWAYS, never auto-proposes */
    if governance_observe_reset() != 0i32 { return 12u64 }
    if governance_observe_history_len() != 0u32 { return 13u64 }
    if governance_observe_history_pid(0u32) != 0u64 { return 14u64 }             /* empty/OOB */
    let cb : u32 = governance_proposal_count()
    if governance_observe_and_propose(3u32) != 0u32 { return 15u64 }             /* THE LAW */
    if governance_proposal_count() != cb { return 16u64 }                        /* no auto-proposals */
    if governance_observe_history_len() > 3u32 { return 17u64 }
    if governance_observe_history_pid(15u32) != 0u64 { return 18u64 }            /* OOB */

    /* ---- CHARTERS: GREEN -> sealed verdicts copy, nonzero, reproducible ---- */
    if h13_run_charter() != 99u64 { return 20u64 }
    if h13_verdict(((&V1 as u64)) as *u8) != 0i32 { return 21u64 }
    let mut z13 : u32 = 0u32
    let mut j : u64 = 0u64
    while j < 32u64 { if V1[j] != 0u8 { z13 = z13 + 1u32 }   j = j + 1u64 }
    if z13 == 0u32 { return 22u64 }
    if h13_run_charter() != 99u64 { return 23u64 }
    if h13_verdict(((&V2 as u64)) as *u8) != 0i32 { return 24u64 }
    let mut k : u64 = 0u64
    while k < 32u64 { if V1[k] != V2[k] { return 25u64 }   k = k + 1u64 }
    let np : *u8 = (0u64) as *u8
    if h13_verdict(np) != -1i32 { return 26u64 }
    if h2_run_charter() != 99u64 { return 27u64 }
    if h2_verdict(((&V1 as u64)) as *u8) != 0i32 { return 28u64 }
    let mut z2 : u32 = 0u32
    let mut j2 : u64 = 0u64
    while j2 < 32u64 { if V1[j2] != 0u8 { z2 = z2 + 1u32 }   j2 = j2 + 1u64 }
    if z2 == 0u32 { return 29u64 }
    if h2_verdict(np) != -1i32 { return 30u64 }

    /* ---- HEXAD: eq6 algebra; dynamic count; bitmap digest ---- */
    if iii_hexad_eq6(0x2Au16, 0x2Au16) != 1u8 { return 40u64 }
    if iii_hexad_eq6(0x2Au16, 0x2Bu16) != 0u8 { return 41u64 }
    if iii_hexad_eq6(0u16, 0u16) != 1u8 { return 42u64 }
    let d1 : u64 = iii_hexad_dynamic_count()
    if iii_hexad_dynamic_count() != d1 { return 43u64 }                          /* deterministic */
    if iii_hexad_bitmap_sha256((&HX1 as u64)) != 0i32 { return 44u64 }
    if iii_hexad_bitmap_sha256((&HX2 as u64)) != 0i32 { return 45u64 }
    let mut hnz : u32 = 0u32
    let mut h : u64 = 0u64
    while h < 32u64 {
        if HX1[h] != HX2[h] { return 46u64 }                                     /* reproducible */
        if HX1[h] != 0u8 { hnz = hnz + 1u32 }
        h = h + 1u64
    }
    if hnz == 0u32 { return 47u64 }

    /* ---- HW-OFFLOAD: deterministic, within the blob cap ---- */
    let bu : u32 = hw_offload_blob_used()
    if hw_offload_blob_used() != bu { return 50u64 }
    if bu > 16384u32 { return 51u64 }

    /* ---- HIP: a real resolve tokenizes; identical input -> identical count ---- */
    TXT[0u64] = 0x6Du8   /* m */
    TXT[1u64] = 0x6Fu8   /* o */
    TXT[2u64] = 0x76u8   /* v */
    TXT[3u64] = 0x65u8   /* e */
    TXT[4u64] = 0x20u8
    TXT[5u64] = 0x78u8   /* x */
    TXT[6u64] = 0x20u8
    TXT[7u64] = 0x74u8   /* t */
    TXT[8u64] = 0x6Fu8   /* o */
    TXT[9u64] = 0x20u8
    TXT[10u64] = 0x79u8  /* y */
    hip_resolve((&TXT as u64), 11u32, (&CAND as u64), (&META as u64))
    let t1 : u32 = hip_last_token_count()
    if t1 == 0u32 { return 60u64 }
    hip_resolve((&TXT as u64), 11u32, (&CAND as u64), (&META as u64))
    if hip_last_token_count() != t1 { return 61u64 }

    /* ---- VAULT accessors: blen exact; keyshare ptrs nonzero + 32-stride distinct ---- */
    let mut v : u64 = 0u64
    while v < 48u64 { VB[v] = (v & 0xFFu64) as u8   v = v + 1u64 }
    let mut q : u64 = 0u64
    while q < 32u64 { VK[q] = (0x70u64 + q & 0xFFu64) as u8   VC[q] = (0x55u64 + q & 0xFFu64) as u8   q = q + 1u64 }
    let mut w : u64 = 0u64
    while w < 12u64 { VN[w] = (w & 0xFFu64) as u8   w = w + 1u64 }
    if tv_seal((&VB as u64), 48u32, 2u32, 3u32, 2u32, 3u32,
               (&VK as u64), (&VN as u64), (&VC as u64)) != 0i32 { return 70u64 }
    if tv_blen() != 48u32 { return 71u64 }
    let p0 : u64 = tv_keyshare_ptr(0u32)
    let p1 : u64 = tv_keyshare_ptr(1u32)
    if p0 == 0u64 { return 72u64 }
    if p1 != p0 + 32u64 { return 73u64 }                                         /* 32-stride */

    return 99u64
}
