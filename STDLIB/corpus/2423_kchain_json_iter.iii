/* 1403_kchain_json_iter.iii -- K-CHAIN READMISSION, JSON ERROR SURFACE, GENERIC ITERATORS,
 * K0 FREEZE, ONELANG TOTALITY (burn-down tranche 12; ~17 census orphans).
 *
 *  KCHAIN (3): kchain_to_basis_points (Q-1e9 conversion EXACT: FULL->10000, half->5000,
 *      0->0), kchain_readmit / kchain_readmit_count (a composed-down chain readmits to
 *      FULL, the counter is exact, a dead id refuses);
 *  K0 (1): k0_is_frozen -- 0 before the one-way freeze, 1 after (the anchor latch);
 *  JSON (3): json_last_error / json_last_error_pos / json_node_count -- a valid parse
 *      reports JSON_OK + a deterministic node count; a malformed document reports
 *      JSON_E_PARSE with the EXACT byte position of the offending token;
 *  ITER u8 (2): iter_u8_pos / iter_u8_remaining -- pos+remaining == len at every step;
 *  (iter__/option__ @specialize GENERICS are TEMPLATES, not ABI surface -- nothing
 *      instantiates them, no symbol exists to link; the coverage scanner now excludes
 *      generic templates from the census by the same reasoning.)
 *  ONELANG (2): onelang_n_dirs -- EXACT on a hermetic synthetic tree (root + 2 subdirs);
 *      onelang_gate_cwd -- total (verdict 0/1/2) and deterministic across calls.
 * Exit 99. */
module corpus_2423

extern @abi(c-msvc-x64) fn kchain_new(custom_floor: u64) -> u64 from "kchain.iii"
extern @abi(c-msvc-x64) fn kchain_compose(id: u64, k_call_fx: u64) -> u8 from "kchain.iii"
extern @abi(c-msvc-x64) fn kchain_current(id: u64) -> u64 from "kchain.iii"
extern @abi(c-msvc-x64) fn kchain_readmit(id: u64) -> u8 from "kchain.iii"
extern @abi(c-msvc-x64) fn kchain_readmit_count(id: u64) -> u32 from "kchain.iii"
extern @abi(c-msvc-x64) fn kchain_to_basis_points(k_fx: u64) -> u32 from "kchain.iii"
extern @abi(c-msvc-x64) fn kchain_drop(id: u64) -> u8 from "kchain.iii"
extern @abi(c-msvc-x64) fn k0_is_frozen() -> u32 from "k0_referee.iii"
extern @abi(c-msvc-x64) fn k0_freeze_anchor() -> i32 from "k0_referee.iii"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn json_parse(arena: u64, input_base: u64, input_len: u64) -> u64 from "json.iii"
extern @abi(c-msvc-x64) fn json_last_error() -> i32 from "json.iii"
extern @abi(c-msvc-x64) fn json_last_error_pos() -> u64 from "json.iii"
extern @abi(c-msvc-x64) fn json_node_count() -> u32 from "json.iii"
extern @abi(c-msvc-x64) fn iter_u8_new(base: u64, len: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_u8_pos(id: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_u8_remaining(id: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn iter_u8_next(id: u64) -> u64 from "iter.iii"
extern @abi(c-msvc-x64) fn onelang_audit(cap_id: u64, root_addr: u64) -> u64 from "onelang.iii"
extern @abi(c-msvc-x64) fn onelang_n_dirs() -> u64 from "onelang.iii"
extern @abi(c-msvc-x64) fn onelang_gate_cwd(cap_id: u64) -> u32 from "onelang.iii"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn fs_mkdir(cap: u64, path: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_rmdir(cap: u64, path: u64) -> i32 from "fs.iii"

var JSON_GOOD : [u8; 32]
var JSON_BAD  : [u8; 32]
var BYTES     : [u8; 8]
var WORDS     : [u32; 4]
var P_ROOT    : [u8; 32]
var P_SUB1    : [u8; 32]
var P_SUB2    : [u8; 32]

fn setp(dst_addr: u64, src_addr: u64, n: u64) {
    let d : *u8 = dst_addr as *u8
    let s : *u8 = src_addr as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]   i = i + 1u64 }
    d[n] = 0u8
}

fn main() -> u64 {
    /* ---- KCHAIN: exact basis points; readmit cycle ---- */
    if kchain_to_basis_points(1000000000u64) != 10000u32 { return 1u64 }
    if kchain_to_basis_points(500000000u64) != 5000u32 { return 2u64 }
    if kchain_to_basis_points(0u64) != 0u32 { return 3u64 }
    if kchain_to_basis_points(123400000u64) != 1234u32 { return 4u64 }
    let ch : u64 = kchain_new(100000000u64)              /* floor 0.10 */
    if ch == 0u64 { return 5u64 }
    if kchain_to_basis_points(kchain_current(ch)) != 10000u32 { return 6u64 }   /* born FULL */
    if kchain_compose(ch, 500000000u64) != 1u8 { return 7u64 }                  /* x0.5 */
    if kchain_to_basis_points(kchain_current(ch)) != 5000u32 { return 8u64 }
    if kchain_readmit_count(ch) != 0u32 { return 9u64 }
    if kchain_readmit(ch) != 1u8 { return 10u64 }
    if kchain_to_basis_points(kchain_current(ch)) != 10000u32 { return 11u64 }  /* FULL again */
    if kchain_readmit_count(ch) != 1u32 { return 12u64 }
    if kchain_drop(ch) != 1u8 { return 13u64 }
    if kchain_readmit(ch) != 0u8 { return 14u64 }                               /* dead refuses */
    if kchain_readmit_count(ch) != 0u32 { return 15u64 }

    /* ---- K0: the one-way freeze latch ---- */
    if k0_is_frozen() != 0u32 { return 20u64 }
    if k0_freeze_anchor() != 0i32 { return 21u64 }
    if k0_is_frozen() != 1u32 { return 22u64 }

    /* ---- JSON: OK + node count; malformed -> E_PARSE at the EXACT byte ---- */
    let ar : u64 = arena_new(65536u64)
    if ar == 0u64 { return 30u64 }
    /* {"a":1}  -- 7 bytes */
    JSON_GOOD[0u64] = 0x7Bu8
    JSON_GOOD[1u64] = 0x22u8
    JSON_GOOD[2u64] = 0x61u8
    JSON_GOOD[3u64] = 0x22u8
    JSON_GOOD[4u64] = 0x3Au8
    JSON_GOOD[5u64] = 0x31u8
    JSON_GOOD[6u64] = 0x7Du8
    let ok : u64 = json_parse(ar, (&JSON_GOOD as u64), 7u64)
    if ok == 0u64 { return 31u64 }
    if json_last_error() != 0i32 { return 32u64 }
    let nc1 : u32 = json_node_count()
    if nc1 == 0u32 { return 33u64 }
    /* {"a":!}  -- '!' at byte 5 is the offending token */
    JSON_BAD[0u64] = 0x7Bu8
    JSON_BAD[1u64] = 0x22u8
    JSON_BAD[2u64] = 0x61u8
    JSON_BAD[3u64] = 0x22u8
    JSON_BAD[4u64] = 0x3Au8
    JSON_BAD[5u64] = 0x21u8
    JSON_BAD[6u64] = 0x7Du8
    let bad : u64 = json_parse(ar, (&JSON_BAD as u64), 7u64)
    if bad != 0u64 { return 34u64 }
    if json_last_error() != -3i32 { return 35u64 }                              /* JSON_E_PARSE */
    if json_last_error_pos() != 5u64 { return 36u64 }                           /* the exact byte */

    /* ---- ITER u8: pos + remaining == len at every step ---- */
    BYTES[0u64] = 10u8
    BYTES[1u64] = 20u8
    BYTES[2u64] = 30u8
    let it8 : u64 = iter_u8_new((&BYTES as u64), 3u64)
    if it8 == 0u64 { return 40u64 }
    if iter_u8_pos(it8) != 0u64 { return 41u64 }
    if iter_u8_remaining(it8) != 3u64 { return 42u64 }
    iter_u8_next(it8)
    if iter_u8_pos(it8) != 1u64 { return 43u64 }
    if iter_u8_remaining(it8) != 2u64 { return 44u64 }
    if iter_u8_pos(it8) + iter_u8_remaining(it8) != 3u64 { return 45u64 }

    /* ---- ONELANG: n_dirs exact on a hermetic tree; gate_cwd total + deterministic ---- */
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)
    setp((&P_ROOT as u64), ("./iii_1403_ol" as u64), 13u64)
    setp((&P_SUB1 as u64), ("./iii_1403_ol/a" as u64), 15u64)
    setp((&P_SUB2 as u64), ("./iii_1403_ol/b" as u64), 15u64)
    fs_rmdir(cap, (&P_SUB1 as u64))
    fs_rmdir(cap, (&P_SUB2 as u64))
    fs_rmdir(cap, (&P_ROOT as u64))
    if fs_mkdir(cap, (&P_ROOT as u64)) != 0i32 { return 70u64 }
    if fs_mkdir(cap, (&P_SUB1 as u64)) != 0i32 { return 71u64 }
    if fs_mkdir(cap, (&P_SUB2 as u64)) != 0i32 { return 72u64 }
    onelang_audit(cap, (&P_ROOT as u64))
    if onelang_n_dirs() != 3u64 { return 73u64 }                                /* root + a + b */
    fs_rmdir(cap, (&P_SUB1 as u64))
    fs_rmdir(cap, (&P_SUB2 as u64))
    fs_rmdir(cap, (&P_ROOT as u64))
    let gv1 : u32 = onelang_gate_cwd(cap)
    if gv1 > 2u32 { return 74u64 }                                              /* total: 0/1/2 */
    if onelang_gate_cwd(cap) != gv1 { return 75u64 }                            /* deterministic */

    return 99u64
}
