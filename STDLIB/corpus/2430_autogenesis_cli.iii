/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\1410_autogenesis_cli.iii
 *
 * Falsifier KAT for sanctus::autogenesis_cli (the loop's context-aware command surface).  Drives a
 * full session: help/gap/theorems render; `cycle` actually runs a cycle (status then shows
 * inflight=1); ledger/state render fixed-width hex roots; an unauthorized `commit` is refused
 * (rc=-5, the apprentice gate still bites through the CLI); `rollback` clears the cycle (status then
 * shows inflight=0); an unknown verb falls through to the help hint. */

module corpus_2430_autogenesis_cli

extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn agc_attach(cap: u64) -> i32 from "autogenesis_cli.iii"
extern @abi(c-msvc-x64) fn agc_exec(cmd: u64, len: u64, out: u64) -> i64 from "autogenesis_cli.iii"

var OUT : [u8; 512]

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x80000u64, 0u64)
    agc_attach(cap)

    if agc_exec(("help" as u64), 4u64, (&OUT as u64)) <= 0i64 { return 1u64 }
    if OUT[0u64] != 104u8 { return 2u64 }

    if agc_exec(("gap" as u64), 3u64, (&OUT as u64)) <= 0i64 { return 3u64 }
    if OUT[0u64] != 103u8 { return 4u64 }

    agc_exec(("theorems" as u64), 8u64, (&OUT as u64))
    if OUT[0u64] != 116u8 { return 5u64 }

    agc_exec(("cycle" as u64), 5u64, (&OUT as u64))
    if OUT[0u64] != 99u8 { return 6u64 }

    agc_exec(("status" as u64), 6u64, (&OUT as u64))
    if OUT[0u64] != 115u8 { return 7u64 }
    if OUT[16u64] != 49u8 { return 8u64 }

    let l6 : i64 = agc_exec(("ledger" as u64), 6u64, (&OUT as u64))
    if l6 != 72i64 { return 9u64 }
    if OUT[0u64] != 108u8 { return 10u64 }

    let l7 : i64 = agc_exec(("state" as u64), 5u64, (&OUT as u64))
    if l7 != 71i64 { return 11u64 }

    agc_exec(("commit" as u64), 6u64, (&OUT as u64))
    if OUT[0u64] != 99u8 { return 12u64 }
    if OUT[10u64] != 45u8 { return 13u64 }

    agc_exec(("rollback" as u64), 8u64, (&OUT as u64))
    if OUT[0u64] != 114u8 { return 14u64 }

    agc_exec(("status" as u64), 6u64, (&OUT as u64))
    if OUT[16u64] != 48u8 { return 15u64 }

    agc_exec(("frobnicate" as u64), 10u64, (&OUT as u64))
    if OUT[0u64] != 117u8 { return 16u64 }

    return 99u64
}
