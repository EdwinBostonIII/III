/* 2456_stoma_proc.iii -- STOMA M2 gate: pipe-mode spawn, full-width codes, tree-kill.
 *
 * Proves:
 *   1. FULL-WIDTH exit codes: `cmd /c exit 300` reads back 300 (not 300&0xFF=44 -- the
 *      8-bit-mask trap class is dead at this layer).
 *   2. stdout capture: `cmd /c echo PROCPIPE` -> marker in proc stdout, NOT in stderr.
 *   3. stderr capture: `cmd /c echo ERRSIDE 1>&2` -> marker in stderr, NOT in stdout.
 *   4. NO ORPHANS on job CLOSE: `cmd /c start /b ping -n 30 ...` -- cmd exits instantly,
 *      the 30s grandchild ping must be reaped by KILL_ON_JOB_CLOSE.  Witness = Toolhelp
 *      snapshot (INDEPENDENT of the killer): no live process has ppid == the child cmd's pid.
 *   5. NO ORPHANS on TIMEOUT: `ping -n 30 ...` under cap_ms=1200 -> timed_out, elapsed sane,
 *      and the pid itself is gone from the snapshot.
 *   6. crt0-compatible quoting: space-arg wrapped, clean arg untouched, embedded quote REFUSED.
 *
 * Exit map: 2-3 exit300; 10-12 stdout; 20-22 stderr; 30-33 orphan-on-close; 40-43 timeout;
 *           50-52 quoting; 99 = full pass.
 * NIH: stoma_proc + kernel32 (Toolhelp) only. */
module corpus_2456

extern @abi(c-msvc-x64) fn proc_run(cmd: u64, cwd: u64, cap_ms: u32) -> i32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_code() -> u32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_timed_out() -> u32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_pid() -> u32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_ms() -> u64 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_out_len() -> u64 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_err_len() -> u64 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_out_find(pat: u64, plen: u64) -> u32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_err_find(pat: u64, plen: u64) -> u32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_quote(arg: u64, alen: u32, dst: u64, off: u32) -> u32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn CreateToolhelp32Snapshot(flags: u32, pid: u32) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn Process32First(snap: u64, ppe: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn Process32Next(snap: u64, ppe: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn Sleep(ms: u32) -> u64 from "kernel32"

var K_CMD : [u8; 128]
var K_PE  : [u8; 312]         /* PROCESSENTRY32 (ANSI, x64) = 304 */
var K_QB  : [u8; 64]

fn k_scpy(lit: u64, n: u32) -> i32 {
    let s : *u8 = lit as *u8
    let mut i : u32 = 0u32
    while i < n {
        K_CMD[i as u64] = s[i as u64]
        i = i + 1u32
    }
    K_CMD[n as u64] = 0u8
    return 0i32
}

/* count live processes with the given parent pid (ppsel=1) or with the given pid (ppsel=0) */
fn k_count(sel: u32, ppsel: u32) -> u32 {
    let snap : u64 = CreateToolhelp32Snapshot(2u32, 0u32)
    if snap + 1u64 == 0u64 { return 999u32 }
    let mut i : u64 = 0u64
    while i < 312u64 {
        K_PE[i] = 0u8
        i = i + 1u64
    }
    let psz : *u32 = ((&K_PE) as u64) as *u32
    psz[0u64] = 304u32
    let mut cnt : u32 = 0u32
    if Process32First(snap, (&K_PE) as u64) != 0i32 {
        let mut more : u32 = 1u32
        while more == 1u32 {
            let ppid : *u32 = (((&K_PE) as u64) + 32u64) as *u32
            let pid  : *u32 = (((&K_PE) as u64) + 8u64) as *u32
            if ppsel == 1u32 {
                if ppid[0u64] == sel { cnt = cnt + 1u32 }
            } else {
                if pid[0u64] == sel { cnt = cnt + 1u32 }
            }
            if Process32Next(snap, (&K_PE) as u64) == 0i32 { more = 0u32 }
        }
    }
    CloseHandle(snap)
    return cnt
}

fn main() -> u64 {
    /* ── 1. full-width exit code ── */
    k_scpy("cmd /c exit 300" as u64, 15u32)
    let r1 : i32 = proc_run((&K_CMD) as u64, 0u64, 20000u32)
    if r1 != 0i32 { return 2u64 }
    if proc_code() != 300u32 { return 3u64 }

    /* ── 2. stdout capture ── */
    k_scpy("cmd /c echo PROCPIPE" as u64, 20u32)
    let r2 : i32 = proc_run((&K_CMD) as u64, 0u64, 20000u32)
    if r2 != 0i32 { return 10u64 }
    if proc_code() != 0u32 { return 10u64 }
    if proc_out_find("PROCPIPE" as u64, 8u64) != 1u32 { return 11u64 }
    if proc_err_find("PROCPIPE" as u64, 8u64) != 0u32 { return 12u64 }

    /* ── 3. stderr capture ── */
    k_scpy("cmd /c echo ERRSIDE 1>&2" as u64, 24u32)
    let r3 : i32 = proc_run((&K_CMD) as u64, 0u64, 20000u32)
    if r3 != 0i32 { return 20u64 }
    if proc_err_find("ERRSIDE" as u64, 7u64) != 1u32 { return 21u64 }
    if proc_out_find("ERRSIDE" as u64, 7u64) != 0u32 { return 22u64 }

    /* ── 4. no orphans on job CLOSE ── */
    k_scpy("cmd /c start /b ping -n 30 -w 1000 127.0.0.1" as u64, 44u32)
    let r4 : i32 = proc_run((&K_CMD) as u64, 0u64, 20000u32)
    if r4 != 0i32 { return 30u64 }
    if proc_timed_out() != 0u32 { return 31u64 }
    let cpid : u32 = proc_pid()
    if cpid == 0u32 { return 32u64 }
    /* allow up to ~3s reap lag, then demand zero children of the dead cmd */
    let mut tries : u32 = 0u32
    let mut kids : u32 = 999u32
    while tries < 30u32 {
        kids = k_count(cpid, 1u32)
        if kids == 0u32 { tries = 30u32 }
        else {
            Sleep(100u32)
            tries = tries + 1u32
        }
    }
    if kids != 0u32 { return 33u64 }

    /* ── 5. no orphans on TIMEOUT ── */
    k_scpy("ping -n 30 -w 1000 127.0.0.1" as u64, 28u32)
    let r5 : i32 = proc_run((&K_CMD) as u64, 0u64, 1200u32)
    if r5 != 1i32 { return 40u64 }
    if proc_timed_out() != 1u32 { return 41u64 }
    let ms : u64 = proc_ms()
    if ms > 8000u64 { return 42u64 }
    let vpid : u32 = proc_pid()
    let mut tries2 : u32 = 0u32
    let mut live : u32 = 999u32
    while tries2 < 30u32 {
        live = k_count(vpid, 0u32)
        if live == 0u32 { tries2 = 30u32 }
        else {
            Sleep(100u32)
            tries2 = tries2 + 1u32
        }
    }
    if live != 0u32 { return 43u64 }

    /* ── 6. quoting ── */
    let q1 : u32 = proc_quote("a b" as u64, 3u32, (&K_QB) as u64, 0u32)
    if q1 != 5u32 { return 50u64 }
    if K_QB[0u64] != 34u8 { return 50u64 }
    if K_QB[4u64] != 34u8 { return 50u64 }
    let q2 : u32 = proc_quote("ab" as u64, 2u32, (&K_QB) as u64, 0u32)
    if q2 != 2u32 { return 51u64 }
    if K_QB[0u64] != 97u8 { return 51u64 }
    var K_BADQ : [u8; 4]
    K_BADQ[0u64] = 97u8
    K_BADQ[1u64] = 34u8
    K_BADQ[2u64] = 98u8
    let q3 : u32 = proc_quote((&K_BADQ) as u64, 3u32, (&K_QB) as u64, 0u32)
    if q3 + 1u32 != 0u32 { return 52u64 }

    return 99u64
}
