/* 2457_stoma_pty.iii -- STOMA M3 gate: ConPTY jobs (productized probe).
 *
 * Proves:
 *   1. echo through the pty: spawn `cmd /c echo PTYMARK55`, pump to child exit, marker present
 *      in the accumulated pty output (the M0 result, now via the organ API).
 *   2. VT preamble present: ConPTY attach emits its private-mode hello (ESC [ ? ) -- the child
 *      really is on a pseudoconsole, not a bare pipe (bytes arrive VERBATIM, VT and all).
 *   3. exit code captured: pty_code() == 0 after the echo child.
 *   4. Ctrl-C: spawn `cmd /c pause` (waits for a key), send pty_ctrlc(), the child terminates
 *      within a bounded wait (pty_exited() becomes 1).
 *
 * Exit map: 2-6 spawn errors; 10-11 echo marker; 12 VT preamble; 13 exit code; 20-22 ctrl-c;
 *           99 = full pass.
 * NIH: stoma_pty + kernel32 only. */
module corpus_2457

extern @abi(c-msvc-x64) fn pty_spawn(cmd: u64, cols: u32, rows: u32) -> i32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_pump() -> u64 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_acc_find(pat: u64, plen: u64) -> u32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_acc_len() -> u64 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_acc_byte(i: u64) -> u8 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_resize(cols: u32, rows: u32) -> i32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_acc_reset() -> i32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_exited() -> u32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_code() -> u32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_ctrlc() -> i32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_close() -> i32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn Sleep(ms: u32) -> u64 from "kernel32"

var K_CMD : [u8; 96]
var K_ESC : [u8; 2]
var K_PAT : [u8; 9]

fn k_scpy(lit: u64, n: u32) -> i32 {
    let s : *u8 = lit as *u8
    let mut i : u32 = 0u32
    while i < n { K_CMD[i as u64] = s[i as u64]   i = i + 1u32 }
    K_CMD[n as u64] = 0u8
    return 0i32
}

/* pump until child exits or a bounded number of idle slices pass */
fn k_run_to_exit(max_idle: u32) -> i32 {
    let mut idle : u32 = 0u32
    let mut guard : u32 = 0u32
    while guard < 2000u32 {
        guard = guard + 1u32
        let got : u64 = pty_pump()
        if got == 0u64 {
            if pty_exited() == 1u32 { guard = 2000u32 }
            else {
                idle = idle + 1u32
                if idle > max_idle { guard = 2000u32 }
                Sleep(5u32)
            }
        } else { idle = 0u32 }
    }
    return 0i32
}

fn main() -> u64 {
    /* ── 1-3. echo + VT + exit code ── */
    pty_acc_reset()
    k_scpy("cmd /c echo PTYMARK55" as u64, 21u32)
    let r1 : i32 = pty_spawn((&K_CMD) as u64, 80u32, 25u32)
    if r1 != 0i32 { return 2u64 + (r1 as u64) }
    k_run_to_exit(200u32)
    pty_close()
    if pty_acc_len() == 0u64 { return 10u64 }
    if pty_acc_find("PTYMARK55" as u64, 9u64) != 1u32 { return 11u64 }
    /* pty_acc_byte (the ring reader) finds the SAME marker pty_acc_find does -- two independent
     * readers agree -- and returns 0 past the stored length (the bound) */
    K_PAT[0u64]=80u8 K_PAT[1u64]=84u8 K_PAT[2u64]=89u8 K_PAT[3u64]=77u8 K_PAT[4u64]=65u8
    K_PAT[5u64]=82u8 K_PAT[6u64]=75u8 K_PAT[7u64]=53u8 K_PAT[8u64]=53u8
    let alen : u64 = pty_acc_len()
    let mut abfound : u32 = 0u32
    let mut ai : u64 = 0u64
    while ai + 9u64 <= alen {
        if pty_acc_byte(ai) == 80u8 {
            let mut aj : u64 = 0u64   let mut am : u32 = 1u32
            while aj < 9u64 { if pty_acc_byte(ai + aj) != K_PAT[aj] { am = 0u32   aj = 9u64 } else { aj = aj + 1u64 } }
            if am == 1u32 { abfound = 1u32   ai = alen }
        }
        ai = ai + 1u64
    }
    if abfound != 1u32 { return 14u64 }
    if pty_acc_byte(alen) != 0u8 { return 14u64 }              /* one past the stored length */
    if pty_acc_byte(1000000000u64) != 0u8 { return 14u64 }     /* far past = guarded 0 */
    /* VT preamble: ESC '[' '?' appears (ConPTY private-mode hello) */
    K_ESC[0u64] = 27u8
    K_ESC[1u64] = 91u8
    if pty_acc_find((&K_ESC) as u64, 2u64) != 1u32 { return 12u64 }
    if pty_code() != 0u32 { return 13u64 }

    /* ── 4. Ctrl-C terminates a paused child ── */
    pty_acc_reset()
    k_scpy("cmd /c pause" as u64, 12u32)
    let r2 : i32 = pty_spawn((&K_CMD) as u64, 80u32, 25u32)
    if r2 != 0i32 { return 20u64 }
    /* the LIVE pseudo-console accepts a resize (ResizePseudoConsole -> S_OK == 0) */
    if pty_resize(100u32, 30u32) != 0i32 { return 23u64 }
    /* let cmd print its "Press any key" prompt */
    let mut warm : u32 = 0u32
    while warm < 60u32 {
        warm = warm + 1u32
        pty_pump()
        Sleep(10u32)
    }
    if pty_exited() == 1u32 { return 21u64 }        /* must still be waiting */
    pty_ctrlc()
    /* pump + wait for the child to die within ~3s */
    let mut done : u32 = 0u32
    let mut spins : u32 = 0u32
    while spins < 300u32 {
        spins = spins + 1u32
        pty_pump()
        if pty_exited() == 1u32 { done = 1u32   spins = 300u32 }
        else { Sleep(10u32) }
    }
    pty_close()
    if done != 1u32 { return 22u64 }
    /* ...and a CLOSED pty refuses the resize (PT_ALIVE == 0 -> -1): the negative arm */
    if pty_resize(80u32, 25u32) != (0i32 - 1i32) { return 24u64 }

    return 99u64
}
