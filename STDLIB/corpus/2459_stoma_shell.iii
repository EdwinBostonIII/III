/* 2459_stoma_shell.iii -- STOMA M4 gate: shell integration + SJ1 journal round-trip.
 *
 * Proves the walking skeleton end to end:
 *   1. dispatch transcript: "help" -> help text; a bare external "cmd /c echo SHELLRUN" ->
 *      captured stdout + "[exit 0]"; an unknown program -> "cannot spawn"; a bad quote ->
 *      letter-precise caret error.
 *   2. journal round-trip: every fed line writes an input record (kind 1) + a transcript record
 *      (kind 2); re-reading the segment returns them in order with the right payloads.
 *   3. crash-safety: a synthetic torn segment (good record + partial header) yields exactly the
 *      good prefix then clean end -- no over-read (adversarial-verify arm).
 *   4. UNJOURNALED: appending with the journal closed returns 1 and bumps the counter -- the wire
 *      is never stalled by a journal fault (adversarial-verify arm).
 *
 * Exit map: 10-14 transcript; 20-24 journal round-trip; 30-33 torn tail; 40-41 unjournaled; 99.
 * NIH: stoma_shell + stoma_journal + kernel32. */
module corpus_2459

extern @abi(c-msvc-x64) fn shell_feed_line(line: u64, llen: u64) -> u32 from "stoma_shell.iii"
extern @abi(c-msvc-x64) fn shell_set_plain(v: u32) -> i32 from "stoma_shell.iii"
extern @abi(c-msvc-x64) fn shell_plain() -> u32 from "stoma_shell.iii"
extern @abi(c-msvc-x64) fn shell_set_con(v: u32) -> i32 from "stoma_shell.iii"
extern @abi(c-msvc-x64) fn vb_out_ptr() -> u64 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_out_len() -> u64 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_out_byte(i: u64) -> u8 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_out_reset() -> i32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_err_off() -> u64 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_build() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_extern() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn journal_seq() -> u64 from "stoma_journal.iii"
extern @abi(c-msvc-x64) fn journal_seg() -> u64 from "stoma_journal.iii"
extern @abi(c-msvc-x64) fn journal_rec_seq() -> u64 from "stoma_journal.iii"
extern @abi(c-msvc-x64) fn journal_rec_fnv() -> u64 from "stoma_journal.iii"

extern @abi(c-msvc-x64) fn journal_open(base: u64, taglen: u64, tag: u64) -> i32 from "stoma_journal.iii"
extern @abi(c-msvc-x64) fn journal_append(kind: u32, payload: u64, paylen: u64) -> i32 from "stoma_journal.iii"
extern @abi(c-msvc-x64) fn journal_close() -> i32 from "stoma_journal.iii"
extern @abi(c-msvc-x64) fn journal_unjournaled() -> u64 from "stoma_journal.iii"
extern @abi(c-msvc-x64) fn journal_read_open(path: u64) -> i32 from "stoma_journal.iii"
extern @abi(c-msvc-x64) fn journal_read_next() -> u32 from "stoma_journal.iii"
extern @abi(c-msvc-x64) fn journal_rec_kind() -> u32 from "stoma_journal.iii"
extern @abi(c-msvc-x64) fn journal_rec_paylen() -> u64 from "stoma_journal.iii"
extern @abi(c-msvc-x64) fn journal_rec_byte(i: u64) -> u8 from "stoma_journal.iii"

extern @abi(c-msvc-x64) fn CreateDirectoryA(name: u64, sec: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CreateFileA(name: u64, access: u32, share: u32, sec: u64, disp: u32, flags: u32, tmpl: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn WriteFile(h: u64, buf: u64, n: u32, pnw: u64, ovl: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> u32 from "kernel32"

var K_FED  : [u8; 128]
var K_TORN : [u8; 64]
var K_PATH : [u8; 64]
var K_SCR  : [u64; 2]

/* find literal in the current transcript */
fn out_find(pat: u64, plen: u64) -> u32 {
    let base : u64 = vb_out_ptr()
    let n : u64 = vb_out_len()
    if n < plen { return 0u32 }
    let s : *u8 = pat as *u8
    let b : *u8 = base as *u8
    let mut i : u64 = 0u64
    let lim : u64 = n - plen + 1u64
    while i < lim {
        let mut j : u64 = 0u64
        let mut ok : u32 = 1u32
        while j < plen {
            if b[i + j] != s[j] { ok = 0u32   j = plen }
            else { j = j + 1u64 }
        }
        if ok == 1u32 { return 1u32 }
        i = i + 1u64
    }
    return 0u32
}

fn feed(lit: u64, n: u64) -> u32 {
    let s : *u8 = lit as *u8
    let mut i : u64 = 0u64
    while i < n { K_FED[i] = s[i]   i = i + 1u64 }
    return shell_feed_line((&K_FED) as u64, n)
}

fn w32(base: u64, off: u64, v: u32) -> i32 {
    let p : *u32 = (base + off) as *u32
    p[0u64] = v
    return 0i32
}

fn main() -> u64 {
    /* headless mode: externals dispatch through plain pipes (no pty), the piped-gate default.
     * shell_plain reads back the flag we set; shell_set_con is the console-mode toggle (0 = off) */
    if shell_set_plain(1u32) != 0i32 { return 4u64 }
    if shell_plain() != 1u32 { return 4u64 }
    if shell_set_con(0u32) != 0i32 { return 4u64 }
    /* the verb-kind namespace is injective -- a classifier collapsing two kinds is a defect */
    if vb_k_build() == vb_k_extern() { return 4u64 }

    /* journal base: create ./stjt, session tag "s1" */
    CreateDirectoryA("stjt" as u64, 0u64)
    if journal_open("stjt" as u64, 2u64, "s1" as u64) != 0i32 { return 5u64 }

    /* ── 1. transcript ── */
    feed("help" as u64, 4u64)
    if out_find("STOMA verbs" as u64, 11u64) != 1u32 { return 10u64 }
    /* vb_out_byte mirrors the transcript buffer byte-for-byte, guarded past the written length */
    let vp : *u8 = vb_out_ptr() as *u8
    if vb_out_byte(0u64) != vp[0u64] { return 15u64 }
    if vb_out_byte(1000000u64) != 0u8 { return 15u64 }

    feed("cmd /c echo SHELLRUN" as u64, 20u64)
    if out_find("SHELLRUN" as u64, 8u64) != 1u32 { return 11u64 }
    if out_find("[exit 0]" as u64, 8u64) != 1u32 { return 12u64 }

    feed("no_such_program_xyzzy" as u64, 21u64)
    if out_find("cannot spawn" as u64, 12u64) != 1u32 { return 13u64 }

    /* bad quote -> caret error */
    feed("cd \"abc" as u64, 7u64)
    if out_find("unterminated quote" as u64, 18u64) != 1u32 { return 14u64 }
    /* the error offset points somewhere inside the 7-byte fed line (never a garbage magnitude) */
    if vb_err_off() > 7u64 { return 16u64 }

    journal_close()
    /* the append counters after four two-record lines: 8 records, all in segment 0 */
    if journal_seq() != 8u64 { return 6u64 }
    if journal_seg() != 0u64 { return 6u64 }

    /* ── 2. journal round-trip: reopen seg0 and count kind-1/kind-2 pairs ── */
    if journal_read_open("stjt/s1/seg0.sj1" as u64) != 0i32 { return 20u64 }
    /* first record must be kind 1 with payload "help" */
    if journal_read_next() != 1u32 { return 21u64 }
    if journal_rec_kind() != 1u32 { return 22u64 }
    if journal_rec_paylen() != 4u64 { return 22u64 }
    if journal_rec_byte(0u64) != 104u8 { return 22u64 }   /* 'h' */
    /* count all records; must be 8 (4 lines * 2 records) and alternate 1,2,1,2... */
    let mut cnt : u64 = 1u64
    let mut expect : u32 = 2u32
    let mut ok : u32 = 1u32
    /* record 1 carries stored seq 1 and a nonzero payload FNV; later records' seqs strictly
     * increase and at least one differs in FNV (distinct payloads -> distinct hash) */
    if journal_rec_seq() != 1u64 { return 22u64 }
    let fnv1 : u64 = journal_rec_fnv()
    if fnv1 == 0u64 { return 22u64 }
    let mut prev : u64 = 1u64
    let mut fnvdiff : u32 = 0u32
    while journal_read_next() == 1u32 {
        if journal_rec_kind() != expect { ok = 0u32 }
        let sq : u64 = journal_rec_seq()
        if sq <= prev { ok = 0u32 }
        prev = sq
        if journal_rec_fnv() != fnv1 { fnvdiff = 1u32 }
        if expect == 2u32 { expect = 1u32 } else { expect = 2u32 }
        cnt = cnt + 1u64
    }
    if ok != 1u32 { return 23u64 }
    if cnt != 8u64 { return 24u64 }
    if fnvdiff != 1u32 { return 24u64 }

    /* ── 3. torn tail: SJ1 header + one good record (len 24+3 "XYZ") + partial header ── */
    K_TORN[0u64]=83u8  K_TORN[1u64]=74u8  K_TORN[2u64]=49u8  K_TORN[3u64]=1u8
    w32((&K_TORN) as u64, 4u64, 27u32)          /* rec_len = 24 + 3 */
    w32((&K_TORN) as u64, 8u64, 2u32)           /* kind = 2 */
    /* seq(8)+ts(8) zero @ +12..+27, payload "XYZ" @ +28..+30 */
    K_TORN[28u64]=88u8  K_TORN[29u64]=89u8  K_TORN[30u64]=90u8
    /* partial next record: only 6 bytes of a header (claims len 999) */
    w32((&K_TORN) as u64, 31u64, 999u32)
    K_TORN[35u64]=0u8   K_TORN[36u64]=0u8
    /* total torn file bytes = 37 */
    let h : u64 = CreateFileA("stjt/torn.sj1" as u64, 1073741824u32, 1u32, 0u64, 2u32, 128u32, 0u64)
    if h + 1u64 == 0u64 { return 30u64 }
    WriteFile(h, (&K_TORN) as u64, 37u32, (&K_SCR) as u64, 0u64)
    CloseHandle(h)
    if journal_read_open("stjt/torn.sj1" as u64) != 0i32 { return 31u64 }
    if journal_read_next() != 1u32 { return 32u64 }       /* the good record */
    if journal_rec_paylen() != 3u64 { return 32u64 }
    if journal_read_next() != 0u32 { return 33u64 }       /* torn tail: clean stop, no over-read */

    /* ── 4. UNJOURNALED: journal is closed; append must fail-soft ── */
    let before : u64 = journal_unjournaled()
    if journal_append(2u32, "z" as u64, 1u64) != 1i32 { return 40u64 }
    if journal_unjournaled() != before + 1u64 { return 41u64 }

    /* vb_out_reset empties the transcript buffer (the app clears it between frames) */
    vb_out_reset()
    if vb_out_len() != 0u64 { return 42u64 }

    return 99u64
}
