/* 2463_stoma_ripple.iii -- STOMA M8 gate: the ripple heartbeat, deterministic.
 *
 * Builds a synthetic module graph in a scratch dir (rga -> rgb -> rgc; rgd unrelated), then:
 *   1. content-hash DEBOUNCE: a pulse right after baseline finds 0 dirty (nothing moved).
 *   2. reverse IMPACT: edit the leaf rgc -> pulse finds dirty={rgc} -> impacted set is exactly
 *      {rga, rgb, rgc} (all that transitively import rgc), EXCLUDING rgd.
 *   3. DEBOUNCE again: a second pulse after the re-hash finds 0 dirty.
 *   4. SELF-TRIGGER exclusion: writing a build artifact (.o, not indexed) dirties nothing.
 *   5. BLAME set (cell->gene): blame(rga) == its forward closure {rga, rgb, rgc} == 3.
 *
 * Exit map: 10 index; 20 debounce; 30-34 impact; 40 debounce2; 50 self-trigger; 60 blame; 99.
 * NIH: stoma_ripple + stoma_build + kernel32.  Files are plain text (the engine scans bytes). */
module corpus_2463

extern @abi(c-msvc-x64) fn bd_reset() -> i32 from "stoma_build.iii"
extern @abi(c-msvc-x64) fn bd_index_dir(dir: u64) -> u64 from "stoma_build.iii"
extern @abi(c-msvc-x64) fn bd_closure_count() -> u64 from "stoma_build.iii"
extern @abi(c-msvc-x64) fn rp_reset() -> i32 from "stoma_ripple.iii"
extern @abi(c-msvc-x64) fn rp_baseline() -> i32 from "stoma_ripple.iii"
extern @abi(c-msvc-x64) fn rp_pulse() -> u64 from "stoma_ripple.iii"
extern @abi(c-msvc-x64) fn rp_impacted() -> u64 from "stoma_ripple.iii"
extern @abi(c-msvc-x64) fn rp_in_impact(name: u64, nlen: u64) -> u32 from "stoma_ripple.iii"
extern @abi(c-msvc-x64) fn rp_blame(name: u64, nlen: u64) -> u64 from "stoma_ripple.iii"

extern @abi(c-msvc-x64) fn CreateDirectoryA(name: u64, sec: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CreateFileA(name: u64, access: u32, share: u32, sec: u64, disp: u32, flags: u32, tmpl: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn WriteFile(h: u64, buf: u64, n: u32, pnw: u64, ovl: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> u32 from "kernel32"

var K_SCR : [u64; 2]
var K_TMP : [u8; 256]

fn slen(p: u64) -> u64 {
    let s : *u8 = p as *u8
    let mut i : u64 = 0u64
    let mut go : u32 = 1u32
    while go == 1u32 { if s[i] == 0u8 { go = 0u32 } else { i = i + 1u64 } }
    return i
}

/* write content (NUL-terminated) to path (NUL-terminated), CREATE_ALWAYS */
fn wfile(path: u64, content: u64) -> i32 {
    let h : u64 = CreateFileA(path, 1073741824u32, 1u32, 0u64, 2u32, 128u32, 0u64)
    if h + 1u64 == 0u64 { return 0i32 - 1i32 }
    let n : u64 = slen(content)
    WriteFile(h, content, n as u32, (&K_SCR) as u64, 0u64)
    CloseHandle(h)
    return 0i32
}

fn main() -> u64 {
    CreateDirectoryA("stjt_rip" as u64, 0u64)
    wfile("stjt_rip/rga.iii" as u64, "module rga\nfrom \"rgb.iii\"\n" as u64)
    wfile("stjt_rip/rgb.iii" as u64, "module rgb\nfrom \"rgc.iii\"\n" as u64)
    wfile("stjt_rip/rgc.iii" as u64, "module rgc\n// leaf v1\n" as u64)
    wfile("stjt_rip/rgd.iii" as u64, "module rgd\n// unrelated\n" as u64)

    bd_reset()
    if bd_index_dir("stjt_rip" as u64) != 4u64 { return 10u64 }
    rp_reset()
    rp_baseline()

    /* 1. debounce: immediate pulse finds nothing */
    if rp_pulse() != 0u64 { return 20u64 }

    /* 2. edit the leaf rgc -> impact {rga,rgb,rgc} */
    wfile("stjt_rip/rgc.iii" as u64, "module rgc\n// leaf v2 EDITED\n" as u64)
    if rp_pulse() != 1u64 { return 30u64 }
    if rp_impacted() != 3u64 { return 31u64 }
    if rp_in_impact("rga" as u64, 3u64) != 1u32 { return 32u64 }
    if rp_in_impact("rgb" as u64, 3u64) != 1u32 { return 32u64 }
    if rp_in_impact("rgc" as u64, 3u64) != 1u32 { return 32u64 }
    if rp_in_impact("rgd" as u64, 3u64) != 0u32 { return 33u64 }   /* unrelated NOT impacted */

    /* 3. debounce after re-hash */
    if rp_pulse() != 0u64 { return 40u64 }

    /* 4. self-trigger exclusion: a build artifact (.o) is not indexed -> no dirty */
    wfile("stjt_rip/rgc.o" as u64, "OBJECTBYTES" as u64)
    if rp_pulse() != 0u64 { return 50u64 }

    /* 5. blame(rga) == forward closure {rga,rgb,rgc} == 3 */
    if rp_blame("rga" as u64, 3u64) != 3u64 { return 60u64 }
    if bd_closure_count() != 3u64 { return 60u64 }

    return 99u64
}
