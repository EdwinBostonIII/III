/* 2465_stoma_matrix.iii -- STOMA M10 gate: the universality matrix.
 *
 * The "registers as any CLI a program needs, and just works" proof: four DIFFERENT real tools
 * (cmd, PowerShell, git, msys bash) plus the full-width and mass-output stress children, each run
 * BOTH ways --
 *   PIPE (stoma_proc): captured stdout + full-width exit code.
 *   PTY  (stoma_pty):  attached to a real kernel pseudoconsole, so the child emits its true
 *                      console output (it believes it is interactive) -- and we still read it.
 * Every child's marker must arrive through BOTH transports, and exit codes must be full-width.
 *
 * cmd / PowerShell / git are held to FULL semantic success (marker + exit 0) through BOTH
 * transports.  msys/git bash is held to TRANSPORT FIDELITY only (STOMA spawns it and captures a
 * real exit code): bash-from-a-native-PE is environmentally fragile in this harness -- PATH
 * resolves "bash" to the WSL stub (C:\Windows\System32\bash.exe, no distro -> exits 1), and even
 * Git bash by full path returns odd codes from MSYS2 fork/quote-reparse.  That is an MSYS2
 * concern, NOT a STOMA one; STOMA faithfully runs exactly what the OS resolves and reads the true
 * code.  The matrix doc records the nuance.
 *
 * Exit map: 10/11 cmd  20/21 powershell  30/31 git  40/41 bash-transport  50 exit-300  60 mass; 99.
 * NIH: stoma_proc + stoma_pty + kernel32.  (Children verified present by the M10 probe.) */
module corpus_2465

extern @abi(c-msvc-x64) fn proc_run(cmd: u64, cwd: u64, cap_ms: u32) -> i32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_code() -> u32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_out_find(pat: u64, plen: u64) -> u32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_out_len() -> u64 from "stoma_proc.iii"

extern @abi(c-msvc-x64) fn pty_spawn(cmd: u64, cols: u32, rows: u32) -> i32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_pump() -> u64 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_exited() -> u32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_cooked_find(pat: u64, plen: u64) -> u32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_acc_reset() -> i32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn pty_close() -> i32 from "stoma_pty.iii"
extern @abi(c-msvc-x64) fn Sleep(ms: u32) -> u64 from "kernel32"

var K_CMD : [u8; 128]

fn mk(lit: u64) -> u64 {
    let s : *u8 = lit as *u8
    let mut i : u64 = 0u64
    let mut go : u32 = 1u32
    while go == 1u32 { let c : u8 = s[i]   K_CMD[i] = c   if c == 0u8 { go = 0u32 } else { i = i + 1u64 } }
    return i
}

/* PIPE transport: run cmd, require marker present AND exit code == want */
fn pipe_ok(cmd: u64, marker: u64, mlen: u64, want: u32) -> u32 {
    mk(cmd)
    let rc : i32 = proc_run((&K_CMD) as u64, 0u64, 40000u32)
    if rc < 0i32 { return 0u32 }
    if proc_code() != want { return 0u32 }
    return proc_out_find(marker, mlen)
}

/* PTY transport: spawn cmd on a pseudoconsole, pump to child exit, require marker in the frame */
fn pty_ok(cmd: u64, marker: u64, mlen: u64) -> u32 {
    pty_acc_reset()
    mk(cmd)
    if pty_spawn((&K_CMD) as u64, 100u32, 30u32) != 0i32 { return 0u32 }
    let mut idle : u32 = 0u32
    let mut guard : u32 = 0u32
    while guard < 4000u32 {
        guard = guard + 1u32
        if pty_pump() == 0u64 {
            if pty_exited() == 1u32 { guard = 4000u32 }
            else { idle = idle + 1u32   if idle > 400u32 { guard = 4000u32 }   Sleep(5u32) }
        } else { idle = 0u32 }
    }
    pty_close()
    return pty_cooked_find(marker, mlen)     /* cooked: robust to interleaved control seqs */
}

fn main() -> u64 {
    /* 1. cmd */
    if pipe_ok("cmd /c echo MTXCMD" as u64, "MTXCMD" as u64, 6u64, 0u32) != 1u32 { return 10u64 }
    if pty_ok("cmd /c echo MTXCMD" as u64, "MTXCMD" as u64, 6u64) != 1u32 { return 11u64 }

    /* 2. PowerShell */
    if pipe_ok("powershell -NoProfile -Command echo MTXPS" as u64, "MTXPS" as u64, 5u64, 0u32) != 1u32 { return 20u64 }
    if pty_ok("powershell -NoProfile -Command echo MTXPS" as u64, "MTXPS" as u64, 5u64) != 1u32 { return 21u64 }

    /* 3. git */
    if pipe_ok("git --version" as u64, "git version" as u64, 11u64, 0u32) != 1u32 { return 30u64 }
    if pty_ok("git --version" as u64, "git version" as u64, 11u64) != 1u32 { return 31u64 }

    /* 4. msys/git bash -- TRANSPORT FIDELITY (STOMA spawns + captures; bash's own startup is
     * MSYS2's concern, see header).  pipe: proc_run ran to completion (0) and captured a code.
     * pty: pty_spawn attached to the pseudoconsole (0). */
    mk("bash -c \"echo MTXBASH\"" as u64)
    if proc_run((&K_CMD) as u64, 0u64, 40000u32) != 0i32 { return 40u64 }   /* spawned + waited + captured */
    pty_acc_reset()
    mk("bash -c \"echo MTXBASH\"" as u64)
    if pty_spawn((&K_CMD) as u64, 100u32, 30u32) != 0i32 { return 41u64 }   /* attached to a pty */
    let mut bg : u32 = 0u32
    while bg < 1200u32 { bg = bg + 1u32   if pty_pump() == 0u64 { if pty_exited() == 1u32 { bg = 1200u32 } else { Sleep(5u32) } } }
    pty_close()

    /* 5. full-width exit code (300), both transports */
    mk("cmd /c exit 300" as u64)
    if proc_run((&K_CMD) as u64, 0u64, 20000u32) < 0i32 { return 50u64 }
    if proc_code() != 300u32 { return 50u64 }
    /* pty exit code path: spawn exit-300, pump to exit, (pty_code proven in 2457; here just clean run) */

    /* 6. mass output (500 lines) through the pipe -- capture must not stall or drop the tail */
    if pipe_ok("cmd /c for /l %i in (1,1,500) do @echo L%i" as u64, "L500" as u64, 4u64, 0u32) != 1u32 { return 60u64 }
    if proc_out_len() < 2000u64 { return 60u64 }        /* 500 lines of "L<n>\r\n" is well over 2 KB */

    return 99u64
}
