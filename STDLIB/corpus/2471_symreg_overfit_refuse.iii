/* 2471_symreg_overfit_refuse.iii -- FALSIFIER for symbolic_regression (reunification W4a.6.1b):
 * OVERFIT REFUSAL.  A pure-noise table (5 scattered points with no low-depth closed form over the
 * declared basis) must return SYMREG_E_NO_FIT (-3) at tol 0 -- NEVER an N-term interpolation.
 * This is the anti-ML tooth: the engine is an exact bounded searcher, not a curve fitter; when no
 * expressible form exists it REFUSES rather than hallucinating fit.
 *
 * Noise table: (1,7) (2,3) (3,9) (4,2) (5,8) -- non-monotone, prime-scattered.  Basis
 * {ADD, SUB, MUL} + const 2, depth 3, 1 var, tol 0.  Sub-arm: the SAME basis and depth DOES fit a
 * legitimate table generated by (x*x)-2 (1->-1, 2->2, 3->7, 4->14, 5->23), proving the refusal
 * arm is not a dead searcher (positive-arm discipline: the negative is meaningful only because
 * the identical configuration succeeds on expressible data).
 *
 * exit 99 = pass;  10 noise not-refused;  11 positive arm regress;  12 positive arm verify */
module corpus_2471_symreg_overfit_refuse

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn symreg_init() -> i32 from "symbolic_regression.iii"
extern @abi(c-msvc-x64) fn symreg_regress(req: *u8, out_expr: *u8, out_expr_cap: u32, out_len: *u32) -> i32 from "symbolic_regression.iii"
extern @abi(c-msvc-x64) fn symreg_verify(expr: *u8, expr_len: u32, data: *u8, data_len: u32, tol_q: u64) -> u8 from "symbolic_regression.iii"
extern @abi(c-msvc-x64) fn wh_init(t: u64) -> i32 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(p: u64, m: u64, e: u64) -> u64 from "capability.iii"

fn e_i64(v: i64) -> i32 { if v < 0i64 { putchar(45i32)   return e_i64(0i64 - v) }   if v >= 10i64 { e_i64(v / 10i64) }   putchar(((v % 10i64) + 48i64) as i32)   return 0i32 }
fn sp() -> i32 { putchar(32i32)   return 0i32 }   fn nl() -> i32 { putchar(10i32)   return 0i32 }

var RQ  : [u8; 64]
var SG  : [u8; 64]
var DT  : [u8; 128]    /* 5 rows x 2 x 9 = 90 */
var EX  : [u8; 320]
var XL  : [u32; 1]
var CAPV : [u64; 1]

fn put32(b: u64, off: u64, v: u32) -> i32 {
    let p : *u8 = b as *u8
    p[off] = (v & 0xFFu32) as u8   p[off+1u64] = ((v >> 8u32) & 0xFFu32) as u8
    p[off+2u64] = ((v >> 16u32) & 0xFFu32) as u8   p[off+3u64] = ((v >> 24u32) & 0xFFu32) as u8
    return 0i32
}
fn put64(b: u64, off: u64, v: u64) -> i32 {
    let p : *u8 = b as *u8
    let mut k : u64 = 0u64
    while k < 8u64 { p[off+k] = ((v >> (k*8u64)) & 0xFFu64) as u8   k = k + 1u64 }
    return 0i32
}
fn putval(b: u64, off: u64, sign: u8, mag: u64) -> i32 {
    let p : *u8 = b as *u8
    p[off] = sign & 1u8
    put64(b, off + 1u64, mag)
    return 0i32
}
fn q(k: u64) -> u64 { return k * 4294967296u64 }

fn build_sig() -> i32 {
    let s : u64 = &SG as u64
    put32(s, 0u64, 0x53524731u32)
    put32(s, 4u64, 3u32)
    let sp8 : *u8 = s as *u8
    sp8[8u64]  = 0x10u8               /* ADD */
    sp8[9u64]  = 0x11u8               /* SUB */
    sp8[10u64] = 0x12u8               /* MUL */
    put32(s, 11u64, 1u32)             /* n_consts = 1 */
    sp8[15u64] = 0u8                  /* +2 */
    put64(s, 16u64, q(2u64))
    return 0i32
}
fn build_req() -> i32 {
    let b : u64 = &RQ as u64
    put32(b, 0u64, 0x53525231u32)
    put32(b, 4u64, 1u32)
    put32(b, 8u64, 5u32)
    let p : *u8 = b as *u8
    p[12u64] = 0u8
    put64(b, 13u64, 0u64)             /* tol 0 */
    put32(b, 21u64, 3u32)             /* depth 3 */
    put64(b, 25u64, &DT as u64)
    put64(b, 33u64, &SG as u64)
    put32(b, 41u64, 24u32)
    put64(b, 45u64, CAPV[0u64])
    return 0i32
}

fn main() -> u64 {
    symreg_init()
    wh_init(0u64)
    let root : u64 = cap_env_init()
    CAPV[0u64] = cap_attenuate(root, 0x0800u64, 0u64)
    build_sig()
    /* ══ NOISE: (1,7) (2,3) (3,9) (4,2) (5,8) -> must REFUSE. */
    let d : u64 = &DT as u64
    putval(d, 0u64,  0u8, q(1u64))   putval(d, 9u64,  0u8, q(7u64))
    putval(d, 18u64, 0u8, q(2u64))   putval(d, 27u64, 0u8, q(3u64))
    putval(d, 36u64, 0u8, q(3u64))   putval(d, 45u64, 0u8, q(9u64))
    putval(d, 54u64, 0u8, q(4u64))   putval(d, 63u64, 0u8, q(2u64))
    putval(d, 72u64, 0u8, q(5u64))   putval(d, 81u64, 0u8, q(8u64))
    build_req()
    let rn : i32 = symreg_regress((&RQ) as u64 as *u8, (&EX) as u64 as *u8, 320u32, (&XL) as u64 as *u32)
    putchar(78i32) putchar(58i32) sp() e_i64(rn as i64) nl()          /* "N: -3" */
    if rn != (0i32 - 3i32) { return 10u64 }

    /* ══ POSITIVE ARM: same basis/depth, data from (x*x)-2 -> must FIT (searcher is alive). */
    putval(d, 9u64,  1u8, q(1u64))    /* 1 -> -1 */
    putval(d, 27u64, 0u8, q(2u64))    /* 2 ->  2 */
    putval(d, 45u64, 0u8, q(7u64))    /* 3 ->  7 */
    putval(d, 63u64, 0u8, q(14u64))   /* 4 -> 14 */
    putval(d, 81u64, 0u8, q(23u64))   /* 5 -> 23 */
    build_req()
    let rp : i32 = symreg_regress((&RQ) as u64 as *u8, (&EX) as u64 as *u8, 320u32, (&XL) as u64 as *u32)
    putchar(80i32) putchar(58i32) sp() e_i64(rp as i64) sp() e_i64(XL[0u64] as i64) nl()
    if rp != 0i32 { return 11u64 }
    if symreg_verify((&EX) as u64 as *u8, XL[0u64], (&DT) as u64 as *u8, 90u32, 0u64) != 1u8 { return 12u64 }

    return 99u64
}
