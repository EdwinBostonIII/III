/* 2485_choreography.iii -- GATE for MULTI-AGENT EXACT CHOREOGRAPHY (E-IV): rs_elim TOI + continuous
 * tangency + the commuting-event planner, composed on the exact Q(sqrt2) substrate (choreo.iii +
 * numera resultant).  The multi-agent lift of no-tunneling collision (2153) + inverse design (2480)
 * + the gas commuting-tie theorem.
 *
 * A -- CONTINUOUS TANGENCY BY ELIMINATION: agent 0 at (0,0,0) moving +x (r=1) vs agent 1 at (10,u,0)
 *   moving -x (r=1).  sep2(t;u) = 4t^2 - 40t + (96 + u^2).  The grazing designs are the roots of the
 *   discriminant-in-u, delivered EXACTLY by Res_t(sep2, d sep2/dt) = 64 u^2 - 256 (rs_elim), so the
 *   tangency locus is u = +-2 -- an algebraic set, not sampled.  WELD: choreo's exact disc-sign
 *   agrees at u=1 (HIT, +1), u=2 (GRAZE, 0), u=3 (MISS, -1); at the graze the contact time is the
 *   EXACT t* = -B/2A = 5.
 * B -- THE COMMUTING-EVENT PLANNER: two DISJOINT head-on pairs {0,1} and {2,3} contact at the SAME
 *   exact instant (TOI = 1, certified equal).  The elastic response touches only each pair's two
 *   velocity slots, so applying {0,1} then {2,3} yields the BIT-IDENTICAL exact Q(sqrt2) velocity
 *   state as the reverse order -- the choreography is well-defined without an ordering tie-break.
 * C -- INTERACTING REFUSAL (teeth): pairs {0,1} and {1,2} share agent 1, so they mutate a shared
 *   velocity slot -- ch_pairs_disjoint == 0, the tie is CERTIFIED and REFUSED, never silently
 *   commuted (order genuinely matters there).
 * D -- EXACT SURD PATH: agent 0 moving (3+sqrt2, 0, 0) vs a stationary agent 1 at (20,0,0) has
 *   discriminant 176 + 96 sqrt2 -- genuinely irrational -- whose sign (+1, HIT) is decided exactly
 *   by the surd engine, no float.
 *
 * exit 99 = pass;  10 A elim;  11 A disc-signs/graze;  12 B TOI-tie;  13 B non-commuting;
 *   14 C interacting-not-refused;  15 D surd sign */
module corpus_2485_choreography

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn rs_elim(fp: u64, fdu: i64, fdt: i64, gp: u64, gdu: i64, gdt: i64, outp: u64) -> i64 from "resultant.iii"
extern @abi(c-msvc-x64) fn ch_reset() -> i32 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_add_agent(px0: i64, px1: i64, pxd: i64, py0: i64, py1: i64, pyd: i64, pz0: i64, pz1: i64, pzd: i64, vx0: i64, vx1: i64, vxd: i64, vy0: i64, vy1: i64, vyd: i64, vz0: i64, vz1: i64, vzd: i64, r: i64) -> i32 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_disc_sign(i: u64, j: u64) -> i32 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_graze_time(i: u64, j: u64) -> i32 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_toi(i: u64, j: u64) -> i32 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_toi_exit(i: u64, j: u64) -> i32 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_t0() -> i64 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_t1() -> i64 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_td() -> i64 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_apply(i: u64, j: u64) -> i32 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_vel(i: u64, axis: u64, k: u64) -> i64 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_pairs_disjoint(i: u64, j: u64, k: u64, l: u64) -> u8 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_snapshot() -> i32 from "choreo.iii"
extern @abi(c-msvc-x64) fn ch_state_eq_snapshot() -> u8 from "choreo.iii"

fn e_i64(v: i64) -> i32 { if v < 0i64 { putchar(45i32)   return e_i64(0i64 - v) }   if v >= 10i64 { e_i64(v / 10i64) }   putchar(((v % 10i64) + 48i64) as i32)   return 0i32 }
fn sp() -> i32 { putchar(32i32)   return 0i32 }   fn nl() -> i32 { putchar(10i32)   return 0i32 }

var EF : [i64; 64]   var EG : [i64; 64]   var EO : [i64; 20]
fn zf() -> i32 { let mut i : u64 = 0u64   while i < 64u64 { EF[i] = 0i64   EG[i] = 0i64   i = i + 1u64 }   return 0i32 }

/* integer agent at (x,y,z) with integer velocity (vx,vy,vz), radius r */
fn addI(x: i64, y: i64, z: i64, vx: i64, vy: i64, vz: i64, r: i64) -> i32 {
    return ch_add_agent(x,0i64,1i64, y,0i64,1i64, z,0i64,1i64, vx,0i64,1i64, vy,0i64,1i64, vz,0i64,1i64, r)
}
/* build the 4-agent commuting scene: disjoint head-on pairs {0,1} and {2,3}, both TOI=1 */
fn scene4() -> i32 {
    ch_reset()
    addI(0i64,0i64,0i64,  1i64,0i64,0i64, 1i64)          /* A0 */
    addI(4i64,0i64,0i64,  0i64-1i64,0i64,0i64, 1i64)     /* A1 */
    addI(0i64,50i64,0i64, 1i64,0i64,0i64, 1i64)          /* A2 */
    addI(4i64,50i64,0i64, 0i64-1i64,0i64,0i64, 1i64)     /* A3 */
    return 0i32
}

fn main() -> u64 {
    /* ══ A: rs_elim tangency-design. F=sep2(t;u)=4t^2-40t+96+u^2 (row=deg_t, j=deg_u); G=dF/dt. */
    zf()
    EF[16u64] = 4i64   EF[8u64] = 0i64 - 40i64   EF[0u64] = 96i64   EF[2u64] = 1i64
    EG[8u64] = 8i64    EG[0u64] = 0i64 - 40i64
    let da : i64 = rs_elim((&EF) as u64, 2i64, 2i64, (&EG) as u64, 1i64, 0i64, (&EO) as u64)
    putchar(65i32) putchar(58i32) sp() e_i64(da) sp() e_i64(EO[0u64]) sp() e_i64(EO[1u64]) sp() e_i64(EO[2u64]) nl()   /* "A: 2 -256 0 64" */
    if da != 2i64 { return 10u64 }
    if EO[0u64] != (0i64 - 256i64) { return 10u64 }        /* Res_t = 64 u^2 - 256 */
    if EO[1u64] != 0i64 { return 10u64 }
    if EO[2u64] != 64i64 { return 10u64 }                  /* roots u = +-2: the grazing designs */

    /* the exact disc-sign weld at u=1 (hit), u=2 (graze + t*=5), u=3 (miss). */
    ch_reset()   addI(0i64,0i64,0i64, 1i64,0i64,0i64, 1i64)   addI(10i64,1i64,0i64, 0i64-1i64,0i64,0i64, 1i64)
    let s1 : i32 = ch_disc_sign(0u64,1u64)
    ch_reset()   addI(0i64,0i64,0i64, 1i64,0i64,0i64, 1i64)   addI(10i64,2i64,0i64, 0i64-1i64,0i64,0i64, 1i64)
    let s2 : i32 = ch_disc_sign(0u64,1u64)
    let g2 : i32 = ch_graze_time(0u64,1u64)
    let gt0 : i64 = ch_t0()   let gt1 : i64 = ch_t1()   let gtd : i64 = ch_td()
    ch_reset()   addI(0i64,0i64,0i64, 1i64,0i64,0i64, 1i64)   addI(10i64,3i64,0i64, 0i64-1i64,0i64,0i64, 1i64)
    let s3 : i32 = ch_disc_sign(0u64,1u64)
    putchar(87i32) putchar(58i32) sp() e_i64(s1 as i64) sp() e_i64(s2 as i64) sp() e_i64(s3 as i64) sp() e_i64(gt0) putchar(47i32) e_i64(gtd) nl()   /* "W: 1 0 -1 320/64" */
    if s1 != 1i32 { return 11u64 }
    if s2 != 0i32 { return 11u64 }
    if s3 != (0i32 - 1i32) { return 11u64 }
    if g2 != 1i32 { return 11u64 }
    if (gt0 * 1i64) != (5i64 * gtd) { return 11u64 }       /* t* == 5 exactly (as a fraction) */
    if gt1 != 0i64 { return 11u64 }                        /* the integer-scene graze time is RATIONAL: zero sqrt2-coefficient */

    /* ══ B: the commuting-event planner. certify the two disjoint pairs share the exact TOI. */
    scene4()
    if ch_toi(0u64,1u64) != 1i32 { return 12u64 }
    let ta0 : i64 = ch_t0()   let tad : i64 = ch_td()
    /* the contact EXIT time strictly follows entry.  NOTE ch_t1() is the sqrt2-COEFFICIENT of the
     * time triple t = (T0 + T1 sqrt2)/TD, not a second root -- the exit root has its own accessor. */
    if ch_toi_exit(0u64,1u64) != 1i32 { return 12u64 }
    let tx0 : i64 = ch_t0()   let txd : i64 = ch_td()
    if (tx0 * tad) <= (ta0 * txd) { return 12u64 }         /* exit > entry, exact cross-multiply (dens > 0) */
    if ch_toi(0u64,1u64) != 1i32 { return 12u64 }          /* restore the entry triple for the tie test */
    if ch_toi(2u64,3u64) != 1i32 { return 12u64 }
    let tb0 : i64 = ch_t0()   let tbd : i64 = ch_td()
    /* certified simultaneous: ta0/tad == tb0/tbd (both == 1) */
    if (ta0 * tbd) != (tb0 * tad) { return 12u64 }
    putchar(66i32) putchar(58i32) sp() e_i64(ta0) putchar(47i32) e_i64(tad) sp() e_i64(ch_pairs_disjoint(0u64,1u64,2u64,3u64) as i64) nl()   /* "B: 8/8 1" */
    if ch_pairs_disjoint(0u64,1u64,2u64,3u64) != 1u8 { return 12u64 }

    /* order 1: {0,1} then {2,3} -> snapshot */
    scene4()
    ch_apply(0u64,1u64)   ch_apply(2u64,3u64)
    ch_snapshot()
    /* order 2: {2,3} then {0,1} -> must equal the snapshot BIT-EXACTLY */
    scene4()
    ch_apply(2u64,3u64)   ch_apply(0u64,1u64)
    let eq : u8 = ch_state_eq_snapshot()
    /* also confirm the response is NON-trivial: V0x swapped to -1 */
    let v0x0 : i64 = ch_vel(0u64,0u64,0u64)   let v0xd : i64 = ch_vel(0u64,0u64,2u64)
    putchar(67i32) putchar(58i32) sp() e_i64(eq as i64) sp() e_i64(v0x0) putchar(47i32) e_i64(v0xd) nl()   /* "C: 1 -1/1-ish" */
    if eq != 1u8 { return 13u64 }
    if (v0x0 * 1i64) != (0i64 - 1i64) * v0xd { return 13u64 }   /* the exchange actually happened */

    /* ══ C: interacting tie must be REFUSED. {0,1} and {1,2} share agent 1. */
    if ch_pairs_disjoint(0u64,1u64,1u64,2u64) != 0u8 { return 14u64 }   /* j==k */
    if ch_pairs_disjoint(0u64,1u64,3u64,1u64) != 0u8 { return 14u64 }   /* j==l */
    if ch_pairs_disjoint(2u64,1u64,2u64,3u64) != 0u8 { return 14u64 }   /* i==k */
    if ch_pairs_disjoint(0u64,1u64,3u64,0u64) != 0u8 { return 14u64 }   /* i==l */
    /* and the POSITIVE arm: a genuinely disjoint pair-set IS admitted */
    if ch_pairs_disjoint(0u64,1u64,2u64,3u64) != 1u8 { return 14u64 }

    /* ══ D: exact surd path. agent 0 vel (3+sqrt2,0,0), agent 1 stationary at (20,0,0). disc=176+96 sqrt2>0. */
    ch_reset()
    ch_add_agent(0i64,0i64,1i64, 0i64,0i64,1i64, 0i64,0i64,1i64,  3i64,1i64,1i64, 0i64,0i64,1i64, 0i64,0i64,1i64, 1i64)
    addI(20i64,0i64,0i64, 0i64,0i64,0i64, 1i64)
    let sd : i32 = ch_disc_sign(0u64,1u64)
    putchar(68i32) putchar(58i32) sp() e_i64(sd as i64) nl()          /* "D: 1" */
    if sd != 1i32 { return 15u64 }

    /* ══ E: THE COMMUTING THEOREM IS NON-VACUOUS (teeth).  Three colinear agents: {0,1} and {1,2}
     * SHARE agent 1, so the two application orders mutate a shared slot and MUST diverge -- proving
     * disjointness is load-bearing, not decorative. */
    ch_reset()
    addI(0i64,0i64,0i64,  2i64,0i64,0i64, 1i64)          /* A0 -> */
    addI(5i64,0i64,0i64,  0i64,0i64,0i64, 1i64)          /* A1 (still) */
    addI(10i64,0i64,0i64, 0i64-2i64,0i64,0i64, 1i64)     /* A2 <- */
    ch_apply(0u64,1u64)   ch_apply(1u64,2u64)            /* order 1 */
    ch_snapshot()
    ch_reset()
    addI(0i64,0i64,0i64,  2i64,0i64,0i64, 1i64)
    addI(5i64,0i64,0i64,  0i64,0i64,0i64, 1i64)
    addI(10i64,0i64,0i64, 0i64-2i64,0i64,0i64, 1i64)
    ch_apply(1u64,2u64)   ch_apply(0u64,1u64)            /* order 2 */
    let diverge : u8 = ch_state_eq_snapshot()           /* MUST be 0 (states differ) */
    putchar(69i32) putchar(58i32) sp() e_i64(diverge as i64) sp() e_i64(ch_pairs_disjoint(0u64,1u64,1u64,2u64) as i64) nl()   /* "E: 0 0" */
    if diverge != 0u8 { return 16u64 }                   /* if they commuted, the theorem is vacuous */

    return 99u64
}
