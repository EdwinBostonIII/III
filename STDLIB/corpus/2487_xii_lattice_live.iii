module corpus_2487_xii_lattice_live

/* @lattice: dispatch this fn's body to the XII lattice codegen pipeline (NOP placeholder +
 * call-site descriptor).  The annotation goes after the return type, before the body. */
fn latwork(x: u64) -> u64 @lattice { return x + 1u64 }

fn main() -> u64 {
    latwork(5u64)      /* fires the XII gate at compile time; result is the LDIL placeholder */
    return 99u64
}
