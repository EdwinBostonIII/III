/* STDLIB/corpus/2491_mldsa44_c2sp_kat.iii
 *
 * ML-DSA-44 (FIPS 204) gated on the OFFICIAL C2SP/CCTV accumulated known-answer vectors --
 * the de-facto FIPS-204 conformance test (github.com/C2SP/CCTV/ML-DSA/accumulated).
 * Follow-on to independence-closure F (corpus/2490 is the ML-KEM-768 sibling).
 *
 * Protocol (C2SP README verbatim):
 *   s = SHAKE128(empty)   a = SHAKE128
 *   per iteration: seed = read(s,32); (pk,sk) = keygen(seed); write(a, pk);
 *     sig = sign_deterministic(sk, msg="", ctx="")   -- FIPS-204 external API, so the bytes
 *           hashed are M' = 0x00 || 0x00 (empty ctx wrap) and rnd = 0^32 (deterministic variant)
 *     verify(pk, sig) must ACCEPT; write(a, sig)
 *   read(a,32) must equal the published digest.  BOTH checkpoints are enforced: 100 iters
 *   (finalize a COPY of the accumulator mid-stream) and 10000 iters (the CI count).
 *
 * TEETH: any byte divergence in ANY pk or sig over 10000 keygen+sign+verify triples moves the
 * digest.  This vector is what exposed the module's round-3 leftovers (rhoprime without the
 * rnd=0^32 field; fixed-32 c~) -- fixed in mldsa.iii 2026-07-07.
 *
 * exit 99 = both official digests reproduced byte-for-byte
 *      11 = 100-iteration digest mismatch      12 = 10000-iteration digest mismatch
 *       2 = keygen error   3 = sign error   4 = wrong siglen   5 = verify rejected a genuine sig
 */
module corpus_2491_mldsa44_c2sp_kat

extern @abi(c-msvc-x64) fn keccak_f1600(state_ptr: u64) -> i32 from "keccak.iii"
extern @abi(c-msvc-x64) fn iii_mldsa_keygen(level: u64, seed: u64, pk: u64, sk: u64) -> i32 from "mldsa.iii"
extern @abi(c-msvc-x64) fn iii_mldsa_sign_sealed(level: u64, sk: u64, msg: u64, msglen: u64, sig_out: *u8, sig_len_out: *u64) -> i32 from "mldsa.iii"
extern @abi(c-msvc-x64) fn iii_mldsa_verify(level: u64, pk: u64, msg: u64, msglen: u64, sig: u64, siglen: u64) -> i32 from "mldsa.iii"

const RATE  : u32 = 168u32         /* SHAKE-128 rate */
const LEVEL : u64 = 2u64           /* ML-DSA-44 */
const PKB   : u64 = 1312u64
const SIGB  : u64 = 2420u64        /* FIPS-204: lambda/4=32 + 4*576 + 80 + 4 */

/* DRBG state (SHAKE-128 of empty, continuous squeeze; stream starts 7f9c2ba4e88f827d...) */
var DS : [u8; 200]  var DPOS : u32 = 168u32
/* accumulator state + a copy slot for the mid-stream 100-iter checkpoint */
var AS : [u8; 200]  var APOS : u32 = 0u32
var AS2 : [u8; 200]
var SEED : [u8; 32]
var PK  : [u8; 1312]  var SK : [u8; 2560]  var SIG : [u8; 2420]
var SLQ : [u64; 1]
var MPRIME : [u8; 2]               /* M' for msg="" ctx="": 0x00 || 0x00 */
var DIG : [u8; 32]
/* official C2SP/CCTV ML-DSA-44 accumulated digests */
var W100 : [u8; 32] = [
  0xd5u8,0x11u8,0x48u8,0xe1u8,0xf9u8,0xf4u8,0xfau8,0x1au8,0x72u8,0x3au8,0x6cu8,0xf4u8,0x2eu8,0x25u8,0xf2u8,0xa9u8,
  0x9eu8,0xb5u8,0xc1u8,0xb3u8,0x78u8,0xb3u8,0xd2u8,0xdbu8,0xbdu8,0x56u8,0x1bu8,0x12u8,0x03u8,0xbeu8,0xeau8,0xe4u8 ]
var W10K : [u8; 32] = [
  0xe7u8,0xfdu8,0x21u8,0xf6u8,0xa5u8,0x9bu8,0xcbu8,0xa6u8,0x0du8,0x65u8,0xadu8,0xc4u8,0x44u8,0x04u8,0xbbu8,0x29u8,
  0xa7u8,0xc0u8,0x0eu8,0x5du8,0x8du8,0x3eu8,0xc0u8,0x6au8,0x73u8,0x2cu8,0x00u8,0xa3u8,0x06u8,0xa7u8,0xd1u8,0x43u8 ]

/* --- DRBG: SHAKE-128(empty) initialised, then continuous squeeze --- */
fn drbg_init() {
    let s : *u8 = (&DS) as *u8
    let mut i : u32 = 0u32  while i < 200u32 { s[i as u64] = 0u8  i = i + 1u32 }
    s[0u64] = 0x1Fu8
    s[(RATE - 1u32) as u64] = s[(RATE - 1u32) as u64] ^ 0x80u8
    keccak_f1600((&DS) as u64)
    DPOS = 0u32
}
fn drbg_squeeze(dst: u64, n: u64) {
    let s : *u8 = (&DS) as *u8
    let d : *u8 = dst as *u8
    let mut i : u64 = 0u64
    while i < n {
        if DPOS >= RATE { keccak_f1600((&DS) as u64)  DPOS = 0u32 }
        d[i] = s[DPOS as u64]
        DPOS = DPOS + 1u32
        i = i + 1u64
    }
}
/* --- accumulator: incremental SHAKE-128 absorb --- */
fn acc_absorb(src: u64, n: u64) {
    let s : *u8 = (&AS) as *u8
    let m : *u8 = src as *u8
    let mut i : u64 = 0u64
    while i < n {
        s[APOS as u64] = s[APOS as u64] ^ m[i]
        APOS = APOS + 1u32
        if APOS >= RATE { keccak_f1600((&AS) as u64)  APOS = 0u32 }
        i = i + 1u64
    }
}
fn acc_final(out: u64) {
    let s : *u8 = (&AS) as *u8
    s[APOS as u64] = s[APOS as u64] ^ 0x1Fu8
    s[(RATE - 1u32) as u64] = s[(RATE - 1u32) as u64] ^ 0x80u8
    keccak_f1600((&AS) as u64)
    let o : *u8 = out as *u8
    let mut i : u64 = 0u64  while i < 32u64 { o[i] = s[i]  i = i + 1u64 }
}
/* finalize a COPY of the accumulator (the live stream continues) and compare to want. */
fn acc_check_copy(want: u64) -> u64 {
    let s : *u8 = (&AS) as *u8
    let c : *u8 = (&AS2) as *u8
    let mut i : u64 = 0u64  while i < 200u64 { c[i] = s[i]  i = i + 1u64 }
    c[APOS as u64] = c[APOS as u64] ^ 0x1Fu8
    c[(RATE - 1u32) as u64] = c[(RATE - 1u32) as u64] ^ 0x80u8
    keccak_f1600((&AS2) as u64)
    let w : *u8 = want as *u8
    i = 0u64
    while i < 32u64 { if c[i] != w[i] { return 1u64 }  i = i + 1u64 }
    return 0u64
}

fn main() -> u64 {
    drbg_init()
    MPRIME[0] = 0u8  MPRIME[1] = 0u8
    let mut it : u32 = 0u32
    while it < 10000u32 {
        drbg_squeeze((&SEED) as u64, 32u64)
        if iii_mldsa_keygen(LEVEL, (&SEED) as u64, (&PK) as u64, (&SK) as u64) != 0i32 { return 2u64 }
        acc_absorb((&PK) as u64, PKB)
        if iii_mldsa_sign_sealed(LEVEL, (&SK) as u64, (&MPRIME) as u64, 2u64, (&SIG) as *u8, (&SLQ) as *u64) != 0i32 { return 3u64 }
        if SLQ[0] != SIGB { return 4u64 }
        if iii_mldsa_verify(LEVEL, (&PK) as u64, (&MPRIME) as u64, 2u64, (&SIG) as u64, SIGB) != 0i32 { return 5u64 }
        acc_absorb((&SIG) as u64, SIGB)
        it = it + 1u32
        if it == 100u32 { if acc_check_copy((&W100) as u64) != 0u64 { return 11u64 } }
    }
    acc_final((&DIG) as u64)
    let d : *u8 = (&DIG) as *u8
    let w : *u8 = (&W10K) as *u8
    let mut i : u64 = 0u64
    while i < 32u64 { if d[i] != w[i] { return 12u64 }  i = i + 1u64 }
    return 99u64
}
