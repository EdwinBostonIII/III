    if vr != 0i32 { return 30u64 }
    sig[100u64] = sig[100u64] ^ 1u8
    let vb : i32 = iii_slhdsa_sha2_verify(1u64, pk, &MSG as u64, 757u64, sig as u64, 16224u64)
    if vb == 0i32 { return 40u64 }
    return 99u64
