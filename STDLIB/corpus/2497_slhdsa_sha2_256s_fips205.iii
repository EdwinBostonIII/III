    EXP[31u64] = 0x91u8
    let sig : *u8 = malloc(29856u64)
    let sr : i32 = iii_slhdsa_sha2_sign(2u64, &SK as u64, &MSG as u64, 2071u64, sig as u64, &SLB as u64)
    if sr != 0i32 { return 10u64 }
    if SLB != 29792u64 { return 11u64 }
    sha256_oneshot(sig as u64, 29792u64, &DIG as u64)
    let mut i : u64 = 0u64
    while i < 32u64 { if DIG[i] != EXP[i] { return 20u64 }  i = i + 1u64 }
    let pk : u64 = (&SK as u64) + 64u64   /* pk = pkseed||root = sk+2n */
    let vr : i32 = iii_slhdsa_sha2_verify(2u64, pk, &MSG as u64, 2071u64, sig as u64, 29792u64)
    if vr != 0i32 { return 30u64 }
    sig[100u64] = sig[100u64] ^ 1u8
    let vb : i32 = iii_slhdsa_sha2_verify(2u64, pk, &MSG as u64, 2071u64, sig as u64, 29792u64)
    if vb == 0i32 { return 40u64 }
    return 99u64
