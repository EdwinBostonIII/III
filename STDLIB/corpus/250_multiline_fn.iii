/* Diag: multi-line fn signature trap.
 *
 * Today iiis-0 requires the entire fn signature on one line.  Wrapping
 * after parameters silently miscompiles param offsets OR throws a
 * parse error.  This diag tests whether multi-line signatures parse
 * and execute correctly. */
module corpus_250

fn f_multi(
    a: u64,
    b: u64,
    c: u64
) -> u64 {
    return a + b + c
}

fn main() -> u64 {
    let r : u64 = f_multi(1u64, 2u64, 3u64)
    if r != 6u64 { return 1u64 }
    return 99u64
}
