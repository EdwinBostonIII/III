/* STDLIB/corpus/2620_mathesis_ground.iii -- THE GROUNDING (Xi2, III-MATHESIS-MAP.md s7): a sealed
 * theorem's BOTH SIDES executed on the silicon, the execution CONSTRAINED by the zk AIR, the trace
 * content-addressed into an attestation root -- the WITNESSED clause grows a cryptographic leg.
 *
 * The grounded citizen: MATHESIS-THEOREM-0008 (mul-associativity, the 2612 frontier promotion).  For
 * 8-bit witnesses the product chain is EXACT in the AIR's field (max 255^3 = 16.6M << p = 998244353),
 * so the mod-2^8 statement's instances are grounded by exact integer execution:
 *
 *   program A:  acc = x ; MUL c1 ; MUL c2        -- the LEFT association, one trace row per step
 *   program B:  acc = x ; MUL (c1*c2)            -- the RIGHT association
 *
 * Each program is a zk_svir_vm-layout trace (cols acc, v, prod, sel_add, sel_mul; dispatch/product/
 * one-hot/boolean constraints, degree <= 2): air_constraints_hold() == 1 means EVERY step of the
 * claimed execution is algebraically forced -- the silicon cannot have computed anything else.  The
 * two attested finals AGREE on every witness triple (associativity, grounded).
 *
 * THE ATTESTATION ROOT: SHA-256 over the 40 trace cells (LE) -- input-sensitive (a different witness
 * yields a different root), and a FORGED trace (a flipped intermediate accumulator; a swapped opcode
 * selector) FAILS the constraints: a forgery cannot attest.  RESIDUAL (frontier, blocker named in
 * DOCS/MATHESIS-RATCHET.txt): bitwise schemas await the zk bit-decomposition gadget layer
 * (zk_svir_range) -- the arithmetic fragment opens Xi2, it does not finish it.
 * 99 == theorems are bound to witnessed, constrained, content-addressed silicon execution. */
module corpus_2620_mathesis_ground

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_constraints_hold() -> u8 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_consistent_at(j: u64) -> u8 from "zk_air.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_eq(a: u64, b: u64) -> u8 from "cad.iii"

const P : u32 = 998244353u32

var TR : [u32; 40]        /* 8 rows x 5 cols, row-major: the trace mirror the root hashes */
var SER : [u8; 160]
var ROOT_A : [u8; 32]
var ROOT_B : [u8; 32]
var ROOT_C : [u8; 32]

fn cell(row: u64, col: u64, v: u32) -> u32 {
    TR[(row * 5u64) + col] = v
    air_set_trace(row, col, v)
    return 1u32
}

fn setup_constraints() -> u32 {
    air_add_term(0u32, 1u32, 6u32, 0u32)
    air_add_term(0u32, P - 1u32, 4u32, 1u32)
    air_add_term(0u32, P - 1u32, 4u32, 2u32)
    air_add_term(0u32, P - 1u32, 5u32, 3u32)
    air_add_term(1u32, 1u32, 3u32, 0u32)  air_add_term(1u32, P - 1u32, 1u32, 2u32)
    air_add_term(2u32, 1u32, 4u32, 0u32)  air_add_term(2u32, 1u32, 5u32, 0u32)  air_add_term(2u32, P - 1u32, 0u32, 0u32)
    air_add_term(3u32, 1u32, 4u32, 4u32)  air_add_term(3u32, P - 1u32, 4u32, 0u32)
    air_add_term(4u32, 1u32, 5u32, 5u32)  air_add_term(4u32, P - 1u32, 5u32, 0u32)
    air_set_alpha(0u64, 3u32)  air_set_alpha(1u64, 5u32)  air_set_alpha(2u64, 7u32)
    air_set_alpha(3u64, 11u32)  air_set_alpha(4u64, 13u32)
    return 1u32
}

/* one MUL-step row: acc, v, prod=acc*v, sel_mul=1. */
fn mul_row(row: u64, acc: u64, v: u64) -> u64 {
    let prod : u64 = acc * v
    cell(row, 0u64, acc as u32)
    cell(row, 1u64, v as u32)
    cell(row, 2u64, prod as u32)
    cell(row, 3u64, 0u32)
    cell(row, 4u64, 1u32)
    return prod
}
/* HALT padding rows from r0 to 7: acc self-loop via ADD 0. */
fn halt_rows(r0: u64, acc: u64) -> u32 {
    let mut r : u64 = r0
    while r < 8u64 {
        cell(r, 0u64, acc as u32)
        cell(r, 1u64, 0u32)
        cell(r, 2u64, 0u32)
        cell(r, 3u64, 1u32)
        cell(r, 4u64, 0u32)
        r = r + 1u64
    }
    return 1u32
}

/* the attestation root: SHA-256 over the 40 cells, canonical LE. */
fn attest(out32: u64) -> u32 {
    let mut i : u64 = 0u64
    while i < 40u64 {
        let mut v : u32 = TR[i]
        let mut b : u64 = 0u64
        while b < 4u64 {
            SER[(i * 4u64) + b] = (v & 255u32) as u8
            v = v >> 8u32
            b = b + 1u64
        }
        i = i + 1u64
    }
    cad_oneshot(0u32, (&SER as u64) as *u8, 160u64, out32 as *u8)
    return 1u32
}

/* build + attest program A: ((x*c1)*c2).  Returns the final acc; root into out32. */
fn run_a(x: u64, c1: u64, c2: u64, out32: u64) -> u64 {
    air_reset(5u32, 8u32)
    let a1 : u64 = mul_row(0u64, x, c1)
    let a2 : u64 = mul_row(1u64, a1, c2)
    halt_rows(2u64, a2)
    setup_constraints()
    air_build_lde()
    air_build_cp()
    if air_constraints_hold() != 1u8 { return 18446744073709551615u64 }
    if air_cp_consistent_at(1u64) != 1u8 { return 18446744073709551615u64 }
    if air_cp_consistent_at(3u64) != 1u8 { return 18446744073709551615u64 }
    attest(out32)
    return a2
}
/* build + attest program B: (x*(c1*c2)). */
fn run_b(x: u64, c1: u64, c2: u64, out32: u64) -> u64 {
    air_reset(5u32, 8u32)
    let b1 : u64 = mul_row(0u64, x, c1 * c2)
    halt_rows(1u64, b1)
    setup_constraints()
    air_build_lde()
    air_build_cp()
    if air_constraints_hold() != 1u8 { return 18446744073709551615u64 }
    if air_cp_consistent_at(2u64) != 1u8 { return 18446744073709551615u64 }
    attest(out32)
    return b1
}

fn main() -> u64 {
    /* ---- the witness triples: semantic edges of the 8-bit domain (field-exact) ---- */
    let mut t : u64 = 0u64
    while t < 5u64 {
        let mut x : u64 = 2u64
        let mut c1 : u64 = 3u64
        let mut c2 : u64 = 5u64
        if t == 1u64 { x = 251u64  c1 = 7u64   c2 = 13u64 }
        if t == 2u64 { x = 255u64  c1 = 255u64 c2 = 255u64 }
        if t == 3u64 { x = 17u64   c1 = 0u64   c2 = 9u64 }
        if t == 4u64 { x = 1u64    c1 = 255u64 c2 = 2u64 }
        let fa : u64 = run_a(x, c1, c2, &ROOT_A as u64)
        if fa == 18446744073709551615u64 { return 10u64 }
        let fb : u64 = run_b(x, c1, c2, &ROOT_B as u64)
        if fb == 18446744073709551615u64 { return 11u64 }
        /* the grounded theorem instance: both association orders agree on the silicon, exactly */
        if fa != fb { return 12u64 }
        t = t + 1u64
    }

    /* ---- the root is input-sensitive (content-binding, not a constant) ---- */
    if run_a(2u64, 3u64, 5u64, &ROOT_A as u64) == 18446744073709551615u64 { return 20u64 }
    if run_a(2u64, 3u64, 7u64, &ROOT_C as u64) == 18446744073709551615u64 { return 21u64 }
    if cad_eq(&ROOT_A as u64, &ROOT_C as u64) == 1u8 { return 22u64 }
    if run_a(2u64, 3u64, 5u64, &ROOT_B as u64) == 18446744073709551615u64 { return 23u64 }
    if cad_eq(&ROOT_A as u64, &ROOT_B as u64) != 1u8 { return 24u64 }   /* deterministic re-attest */

    /* ---- FORGERY ARMS: a wrong execution cannot attest ---- */
    /* forged intermediate accumulator */
    air_reset(5u32, 8u32)
    let a1 : u64 = mul_row(0u64, 2u64, 3u64)
    let a2 : u64 = mul_row(1u64, a1, 5u64)
    halt_rows(2u64, a2)
    setup_constraints()
    air_set_trace(1u64, 0u64, 99u32)          /* forge acc at step 1 */
    air_build_lde()
    air_build_cp()
    if air_constraints_hold() != 0u8 { return 30u64 }
    /* forged opcode selector (claim ADD where the trace multiplied) */
    air_reset(5u32, 8u32)
    let b1 : u64 = mul_row(0u64, 2u64, 3u64)
    let b2 : u64 = mul_row(1u64, b1, 5u64)
    halt_rows(2u64, b2)
    setup_constraints()
    air_set_trace(0u64, 3u64, 1u32)
    air_set_trace(0u64, 4u64, 0u32)
    air_build_lde()
    air_build_cp()
    if air_constraints_hold() != 0u8 { return 31u64 }

    return 99u64
}
