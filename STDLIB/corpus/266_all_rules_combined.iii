/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\corpus\266_all_rules_combined.iii
 *
 * III conformance corpus 266 -- exercise ALL four iiis-1 static
 * propagation rules on a single call site simultaneously.
 *
 * - Caller declares @cap_required(0x300), @k_max(800M), @hexad_kind(6)
 * - Callee declares @cap_required(0x100), @k_max(400M), @hexad_kind(6)
 *   AND @returns_hexad(6)
 * - Callee has a typed-intent parameter @hexad_kind(6)
 * - Result let is typed @hexad_kind(6)
 *
 * All four static checks pass simultaneously:
 *   cap-flow:     0x300 ⊇ 0x100  ✓
 *   K-floor:      800M >= 400M   ✓
 *   intent-kind:  6 == 6 (param) ✓
 *   return-kind:  6 == 6 (let)   ✓
 *
 * Runtime gates pass when given a properly-formed ctx (hexad=6,
 * cap_id holding 0x300, K=1.0).
 *
 * This proves the four checks are ORTHOGONAL — they compose cleanly
 * on a single fn.
 */
module corpus_266

extern @abi(c-msvc-x64) fn call_context_init_set(cap_id: u64, kchain_id: u8, ring: u8, hexad_kind: u8) -> i32 from "call_context.iii"
extern @abi(c-msvc-x64) fn call_context_new() -> u64 from "call_context.iii"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent_id: u64, rights_mask: u64, expires_at: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn kchain_new(custom_floor: u64) -> u64 from "kchain.iii"

/* Callee: requires CAP 0x100, K-floor 400M, hexad COMPOSE (6).
 * Parameter `tag` is typed @hexad_kind(6).
 * Return value carries @returns_hexad(6). */
fn _combined_op(ctx: u64, tag: u64 @hexad_kind(6u64)) -> u64 @cap_required(0x100u64) @k_max(400000000u64) @hexad_kind(6u64) @returns_hexad(6u64) {
    let _u : u64 = tag
    return 0x1234u64 + tag
}

/* Caller: declares CAP 0x300 (superset), K-floor 800M (higher),
 * hexad 6 (matches).  All four static checks pass at the call site. */
fn _outer_combined(ctx: u64, tag_in: u64 @hexad_kind(6u64)) -> u64 @cap_required(0x300u64) @k_max(800000000u64) @hexad_kind(6u64) @returns_hexad(6u64) {
    let r : u64 = _combined_op(ctx, tag_in)
    return r
}

fn main() -> u64 {
    /* Build a high-cap, high-K, hexad-COMPOSE ctx. */
    let env : u64 = cap_env_init()
    if env == 0u64 { return 1u64 }
    let cap : u64 = cap_attenuate(env, 0x300u64, 0u64)
    if cap == 0u64 { return 2u64 }
    let kch : u64 = kchain_new(0u64)
    if kch == 0xFFFFFFFFFFFFFFFFu64 { return 3u64 }
    call_context_init_set(cap, kch as u8, 2u8, 6u8)
    let ctx : u64 = call_context_new()
    if ctx == 0u64 { return 4u64 }

    let tag : u64 @hexad_kind(6u64) = 0xAAu64

    /* Direct call to _combined_op: all checks pass. */
    let result : u64 @hexad_kind(6u64) = _combined_op(ctx, tag)
    if result != 0x12DEu64 { return 5u64 }

    /* Indirect via _outer_combined: static checks pass at BOTH
     * call sites (outer→combined, main→outer). */
    let outer_result : u64 @hexad_kind(6u64) = _outer_combined(ctx, tag)
    if outer_result != 0x12DEu64 { return 6u64 }

    return 99u64
}
