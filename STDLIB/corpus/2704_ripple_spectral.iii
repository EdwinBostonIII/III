/* 2704_ripple_spectral.iii -- GATE for THE EXACT SPECTRAL ORGAN (campaign Rho): III measures its
 * own body in exact algebra, and the ripple architecture gains a CERTIFIED structural dimension.
 *
 * E -- envelope refusals NAMED first: n = 65 refused; an entry past 2^20 refused.
 * F -- fixture P_4 (path graph) TWO-PATH: the organ's modular-CRT charpoly must equal the gate's
 *      OWN integer Chebyshev-style recurrence phi_k = t*phi_{k-1} - phi_{k-2} coefficient-for-
 *      coefficient (deliberately-wrong recurrence value REFUTED first); all 4 eigenvalues counted
 *      in (-2, 2] through the bigint chain; bipartite => odd coefficients ZERO.
 * C -- fixture C_4 (cycle): eigenvalues {2, 0, 0, -2} certified through the chain alone --
 *      multiplicity of 0 == 2 (root_mult2_cur at (-1/2, 0]), one root in (3/2, 2], one in
 *      (-5/2, -3/2], and the even cycle's bipartite symmetry (odd coefficients zero).
 * R -- THE REAL ARM: III's own module graph (omnia/self_atlas_data, the machine-generated
 *      self-image): the "ripple"-prefixed subsystem's induced directed subgraph -- THE
 *      ACYCLICITY CERTIFICATE char(A) == t^n decided by exact algebra, cross-checked by the
 *      gate's OWN Kahn toposort (two independent paths must AGREE); the symmetrized Laplacian's
 *      zero-eigenvalue multiplicity == the gate's OWN union-find component count (two paths).
 * W -- THE RIPPLE TIE: the SAME real subsystem fed to the standing ripple metric (rm_add_node/
 *      rm_add_edge from the archive): a synthetic unused edge raises rm_noise by exactly 1 (the
 *      metric PRICES degradation); the spectral organ, given the reverse of an existing edge (a
 *      2-cycle), flips the acyclicity certificate to NO (the certificate PROVES the break) --
 *      priced by the metric, PROVEN by the algebra, agreed by the toposort.
 *
 * exit 99 pass; 10 E; 11 F-refute; 12 F-match; 13 F-count; 14 C; 15 R-load; 16 R-dag;
 * 17 R-lap; 18 W-metric; 19 W-spectral. */
module corpus_2704_ripple_spectral

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn ca_reset(n: i64) -> i32 from "charpoly.iii"
extern @abi(c-msvc-x64) fn ca_n() -> i64 from "charpoly.iii"
extern @abi(c-msvc-x64) fn ca_set(i: i64, j: i64, v: i64) -> i32 from "charpoly.iii"
extern @abi(c-msvc-x64) fn ca_charpoly() -> i32 from "charpoly.iii"
extern @abi(c-msvc-x64) fn ca_load_chain(build: i64) -> i32 from "charpoly.iii"
extern @abi(c-msvc-x64) fn ca_is_tn() -> i64 from "charpoly.iii"
extern @abi(c-msvc-x64) fn ca_coeff_sgn(i: i64) -> i64 from "charpoly.iii"
extern @abi(c-msvc-x64) fn ca_coeff_len(i: i64) -> i64 from "charpoly.iii"
extern @abi(c-msvc-x64) fn ca_coeff_limb(i: i64, j: i64) -> u64 from "charpoly.iii"
extern @abi(c-msvc-x64) fn ca_nuse() -> i64 from "charpoly.iii"
extern @abi(c-msvc-x64) fn root_count2(an: i64, ad: i64, bn: i64, bd: i64) -> i64 from "sturm_big.iii"
extern @abi(c-msvc-x64) fn root_mult2_cur(an: i64, ad: i64, bn: i64, bd: i64) -> i64 from "sturm_big.iii"
extern @abi(c-msvc-x64) fn satlas_data_load() -> i32 from "self_atlas_data.iii"
extern @abi(c-msvc-x64) fn satlas_node_count() -> u32 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_name_into(n: u32, out_ptr: u64, max: u64) -> u64 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn satlas_depends_direct(src: u32, tgt: u32) -> u8 from "self_atlas.iii"
extern @abi(c-msvc-x64) fn rm_reset() -> u64 from "ripple_metric.iii"
extern @abi(c-msvc-x64) fn rm_add_node(cap: u64, iclass: u32) -> u32 from "ripple_metric.iii"
extern @abi(c-msvc-x64) fn rm_add_edge(src: u32, dst: u32, used: u32, intent: u32) -> u32 from "ripple_metric.iii"
extern @abi(c-msvc-x64) fn rm_noise() -> u32 from "ripple_metric.iii"
extern @abi(c-msvc-x64) fn rm_j() -> u64 from "ripple_metric.iii"

fn e_i64(v: i64) -> i32 { if v < 0i64 { putchar(45i32)   return e_i64(0i64 - v) }   if v >= 10i64 { e_i64(v / 10i64) }   putchar(((v % 10i64) + 48i64) as i32)   return 0i32 }
fn sp() -> i32 { putchar(32i32)   return 0i32 }   fn nl() -> i32 { putchar(10i32)   return 0i32 }

/* module-scope scratch (the cg_r3 64-local-slot ceiling) */
var PHI : [i64; 30]        /* recurrence rows: phi_k coefficients at k*6+i (n <= 4) */
var PH2 : [i64; 30]
var NAMEB : [u8; 64]
var RIDS : [i64; 64]       /* atlas ids of the subsystem nodes */
var RADJ : [i64; 4096]     /* induced adjacency */
var RDEG : [i64; 64]
var UFP : [i64; 64]
var INDEG : [i64; 64]
var QUEUE : [i64; 64]
var NR : i64
var EA : i32   var EB : i32
var FREF : i64   var FMATCH : i64   var FCNT : i64   var FB1 : i64   var FB3 : i64
var CM0 : i64   var C2 : i64   var CM2 : i64
var RDAG : i64   var RKAHN : i64   var RM0 : i64   var RUF : i64
var WN0 : i64   var WN1 : i64   var WT : i64   var WD : i64

/* the gate's OWN path-graph recurrence: phi_0 = 1, phi_1 = t, phi_k = t*phi_{k-1} - phi_{k-2}. */
fn phi_build(n: i64) -> i32 {
    let mut i : i64 = 0i64
    while i < 30i64 { PHI[i as u64] = 0i64   i = i + 1i64 }
    PHI[0u64] = 1i64                    /* phi_0 = 1 */
    PHI[(6i64 + 1i64) as u64] = 1i64    /* phi_1 = t */
    let mut k : i64 = 2i64
    while k <= n {
        let mut j : i64 = 0i64
        while j <= k {
            let mut v : i64 = 0i64
            if j >= 1i64 { v = PHI[(((k - 1i64) * 6i64) + (j - 1i64)) as u64] }
            v = v - PHI[(((k - 2i64) * 6i64) + j) as u64]
            PHI[((k * 6i64) + j) as u64] = v
            j = j + 1i64
        }
        k = k + 1i64
    }
    return 0i32
}

/* compare the organ's delivered coefficient i against an i64 expectation. 1 equal, 0 not. */
fn coeff_is(i: i64, v: i64) -> i64 {
    let mut a : i64 = v
    let mut sg : i64 = 1i64
    if v == 0i64 { sg = 0i64 }
    if v < 0i64 { a = 0i64 - v   sg = 0i64 - 1i64 }
    if ca_coeff_sgn(i) != sg { return 0i64 }
    if sg == 0i64 { return 1i64 }
    if ca_coeff_len(i) != 1i64 { return 0i64 }
    if ca_coeff_limb(i, 0i64) != (a as u64) { return 0i64 }
    return 1i64
}

/* name of atlas node n starts with "ripple"? */
fn is_ripple(n: u32) -> i64 {
    let ln : u64 = satlas_name_into(n, (&NAMEB) as u64, 64u64)
    if ln < 6u64 { return 0i64 }
    if NAMEB[0u64] != 114u8 { return 0i64 }   /* r */
    if NAMEB[1u64] != 105u8 { return 0i64 }   /* i */
    if NAMEB[2u64] != 112u8 { return 0i64 }   /* p */
    if NAMEB[3u64] != 112u8 { return 0i64 }   /* p */
    if NAMEB[4u64] != 108u8 { return 0i64 }   /* l */
    if NAMEB[5u64] != 101u8 { return 0i64 }   /* e */
    return 1i64
}

/* Kahn toposort over RADJ (n nodes): 1 acyclic, 0 cyclic -- the gate's own combinatorial path. */
fn kahn(n: i64) -> i64 {
    let mut i : i64 = 0i64
    while i < n { INDEG[i as u64] = 0i64   i = i + 1i64 }
    i = 0i64
    while i < n {
        let mut j : i64 = 0i64
        while j < n {
            if RADJ[((i * n) + j) as u64] == 1i64 { INDEG[j as u64] = INDEG[j as u64] + 1i64 }
            j = j + 1i64
        }
        i = i + 1i64
    }
    let mut qh : i64 = 0i64
    let mut qt : i64 = 0i64
    i = 0i64
    while i < n { if INDEG[i as u64] == 0i64 { QUEUE[qt as u64] = i   qt = qt + 1i64 }   i = i + 1i64 }
    let mut seen : i64 = 0i64
    while qh < qt {
        let u : i64 = QUEUE[qh as u64]
        qh = qh + 1i64
        seen = seen + 1i64
        let mut j2 : i64 = 0i64
        while j2 < n {
            if RADJ[((u * n) + j2) as u64] == 1i64 {
                INDEG[j2 as u64] = INDEG[j2 as u64] - 1i64
                if INDEG[j2 as u64] == 0i64 { QUEUE[qt as u64] = j2   qt = qt + 1i64 }
            }
            j2 = j2 + 1i64
        }
    }
    if seen == n { return 1i64 }
    return 0i64
}

/* union-find component count over the SYMMETRIZED RADJ -- the gate's own second path. */
fn uf_find(x: i64) -> i64 {
    let mut r : i64 = x
    while UFP[r as u64] != r { r = UFP[r as u64] }
    return r
}
fn ufcomp(n: i64) -> i64 {
    let mut i : i64 = 0i64
    while i < n { UFP[i as u64] = i   i = i + 1i64 }
    i = 0i64
    while i < n {
        let mut j : i64 = 0i64
        while j < n {
            let mut e : i64 = RADJ[((i * n) + j) as u64]
            if RADJ[((j * n) + i) as u64] == 1i64 { e = 1i64 }
            if e == 1i64 {
                let ra : i64 = uf_find(i)
                let rb : i64 = uf_find(j)
                if ra != rb { UFP[ra as u64] = rb }
            }
            j = j + 1i64
        }
        i = i + 1i64
    }
    let mut c : i64 = 0i64
    i = 0i64
    while i < n { if uf_find(i) == i { c = c + 1i64 }   i = i + 1i64 }
    return c
}

/* load the induced DIRECTED adjacency into the organ. extra = 1 adds the reverse of the first
 * existing edge (the synthetic 2-cycle for the degradation arm). */
fn load_dir(n: i64, extra: i64) -> i32 {
    if ca_reset(n) != 0i32 { return 0i32 - 1i32 }
    let mut done : i64 = 0i64
    let mut i : i64 = 0i64
    while i < n {
        let mut j : i64 = 0i64
        while j < n {
            if RADJ[((i * n) + j) as u64] == 1i64 {
                ca_set(i, j, 1i64)
                if extra == 1i64 { if done == 0i64 {
                    ca_set(j, i, 1i64)
                    done = 1i64
                } }
            }
            j = j + 1i64
        }
        i = i + 1i64
    }
    return 0i32
}

fn main() -> u64 {
    /* == E: envelope refusals named first. */
    /* (ca_n externed below with the other charpoly doors) */
EA = ca_reset(65i64)
    ca_reset(2i64)
    EB = ca_set(0i64, 0i64, 2097152i64)
    putchar(69i32) putchar(58i32) sp() e_i64(EA as i64) sp() e_i64(EB as i64) nl()   /* "E: -1 -1" */
    if EA != (0i32 - 1i32) { return 10u64 }
    if EB != (0i32 - 1i32) { return 10u64 }

    /* == F: fixture P_4, two-path. */
    phi_build(4i64)
    if ca_reset(4i64) != 0i32 { return 12u64 }
    ca_set(0i64, 1i64, 1i64)   ca_set(1i64, 0i64, 1i64)
    ca_set(1i64, 2i64, 1i64)   ca_set(2i64, 1i64, 1i64)
    ca_set(2i64, 3i64, 1i64)   ca_set(3i64, 2i64, 1i64)
    if ca_charpoly() != 0i32 { return 12u64 }
    /* the dimension register: live after the accepted reset, and IMMUNE to a refused
     * one (a refusal that clobbered state would poison every later read). */
    if ca_n() != 4i64 { return 60u64 }
    if ca_reset(65i64) != (0i32 - 1i32) { return 61u64 }
    if ca_n() != 4i64 { return 62u64 }
    /* the deliberately-WRONG recurrence value is REFUTED (discrimination, not vacuous match) */
    FREF = coeff_is(2i64, 3i64)                          /* true c2 = -3: +3 must MISMATCH */
    FMATCH = 1i64
    let mut i : i64 = 0i64
    while i <= 4i64 {
        if coeff_is(i, PHI[((4i64 * 6i64) + i) as u64]) != 1i64 { FMATCH = 0i64 }
        i = i + 1i64
    }
    if ca_load_chain(1i64) != 0i32 { return 13u64 }
    FCNT = root_count2(0i64 - 2i64, 1i64, 2i64, 1i64)
    FB1 = ca_coeff_sgn(1i64)
    FB3 = ca_coeff_sgn(3i64)
    putchar(70i32) putchar(58i32) sp() e_i64(FREF) sp() e_i64(FMATCH) sp() e_i64(FCNT) sp() e_i64(FB1) sp() e_i64(FB3) sp() e_i64(ca_nuse()) nl()
    if FREF != 0i64 { return 11u64 }
    if FMATCH != 1i64 { return 12u64 }
    if FCNT != 4i64 { return 13u64 }
    if FB1 != 0i64 { return 13u64 }
    if FB3 != 0i64 { return 13u64 }

    /* == C: fixture C_4 -- eigenvalues {2, 0, 0, -2} certified through the chain alone. */
    if ca_reset(4i64) != 0i32 { return 14u64 }
    ca_set(0i64, 1i64, 1i64)   ca_set(1i64, 0i64, 1i64)
    ca_set(1i64, 2i64, 1i64)   ca_set(2i64, 1i64, 1i64)
    ca_set(2i64, 3i64, 1i64)   ca_set(3i64, 2i64, 1i64)
    ca_set(3i64, 0i64, 1i64)   ca_set(0i64, 3i64, 1i64)
    if ca_charpoly() != 0i32 { return 14u64 }
    if ca_load_chain(1i64) != 0i32 { return 14u64 }
    C2 = root_count2(3i64, 2i64, 2i64, 1i64)             /* one root in (3/2, 2] */
    CM2 = root_count2(0i64 - 5i64, 2i64, 0i64 - 3i64, 2i64)   /* one in (-5/2, -3/2] */
    if ca_load_chain(0i64) != 0i32 { return 14u64 }      /* reload CUR (mult consumes) */
    /* THE INTERIOR-BRACKET LAW: a MULTIPLE root at a bracket endpoint vanishes EVERY chain entry
     * there (the gcd divides them all) and the variation count degenerates -- the multiple root
     * must sit INTERIOR.  (-1/8, 1/8] keeps 0 interior; the other eigenvalues are +-2. */
    CM0 = root_mult2_cur(0i64 - 1i64, 8i64, 1i64, 8i64)
    putchar(67i32) putchar(58i32) sp() e_i64(C2) sp() e_i64(CM2) sp() e_i64(CM0) sp() e_i64(ca_coeff_sgn(1i64)) sp() e_i64(ca_coeff_sgn(3i64)) nl()
    if C2 != 1i64 { return 14u64 }
    if CM2 != 1i64 { return 14u64 }
    if CM0 != 2i64 { return 14u64 }
    if ca_coeff_sgn(1i64) != 0i64 { return 14u64 }
    if ca_coeff_sgn(3i64) != 0i64 { return 14u64 }

    /* == R: THE REAL ARM -- III's own "ripple" subsystem from the machine-generated self-image. */
    if satlas_data_load() != 0i32 { return 15u64 }
    let total : i64 = satlas_node_count() as i64
    NR = 0i64
    i = 0i64
    while i < total {
        if is_ripple(i as u32) == 1i64 {
            if NR < 64i64 { RIDS[NR as u64] = i   NR = NR + 1i64 }
        }
        i = i + 1i64
    }
    if NR < 4i64 { return 15u64 }
    i = 0i64
    while i < NR {
        let mut j : i64 = 0i64
        while j < NR {
            RADJ[((i * NR) + j) as u64] = 0i64
            if i != j {
                if satlas_depends_direct(RIDS[i as u64] as u32, RIDS[j as u64] as u32) == 1u8 {
                    RADJ[((i * NR) + j) as u64] = 1i64
                }
            }
            j = j + 1i64
        }
        i = i + 1i64
    }
    /* the ACYCLICITY CERTIFICATE, two paths */
    if load_dir(NR, 0i64) != 0i32 { return 16u64 }
    if ca_charpoly() != 0i32 { return 16u64 }
    RDAG = ca_is_tn()
    RKAHN = kahn(NR)
    if RDAG != RKAHN { return 16u64 }
    /* the CONNECTIVITY CERTIFICATE: symmetrized Laplacian, two paths */
    if ca_reset(NR) != 0i32 { return 17u64 }
    i = 0i64
    while i < NR { RDEG[i as u64] = 0i64   i = i + 1i64 }
    i = 0i64
    while i < NR {
        let mut j : i64 = 0i64
        while j < NR {
            if i != j {
                let mut e : i64 = RADJ[((i * NR) + j) as u64]
                if RADJ[((j * NR) + i) as u64] == 1i64 { e = 1i64 }
                if e == 1i64 {
                    ca_set(i, j, 0i64 - 1i64)
                    RDEG[i as u64] = RDEG[i as u64] + 1i64
                }
            }
            j = j + 1i64
        }
        i = i + 1i64
    }
    i = 0i64
    while i < NR { ca_set(i, i, RDEG[i as u64])   i = i + 1i64 }
    if ca_charpoly() != 0i32 { return 17u64 }
    if ca_load_chain(0i64) != 0i32 { return 17u64 }
    /* the zero eigenvalue INTERIOR (the interior-bracket law); every positive Laplacian
     * eigenvalue of a graph on <= 64 nodes is >= 2(1-cos(pi/64)) > 2^-9 (the Fiedler path
     * bound), so (-2^-13, 2^-13] holds 0 and nothing else. */
    RM0 = root_mult2_cur(0i64 - 1i64, 8192i64, 1i64, 8192i64)
    RUF = ufcomp(NR)
    putchar(82i32) putchar(58i32) sp() e_i64(NR) sp() e_i64(RDAG) sp() e_i64(RKAHN) sp() e_i64(RM0) sp() e_i64(RUF) nl()
    if RM0 != RUF { return 17u64 }

    /* == W: the ripple tie -- the metric PRICES, the certificate PROVES, the toposort agrees. */
    rm_reset()
    i = 0i64
    while i < NR { rm_add_node(1u64, 0u32)   i = i + 1i64 }
    let mut ne : i64 = 0i64
    i = 0i64
    while i < NR {
        let mut j : i64 = 0i64
        while j < NR {
            if RADJ[((i * NR) + j) as u64] == 1i64 {
                rm_add_edge(i as u32, j as u32, 1u32, 0u32)
                ne = ne + 1i64
            }
            j = j + 1i64
        }
        i = i + 1i64
    }
    WN0 = rm_noise() as i64
    rm_add_edge(0u32, (NR - 1i64) as u32, 0u32, 0u32)    /* one synthetic UNUSED edge */
    WN1 = rm_noise() as i64
    /* the spectral side: the reverse of an existing edge = a 2-cycle; the certificate flips */
    if load_dir(NR, 1i64) != 0i32 { return 19u64 }
    if ca_charpoly() != 0i32 { return 19u64 }
    WD = ca_is_tn()
    WT = kahn_after_reverse(NR)
    putchar(87i32) putchar(58i32) sp() e_i64(ne) sp() e_i64(WN0) sp() e_i64(WN1 - WN0) sp() e_i64(WD) sp() e_i64(WT) nl()
    if (WN1 - WN0) != 1i64 { return 18u64 }
    if WD != 0i64 { return 19u64 }
    if WT != 0i64 { return 19u64 }

    return 99u64
}

/* Kahn over RADJ with the first edge's reverse added (mirrors load_dir extra=1). */
fn kahn_after_reverse(n: i64) -> i64 {
    let mut fi : i64 = 0i64 - 1i64
    let mut fj : i64 = 0i64 - 1i64
    let mut i : i64 = 0i64
    while i < n {
        let mut j : i64 = 0i64
        while j < n {
            if fi < 0i64 { if RADJ[((i * n) + j) as u64] == 1i64 { fi = i   fj = j } }
            j = j + 1i64
        }
        i = i + 1i64
    }
    if fi < 0i64 { return 1i64 }
    let old : i64 = RADJ[((fj * n) + fi) as u64]
    RADJ[((fj * n) + fi) as u64] = 1i64
    let r : i64 = kahn(n)
    RADJ[((fj * n) + fi) as u64] = old
    return r
}
