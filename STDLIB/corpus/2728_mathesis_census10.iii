/* 2728_mathesis_census10.iii -- GATE for THE CENSUS AT TEN TOKENS (campaign Omega-2).
 *
 * Psi counted the iso-classes of all binary operations for n = 5, 6, 7 by Burnside over S_n in
 * exact bigint, TWO INDEPENDENT ROUTES agreeing to the digit.  Omega-2 lifts the organ's
 * envelope (permutation slots 8 -> 12, flood cells 64 -> 144, digit render 64 -> 128 bytes) and
 * extends the same two-route census to n = 8, 9, 10.  Observed 2026-07-14, pinned here:
 *
 *   n    ALL binary ops (up to iso)     COMMUTATIVE ops (up to iso)
 *   8    1.556...e53  (54 digits)       8.048...e27  (28 digits)
 *   9    5.418...e71  (72 digits)       2.405...e37  (38 digits)
 *   10   2.755...e93  (94 digits)       2.755...e48  (49 digits)
 *
 * n = 10 counts the iso-classes of 10^100 operations -- a googol of tables -- WITHOUT
 * enumerating one.  The gate re-anchors the LIFTED organ to the sealed Psi values first (n = 5
 * both flavors by exact i64, n = 7 full by all 38 digits: the envelope edit changed no sealed
 * output), then requires route agreement AND the digit strings above at n = 8, 9, 10.
 * EXIT 99. */
module corpus_2728_mathesis_census10

extern @abi(c-msvc-x64) fn mce_burnside(n: i64, comm: i64) -> i64 from "mathesis_census.iii"
extern @abi(c-msvc-x64) fn mce_rh() -> i64 from "mathesis_census.iii"
extern @abi(c-msvc-x64) fn mce_fits() -> i64 from "mathesis_census.iii"
extern @abi(c-msvc-x64) fn mce_i64() -> i64 from "mathesis_census.iii"
extern @abi(c-msvc-x64) fn bc_render(h: i64, slot: i64) -> i32 from "mathesis_bigcurve.iii"
extern @abi(c-msvc-x64) fn bg_diglen(slot: i64) -> i64 from "mathesis_bigcurve.iii"
extern @abi(c-msvc-x64) fn bg_digat(slot: i64, i: i64) -> i64 from "mathesis_bigcurve.iii"

var EXP : [i64; 96]
var LEN : i64

/* run mce_burnside(n,comm); require routes agree AND the result renders to EXP[0..LEN). */
fn chk(n: i64, comm: i64) -> i64 {
    if mce_burnside(n, comm) != 0i64 { return 0i64 }
    bc_render(mce_rh(), 41i64)
    if bg_diglen(41i64) != LEN { return 0i64 }
    let mut i : i64 = 0i64
    while i < LEN {
        if bg_digat(41i64, i) != (48i64 + EXP[i as u64]) { return 0i64 }   /* bc_render stores ASCII */
        i = i + 1i64
    }
    return 1i64
}
fn chki(n: i64, comm: i64, v: i64) -> i64 {
    if mce_burnside(n, comm) != 0i64 { return 0i64 }
    if mce_fits() != 1i64 { return 0i64 }
    if mce_i64() != v { return 0i64 }
    return 1i64
}

