fn main() -> i32 {
    /* [A] THE ANCHOR: the lifted organ still equals the SEALED Psi values (envelope edits
     * changed no sealed output) -- n = 5 exact i64 both flavors, n = 7 full digit-for-digit */
    if chki(5i64, 0i64, 2483527537094825i64) != 1i64 { return 10i32 }
    if chki(5i64, 1i64, 254429900i64) != 1i64 { return 11i32 }
    set_n7full()
    if chk(7i64, 0i64) != 1i64 { return 12i32 }
    /* [B] n = 8: both routes agree, digits pinned */
    set_n8full()
    if chk(8i64, 0i64) != 1i64 { return 20i32 }
    set_n8comm()
    if chk(8i64, 1i64) != 1i64 { return 21i32 }
    /* [C] n = 9 */
    set_n9full()
    if chk(9i64, 0i64) != 1i64 { return 30i32 }
    set_n9comm()
    if chk(9i64, 1i64) != 1i64 { return 31i32 }
    /* [D] n = 10: the iso-count of a googol of operations, two routes, one number */
    set_n10full()
    if chk(10i64, 0i64) != 1i64 { return 40i32 }
    set_n10comm()
    if chk(10i64, 1i64) != 1i64 { return 41i32 }
    /* [E] the envelope refusal is NAMED, never garbage */
    if mce_burnside(11i64, 0i64) != (0i64 - 1i64) { return 50i32 }
    return 99i32
}
