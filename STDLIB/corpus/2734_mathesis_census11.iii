extern @abi(c-msvc-x64) fn bc_render(h: i64, slot: i64) -> i32 from "mathesis_bigcurve.iii"
extern @abi(c-msvc-x64) fn bg_diglen(slot: i64) -> i64 from "mathesis_bigcurve.iii"
extern @abi(c-msvc-x64) fn bg_digat(slot: i64, i: i64) -> i64 from "mathesis_bigcurve.iii"

var EXP : [i64; 128]
var LEN : i64

fn chk(n: i64, comm: i64) -> i64 {
    if mce_burnside(n, comm) != 0i64 { return 0i64 }
    bc_render(mce_rh(), 41i64)
    if bg_diglen(41i64) != LEN { return 0i64 }
    let mut i : i64 = 0i64
    while i < LEN {
        if bg_digat(41i64, i) != (48i64 + EXP[i as u64]) { return 0i64 }
        i = i + 1i64
    }
    return 1i64
}

