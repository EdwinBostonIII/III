/* 2739_mathesis_pilot42.iii -- GATE for THE PILOT'S SEVENTH EXTENSION (campaign Omega-4:
 * budget 42 -- the autonomous ledger extends deterministically, forever).
 *
 * Rounds 36..41, every experiment a pure function of the round number (observed 2026-07-14):
 *   r36 NEW-D  d=28 at 60  -> A:3 B:0  -- THE PILOT'S EIGHTH AUTONOMOUS DISCOVERY: d=28 = 4*7
 *              carries THREE curve-A identities (the box sweep's independent find, reached by
 *              the pilot's own schedule)
 *   r37 kind 9 (1, 12)     -> the HEIGHT schedule stays exhausted: a NAMED refusal, chained
 *   r38 LOCAL  (10, 31)    -> 21 / 39
 *   r39 NEW-D  d=29 at 60  -> A:0 B:0  (the prime 29 joins the nonexistence inventory)
 *   r40 kind 9 (1, 13)     -> the same named refusal at q=13
 *   r41 LOCAL  (10, 37)    -> 27 / 27
 *
 * THE PREFIX LAW: head(36) recomputed in-gate equals the SEALED Omega-3 ledger head byte for
 * byte; head(42) is pinned as the new frontier head and is IDENTICAL across two full runs.
 * EXIT 99. */
module corpus_2739_mathesis_pilot42

extern @abi(c-msvc-x64) fn mpl_round(r: i64) -> i64 from "mathesis_pilot.iii"
extern @abi(c-msvc-x64) fn mpl_k() -> i64 from "mathesis_pilot.iii"
extern @abi(c-msvc-x64) fn mpl_p1() -> i64 from "mathesis_pilot.iii"
extern @abi(c-msvc-x64) fn mpl_p2() -> i64 from "mathesis_pilot.iii"
extern @abi(c-msvc-x64) fn mpl_r1() -> i64 from "mathesis_pilot.iii"
extern @abi(c-msvc-x64) fn mpl_r2() -> i64 from "mathesis_pilot.iii"
extern @abi(c-msvc-x64) fn mpl_run(k: i64) -> i64 from "mathesis_pilot.iii"
extern @abi(c-msvc-x64) fn mpl_head_byte(i: i64) -> u64 from "mathesis_pilot.iii"

var H36 : [u64; 32]
var H42 : [u64; 32]
var SNAP : [u64; 32]

fn fill_heads() -> i32 {
    /* the SEALED Omega-3 head(36): aa4e38be8c6cc3532ae121a3a1470dbc440d654290f29abbad51dc7419db9641 */
    H36[0u64] = 170u64  H36[1u64] = 78u64   H36[2u64] = 56u64   H36[3u64] = 190u64
    H36[4u64] = 140u64  H36[5u64] = 108u64  H36[6u64] = 195u64  H36[7u64] = 83u64
    H36[8u64] = 42u64   H36[9u64] = 225u64  H36[10u64] = 33u64  H36[11u64] = 163u64
    H36[12u64] = 161u64 H36[13u64] = 71u64  H36[14u64] = 13u64  H36[15u64] = 188u64
    H36[16u64] = 68u64  H36[17u64] = 13u64  H36[18u64] = 101u64 H36[19u64] = 66u64
    H36[20u64] = 144u64 H36[21u64] = 242u64 H36[22u64] = 154u64 H36[23u64] = 187u64
    H36[24u64] = 173u64 H36[25u64] = 81u64  H36[26u64] = 220u64 H36[27u64] = 116u64
    H36[28u64] = 25u64  H36[29u64] = 219u64 H36[30u64] = 150u64 H36[31u64] = 65u64
    /* the observed head(42): d24760d33dde16feaad8ac23c6e02f2b6340625fd8c04ade080047c9cfe286fb */
    H42[0u64] = 210u64  H42[1u64] = 71u64   H42[2u64] = 96u64   H42[3u64] = 211u64
    H42[4u64] = 61u64   H42[5u64] = 222u64  H42[6u64] = 22u64   H42[7u64] = 254u64
    H42[8u64] = 170u64  H42[9u64] = 216u64  H42[10u64] = 172u64 H42[11u64] = 35u64
    H42[12u64] = 198u64 H42[13u64] = 224u64 H42[14u64] = 47u64  H42[15u64] = 43u64
    H42[16u64] = 99u64  H42[17u64] = 64u64  H42[18u64] = 98u64  H42[19u64] = 95u64
    H42[20u64] = 216u64 H42[21u64] = 192u64 H42[22u64] = 74u64  H42[23u64] = 222u64
    H42[24u64] = 8u64   H42[25u64] = 0u64   H42[26u64] = 71u64  H42[27u64] = 201u64
    H42[28u64] = 207u64 H42[29u64] = 226u64 H42[30u64] = 134u64 H42[31u64] = 251u64
    return 0i32
}

fn chk_round(r: i64, k: i64, p1: i64, p2: i64, r1: i64, r2: i64) -> i64 {
    if mpl_round(r) != 0i64 { return 0i64 }
    if mpl_k() != k { return 0i64 }
    if mpl_p1() != p1 { return 0i64 }
    if mpl_p2() != p2 { return 0i64 }
    if mpl_r1() != r1 { return 0i64 }
    if mpl_r2() != r2 { return 0i64 }
    return 1i64
}

fn main() -> i32 {
    fill_heads()
    /* [A] the six new rounds, outcome for outcome */
    if chk_round(36i64, 0i64, 28i64, 60i64, 3i64, 0i64) != 1i64 { return 10i32 }
    if chk_round(37i64, 9i64, 1i64, 12i64, 0i64, 0i64) != 1i64 { return 11i32 }
    if chk_round(38i64, 2i64, 10i64, 31i64, 21i64, 39i64) != 1i64 { return 12i32 }
    if chk_round(39i64, 0i64, 29i64, 60i64, 0i64, 0i64) != 1i64 { return 13i32 }
    if chk_round(40i64, 9i64, 1i64, 13i64, 0i64, 0i64) != 1i64 { return 14i32 }
    if chk_round(41i64, 2i64, 10i64, 37i64, 27i64, 27i64) != 1i64 { return 15i32 }
    /* [B] THE PREFIX LAW: head(36) == the sealed Omega-3 ledger head */
    if mpl_run(36i64) != 36i64 { return 20i32 }
    let mut i : i64 = 0i64
    while i < 32i64 {
        if mpl_head_byte(i) != H36[i as u64] { return 21i32 }
        i = i + 1i64
    }
    /* [C] head(42): the new frontier head, pinned */
    if mpl_run(42i64) != 42i64 { return 30i32 }
    i = 0i64
    while i < 32i64 {
        SNAP[i as u64] = mpl_head_byte(i)
        if mpl_head_byte(i) != H42[i as u64] { return 31i32 }
        i = i + 1i64
    }
    /* [D] determinism EXECUTED: a second full run, the same head */
    if mpl_run(42i64) != 42i64 { return 40i32 }
    i = 0i64
    while i < 32i64 {
        if mpl_head_byte(i) != SNAP[i as u64] { return 41i32 }
        i = i + 1i64
    }
    return 99i32
}
