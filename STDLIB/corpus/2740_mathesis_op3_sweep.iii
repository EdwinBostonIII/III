/* 2740_mathesis_op3_sweep.iii -- GATE for THE MACHINE-WORD SWEEP (campaign Omega-4: the
 * width-64 decision of the 3-op grammar against rot_1, with the refusal envelope NAMED).
 *
 * The FULL 207,360-class sweep is the fleet-measured campaign artifact (16-way partition,
 * ~5.5 h single-threaded): 199,226 DECIDED (56 carrying a rot_1 spelling, 199,170 refuted),
 * 8,130 REFUSED at the SEALED bb capacity pins -- mechanism-1 (0xFF at 3-56 samples) on
 * every sampled refusal (20/20 across 13 regions), coordinates and reasons kept
 * (mr3_why/whyn) -- and FOUR classes (120620/120624/120628/120630, one leaf-quad family of
 * tree 2) wall-clock UNREACHED (>1 h solo each without an engine verdict): the residual
 * drain's first entries.  The certificate-vs-census split is the cost64 precedent: the gate
 * re-verifies a PRICED subset exactly; the census row lives in MATHESIS-PSI-ROUND1.log,
 * grep-pinned by stage [19].  Observed 2026-07-15.
 *
 * In-gate: [A] the NAMED DEFINIENS ARM -- (x << c1) | (x >> c2), sid 118919, decided by the
 * width-SETTING one-class omega range (the width-0 probe lesson: never a width-consuming
 * door before a width-setting one) -- it must MATCH at the machine word.  [B] THE STRIDE-97
 * CERTIFICATE SUBSET -- every 97th sid (97 prime: all five trees, all op-triple regions,
 * all leaf-quad classes sampled; the four unreached sids are NOT stride multiples, proven
 * by the 40 s runtime): 2138 classes, counts pinned EXACTLY (2051 decided, 0 matched, 87
 * refused), reproduced across two runs -- the engine is deterministic, so drift here is
 * engine drift.  [C] THE FAR-BOUNDARY ARMS (boundary-arm law: pin the MECHANISM far from
 * the envelope): the empty range at the grammar edge decides nothing; the refusal-
 * coordinate store guards refuse out-of-range reads by name.  EXIT 99. */
module corpus_2740_mathesis_op3_sweep

extern @abi(c-msvc-x64) fn mr3_omega(k: i64, lo: i64, hi: i64) -> i64 from "mathesis_rot64.iii"
extern @abi(c-msvc-x64) fn mr3_odec() -> i64 from "mathesis_rot64.iii"
extern @abi(c-msvc-x64) fn mr3_ound() -> i64 from "mathesis_rot64.iii"
extern @abi(c-msvc-x64) fn mr3_omatch() -> i64 from "mathesis_rot64.iii"
extern @abi(c-msvc-x64) fn mr3_undn() -> i64 from "mathesis_rot64.iii"
extern @abi(c-msvc-x64) fn mr3_undat(i: i64) -> i64 from "mathesis_rot64.iii"

fn main() -> i32 {
    /* [A] the named definiens arm: one-class range sets width 64; sid 118919 must MATCH */
    mr3_omega(1i64, 118919i64, 118920i64)
    if mr3_odec() != 1i64 { return 10i32 }
    if mr3_omatch() != 1i64 { return 11i32 }
    /* [B] the stride-97 certificate subset: counts pinned exactly (deterministic engine) */
    let mut sid : i64 = 0i64
    let mut dec : i64 = 0i64
    let mut mat : i64 = 0i64
    let mut und : i64 = 0i64
    while sid < 207360i64 {
        mr3_omega(1i64, sid, sid + 1i64)
        dec = dec + mr3_odec()
        mat = mat + mr3_omatch()
        und = und + mr3_ound()
        sid = sid + 97i64
    }
    if dec != 2051i64 { return 20i32 }
    if mat != 0i64 { return 21i32 }
    if und != 87i64 { return 22i32 }
    /* [C] the far-boundary arms: the empty range at the grammar edge decides nothing; the
     * refusal store guards refuse out-of-range reads BY NAME */
    mr3_omega(1i64, 207360i64, 207360i64)
    if mr3_odec() != 0i64 { return 30i32 }
    if mr3_ound() != 0i64 { return 31i32 }
    if mr3_undat(0i64) != 0i64 - 1i64 { return 32i32 }
    if mr3_undat(0i64 - 1i64) != 0i64 - 1i64 { return 33i32 }
    return 99i32
}
