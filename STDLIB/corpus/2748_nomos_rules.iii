/* STDLIB/corpus/2748_nomos_rules.iii -- THE NOMOS LEDGER GATE.
 *
 * The sealed machine-legislated rule module (COMPILER/BOOT/cg_phys_rules.iii
 * [EMITTED] -- friction-held laws, iii-prove PROVEN over all 2^64 by
 * nomos_seal.sh before landing) is (a) structurally self-consistent, (b)
 * semantically TRUE on a live battery through an INDEPENDENT evaluator
 * restating the atoms' base-op definiens (a tampered row reddens here even
 * though the 2^64 proof happened at seal time), and (c) door-DISCRIMINATING:
 * the involution doors admit exactly the legislated kinds and refuse the
 * rest; every row accessor refuses out-of-range indices with its sentinel.
 *
 * Consumes the WHOLE cgphys export surface (the carto consumer edge for the
 * emitted module).  Runner: standing-tools nomos arm + the mathesis-family
 * SKIP tier in run_corpus.sh.  Exit 99 = green; distinct exits per arm. */
module corpus_2748_nomos_rules

extern @abi(c-msvc-x64) fn cgphys_invol_admit(k: u32) -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_not_const() -> u64 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_neg_const() -> u64 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_nrules() -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_fuel() -> u64 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_cap() -> u64 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_set_id() -> u64 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_law(i: u32) -> u64 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_class(i: u32) -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_live(i: u32) -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_dear_len(i: u32) -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_cheap_len(i: u32) -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_dear_b(i: u32, j: u32) -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_cheap_b(i: u32, j: u32) -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_floor_dear(i: u32) -> u64 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_floor_cheap(i: u32) -> u64 from "cg_phys_rules.iii"

/* ---- the independent evaluator: preorder walk over a row side's ser bytes.
 * The atom formulas RESTATE the base-op definiens (the same spellings
 * ia_def1/lo_walk pin) without linking the isa organs -- two engines, one
 * claim, so a transcription drift in EITHER reddens the agreement arm. ---- */
var GI : u64 = 0u64      /* row under evaluation */
var GS : u64 = 0u64      /* side: 0 dear, 1 cheap */
var GC : u64 = 0u64      /* cursor */
var GL : u64 = 0u64      /* side length */
var GX : u64 = 0u64      /* leaf x value */
var GY : u64 = 0u64      /* leaf y value */
var GBAD : u64 = 0u64    /* unknown atom seen (count/deposit -- never sealed) */

fn gb() -> u64 {
    if GC >= GL { GBAD = 1u64   return 0u64 }
    let mut b : u32 = 0u32
    if GS == 0u64 { b = cgphys_rule_dear_b(GI as u32, GC as u32) } else { b = cgphys_rule_cheap_b(GI as u32, GC as u32) }
    GC = GC + 1u64
    return b as u64
}
fn geval() -> u64 {
    let b : u64 = gb()
    if b == 0u64 { return GX }
    if b == 1u64 { return GY }
    let id : u64 = b - 2u64
    if id == 0u64 { return 18446744073709551615u64 ^ geval() }
    if id == 1u64 { return 0u64 - geval() }
    if id == 2u64 { let a2 : u64 = geval()   return a2 & (0u64 - a2) }
    if id == 3u64 { let a3 : u64 = geval()   return a3 ^ (a3 - 1u64) }
    if id == 4u64 { let a4 : u64 = geval()   return a4 & (a4 - 1u64) }
    if id == 8u64 { let l8 : u64 = geval()   let r8 : u64 = geval()   return l8 & r8 }
    if id == 9u64 { let l9 : u64 = geval()   let r9 : u64 = geval()   return l9 | r9 }
    if id == 10u64 { let la : u64 = geval()   let ra : u64 = geval()   return la ^ ra }
    if id == 11u64 { let lb : u64 = geval()   let rb : u64 = geval()   return lb + rb }
    if id == 12u64 { let lc : u64 = geval()   let rc : u64 = geval()   return lc - rc }
    if id == 13u64 { let ld : u64 = geval()   let rd : u64 = geval()   return ld * rd }
    if id == 14u64 { let le : u64 = geval()   let re : u64 = geval()   return le << (re & 63u64) }
    if id == 15u64 { let lf : u64 = geval()   let rf : u64 = geval()   return lf >> (rf & 63u64) }
    if id == 16u64 { let lg : u64 = geval()   let rg : u64 = geval()   return (18446744073709551615u64 ^ lg) & rg }
    /* COUNT atoms (the loop rung paid 2026-07-17): the gate's restatement is the
     * NAIVE per-bit loop -- deliberately NOT the emitter's SWAR lowering and NOT
     * ia_def1's early-return spellings (three engines, one claim: a drift in the
     * SWAR text, the definiens, or these loops splits the agreement arm). */
    if id == 5u64 {
        let a5 : u64 = geval()
        let mut c5 : u64 = 0u64
        let mut v5 : u64 = a5
        let mut i5 : u64 = 0u64
        while i5 < 64u64 { c5 = c5 + (v5 & 1u64)   v5 = v5 >> 1u64   i5 = i5 + 1u64 }
        return c5
    }
    if id == 6u64 {
        let a6 : u64 = geval()
        let mut c6 : u64 = 0u64
        let mut r6 : u64 = 64u64
        let mut s6 : u64 = 0u64
        while s6 < 64u64 {
            if r6 == 64u64 { if ((a6 >> (63u64 - s6)) & 1u64) == 1u64 { r6 = c6 } }
            c6 = c6 + 1u64
            s6 = s6 + 1u64
        }
        return r6
    }
    if id == 7u64 {
        let a7v : u64 = geval()
        let mut c7 : u64 = 0u64
        let mut r7 : u64 = 64u64
        while c7 < 64u64 {
            if r7 == 64u64 { if ((a7v >> c7) & 1u64) == 1u64 { r7 = c7 } }
            c7 = c7 + 1u64
        }
        return r7
    }
    GBAD = 1u64
    return 0u64
}
fn side_eval(i: u64, side: u64, x: u64, y: u64) -> u64 {
    GI = i
    GS = side
    GC = 0u64
    if side == 0u64 { GL = cgphys_rule_dear_len(i as u32) as u64 } else { GL = cgphys_rule_cheap_len(i as u32) as u64 }
    GX = x
    GY = y
    return geval()
}

/* the probe battery: structured corners + a walking bit + mixed patterns */
fn bat(k: u64) -> u64 {
    if k == 0u64 { return 0u64 }
    if k == 1u64 { return 1u64 }
    if k == 2u64 { return 2u64 }
    if k == 3u64 { return 18446744073709551615u64 }
    if k == 4u64 { return 9223372036854775808u64 }
    if k == 5u64 { return 12297829382473034410u64 }
    if k == 6u64 { return 6148914691236517205u64 }
    if k == 7u64 { return 4294967295u64 }
    if k == 8u64 { return 18446744069414584320u64 }
    if k == 9u64 { return 81985529216486895u64 }
    if k == 10u64 { return 16045690984833335023u64 }
    if k == 11u64 { return 9223372036854775809u64 }
    if k == 12u64 { return 9223372036854775807u64 }
    if k == 13u64 { return 42u64 }
    if k == 14u64 { return 1000003u64 }
    return 1u64 << (k & 63u64)
}

fn main() -> i32 {
    let n : u64 = cgphys_nrules() as u64
    if n < 1u64 { return 10i32 }
    if n > 32u64 { return 10i32 }
    if cgphys_set_id() == 0u64 { return 11i32 }
    if cgphys_fuel() < 1u64 { return 11i32 }
    if cgphys_cap() > 15u64 { return 11i32 }

    /* the doors admit EXACTLY the legislated involution kinds, refuse the rest */
    if cgphys_invol_admit(0u32) != 1u32 { return 12i32 }
    if cgphys_invol_admit(1u32) != 1u32 { return 12i32 }
    let mut dk : u32 = 2u32
    while dk < 8u32 {
        if cgphys_invol_admit(dk) != 0u32 { return 13i32 }
        dk = dk + 1u32
    }
    if cgphys_not_const() != 18446744073709551615u64 { return 14i32 }
    if cgphys_neg_const() != 0u64 { return 14i32 }

    let mut i : u64 = 0u64
    let mut lastlaw : u64 = 0u64
    let mut sawlive : u64 = 0u64
    while i < n {
        let dl : u64 = cgphys_rule_dear_len(i as u32) as u64
        let cl : u64 = cgphys_rule_cheap_len(i as u32) as u64
        if dl < 1u64 { return 20i32 }
        if dl > 60u64 { return 20i32 }
        if cl < 1u64 { return 20i32 }
        if cl > 60u64 { return 20i32 }
        /* laws arrive in stream order: strictly increasing indices */
        let lw : u64 = cgphys_rule_law(i as u32)
        if i > 0u64 { if lw <= lastlaw { return 21i32 } }
        lastlaw = lw
        /* the friction fact every seat carries: the dear side measured dearer */
        if cgphys_rule_floor_dear(i as u32) <= cgphys_rule_floor_cheap(i as u32) { return 22i32 }
        let cls : u32 = cgphys_rule_class(i as u32)
        if cls > 3u32 { return 23i32 }
        /* live <=> class 0, and the live shape is EXACTLY u(u(leaf)) -> leaf, u in {NOT,NEG} */
        let lv : u32 = cgphys_rule_live(i as u32)
        if cls == 0u32 { if lv != 1u32 { return 24i32 } }
        if cls != 0u32 { if lv != 0u32 { return 24i32 } }
        if cls == 0u32 {
            sawlive = sawlive + 1u64
            if dl != 3u64 { return 25i32 }
            if cl != 1u64 { return 25i32 }
            let u0 : u32 = cgphys_rule_dear_b(i as u32, 0u32)
            let u1 : u32 = cgphys_rule_dear_b(i as u32, 1u32)
            if u0 != u1 { return 25i32 }
            if u0 != 2u32 { if u0 != 3u32 { return 25i32 } }
            if cgphys_rule_dear_b(i as u32, 2u32) >= 2u32 { return 25i32 }
            if cgphys_rule_cheap_b(i as u32, 0u32) >= 2u32 { return 25i32 }
        }
        /* THE AGREEMENT ARM: dear == cheap through the independent evaluator over
         * the whole battery (16 x-values x 4 y-values).  The 2^64 disposition is the
         * seal ceremony's (iii-prove); THIS arm pins the SEALED BYTES to live
         * arithmetic -- a tampered row (or a drifted definiens) reddens here. */
        let mut kx : u64 = 0u64
        while kx < 16u64 {
            let mut ky : u64 = 0u64
            while ky < 4u64 {
                GBAD = 0u64
                let vd : u64 = side_eval(i, 0u64, bat(kx), bat(ky * 5u64))
                let vc : u64 = side_eval(i, 1u64, bat(kx), bat(ky * 5u64))
                if GBAD != 0u64 { return 26i32 }
                if vd != vc { return 30i32 }
                ky = ky + 1u64
            }
            kx = kx + 1u64
        }
        i = i + 1u64
    }
    if sawlive < 2u64 { return 27i32 }   /* NOT and NEG both legislated in the sealed set */

    /* negative arms: every accessor refuses out-of-range with its sentinel */
    if cgphys_rule_law(n as u32) != 18446744073709551615u64 { return 40i32 }
    if cgphys_rule_dear_b(0u32, 99u32) != 255u32 { return 41i32 }
    if cgphys_rule_cheap_b(0u32, 99u32) != 255u32 { return 41i32 }
    if cgphys_rule_class(n as u32) != 255u32 { return 42i32 }
    if cgphys_rule_dear_len(n as u32) != 0u32 { return 43i32 }
    if cgphys_rule_cheap_len(n as u32) != 0u32 { return 43i32 }
    if cgphys_rule_floor_dear(n as u32) != 0u64 { return 44i32 }
    if cgphys_rule_floor_cheap(n as u32) != 0u64 { return 44i32 }

    return 99i32
}
