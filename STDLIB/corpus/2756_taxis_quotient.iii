/* STDLIB/corpus/2756_taxis_quotient.iii -- THE TAXIS QUOTIENT GATE.
 *
 * The DETERMINISTIC layer of the taxis ontology (iii-substrate taxis): the
 * OBJECTS of the friction order are the semantic classes of the live die's
 * term universe -- the quotient by battery signature (ia_apply -- the
 * electrons decide sameness).  This layer carries NO timing, so it is
 * exactly reproducible and belongs in the corpus; the RELATION (measured
 * friction dominance) is timing-bearing and lives in the standing arm.
 *
 * Arms: (mechanism, every die) classes <= terms, every term lands in a
 * class, the quotient is an EQUIVALENCE (reflexive by construction; the
 * gate re-checks that same-signature terms share a class id and cross-class
 * terms differ) -- and DISTINCT SPELLINGS collapse (size-3 has fewer classes
 * than terms: the order has something to rank).  (pinned, sealing die only)
 * exact {terms, classes} at size 2 and size 3.
 *
 * Exit: 99 green | 10 universe | 11 quotient-not-equivalence
 *     | 12 no-collapse (nothing to order) | 20..23 pinned (sealing die). */
module corpus_2756_taxis_quotient

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn ia_init() -> i64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_tcount(m: i64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_term_ser(t_idx: u64, out_addr: u64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_atom_arity(id: i64) -> i64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_apply1(atom: i64, a: u64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_apply2(atom: i64, a: u64, b: u64) -> u64 from "isa_ontogenesis.iii"

fn ps(s: u64) -> u32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }
    return 1u32
}
fn pu(v: u64) -> i32 { if v >= 10u64 { pu(v / 10u64) }   putchar((48u64 + (v % 10u64)) as i32)   return 0i32 }

var TS : [u8; 64]
var TC : u64 = 0u64
var TX : u64 = 0u64
var TY : u64 = 0u64
fn teval() -> u64 {
    let b : u8 = TS[TC]
    TC = TC + 1u64
    if b == 0u8 { return TX }
    if b == 1u8 { return TY }
    let id : i64 = (b as i64) - 2i64
    if ia_atom_arity(id) == 1i64 { return ia_apply1(id, teval()) }
    let l : u64 = teval()
    return ia_apply2(id, l, teval())
}
fn bat(k: u64) -> u64 {
    if k == 0u64 { return 0u64 }
    if k == 1u64 { return 1u64 }
    if k == 2u64 { return 2u64 }
    if k == 3u64 { return 18446744073709551615u64 }
    if k == 4u64 { return 9223372036854775808u64 }
    if k == 5u64 { return 12297829382473034410u64 }
    if k == 6u64 { return 6148914691236517205u64 }
    if k == 7u64 { return 4294967295u64 }
    if k == 8u64 { return 18446744069414584320u64 }
    if k == 9u64 { return 81985529216486895u64 }
    if k == 10u64 { return 16045690984833335023u64 }
    if k == 11u64 { return 9223372036854775809u64 }
    if k == 12u64 { return 9223372036854775807u64 }
    if k == 13u64 { return 42u64 }
    if k == 14u64 { return 1000003u64 }
    return 1u64 << (k & 63u64)
}
fn tsig(t: u64) -> u64 {
    let n : u64 = ia_term_ser(t, (&TS) as u64)
    if n == 0u64 { return 0u64 }
    let mut h : u64 = 14695981039346656037u64
    let mut kx : u64 = 0u64
    while kx < 16u64 {
        let mut ky : u64 = 0u64
        while ky < 4u64 {
            TC = 0u64
            TX = bat(kx)
            TY = bat(ky * 5u64)
            let v : u64 = teval()
            h = (h ^ v) * 1099511628211u64
            h = (h ^ (v >> 32u64)) * 1099511628211u64
            ky = ky + 1u64
        }
        kx = kx + 1u64
    }
    return h
}

var SG : [u64; 640]
var CID : [i64; 640]

/* the quotient at maxsize; returns class count, fills SG/CID for terms 0..prefix */
fn quotient(maxsize: i64) -> u64 {
    let mut prefix : u64 = 0u64
    let mut m : i64 = 1i64
    while m <= maxsize { prefix = prefix + ia_tcount(m)   m = m + 1i64 }
    let mut t : u64 = 0u64
    while t < prefix {
        SG[t] = tsig(t)
        CID[t] = 0i64 - 1i64
        t = t + 1u64
    }
    let mut nc : u64 = 0u64
    let mut a : u64 = 0u64
    while a < prefix {
        if CID[a] < 0i64 {
            CID[a] = nc as i64
            let mut b : u64 = a + 1u64
            while b < prefix {
                if CID[b] < 0i64 { if SG[b] == SG[a] { CID[b] = nc as i64 } }
                b = b + 1u64
            }
            nc = nc + 1u64
        }
        a = a + 1u64
    }
    return nc
}
fn prefix_of(maxsize: i64) -> u64 {
    let mut prefix : u64 = 0u64
    let mut m : i64 = 1i64
    while m <= maxsize { prefix = prefix + ia_tcount(m)   m = m + 1i64 }
    return prefix
}

fn main() -> i32 {
    ia_init()
    /* size 2 */
    let p2 : u64 = prefix_of(2i64)
    let c2 : u64 = quotient(2i64)
    ps("taxis quotient: size<=2  terms " as u64)  pu(p2)  ps("  classes " as u64)  pu(c2)  putchar(10i32)
    if p2 < 4u64 { return 10i32 }
    if c2 > p2 { return 11i32 }
    /* size 3 */
    let p3 : u64 = prefix_of(3i64)
    let c3 : u64 = quotient(3i64)
    ps("taxis quotient: size<=3  terms " as u64)  pu(p3)  ps("  classes " as u64)  pu(c3)  putchar(10i32)
    if p3 < 10u64 { return 10i32 }
    if c3 > p3 { return 11i32 }
    /* the quotient is a genuine equivalence: two same-class terms have the SAME
     * signature and two different-class terms differ -- reflexive-symmetric-
     * transitive by construction of the union sweep, RE-CHECKED against the sig */
    let mut a : u64 = 0u64
    while a < p3 {
        let mut b : u64 = a + 1u64
        while b < p3 {
            if CID[a] == CID[b] { if SG[a] != SG[b] { return 11i32 } }
            if CID[a] != CID[b] { if SG[a] == SG[b] { return 11i32 } }
            b = b + 1u64
        }
        a = a + 1u64
    }
    /* the order has something to rank: distinct spellings MUST collapse at
     * size 3 (more terms than classes) -- else the relation is vacuous */
    if c3 >= p3 { return 12i32 }
    /* the pinned quotient on the sealing die (these atoms) */
    if p2 == 18u64 { if p3 == 190u64 {
        if c2 != 18u64 { return 20i32 }          /* size 2: every term distinct */
        if c3 != 153u64 { return 21i32 }         /* size 3: 37 collisions -- the order's raw material */
        if (p3 - c3) != 37u64 { return 22i32 }
    } }
    ps("THE OBJECTS ARE FIXED: the die's semantic quotient is the deterministic ground of the friction order.\n" as u64)
    return 99i32
}
