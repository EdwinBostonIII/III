/* STDLIB/corpus/2764_synapse.iii -- Ξ-ΣΥΝ THE SYNAPSE GATE: the constitution-
 * pinned wire protocol, every law re-derived in-process, stored-answer-free.
 *
 * No sockets here (the protocol organ is R0-pure; transport is the tool's
 * composition) -- which is exactly what makes every rule PROVABLE: this gate
 * builds real frames, walks the whole refusal order with named codes, serves
 * real proof obligations, and cross-checks every wire answer against its OWN
 * independent engines (bit-loop evaluators for the GLOSSA words; the direct
 * organ road for AUTOPHASIS).  Foreign constitutions are hand-forged and must
 * be refused BY NAME.  Nothing is stored: the constitution ids come from the
 * sealed seats at link time, the fold is re-derived here, the battery is
 * generated, the evaluators are independent code.
 *
 * ARMS: SELF 10 | HELLO 11 | FOREIGN 12 | CONTENT 13 | CRC 14 | SEAL 15
 *     | SHORT 16 | GLOSSA-WIRE 17 | AUTOPHASIS-WIRE 18 | NONCE 19
 *     | REFUSALS 20 | FACET 21 | exit 99 green. */
module corpus_d2764

extern @abi(c-msvc-x64) fn synapse_hello_build(buf: u64) -> u32 from "synapse.iii"
extern @abi(c-msvc-x64) fn synapse_hello_verify(in_buf: u64, in_len: u32) -> i32 from "synapse.iii"
extern @abi(c-msvc-x64) fn synapse_ask_build(buf: u64, kind: u32, args_ptr: u64, nonce: u64) -> u32 from "synapse.iii"
extern @abi(c-msvc-x64) fn synapse_serve(in_buf: u64, in_len: u32, out_buf: u64) -> u32 from "synapse.iii"
extern @abi(c-msvc-x64) fn synapse_verdict_verify(in_buf: u64, in_len: u32, nonce: u64, kind: u32) -> i32 from "synapse.iii"
extern @abi(c-msvc-x64) fn synapse_verdict_result(in_buf: u64) -> u64 from "synapse.iii"
extern @abi(c-msvc-x64) fn synapse_verdict_ok(in_buf: u64) -> u8 from "synapse.iii"
extern @abi(c-msvc-x64) fn synapse_frame_gate(in_buf: u64, in_len: u32) -> i32 from "synapse.iii"
extern @abi(c-msvc-x64) fn synapse_seal_const() -> u64 from "synapse.iii"

