/* STDLIB/corpus/2765_anastasis.iii -- GATE for THE ANASTASIS TIER (Ξ-Ω, THE REDEMPTION):
 * every operation CONSERVATION condemned as irreversible is REDEEMED -- lifted into a
 * proven bijection whose ancilla pays EXACTLY the measured information deficit.
 * Irreversibility is a property of the projection, never of the computation.
 *
 * These arms prove the redemption SHAPES on the real machinery (bv_bits SAT miter +
 * full-domain exhaustion), stored-answer-free: every verdict is re-derived here.
 *
 * ARMS (each falsifiable, distinct exit):
 *   BENNETT  the universal lift B_f(x) = x ^ (f(low(x)) << 13) of a genuinely
 *            nonlinear irreversible f (t & (t>>1)) is a SAT-PROVEN involution of
 *            the 26-bit double die -- and BITES (is not the identity).
 *   HOMO     B_f . B_g == B_{f^g}, SAT-proven: the redeemed ops form an abelian
 *            group, the lift is a homomorphism from (ops, XOR) into involutions.
 *   SECOND   the same lift shape at 8-bit halves is a bijection + involution by
 *            FULL 2^16 exhaustion -- the independent second path.
 *   SHLFIX   the minimal repair of SHL-1 (deficit 1 bit): ((x<<1)>>1)|(bit12(x)<<12)
 *            == x, SAT-proven at W=13 -- the erased bit, salvaged, is sufficient.
 *   MULFIX   the minimal redemption of MUL-6 (= 2*3, deficit tz(6)=1): the odd part
 *            is undone by the ring unit-inverse (3^-1 mod 2^13 = 2731), the even
 *            part by the salvaged top bit of x*3 -- COMPOSED, proven by full 2^13
 *            exhaustion.  The two repair mechanisms compose.
 *
 *   CENSUS   the ORGAN arm: an_run(2) re-derives a small fair census live --
 *            fallen ops exist, every one is REDEEMED (minimal lift injective +
 *            reconstructed over all 2^13), every Bennett involution is proven,
 *            minimality is witnessed, and the pairwise group laws all hold.
 *   TEETH    the stripped SHL-1 lift fails on exactly half the domain -- the
 *            deficit is real information, not ceremony.
 *
 * exit 99 = all arms hold.  10/11 BENNETT  20 HOMO  30/31 SECOND  40 SHLFIX
 * 50 MULFIX  60 census-broken  61 no-fallen  62 unredeemed  63 bennett-missing
 * 64 minwit-missing  65 homo-broken  66 comm-broken  67 teeth-broken. */
module corpus_d2765

extern @abi(c-msvc-x64) fn an_run(maxsize: i64) -> i64 from "reversibility.iii"
extern @abi(c-msvc-x64) fn an_fallen() -> u64 from "reversibility.iii"
extern @abi(c-msvc-x64) fn an_redeemed() -> u64 from "reversibility.iii"
extern @abi(c-msvc-x64) fn an_ben12_n() -> u64 from "reversibility.iii"
extern @abi(c-msvc-x64) fn an_minwit() -> u64 from "reversibility.iii"
extern @abi(c-msvc-x64) fn an_homo() -> u64 from "reversibility.iii"
extern @abi(c-msvc-x64) fn an_comm() -> u64 from "reversibility.iii"
extern @abi(c-msvc-x64) fn an_pairs() -> u64 from "reversibility.iii"
extern @abi(c-msvc-x64) fn an_neg_teeth() -> u64 from "reversibility.iii"

extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_and(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_or(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_xor(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_mul(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shl(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shr(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_equal(a: u32, b: u32) -> u8 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_set_input(v: u32, val: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_eval(t: u32) -> u64 from "bv_bits.iii"

/* BENNETT + HOMO at the 26-bit double die, SAT-proven.
 * f(t) = t & (t>>1) on the low half -- nonlinear, irreversible on its own die. */
fn arm_bennett_homo() -> u64 {
    bb_reset(26u64)
    let x : u32 = bb_var(0u32)
    let m13 : u32 = bb_const(8191u64)
    let xl : u32 = bb_and(x, m13)
    let f : u32 = bb_and(bb_and(xl, bb_shr(xl, 1u64)), m13)
    let b1 : u32 = bb_xor(x, bb_shl(f, 13u64))
    let b1l : u32 = bb_and(b1, m13)
    let f2 : u32 = bb_and(bb_and(b1l, bb_shr(b1l, 1u64)), m13)
    let b2 : u32 = bb_xor(b1, bb_shl(f2, 13u64))
    if bb_equal(b2, x) != 1u8 { return 10u64 }
    if bb_equal(b1, x) == 1u8 { return 11u64 }
    /* B_f(B_g(x)) == B_{f xor g}(x) */
    let g : u32 = bb_and(bb_xor(xl, bb_shr(xl, 2u64)), m13)
    let t1 : u32 = bb_xor(x, bb_shl(g, 13u64))
    let t1l : u32 = bb_and(t1, m13)
    let f3 : u32 = bb_and(bb_and(t1l, bb_shr(t1l, 1u64)), m13)
    let lhs : u32 = bb_xor(t1, bb_shl(f3, 13u64))
    let rhs : u32 = bb_xor(x, bb_shl(bb_xor(f, g), 13u64))
    if bb_equal(lhs, rhs) != 1u8 { return 20u64 }
    return 0u64
}

/* SECOND path: exhaustive bijection + involution at the 16-bit packed double (8-bit halves) */
var A3M : [u8; 65536]
fn arm_second() -> u64 {
    bb_reset(16u64)
    let x : u32 = bb_var(0u32)
    let m8 : u32 = bb_const(255u64)
    let xl : u32 = bb_and(x, m8)
    let f : u32 = bb_and(bb_and(xl, bb_shr(xl, 1u64)), m8)
    let b : u32 = bb_xor(x, bb_shl(f, 8u64))
    let mut v : u64 = 0u64
    while v < 65536u64 { A3M[v] = 0u8   v = v + 1u64 }
    v = 0u64
    while v < 65536u64 {
        bb_set_input(0u32, v)
        let w : u64 = bb_eval(b) & 65535u64
        if A3M[w] != 0u8 { return 30u64 }
        A3M[w] = 1u8
        v = v + 1u64
    }
    v = 0u64
    while v < 65536u64 {
        bb_set_input(0u32, v)
        let w : u64 = bb_eval(b) & 65535u64
        bb_set_input(0u32, w)
        let u : u64 = bb_eval(b) & 65535u64
        if u != v { return 31u64 }
        v = v + 257u64
    }
    return 0u64
}

/* SHLFIX: minimal repair of SHL-1 at W=13, SAT-proven */
fn arm_shlfix() -> u64 {
    bb_reset(13u64)
    let x : u32 = bb_var(0u32)
    let low : u32 = bb_shl(x, 1u64)
    let keep : u32 = bb_shr(x, 12u64)
    let rec : u32 = bb_or(bb_shr(low, 1u64), bb_shl(keep, 12u64))
    if bb_equal(rec, x) != 1u8 { return 40u64 }
    return 0u64
}

/* MULFIX: minimal redemption of MUL-6 at W=13 by full-domain exhaustion */
fn arm_mulfix() -> u64 {
    bb_reset(13u64)
    let x : u32 = bb_var(0u32)
    let x3 : u32 = bb_mul(x, bb_const(3u64))
    let low : u32 = bb_shl(x3, 1u64)
    let keep : u32 = bb_and(bb_shr(x3, 12u64), bb_const(1u64))
    let rec : u32 = bb_mul(bb_or(bb_shr(low, 1u64), bb_shl(keep, 12u64)), bb_const(2731u64))
    let mut v : u64 = 0u64
    while v < 8192u64 {
        bb_set_input(0u32, v)
        if (bb_eval(rec) & 8191u64) != v { return 50u64 }
        v = v + 1u64
    }
    return 0u64
}

/* CENSUS: the organ re-derives a small fair census live, stored-answer-free */
fn arm_census() -> u64 {
    let frc : i64 = an_run(2i64)
    if frc < 0i64 { return 60u64 }
    if an_fallen() == 0u64 { return 61u64 }
    if an_redeemed() != an_fallen() { return 62u64 }
    if an_ben12_n() != an_fallen() { return 63u64 }
    if an_minwit() != an_fallen() { return 64u64 }
    if an_homo() != an_pairs() { return 65u64 }
    if an_comm() != an_pairs() { return 66u64 }
    if an_neg_teeth() != 1u64 { return 67u64 }
    return 0u64
}

fn main() -> i32 {
    let r1 : u64 = arm_bennett_homo()
    if r1 != 0u64 { return r1 as i32 }
    let r3 : u64 = arm_second()
    if r3 != 0u64 { return r3 as i32 }
    let r4 : u64 = arm_shlfix()
    if r4 != 0u64 { return r4 as i32 }
    let r5 : u64 = arm_mulfix()
    if r5 != 0u64 { return r5 as i32 }
    let r6 : u64 = arm_census()
    if r6 != 0u64 { return r6 as i32 }
    return 99i32
}
