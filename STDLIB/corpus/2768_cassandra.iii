/* STDLIB/corpus/2768_cassandra.iii -- THE CASSANDRA GATE: thermodynamic branch
 * prediction by least-action epistemic superposition, PROVEN not to explode.
 *
 * The Schrodinger's-colors claim made falsifiable: K orthogonal color-tags hold
 * 2^K distinct timelines in K words (linear storage, exponential reach), each
 * DERIVED on observation and never stored; the collapse is a thermodynamic filter
 * that annihilates the false futures at ZERO rewind cost.
 *
 * Stored-answer-free: every state is re-derived from the live constitution and
 * the proven bijection.
 *
 * ARMS (each falsifiable, distinct exit):
 *   SELF     the organ's own self-proof returns 0 (orthogonality, 2^K-distinct,
 *            least-action, exact+no-rewind collapse, ceiling, out-of-span refusal).
 *   SPAN     10 independent colors -> ALL 1024 derived timelines are pairwise
 *            DISTINCT (2^K reach from K=10 stored words, proven by exhaustion).
 *   ANTIEXPL the anti-explosion bound: a dependent color is refused; the 64-dim
 *            ceiling is enforced; storage stays K words for 2^K timelines.
 *   COLLAPSE observing the true pulse yields EXACTLY the derived timeline it
 *            selects, annihilates the other 2^K - 1, and pays ZERO rewinds.
 *   NOREWIND across a full predict/observe cycle the rewind counter stays 0 --
 *            strictly cheaper than the Lagrangian coupling's provisional reversal.
 *
 * exit 99 = all arms hold.  10 SELF  20/21 SPAN  30/31 ANTIEXPL  40/41 COLLAPSE
 * 50 NOREWIND. */
module corpus_d2768

extern @abi(c-msvc-x64) fn cass_selfproof() -> u64 from "cassandra.iii"
extern @abi(c-msvc-x64) fn cass_reset(acc: u64) -> i32 from "cassandra.iii"
extern @abi(c-msvc-x64) fn cass_add_color(delta: u64) -> u64 from "cassandra.iii"
extern @abi(c-msvc-x64) fn cass_count() -> u64 from "cassandra.iii"
extern @abi(c-msvc-x64) fn cass_derive(mask: u64) -> u64 from "cassandra.iii"
extern @abi(c-msvc-x64) fn cass_combo(mask: u64) -> u64 from "cassandra.iii"
extern @abi(c-msvc-x64) fn cass_solve(target: u64) -> u64 from "cassandra.iii"
extern @abi(c-msvc-x64) fn cass_observe(true_delta: u64) -> u64 from "cassandra.iii"
extern @abi(c-msvc-x64) fn cass_annihilated() -> u64 from "cassandra.iii"
extern @abi(c-msvc-x64) fn cass_rewinds() -> u64 from "cassandra.iii"
extern @abi(c-msvc-x64) fn cass_refused_dep() -> u64 from "cassandra.iii"
extern @abi(c-msvc-x64) fn cass_refused_full() -> u64 from "cassandra.iii"
extern @abi(c-msvc-x64) fn lg_noise(seed: u64, i: u64) -> u64 from "lagrangian.iii"

/* 1024 derived states for the pairwise-distinct exhaustion */
var STATES : [u64; 1024]

fn arm_span() -> u64 {
    cass_reset(0x9E3779B97F4A7C15u64)
    /* 10 independent colors = the 10 unit directions (guaranteed independent) */
    let mut k : u64 = 0u64
    while k < 10u64 {
        if cass_add_color(1u64 << (k * 3u64)) != 1u64 { return 20u64 }
        k = k + 1u64
    }
    if cass_count() != 10u64 { return 20u64 }
    /* derive all 2^10 timelines; assert pairwise distinct by hash-sorted scan */
    let mut m : u64 = 0u64
    while m < 1024u64 { STATES[m] = cass_derive(m)   m = m + 1u64 }
    /* O(n^2) pairwise (1024^2 ~ 1e6, fine) -- a genuine exhaustion */
    m = 0u64
    while m < 1024u64 {
        let mut n : u64 = m + 1u64
        while n < 1024u64 {
            if STATES[m] == STATES[n] { return 21u64 }
            n = n + 1u64
        }
        m = m + 1u64
    }
    return 0u64
}
fn arm_antiexpl() -> u64 {
    cass_reset(0x1234u64)
    cass_add_color(0x1u64)
    cass_add_color(0x2u64)
    cass_add_color(0x4u64)
    /* dependent: 0x7 = 0x1^0x2^0x4 -> refused */
    if cass_add_color(0x7u64) != 0u64 { return 30u64 }
    if cass_refused_dep() != 1u64 { return 30u64 }
    if cass_count() != 3u64 { return 30u64 }
    /* ceiling: fill to 64, then a 65th independent color is refused */
    cass_reset(0x55u64)
    let mut k : u64 = 0u64
    while k < 64u64 { cass_add_color(1u64 << k)   k = k + 1u64 }
    if cass_count() != 64u64 { return 31u64 }
    if cass_add_color(0xDEADBEEFCAFEu64) != 0u64 { return 31u64 }
    if cass_refused_full() != 1u64 { return 31u64 }
    return 0u64
}
fn arm_collapse() -> u64 {
    cass_reset(0xC0FFEEu64)
    /* 5 independent colors from the noise, forced independent by unit-seeding */
    let mut k : u64 = 0u64
    while k < 5u64 { cass_add_color(1u64 << (k * 7u64))   k = k + 1u64 }
    /* the true pulse = XOR of colors {0,2,4} */
    let target : u64 = cass_combo(21u64)          /* mask 10101b = {0,2,4} */
    let want : u64 = cass_derive(cass_solve(target))
    let got : u64 = cass_observe(target)
    if got != want { return 40u64 }
    /* 2^5 - 1 = 31 false timelines annihilated */
    if cass_annihilated() != 31u64 { return 41u64 }
    if cass_rewinds() != 0u64 { return 41u64 }
    return 0u64
}

fn main() -> i32 {
    if cass_selfproof() != 0u64 { return 10i32 }
    let s : u64 = arm_span()
    if s != 0u64 { return s as i32 }
    let a : u64 = arm_antiexpl()
    if a != 0u64 { return a as i32 }
    let c : u64 = arm_collapse()
    if c != 0u64 { return c as i32 }
    if cass_rewinds() != 0u64 { return 50i32 }
    return 99i32
}
