/* III conformance corpus 276 -- Stage 3.8: let-mut checkpoint-flag regression.
 *
 * The CLAUDE.md trap registry documented an "iiis-0 `let mut x = 0u32`
 * checkpoint-flag bug": a flag set in one conditional branch read stale in
 * a later `if flag == 0` check (the flag lived in a register that was not
 * reloaded after the conditional store).  cg_r3.iii::r3_emit_global_ident
 * historically used early-return-per-branch to dodge it.
 *
 * Stage 3.8 verified (probe + iiis-0/iiis-2 disassembly) that the bug is
 * GONE: every `let mut` local is memory-backed at a stack slot with
 * store-then-reload semantics, so conditional mutation is correct.  This
 * test is the permanent regression pin -- it exercises the formerly-buggy
 * pattern in four shapes and must return 99.
 *
 * Exit = 99 on success; 1..10 = the specific case that regressed.
 */
module corpus_276

/* C1: flag set in one branch, checked in a later if. */
fn c1(input: u32) -> u32 {
    let mut handled : u32 = 0u32
    if input == 5u32 { handled = 1u32 }
    if handled == 0u32 { return 100u32 }
    return 200u32
}

/* C2: multi-branch flag dispatch (the later set must win). */
fn c2(a: u32, b: u32) -> u32 {
    let mut f : u32 = 0u32
    if a == 1u32 { f = 10u32 }
    if b == 1u32 { f = 20u32 }
    return f
}

/* C3: flag set inside a loop, checked after. */
fn c3(target: u32) -> u32 {
    let mut found : u32 = 0u32
    let mut i : u32 = 0u32
    while i < 8u32 {
        if i == target { found = 1u32 }
        i = i + 1u32
    }
    if found == 1u32 { return 55u32 }
    return 44u32
}

/* C4: the r3_emit_global_ident-style flag dispatch (the workaround's
 * buggy form -- a `handled` checkpoint guarding subsequent branches). */
fn c4(kind: u32) -> u32 {
    let mut handled : u32 = 0u32
    let mut result : u32 = 0u32
    if kind == 1u32 { result = 11u32; handled = 1u32 }
    if handled == 0u32 { if kind == 2u32 { result = 22u32; handled = 1u32 } }
    if handled == 0u32 { result = 99u32 }
    return result
}

fn main() -> u64 {
    if c1(5u32) != 200u32 { return 1u64 }
    if c1(3u32) != 100u32 { return 2u64 }
    if c2(1u32, 0u32) != 10u32 { return 3u64 }
    if c2(0u32, 1u32) != 20u32 { return 4u64 }
    if c2(1u32, 1u32) != 20u32 { return 5u64 }
    if c3(3u32) != 55u32 { return 6u64 }
    if c3(9u32) != 44u32 { return 7u64 }
    if c4(1u32) != 11u32 { return 8u64 }
    if c4(2u32) != 22u32 { return 9u64 }
    if c4(7u32) != 99u32 { return 10u64 }
    return 99u64
}
