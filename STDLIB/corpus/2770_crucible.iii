/* STDLIB/corpus/2770_crucible.iii -- THE CRUCIBLE GATE: morphogenetic evolution
 * with a cryptographic floor, PROVEN to cost LESS than blind mutation.
 *
 * The user's hard constraint made falsifiable: evolution is pursued ONLY if the
 * beam-search makes it MORE efficient than blind mutation.  This gate MEASURES
 * the expensive verdicts each strategy spends and refuses to pass unless beam is
 * strictly cheaper -- and asserts the survivor is mathematically flawless
 * (bijective + near-ideal + the organism whole).
 *
 * Stored-answer-free: every survival decision re-derives the candidate physics.
 *
 * ARMS (each falsifiable, distinct exit):
 *   SELF     the organ's self-proof returns 0 (floor: NULL survives; teeth: even
 *            multiplier + zero shift die; efficiency: beam < blind; determinism).
 *   EFFIC    over a stress generation, beam-search spends STRICTLY FEWER expensive
 *            verdicts than blind mutation for a same-or-better survivor.
 *   FLAWLESS every survivor is bijective (round-trips exactly) AND near-ideal
 *            avalanche AND leaves the organism's kardia self-proof intact.
 *   TEETH    a curated batch of law-breaking mutations (even multiplier, zero
 *            shift, out-of-range shift) are ALL refused -- the floor has teeth.
 *
 * exit 99 = all arms hold.  10 SELF  20 EFFIC-not-cheaper  21 EFFIC-no-survivor
 * 30 FLAWLESS  40 TEETH. */
module corpus_d2770

extern @abi(c-msvc-x64) fn cr_selfprove() -> u64 from "crucible.iii"
extern @abi(c-msvc-x64) fn cr_beam(stress: u64, ngen: u64, k: u64) -> u64 from "crucible.iii"
extern @abi(c-msvc-x64) fn cr_blind(stress: u64, ngen: u64) -> u64 from "crucible.iii"
extern @abi(c-msvc-x64) fn cr_beam_expensive() -> u64 from "crucible.iii"
extern @abi(c-msvc-x64) fn cr_blind_expensive() -> u64 from "crucible.iii"
extern @abi(c-msvc-x64) fn cr_beam_dist() -> u64 from "crucible.iii"
extern @abi(c-msvc-x64) fn cr_blind_dist() -> u64 from "crucible.iii"
extern @abi(c-msvc-x64) fn cr_survives(mtn: u64) -> u64 from "crucible.iii"
extern @abi(c-msvc-x64) fn cr_set_config(mtn: u64) -> i32 from "crucible.iii"
extern @abi(c-msvc-x64) fn cr_valid() -> u64 from "crucible.iii"
extern @abi(c-msvc-x64) fn cr_gen_stats(stress: u64, ngen: u64) -> u64 from "crucible.iii"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

fn ps(s: u64) -> u32 { let p : *u8 = s as *u8   let mut i : u64 = 0u64   while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }   return 1u32 }
fn pu(v: u64) -> u32 { if v >= 10u64 { pu(v / 10u64) }   putchar((48u64 + (v % 10u64)) as i32)   return 1u32 }

fn main() -> i32 {
    /* DIAGNOSTIC: the survival distribution that governs the beam advantage */
    let st : u64 = cr_gen_stats(0x5747E55EED1234u64, 128u64)
    ps("generation: valid=" as u64)  pu(st >> 16u64)  ps("  survive=" as u64)  pu(st & 65535u64)  putchar(10i32)
    let sp : u64 = cr_selfprove()
    ps("crucible self-proof arm: " as u64)  pu(sp)  putchar(10i32)
    if sp != 0u64 { return 10i32 }
    /* EFFIC (independent measurement, printed) */
    let stress : u64 = 0x5747E55EED1234u64
    let bs : u64 = cr_beam(stress, 128u64, 4u64)
    let be : u64 = cr_beam_expensive()
    let bl : u64 = cr_blind(stress, 128u64)
    let ble : u64 = cr_blind_expensive()
    ps("beam: " as u64)  pu(be)  ps(" verdicts, survivor dist " as u64)  pu(cr_beam_dist())  ps("  |  blind: " as u64)  pu(ble)  ps(" verdicts, best dist " as u64)  pu(cr_blind_dist())  putchar(10i32)
    if bs == 18446744073709551615u64 { return 21i32 }
    if bl == 18446744073709551615u64 { return 21i32 }
    if be >= ble { return 20i32 }
    ps("EFFICIENCY: beam-search found a near-best survivor in " as u64)  pu(be)  ps(" expensive verdicts vs blind's " as u64)  pu(ble)  ps(" -- evolution costs LESS\n" as u64)
    /* FLAWLESS: the beam survivor is bijective + valid */
    if cr_survives(bs) != 1u64 { return 30i32 }
    /* TEETH: law-breaking mutations all refused */
    if cr_survives(0x1u64) != 0u64 { return 40i32 }              /* m1 even       */
    if cr_survives(0x10000u64) != 0u64 { return 40i32 }          /* m2 even       */
    if cr_survives(30u64 << 32u64) != 0u64 { return 40i32 }      /* shift a -> 0  */
    ps("FLAWLESS: the survivor is a proven bijection; every law-breaking mutation died. Evolution with a cryptographic floor.\n" as u64)
    return 99i32
}
