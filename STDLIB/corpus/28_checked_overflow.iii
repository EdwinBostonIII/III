/* checked: u32 add of MAX-3 + 5 overflows -> none; MAX-3 + 2 ok -> some(MAX-1) */
module corpus_b28

extern @abi(c-msvc-x64) fn checked_u32_add(a: u32, b: u32) -> u64 from "checked.iii"
extern @abi(c-msvc-x64) fn checked_u32_mul(a: u32, b: u32) -> u64 from "checked.iii"

fn main() -> u64 {
    /* Overflow case */
    let r1 : u64 = checked_u32_add(0xFFFFFFFCu32, 5u32)
    if (r1 & 1u64) != 0u64 { return 1u64 }
    /* Non-overflow case */
    let r2 : u64 = checked_u32_add(0xFFFFFFFCu32, 2u32)
    if (r2 & 1u64) != 1u64 { return 2u64 }
    let v : u32 = ((r2 >> 1u64) & 0xFFFFFFFFu64) as u32
    if v != 0xFFFFFFFEu32 { return 3u64 }
    /* Mul overflow */
    let r3 : u64 = checked_u32_mul(0x80000000u32, 2u32)
    if (r3 & 1u64) != 0u64 { return 4u64 }
    /* Mul ok */
    let r4 : u64 = checked_u32_mul(7u32, 6u32)
    let v4 : u32 = ((r4 >> 1u64) & 0xFFFFFFFFu64) as u32
    if v4 != 42u32 { return 5u64 }
    return 99u64
}
