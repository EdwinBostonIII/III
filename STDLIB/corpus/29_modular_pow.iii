/* modular: 7^13 mod 19 = 7^13 = 96889010407, mod 19 = ? Quick verify
 * By Fermat: 7^18 ≡ 1 (mod 19), so 7^13 ≡ 7^(-5) ≡ ... compute directly:
 * 7^1=7, 7^2=49 mod 19 = 11, 7^4 = 121 mod 19 = 7, 7^8 = 49 mod 19 = 11.
 * 7^13 = 7^8 * 7^4 * 7^1 = 11 * 7 * 7 mod 19 = 539 mod 19 = 539 - 28*19 = 539 - 532 = 7.
 * Expected: 7. */
module corpus_b29

extern @abi(c-msvc-x64) fn mod_u32_pow(b: u32, e: u32, m: u32) -> u32 from "modular.iii"
extern @abi(c-msvc-x64) fn mod_u32_mul(a: u32, b: u32, m: u32) -> u32 from "modular.iii"

fn main() -> u64 {
    let r : u32 = mod_u32_pow(7u32, 13u32, 19u32)
    if r != 7u32 { return 1u64 }
    /* Sanity: (12 * 13) mod 5 = 156 mod 5 = 1 */
    let m : u32 = mod_u32_mul(12u32, 13u32, 5u32)
    if m != 1u32 { return 2u64 }
    return 99u64
}
