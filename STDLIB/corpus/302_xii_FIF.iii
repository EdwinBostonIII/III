/* corpus/302_xii_FIF.iii
 * XII Phase β conformance: F.IF fusion operator (kind=22, ternary).
 */

module corpus_302_xii_FIF

extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_if(p: u32, t: u32, e: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_kind(idx: u32) -> u8 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_a(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_b(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_c(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_is_fusion(idx: u32) -> u8 from "xii_term.iii"

fn main() -> u64 {
    xii_term_arena_reset()
    let p : u32 = xii_term_make_basis(0u8, 0x10u32)
    let then_b : u32 = xii_term_make_basis(1u8, 0x20u32)
    let else_b : u32 = xii_term_make_basis(1u8, 0x30u32)
    let t : u32 = xii_term_make_if(p, then_b, else_b)
    if xii_term_get_kind(t) != 22u8 { return 1u64 }
    if xii_term_get_child_a(t) != p { return 2u64 }
    if xii_term_get_child_b(t) != then_b { return 3u64 }
    if xii_term_get_child_c(t) != else_b { return 4u64 }
    if xii_term_is_fusion(t) != 1u8 { return 5u64 }
    return 0u64
}
