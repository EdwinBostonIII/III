/* corpus/305_xii_R002.iii  -- R002 [A2] Then right-assoc */

module corpus_305_xii_R002

extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_fusion2(kind: u8, a: u32, b: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_kind(idx: u32) -> u8 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_a(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_b(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_apply_one(t: u32) -> u32 from "xii_rewrite.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_last_rule_fired() -> u32 from "xii_rewrite.iii"

fn main() -> u64 {
    xii_term_arena_reset()
    let a : u32 = xii_term_make_basis(2u8, 0x100u32)
    let b : u32 = xii_term_make_basis(2u8, 0x200u32)
    let c : u32 = xii_term_make_basis(2u8, 0x300u32)
    /* route-S: associativity is STRUCTURAL. make_fusion2 re-associates then(then(a,b),c) into the
     * right-nested canonical form then(a, then(b,c)) AT CONSTRUCTION (R002 retired). */
    let inner : u32 = xii_term_make_fusion2(19u8, a, b)
    let t : u32 = xii_term_make_fusion2(19u8, inner, c)
    if xii_term_get_kind(t) != 19u8 { return 2u64 }
    if xii_term_get_child_a(t) != a { return 3u64 }
    let new_inner : u32 = xii_term_get_child_b(t)
    if xii_term_get_kind(new_inner) != 19u8 { return 4u64 }
    /* and R002 is RETIRED: it cannot fire on the (already-canonical) term. */
    xii_rewrite_apply_one(t)
    if xii_rewrite_last_rule_fired() == 2u32 { return 1u64 }
    return 0u64
}
