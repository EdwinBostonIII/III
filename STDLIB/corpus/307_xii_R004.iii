/* corpus/307_xii_R004.iii  -- R004 [A4] Under left-assoc */

module corpus_307_xii_R004

extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_fusion2(kind: u8, a: u32, b: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_kind(idx: u32) -> u8 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_a(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_b(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_apply_one(t: u32) -> u32 from "xii_rewrite.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_last_rule_fired() -> u32 from "xii_rewrite.iii"

fn main() -> u64 {
    xii_term_arena_reset()
    let a : u32 = xii_term_make_basis(9u8, 0x100u32)
    let b : u32 = xii_term_make_basis(9u8, 0x200u32)
    let c : u32 = xii_term_make_basis(9u8, 0x300u32)
    /* route-S: associativity is STRUCTURAL. FUNDER left-associates, so make_fusion2 turns
     * under(a, under(b,c)) into the LEFT-nested canonical form under(under(a,b), c) AT CONSTRUCTION
     * (R004 retired) -- the opposite-direction structural re-association. */
    let inner : u32 = xii_term_make_fusion2(21u8, b, c)
    let t : u32 = xii_term_make_fusion2(21u8, a, inner)
    if xii_term_get_kind(t) != 21u8 { return 2u64 }
    let new_outer : u32 = xii_term_get_child_a(t)
    if xii_term_get_kind(new_outer) != 21u8 { return 3u64 }
    if xii_term_get_child_b(t) != c { return 4u64 }
    /* and R004 is RETIRED: it cannot fire on the (already-canonical) term. */
    xii_rewrite_apply_one(t)
    if xii_rewrite_last_rule_fired() == 4u32 { return 1u64 }
    return 0u64
}
