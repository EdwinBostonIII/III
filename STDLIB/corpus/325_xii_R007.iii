/* corpus/325_xii_R007.iii  -- R007 [B3] IF/COMPOSE prefix lift */

module corpus_325_xii_R007

extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_fusion2(kind: u8, a: u32, b: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_if(p: u32, t: u32, e: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_kind(idx: u32) -> u8 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_apply_one(t: u32) -> u32 from "xii_rewrite.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_last_rule_fired() -> u32 from "xii_rewrite.iii"

fn main() -> u64 {
    xii_term_arena_reset()
    let p : u32 = xii_term_make_basis(0u8, 0x10u32)
    let a1 : u32 = xii_term_make_basis(0u8, 0x100u32)
    let a2 : u32 = xii_term_make_basis(0u8, 0x100u32)
    let t_inner : u32 = xii_term_make_basis(1u8, 0x200u32)
    let e_inner : u32 = xii_term_make_basis(1u8, 0x300u32)
    let then_b : u32 = xii_term_make_fusion2(18u8, a1, t_inner)
    let else_b : u32 = xii_term_make_fusion2(18u8, a2, e_inner)
    let t : u32 = xii_term_make_if(p, then_b, else_b)
    let r : u32 = xii_rewrite_apply_one(t)
    if xii_rewrite_last_rule_fired() != 7u32 { return 1u64 }
    if xii_term_get_kind(r) != 18u8 { return 2u64 }
    return 0u64
}
