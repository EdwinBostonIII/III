/* corpus/369_xii_curated_embedded.iii — Cortex-M curated payloads */

module corpus_369_xii_curated_embedded

extern @abi(c-msvc-x64) fn xii_register_all() -> i32 from "xii_register_all.iii"
extern @abi(c-msvc-x64) fn xii_emit_gen_produce(horizon_id: u32, target: u32, expected_size: u32, out: *u8) -> u32 from "xii_emit_gen.iii"

var BUF369 : [u8; 256]

fn main() -> u64 {
    xii_register_all()

    /* Cortex-M prologue is 4 bytes (push {lr}; push {r7, lr}). */
    /* H051 swap_bytes_u64 on target 6 (Cortex-M): rev r0, r0 = 80 ba */
    let n51 : u32 = xii_emit_gen_produce(50u32, 6u32, 32u32, &BUF369 as *u8)
    if n51 == 0u32 { return 1u64 }
    /* Prologue first byte = 0x00, second = 0xB5 (push {lr}). */
    if BUF369[0] != 0x00u8 { return 2u64 }
    if BUF369[1] != 0xB5u8 { return 3u64 }
    /* Body at offset 4 should start with REV r0, r0 = 80 ba */
    if BUF369[4] != 0x80u8 { return 4u64 }
    if BUF369[5] != 0xBAu8 { return 5u64 }

    /* H058 aligned_load_u128 on Cortex-M: LDM r0!, {r1-r4} = 1e c8 */
    let n58 : u32 = xii_emit_gen_produce(57u32, 6u32, 32u32, &BUF369 as *u8)
    if n58 == 0u32 { return 6u64 }
    if BUF369[4] != 0x1Eu8 { return 7u64 }
    if BUF369[5] != 0xC8u8 { return 8u64 }

    return 0u64
}
