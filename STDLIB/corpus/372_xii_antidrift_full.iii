/* corpus/372_xii_antidrift_full.iii
 *
 * Exercises the new xii_antidrift_check_all signature and the three
 * previously-missing checks (lattice, empirical confluence, anchor sig).
 *
 * Strategy: build a synthetic in-memory manifest, compute its mhash as
 * the golden, then drive every anti-drift check. The synthetic manifest
 * has no real signature (Ed25519 verify is expected to fail) but we
 * exercise the individual checks separately to make sure each returns
 * the right code path.
 *
 * Hexad: kind_essence. Ring: R0.
 *
 * NIH: libc only.
 */

module corpus_372_xii_antidrift_full

extern @abi(c-msvc-x64) fn sha256_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 from "sha256.iii"

extern @abi(c-msvc-x64) fn xii_horizon_init() -> i32 from "xii_horizon.iii"
extern @abi(c-msvc-x64) fn xii_register_all() -> i32 from "xii_register_all.iii"
extern @abi(c-msvc-x64) fn xii_chd_construct() -> u8 from "xii_chd.iii"
extern @abi(c-msvc-x64) fn xii_chd_set_hash(idx: u32, hash_lo: u32, hash_hi: u32) -> i32 from "xii_chd.iii"

extern @abi(c-msvc-x64) fn xii_antidrift_check_manifest(manifest_ptr: *u8, manifest_size: u32, golden_mhash: *u8) -> u32 from "xii_antidrift.iii"
extern @abi(c-msvc-x64) fn xii_antidrift_check_lattice(text_section: *u8, audit_records: *u8, record_count: u32) -> u32 from "xii_antidrift.iii"
extern @abi(c-msvc-x64) fn xii_antidrift_check_reach6() -> u32 from "xii_antidrift.iii"
extern @abi(c-msvc-x64) fn xii_antidrift_check_critpairs() -> u32 from "xii_antidrift.iii"
extern @abi(c-msvc-x64) fn xii_antidrift_check_hexad() -> u32 from "xii_antidrift.iii"
extern @abi(c-msvc-x64) fn xii_antidrift_check_dk_symmetry() -> u32 from "xii_antidrift.iii"
extern @abi(c-msvc-x64) fn xii_antidrift_check_confluence_empirical(n_samples: u32, seed: u32) -> u32 from "xii_antidrift.iii"
extern @abi(c-msvc-x64) fn xii_antidrift_check_mphf() -> u32 from "xii_antidrift.iii"

const C372_OK            : u32 = 0u32
const C372_MANIFEST_SIZE : u32 = 1040u32

/* Synthetic manifest: 1040 bytes of structured filler so SHA-256 has
 * something concrete to lock onto. The pattern is byte_i = i & 0xFF
 * so the mhash is fully determined by file content. */
var C372_MANIFEST : [u8; 1040]
var C372_GOLDEN   : [u8; 32]

fn _c372_seed_manifest() -> i32 {
    let mut i : u32 = 0u32
    while i < C372_MANIFEST_SIZE {
        C372_MANIFEST[i] = (i & 0xFFu32) as u8
        i = i + 1u32
    }
    return 0i32
}

/* Seed CHD with 144 deterministic distinct hashes so MPHF check can pass. */
fn _c372_seed_chd() -> i32 {
    let mut i : u32 = 0u32
    while i < 144u32 {
        /* Distinct primary/secondary by multiplying by large odd constants
         * (Fibonacci-style hashing -- avoids collisions in the 144-slot
         * primary table). */
        let lo : u32 = (i * 2654435761u32) ^ 0x9E3779B9u32
        let hi : u32 = (i * 0x85EBCA77u32) ^ 0xC2B2AE3Du32
        xii_chd_set_hash(i, lo, hi)
        i = i + 1u32
    }
    return 0i32
}

fn main() -> u64 {
    /* Bring the curation tables up. */
    xii_register_all()
    _c372_seed_manifest()
    _c372_seed_chd()

    /* Compute the golden mhash of the seeded manifest. */
    sha256_oneshot(&C372_MANIFEST as *u8, C372_MANIFEST_SIZE as u64, &C372_GOLDEN as *u8)

    /* Check 1: manifest mhash matches golden. */
    let r1 : u32 = xii_antidrift_check_manifest(&C372_MANIFEST as *u8, C372_MANIFEST_SIZE, &C372_GOLDEN as *u8)
    if r1 != C372_OK { return 1u64 }

    /* Mutate one byte; check_manifest should now fail. */
    let saved : u8 = C372_MANIFEST[7u32]
    C372_MANIFEST[7u32] = saved ^ 0xFFu8
    let r1b : u32 = xii_antidrift_check_manifest(&C372_MANIFEST as *u8, C372_MANIFEST_SIZE, &C372_GOLDEN as *u8)
    if r1b == C372_OK { return 2u64 }
    /* Restore. */
    C372_MANIFEST[7u32] = saved

    /* Check 2 (lattice): with record_count=0 the check is trivially OK
     * regardless of pointers, exercising the empty-loop path. */
    let r2 : u32 = xii_antidrift_check_lattice(&C372_MANIFEST as *u8, &C372_MANIFEST as *u8, 0u32)
    if r2 != C372_OK { return 3u64 }

    /* Check 3: reach6 productive_count == 126. */
    let r3 : u32 = xii_antidrift_check_reach6()
    if r3 != C372_OK { return 4u64 }

    /* Check 4: empirical confluence (small sample for fast smoke). */
    let r4 : u32 = xii_antidrift_check_confluence_empirical(8u32, 0xDEADBEEFu32)
    if r4 != C372_OK { return 5u64 }

    /* Check 5: critical-pair convergence (18 real two-path tests). */
    let r5 : u32 = xii_antidrift_check_critpairs()
    if r5 != C372_OK { return 6u64 }

    /* Check 6: MPHF collision-free over 144 seeded hashes. */
    let built : u8 = xii_chd_construct()
    if built != 1u8 { return 7u64 }
    let r6 : u32 = xii_antidrift_check_mphf()
    if r6 != C372_OK { return 8u64 }

    /* Check 7: HJ associativity over 343 triples. */
    let r7 : u32 = xii_antidrift_check_hexad()
    if r7 != C372_OK { return 9u64 }

    /* Check 9 (dk symmetry): ΔK_compose symmetric. */
    let r9 : u32 = xii_antidrift_check_dk_symmetry()
    if r9 != C372_OK { return 10u64 }

    return 0u64
}
