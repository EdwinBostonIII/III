/* 375 — Groth16 over BLS12-381: QAP polynomial engine + full setup/prove/verify
 * KAT on x^3=out (verify accepts the valid proof, rejects a tampered public input). */
module corpus_375
extern @abi(c-msvc-x64) fn zk_snark_poly_selftest() -> u64 from "zk_snark.iii"
extern @abi(c-msvc-x64) fn zk_snark_kat() -> u64 from "zk_snark.iii"
fn main() -> u64 {
    let a : u64 = zk_snark_poly_selftest()
    if a != 99u64 { return a }
    return zk_snark_kat()
}
