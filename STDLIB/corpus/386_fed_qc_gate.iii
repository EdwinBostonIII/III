/* 386 — V1 Stage 5 federation QC gate: fed_seal_anchor_with_qc consumes a real
 * HotStuff quorum certificate (3 distinct Ed25519 keypairs, n=4 quorum 3) for
 * cross-tier anchoring.  Invalid QC (one tampered sig -> 2 valid < quorum) ->
 * FED_SEAL_E_QC; valid QC -> anchored.  (The same hs_verify_qc gate is the 4th
 * gate of fed_admit_with_qc_proof.) */
module corpus_386

extern @abi(c-msvc-x64) fn ed25519_pubkey(seed: *u8, out_pk: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn ed25519_sign(seed: *u8, pk: *u8, msg: *u8, msg_len: u64, sig_out: *u8) -> u8 from "crypt_ed25519.iii"
extern @abi(c-msvc-x64) fn hs_init(node_id: u32, peers: *u8, n_peers: u32) -> i32 from "hotstuff.iii"
extern @abi(c-msvc-x64) fn hs_compose_qc(block_mhash: *u8, view: u64, sigs: *u8, n_sigs: u32, out_qc: *u8) -> i32 from "hotstuff.iii"
extern @abi(c-msvc-x64) fn fed_seal_clear() -> i32 from "fed_seal.iii"
extern @abi(c-msvc-x64) fn fed_seal_anchor_with_qc(child_tier: u32, child_root_ptr: u64, parent_tier: u32, parent_root_ptr: u64, qc_ptr: *u8, qc_len: u32) -> i32 from "fed_seal.iii"
extern @abi(c-msvc-x64) fn fed_seal_anchor_count() -> u32 from "fed_seal.iii"

var Q_SEED  : [u8; 128]
var Q_PK    : [u8; 128]
var Q_SI    : [u8; 40]
var Q_SIGS  : [u8; 192]
var Q_QC    : [u8; 256]
var Q_BADQC : [u8; 256]
var Q_BMH   : [u8; 32]
var Q_CR    : [u8; 32]
var Q_PR    : [u8; 32]

fn main() -> u64 {
    /* 4 distinct keypairs */
    let mut i : u64 = 0u64
    while i < 4u64 {
        let mut j : u64 = 0u64
        while j < 32u64 { Q_SEED[i * 32u64 + j] = (i * 7u64 + j + 1u64) as u8  j = j + 1u64 }
        i = i + 1u64
    }
    i = 0u64
    while i < 4u64 {
        if ed25519_pubkey(((&Q_SEED as u64) + i * 32u64) as *u8, ((&Q_PK as u64) + i * 32u64) as *u8) != 1u8 { return 1u64 }
        i = i + 1u64
    }
    hs_init(0u32, (&Q_PK as u64) as *u8, 4u32)            /* quorum 3 */
    /* block_mhash + roots */
    i = 0u64
    while i < 32u64 { Q_BMH[i] = 0xABu8  Q_CR[i] = (i + 1u64) as u8  Q_PR[i] = (i + 100u64) as u8  i = i + 1u64 }
    /* sig_input = block_mhash || view 1 (LE) */
    i = 0u64
    while i < 32u64 { Q_SI[i] = Q_BMH[i]  i = i + 1u64 }
    Q_SI[32u64] = 1u8
    i = 33u64
    while i < 40u64 { Q_SI[i] = 0u8  i = i + 1u64 }
    /* 3 signatures over sig_input by peers 0,1,2 */
    i = 0u64
    while i < 3u64 {
        if ed25519_sign(((&Q_SEED as u64) + i * 32u64) as *u8, ((&Q_PK as u64) + i * 32u64) as *u8, (&Q_SI as u64) as *u8, 40u64, ((&Q_SIGS as u64) + i * 64u64) as *u8) != 1u8 { return 2u64 }
        i = i + 1u64
    }
    if hs_compose_qc((&Q_BMH as u64) as *u8, 1u64, (&Q_SIGS as u64) as *u8, 3u32, (&Q_QC as u64) as *u8) != 0i32 { return 3u64 }
    /* bad QC = valid QC with sig 0 tampered (2 valid < quorum 3); [T1b] sig 0 is now at [52] */
    i = 0u64
    while i < 256u64 { Q_BADQC[i] = Q_QC[i]  i = i + 1u64 }
    Q_BADQC[52u64] = Q_BADQC[52u64] ^ 0x01u8
    fed_seal_clear()
    /* invalid QC -> FED_SEAL_E_QC (-5); [T1b] QC is 52 + 3*64 = 244 bytes */
    if fed_seal_anchor_with_qc(2u32, (&Q_CR as u64), 4u32, (&Q_PR as u64), (&Q_BADQC as u64) as *u8, 244u32) != -5i32 { return 4u64 }
    if fed_seal_anchor_count() != 0u32 { return 5u64 }   /* nothing anchored on rejection */
    /* valid QC -> anchored */
    if fed_seal_anchor_with_qc(2u32, (&Q_CR as u64), 4u32, (&Q_PR as u64), (&Q_QC as u64) as *u8, 244u32) != 0i32 { return 6u64 }
    if fed_seal_anchor_count() != 1u32 { return 7u64 }
    return 99u64
}
