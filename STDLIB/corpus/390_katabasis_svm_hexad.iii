/* 390 -- KATABASIS increment 1: AMD-SVM offset hexad typing (plan 4.7 / ADR-004).
 * Proves the keystone brick defense of the III descent: a WriteMetal cycle
 * naming a hypervisor-critical SVM offset (VMCB / HOST_SAVE / NPT / GUEST /
 * HV_STATE / DIAG) is UNREPRESENTABLE (admissible == 0), while a write to
 * SHARED / ML_STATE is admitted (== 1).  The plan-0.6 BSOD -- a 16-byte write
 * to HOST_SAVE @ 0x1000 -- is rejected by construction.
 * Exit 99 = every assertion holds; 1..19 = the index of the failing assertion. */
module corpus_390_katabasis_svm_hexad

extern @abi(c-msvc-x64) fn katabasis_svm_region(offset: u32) -> u32 from "svm_layout.iii"
extern @abi(c-msvc-x64) fn katabasis_svm_write_admissible(offset: u32) -> u8 from "svm_layout.iii"

fn main() -> u64 {
    /* region classification across the verified layout (plan 0.4) */
    if katabasis_svm_region(0x0u32)     != 1u32 { return 1u64 }
    if katabasis_svm_region(0x1000u32)  != 2u32 { return 2u64 }
    if katabasis_svm_region(0x2000u32)  != 3u32 { return 3u64 }
    if katabasis_svm_region(0xA000u32)  != 4u32 { return 4u64 }
    if katabasis_svm_region(0x10000u32) != 5u32 { return 5u64 }
    if katabasis_svm_region(0x20000u32) != 6u32 { return 6u64 }
    if katabasis_svm_region(0x3E000u32) != 7u32 { return 7u64 }
    if katabasis_svm_region(0x3F000u32) != 8u32 { return 8u64 }
    if katabasis_svm_region(0x40000u32) != 0u32 { return 9u64 }

    /* the keystone: lethal targets are unrepresentable (admissible == 0) */
    if katabasis_svm_write_admissible(0x1000u32) != 0u8 { return 10u64 }
    if katabasis_svm_write_admissible(0x1004u32) != 0u8 { return 11u64 }
    if katabasis_svm_write_admissible(0x0u32)    != 0u8 { return 12u64 }
    if katabasis_svm_write_admissible(0x2000u32) != 0u8 { return 13u64 }
    if katabasis_svm_write_admissible(0xA000u32) != 0u8 { return 14u64 }
    if katabasis_svm_write_admissible(0x3E000u32) != 0u8 { return 15u64 }
    if katabasis_svm_write_admissible(0x3F000u32) != 0u8 { return 16u64 }

    /* the two positive regions ARE writable (admissible == 1) */
    if katabasis_svm_write_admissible(0x10000u32) != 1u8 { return 17u64 }
    if katabasis_svm_write_admissible(0x20000u32) != 1u8 { return 18u64 }
    if katabasis_svm_write_admissible(0x30000u32) != 1u8 { return 19u64 }

    return 99u64
}
