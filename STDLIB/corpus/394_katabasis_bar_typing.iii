/* 394 -- KATABASIS increment 4: GPU BAR write typing (plan FR-7 / 5.4 / 0.6).
 * The F9 CoprocDispatch counterpart of the SVM typing: a metal write is
 * admissible iff its physical target is inside AD103 BAR0/BAR1/BAR3 -- the only
 * targets the 0.6 post-mortem proved contained within the GPU and harmless to
 * the host kernel.  Any other physical address (host RAM, the LAPIC, the SVM
 * region, the gaps between BARs) is UNREPRESENTABLE.
 * Exit 99 = all hold; 1..16 = the index of the failing assertion. */
module corpus_394_katabasis_bar_typing

extern @abi(c-msvc-x64) fn katabasis_bar_region(phys: u64) -> u32 from "bar_layout.iii"
extern @abi(c-msvc-x64) fn katabasis_bar_write_admissible(phys: u64) -> u8 from "bar_layout.iii"

fn main() -> u64 {
    /* region classification (verified BAR addresses, plan 0.2 / 0.6) */
    if katabasis_bar_region(0xFB000000u64)   != 1u32 { return 1u64 }   /* BAR0 base */
    if katabasis_bar_region(0xFB800000u64)   != 1u32 { return 2u64 }   /* BAR0 mid */
    if katabasis_bar_region(0xF800000000u64) != 2u32 { return 3u64 }   /* BAR1 base */
    if katabasis_bar_region(0xFC00000000u64) != 3u32 { return 4u64 }   /* BAR3 base */
    if katabasis_bar_region(0xFC01000000u64) != 3u32 { return 5u64 }   /* BAR3 mid */
    if katabasis_bar_region(0x1000u64)       != 0u32 { return 6u64 }   /* low host RAM */
    if katabasis_bar_region(0xFC000000u64)   != 0u32 { return 7u64 }   /* BAR0 end (exclusive) */
    if katabasis_bar_region(0xF900000000u64) != 0u32 { return 8u64 }   /* BAR1 end (exclusive) */
    if katabasis_bar_region(0xFC02000000u64) != 0u32 { return 9u64 }   /* BAR3 end (exclusive) */
    if katabasis_bar_region(0xFD00000000u64) != 0u32 { return 10u64 }  /* above all BARs */

    /* admission: BAR0/1/3 writable; everything else unrepresentable */
    if katabasis_bar_write_admissible(0xFB000000u64)   != 1u8 { return 11u64 }  /* BAR0 */
    if katabasis_bar_write_admissible(0xF800000000u64) != 1u8 { return 12u64 }  /* BAR1 */
    if katabasis_bar_write_admissible(0xFC00000000u64) != 1u8 { return 13u64 }  /* BAR3 */
    if katabasis_bar_write_admissible(0x1000u64)       != 0u8 { return 14u64 }  /* host RAM */
    if katabasis_bar_write_admissible(0xFEE00000u64)   != 0u8 { return 15u64 }  /* LAPIC */
    if katabasis_bar_write_admissible(0xFC000000u64)   != 0u8 { return 16u64 }  /* just past BAR0 */
    return 99u64
}
