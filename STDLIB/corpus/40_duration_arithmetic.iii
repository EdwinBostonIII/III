/* duration: 1000 ms = 1e9 ns; add/sub; saturate */
module corpus_c40

extern @abi(c-msvc-x64) fn duration_from_millis(n: u64) -> u64 from "duration.iii"
extern @abi(c-msvc-x64) fn duration_from_seconds(n: u64) -> u64 from "duration.iii"
extern @abi(c-msvc-x64) fn duration_add(a: u64, b: u64) -> u64 from "duration.iii"
extern @abi(c-msvc-x64) fn duration_sub(a: u64, b: u64) -> u64 from "duration.iii"
extern @abi(c-msvc-x64) fn duration_to_millis(d: u64) -> u64 from "duration.iii"

fn main() -> u64 {
    let one_sec : u64 = duration_from_millis(1000u64)
    if one_sec != 1000000000u64 { return 1u64 }
    if duration_to_millis(one_sec) != 1000u64 { return 2u64 }
    let two_sec_a : u64 = duration_add(one_sec, one_sec)
    let two_sec_b : u64 = duration_from_seconds(2u64)
    if two_sec_a != two_sec_b { return 3u64 }
    let zero : u64 = duration_sub(one_sec, two_sec_a)
    if zero != 0u64 { return 4u64 }
    let max_test : u64 = duration_add(0xFFFFFFFFFFFFFFFEu64, 100u64)
    if max_test != 0xFFFFFFFFFFFFFFFFu64 { return 5u64 }
    return 99u64
}
