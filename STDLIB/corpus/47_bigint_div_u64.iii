/* bigint_div_u64: 100 / 7 = 14 r 2; (2^64 + 5) / 2 = 2^63 + 2 r 1 */
module corpus_d47

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_from_pair(arena: u64, hi: u64, lo: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_to_u64_lo(id: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_len_limbs(id: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_get_limb(id: u64, i: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_shl_bits(arena: u64, a: u64, n: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_add(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_div_u64(arena: u64, a: u64, scalar: u64) -> u64 from "bigint_div.iii"
extern @abi(c-msvc-x64) fn bigint_remainder_u64() -> u64 from "bigint_div.iii"

fn main() -> u64 {
    let a : u64 = arena_new(1u64 << 16u64)
    /* 100 / 7 = 14 r 2 */
    let hundred : u64 = bigint_from_u64(a, 100u64)
    let q1 : u64 = bigint_div_u64(a, hundred, 7u64)
    if bigint_to_u64_lo(q1) != 14u64 { return 1u64 }
    if bigint_remainder_u64() != 2u64 { return 2u64 }
    /* Build (2^64 + 5):  shift 1 left 64 -> 2^64; add 5. */
    let one : u64 = bigint_from_u64(a, 1u64)
    let two64 : u64 = bigint_shl_bits(a, one, 64u64)
    let five : u64 = bigint_from_u64(a, 5u64)
    let val : u64 = bigint_add(a, two64, five)
    /* val / 2 -> quotient = 2^63 + 2 (low limb 2, high limb missing because
     * 2^63 fits in low 64; quotient should be 2^63 + 2 in low limb). */
    let q2 : u64 = bigint_div_u64(a, val, 2u64)
    /* expected q2 limb 0 = 0x8000000000000002 ; remainder = 1 */
    let lo : u64 = bigint_get_limb(q2, 0u64)
    if lo != 0x8000000000000002u64 { return 3u64 }
    if bigint_remainder_u64() != 1u64 { return 4u64 }
    bigint_drop(hundred); bigint_drop(q1); bigint_drop(one)
    bigint_drop(two64); bigint_drop(five); bigint_drop(val); bigint_drop(q2)
    arena_drop(a)
    return 99u64
}
