/* bigint_div_qr: 100 / 7 = 14 r 2 via full bigint division */
module corpus_d48

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_to_u64_lo(id: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_div_qr(arena: u64, a: u64, b: u64) -> u64 from "bigint_div.iii"
extern @abi(c-msvc-x64) fn bigint_remainder_take() -> u64 from "bigint_div.iii"
extern @abi(c-msvc-x64) fn bigint_mod(arena: u64, a: u64, m: u64) -> u64 from "bigint_div.iii"
extern @abi(c-msvc-x64) fn bigint_modpow(arena: u64, b: u64, e: u64, m: u64) -> u64 from "bigint_div.iii"

fn main() -> u64 {
    let a : u64 = arena_new(1u64 << 18u64)
    let hundred : u64 = bigint_from_u64(a, 100u64)
    let seven : u64 = bigint_from_u64(a, 7u64)
    let q : u64 = bigint_div_qr(a, hundred, seven)
    if bigint_to_u64_lo(q) != 14u64 { return 1u64 }
    let r : u64 = bigint_remainder_take()
    if bigint_to_u64_lo(r) != 2u64 { return 2u64 }
    /* mod test: 100 mod 7 = 2 */
    let m : u64 = bigint_mod(a, hundred, seven)
    if bigint_to_u64_lo(m) != 2u64 { return 3u64 }
    /* modpow: 7^13 mod 19 = 7 */
    let base : u64 = bigint_from_u64(a, 7u64)
    let exp : u64 = bigint_from_u64(a, 13u64)
    let mod_19 : u64 = bigint_from_u64(a, 19u64)
    let mp : u64 = bigint_modpow(a, base, exp, mod_19)
    if bigint_to_u64_lo(mp) != 7u64 { return 4u64 }
    bigint_drop(hundred); bigint_drop(seven); bigint_drop(q); bigint_drop(r)
    bigint_drop(m); bigint_drop(base); bigint_drop(exp); bigint_drop(mod_19); bigint_drop(mp)
    arena_drop(a)
    return 99u64
}
