/* field: Fp7 - (3+5) mod 7 = 1; (3*5) mod 7 = 1; inv(3) mod 7 = 5; (3*5) mod 7 = 1 */
module corpus_d49

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_to_u64_lo(id: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn fp_add(arena: u64, a: u64, b: u64, m: u64) -> u64 from "field.iii"
extern @abi(c-msvc-x64) fn fp_sub(arena: u64, a: u64, b: u64, m: u64) -> u64 from "field.iii"
extern @abi(c-msvc-x64) fn fp_mul(arena: u64, a: u64, b: u64, m: u64) -> u64 from "field.iii"
extern @abi(c-msvc-x64) fn fp_pow(arena: u64, b: u64, e: u64, m: u64) -> u64 from "field.iii"
extern @abi(c-msvc-x64) fn fp_inv_fermat(arena: u64, a: u64, p: u64) -> u64 from "field.iii"

fn main() -> u64 {
    let a : u64 = arena_new(1u64 << 18u64)
    let three : u64 = bigint_from_u64(a, 3u64)
    let five : u64 = bigint_from_u64(a, 5u64)
    let p : u64 = bigint_from_u64(a, 7u64)
    /* (3+5) mod 7 = 1 */
    let sum : u64 = fp_add(a, three, five, p)
    if bigint_to_u64_lo(sum) != 1u64 { return 1u64 }
    /* (3*5) mod 7 = 15 mod 7 = 1 */
    let prod : u64 = fp_mul(a, three, five, p)
    if bigint_to_u64_lo(prod) != 1u64 { return 2u64 }
    /* (3-5) mod 7 = -2 mod 7 = 5 */
    let diff : u64 = fp_sub(a, three, five, p)
    if bigint_to_u64_lo(diff) != 5u64 { return 3u64 }
    /* inv(3) mod 7 = 5 (since 3*5 = 15 = 2*7+1) */
    let inv3 : u64 = fp_inv_fermat(a, three, p)
    if bigint_to_u64_lo(inv3) != 5u64 { return 4u64 }
    /* 3 * inv(3) mod 7 = 1 */
    let check : u64 = fp_mul(a, three, inv3, p)
    if bigint_to_u64_lo(check) != 1u64 { return 5u64 }
    /* fp_pow(3, 6, 7) = 1 by Fermat */
    let six : u64 = bigint_from_u64(a, 6u64)
    let pow6 : u64 = fp_pow(a, three, six, p)
    if bigint_to_u64_lo(pow6) != 1u64 { return 6u64 }
    bigint_drop(three); bigint_drop(five); bigint_drop(p)
    bigint_drop(sum); bigint_drop(prod); bigint_drop(diff)
    bigint_drop(inv3); bigint_drop(check); bigint_drop(six); bigint_drop(pow6)
    arena_drop(a)
    return 99u64
}
