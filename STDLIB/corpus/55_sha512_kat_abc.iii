/* 55_sha512_kat_abc.iii -- SHA-512("abc") FULL 64-byte digest.
 * Strengthened (wave-5 production audit P3): was a toy-trap that read ONLY digest byte 0 (0xDD) and
 * returned it -- a stub emitting the right first byte would pass.  Now compares all 64 bytes to the
 * published FIPS 180-4 vector ddaf35a193617aba...a9ac94fa54ca49f.  99 = every byte matches. */
module corpus_55

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn sha512_oneshot(input: *u8, len: u64, out: *u8) -> u32 from "sha512.iii"

var EXP : [u8; 64]

fn main() -> u64 {
    EXP[0u64]=0xddu8 EXP[1u64]=0xafu8 EXP[2u64]=0x35u8 EXP[3u64]=0xa1u8 EXP[4u64]=0x93u8 EXP[5u64]=0x61u8 EXP[6u64]=0x7au8 EXP[7u64]=0xbau8
    EXP[8u64]=0xccu8 EXP[9u64]=0x41u8 EXP[10u64]=0x73u8 EXP[11u64]=0x49u8 EXP[12u64]=0xaeu8 EXP[13u64]=0x20u8 EXP[14u64]=0x41u8 EXP[15u64]=0x31u8
    EXP[16u64]=0x12u8 EXP[17u64]=0xe6u8 EXP[18u64]=0xfau8 EXP[19u64]=0x4eu8 EXP[20u64]=0x89u8 EXP[21u64]=0xa9u8 EXP[22u64]=0x7eu8 EXP[23u64]=0xa2u8
    EXP[24u64]=0x0au8 EXP[25u64]=0x9eu8 EXP[26u64]=0xeeu8 EXP[27u64]=0xe6u8 EXP[28u64]=0x4bu8 EXP[29u64]=0x55u8 EXP[30u64]=0xd3u8 EXP[31u64]=0x9au8
    EXP[32u64]=0x21u8 EXP[33u64]=0x92u8 EXP[34u64]=0x99u8 EXP[35u64]=0x2au8 EXP[36u64]=0x27u8 EXP[37u64]=0x4fu8 EXP[38u64]=0xc1u8 EXP[39u64]=0xa8u8
    EXP[40u64]=0x36u8 EXP[41u64]=0xbau8 EXP[42u64]=0x3cu8 EXP[43u64]=0x23u8 EXP[44u64]=0xa3u8 EXP[45u64]=0xfeu8 EXP[46u64]=0xebu8 EXP[47u64]=0xbdu8
    EXP[48u64]=0x45u8 EXP[49u64]=0x4du8 EXP[50u64]=0x44u8 EXP[51u64]=0x23u8 EXP[52u64]=0x64u8 EXP[53u64]=0x3cu8 EXP[54u64]=0xe8u8 EXP[55u64]=0x0eu8
    EXP[56u64]=0x2au8 EXP[57u64]=0x9au8 EXP[58u64]=0xc9u8 EXP[59u64]=0x4fu8 EXP[60u64]=0xa5u8 EXP[61u64]=0x4cu8 EXP[62u64]=0xa4u8 EXP[63u64]=0x9fu8

    let inp : *u8 = malloc(3u64)
    inp[0] = 97u8  inp[1] = 98u8  inp[2] = 99u8
    let out : *u8 = malloc(64u64)
    sha512_oneshot(inp, 3u64, out)
    let mut i : u64 = 0u64
    while i < 64u64 {
        if out[i] != EXP[i] { free(inp) free(out) return 10u64 + i }
        i = i + 1u64
    }
    free(inp) free(out)
    return 99u64
}
