/* 607 -- KATABASIS increment 13: the cycle-term content-address seal (plan 4.2).
 * Seals cycle terms and asserts: reproducible (same cycle -> same seal),
 * content-sensitive (different cycle -> different seal), non-zero, and that
 * verify() accepts a cycle's own seal but rejects another's (tamper-evidence).
 * Exit 99 = all hold; 1..6 = the index of the failing assertion. */
module corpus_607_katabasis_seal

extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn katabasis_cycle_act(family: u32, target_kind: u32, target: u64, action_hexad: u32) -> u32 from "cycle_term.iii"
extern @abi(c-msvc-x64) fn katabasis_cycle_under_cap(act_idx: u32, cap_id: u32) -> u32 from "cycle_term.iii"
extern @abi(c-msvc-x64) fn katabasis_cycle_seal(cycle_idx: u32, out_addr: u64) -> i32 from "seal.iii"
extern @abi(c-msvc-x64) fn katabasis_cycle_seal_verify(cycle_idx: u32, claimed_addr: u64) -> u8 from "seal.iii"
extern @abi(c-msvc-x64) fn cad_eq(a: *u8, b: *u8) -> u8 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_is_zero(a: *u8) -> u8 from "cad.iii"

var T_S1 : [u8; 32]
var T_S2 : [u8; 32]
var T_S3 : [u8; 32]

fn main() -> u64 {
    xii_term_arena_reset()
    let a1 : u32 = katabasis_cycle_act(2u32, 1u32, 0x20000u64, 728u32)
    let c1 : u32 = katabasis_cycle_under_cap(a1, 42u32)
    let a3 : u32 = katabasis_cycle_act(9u32, 2u32, 0xFB000000u64, 364u32)
    let c3 : u32 = katabasis_cycle_under_cap(a3, 7u32)

    katabasis_cycle_seal(c1, &T_S1 as u64)
    katabasis_cycle_seal(c1, &T_S2 as u64)
    katabasis_cycle_seal(c3, &T_S3 as u64)

    /* reproducible: same cycle -> identical seal */
    if cad_eq(&T_S1 as *u8, &T_S2 as *u8) != 1u8 { return 1u64 }
    /* content-sensitive: a different cycle -> a different seal */
    if cad_eq(&T_S1 as *u8, &T_S3 as *u8) != 0u8 { return 2u64 }
    /* the seal is non-zero */
    if cad_is_zero(&T_S1 as *u8) != 0u8 { return 3u64 }

    /* verify: a cycle matches its own seal; not another's (tamper-evidence) */
    if katabasis_cycle_seal_verify(c1, &T_S1 as u64) != 1u8 { return 4u64 }
    if katabasis_cycle_seal_verify(c1, &T_S3 as u64) != 0u8 { return 5u64 }
    if katabasis_cycle_seal_verify(c3, &T_S3 as u64) != 1u8 { return 6u64 }

    return 99u64
}
