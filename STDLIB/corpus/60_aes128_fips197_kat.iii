/* AES-128 KAT: FIPS 197 Appendix C.1
 *   plaintext  = 00112233445566778899aabbccddeeff
 *   key        = 000102030405060708090a0b0c0d0e0f
 *   ciphertext = 69c4e0d86a7b0430d8cdb78070b4c55a
 *
 * Exit = first byte of ciphertext = 0x69 = 105.
 */
module corpus_60

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn aes128_set_key(key: *u8) -> i32 from "aes.iii"
extern @abi(c-msvc-x64) fn aes_encrypt_block(in_block: *u8, out_block: *u8) -> i32 from "aes.iii"

fn main() -> u64 {
    let key : *u8 = malloc(16u64)
    key[0]  = 0x00u8
    key[1]  = 0x01u8
    key[2]  = 0x02u8
    key[3]  = 0x03u8
    key[4]  = 0x04u8
    key[5]  = 0x05u8
    key[6]  = 0x06u8
    key[7]  = 0x07u8
    key[8]  = 0x08u8
    key[9]  = 0x09u8
    key[10] = 0x0Au8
    key[11] = 0x0Bu8
    key[12] = 0x0Cu8
    key[13] = 0x0Du8
    key[14] = 0x0Eu8
    key[15] = 0x0Fu8
    let pt : *u8 = malloc(16u64)
    pt[0]  = 0x00u8
    pt[1]  = 0x11u8
    pt[2]  = 0x22u8
    pt[3]  = 0x33u8
    pt[4]  = 0x44u8
    pt[5]  = 0x55u8
    pt[6]  = 0x66u8
    pt[7]  = 0x77u8
    pt[8]  = 0x88u8
    pt[9]  = 0x99u8
    pt[10] = 0xAAu8
    pt[11] = 0xBBu8
    pt[12] = 0xCCu8
    pt[13] = 0xDDu8
    pt[14] = 0xEEu8
    pt[15] = 0xFFu8
    let ct : *u8 = malloc(16u64)
    aes128_set_key(key)
    aes_encrypt_block(pt, ct)
    /* Verify all 16 bytes of expected ciphertext. */
    if ct[0]  != 0x69u8 { return 1u64 }
    if ct[1]  != 0xC4u8 { return 2u64 }
    if ct[2]  != 0xE0u8 { return 3u64 }
    if ct[3]  != 0xD8u8 { return 4u64 }
    if ct[4]  != 0x6Au8 { return 5u64 }
    if ct[5]  != 0x7Bu8 { return 6u64 }
    if ct[6]  != 0x04u8 { return 7u64 }
    if ct[7]  != 0x30u8 { return 8u64 }
    if ct[8]  != 0xD8u8 { return 9u64 }
    if ct[9]  != 0xCDu8 { return 10u64 }
    if ct[10] != 0xB7u8 { return 11u64 }
    if ct[11] != 0x80u8 { return 12u64 }
    if ct[12] != 0x70u8 { return 13u64 }
    if ct[13] != 0xB4u8 { return 14u64 }
    if ct[14] != 0xC5u8 { return 15u64 }
    if ct[15] != 0x5Au8 { return 16u64 }
    /* Return first byte of ciphertext as exit code (0x69 = 105). */
    let result : u64 = ct[0] as u64
    free(key)
    free(pt)
    free(ct)
    return result
}
