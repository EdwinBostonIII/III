/* AES-128-GCM seal: NIST SP 800-38D Test Case 2.
 *   K  = 00 * 16
 *   IV = 00 * 12
 *   P  = 00 * 16
 *   A  = empty
 *   C  = 0388dace60b6a392f328c2b971b2fe78
 *   T  = ab6e47d42cec13bdf53a67b21257bddf
 *
 * Verify ciphertext and tag bytes.  Exit = 99 on success.
 */
module corpus_62

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn aes_gcm_init(key: *u8, nonce: *u8, nonce_len: u64) -> i32 from "aes_gcm.iii"
extern @abi(c-msvc-x64) fn aes_gcm_seal(pt: *u8, pt_len: u64, ct_out: *u8, tag_out: *u8) -> i32 from "aes_gcm.iii"

fn zero_buf(p: *u8, n: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < n {
        p[i] = 0u8
        i = i + 1u64
    }
    return 0i32
}

fn check_ct(ct: *u8) -> u64 {
    /* Expected: 03 88 da ce 60 b6 a3 92 f3 28 c2 b9 71 b2 fe 78 */
    if ct[0]  != 0x03u8 { return 1u64 }
    if ct[1]  != 0x88u8 { return 2u64 }
    if ct[2]  != 0xDAu8 { return 3u64 }
    if ct[3]  != 0xCEu8 { return 4u64 }
    if ct[4]  != 0x60u8 { return 5u64 }
    if ct[5]  != 0xB6u8 { return 6u64 }
    if ct[6]  != 0xA3u8 { return 7u64 }
    if ct[7]  != 0x92u8 { return 8u64 }
    if ct[8]  != 0xF3u8 { return 9u64 }
    if ct[9]  != 0x28u8 { return 10u64 }
    if ct[10] != 0xC2u8 { return 11u64 }
    if ct[11] != 0xB9u8 { return 12u64 }
    if ct[12] != 0x71u8 { return 13u64 }
    if ct[13] != 0xB2u8 { return 14u64 }
    if ct[14] != 0xFEu8 { return 15u64 }
    if ct[15] != 0x78u8 { return 16u64 }
    return 0u64
}

fn check_tag(tag: *u8) -> u64 {
    /* Expected: ab 6e 47 d4 2c ec 13 bd f5 3a 67 b2 12 57 bd df */
    if tag[0]  != 0xABu8 { return 17u64 }
    if tag[1]  != 0x6Eu8 { return 18u64 }
    if tag[2]  != 0x47u8 { return 19u64 }
    if tag[3]  != 0xD4u8 { return 20u64 }
    if tag[4]  != 0x2Cu8 { return 21u64 }
    if tag[5]  != 0xECu8 { return 22u64 }
    if tag[6]  != 0x13u8 { return 23u64 }
    if tag[7]  != 0xBDu8 { return 24u64 }
    if tag[8]  != 0xF5u8 { return 25u64 }
    if tag[9]  != 0x3Au8 { return 26u64 }
    if tag[10] != 0x67u8 { return 27u64 }
    if tag[11] != 0xB2u8 { return 28u64 }
    if tag[12] != 0x12u8 { return 29u64 }
    if tag[13] != 0x57u8 { return 30u64 }
    if tag[14] != 0xBDu8 { return 31u64 }
    if tag[15] != 0xDFu8 { return 32u64 }
    return 0u64
}

fn main() -> u64 {
    let key   : *u8 = malloc(16u64)
    let nonce : *u8 = malloc(12u64)
    let pt    : *u8 = malloc(16u64)
    let ct    : *u8 = malloc(16u64)
    let tag   : *u8 = malloc(16u64)
    zero_buf(key, 16u64)
    zero_buf(nonce, 12u64)
    zero_buf(pt, 16u64)
    aes_gcm_init(key, nonce, 12u64)
    aes_gcm_seal(pt, 16u64, ct, tag)
    let ct_err : u64 = check_ct(ct)
    if ct_err != 0u64 { return ct_err }
    let tag_err : u64 = check_tag(tag)
    if tag_err != 0u64 { return tag_err }
    free(key)
    free(nonce)
    free(pt)
    free(ct)
    free(tag)
    return 99u64
}
