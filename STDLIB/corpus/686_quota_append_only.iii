/* 686_quota_append_only.iii -- M29 keystone: the sandbox quota is APPEND-ONLY + un-gameable.
 * There is NO release path, so an adversary cannot alloc-free-alloc to slip past the budget
 * (the use-after-quota attack; apotheosis M29 Key Move illegal move = "offers a release path").
 * 166 gates one over-cap refusal but never proves the budget ACCUMULATES across successful
 * allocs (the append-only essence).  This KAT, on a 4096-byte cap: successive allocs ACCUMULATE
 * (mem_used grows monotonically 0->1500->3000->4000), an alloc that would exceed is REFUSED with
 * mem_used UNCHANGED, and -- the use-after-quota proof -- once 4000 is spent it CANNOT be
 * reclaimed (no release call exists), so every further over-remaining alloc stays refused.
 * Exit 99 = all hold; 1..N = the failing check.  CORPUS-ONLY (sandbox_quota is complete). */
module corpus_686

extern @abi(c-msvc-x64) fn sandbox_clear_all() -> i32 from "sandbox_ctor.iii"
extern @abi(c-msvc-x64) fn sandbox_quota_clear_all() -> i32 from "sandbox_quota.iii"
extern @abi(c-msvc-x64) fn sandbox_exec_clear_all() -> i32 from "sandbox_exec.iii"
extern @abi(c-msvc-x64) fn sandbox_new(cap_set: u64, mem_cap_bytes: u64, cpu_cap_micros: u64) -> u64 from "sandbox_ctor.iii"
extern @abi(c-msvc-x64) fn sandbox_exec_begin(sb_id: u64, kind: u32, ctx: u64) -> i32 from "sandbox_exec.iii"
extern @abi(c-msvc-x64) fn sandbox_quota_record_alloc(sb_id: u64, n_bytes: u64) -> u8 from "sandbox_quota.iii"
extern @abi(c-msvc-x64) fn sandbox_quota_mem_used(sb_id: u64) -> u64 from "sandbox_quota.iii"

fn main() -> u64 {
    sandbox_clear_all()
    sandbox_quota_clear_all()
    sandbox_exec_clear_all()
    let sb : u64 = sandbox_new(0x1u64, 4096u64, 1000000u64)
    if sb == 0u64 { return 1u64 }
    if sandbox_exec_begin(sb, 1u32, 0u64) != 0i32 { return 2u64 }
    if sandbox_quota_mem_used(sb) != 0u64 { return 3u64 }

    /* accumulation: successive allocs SUM (append-only, monotonic) */
    if sandbox_quota_record_alloc(sb, 1500u64) != 1u8 { return 4u64 }
    if sandbox_quota_mem_used(sb) != 1500u64 { return 5u64 }
    if sandbox_quota_record_alloc(sb, 1500u64) != 1u8 { return 6u64 }
    if sandbox_quota_mem_used(sb) != 3000u64 { return 7u64 }   /* accumulated, not reset */

    /* an alloc that would exceed (3000+1500=4500 > 4096) is REFUSED; mem_used UNCHANGED */
    if sandbox_quota_record_alloc(sb, 1500u64) != 0u8 { return 8u64 }
    if sandbox_quota_mem_used(sb) != 3000u64 { return 9u64 }

    /* a smaller alloc within the remaining 1096 still admits (exact budget, not all-or-nothing) */
    if sandbox_quota_record_alloc(sb, 1000u64) != 1u8 { return 10u64 }
    if sandbox_quota_mem_used(sb) != 4000u64 { return 11u64 }

    /* the use-after-quota proof: the 4000 spent CANNOT be reclaimed (no release call), so a
     * second 1000 (5000 > 4096) stays refused, and even a 200 (4200 > 4096) stays refused. */
    if sandbox_quota_record_alloc(sb, 1000u64) != 0u8 { return 12u64 }
    if sandbox_quota_mem_used(sb) != 4000u64 { return 13u64 }
    if sandbox_quota_record_alloc(sb, 200u64) != 0u8 { return 14u64 }
    if sandbox_quota_mem_used(sb) != 4000u64 { return 15u64 }

    return 99u64
}
