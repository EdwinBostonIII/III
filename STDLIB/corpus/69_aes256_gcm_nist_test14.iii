/* AES-256-GCM seal: NIST SP 800-38D Test Case 14.
 *   K  = 00 * 32
 *   IV = 00 * 12
 *   P  = 00 * 16
 *   A  = empty
 *   C  = cea7403d4d606b6e074ec5d3baf39d18
 *   T  = d0d1c8a799996bf0265b98b5d48ab919
 *
 * Verify ciphertext + tag.  Then round-trip via open.  Exit = 99 on success.
 */
module corpus_69

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn aes_gcm_init_256(key: *u8, nonce: *u8, nonce_len: u64) -> i32 from "aes_gcm.iii"
extern @abi(c-msvc-x64) fn aes_gcm_seal(pt: *u8, pt_len: u64, ct_out: *u8, tag_out: *u8) -> i32 from "aes_gcm.iii"
extern @abi(c-msvc-x64) fn aes_gcm_open(ct: *u8, ct_len: u64, pt_out: *u8, tag_in: *u8) -> u8 from "aes_gcm.iii"

fn zero_buf(p: *u8, n: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < n {
        p[i] = 0u8
        i = i + 1u64
    }
    return 0i32
}

fn check_ct(ct: *u8) -> u64 {
    /* Expected: ce a7 40 3d 4d 60 6b 6e 07 4e c5 d3 ba f3 9d 18 */
    if ct[0]  != 0xCEu8 { return 1u64 }
    if ct[1]  != 0xA7u8 { return 2u64 }
    if ct[2]  != 0x40u8 { return 3u64 }
    if ct[3]  != 0x3Du8 { return 4u64 }
    if ct[4]  != 0x4Du8 { return 5u64 }
    if ct[5]  != 0x60u8 { return 6u64 }
    if ct[6]  != 0x6Bu8 { return 7u64 }
    if ct[7]  != 0x6Eu8 { return 8u64 }
    if ct[8]  != 0x07u8 { return 9u64 }
    if ct[9]  != 0x4Eu8 { return 10u64 }
    if ct[10] != 0xC5u8 { return 11u64 }
    if ct[11] != 0xD3u8 { return 12u64 }
    if ct[12] != 0xBAu8 { return 13u64 }
    if ct[13] != 0xF3u8 { return 14u64 }
    if ct[14] != 0x9Du8 { return 15u64 }
    if ct[15] != 0x18u8 { return 16u64 }
    return 0u64
}

fn check_tag(tag: *u8) -> u64 {
    /* Expected: d0 d1 c8 a7 99 99 6b f0 26 5b 98 b5 d4 8a b9 19 */
    if tag[0]  != 0xD0u8 { return 17u64 }
    if tag[1]  != 0xD1u8 { return 18u64 }
    if tag[2]  != 0xC8u8 { return 19u64 }
    if tag[3]  != 0xA7u8 { return 20u64 }
    if tag[4]  != 0x99u8 { return 21u64 }
    if tag[5]  != 0x99u8 { return 22u64 }
    if tag[6]  != 0x6Bu8 { return 23u64 }
    if tag[7]  != 0xF0u8 { return 24u64 }
    if tag[8]  != 0x26u8 { return 25u64 }
    if tag[9]  != 0x5Bu8 { return 26u64 }
    if tag[10] != 0x98u8 { return 27u64 }
    if tag[11] != 0xB5u8 { return 28u64 }
    if tag[12] != 0xD4u8 { return 29u64 }
    if tag[13] != 0x8Au8 { return 30u64 }
    if tag[14] != 0xB9u8 { return 31u64 }
    if tag[15] != 0x19u8 { return 32u64 }
    return 0u64
}

fn main() -> u64 {
    let key   : *u8 = malloc(32u64)
    let nonce : *u8 = malloc(12u64)
    let pt    : *u8 = malloc(16u64)
    let ct    : *u8 = malloc(16u64)
    let tag   : *u8 = malloc(16u64)
    let pt2   : *u8 = malloc(16u64)
    zero_buf(key, 32u64)
    zero_buf(nonce, 12u64)
    zero_buf(pt, 16u64)
    /* Seal */
    aes_gcm_init_256(key, nonce, 12u64)
    aes_gcm_seal(pt, 16u64, ct, tag)
    let ct_err : u64 = check_ct(ct)
    if ct_err != 0u64 { return ct_err }
    let tag_err : u64 = check_tag(tag)
    if tag_err != 0u64 { return tag_err }
    /* Round-trip via open */
    aes_gcm_init_256(key, nonce, 12u64)
    let ok : u8 = aes_gcm_open(ct, 16u64, pt2, tag)
    if ok != 1u8 { return 50u64 }
    let mut i : u64 = 0u64
    while i < 16u64 {
        if pt2[i] != pt[i] { return 60u64 + i }
        i = i + 1u64
    }
    /* Tamper-detection: flip a tag bit, expect open to reject */
    tag[0] = (tag[0] as u32 ^ 1u32) as u8
    aes_gcm_init_256(key, nonce, 12u64)
    let ok_bad : u8 = aes_gcm_open(ct, 16u64, pt2, tag)
    if ok_bad != 0u8 { return 80u64 }
    free(key); free(nonce); free(pt); free(ct); free(tag); free(pt2)
    return 99u64
}
