/* ChaCha20-Poly1305 AEAD KAT: RFC 8439 §2.8.2.
 *
 *   key = 80 81 82 ... 9F  (32 bytes ascending from 0x80)
 *   nonce = 07 00 00 00 40 41 42 43 44 45 46 47
 *   aad = 50 51 52 53 C0 C1 C2 C3 C4 C5 C6 C7
 *   plaintext = "Ladies and Gentlemen ... sunscreen would be it." (114 bytes)
 *
 *   expected ct[0]   = 0xD3
 *   expected ct[113] = 0x16
 *   expected tag = 1A:E1:0B:59:4F:09:E2:6A:7E:90:2E:CB:D0:60:06:91
 *
 * Plus round-trip via open and tampering rejection.  Exit = 99 on success.
 */
module corpus_72

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn aead_chacha20_poly1305_init(key: *u8, nonce: *u8) -> i32 from "chacha20_poly1305.iii"
extern @abi(c-msvc-x64) fn aead_chacha20_poly1305_aad(aad: *u8, aad_len: u64) -> i32 from "chacha20_poly1305.iii"
extern @abi(c-msvc-x64) fn aead_chacha20_poly1305_seal(pt: *u8, pt_len: u64, ct_out: *u8, tag_out: *u8) -> i32 from "chacha20_poly1305.iii"
extern @abi(c-msvc-x64) fn aead_chacha20_poly1305_open(ct: *u8, ct_len: u64, pt_out: *u8, tag_in: *u8) -> u8 from "chacha20_poly1305.iii"

fn fill_key(k: *u8) -> i32 {
    let mut i : u64 = 0u64
    while i < 32u64 {
        k[i] = (i + 0x80u64) as u8
        i = i + 1u64
    }
    return 0i32
}

fn fill_nonce(n: *u8) -> i32 {
    n[0]  = 0x07u8; n[1]  = 0x00u8; n[2]  = 0x00u8; n[3]  = 0x00u8
    n[4]  = 0x40u8; n[5]  = 0x41u8; n[6]  = 0x42u8; n[7]  = 0x43u8
    n[8]  = 0x44u8; n[9]  = 0x45u8; n[10] = 0x46u8; n[11] = 0x47u8
    return 0i32
}

fn fill_aad(a: *u8) -> i32 {
    a[0]  = 0x50u8; a[1]  = 0x51u8; a[2]  = 0x52u8; a[3]  = 0x53u8
    a[4]  = 0xC0u8; a[5]  = 0xC1u8; a[6]  = 0xC2u8; a[7]  = 0xC3u8
    a[8]  = 0xC4u8; a[9]  = 0xC5u8; a[10] = 0xC6u8; a[11] = 0xC7u8
    return 0i32
}

/* "Ladies and Gentlemen of the class of '99: If I could offer you only one tip for the future, sunscreen would be it." */
fn fill_pt(p: *u8) -> i32 {
    p[0]   = 76u8;  p[1]   = 97u8;  p[2]   = 100u8; p[3]   = 105u8
    p[4]   = 101u8; p[5]   = 115u8; p[6]   = 32u8;  p[7]   = 97u8
    p[8]   = 110u8; p[9]   = 100u8; p[10]  = 32u8;  p[11]  = 71u8
    p[12]  = 101u8; p[13]  = 110u8; p[14]  = 116u8; p[15]  = 108u8
    p[16]  = 101u8; p[17]  = 109u8; p[18]  = 101u8; p[19]  = 110u8
    p[20]  = 32u8;  p[21]  = 111u8; p[22]  = 102u8; p[23]  = 32u8
    p[24]  = 116u8; p[25]  = 104u8; p[26]  = 101u8; p[27]  = 32u8
    p[28]  = 99u8;  p[29]  = 108u8; p[30]  = 97u8;  p[31]  = 115u8
    p[32]  = 115u8; p[33]  = 32u8;  p[34]  = 111u8; p[35]  = 102u8
    p[36]  = 32u8;  p[37]  = 39u8;  p[38]  = 57u8;  p[39]  = 57u8
    p[40]  = 58u8;  p[41]  = 32u8;  p[42]  = 73u8;  p[43]  = 102u8
    p[44]  = 32u8;  p[45]  = 73u8;  p[46]  = 32u8;  p[47]  = 99u8
    p[48]  = 111u8; p[49]  = 117u8; p[50]  = 108u8; p[51]  = 100u8
    p[52]  = 32u8;  p[53]  = 111u8; p[54]  = 102u8; p[55]  = 102u8
    p[56]  = 101u8; p[57]  = 114u8; p[58]  = 32u8;  p[59]  = 121u8
    p[60]  = 111u8; p[61]  = 117u8; p[62]  = 32u8;  p[63]  = 111u8
    p[64]  = 110u8; p[65]  = 108u8; p[66]  = 121u8; p[67]  = 32u8
    p[68]  = 111u8; p[69]  = 110u8; p[70]  = 101u8; p[71]  = 32u8
    p[72]  = 116u8; p[73]  = 105u8; p[74]  = 112u8; p[75]  = 32u8
    p[76]  = 102u8; p[77]  = 111u8; p[78]  = 114u8; p[79]  = 32u8
    p[80]  = 116u8; p[81]  = 104u8; p[82]  = 101u8; p[83]  = 32u8
    p[84]  = 102u8; p[85]  = 117u8; p[86]  = 116u8; p[87]  = 117u8
    p[88]  = 114u8; p[89]  = 101u8; p[90]  = 44u8;  p[91]  = 32u8
    p[92]  = 115u8; p[93]  = 117u8; p[94]  = 110u8; p[95]  = 115u8
    p[96]  = 99u8;  p[97]  = 114u8; p[98]  = 101u8; p[99]  = 101u8
    p[100] = 110u8; p[101] = 32u8;  p[102] = 119u8; p[103] = 111u8
    p[104] = 117u8; p[105] = 108u8; p[106] = 100u8; p[107] = 32u8
    p[108] = 98u8;  p[109] = 101u8; p[110] = 32u8;  p[111] = 105u8
    p[112] = 116u8; p[113] = 46u8
    return 0i32
}

fn check_ct_anchors(ct: *u8) -> u64 {
    if ct[0]   != 0xD3u8 { return 1u64 }
    if ct[1]   != 0x1Au8 { return 2u64 }
    if ct[2]   != 0x8Du8 { return 3u64 }
    if ct[3]   != 0x34u8 { return 4u64 }
    if ct[4]   != 0x64u8 { return 5u64 }
    if ct[5]   != 0x8Eu8 { return 6u64 }
    if ct[6]   != 0x60u8 { return 7u64 }
    if ct[7]   != 0xDBu8 { return 8u64 }
    if ct[61]  != 0xCDu8 { return 9u64 }
    if ct[63]  != 0x36u8 { return 90u64 }
    if ct[112] != 0x61u8 { return 10u64 }
    if ct[113] != 0x16u8 { return 11u64 }
    return 0u64
}

fn check_tag(tag: *u8) -> u64 {
    /* 1A E1 0B 59 4F 09 E2 6A 7E 90 2E CB D0 60 06 91 */
    if tag[0]  != 0x1Au8 { return 12u64 }
    if tag[1]  != 0xE1u8 { return 13u64 }
    if tag[2]  != 0x0Bu8 { return 14u64 }
    if tag[3]  != 0x59u8 { return 15u64 }
    if tag[4]  != 0x4Fu8 { return 16u64 }
    if tag[5]  != 0x09u8 { return 17u64 }
    if tag[6]  != 0xE2u8 { return 18u64 }
    if tag[7]  != 0x6Au8 { return 19u64 }
    if tag[8]  != 0x7Eu8 { return 20u64 }
    if tag[9]  != 0x90u8 { return 21u64 }
    if tag[10] != 0x2Eu8 { return 22u64 }
    if tag[11] != 0xCBu8 { return 23u64 }
    if tag[12] != 0xD0u8 { return 24u64 }
    if tag[13] != 0x60u8 { return 25u64 }
    if tag[14] != 0x06u8 { return 26u64 }
    if tag[15] != 0x91u8 { return 27u64 }
    return 0u64
}

fn main() -> u64 {
    let key   : *u8 = malloc(32u64)
    let nonce : *u8 = malloc(12u64)
    let aad   : *u8 = malloc(12u64)
    let pt    : *u8 = malloc(114u64)
    let ct    : *u8 = malloc(114u64)
    let tag   : *u8 = malloc(16u64)
    let pt2   : *u8 = malloc(114u64)
    fill_key(key)
    fill_nonce(nonce)
    fill_aad(aad)
    fill_pt(pt)
    /* Seal */
    aead_chacha20_poly1305_init(key, nonce)
    aead_chacha20_poly1305_aad(aad, 12u64)
    aead_chacha20_poly1305_seal(pt, 114u64, ct, tag)
    let ct_err : u64 = check_ct_anchors(ct)
    if ct_err != 0u64 { return ct_err }
    let tag_err : u64 = check_tag(tag)
    if tag_err != 0u64 { return tag_err }
    /* Round-trip via open. */
    aead_chacha20_poly1305_init(key, nonce)
    aead_chacha20_poly1305_aad(aad, 12u64)
    let ok : u8 = aead_chacha20_poly1305_open(ct, 114u64, pt2, tag)
    if ok != 1u8 { return 30u64 }
    let mut i : u64 = 0u64
    while i < 114u64 {
        if pt2[i] != pt[i] { return 40u64 + i }
        i = i + 1u64
    }
    /* Tampering rejection: flip a tag bit. */
    tag[0] = (tag[0] as u32 ^ 1u32) as u8
    aead_chacha20_poly1305_init(key, nonce)
    aead_chacha20_poly1305_aad(aad, 12u64)
    let ok_bad : u8 = aead_chacha20_poly1305_open(ct, 114u64, pt2, tag)
    if ok_bad != 0u8 { return 200u64 }
    free(key); free(nonce); free(aad); free(pt); free(ct); free(tag); free(pt2)
    return 99u64
}
