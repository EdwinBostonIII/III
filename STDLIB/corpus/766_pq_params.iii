/* APOTHEOSIS C.1: pq_params descriptor table — O(1) suite lookup retiring the
 * nibble-arithmetic decode (E-PQD-2).
 *
 * Arms:
 *   positive  -- the 9 FIPS suites map to the right rows + field values
 *   E-PQD-2   -- suite 0x0100 (low nibble 0) returns PQP_NONE, NOT a
 *                u64::MAX underflow (the old (nibble-1) hazard is GONE)
 *   negative  -- an unrouted suite id returns PQP_NONE
 */
module corpus_c766

extern @abi(c-msvc-x64) fn pq_params_for(suite_id: u64) -> u64 from "pq_params.iii"
extern @abi(c-msvc-x64) fn pq_params_count() -> u64 from "pq_params.iii"
extern @abi(c-msvc-x64) fn pq_params_scheme(row: u64) -> u64 from "pq_params.iii"
extern @abi(c-msvc-x64) fn pq_params_selector(row: u64) -> u64 from "pq_params.iii"
extern @abi(c-msvc-x64) fn pq_params_n(row: u64) -> u64 from "pq_params.iii"
extern @abi(c-msvc-x64) fn pq_params_q(row: u64) -> u64 from "pq_params.iii"
extern @abi(c-msvc-x64) fn pq_params_k(row: u64) -> u64 from "pq_params.iii"
extern @abi(c-msvc-x64) fn pq_params_l(row: u64) -> u64 from "pq_params.iii"
extern @abi(c-msvc-x64) fn pq_params_eta(row: u64) -> u64 from "pq_params.iii"
extern @abi(c-msvc-x64) fn pq_params_du(row: u64) -> u64 from "pq_params.iii"
extern @abi(c-msvc-x64) fn pq_params_dv(row: u64) -> u64 from "pq_params.iii"

fn main() -> u64 {
    let NONE : u64 = 0xFFFFFFFFFFFFFFFFu64

    if pq_params_count() != 9u64 { return 1u64 }

    /* ML-KEM-512 (0x0101): KEM(1), k=2, n=256, q=3329, eta1=3, du=10, dv=4 */
    let r0 : u64 = pq_params_for(0x0101u64)
    if r0 != 0u64 { return 2u64 }
    if pq_params_scheme(r0)   != 1u64 { return 3u64 }
    if pq_params_selector(r0) != 2u64 { return 4u64 }
    if pq_params_n(r0)  != 256u64  { return 5u64 }
    if pq_params_q(r0)  != 3329u64 { return 6u64 }
    if pq_params_k(r0)  != 2u64    { return 7u64 }
    if pq_params_eta(r0) != 3u64   { return 8u64 }
    if pq_params_du(r0) != 10u64   { return 9u64 }
    if pq_params_dv(r0) != 4u64    { return 10u64 }

    /* ML-KEM-1024 (0x0103): k=4, du=11, dv=5 */
    let r2 : u64 = pq_params_for(0x0103u64)
    if r2 != 2u64 { return 11u64 }
    if pq_params_k(r2) != 4u64  { return 12u64 }
    if pq_params_du(r2) != 11u64 { return 13u64 }
    if pq_params_dv(r2) != 5u64  { return 14u64 }

    /* ML-DSA-87 (0x0113): DSA(2), level=5, q=8380417, k=8, l=7, eta=2 */
    let r5 : u64 = pq_params_for(0x0113u64)
    if r5 != 5u64 { return 15u64 }
    if pq_params_scheme(r5)   != 2u64 { return 16u64 }
    if pq_params_selector(r5) != 5u64 { return 17u64 }
    if pq_params_q(r5) != 8380417u64 { return 18u64 }
    if pq_params_k(r5) != 8u64 { return 19u64 }
    if pq_params_l(r5) != 7u64 { return 20u64 }

    /* SLH-DSA-256s (0x0123): SLH(3), lv=2, n=32 */
    let r8 : u64 = pq_params_for(0x0123u64)
    if r8 != 8u64 { return 21u64 }
    if pq_params_scheme(r8)   != 3u64 { return 22u64 }
    if pq_params_selector(r8) != 2u64 { return 23u64 }
    if pq_params_n(r8) != 32u64 { return 24u64 }
    if pq_params_q(r8) != 0u64  { return 25u64 }

    /* E-PQD-2 falsifier: suite 0x0100 has low nibble 0; the OLD pq_slh_lv did
     * (0 - 1) -> u64::MAX.  The descriptor returns PQP_NONE -- no underflow. */
    if pq_params_for(0x0100u64) != NONE { return 26u64 }
    /* unrouted ids -> NONE */
    if pq_params_for(0x0199u64) != NONE { return 27u64 }
    if pq_params_for(0u64)      != NONE { return 28u64 }
    if pq_params_for(0x0114u64) != NONE { return 29u64 }   /* nibble 4, out of 1..3 */

    return 99u64
}
