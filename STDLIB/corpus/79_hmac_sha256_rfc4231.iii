/* HMAC-SHA256 KAT: RFC 4231 Test Case 1 -- now the FULL 32-byte tag.
 *   key = 0x0b * 20 ; msg = "Hi There"
 *   tag = b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7
 *
 * W42 strengthen: the prior version asserted only 9 of 32 tag bytes (0-5,15,16,31), so a
 * bug in bytes 6-14 / 17-30 would pass.  Now every byte is checked against the published
 * RFC 4231 vector.  Exit = first byte of tag = 0xB0 = 176 (EXPECTED unchanged).
 */
module corpus_79

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn hmac_sha256(key: *u8, key_len: u64, msg: *u8, msg_len: u64) -> i32 from "hmac.iii"
extern @abi(c-msvc-x64) fn hmac_sha256_tag(out_32: *u8) -> i32 from "hmac.iii"

var EXP : [u8; 32]

fn main() -> u64 {
    /* RFC 4231 TC1 expected HMAC-SHA256 tag (all 32 bytes) */
    EXP[0u64]=0xB0u8  EXP[1u64]=0x34u8  EXP[2u64]=0x4Cu8  EXP[3u64]=0x61u8
    EXP[4u64]=0xD8u8  EXP[5u64]=0xDBu8  EXP[6u64]=0x38u8  EXP[7u64]=0x53u8
    EXP[8u64]=0x5Cu8  EXP[9u64]=0xA8u8  EXP[10u64]=0xAFu8 EXP[11u64]=0xCEu8
    EXP[12u64]=0xAFu8 EXP[13u64]=0x0Bu8 EXP[14u64]=0xF1u8 EXP[15u64]=0x2Bu8
    EXP[16u64]=0x88u8 EXP[17u64]=0x1Du8 EXP[18u64]=0xC2u8 EXP[19u64]=0x00u8
    EXP[20u64]=0xC9u8 EXP[21u64]=0x83u8 EXP[22u64]=0x3Du8 EXP[23u64]=0xA7u8
    EXP[24u64]=0x26u8 EXP[25u64]=0xE9u8 EXP[26u64]=0x37u8 EXP[27u64]=0x6Cu8
    EXP[28u64]=0x2Eu8 EXP[29u64]=0x32u8 EXP[30u64]=0xCFu8 EXP[31u64]=0xF7u8

    let key : *u8 = malloc(20u64)
    let msg : *u8 = malloc(8u64)
    let tag : *u8 = malloc(32u64)
    let mut i : u64 = 0u64
    while i < 20u64 { key[i] = 0x0Bu8; i = i + 1u64 }
    msg[0] = 72u8;  msg[1] = 105u8; msg[2] = 32u8;  msg[3] = 84u8
    msg[4] = 104u8; msg[5] = 101u8; msg[6] = 114u8; msg[7] = 101u8
    hmac_sha256(key, 20u64, msg, 8u64)
    hmac_sha256_tag(tag)

    let mut j : u64 = 0u64
    while j < 32u64 { if tag[j] != EXP[j] { return 20u64 + j }  j = j + 1u64 }   /* full-tag verify */

    let result : u64 = tag[0] as u64
    free(key); free(msg); free(tag)
    return result
}
