/* 804 -- nous Phase 3: the deterministic integer proposer.  Drives the three faculty
 * selftests (features, policy, value) and then the POLICY KEYSTONE: under the real
 * kind-aware policy (order mode 2, which for a trit term tries the trit rules FIRST --
 * a different order than the fixed cascade), the canonical normal form is UNCHANGED
 * (active=0 cascade NF == active=1 policy NF) over the full 3x3 trit domain.  This is
 * the keystone under the real ranker: a different proposal order changed no answer
 * (confluence over the certified set).  The negative arm (a type-illegal / non-certified
 * rule is never proposed) is the full-permutation check inside nous_policy_selftest.
 * Exit 99 = all hold; 1..6 = the failing check. */
module corpus_804

extern @abi(c-msvc-x64) fn nous_features_selftest() -> u64 from "nous_features.iii"
extern @abi(c-msvc-x64) fn nous_policy_selftest() -> u64 from "nous_policy.iii"
extern @abi(c-msvc-x64) fn nous_value_selftest() -> u64 from "nous_value.iii"
extern @abi(c-msvc-x64) fn nous_set_active(flag: u8) -> i32 from "nous_socket.iii"
extern @abi(c-msvc-x64) fn nous_set_order_mode(mode: u8) -> i32 from "nous_socket.iii"
extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_fusion2(kind: u8, a: u32, b: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_canonicalise(t: u32) -> u32 from "xii_canonicalise.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_struct_eq(a: u32, b: u32) -> u8 from "xii_rewrite.iii"

const C804_TRIT_VAL : u8 = 24u8
const C804_TRIT_AND : u8 = 26u8
const C804_TRIT_OR  : u8 = 27u8
const C804_TRIT_SUM : u8 = 28u8

fn c804_mkval(v: i32) -> u32 { return xii_term_make_basis(C804_TRIT_VAL, (v + 1i32) as u32) }

/* Canonicalise op(a,b) under the fixed cascade (active=0) and under the real policy
 * (active=1, order mode 2), compare the normal forms.  Returns 1 iff equal. */
fn c804_policy_keystone(opk: u8, a: i32, b: i32) -> u8 {
    nous_set_order_mode(2u8)
    xii_term_arena_reset()
    let t0 : u32 = xii_term_make_fusion2(opk, c804_mkval(a), c804_mkval(b))
    let t1 : u32 = xii_term_make_fusion2(opk, c804_mkval(a), c804_mkval(b))
    nous_set_active(0u8)
    let r0 : u32 = xii_canonicalise(t0)
    nous_set_active(1u8)
    let r1 : u32 = xii_canonicalise(t1)
    nous_set_active(0u8)
    nous_set_order_mode(0u8)
    return xii_rewrite_struct_eq(r0, r1)
}

fn main() -> u64 {
    if nous_features_selftest() != 99u64 { return 1u64 }
    if nous_policy_selftest() != 99u64 { return 2u64 }
    if nous_value_selftest() != 99u64 { return 3u64 }

    let mut ia : u64 = 0u64
    while ia < 3u64 {
        let a : i32 = (ia as i32) - 1i32
        let mut ib : u64 = 0u64
        while ib < 3u64 {
            let b : i32 = (ib as i32) - 1i32
            if c804_policy_keystone(C804_TRIT_AND, a, b) != 1u8 { return 4u64 }
            if c804_policy_keystone(C804_TRIT_OR,  a, b) != 1u8 { return 5u64 }
            if c804_policy_keystone(C804_TRIT_SUM, a, b) != 1u8 { return 6u64 }
            ib = ib + 1u64
        }
        ia = ia + 1u64
    }
    return 99u64
}
