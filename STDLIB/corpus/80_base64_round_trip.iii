/* Base64 round-trip: encode then decode several RFC 4648 example
 * strings, verify recovery byte-for-byte.
 *   "f"      -> "Zg=="
 *   "fo"     -> "Zm8="
 *   "foo"    -> "Zm9v"
 *   "foobar" -> "Zm9vYmFy"
 */
module corpus_80

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn builder_new(arena: u64, hint: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_seal(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_len(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn base64_encode(builder_id: u64, src_base: u64, src_len: u64) -> i32 from "base64.iii"
extern @abi(c-msvc-x64) fn base64_decode(builder_id: u64, src_base: u64, src_len: u64) -> i32 from "base64.iii"

fn main() -> u64 {
    let a : u64 = arena_new(1u64 << 16u64)
    /* "foobar" (6 bytes) -> "Zm9vYmFy" (8 bytes) */
    let src : *u8 = malloc(6u64)
    src[0] = 102u8; src[1] = 111u8; src[2] = 111u8
    src[3] = 98u8;  src[4] = 97u8;  src[5] = 114u8
    let enc_b : u64 = builder_new(a, 32u64)
    base64_encode(enc_b, src as u64, 6u64)
    if builder_len(enc_b) != 8u64 { return 1u64 }
    let enc : *u8 = builder_seal(enc_b) as *u8
    /* Verify "Zm9vYmFy" */
    if enc[0] != 90u8  { return 2u64 }   /* Z */
    if enc[1] != 109u8 { return 3u64 }   /* m */
    if enc[2] != 57u8  { return 4u64 }   /* 9 */
    if enc[3] != 118u8 { return 5u64 }   /* v */
    if enc[4] != 89u8  { return 6u64 }   /* Y */
    if enc[5] != 109u8 { return 7u64 }   /* m */
    if enc[6] != 70u8  { return 8u64 }   /* F */
    if enc[7] != 121u8 { return 9u64 }   /* y */
    /* Decode round-trip */
    let dec_b : u64 = builder_new(a, 32u64)
    base64_decode(dec_b, enc as u64, 8u64)
    if builder_len(dec_b) != 6u64 { return 10u64 }
    let dec : *u8 = builder_seal(dec_b) as *u8
    let mut i : u64 = 0u64
    while i < 6u64 {
        if dec[i] != src[i] { return 20u64 + i }
        i = i + 1u64
    }
    /* Test padding case: "f" -> "Zg==" */
    let src2 : *u8 = malloc(1u64)
    src2[0] = 102u8
    let enc2_b : u64 = builder_new(a, 16u64)
    base64_encode(enc2_b, src2 as u64, 1u64)
    if builder_len(enc2_b) != 4u64 { return 30u64 }
    let enc2 : *u8 = builder_seal(enc2_b) as *u8
    if enc2[0] != 90u8 { return 31u64 }   /* Z */
    if enc2[1] != 103u8 { return 32u64 }  /* g */
    if enc2[2] != 61u8 { return 33u64 }   /* = */
    if enc2[3] != 61u8 { return 34u64 }   /* = */
    /* Decode "Zg==" -> "f" */
    let dec2_b : u64 = builder_new(a, 16u64)
    base64_decode(dec2_b, enc2 as u64, 4u64)
    if builder_len(dec2_b) != 1u64 { return 35u64 }
    let dec2 : *u8 = builder_seal(dec2_b) as *u8
    if dec2[0] != 102u8 { return 36u64 }
    free(src); free(src2)
    arena_drop(a)
    return 99u64
}
