/* HKDF-SHA256 KAT: RFC 5869 Test Case 1.
 *   IKM  = 0x0b * 22
 *   salt = 00 01 02 03 04 05 06 07 08 09 0a 0b 0c
 *   info = f0 f1 f2 f3 f4 f5 f6 f7 f8 f9
 *   L    = 42
 *   OKM  = 3cb25f25faacd57a90434f64d0362f2a2d2d0a90cf1a5a4c5db02d56ecc4c5bf
 *          34007208d5b887185865
 * W45 strengthen: was 9 of 42 bytes -> now the FULL RFC 5869 OKM (dump-verified vs III).
 * Exit = first byte of OKM = 0x3C = 60.
 */
module corpus_81

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn hkdf_sha256_extract(salt: *u8, salt_len: u64, ikm: *u8, ikm_len: u64) -> i32 from "hkdf.iii"
extern @abi(c-msvc-x64) fn hkdf_sha256_expand(info: *u8, info_len: u64, out: *u8, out_len: u64) -> i32 from "hkdf.iii"

var EXP : [u8; 42]

fn main() -> u64 {
    EXP[0u64]=0x3cu8  EXP[1u64]=0xb2u8  EXP[2u64]=0x5fu8  EXP[3u64]=0x25u8
    EXP[4u64]=0xfau8  EXP[5u64]=0xacu8  EXP[6u64]=0xd5u8  EXP[7u64]=0x7au8
    EXP[8u64]=0x90u8  EXP[9u64]=0x43u8  EXP[10u64]=0x4fu8 EXP[11u64]=0x64u8
    EXP[12u64]=0xd0u8 EXP[13u64]=0x36u8 EXP[14u64]=0x2fu8 EXP[15u64]=0x2au8
    EXP[16u64]=0x2du8 EXP[17u64]=0x2du8 EXP[18u64]=0x0au8 EXP[19u64]=0x90u8
    EXP[20u64]=0xcfu8 EXP[21u64]=0x1au8 EXP[22u64]=0x5au8 EXP[23u64]=0x4cu8
    EXP[24u64]=0x5du8 EXP[25u64]=0xb0u8 EXP[26u64]=0x2du8 EXP[27u64]=0x56u8
    EXP[28u64]=0xecu8 EXP[29u64]=0xc4u8 EXP[30u64]=0xc5u8 EXP[31u64]=0xbfu8
    EXP[32u64]=0x34u8 EXP[33u64]=0x00u8 EXP[34u64]=0x72u8 EXP[35u64]=0x08u8
    EXP[36u64]=0xd5u8 EXP[37u64]=0xb8u8 EXP[38u64]=0x87u8 EXP[39u64]=0x18u8
    EXP[40u64]=0x58u8 EXP[41u64]=0x65u8

    let ikm  : *u8 = malloc(22u64)
    let salt : *u8 = malloc(13u64)
    let info : *u8 = malloc(10u64)
    let okm  : *u8 = malloc(42u64)
    let mut i : u64 = 0u64
    while i < 22u64 { ikm[i] = 0x0Bu8; i = i + 1u64 }
    let mut j : u64 = 0u64
    while j < 13u64 { salt[j] = j as u8; j = j + 1u64 }
    let mut k : u64 = 0u64
    while k < 10u64 { info[k] = (0xF0u64 + k) as u8; k = k + 1u64 }
    hkdf_sha256_extract(salt, 13u64, ikm, 22u64)
    hkdf_sha256_expand(info, 10u64, okm, 42u64)

    let mut a : u64 = 0u64
    while a < 42u64 { if okm[a] != EXP[a] { return 1u64 + a }  a = a + 1u64 }

    let result : u64 = okm[0] as u64
    free(ikm); free(salt); free(info); free(okm)
    return result
}
