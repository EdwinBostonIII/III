/* 828_reach_memo.iii -- The Reach, Phase 2: the L0 memo tier + the nearest-first lattice.
 * Proves: emit primes L0 (1); reach serves + round-trips (2); CACHE-FILL-DOWN -- a value present
 * only in L1 (disk) is, after one reach, ALSO in L0 (3); the L0 INTEGRITY TEETH -- a poisoned L0
 * entry (bytes that do not hash to their key) is NEVER returned (reach re-hashes every tier,
 * rejects, falls through to L1, and degrades to GAP) (4); the BOUND -- a value larger than the L0
 * slot is not cached yet stays reachable via L1 (5).  L0 changes only SPEED, never a RESULT.
 * Exit 99 = all hold.  CORPUS-ONLY (backend_memo / reach_core / reach_store / cad / fs complete). */
module corpus_828

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn reach_emit(buf: u64, len: u64, cap: u64, out_addr: u64) -> i32 from "reach_core.iii"
extern @abi(c-msvc-x64) fn reach(addr: u64, cap: u64, out: u64, max: u64, out_len: u64, out_gid: u64) -> i32 from "reach_core.iii"
extern @abi(c-msvc-x64) fn reach_store_put(addr: u64, buf: u64, len: u64, cap: u64) -> i32 from "reach_store.iii"
extern @abi(c-msvc-x64) fn backend_memo_has(addr: u64) -> u8 from "backend_memo.iii"
extern @abi(c-msvc-x64) fn backend_memo_put(addr: u64, buf: u64, len: u64) -> i32 from "backend_memo.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_eq(a: *u8, b: *u8) -> u8 from "cad.iii"
extern @abi(c-msvc-x64) fn fs_delete(cap: u64, path: u64) -> i32 from "fs.iii"

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)

    /* clean the disk store ("iii_reach_store.bin") for a deterministic start */
    let path : *u8 = malloc(24u64)
    path[0] = 105u8
    path[1] = 105u8
    path[2] = 105u8
    path[3] = 95u8
    path[4] = 114u8
    path[5] = 101u8
    path[6] = 97u8
    path[7] = 99u8
    path[8] = 104u8
    path[9] = 95u8
    path[10] = 115u8
    path[11] = 116u8
    path[12] = 111u8
    path[13] = 114u8
    path[14] = 101u8
    path[15] = 46u8
    path[16] = 98u8
    path[17] = 105u8
    path[18] = 110u8
    path[19] = 0u8
    fs_delete(cap, path as u64)

    let out : *u8 = malloc(1024u64)
    let olen_p : *u8 = malloc(8u64)
    let olen : *u64 = olen_p as *u64
    let gid : *u8 = malloc(8u64)
    let tmp : *u8 = malloc(32u64)

    /* (1) emit primes L0 */
    let val : *u8 = malloc(5u64)
    val[0] = 65u8
    val[1] = 66u8
    val[2] = 67u8
    val[3] = 68u8
    val[4] = 69u8
    let addr : *u8 = malloc(32u64)
    if reach_emit(val as u64, 5u64, cap, addr as u64) != 0i32 { return 1u64 }
    if backend_memo_has(addr as u64) != 1u8 { return 1u64 }

    /* (2) reach serves + round-trips (returned value content-addresses to the requested address) */
    if reach(addr as u64, cap, out as u64, 1024u64, olen as u64, gid as u64) != 0i32 { return 2u64 }
    cad_oneshot(0u32, out, olen[0], tmp)
    if cad_eq(tmp, addr) != 1u8 { return 2u64 }

    /* (3) CACHE-FILL-DOWN: a value placed only in L1 is, after one reach, also in L0 */
    let valb : *u8 = malloc(6u64)
    valb[0] = 49u8
    valb[1] = 50u8
    valb[2] = 51u8
    valb[3] = 52u8
    valb[4] = 53u8
    valb[5] = 54u8
    let a2 : *u8 = malloc(32u64)
    cad_oneshot(0u32, valb, 6u64, a2)
    if reach_store_put(a2 as u64, valb as u64, 6u64, cap) != 0i32 { return 3u64 }
    if backend_memo_has(a2 as u64) != 0u8 { return 3u64 }
    if reach(a2 as u64, cap, out as u64, 1024u64, olen as u64, gid as u64) != 0i32 { return 3u64 }
    if backend_memo_has(a2 as u64) != 1u8 { return 3u64 }

    /* (4) L0 INTEGRITY TEETH: poison L0 with bytes that do not hash to their key; reach must NOT
     * return them (re-hash rejects -> fall through to L1 -> miss -> GAP), and leak no length. */
    let valc : *u8 = malloc(4u64)
    valc[0] = 7u8
    valc[1] = 7u8
    valc[2] = 7u8
    valc[3] = 7u8
    let a3 : *u8 = malloc(32u64)
    cad_oneshot(0u32, valc, 4u64, a3)
    let vald : *u8 = malloc(4u64)
    vald[0] = 8u8
    vald[1] = 8u8
    vald[2] = 8u8
    vald[3] = 8u8
    backend_memo_put(a3 as u64, vald as u64, 4u64)
    let rc4 : i32 = reach(a3 as u64, cap, out as u64, 1024u64, olen as u64, gid as u64)
    if rc4 == 0i32 { return 4u64 }
    if olen[0] != 0u64 { return 4u64 }

    /* (5) BOUND: a value larger than the L0 slot is not cached, but stays reachable via L1 */
    let big : *u8 = malloc(700u64)
    let mut k : u64 = 0u64
    while k < 600u64 {
        big[k] = (k & 0xFFu64) as u8
        k = k + 1u64
    }
    let abig : *u8 = malloc(32u64)
    if reach_emit(big as u64, 600u64, cap, abig as u64) != 0i32 { return 5u64 }
    if backend_memo_has(abig as u64) != 0u8 { return 5u64 }
    if reach(abig as u64, cap, out as u64, 1024u64, olen as u64, gid as u64) != 0i32 { return 5u64 }
    if olen[0] != 600u64 { return 5u64 }

    fs_delete(cap, path as u64)
    free(path)
    free(out)
    free(olen_p)
    free(gid)
    free(tmp)
    free(val)
    free(addr)
    free(valb)
    free(a2)
    free(valc)
    free(a3)
    free(vald)
    free(big)
    free(abig)
    return 99u64
}
