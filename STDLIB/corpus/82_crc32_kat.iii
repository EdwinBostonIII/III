/* CRC-32 KAT: standard "123456789" test string -> 0xCBF43926.
 * Exit = first byte = 0xCB = 203.
 *
 * Also verify the empty-string CRC = 0x00000000.
 */
module corpus_82

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn crc32_oneshot(data: *u8, len: u64) -> u32 from "crc32.iii"

fn main() -> u64 {
    let s : *u8 = malloc(9u64)
    s[0] = 49u8; s[1] = 50u8; s[2] = 51u8; s[3] = 52u8; s[4] = 53u8
    s[5] = 54u8; s[6] = 55u8; s[7] = 56u8; s[8] = 57u8
    let crc : u32 = crc32_oneshot(s, 9u64)
    /* Expected CRC = 0xCBF43926 */
    if crc != 0xCBF43926u32 { return 1u64 }
    /* Empty string */
    let empty : *u8 = malloc(1u64)
    let crc_empty : u32 = crc32_oneshot(empty, 0u64)
    if crc_empty != 0u32 { return 2u64 }
    let result : u64 = ((crc >> 24u32) & 0xFFu32) as u64
    free(s); free(empty)
    return result
}
