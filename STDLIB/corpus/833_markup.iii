/* 833_markup.iii -- verba::markup, the HTML ingestion front of "the web as knowledge".
 * Proves the tokenizer end to end with POSITIVE and prove-the-gate NEGATIVE arms:
 *   (K1) a simple element round-trips: OPEN/TAG_END/TEXT/CLOSE with correct slices;
 *   (K2) attributes: quoted, unquoted, and the value-less/equals forms all tokenize;
 *   (K3) a void/self-closing tag sets the self-close flag (TAG_END.len==1);
 *   (K4, negative) a comment CONTAINING '>' is skipped whole -- '>' does not end it;
 *   (K5) <script> rawtext: a '<' INSIDE the script is TEXT, not a tag;
 *   (K7, negative) </div> inside <script> stays TEXT -- only a NAME-matched </script>
 *        closes (the rawtext end gate is a name match, not "any </");
 *   (K6, the BOUND) a too-small token buffer returns MK_OVERFLOW, never a silent
 *        truncation that would look like success.
 * Exit 99 = all hold.  CORPUS-ONLY (verba/markup is pure -- no IO). */
module corpus_833

extern @abi(c-msvc-x64) fn markup_tokenize(src: u64, len: u64, toks: u64, max_toks: u32) -> u32 from "markup.iii"
extern @abi(c-msvc-x64) fn markup_tok_kind(toks: u64, idx: u32) -> u32 from "markup.iii"
extern @abi(c-msvc-x64) fn markup_tok_off(toks: u64, idx: u32) -> u32 from "markup.iii"
extern @abi(c-msvc-x64) fn markup_tok_len(toks: u64, idx: u32) -> u32 from "markup.iii"

/* token kinds (mirror verba/markup) */
const K_TEXT : u32 = 0u32
const K_OPEN : u32 = 1u32
const K_CLOS : u32 = 2u32
const K_ANAM : u32 = 3u32
const K_AVAL : u32 = 4u32
const K_TEND : u32 = 5u32

var TOKS : [u8; 1200]

var H1 : [u8; 9]  = [60u8, 112u8, 62u8, 104u8, 105u8, 60u8, 47u8, 112u8, 62u8]                                                                                    /* <p>hi</p> */
var H2 : [u8; 17] = [60u8, 97u8, 32u8, 104u8, 114u8, 101u8, 102u8, 61u8, 34u8, 120u8, 34u8, 32u8, 105u8, 100u8, 61u8, 121u8, 62u8]                                /* <a href="x" id=y> */
var H3 : [u8; 5]  = [60u8, 98u8, 114u8, 47u8, 62u8]                                                                                                               /* <br/> */
var H4 : [u8; 15] = [60u8, 33u8, 45u8, 45u8, 32u8, 97u8, 32u8, 62u8, 32u8, 98u8, 32u8, 45u8, 45u8, 62u8, 116u8]                                                   /* <!-- a > b -->t */
var H5 : [u8; 27] = [60u8, 115u8, 99u8, 114u8, 105u8, 112u8, 116u8, 62u8, 105u8, 102u8, 40u8, 97u8, 60u8, 98u8, 41u8, 123u8, 125u8, 60u8, 47u8, 115u8, 99u8, 114u8, 105u8, 112u8, 116u8, 62u8, 120u8]   /* <script>if(a<b){}</script>x */
var H7 : [u8; 23] = [60u8, 115u8, 99u8, 114u8, 105u8, 112u8, 116u8, 62u8, 60u8, 47u8, 100u8, 105u8, 118u8, 62u8, 60u8, 47u8, 115u8, 99u8, 114u8, 105u8, 112u8, 116u8, 62u8]                              /* <script></div></script> */

fn main() -> u64 {
    let toks : u64 = (&TOKS as u64)

    /* K1: <p>hi</p> -> OPEN(p) TAG_END TEXT(hi) CLOSE(p) */
    let n1 : u32 = markup_tokenize((&H1 as u64), 9u64, toks, 64u32)
    if n1 != 4u32 { return 1u64 }
    if markup_tok_kind(toks, 0u32) != K_OPEN { return 2u64 }
    if markup_tok_len(toks, 0u32) != 1u32 { return 3u64 }
    if markup_tok_kind(toks, 1u32) != K_TEND { return 4u64 }
    if markup_tok_kind(toks, 2u32) != K_TEXT { return 5u64 }
    if markup_tok_off(toks, 2u32) != 3u32 { return 6u64 }
    if markup_tok_len(toks, 2u32) != 2u32 { return 7u64 }
    if markup_tok_kind(toks, 3u32) != K_CLOS { return 8u64 }
    if markup_tok_off(toks, 3u32) != 7u32 { return 9u64 }

    /* K2: <a href="x" id=y> -> OPEN ANAM AVAL ANAM AVAL TEND */
    let n2 : u32 = markup_tokenize((&H2 as u64), 17u64, toks, 64u32)
    if n2 != 6u32 { return 10u64 }
    if markup_tok_kind(toks, 1u32) != K_ANAM { return 11u64 }
    if markup_tok_len(toks, 1u32) != 4u32 { return 12u64 }       /* "href" */
    if markup_tok_kind(toks, 2u32) != K_AVAL { return 13u64 }
    if markup_tok_off(toks, 2u32) != 9u32 { return 14u64 }       /* quoted "x" */
    if markup_tok_len(toks, 2u32) != 1u32 { return 15u64 }
    if markup_tok_kind(toks, 3u32) != K_ANAM { return 16u64 }
    if markup_tok_len(toks, 3u32) != 2u32 { return 17u64 }       /* "id" */
    if markup_tok_kind(toks, 4u32) != K_AVAL { return 18u64 }    /* unquoted "y" */
    if markup_tok_len(toks, 4u32) != 1u32 { return 19u64 }
    if markup_tok_kind(toks, 5u32) != K_TEND { return 20u64 }

    /* K3: <br/> -> OPEN(br) TAG_END(self-close) */
    let n3 : u32 = markup_tokenize((&H3 as u64), 5u64, toks, 64u32)
    if n3 != 2u32 { return 21u64 }
    if markup_tok_kind(toks, 0u32) != K_OPEN { return 22u64 }
    if markup_tok_len(toks, 0u32) != 2u32 { return 23u64 }       /* "br" */
    if markup_tok_kind(toks, 1u32) != K_TEND { return 24u64 }
    if markup_tok_len(toks, 1u32) != 1u32 { return 25u64 }       /* self-close flag */

    /* K4 (negative): <!-- a > b -->t -> only TEXT("t"); the '>' inside the comment does NOT end it */
    let n4 : u32 = markup_tokenize((&H4 as u64), 15u64, toks, 64u32)
    if n4 != 1u32 { return 26u64 }
    if markup_tok_kind(toks, 0u32) != K_TEXT { return 27u64 }
    if markup_tok_off(toks, 0u32) != 14u32 { return 28u64 }
    if markup_tok_len(toks, 0u32) != 1u32 { return 29u64 }

    /* K5: <script>if(a<b){}</script>x -> '<' inside script is TEXT */
    let n5 : u32 = markup_tokenize((&H5 as u64), 27u64, toks, 64u32)
    if n5 != 5u32 { return 30u64 }
    if markup_tok_kind(toks, 0u32) != K_OPEN { return 31u64 }
    if markup_tok_len(toks, 0u32) != 6u32 { return 32u64 }       /* "script" */
    if markup_tok_kind(toks, 2u32) != K_TEXT { return 33u64 }
    if markup_tok_off(toks, 2u32) != 8u32 { return 34u64 }
    if markup_tok_len(toks, 2u32) != 9u32 { return 35u64 }       /* "if(a<b){}" incl. the '<' */
    if markup_tok_kind(toks, 3u32) != K_CLOS { return 36u64 }
    if markup_tok_off(toks, 3u32) != 19u32 { return 37u64 }

    /* K7 (negative): </div> inside <script> stays TEXT; only </script> closes */
    let n7 : u32 = markup_tokenize((&H7 as u64), 23u64, toks, 64u32)
    if n7 != 4u32 { return 38u64 }
    if markup_tok_kind(toks, 2u32) != K_TEXT { return 39u64 }
    if markup_tok_off(toks, 2u32) != 8u32 { return 40u64 }
    if markup_tok_len(toks, 2u32) != 6u32 { return 41u64 }       /* "</div>" as text */
    if markup_tok_kind(toks, 3u32) != K_CLOS { return 42u64 }
    if markup_tok_off(toks, 3u32) != 16u32 { return 43u64 }

    /* K6 (the bound): a 2-token buffer cannot hold <p>hi</p>'s 4 tokens -> MK_OVERFLOW */
    let n6 : u32 = markup_tokenize((&H1 as u64), 9u64, toks, 2u32)
    if n6 != 0xFFFFFFFFu32 { return 44u64 }

    return 99u64
}
