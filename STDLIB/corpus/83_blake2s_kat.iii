/* BLAKE2s KAT: RFC 7693 Appendix B.
 *   input  = "abc"
 *   output = 50 8c 5e 8c 32 7c 14 e2 e1 a7 2b a3 4e eb 45 2f
 *            37 45 8b 20 9e d6 3a 29 4d 99 9b 4c 86 67 59 82
 *
 * Exit = first byte = 0x50 = 80.
 */
module corpus_83

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn blake2s_oneshot(input: *u8, len: u64, out: *u8, out_len: u64) -> u32 from "blake2s.iii"

fn main() -> u64 {
    let inp : *u8 = malloc(3u64)
    let out : *u8 = malloc(32u64)
    inp[0] = 97u8; inp[1] = 98u8; inp[2] = 99u8   /* "abc" */
    blake2s_oneshot(inp, 3u64, out, 32u64)
    if out[0]  != 0x50u8 { return 1u64 }
    if out[1]  != 0x8Cu8 { return 2u64 }
    if out[2]  != 0x5Eu8 { return 3u64 }
    if out[3]  != 0x8Cu8 { return 4u64 }
    if out[15] != 0x2Fu8 { return 5u64 }
    if out[16] != 0x37u8 { return 6u64 }
    if out[31] != 0x82u8 { return 7u64 }
    let result : u64 = out[0] as u64
    free(inp); free(out)
    return result
}
