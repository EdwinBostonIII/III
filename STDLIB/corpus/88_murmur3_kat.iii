/* MurmurHash3 32-bit KAT.
 *   "" with seed 0 = 0x00000000
 *   "test" with seed 0 = 0xBA6BD213
 * Exit = top byte of "test" hash = 0xBA = 186.
 */
module corpus_88

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn murmur3_32(data: *u8, len: u64, seed: u32) -> u32 from "murmur3.iii"

fn main() -> u64 {
    let empty : *u8 = malloc(1u64)
    let h0 : u32 = murmur3_32(empty, 0u64, 0u32)
    if h0 != 0u32 { return 1u64 }
    let s : *u8 = malloc(4u64)
    s[0] = 116u8; s[1] = 101u8; s[2] = 115u8; s[3] = 116u8
    let h1 : u32 = murmur3_32(s, 4u64, 0u32)
    if h1 != 0xBA6BD213u32 { return 2u64 }
    let result : u64 = ((h1 >> 24u32) & 0xFFu32) as u64
    free(empty); free(s)
    return result
}
