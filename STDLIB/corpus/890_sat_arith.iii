/* 890_sat_arith.iii -- gates numera/sat_arith (saturating fixed-width arithmetic + popcount +
 * min/max), used by the resolver activation-score path.  NO STDLIB corpus test exercised its
 * @export functions -- the resolver hits them transitively but never the SATURATION EDGES
 * (overflow->MAX, underflow->0, div0->MAX), the whole point of the module.  This KATs those
 * edges plus normal cases, popcount, and min/max.  99 = all correct; the code names the check. */
module corpus_890

extern @abi(c-msvc-x64) fn sat_add_u64(a: u64, b: u64) -> u64 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn sat_sub_u64(a: u64, b: u64) -> u64 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn sat_mul_u64(a: u64, b: u64) -> u64 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn sat_div_u64(a: u64, b: u64) -> u64 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn sat_add_u32(a: u32, b: u32) -> u32 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn sat_sub_u32(a: u32, b: u32) -> u32 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn sat_mul_u32(a: u32, b: u32) -> u32 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn sat_div_u32(a: u32, b: u32) -> u32 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn popcount_u32(x: u32) -> u32 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn popcount_u64(x: u64) -> u32 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn min_u64(a: u64, b: u64) -> u64 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn max_u64(a: u64, b: u64) -> u64 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn min_u32(a: u32, b: u32) -> u32 from "sat_arith.iii"
extern @abi(c-msvc-x64) fn max_u32(a: u32, b: u32) -> u32 from "sat_arith.iii"

fn main() -> u64 {
    /* u64 saturating: the clamp edges (the module's reason to exist) + normal pass-through */
    if sat_add_u64(0xFFFFFFFFFFFFFFFFu64, 1u64) != 0xFFFFFFFFFFFFFFFFu64 { return 1u64 }
    if sat_add_u64(5u64, 7u64) != 12u64 { return 2u64 }
    if sat_sub_u64(0u64, 1u64) != 0u64 { return 3u64 }
    if sat_sub_u64(10u64, 3u64) != 7u64 { return 4u64 }
    if sat_mul_u64(0xFFFFFFFFFFFFFFFFu64, 2u64) != 0xFFFFFFFFFFFFFFFFu64 { return 5u64 }
    if sat_mul_u64(6u64, 7u64) != 42u64 { return 6u64 }
    if sat_div_u64(42u64, 0u64) != 0xFFFFFFFFFFFFFFFFu64 { return 7u64 }
    if sat_div_u64(42u64, 6u64) != 7u64 { return 8u64 }
    /* u32 saturating */
    if sat_add_u32(0xFFFFFFFFu32, 1u32) != 0xFFFFFFFFu32 { return 9u64 }
    if sat_add_u32(5u32, 7u32) != 12u32 { return 10u64 }
    if sat_sub_u32(0u32, 1u32) != 0u32 { return 11u64 }
    if sat_mul_u32(0xFFFFFFFFu32, 2u32) != 0xFFFFFFFFu32 { return 12u64 }
    if sat_div_u32(42u32, 0u32) != 0xFFFFFFFFu32 { return 13u64 }
    /* popcount */
    if popcount_u32(0xFFu32) != 8u32 { return 14u64 }
    if popcount_u32(0u32) != 0u32 { return 15u64 }
    if popcount_u64(0xFFFFFFFFFFFFFFFFu64) != 64u32 { return 16u64 }
    /* min/max (u64-safe ordering per ADR-RES-016) */
    if min_u64(3u64, 7u64) != 3u64 { return 17u64 }
    if max_u64(3u64, 7u64) != 7u64 { return 18u64 }
    if min_u32(7u32, 3u32) != 3u32 { return 19u64 }
    if max_u32(7u32, 3u32) != 7u32 { return 20u64 }
    return 99u64
}
