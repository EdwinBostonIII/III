/* 892_xii_nop_tables.iii -- gates numera/xii_nop_tables (per-target NOP encodings for LDIL
 * placeholder fill, DOCS/III-XII.md S26.12.3).  No STDLIB corpus test exercised its @export
 * fill/unit-size functions.  This KATs the actual NOP byte patterns per ISA, the byte-count
 * returns, bad-target refusal (->0), and the ARM64 round-down.  99 = all correct. */
module corpus_892

extern @abi(c-msvc-x64) fn xii_nop_fill(target: u32, out: *u8, count: u32) -> u32 from "xii_nop_tables.iii"
extern @abi(c-msvc-x64) fn xii_nop_unit_size(target: u32) -> u32 from "xii_nop_tables.iii"

var NOP_BUF : [u8; 32]

fn main() -> u64 {
    /* unit sizes: x86 family = 1, arm64/riscv = 4, cortex-m = 2, bad target = 0 */
    if xii_nop_unit_size(0u32) != 1u32 { return 1u64 }
    if xii_nop_unit_size(2u32) != 1u32 { return 2u64 }
    if xii_nop_unit_size(3u32) != 4u32 { return 3u64 }
    if xii_nop_unit_size(5u32) != 4u32 { return 4u64 }
    if xii_nop_unit_size(6u32) != 2u32 { return 5u64 }
    if xii_nop_unit_size(7u32) != 0u32 { return 6u64 }

    let p : *u8 = (&NOP_BUF as u64) as *u8

    /* x86 scalar-ct (target 2): three single-byte 0x90 NOPs */
    if xii_nop_fill(2u32, p, 3u32) != 3u32 { return 7u64 }
    if NOP_BUF[0u64] != 0x90u8 { return 8u64 }
    if NOP_BUF[1u64] != 0x90u8 { return 9u64 }
    if NOP_BUF[2u64] != 0x90u8 { return 10u64 }

    /* x86 (target 0): the 4-byte NOP 0x0F 0x1F 0x40 0x00 */
    if xii_nop_fill(0u32, p, 4u32) != 4u32 { return 11u64 }
    if NOP_BUF[0u64] != 0x0Fu8 { return 12u64 }
    if NOP_BUF[1u64] != 0x1Fu8 { return 13u64 }
    if NOP_BUF[2u64] != 0x40u8 { return 14u64 }
    if NOP_BUF[3u64] != 0x00u8 { return 15u64 }

    /* arm64 (target 3): 0x1F 0x20 0x03 0xD5 */
    if xii_nop_fill(3u32, p, 4u32) != 4u32 { return 16u64 }
    if NOP_BUF[0u64] != 0x1Fu8 { return 17u64 }
    if NOP_BUF[1u64] != 0x20u8 { return 18u64 }
    if NOP_BUF[2u64] != 0x03u8 { return 19u64 }
    if NOP_BUF[3u64] != 0xD5u8 { return 20u64 }

    /* riscv (target 5): 0x13 0x00 0x00 0x00 */
    if xii_nop_fill(5u32, p, 4u32) != 4u32 { return 21u64 }
    if NOP_BUF[0u64] != 0x13u8 { return 22u64 }

    /* cortex-m (target 6): 0x00 0xBF */
    if xii_nop_fill(6u32, p, 2u32) != 2u32 { return 23u64 }
    if NOP_BUF[0u64] != 0x00u8 { return 24u64 }
    if NOP_BUF[1u64] != 0xBFu8 { return 25u64 }

    /* bad target (7): refuses, writes nothing, returns 0 */
    if xii_nop_fill(7u32, p, 4u32) != 0u32 { return 26u64 }

    /* arm64 round-down: count 5 -> aligned 4 written */
    if xii_nop_fill(3u32, p, 5u32) != 4u32 { return 27u64 }

    return 99u64
}
