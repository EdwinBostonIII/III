/* 900_pattern_form.iii -- integration gate for verba/pattern_form.iii (was wired NOWHERE).
 * pattern_form fills a 168-byte pattern_t template from a "key=val,.." spec via pattern.iii's
 * setters.  pattern.iii exposes no getters, so this gates DIFFERENTIALLY: the parse path must
 * produce a byte-identical template to the same fields applied via direct setter calls -- two
 * genuinely different code paths, so agreement is non-tautological.  A sensitivity check (a
 * deliberately-wrong direct-set must NOT match) proves the comparison has teeth.
 * 99 = parse == direct-set, and the comparison distinguishes a mismatch. */
module corpus_900

extern @abi(c-msvc-x64) fn pattern_form_parse(spec_src: u64, spec_len: u64, template_buf: u64) -> i32 from "pattern_form.iii"
extern @abi(c-msvc-x64) fn pattern_template_zero(buf: u64) -> i32 from "pattern.iii"
extern @abi(c-msvc-x64) fn pattern_template_set_hexad_kind(buf: u64, h: u8) -> i32 from "pattern.iii"
extern @abi(c-msvc-x64) fn pattern_template_set_ring(buf: u64, r: u8) -> i32 from "pattern.iii"

var PFBUF1 : [u8; 168]
var PFBUF2 : [u8; 168]

fn buf_eq(a: u64, b: u64, n: u64) -> u32 {
    let pa : *u8 = a as *u8
    let pb : *u8 = b as *u8
    let mut k : u64 = 0u64
    while k < n { if pa[k] != pb[k] { return 0u32 } ; k = k + 1u64 }
    return 1u32
}

fn main() -> u64 {
    let b1 : u64 = (&PFBUF1) as u64
    let b2 : u64 = (&PFBUF2) as u64

    /* parse path: "hexad=6,ring=2" (14 chars) */
    pattern_template_zero(b1)
    let spec : u64 = ("hexad=6,ring=2" as *u8) as u64
    if pattern_form_parse(spec, 14u64, b1) != 0i32 { return 1u64 }

    /* direct-set path (independent reconstruction) */
    pattern_template_zero(b2)
    pattern_template_set_hexad_kind(b2, 6u8)
    pattern_template_set_ring(b2, 2u8)

    /* differential: the parse produced the same template as the direct setters */
    if buf_eq(b1, b2, 168u64) != 1u32 { return 2u64 }

    /* sensitivity: a WRONG direct-set must NOT match (the comparison has teeth) */
    pattern_template_zero(b2)
    pattern_template_set_hexad_kind(b2, 7u8)
    pattern_template_set_ring(b2, 2u8)
    if buf_eq(b1, b2, 168u64) == 1u32 { return 3u64 }

    return 99u64
}
