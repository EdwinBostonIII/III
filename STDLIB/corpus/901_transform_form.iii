/* 901_transform_form.iii -- integration gate for verba/transform_form.iii (was wired NOWHERE).
 * transform_form parses "src=,dst=,input=" then calls transform(); the parsed values are exposed
 * via accessors set during the parse (before the transform call).  This proves the parse populates
 * src/dst/input correctly and that the null-src / zero-len guards REFUSE (negative cases).
 * 99 = parsed fields match and both guards fire. */
module corpus_901

extern @abi(c-msvc-x64) fn transform_form_invoke(src: u64, len: u64, ctx: u64) -> u64 from "transform_form.iii"
extern @abi(c-msvc-x64) fn transform_form_src_form() -> u32 from "transform_form.iii"
extern @abi(c-msvc-x64) fn transform_form_dst_form() -> u32 from "transform_form.iii"
extern @abi(c-msvc-x64) fn transform_form_input() -> u64 from "transform_form.iii"

fn main() -> u64 {
    let spec : u64 = ("src=1,dst=3,input=0xCAFE" as *u8) as u64       /* 24 chars */
    transform_form_invoke(spec, 24u64, 0u64)
    if transform_form_src_form() != 1u32 { return 1u64 }
    if transform_form_dst_form() != 3u32 { return 2u64 }
    let expinp : u64 = 0xCAFEu64
    if transform_form_input() != expinp { return 3u64 }
    /* NEGATIVE: null src and zero len are refused (return 0) */
    if transform_form_invoke(0u64, 24u64, 0u64) != 0u64 { return 4u64 }
    if transform_form_invoke(spec, 0u64, 0u64) != 0u64 { return 5u64 }
    return 99u64
}
