/* 922_pcc_gate.iii -- the Generative Frontier (Phase C): Proof-Carrying Code end-to-end, driving
 * III's REAL CIC kernel (typecheck.iii tc_check) to evaluate constructive proofs against
 * dependent-type specs.  Every verdict is the kernel's; the falsifiers prove it cannot be tricked:
 *   spec Nat        : 0 : Nat admits;  true : Nat rejects (wrong type).
 *   spec Nat->Nat   : (lam x. x) admits;  (lam x. true) rejects (wrong return type).
 *   spec Id 0 0/0 1 : refl 0 : (0=0) admits;  refl 0 : (0=1) REJECTS -- THE HEART: the kernel will
 *                     not prove a falsehood, so generative code carrying a false proof is destroyed.
 *   composed pcc_admit: proven + kernel-live -> commit;  flawed proof -> destroyed;  kernel down -> reject.
 * 99 = all arms pass; 10..42 localize the first failing arm. */
module corpus_922

extern @abi(c-msvc-x64) fn tc_reset() -> u64 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_nat() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_zero() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_succ(n: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_true() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_id(ty: u32, lhs: u32, rhs: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_refl(a: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_pi(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_lam(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_var(k: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn pcc_verify(proof_term: u32, spec_type: u32) -> u8 from "pcc_gate.iii"
extern @abi(c-msvc-x64) fn pcc_admit(proof_term: u32, spec_type: u32, kernel_ok: u32) -> u32 from "pcc_gate.iii"

fn main() -> u64 {
    tc_reset()

    /* ===== spec: Nat ===== */
    if pcc_verify(tc_zero(), tc_nat()) != 1u8 { return 10u64 }   /* 0 : Nat -> admit */
    if pcc_verify(tc_true(), tc_nat()) != 0u8 { return 11u64 }   /* true : Bool != Nat -> reject */

    /* ===== spec: Nat -> Nat (the identity function) ===== */
    let nat2nat : u32 = tc_pi(tc_nat(), tc_nat())
    if pcc_verify(tc_lam(tc_nat(), tc_var(0u32)), nat2nat) != 1u8 { return 20u64 }   /* lam x. x -> admit */
    if pcc_verify(tc_lam(tc_nat(), tc_true()), nat2nat) != 0u8 { return 21u64 }      /* lam x. true -> reject */

    /* ===== spec: Id Nat 0 0 (a TRUE equality) vs Id Nat 0 1 (a FALSE one) -- THE HEART ===== */
    let z   : u32 = tc_zero()
    let one : u32 = tc_succ(tc_zero())
    if pcc_verify(tc_refl(z), tc_id(tc_nat(), z, z)) != 1u8 { return 30u64 }     /* refl 0 : (0=0) -> admit */
    if pcc_verify(tc_refl(z), tc_id(tc_nat(), z, one)) != 0u8 { return 31u64 }   /* refl 0 : (0=1)? NO -> REJECT */

    /* ===== composed PCC admission ===== */
    if pcc_admit(tc_refl(z), tc_id(tc_nat(), z, z), 1u32) != 1u32 { return 40u64 }     /* proven + kernel live -> commit */
    if pcc_admit(tc_refl(z), tc_id(tc_nat(), z, one), 1u32) != 0u32 { return 41u64 }   /* flawed proof -> destroyed */
    if pcc_admit(tc_refl(z), tc_id(tc_nat(), z, z), 0u32) != 0u32 { return 42u64 }     /* kernel down -> reject */

    return 99u64
}
