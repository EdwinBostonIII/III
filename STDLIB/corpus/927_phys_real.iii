/* 927_phys_real.iii -- III -> Silicon (SX2): the cost lattice gains REALISM -- per-gate-TYPE delay
 * (the weighted critical path) and fan-out capacitance (quadratic load). Two arms:
 *   - an XOR-deep path is SLOWER than a NAND-deep path of EQUAL gate count (XOR delay 2 vs 1);
 *   - a net driving 3 gates has 9x the fan-out capacitance of one driving 1 (3^2 vs 1^2).
 * Gate-kind codes: NOT=4, XOR=7, NAND=8. 99 = all arms; 10..21 localize the first failing arm. */
module corpus_927

extern @abi(c-msvc-x64) fn hdl_reset() -> u64 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_add_in(input_idx: u32) -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_add(kind: u32, a: u32, b: u32) -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn pc_crit_delay(out: u32) -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn pc_fanout_cap() -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn pc_gate_delay(kind: u32) -> u32 from "hdl.iii"

fn main() -> u64 {
    /* ===== WEIGHTED gate delay: equal gate count, different timing ===== */
    hdl_reset()
    let a : u32 = hdl_add_in(0u32)
    let b : u32 = hdl_add_in(1u32)
    let x1 : u32 = hdl_add(7u32, a, b)
    let x2 : u32 = hdl_add(7u32, x1, a)            /* 2 XOR gates: weighted delay 2 + 2 = 4 */
    let dx : u32 = pc_crit_delay(x2)
    hdl_reset()
    let c : u32 = hdl_add_in(0u32)
    let d : u32 = hdl_add_in(1u32)
    let n1 : u32 = hdl_add(8u32, c, d)
    let n2 : u32 = hdl_add(8u32, n1, c)            /* 2 NAND gates: weighted delay 1 + 1 = 2 */
    let dn : u32 = pc_crit_delay(n2)
    if dx != 4u32 { return 10u64 }
    if dn != 2u32 { return 11u64 }                 /* same gate count, XOR path is slower */
    if pc_gate_delay(7u32) != 2u32 { return 12u64 }   /* XOR delay 2 */
    if pc_gate_delay(8u32) != 1u32 { return 13u64 }   /* NAND delay 1 */

    /* ===== fan-out CAPACITANCE: quadratic load ===== */
    hdl_reset()
    let e : u32 = hdl_add_in(0u32)
    let h0 : u32 = hdl_add(4u32, e, e)
    let h1 : u32 = hdl_add(4u32, e, e)
    let h2 : u32 = hdl_add(4u32, e, e)             /* e drives 3 NOTs -> fan-out 3 -> cap 9 */
    if pc_fanout_cap() != 9u32 { return 20u64 }
    hdl_reset()
    let f : u32 = hdl_add_in(0u32)
    let l0 : u32 = hdl_add(4u32, f, f)             /* f drives 1 NOT -> fan-out 1 -> cap 1 */
    if pc_fanout_cap() != 1u32 { return 21u64 }

    return 99u64
}
