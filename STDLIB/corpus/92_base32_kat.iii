/* Base32 RFC 4648 KAT.
 *   "" -> ""
 *   "f" -> "MY======"
 *   "fo" -> "MZXQ===="
 *   "foo" -> "MZXW6==="
 *   "foob" -> "MZXW6YQ="
 *   "fooba" -> "MZXW6YTB"
 *   "foobar" -> "MZXW6YTBOI======"
 *
 * Verify "foobar" → "MZXW6YTBOI======". Exit = 99 on success.
 */
module corpus_92

extern @abi(c-msvc-x64) fn malloc(n: u64) -> *u8 from "msvcrt"
extern @abi(c-msvc-x64) fn free(p: *u8) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn builder_new(arena: u64, hint: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_seal(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_len(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn base32_encode(builder_id: u64, src_base: u64, src_len: u64) -> i32 from "base32.iii"

fn main() -> u64 {
    let a : u64 = arena_new(1u64 << 16u64)
    let src : *u8 = malloc(6u64)
    src[0] = 102u8; src[1] = 111u8; src[2] = 111u8
    src[3] = 98u8;  src[4] = 97u8;  src[5] = 114u8
    let b : u64 = builder_new(a, 32u64)
    base32_encode(b, src as u64, 6u64)
    if builder_len(b) != 16u64 { return 100u64 + builder_len(b) }
    let enc : *u8 = builder_seal(b) as *u8
    /* "MZXW6YTBOI======" */
    if enc[0]  != 77u8  { return 1u64 }   /* M */
    if enc[1]  != 90u8  { return 2u64 }   /* Z */
    if enc[2]  != 88u8  { return 3u64 }   /* X */
    if enc[3]  != 87u8  { return 4u64 }   /* W */
    if enc[4]  != 54u8  { return 5u64 }   /* 6 */
    if enc[5]  != 89u8  { return 6u64 }   /* Y */
    if enc[6]  != 84u8  { return 7u64 }   /* T */
    if enc[7]  != 66u8  { return 8u64 }   /* B */
    if enc[8]  != 79u8  { return 9u64 }   /* O */
    if enc[9]  != 73u8  { return 10u64 }  /* I */
    if enc[10] != 61u8  { return 11u64 }  /* = */
    if enc[15] != 61u8  { return 12u64 }  /* = */
    free(src)
    arena_drop(a)
    return 99u64
}
