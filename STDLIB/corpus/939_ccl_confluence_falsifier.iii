/* 939 — CCL confluence enumerator falsifier (W2.3 / SEPARATE-2 / II-CCL-3 / I4).
 *
 * Proves the machine critical-pair enumerator is a REAL guard, not a vacuous one: it must
 * (a) report all-join (99) on the TRUE rule set, and (b) report a NON-joining pair (!=99) for
 * each of several DELIBERATELY WRONG rule RHS injections -- divergence the hand-enumerated
 * CP1..CP16 cannot see (it only ever checks its 16 fixed pairs).  This is the de-deferred
 * "confluence is a theorem, not a sample": a wrong rule is caught at BUILD time. */
module corpus_939
extern @abi(c-msvc-x64) fn ccl_critpair_enum(fault: u32) -> u64 from "ccl.iii"

fn main() -> u64 {
    /* the REAL rule set: every rule-rule critical pair joins. */
    if ccl_critpair_enum(0u32) != 99u64 { return 1u64 }
    /* inject a wrong fst RHS (Fst o <x,y> -> y instead of x): MUST be caught. */
    if ccl_critpair_enum(6u32) == 99u64 { return 2u64 }
    /* inject a wrong ass RHS (swap x,y): MUST be caught. */
    if ccl_critpair_enum(3u32) == 99u64 { return 3u64 }
    /* inject a wrong beta RHS (swap the argument pair y,z): MUST be caught. */
    if ccl_critpair_enum(8u32) == 99u64 { return 4u64 }
    /* inject a wrong snd RHS (Snd o <x,y> -> x): MUST be caught. */
    if ccl_critpair_enum(7u32) == 99u64 { return 5u64 }
    return 99u64
}
