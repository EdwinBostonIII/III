/* 940 -- W4.2 / ENHANCE-17 falsifier: sanctus/irreducibility_proof's proof_pair is now
 * LOAD-BEARING -- its verdict depends on the real irreducibility witness (structural
 * distinguishability OR a documented operational pair), not a bare `return PROOF_OK`.
 *
 * The calculus has NO reducible pair by construction, so the falsifier MANUFACTURES one:
 * de-whitelist the operational pair (mean=4, prove=8) -- which shares all four structural
 * fields -- and prove proof_pair / proof_run_full_matrix / proof_first_failure all REJECT
 * it (the gate can say *no*).  Restore and reconfirm the theorem.  99 = pass. */
module corpus_940

extern @abi(c-msvc-x64) fn calculus_init() -> i32 from "calculus_v1.iii"
extern @abi(c-msvc-x64) fn proof_init() -> i32 from "irreducibility_proof.iii"
extern @abi(c-msvc-x64) fn proof_pair(i: u32, j: u32) -> u32 from "irreducibility_proof.iii"
extern @abi(c-msvc-x64) fn proof_structural_distinguishability(i: u32, j: u32) -> u32 from "irreducibility_proof.iii"
extern @abi(c-msvc-x64) fn is_operational_pair(i: u32, j: u32) -> u8 from "irreducibility_proof.iii"
extern @abi(c-msvc-x64) fn proof_run_full_matrix() -> u32 from "irreducibility_proof.iii"
extern @abi(c-msvc-x64) fn proof_count_irreducible() -> u32 from "irreducibility_proof.iii"
extern @abi(c-msvc-x64) fn proof_first_failure() -> u32 from "irreducibility_proof.iii"
extern @abi(c-msvc-x64) fn proof_drop_op_pair_for_test(idx: u32) -> u32 from "irreducibility_proof.iii"
extern @abi(c-msvc-x64) fn proof_restore_op_pairs_for_test() -> i32 from "irreducibility_proof.iii"

fn main() -> u64 {
    calculus_init()
    proof_init()

    /* Positive arm: the full 18-primitive (+abstract = 19) calculus is irreducible. */
    if proof_run_full_matrix()  != 0u32   { return 1u64 }
    if proof_count_irreducible() != 361u32 { return 2u64 }   /* 19*19, all OK */
    if proof_first_failure()    != 0u32   { return 3u64 }

    /* The operational pairs are exactly the structurally-IDENTICAL ones (that is WHY they
     * need the table).  (4,8) = mean<->prove shares hexad/K/mask/ring. */
    if proof_structural_distinguishability(4u32, 8u32) != 0u32 { return 4u64 }
    if is_operational_pair(4u32, 8u32) != 1u8 { return 5u64 }
    if proof_pair(4u32, 8u32) != 0u32 { return 6u64 }        /* OK -- but via the table, not vacuously */

    /* FALSIFIER: de-whitelist slot 0 = (4,8).  It becomes a reducible input. */
    let dropped : u32 = proof_drop_op_pair_for_test(0u32)
    if dropped != 408u32 { return 7u64 }                     /* 4*100 + 8 */
    if is_operational_pair(4u32, 8u32) != 0u8 { return 8u64 } /* no longer whitelisted */

    /* proof_pair MUST now reject it (non-OK) -- the verdict depends on real work. */
    if proof_pair(4u32, 8u32) == 0u32 { return 9u64 }
    /* The matrix counts the failure; the irreducible count drops below 361. */
    if proof_run_full_matrix()  == 0u32   { return 10u64 }
    if proof_count_irreducible() == 361u32 { return 11u64 }
    /* The diagnostic points at the manufactured reducible pair. */
    if proof_first_failure()    != 408u32 { return 12u64 }

    /* Restore: the drop was the ONLY cause; the theorem holds again. */
    proof_restore_op_pairs_for_test()
    if proof_run_full_matrix()  != 0u32   { return 13u64 }
    if proof_count_irreducible() != 361u32 { return 14u64 }
    if proof_pair(4u32, 8u32)   != 0u32   { return 15u64 }
    if is_operational_pair(4u32, 8u32) != 1u8 { return 16u64 }
    return 99u64
}
