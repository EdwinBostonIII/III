/* Diag: reproduce the corpus 239 ch_bc_b vs ch_ac_a SID collision in
 * isolation.  If we see exit 50 here, the bug is in sealed_channel.iii
 * (slot allocator, session_id derivation, or aliasing).  If exit 99,
 * the bug is elsewhere in corpus 239. */
module diag_239_repro

extern @abi(c-msvc-x64) fn x25519(out: *u8, scalar: *u8, u_in: *u8) -> i32 from "x25519.iii"
extern @abi(c-msvc-x64) fn sc_handshake_init(peer_pubkey_ptr: u64, my_secret_ptr: u64) -> u64 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_session_id_byte(channel_id: u64, i: u32) -> u32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_reset_all() -> i32 from "sealed_channel.iii"

var BP   : [u8; 32]
var A_SK : [u8; 32]
var B_SK : [u8; 32]
var C_SK : [u8; 32]
var A_PK : [u8; 32]
var B_PK : [u8; 32]
var C_PK : [u8; 32]

fn _fill(p: *u8, base: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < 32u64 {
        p[i] = ((base + i) & 0xFFu64) as u8
        i = i + 1u64
    }
    return 0i32
}

fn _sid_eq(ch_a: u64, ch_b: u64) -> u8 {
    let mut k : u32 = 0u32
    while k < 8u32 {
        let av : u32 = sc_session_id_byte(ch_a, k)
        let bv : u32 = sc_session_id_byte(ch_b, k)
        if av != bv { return 0u8 }
        k = k + 1u32
    }
    return 1u8
}

fn main() -> u64 {
    sc_reset_all()

    let bp   : *u8 = (&BP) as *u8
    bp[0u64] = 9u8
    let mut z : u64 = 1u64
    while z < 32u64 { bp[z] = 0u8; z = z + 1u64 }

    let a_sk : *u8 = (&A_SK) as *u8
    let b_sk : *u8 = (&B_SK) as *u8
    let c_sk : *u8 = (&C_SK) as *u8
    _fill(a_sk, 0x11u64)
    _fill(b_sk, 0x40u64)
    _fill(c_sk, 0x80u64)

    let a_pk : *u8 = (&A_PK) as *u8
    let b_pk : *u8 = (&B_PK) as *u8
    let c_pk : *u8 = (&C_PK) as *u8
    if x25519(a_pk, a_sk, bp) != 0i32 { return 1u64 }
    if x25519(b_pk, b_sk, bp) != 0i32 { return 2u64 }
    if x25519(c_pk, c_sk, bp) != 0i32 { return 3u64 }

    /* 6 pairwise handshakes — same exact order as corpus 239. */
    let ch_ab_a : u64 = sc_handshake_init(b_pk as u64, a_sk as u64)
    if ch_ab_a == 0u64 { return 4u64 }
    let ch_ab_b : u64 = sc_handshake_init(a_pk as u64, b_sk as u64)
    if ch_ab_b == 0u64 { return 5u64 }
    let ch_bc_b : u64 = sc_handshake_init(c_pk as u64, b_sk as u64)
    if ch_bc_b == 0u64 { return 6u64 }
    let ch_bc_c : u64 = sc_handshake_init(b_pk as u64, c_sk as u64)
    if ch_bc_c == 0u64 { return 7u64 }
    let ch_ac_a : u64 = sc_handshake_init(c_pk as u64, a_sk as u64)
    if ch_ac_a == 0u64 { return 8u64 }
    let ch_ac_c : u64 = sc_handshake_init(a_pk as u64, c_sk as u64)
    if ch_ac_c == 0u64 { return 9u64 }

    /* Report the channel slots actually returned (channel_id - 1). */
    /* Encode: high nibble = ch_bc_b slot, low = ch_ac_a slot, in exit code */
    let slot_bc_b : u64 = ch_bc_b - 1u64
    let slot_ac_a : u64 = ch_ac_a - 1u64
    if slot_bc_b == slot_ac_a { return 20u64 }   /* slot allocator broke */

    /* Compare SIDs directly. */
    if _sid_eq(ch_bc_b, ch_ac_a) == 1u8 { return 50u64 }  /* SID collision */

    return 99u64
}
