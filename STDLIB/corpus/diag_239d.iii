/* 2 handshakes back-to-back without reset.  AB sides should agree. */
module diag_239d

extern @abi(c-msvc-x64) fn sc_handshake_init(peer_pubkey_ptr: u64, my_secret_ptr: u64) -> u64 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_session_id_byte(channel_id: u64, i: u32) -> u32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_reset_all() -> i32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn x25519(out: *u8, scalar: *u8, u_in: *u8) -> i32 from "x25519.iii"

var BP : [u8; 32]
var A_SK : [u8; 32]
var B_SK : [u8; 32]
var C_SK : [u8; 32]
var A_PK : [u8; 32]
var B_PK : [u8; 32]
var C_PK : [u8; 32]

fn _fill(buf: *u8, base: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < 32u64 { buf[i] = ((base + i) & 0xFFu64) as u8; i = i + 1u64 }
    return 0i32
}

fn main() -> u64 {
    sc_reset_all()
    let bp : *u8 = (&BP) as *u8
    bp[0u64] = 9u8
    let mut z : u64 = 1u64
    while z < 32u64 { bp[z] = 0u8; z = z + 1u64 }
    let a_sk : *u8 = (&A_SK) as *u8
    let b_sk : *u8 = (&B_SK) as *u8
    let c_sk : *u8 = (&C_SK) as *u8
    _fill(a_sk, 0x11u64)
    _fill(b_sk, 0x40u64)
    _fill(c_sk, 0x80u64)
    let a_pk : *u8 = (&A_PK) as *u8
    let b_pk : *u8 = (&B_PK) as *u8
    let c_pk : *u8 = (&C_PK) as *u8
    x25519(a_pk, a_sk, bp)
    x25519(b_pk, b_sk, bp)
    x25519(c_pk, c_sk, bp)

    let ch_a : u64 = sc_handshake_init(b_pk as u64, a_sk as u64)   /* slot 0 */
    let ch_b : u64 = sc_handshake_init(a_pk as u64, b_sk as u64)   /* slot 1 */
    /* slot 2 only — different secret. */
    let _ch2 : u64 = sc_handshake_init(c_pk as u64, b_sk as u64)   /* slot 2 BC */

    /* Compare all 8 bytes of sid; return first differing byte index + 1, or 99 if all match. */
    let mut k : u32 = 0u32
    while k < 8u32 {
        if sc_session_id_byte(ch_a, k) != sc_session_id_byte(ch_b, k) { return (k as u64) + 10u64 }
        k = k + 1u32
    }
    return 99u64
}
