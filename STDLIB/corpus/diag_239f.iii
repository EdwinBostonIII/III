/* CLEAN: 2 handshakes only, distinct vars, compare sids. */
module diag_239f

extern @abi(c-msvc-x64) fn sc_handshake_init(peer_pubkey_ptr: u64, my_secret_ptr: u64) -> u64 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_session_id_byte(channel_id: u64, i: u32) -> u32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_reset_all() -> i32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn x25519(out: *u8, scalar: *u8, u_in: *u8) -> i32 from "x25519.iii"

var BP : [u8; 32]
var ASK : [u8; 32]
var BSK : [u8; 32]
var CSK : [u8; 32]
var APK : [u8; 32]
var BPK : [u8; 32]
var CPK : [u8; 32]

fn main() -> u64 {
    sc_reset_all()
    let bp : *u8 = (&BP) as *u8
    bp[0u64] = 9u8
    let mut z : u64 = 1u64
    while z < 32u64 { bp[z] = 0u8; z = z + 1u64 }

    let ask : *u8 = (&ASK) as *u8
    let bsk : *u8 = (&BSK) as *u8
    let csk : *u8 = (&CSK) as *u8
    let mut i : u64 = 0u64
    while i < 32u64 { ask[i] = ((0x11u64 + i) & 0xFFu64) as u8; i = i + 1u64 }
    let mut j : u64 = 0u64
    while j < 32u64 { bsk[j] = ((0x40u64 + j) & 0xFFu64) as u8; j = j + 1u64 }
    let mut h : u64 = 0u64
    while h < 32u64 { csk[h] = ((0x80u64 + h) & 0xFFu64) as u8; h = h + 1u64 }

    let apk : *u8 = (&APK) as *u8
    let bpk : *u8 = (&BPK) as *u8
    let cpk : *u8 = (&CPK) as *u8
    x25519(apk, ask, bp)
    x25519(bpk, bsk, bp)

    let chA : u64 = sc_handshake_init(bpk as u64, ask as u64)   /* slot 0 */
    let chB : u64 = sc_handshake_init(apk as u64, bsk as u64)   /* slot 1 */
    if chA == 0u64 { return 1u64 }
    if chB == 0u64 { return 2u64 }

    /* Compare 8 bytes; return first differing index + 10, or 99 if match. */
    let mut k : u32 = 0u32
    while k < 8u32 {
        let av : u32 = sc_session_id_byte(chA, k)
        let bv : u32 = sc_session_id_byte(chB, k)
        if av != bv { return (k as u64) + 10u64 }
        k = k + 1u32
    }
    return 99u64
}
