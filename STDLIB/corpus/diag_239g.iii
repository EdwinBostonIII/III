/* Snapshot ALL slot sids before/after slot 2 init.  Detect corruption. */
module diag_239g

extern @abi(c-msvc-x64) fn sc_handshake_init(peer_pubkey_ptr: u64, my_secret_ptr: u64) -> u64 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_session_id_byte(channel_id: u64, i: u32) -> u32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_reset_all() -> i32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn x25519(out: *u8, scalar: *u8, u_in: *u8) -> i32 from "x25519.iii"

var BP : [u8; 32]
var ASK : [u8; 32]
var BSK : [u8; 32]
var CSK : [u8; 32]
var APK : [u8; 32]
var BPK : [u8; 32]
var CPK : [u8; 32]
var SNAP_A_PRE : [u8; 8]
var SNAP_B_PRE : [u8; 8]
var SNAP_A_POST : [u8; 8]
var SNAP_B_POST : [u8; 8]

fn _snap(buf: *u8, ch: u64) -> i32 {
    let mut k : u32 = 0u32
    while k < 8u32 {
        buf[k as u64] = (sc_session_id_byte(ch, k) & 0xFFu32) as u8
        k = k + 1u32
    }
    return 0i32
}

fn _bufeq(a: *u8, b: *u8) -> i32 {
    let mut q : u64 = 0u64
    while q < 8u64 {
        if a[q] != b[q] { return (q as i32) + 1i32 }
        q = q + 1u64
    }
    return 0i32
}

fn main() -> u64 {
    sc_reset_all()
    let bp : *u8 = (&BP) as *u8
    bp[0u64] = 9u8
    let mut z : u64 = 1u64
    while z < 32u64 { bp[z] = 0u8; z = z + 1u64 }

    let ask : *u8 = (&ASK) as *u8
    let bsk : *u8 = (&BSK) as *u8
    let csk : *u8 = (&CSK) as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        ask[i] = ((0x11u64 + i) & 0xFFu64) as u8
        bsk[i] = ((0x40u64 + i) & 0xFFu64) as u8
        csk[i] = ((0x80u64 + i) & 0xFFu64) as u8
        i = i + 1u64
    }
    let apk : *u8 = (&APK) as *u8
    let bpk : *u8 = (&BPK) as *u8
    let cpk : *u8 = (&CPK) as *u8
    x25519(apk, ask, bp)
    x25519(bpk, bsk, bp)
    x25519(cpk, csk, bp)

    let chA : u64 = sc_handshake_init(bpk as u64, ask as u64)
    let chB : u64 = sc_handshake_init(apk as u64, bsk as u64)
    _snap((&SNAP_A_PRE) as *u8, chA)
    _snap((&SNAP_B_PRE) as *u8, chB)

    /* Verify chA sid == chB sid PRE-slot-2. */
    if _bufeq((&SNAP_A_PRE) as *u8, (&SNAP_B_PRE) as *u8) != 0i32 { return 30u64 }

    let chC : u64 = sc_handshake_init(cpk as u64, bsk as u64)

    _snap((&SNAP_A_POST) as *u8, chA)
    _snap((&SNAP_B_POST) as *u8, chB)

    /* Did slot 0 sid change? */
    if _bufeq((&SNAP_A_PRE) as *u8, (&SNAP_A_POST) as *u8) != 0i32 { return 40u64 }
    /* Did slot 1 sid change? */
    if _bufeq((&SNAP_B_PRE) as *u8, (&SNAP_B_POST) as *u8) != 0i32 { return 50u64 }

    /* Are slot 0 and slot 1 still equal AFTER? */
    if _bufeq((&SNAP_A_POST) as *u8, (&SNAP_B_POST) as *u8) != 0i32 { return 60u64 }

    return 99u64
}
