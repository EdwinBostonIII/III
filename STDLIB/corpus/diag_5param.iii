/* Diag: does iiis-0 actually support 5+ fn params today? */
module diag_5param

fn f5(a: u64, b: u64, c: u64, d: u64, e: u64) -> u64 {
    return a + b + c + d + e
}

fn f6(a: u64, b: u64, c: u64, d: u64, e: u64, f: u64) -> u64 {
    return a + b + c + d + e + f
}

fn main() -> u64 {
    let r5 : u64 = f5(1u64, 2u64, 3u64, 4u64, 5u64)
    let r6 : u64 = f6(1u64, 2u64, 3u64, 4u64, 5u64, 6u64)
    if r5 != 15u64 { return 5u64 }
    if r6 != 21u64 { return 6u64 }
    return 99u64
}
