/* Diag: measure actual AEAD send+recv median cycle counts for 16/64/256/1024B
 * payloads.  Reports value via packed exit code (low 16 bits = thousands of
 * cycles for 16B median). */
module diag_aead_cycles

extern @abi(c-msvc-x64) fn x25519(out: *u8, scalar: *u8, u_in: *u8) -> i32 from "x25519.iii"
extern @abi(c-msvc-x64) fn sc_handshake_init(peer_pubkey_ptr: u64, my_secret_ptr: u64) -> u64 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_send(channel_id: u64, plaintext_ptr: u64, len: u32, tag_out_ptr: u64) -> i32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_recv(channel_id: u64, ciphertext_ptr: u64, len: u32, tag_in_ptr: u64) -> i32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_reset_all() -> i32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn bench_now_p() -> u64 from "bench.iii"
extern @abi(c-msvc-x64) fn bench_warmup() -> i32 from "bench.iii"

var BP   : [u8; 32]
var ASK  : [u8; 32]
var BSK  : [u8; 32]
var APK  : [u8; 32]
var BPK  : [u8; 32]
var PT   : [u8; 1024]
var TAG  : [u8; 16]
var DELTAS : [u64; 100]

fn _fill_sk(p: *u8, base: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < 32u64 {
        p[i] = ((base + i) & 0xFFu64) as u8
        i = i + 1u64
    }
    return 0i32
}

fn _fill_pt(n: u32) -> i32 {
    let mut i : u64 = 0u64
    let ln : u64 = (n as u64) & 0xFFFFFFFFu64
    while i < ln {
        PT[i] = (i & 0xFFu64) as u8
        i = i + 1u64
    }
    return 0i32
}

fn _sort_n(n: u32) -> i32 {
    let ln : u64 = (n as u64) & 0xFFFFFFFFu64
    let mut i : u64 = 1u64
    while i < ln {
        let mut j : u64 = i
        while j > 0u64 {
            let prev : u64 = DELTAS[j - 1u64]
            let cur  : u64 = DELTAS[j]
            if prev > cur {
                DELTAS[j - 1u64] = cur
                DELTAS[j] = prev
            }
            j = j - 1u64
        }
        i = i + 1u64
    }
    return 0i32
}

fn _bench_size(ach: u64, bch: u64, size: u32, samples: u32) -> u64 {
    let mut i : u32 = 0u32
    while i < samples {
        _fill_pt(size)
        bench_warmup()
        let t0 : u64 = bench_now_p()
        let sr : i32 = sc_send(ach, (&PT) as u64, size, (&TAG) as u64)
        let rr : i32 = sc_recv(bch, (&PT) as u64, size, (&TAG) as u64)
        let t1 : u64 = bench_now_p()
        if sr != 0i32 { return 0xFFFFFFFFFFFFFFFDu64 }
        if rr != 0i32 { return 0xFFFFFFFFFFFFFFFEu64 }
        DELTAS[(i as u64) & 0xFFu64] = t1 - t0
        i = i + 1u32
    }
    _sort_n(samples)
    return DELTAS[(samples as u64) / 2u64]
}

fn main() -> u64 {
    sc_reset_all()
    let bp : *u8 = (&BP) as *u8
    bp[0u64] = 9u8
    let mut z : u64 = 1u64
    while z < 32u64 { bp[z] = 0u8; z = z + 1u64 }
    _fill_sk((&ASK) as *u8, 0x11u64)
    _fill_sk((&BSK) as *u8, 0x40u64)
    if x25519((&APK) as *u8, (&ASK) as *u8, bp) != 0i32 { return 1u64 }
    if x25519((&BPK) as *u8, (&BSK) as *u8, bp) != 0i32 { return 2u64 }
    let ach : u64 = sc_handshake_init((&BPK) as u64, (&ASK) as u64)
    let bch : u64 = sc_handshake_init((&APK) as u64, (&BSK) as u64)
    if ach == 0u64 { return 3u64 }
    if bch == 0u64 { return 4u64 }

    let m16   : u64 = _bench_size(ach, bch, 16u32, 100u32)
    let m64   : u64 = _bench_size(ach, bch, 64u32, 100u32)
    let m256  : u64 = _bench_size(ach, bch, 256u32, 100u32)
    let m1024 : u64 = _bench_size(ach, bch, 1024u32, 100u32)

    /* Encode each median as the bytes of exit code.
     * Exit code = (m16 / 1000) capped at 255 — just for 16B class. */
    if m16 == 0xFFFFFFFFFFFFFFFDu64 { return 200u64 }
    if m16 == 0xFFFFFFFFFFFFFFFEu64 { return 201u64 }
    let m16_k : u64 = m16 / 1000u64
    if m16_k > 255u64 { return 250u64 }
    /* Quick check: also report whether m1024 > 5 * m16 (linear scaling).
     * That would suggest bigint mul cost scales linearly with payload. */
    return m16_k
}
