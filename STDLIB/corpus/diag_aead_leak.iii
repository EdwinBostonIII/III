/* Diag: trace bigint live count across AEAD seal/open pairs to find
 * the leak location.  Reports live count after iteration that fills the
 * table -- if we reach 64 by iter N, the leak is N/64 bigints per round. */
module diag_aead_leak

extern @abi(c-msvc-x64) fn x25519(out: *u8, scalar: *u8, u_in: *u8) -> i32 from "x25519.iii"
extern @abi(c-msvc-x64) fn sc_handshake_init(peer_pubkey_ptr: u64, my_secret_ptr: u64) -> u64 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_send(channel_id: u64, plaintext_ptr: u64, len: u32, tag_out_ptr: u64) -> i32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_recv(channel_id: u64, ciphertext_ptr: u64, len: u32, tag_in_ptr: u64) -> i32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_reset_all() -> i32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn bigint_live_count() -> u32 from "bigint.iii"

var BP   : [u8; 32]
var ASK  : [u8; 32]
var BSK  : [u8; 32]
var APK  : [u8; 32]
var BPK  : [u8; 32]
var PT   : [u8; 16]
var PTSAVE : [u8; 16]
var TAG  : [u8; 16]

fn _fill_sk(p: *u8, base: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < 32u64 {
        p[i] = ((base + i) & 0xFFu64) as u8
        i = i + 1u64
    }
    return 0i32
}

fn _restore_pt() -> i32 {
    let mut i : u64 = 0u64
    while i < 16u64 {
        PT[i] = PTSAVE[i]
        i = i + 1u64
    }
    return 0i32
}

fn main() -> u64 {
    sc_reset_all()
    let bp : *u8 = (&BP) as *u8
    bp[0u64] = 9u8
    let mut z : u64 = 1u64
    while z < 32u64 { bp[z] = 0u8; z = z + 1u64 }

    _fill_sk((&ASK) as *u8, 0x11u64)
    _fill_sk((&BSK) as *u8, 0x40u64)

    if x25519((&APK) as *u8, (&ASK) as *u8, bp) != 0i32 { return 1u64 }
    if x25519((&BPK) as *u8, (&BSK) as *u8, bp) != 0i32 { return 2u64 }

    /* live count after x25519 derivations */
    let lc_post_x25519 : u32 = bigint_live_count()

    let ach : u64 = sc_handshake_init((&BPK) as u64, (&ASK) as u64)
    if ach == 0u64 { return 3u64 }
    let bch : u64 = sc_handshake_init((&APK) as u64, (&BSK) as u64)
    if bch == 0u64 { return 4u64 }

    let lc_post_handshakes : u32 = bigint_live_count()

    let mut k : u64 = 0u64
    while k < 16u64 {
        PTSAVE[k] = (k & 0xFFu64) as u8
        PT[k]     = (k & 0xFFu64) as u8
        k = k + 1u64
    }

    /* Track live count growth per send/recv pair.  After warmup
     * iteration, report the count.  Stop early if count reaches 50+. */
    let mut i : u32 = 0u32
    let mut last_count : u32 = 0u32
    while i < 100u32 {
        _restore_pt()
        let sr : i32 = sc_send(ach, (&PT) as u64, 16u32, (&TAG) as u64)
        if sr != 0i32 { return (100u64 + (i as u64)) & 0xFFu64 }
        let rr : i32 = sc_recv(bch, (&PT) as u64, 16u32, (&TAG) as u64)
        if rr != 0i32 {
            /* recv failed -- report live count via packed exit code:
             * upper byte = iteration, lower byte = live count. */
            let lc : u32 = bigint_live_count()
            return ((i as u64) << 8u64) | ((lc as u64) & 0xFFu64) | 0x010000u64
        }
        last_count = bigint_live_count()
        i = i + 1u32
    }

    return (last_count as u64) & 0xFFu64
}
