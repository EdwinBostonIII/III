/* Diagnostic: indirect call to meta_dispatch_unreachable. */
module diag_indirect

extern @abi(c-msvc-x64) fn resolution_init() -> i32 from "resolution_init.iii"
extern @abi(c-msvc-x64) fn pattern_set_global() -> u64 from "pattern_table.iii"
extern @abi(c-msvc-x64) fn pattern_table_get(slot: u32) -> u64 from "pattern_table.iii"
extern @abi(c-msvc-x64) fn pattern_dispatch_fn(p: u64) -> u64 from "pattern_table.iii"
extern @abi(c-msvc-x64) fn meta_dispatch_unreachable(a: u64, b: u64, c: u64, d: u64) -> u64 from "resolution_meta_dispatch.iii"

fn main() -> u64 {
    resolution_init()
    /* Walk all 19 slots, verify each pattern's dispatch_fn points to meta_dispatch_unreachable. */
    let direct : u64 = (&meta_dispatch_unreachable) as u64
    let mut s : u32 = 0u32
    while s < 19u32 {
        let p : u64 = pattern_table_get(s)
        if p == 0u64 {
            /* slot s not registered or pid=0; encode in exit code. */
            return (10u64 + (s as u64))
        }
        let fp : u64 = pattern_dispatch_fn(p)
        if fp != direct {
            /* Mismatch -- this is our target bug.  Encode slot. */
            return (40u64 + (s as u64))
        }
        s = s + 1u32
    }
    return 99u64
}
