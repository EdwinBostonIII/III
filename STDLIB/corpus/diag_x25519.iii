/* Diag: verify x25519 ECDH symmetry — A·(B·G) == B·(A·G). */
module diag_x25519

extern @abi(c-msvc-x64) fn x25519(out: *u8, scalar: *u8, u_in: *u8) -> i32 from "x25519.iii"

var BP : [u8; 32]
var A_SK : [u8; 32]
var B_SK : [u8; 32]
var A_PK : [u8; 32]
var B_PK : [u8; 32]
var SHARED_AB : [u8; 32]   /* a_sk · b_pk */
var SHARED_BA : [u8; 32]   /* b_sk · a_pk */

fn _fill(buf: *u8, base: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < 32u64 { buf[i] = ((base + i) & 0xFFu64) as u8; i = i + 1u64 }
    return 0i32
}

fn main() -> u64 {
    let bp : *u8 = (&BP) as *u8
    bp[0u64] = 9u8
    let mut z : u64 = 1u64
    while z < 32u64 { bp[z] = 0u8; z = z + 1u64 }
    let a_sk : *u8 = (&A_SK) as *u8
    let b_sk : *u8 = (&B_SK) as *u8
    _fill(a_sk, 0x11u64)
    _fill(b_sk, 0x40u64)
    let a_pk : *u8 = (&A_PK) as *u8
    let b_pk : *u8 = (&B_PK) as *u8
    if x25519(a_pk, a_sk, bp) != 0i32 { return 1u64 }
    if x25519(b_pk, b_sk, bp) != 0i32 { return 2u64 }
    let s_ab : *u8 = (&SHARED_AB) as *u8
    let s_ba : *u8 = (&SHARED_BA) as *u8
    if x25519(s_ab, a_sk, b_pk) != 0i32 { return 3u64 }
    if x25519(s_ba, b_sk, a_pk) != 0i32 { return 4u64 }
    let mut i : u64 = 0u64
    while i < 32u64 {
        if s_ab[i] != s_ba[i] { return 10u64 + i }
        i = i + 1u64
    }
    return 99u64
}
