    SN[224u64]=(0i64-724i64) SN[225u64]=(0i64-706i64) SN[226u64]=(0i64-688i64) SN[227u64]=(0i64-669i64) SN[228u64]=(0i64-650i64) SN[229u64]=(0i64-630i64) SN[230u64]=(0i64-610i64) SN[231u64]=(0i64-590i64)
    SN[232u64]=(0i64-569i64) SN[233u64]=(0i64-548i64) SN[234u64]=(0i64-526i64) SN[235u64]=(0i64-505i64) SN[236u64]=(0i64-483i64) SN[237u64]=(0i64-460i64) SN[238u64]=(0i64-438i64) SN[239u64]=(0i64-415i64)
    SN[240u64]=(0i64-392i64) SN[241u64]=(0i64-369i64) SN[242u64]=(0i64-345i64) SN[243u64]=(0i64-321i64) SN[244u64]=(0i64-297i64) SN[245u64]=(0i64-273i64) SN[246u64]=(0i64-249i64) SN[247u64]=(0i64-224i64)
    SN[248u64]=(0i64-200i64) SN[249u64]=(0i64-175i64) SN[250u64]=(0i64-150i64) SN[251u64]=(0i64-125i64) SN[252u64]=(0i64-100i64) SN[253u64]=(0i64-75i64) SN[254u64]=(0i64-50i64) SN[255u64]=(0i64-25i64)
    return 0i32
}

fn w_strlen(s: u64) -> i64 { let p : *u8 = s as *u8   let mut i : i64 = 0i64   while p[i as u64] != 0u8 { i = i + 1i64 }   return i }
fn w_text(dc: u64, x: i32, y: i32, s: u64) -> i32 { TextOutA(dc, x, y, s, w_strlen(s) as i32)   return 0i32 }
fn w_snumtext(dc: u64, x: i32, y: i32, v: i64) -> i32 {
    if v < 0i64 { TextOutA(dc, x, y, "-" as u64, 1i32)   w_numtext(dc, x + 7i32, y, 0i64 - v) } else { w_numtext(dc, x, y, v) }
    return 0i32
}

/* the WORKBENCH readout: III's exact verdicts in words + real numbers, updated live every frame. */
fn wb_readout(dc: u64) -> i32 {
    SetTextColor(dc, 0x0080E0FFu32)
    w_text(dc, 14i32, 30i32, "[WORKBENCH]  summon & move exact constructs  ->  every interaction decided by EXACT algebra: integer + sum-of-square-roots signs (no float)" as u64)
    let sel : i64 = WB_SEL
    SetTextColor(dc, 0x00FFFFFFu32)
    w_text(dc, 14i32, 50i32, "selected:" as u64)
    if sel >= 0i64 {
        let sb : u64 = sel as u64   let k : i64 = WB_KIND[sb]
        w_text(dc, 92i32, 50i32, wb_kind_name(k))
        w_text(dc, 196i32, 50i32, "#" as u64)   w_numtext(dc, 206i32, 50i32, sel)
        w_text(dc, 236i32, 50i32, "pos (" as u64)
        w_snumtext(dc, 278i32, 50i32, WB_X[sb])   w_text(dc, 316i32, 50i32, "," as u64)
        w_snumtext(dc, 326i32, 50i32, WB_Y[sb])   w_text(dc, 364i32, 50i32, "," as u64)
        w_snumtext(dc, 374i32, 50i32, WB_Z[sb])   w_text(dc, 412i32, 50i32, ")" as u64)
    } else { w_text(dc, 92i32, 50i32, "(none - press Tab or add one)" as u64) }

    let yl0 : i32 = (VW_H - 96i64) as i32
    let yl1 : i32 = (VW_H - 76i64) as i32
    let yl2 : i32 = (VW_H - 56i64) as i32

    SetTextColor(dc, 0x0066FF88u32)
    w_text(dc, 14i32, yl0, "COLLISION (sphere, exact):" as u64)
    let ca : i64 = WB_CA
    if ca >= 0i64 {
        w_text(dc, 236i32, yl0, "sphere #" as u64)   w_numtext(dc, 300i32, yl0, WB_CA)
        w_text(dc, 322i32, yl0, "vs #" as u64)       w_numtext(dc, 356i32, yl0, WB_CB)
        let cst : i64 = WB_CST
        if cst > 0i64 { SetTextColor(dc, 0x0080FF80u32)   w_text(dc, 386i32, yl0, "SEPARATED   gap^2 =" as u64)   w_numtext(dc, 526i32, yl0, WB_CPEN) }
        if cst == 0i64 { SetTextColor(dc, 0x00FFFF60u32)  w_text(dc, 386i32, yl0, "TOUCHING  (exact tangency)" as u64) }
        if cst < 0i64 { SetTextColor(dc, 0x00FF6060u32)   w_text(dc, 386i32, yl0, "OVERLAPPING   depth^2 =" as u64)   let pen : i64 = 0i64 - WB_CPEN   w_numtext(dc, 560i32, yl0, pen) }
    } else { SetTextColor(dc, 0x00708090u32)   w_text(dc, 236i32, yl0, "add 2+ spheres (press S) and slide one into the other" as u64) }

    SetTextColor(dc, 0x00FFE24Du32)
    w_text(dc, 14i32, yl1, "PHOTON (Sqrt-sum exact depth order):" as u64)
    let hp : i64 = WB_HP
    if hp >= 0i64 {
        w_text(dc, 300i32, yl1, "photon #" as u64)   w_numtext(dc, 366i32, yl1, WB_HP)
        let ho : i64 = WB_HO
        if ho >= 0i64 { SetTextColor(dc, 0x00FFD0A0u32)   w_text(dc, 392i32, yl1, "->  nearest hit = sphere #" as u64)   w_numtext(dc, 600i32, yl1, WB_HO)   w_text(dc, 626i32, yl1, "(exact Sqrt-sum ordering, no float)" as u64) }
        else { SetTextColor(dc, 0x00A09070u32)   w_text(dc, 392i32, yl1, "->  no sphere in its path" as u64) }
    } else { SetTextColor(dc, 0x00A09070u32)   w_text(dc, 300i32, yl1, "press P to fire a photon into the scene" as u64) }

    SetTextColor(dc, 0x00C0A0FFu32)
    w_text(dc, 14i32, yl2, "CALC (Sqrt-sum exact relay):" as u64)
    let xst : i64 = WB_XST
    if xst == 3i64 { SetTextColor(dc, 0x00807090u32)   w_text(dc, 236i32, yl2, "need >=4 constructs for a relay measurement (press X to draw the routes)" as u64) } else {
        w_text(dc, 236i32, yl2, "S->#" as u64)   w_numtext(dc, 274i32, yl2, WB_XA)
        w_text(dc, 296i32, yl2, "->T   vs   S->#" as u64)   w_numtext(dc, 416i32, yl2, WB_XB)   w_text(dc, 438i32, yl2, "->T :" as u64)
        SetTextColor(dc, 0x00E0C0FFu32)
        if xst < 0i64 { w_text(dc, 480i32, yl2, "via #" as u64)   w_numtext(dc, 520i32, yl2, WB_XA)   w_text(dc, 542i32, yl2, "is EXACTLY shorter" as u64) }
        if xst > 0i64 { w_text(dc, 480i32, yl2, "via #" as u64)   w_numtext(dc, 520i32, yl2, WB_XB)   w_text(dc, 542i32, yl2, "is EXACTLY shorter" as u64) }
        if xst == 0i64 { w_text(dc, 480i32, yl2, "the two routes are EXACTLY equal" as u64) }
    }

    SetTextColor(dc, 0x00A0A0B0u32)
    w_text(dc, 14i32, (VW_H - 24i64) as i32, "[S]phere [E]llipsoid [P]hoton   arrows + PgUp/PgDn move   [G/H] size   [X] routes   Tab select   Del remove   drag=rotate wheel=zoom   [4] atlas   [Q]uit" as u64)
    return 0i32
}

fn main() -> u64 {
    w_init_sin()
    let inst : u64 = GetModuleHandleA(0u64)
    CLS[0u64]=65u8 CLS[1u64]=87u8 CLS[2u64]=111u8 CLS[3u64]=114u8 CLS[4u64]=108u8 CLS[5u64]=100u8 CLS[6u64]=0u8   /* "AWorld" */
    TITLE[0u64]=73u8 TITLE[1u64]=73u8 TITLE[2u64]=73u8 TITLE[3u64]=32u8 TITLE[4u64]=65u8 TITLE[5u64]=69u8 TITLE[6u64]=84u8 TITLE[7u64]=72u8 TITLE[8u64]=69u8 TITLE[9u64]=82u8 TITLE[10u64]=45u8 TITLE[11u64]=87u8 TITLE[12u64]=79u8 TITLE[13u64]=82u8 TITLE[14u64]=76u8 TITLE[15u64]=68u8 TITLE[16u64]=0u8   /* "III AETHER-WORLD" */
    WC[0u64]=0u64   WC[1u64]=(&wndproc) as u64   WC[2u64]=0u64   WC[3u64]=inst   WC[4u64]=0u64   WC[5u64]=0u64   WC[6u64]=0u64   WC[7u64]=0u64   WC[8u64]=(&CLS) as u64
    RegisterClassA((&WC) as u64)
    let hwnd : u64 = CreateWindowExA(0u32, (&CLS) as u64, (&TITLE) as u64, 0x10CF0000u32, 90i32, 90i32, 1000i32, 720i32, 0u64, 0u64, inst, 0u64)
    if hwnd == 0u64 { return 1u64 }
    ShowWindow(hwnd, 5i32)
    GetClientRect(hwnd, (&RC) as u64)
    VW_W = RC[2u64] as i64   VW_H = RC[3u64] as i64
    if VW_W < 16i64 { VW_W = 960i64 }   if VW_H < 16i64 { VW_H = 680i64 }
    YAW = 32i64   PITCH = 24i64   ZOOM = 900i64   WDIST = 980i64   MODE = 0u8   VW_RUN = 1u8   NEED = 0u8   MDOWN = 0u8
    SELN = 0i64 - 1i64   NEEDCLICK = 0u8   MMOVED = 0u8   GSTAMP = 0i64
    WB_N = 0i64   WB_SEL = 0i64 - 1i64   WB_XSHOW = 0u8
    build_scene(MODE)
    let dc : u64 = GetDC(hwnd)
    SetBkMode(dc, 1i32)
    let mut guard : u64 = 0u64
    while VW_RUN == 1u8 {
        while PeekMessageA((&MSG) as u64, 0u64, 0u32, 0u32, 1u32) != 0i32 { TranslateMessage((&MSG) as u64)   DispatchMessageA((&MSG) as u64) }
        if NEED == 1u8 { build_scene(MODE)   NEED = 0u8 }
        if NEEDCLICK == 1u8 { if MODE == 4u8 { do_select() }   NEEDCLICK = 0u8 }
        render_frame()
        BMI[0u64]=40u32   BMI[1u64]=(VW_W as u32)   BMI[2u64]=(0u32 - (VW_H as u32))   BMI[3u64]=1u32 | (32u32 << 16u32)   BMI[4u64]=0u32
        BMI[5u64]=0u32 BMI[6u64]=0u32 BMI[7u64]=0u32 BMI[8u64]=0u32 BMI[9u64]=0u32
        StretchDIBits(dc, 0i32, 0i32, VW_W as i32, VW_H as i32, 0i32, 0i32, VW_W as i32, VW_H as i32, (&FB) as u64, (&BMI) as u64, 0u32, 0x00CC0020u32)
        SetTextColor(dc, 0x00FFFFFFu32)
        w_text(dc, 14i32, 10i32, "III  AETHER-WORLD   -   the sovereign exact-geometry workbench" as u64)
        SetTextColor(dc, 0x0080E0FFu32)
        if MODE == 0u8 { wb_readout(dc) }
        if MODE == 1u8 { w_text(dc, 14i32, 30i32, "[1] PHOTONIC LATTICE  +  exact O_h geodesic photon route (photon_route)   green=source  red=target" as u64) }
        if MODE == 2u8 { w_text(dc, 14i32, 30i32, "[2] EXACT SHAPES  +  sphere-minus-cylinder CSG shell decided by csg_kernel (integer-exact membership)" as u64) }
        if MODE == 3u8 { w_text(dc, 14i32, 30i32, "[3] WIREFRAME  -  cube + octahedron : edges (lines) and vertices (corners)" as u64) }
        if MODE == 4u8 {
            w_text(dc, 14i32, 30i32, "[4] SYSTEM MAP - III analysing ITSELF: 783 modules by DERIVED topological layer (bottom=foundation, top=app), size = transitive impact" as u64)
            let mut cc : i64 = 0i64
            while cc < 12i64 {
                SetTextColor(dc, CCOL[cc as u64])
                w_proj(CCX[cc as u64], CCY[cc as u64], CCZ[cc as u64])
                if PVIS == 1i32 { w_text(dc, (PX + 5i64) as i32, (PY - 7i64) as i32, sys_name(cc)) }
                cc = cc + 1i64
            }
            SetTextColor(dc, 0x00FFD24Du32)
            w_text(dc, (VW_W - 330i64) as i32, 54i32, "CORES  (most modules depend on):" as u64)
            let mut ci : u64 = 0u64
            while ci < 5u64 {
                let yy : i32 = (74i64 + (ci as i64) * 20i64) as i32
                SetTextColor(dc, 0x00FFFFFFu32)   w_text(dc, (VW_W - 318i64) as i32, yy, gr_name(CORE[ci] as u64))
                SetTextColor(dc, 0x0080E0FFu32)   w_numtext(dc, (VW_W - 96i64) as i32, yy, CIMP[ci])
                ci = ci + 1u64
            }
            let sy2 : i32 = (VW_H - 52i64) as i32
            if SELN >= 0i64 {
                SetTextColor(dc, 0x00FFFFFFu32)   w_text(dc, 14i32, (VW_H - 74i64) as i32, "SELECTED:" as u64)   w_text(dc, 100i32, (VW_H - 74i64) as i32, gr_name(SELN as u64))
                SetTextColor(dc, 0x0066FF88u32)   w_text(dc, 14i32, sy2, "needs (direct/all):" as u64)   w_numtext(dc, 190i32, sy2, OUTD[SELN as u64])   w_text(dc, 224i32, sy2, "/" as u64)   w_numtext(dc, 236i32, sy2, FOOT[SELN as u64])
                SetTextColor(dc, 0x00FF9840u32)   w_text(dc, 330i32, sy2, "depended-on (direct/all):" as u64)   w_numtext(dc, 566i32, sy2, IND[SELN as u64])   w_text(dc, 600i32, sy2, "/" as u64)   w_numtext(dc, 612i32, sy2, IMPACT[SELN as u64])
                SetTextColor(dc, 0x00FFD24Du32)   w_text(dc, 720i32, sy2, "layer:" as u64)   w_numtext(dc, 772i32, sy2, LEVEL[SELN as u64])
            } else {
                SetTextColor(dc, 0x0090A0B0u32)   w_text(dc, 14i32, sy2, "CLICK any module -> its name, what depends on it (orange cone), what it needs (green cone), and its layer" as u64)
            }
        }
        if MODE != 0u8 {
            SetTextColor(dc, 0x00A0A0B0u32)
            w_text(dc, 14i32, (VW_H - 24i64) as i32, "[0] WORKBENCH   [1] photon lattice  [2] exact shapes+CSG  [3] wireframe  [4] system atlas   drag=rotate wheel=zoom  [R] reset  [Q] quit" as u64)
        }
        Sleep(8u32)
        guard = guard + 1u64   if guard > 2000000u64 { VW_RUN = 0u8 }
    }
    ReleaseDC(hwnd, dc)
    return 0u64
}
