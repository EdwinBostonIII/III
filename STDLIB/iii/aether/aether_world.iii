/* the REAL system graph, generated from III's own source: 783 modules (nodes) + 5108 extern-dependency edges. */
extern @abi(c-msvc-x64) fn gr_nodes() -> i64 from "world_graph.iii"
extern @abi(c-msvc-x64) fn gr_edges() -> i64 from "world_graph.iii"
extern @abi(c-msvc-x64) fn gr_clu(i: u64) -> i64 from "world_graph.iii"
extern @abi(c-msvc-x64) fn gr_e0(i: u64) -> i64 from "world_graph.iii"
extern @abi(c-msvc-x64) fn gr_e1(i: u64) -> i64 from "world_graph.iii"
