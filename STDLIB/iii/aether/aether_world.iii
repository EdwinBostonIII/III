extern @abi(c-msvc-x64) fn CreateWindowExA(ex: u32, cls: u64, wname: u64, style: u32, x: i32, y: i32, w: i32, h: i32, parent: u64, menu: u64, inst: u64, param: u64) -> u64 from "user32"
extern @abi(c-msvc-x64) fn DefWindowProcA(hwnd: u64, msg: u64, wp: u64, lp: u64) -> u64 from "user32"
extern @abi(c-msvc-x64) fn ShowWindow(hwnd: u64, cmd: i32) -> i32 from "user32"
