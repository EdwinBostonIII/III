fn cf_fill_strings() -> i32 {
    /* "aether::cap_forge" (17) */
    CFORGE_STR_PROD[0] = 97u8  CFORGE_STR_PROD[1] = 101u8 CFORGE_STR_PROD[2] = 116u8 CFORGE_STR_PROD[3] = 104u8
    CFORGE_STR_PROD[4] = 101u8 CFORGE_STR_PROD[5] = 114u8 CFORGE_STR_PROD[6] = 58u8  CFORGE_STR_PROD[7] = 58u8
    CFORGE_STR_PROD[8] = 99u8  CFORGE_STR_PROD[9] = 97u8  CFORGE_STR_PROD[10] = 112u8 CFORGE_STR_PROD[11] = 95u8
    CFORGE_STR_PROD[12] = 102u8 CFORGE_STR_PROD[13] = 111u8 CFORGE_STR_PROD[14] = 114u8 CFORGE_STR_PROD[15] = 103u8
