    CFORGE_TAG_RS[16] = 116u8
    /* "restrict::op" */
    CFORGE_TAG_RO[0] = 114u8 CFORGE_TAG_RO[1] = 101u8 CFORGE_TAG_RO[2] = 115u8 CFORGE_TAG_RO[3] = 116u8
    CFORGE_TAG_RO[4] = 114u8 CFORGE_TAG_RO[5] = 105u8 CFORGE_TAG_RO[6] = 99u8  CFORGE_TAG_RO[7] = 116u8
    CFORGE_TAG_RO[8] = 58u8  CFORGE_TAG_RO[9] = 58u8  CFORGE_TAG_RO[10] = 111u8 CFORGE_TAG_RO[11] = 112u8
    /* "restrict::resource" */
    CFORGE_TAG_RR[0] = 114u8 CFORGE_TAG_RR[1] = 101u8 CFORGE_TAG_RR[2] = 115u8 CFORGE_TAG_RR[3] = 116u8
    CFORGE_TAG_RR[4] = 114u8 CFORGE_TAG_RR[5] = 105u8 CFORGE_TAG_RR[6] = 99u8  CFORGE_TAG_RR[7] = 116u8
    CFORGE_TAG_RR[8] = 58u8  CFORGE_TAG_RR[9] = 58u8  CFORGE_TAG_RR[10] = 114u8 CFORGE_TAG_RR[11] = 101u8
    CFORGE_TAG_RR[12] = 115u8 CFORGE_TAG_RR[13] = 111u8 CFORGE_TAG_RR[14] = 117u8 CFORGE_TAG_RR[15] = 114u8
    CFORGE_TAG_RR[16] = 99u8 CFORGE_TAG_RR[17] = 101u8
    /* "split::subject" */
    CFORGE_TAG_SS[0] = 115u8 CFORGE_TAG_SS[1] = 112u8 CFORGE_TAG_SS[2] = 108u8 CFORGE_TAG_SS[3] = 105u8
    CFORGE_TAG_SS[4] = 116u8 CFORGE_TAG_SS[5] = 58u8  CFORGE_TAG_SS[6] = 58u8  CFORGE_TAG_SS[7] = 115u8
