    /* "aether::cap_forge::forge" (24) */
    CFORGE_STR_FRG[0] = 97u8  CFORGE_STR_FRG[1] = 101u8 CFORGE_STR_FRG[2] = 116u8 CFORGE_STR_FRG[3] = 104u8
