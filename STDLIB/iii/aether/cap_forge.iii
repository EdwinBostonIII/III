    CFORGE_TAG_CR[0] = 99u8  CFORGE_TAG_CR[1] = 111u8 CFORGE_TAG_CR[2] = 109u8 CFORGE_TAG_CR[3] = 112u8
    CFORGE_TAG_CR[4] = 111u8 CFORGE_TAG_CR[5] = 115u8 CFORGE_TAG_CR[6] = 101u8 CFORGE_TAG_CR[7] = 58u8
    CFORGE_TAG_CR[8] = 58u8  CFORGE_TAG_CR[9] = 114u8 CFORGE_TAG_CR[10] = 101u8 CFORGE_TAG_CR[11] = 115u8
    CFORGE_TAG_CR[12] = 111u8 CFORGE_TAG_CR[13] = 117u8 CFORGE_TAG_CR[14] = 114u8 CFORGE_TAG_CR[15] = 99u8
    CFORGE_TAG_CR[16] = 101u8
    /* "restrict::subject" */
    CFORGE_TAG_RS[0] = 114u8 CFORGE_TAG_RS[1] = 101u8 CFORGE_TAG_RS[2] = 115u8 CFORGE_TAG_RS[3] = 116u8
    CFORGE_TAG_RS[4] = 114u8 CFORGE_TAG_RS[5] = 105u8 CFORGE_TAG_RS[6] = 99u8  CFORGE_TAG_RS[7] = 116u8
