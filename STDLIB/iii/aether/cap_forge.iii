    CFORGE_STR_FRG[8] = 99u8  CFORGE_STR_FRG[9] = 97u8  CFORGE_STR_FRG[10] = 112u8 CFORGE_STR_FRG[11] = 95u8
    CFORGE_STR_FRG[12] = 102u8 CFORGE_STR_FRG[13] = 111u8 CFORGE_STR_FRG[14] = 114u8 CFORGE_STR_FRG[15] = 103u8
    CFORGE_STR_FRG[16] = 101u8 CFORGE_STR_FRG[17] = 58u8 CFORGE_STR_FRG[18] = 58u8 CFORGE_STR_FRG[19] = 102u8
    CFORGE_STR_FRG[20] = 111u8 CFORGE_STR_FRG[21] = 114u8 CFORGE_STR_FRG[22] = 103u8 CFORGE_STR_FRG[23] = 101u8
    /* "aether::cap_forge::deforge" (26) */
    CFORGE_STR_DFG[0] = 97u8  CFORGE_STR_DFG[1] = 101u8 CFORGE_STR_DFG[2] = 116u8 CFORGE_STR_DFG[3] = 104u8
    CFORGE_STR_DFG[4] = 101u8 CFORGE_STR_DFG[5] = 114u8 CFORGE_STR_DFG[6] = 58u8  CFORGE_STR_DFG[7] = 58u8
    CFORGE_STR_DFG[8] = 99u8  CFORGE_STR_DFG[9] = 97u8  CFORGE_STR_DFG[10] = 112u8 CFORGE_STR_DFG[11] = 95u8
    CFORGE_STR_DFG[12] = 102u8 CFORGE_STR_DFG[13] = 111u8 CFORGE_STR_DFG[14] = 114u8 CFORGE_STR_DFG[15] = 103u8
