/* STDLIB/iii/aether/choreo.iii -- MULTI-AGENT EXACT CHOREOGRAPHY (E-IV escalation).
 *
 * N agents translate on exact linear trajectories P_i(t) = X_i + V_i t with coordinates in the
 * exact field Q(sqrt2): each scalar is (n0 + n1*sqrt2)/d, stored as an i64 triple.  On this exact
 * substrate the organ delivers three things NO floating dynamics can:
 *
 *  (1) EXACT PAIRWISE CONTACT (TOI) -- the separation of a pair is the quadratic
 *        sep2_ij(t) = |dX + dV t|^2 - (Ri+Rj)^2 = A t^2 + B t + C,   A,B,C in Q(sqrt2).
 *      HIT / GRAZE / MISS is the exact SIGN of the discriminant D = B^2 - 4AC (ch_disc_sign) --
 *      +1 two real contacts, 0 tangent (a double root), -1 never touches.  No root is approximated:
 *      the sign of a Q(sqrt2) quantity is decided by sqrt_sum_sign::ui_bsign1.  At a graze the
 *      contact time is the EXACT rational-in-sqrt2 value t* = -B/(2A) (ch_graze_time).
 *
 *  (2) CONTINUOUS TANGENCY BY ELIMINATION -- when a design parameter shifts one agent, the grazing
 *      designs are the roots of the discriminant-as-a-polynomial-in-the-design, delivered EXACTLY
 *      by numera resultant elimination Res_t(sep2, d sep2/dt) (composed in the gate, corpus 2485) --
 *      the tangency locus is an algebraic set, isolated by Sturm, not sampled.
 *
 *  (3) THE COMMUTING-EVENT PLANNER -- the multi-agent lift of gas.iii's commuting-tie theorem.
 *      A contact response is LOCAL + LINEAR: the elastic normal-velocity exchange
 *        s = ((Vi - Vj) . m) / (m . m),   Vi' = Vi - s m,   Vj' = Vj + s m,   m = Pi - Pj,
 *      which touches ONLY agents i and j (their velocity slots) and stays in Q(sqrt2) exactly.
 *      THEOREM (ch_commute): two simultaneous contacts on DISJOINT agent pairs {i,j} & {k,l} mutate
 *      disjoint velocity slots, so applying them in either order yields the BIT-IDENTICAL exact
 *      Q(sqrt2) state -- the choreography is well-defined without an ordering tie-break.  An
 *      INTERACTING tie (a shared agent) mutates a shared slot: order matters, so it is CERTIFIED
 *      and REFUSED (ch_pairs_disjoint == 0), never silently commuted.
 *
 * Public API:
 *   ch_reset() ; ch_add_agent(px0,px1,pxd, py0,py1,pyd, pz0,pz1,pzd, vx0,vx1,vxd, ...9.., r) -> i32
 *   ch_disc_sign(i,j) -> i32          (+1 hit / 0 graze / -1 miss ; -2 = degenerate A==0)
 *   ch_graze_time(i,j) -> i32         (fills CH_T = t*=-B/2A when disc==0 ; 1 ok / 0 not a graze)
 *   ch_t0()/ch_t1()/ch_td() -> i64    (the last graze time triple)
 *   ch_apply(i,j) -> i32              (elastic response ; mutates Vi,Vj)
 *   ch_vel(i, axis, k) -> i64         (k: 0=n0 1=n1 2=d ; read a velocity component)
 *   ch_pairs_disjoint(i,j,k,l) -> u8  (1 disjoint / 0 shares an agent)
 *   ch_snapshot()/ch_state_eq_snapshot() -> u8   (bit-exact whole-velocity-state compare)
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.  NIH: sqrt_sum_sign only (its sign engine).
 */
module choreo

extern @abi(c-msvc-x64) fn ui_bsign1(u: i64, v: i64, dD: i64) -> i32 from "sqrt_sum_sign.iii"

const CH_MAXN : u64 = 16u64

/* per agent: 9 position triples (3 axes x {n0,n1,d}) then 9 velocity triples ; radius integer. */
var CH_P : [i64; 144]     /* 16 agents * 9 */
var CH_V : [i64; 144]
var CH_R : [i64; 16]
var CH_N : u64 = 0u64

/* the last-computed graze time t* = (CH_T0 + CH_T1*sqrt2)/CH_TD */
var CH_T0 : i64 = 0i64   var CH_T1 : i64 = 0i64   var CH_TD : i64 = 1i64

/* whole-velocity snapshot for the commuting compare */
var CH_SNAP : [i64; 144]

/* ─── exact Q(sqrt2) scalar arithmetic on (n0,n1,d) triples, d>0 ─── */
/* results returned via the three module cells Q0,Q1,QD (single-threaded, per-op). */
var Q0 : i64 = 0i64   var Q1 : i64 = 0i64   var QD : i64 = 1i64

fn q_set(n0: i64, n1: i64, d: i64) -> i32 { Q0 = n0   Q1 = n1   QD = d   return 0i32 }

fn q_add(a0: i64, a1: i64, ad: i64, b0: i64, b1: i64, bd: i64) -> i32 {
    Q0 = (a0 * bd) + (b0 * ad)
    Q1 = (a1 * bd) + (b1 * ad)
    QD = ad * bd
    return 0i32
}
fn q_sub(a0: i64, a1: i64, ad: i64, b0: i64, b1: i64, bd: i64) -> i32 {
    Q0 = (a0 * bd) - (b0 * ad)
    Q1 = (a1 * bd) - (b1 * ad)
    QD = ad * bd
    return 0i32
}
/* (a0+a1 r2)(b0+b1 r2) = (a0 b0 + 2 a1 b1) + (a0 b1 + a1 b0) r2 ; denominators multiply. */
fn q_mul(a0: i64, a1: i64, ad: i64, b0: i64, b1: i64, bd: i64) -> i32 {
    Q0 = (a0 * b0) + (2i64 * (a1 * b1))
    Q1 = (a0 * b1) + (a1 * b0)
    QD = ad * bd
    return 0i32
}
/* sign of (n0 + n1 r2)/d for d>0 : the exact surd sign. */
fn q_sign(n0: i64, n1: i64, d: i64) -> i32 {
    let s : i32 = ui_bsign1(n0, n1, 2i64)
    if d < 0i64 { return 0i32 - s }
    return s
}
/* exact equality (a0+a1 r2)/ad == (b0+b1 r2)/bd : 1 and r2 are Q-independent, so cross-multiply
 * each coordinate.  (denominators are kept positive by construction.) */
fn q_eq(a0: i64, a1: i64, ad: i64, b0: i64, b1: i64, bd: i64) -> u8 {
    if (a0 * bd) != (b0 * ad) { return 0u8 }
    if (a1 * bd) != (b1 * ad) { return 0u8 }
    return 1u8
}

/* ─── agent construction ─── */
fn ch_reset() -> i32 @export { CH_N = 0u64   return 0i32 }

fn ch_add_agent(px0: i64, px1: i64, pxd: i64, py0: i64, py1: i64, pyd: i64, pz0: i64, pz1: i64, pzd: i64,
                vx0: i64, vx1: i64, vxd: i64, vy0: i64, vy1: i64, vyd: i64, vz0: i64, vz1: i64, vzd: i64,
                r: i64) -> i32 @export {
    if CH_N >= CH_MAXN { return 0i32 - 1i64 as i32 }
    let b : u64 = CH_N * 9u64
    CH_P[b+0u64]=px0  CH_P[b+1u64]=px1  CH_P[b+2u64]=pxd
    CH_P[b+3u64]=py0  CH_P[b+4u64]=py1  CH_P[b+5u64]=pyd
    CH_P[b+6u64]=pz0  CH_P[b+7u64]=pz1  CH_P[b+8u64]=pzd
    CH_V[b+0u64]=vx0  CH_V[b+1u64]=vx1  CH_V[b+2u64]=vxd
    CH_V[b+3u64]=vy0  CH_V[b+4u64]=vy1  CH_V[b+5u64]=vyd
    CH_V[b+6u64]=vz0  CH_V[b+7u64]=vz1  CH_V[b+8u64]=vzd
    CH_R[CH_N] = r
    CH_N = CH_N + 1u64
    return 0i32
}

/* dX_axis = X_i - X_j  (into Q0,Q1,QD) */
fn ch_dP(i: u64, j: u64, axis: u64) -> i32 {
    let bi : u64 = i * 9u64 + axis * 3u64
    let bj : u64 = j * 9u64 + axis * 3u64
    return q_sub(CH_P[bi], CH_P[bi+1u64], CH_P[bi+2u64], CH_P[bj], CH_P[bj+1u64], CH_P[bj+2u64])
}
fn ch_dV(i: u64, j: u64, axis: u64) -> i32 {
    let bi : u64 = i * 9u64 + axis * 3u64
    let bj : u64 = j * 9u64 + axis * 3u64
    return q_sub(CH_V[bi], CH_V[bi+1u64], CH_V[bi+2u64], CH_V[bj], CH_V[bj+1u64], CH_V[bj+2u64])
}

/* accumulate the sep^2 quadratic coefficients A=|dV|^2, B=2 dX.dV, C=|dX|^2-(Ri+Rj)^2 into
 * (A0,A1,AD)(B0,B1,BD)(C0,C1,CD). */
var CA0:i64=0i64 var CA1:i64=0i64 var CAD:i64=1i64
var CB0:i64=0i64 var CB1:i64=0i64 var CBD:i64=1i64
var CC0:i64=0i64 var CC1:i64=0i64 var CCD:i64=1i64
fn ch_build_sep(i: u64, j: u64) -> i32 {
    CA0=0i64 CA1=0i64 CAD=1i64  CB0=0i64 CB1=0i64 CBD=1i64  CC0=0i64 CC1=0i64 CCD=1i64
    let mut ax : u64 = 0u64
    while ax < 3u64 {
        /* dX, dV for this axis (recompute; single-cell Q so capture immediately) */
        ch_dP(i, j, ax)   let dx0:i64=Q0  let dx1:i64=Q1  let dxd:i64=QD
        ch_dV(i, j, ax)   let dv0:i64=Q0  let dv1:i64=Q1  let dvd:i64=QD
        /* A += dV*dV */
        q_mul(dv0,dv1,dvd, dv0,dv1,dvd)   let p0:i64=Q0 let p1:i64=Q1 let pd:i64=QD
        q_add(CA0,CA1,CAD, p0,p1,pd)   CA0=Q0 CA1=Q1 CAD=QD
        /* B += 2 dX*dV */
        q_mul(dx0,dx1,dxd, dv0,dv1,dvd)   let q0:i64=Q0 let q1:i64=Q1 let qd:i64=QD
        q_add(CB0,CB1,CBD, 2i64*q0, 2i64*q1, qd)   CB0=Q0 CB1=Q1 CBD=QD
        /* C += dX*dX */
        q_mul(dx0,dx1,dxd, dx0,dx1,dxd)   let r0:i64=Q0 let r1:i64=Q1 let rd:i64=QD
        q_add(CC0,CC1,CCD, r0,r1,rd)   CC0=Q0 CC1=Q1 CCD=QD
        ax = ax + 1u64
    }
    /* C -= (Ri+Rj)^2 (integer) */
    let rr : i64 = CH_R[i] + CH_R[j]
    q_sub(CC0,CC1,CCD, rr*rr, 0i64, 1i64)   CC0=Q0 CC1=Q1 CCD=QD
    return 0i32
}

/* discriminant sign: sign(B^2 - 4AC).  +1 hit, 0 graze, -1 miss, -2 degenerate (A==0). */
fn ch_disc_sign(i: u64, j: u64) -> i32 @export {
    ch_build_sep(i, j)
    if q_sign(CA0,CA1,CAD) == 0i32 { return 0i32 - 2i32 }         /* no relative motion */
    q_mul(CB0,CB1,CBD, CB0,CB1,CBD)   let bb0:i64=Q0 let bb1:i64=Q1 let bbd:i64=QD    /* B^2 */
    q_mul(CA0,CA1,CAD, CC0,CC1,CCD)   let ac0:i64=Q0 let ac1:i64=Q1 let acd:i64=QD    /* AC */
    q_sub(bb0,bb1,bbd, 4i64*ac0, 4i64*ac1, acd)                                       /* B^2 - 4AC */
    return q_sign(Q0, Q1, QD)
}

/* at a graze (disc==0), the contact time t* = -B/(2A) = (-B) * inv(2A). fills CH_T*. 1 ok / 0 not graze. */
fn ch_graze_time(i: u64, j: u64) -> i32 @export {
    if ch_disc_sign(i, j) != 0i32 { return 0i32 }
    ch_build_sep(i, j)
    /* t* = -B / (2A).  keep as (n0,n1,d): numer = -B * (2A conj) / (2A norm) ; do exact rationalise. */
    /* 2A = (2 CA0 + 2 CA1 r2)/CAD ; -B = (-CB0 - CB1 r2)/CBD. t* = (-B)/(2A). */
    let twoA0 : i64 = 2i64 * CA0   let twoA1 : i64 = 2i64 * CA1   let twoAd : i64 = CAD
    /* inv(2A): 1/((a0+a1 r2)/d) = d (a0 - a1 r2)/(a0^2 - 2 a1^2) */
    let norm : i64 = (twoA0 * twoA0) - (2i64 * (twoA1 * twoA1))
    /* inv2A = (twoAd*twoA0, -twoAd*twoA1, norm) */
    q_mul(0i64 - CB0, 0i64 - CB1, CBD, twoAd * twoA0, 0i64 - (twoAd * twoA1), norm)
    CH_T0 = Q0   CH_T1 = Q1   CH_TD = QD
    /* normalise sign so denominator is positive */
    if CH_TD < 0i64 { CH_T0 = 0i64 - CH_T0   CH_T1 = 0i64 - CH_T1   CH_TD = 0i64 - CH_TD }
    return 1i32
}
fn ch_t0() -> i64 @export { return CH_T0 }
fn ch_t1() -> i64 @export { return CH_T1 }
fn ch_td() -> i64 @export { return CH_TD }

/* integer sqrt: exact non-negative root if n is a perfect square, else -1. */
fn ch_isqrt(n: i64) -> i64 {
    if n < 0i64 { return 0i64 - 1i64 }
    if n == 0i64 { return 0i64 }
    let mut r : i64 = 1i64
    while (r * r) < n { r = r + 1i64 }
    if (r * r) == n { return r }
    return 0i64 - 1i64
}

/* FIRST-CONTACT time (TOI) for a HIT with RATIONAL discriminant that is a perfect square:
 * requires A,B,C rational (n1==0) so disc is rational; t = (-B - sqrt(disc))/(2A) is the earlier
 * root.  Fills CH_T* with the exact rational time.  Returns 1 on success, 0 if not an exact-square
 * rational hit (the honest refusal -- a nested-radical TOI is out of the rational fast path). */
fn ch_toi(i: u64, j: u64) -> i32 @export {
    if ch_disc_sign(i, j) != 1i32 { return 0i32 }     /* not two real contacts */
    ch_build_sep(i, j)
    if CA1 != 0i64 { return 0i32 }                     /* A must be rational */
    if CB1 != 0i64 { return 0i32 }                     /* B must be rational */
    if CC1 != 0i64 { return 0i32 }                     /* C must be rational */
    /* rational disc = B^2 - 4AC over (BD^2 vs AD*CD); put on a common scale via cross-mult.
     * Ar=CA0/CAD, Br=CB0/CBD, Cr=CC0/CCD.  Use a common denom L = CAD*CBD*CCD is overkill; instead
     * clear to integers by scaling each to the lcm.  Simplest exact route: disc_num over disc_den^2
     * is fragile; require unit denominators (the gate feeds integer A,B,C). */
    if CAD != 1i64 { return 0i32 }
    if CBD != 1i64 { return 0i32 }
    if CCD != 1i64 { return 0i32 }
    let disc : i64 = (CB0 * CB0) - (4i64 * (CA0 * CC0))
    let sq : i64 = ch_isqrt(disc)
    if sq < 0i64 { return 0i32 }                        /* not a perfect square -> nested radical */
    /* t = (-B - sqrt(disc)) / (2A) = ((-CB0 - sq)) / (2 CA0), rational */
    CH_T0 = (0i64 - CB0) - sq
    CH_T1 = 0i64
    CH_TD = 2i64 * CA0
    if CH_TD < 0i64 { CH_T0 = 0i64 - CH_T0   CH_TD = 0i64 - CH_TD }
    return 1i32
}

/* contact EXIT time for the same rational perfect-square hit: the LATER root
 * t = (-B + sqrt(disc))/(2A).  Same guards and refusals as ch_toi.  For a genuine
 * hit (disc > 0) the exit strictly follows the entry.  1 ok / 0 refused. */
fn ch_toi_exit(i: u64, j: u64) -> i32 @export {
    if ch_disc_sign(i, j) != 1i32 { return 0i32 }     /* not two real contacts */
    ch_build_sep(i, j)
    if CA1 != 0i64 { return 0i32 }                     /* A must be rational */
    if CB1 != 0i64 { return 0i32 }                     /* B must be rational */
    if CC1 != 0i64 { return 0i32 }                     /* C must be rational */
    if CAD != 1i64 { return 0i32 }
    if CBD != 1i64 { return 0i32 }
    if CCD != 1i64 { return 0i32 }
    let disc : i64 = (CB0 * CB0) - (4i64 * (CA0 * CC0))
    let sq : i64 = ch_isqrt(disc)
    if sq < 0i64 { return 0i32 }                        /* not a perfect square -> nested radical */
    /* t = (-B + sqrt(disc)) / (2A), rational */
    CH_T0 = (0i64 - CB0) + sq
    CH_T1 = 0i64
    CH_TD = 2i64 * CA0
    if CH_TD < 0i64 { CH_T0 = 0i64 - CH_T0   CH_TD = 0i64 - CH_TD }
    return 1i32
}

/* ─── the local + linear elastic response (equal agents): exchange the normal velocity component ─── */
/* s = ((Vi - Vj) . m) / (m . m), m = Pi - Pj (a Q(sqrt2) vector).  Vi -= s m ; Vj += s m. */
fn ch_apply(i: u64, j: u64) -> i32 @export {
    /* accumulate dot = (Vi-Vj).m and mm = m.m over axes, as Q(sqrt2). capture m per axis. */
    var MX : [i64; 9]                      /* m components (3 axes x triple) */
    let mut ax : u64 = 0u64
    /* dot, mm accumulators */
    let mut dot0:i64=0i64  let mut dot1:i64=0i64  let mut dotd:i64=1i64
    let mut mm0:i64=0i64   let mut mm1:i64=0i64   let mut mmd:i64=1i64
    while ax < 3u64 {
        ch_dP(i, j, ax)   let m0:i64=Q0 let m1:i64=Q1 let md:i64=QD
        MX[ax*3u64]=m0  MX[ax*3u64+1u64]=m1  MX[ax*3u64+2u64]=md
        ch_dV(i, j, ax)   let dv0:i64=Q0 let dv1:i64=Q1 let dvd:i64=QD
        q_mul(dv0,dv1,dvd, m0,m1,md)   let p0:i64=Q0 let p1:i64=Q1 let pd:i64=QD
        q_add(dot0,dot1,dotd, p0,p1,pd)   dot0=Q0 dot1=Q1 dotd=QD
        q_mul(m0,m1,md, m0,m1,md)   let r0:i64=Q0 let r1:i64=Q1 let rd:i64=QD
        q_add(mm0,mm1,mmd, r0,r1,rd)   mm0=Q0 mm1=Q1 mmd=QD
        ax = ax + 1u64
    }
    /* s = dot / mm = dot * inv(mm) */
    let norm : i64 = (mm0 * mm0) - (2i64 * (mm1 * mm1))
    q_mul(dot0,dot1,dotd, mmd * mm0, 0i64 - (mmd * mm1), norm)
    let s0:i64=Q0  let s1:i64=Q1  let sd:i64=QD
    /* Vi -= s m ; Vj += s m */
    ax = 0u64
    while ax < 3u64 {
        let m0:i64=MX[ax*3u64] let m1:i64=MX[ax*3u64+1u64] let md:i64=MX[ax*3u64+2u64]
        q_mul(s0,s1,sd, m0,m1,md)   let sm0:i64=Q0 let sm1:i64=Q1 let smd:i64=QD
        let bi:u64 = i*9u64 + ax*3u64
        let bj:u64 = j*9u64 + ax*3u64
        q_sub(CH_V[bi],CH_V[bi+1u64],CH_V[bi+2u64], sm0,sm1,smd)   CH_V[bi]=Q0 CH_V[bi+1u64]=Q1 CH_V[bi+2u64]=QD
        q_add(CH_V[bj],CH_V[bj+1u64],CH_V[bj+2u64], sm0,sm1,smd)   CH_V[bj]=Q0 CH_V[bj+1u64]=Q1 CH_V[bj+2u64]=QD
        ax = ax + 1u64
    }
    return 0i32
}

fn ch_vel(i: u64, axis: u64, k: u64) -> i64 @export { return CH_V[i*9u64 + axis*3u64 + k] }

/* two pairs are disjoint iff they share no agent. */
fn ch_pairs_disjoint(i: u64, j: u64, k: u64, l: u64) -> u8 @export {
    if i == k { return 0u8 }   if i == l { return 0u8 }
    if j == k { return 0u8 }   if j == l { return 0u8 }
    return 1u8
}

/* snapshot the whole velocity state; then compare an EVOLVED state against it EXACTLY (as Q(sqrt2)). */
fn ch_snapshot() -> i32 @export {
    let mut i : u64 = 0u64
    while i < 144u64 { CH_SNAP[i] = CH_V[i]   i = i + 1u64 }
    return 0i32
}
/* 1 iff current velocity state == the snapshot, value-for-value as exact Q(sqrt2) (n0/d, n1/d). */
fn ch_state_eq_snapshot() -> u8 @export {
    let n : u64 = CH_N * 9u64
    let mut idx : u64 = 0u64
    while idx < n {
        /* each stored scalar is (V[3k], V[3k+1]) over V[3k+2]; compare as Q(sqrt2) */
        if (idx % 3u64) == 0u64 {
            let a0:i64=CH_V[idx] let a1:i64=CH_V[idx+1u64] let ad:i64=CH_V[idx+2u64]
            let b0:i64=CH_SNAP[idx] let b1:i64=CH_SNAP[idx+1u64] let bd:i64=CH_SNAP[idx+2u64]
            if q_eq(a0,a1,ad, b0,b1,bd) == 0u8 { return 0u8 }
        }
        idx = idx + 1u64
    }
    return 1u8
}
