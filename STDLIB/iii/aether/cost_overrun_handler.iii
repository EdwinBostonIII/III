/* III/STDLIB/iii/aether/cost_overrun_handler.iii -- Layer 11, Module 81 (gospel).
 *
 * III STDLIB - aether::cost_overrun_handler
 *
 * Immune enforcement for cost-lattice boundedness (M19/W37).  The chokepoint
 * through which work whose OBSERVED 6-dim cost exceeds its DECLARED budget is
 * refused, quarantined, witnessed, and -- when structurally critical --
 * escalated toward constitutional re-ratification.  Does NOT measure cost
 * (cost_calculus, M23) nor order it (cost_lattice, M22); it ENFORCES the
 * verdict: admit iff observed <= declared componentwise; refuse otherwise.
 *
 * Severity is an exact integer band over (which dims exceeded, by what integer
 * multiple) -- never heuristic.  Escalation fires on the band of the CURRENT
 * event (a structural invariant), NEVER on an accumulated count crossing a
 * tuned bound (M3: no count-and-promote, no threshold-trigger, no learning).
 *
 * Public API:
 *   corh_init() -> i32
 *   corh_admit(op_id, declared, observed, cap) -> i32        // the W37 gate
 *   corh_on_overrun(ev, cap) -> i32                          // reactive subscriber
 *   corh_severity(declared, observed) -> i32                 // exact band classifier
 *   corh_overrun_count(op_id) -> u64
 *   corh_is_quarantined(op_id) -> u8
 *   corh_release(op_id, cap) -> i32                          // capability-gated recovery
 *   corh_reratification_pending(op_id) -> u8
 *   corh_event_count() -> u64
 *
 * Cost vector dims: 0 latency  1 throughput  2 regp  3 icache  4 dcache  5 energy
 * CRITICAL dims (compile-time, NOT learned): {0 latency, 5 energy} = CORH_CRIT_MASK.
 *
 * Hexad: kind_repair.  Ring: R0.  K: 1.00.
 * Discipline: W2 (aggregates by ptr), W8 (1024-slot bound), W12, W14, W37.
 *
 * SPEC DEVIATIONS (intent preserved):
 *   1. CORH_OP_IDS is [u64;4096] (1024 ids x 4 u64 = 32768 contiguous bytes), the
 *      proven WH_PROD_ID id-array idiom, NOT the spec's [u8;32768] (which iiis
 *      reserves at 8x = 256 KiB and whose byte-contiguity under index is the
 *      Trap-19 hazard).  Byte-pointer 32-byte ident_copy at offset slot*32.
 *   2. corh_witness_event's spec signature has 7 params (W2 violation + the Win64
 *      param-spill miscompile risk).  Refactored to 3 pointer params
 *      (op_id, declared, observed) + 4 module-staged scalars (CORH_EV_MASK/SEV/
 *      PILLAR/REVTAG) set by the caller -- non-reentrant handler, so staging is
 *      safe and W2-clean.
 *   3. corh_release serializes a zero 6-vec from CORH_ZERO_VEC ([u64;6]), not
 *      CORH_ZERO_ID ([u8;32]) -- the serializer reads 48 bytes, so a 32-byte
 *      buffer would over-read.
 */

module aether_cost_overrun_handler

extern @abi(c-msvc-x64) fn ident_zero(out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_eq(a: *u8, b: *u8) -> u8 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_copy(src: *u8, dst: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn wh_publish(producer: *u8, opid: *u8, in_commit: *u8, out_commit: *u8, revtag: u8, phase: u8, pillar: u16, antecedents: *u8, n_ante: u32, payload: *u8, payload_len: u32, out_frag_id: *u8) -> u64 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn cap_verify_rights(id: u64, required: u64) -> u8 from "capability.iii"
// OPTIONAL / NOT-YET-BUILT (no constitution provider on disk today):
// extern @abi(c-msvc-x64) fn cons_request_reratification(op_id: *u8, clause: u32, cap: u64) -> i32 from "constitution.iii"

// --- KAT-harness externs (substrate bring-up for the gated self-test) ---
extern @abi(c-msvc-x64) fn wh_init(initial_time: u64) -> i32 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent_id: u64, rights_mask: u64, expires_at: u64) -> u64 from "capability.iii"

const CORH_OK            : i32 =  0i32
const CORH_E_NULL        : i32 = -1i32
const CORH_E_NOT_INITED  : i32 = -2i32
const CORH_E_FULL        : i32 = -3i32
const CORH_E_DENIED      : i32 = -4i32
const CORH_E_OVERRUN     : i32 = -5i32
const CORH_E_QUARANTINE  : i32 = -6i32
const CORH_E_RERATIFY    : i32 = -7i32

const CORH_SEV_NONE      : i32 =  0i32
const CORH_SEV_MINOR     : i32 =  1i32
const CORH_SEV_MAJOR     : i32 =  2i32
const CORH_SEV_CRITICAL  : i32 =  3i32

const CORH_DIM           : u64 = 6u64
const CORH_SLOTS         : u64 = 1024u64
const CORH_ID_BYTES      : u64 = 32u64

const CORH_SAT           : u64 = 0xFFFFFFFFFFFFFFFFu64
const CORH_SLOT_NONE     : u32 = 0xFFFFFFFFu32
const CORH_CRIT_MASK     : u32 = 0x21u32      // dims {0 latency, 5 energy}
const CORH_ALL6_MASK     : u32 = 0x3Fu32      // all six dims exceeded
const CORH_PILLAR_OVERRUN : u16 = 0x51u16     // 81
const CORH_PILLAR_RELEASE : u16 = 0x52u16
const CORH_RIGHT_AMEND    : u64 = 0x4000u64   // == aether_capability::CAP_RIGHT_AMEND

var CORH_INITED        : u8  = 0u8
var CORH_OP_IDS        : [u64; 4096]     // 1024 ids x 4 u64 = 32768 bytes (WH_PROD_ID idiom)
var CORH_COUNTS        : [u64; 1024]
var CORH_LIVE          : [u8;  1024]
var CORH_QUARANTINE    : [u8;  1024]
var CORH_RERATIFY      : [u8;  1024]
var CORH_EVENTS        : u64 = 0u64
var CORH_LAST_MASK     : u32 = 0u32       // exceed-mask threaded from corh_severity

var CORH_PAYLOAD       : [u8;  160]       // op_id32 | mask4 | sev1 | decl48 | obs48 = 133 used
var CORH_FRAG_ID       : [u8;  32]
var CORH_ZERO_ID       : [u8;  32]
var CORH_ZERO_VEC      : [u64; 6]         // canonical zero 6-vec (release serialization)

// --- event staging (W2 fold for corh_witness_event; non-reentrant) ---
var CORH_EV_MASK       : u32 = 0u32
var CORH_EV_SEV        : i32 = 0i32
var CORH_EV_PILLAR     : u16 = 0u16
var CORH_EV_REVTAG     : u8  = 0u8

// --- self-test scratch ---
var CORH_T_OP          : [u8; 32]
var CORH_T_OP2         : [u8; 32]
var CORH_T_OP3         : [u8; 32]
var CORH_T_OP4         : [u8; 32]
var CORH_T_OPU         : [u8; 32]
var CORH_T_DECL        : [u64; 6]
var CORH_T_OK          : [u64; 6]
var CORH_T_MINOR       : [u64; 6]
var CORH_T_MAJOR       : [u64; 6]
var CORH_T_CRIT        : [u64; 6]
var CORH_T_EV          : [u8; 160]

// =========================== lifecycle ===========================

fn corh_init() -> i32 @export {
    let mut s : u64 = 0u64
    while s < CORH_SLOTS {
        CORH_LIVE[s] = 0u8
        CORH_QUARANTINE[s] = 0u8
        CORH_RERATIFY[s] = 0u8
        CORH_COUNTS[s] = 0u64
        s = s + 1u64
    }
    ident_zero((&CORH_ZERO_ID as u64) as *u8)
    CORH_EVENTS = 0u64
    CORH_LAST_MASK = 0u32
    CORH_INITED = 1u8
    return CORH_OK
}

// ----------------- internal slot registry (u32 sentinel; no i64) -----------------

fn corh_find_slot(op_id: *u8) -> u32 {
    let mut found : u32 = CORH_SLOT_NONE
    let mut i : u64 = 0u64
    while i < CORH_SLOTS {
        if found == CORH_SLOT_NONE {
            if CORH_LIVE[i] == 1u8 {
                let sp : u64 = (&CORH_OP_IDS as u64) + i * 32u64
                if ident_eq(sp as *u8, op_id) == 1u8 { found = i as u32 }
            }
        }
        i = i + 1u64
    }
    return found
}

fn corh_alloc_slot(op_id: *u8) -> u32 {
    let existing : u32 = corh_find_slot(op_id)
    if existing != CORH_SLOT_NONE { return existing }
    let mut chosen : u32 = CORH_SLOT_NONE
    let mut j : u64 = 0u64
    while j < CORH_SLOTS {
        if chosen == CORH_SLOT_NONE {
            if CORH_LIVE[j] == 0u8 { chosen = j as u32 }
        }
        j = j + 1u64
    }
    if chosen == CORH_SLOT_NONE { return CORH_SLOT_NONE }
    let cj : u64 = (chosen as u64) & 0xFFFFFFFFu64
    ident_copy(op_id, ((&CORH_OP_IDS as u64) + cj * 32u64) as *u8)
    CORH_LIVE[cj] = 1u8
    CORH_COUNTS[cj] = 0u64
    CORH_QUARANTINE[cj] = 0u8
    CORH_RERATIFY[cj] = 0u8
    return chosen
}

// ------------- exact-algebraic severity (M3/M4 core: no thresholds) -------------

fn corh_sat_mul2(x: u64) -> u64 {
    let half : u64 = CORH_SAT >> 1u64
    if x > half { return CORH_SAT }
    return x + x
}

fn corh_severity(declared: *u64, observed: *u64) -> i32 @export {
    if (declared as u64) == 0u64 { return CORH_SEV_NONE }
    if (observed as u64) == 0u64 { return CORH_SEV_NONE }
    let mut exceed_mask : u32 = 0u32
    let mut times2 : u32 = 0u32
    let mut crit2 : u32 = 0u32
    let mut k : u64 = 0u64
    while k < CORH_DIM {
        let dk : u64 = declared[k]
        let ok : u64 = observed[k]
        if ok > dk {
            let one : u32 = 1u32
            let bit : u32 = one << (k as u32)
            exceed_mask = exceed_mask | bit
            let twice : u64 = corh_sat_mul2(dk)
            if ok >= twice {
                times2 = 1u32
                let cb : u32 = (CORH_CRIT_MASK >> (k as u32)) & 1u32
                if cb == 1u32 { crit2 = 1u32 }
            }
        }
        k = k + 1u64
    }
    CORH_LAST_MASK = exceed_mask
    if exceed_mask == 0u32 { return CORH_SEV_NONE }
    if crit2 == 1u32 { return CORH_SEV_CRITICAL }
    if exceed_mask == CORH_ALL6_MASK { return CORH_SEV_CRITICAL }
    if times2 == 1u32 { return CORH_SEV_MAJOR }
    return CORH_SEV_MINOR
}

// ----------------- internal witness emit (M6/M10) -----------------

// Serialize 6 u64 from vec into CORH_PAYLOAD at byte offset base (LE byte-by-byte).
fn corh_ser_vec(vec: *u64, base: u64) -> i32 {
    let pp : *u8 = (&CORH_PAYLOAD as u64) as *u8
    let mut k : u64 = 0u64
    while k < CORH_DIM {
        let v : u64 = vec[k]
        let bo : u64 = base + k * 8u64
        let mut b : u64 = 0u64
        while b < 8u64 { pp[bo + b] = ((v >> (b * 8u64)) & 0xFFu64) as u8  b = b + 1u64 }
        k = k + 1u64
    }
    return CORH_OK
}

// W2 fold: dim_mask/severity/pillar/revtag are staged in CORH_EV_* by the caller.
fn corh_witness_event(op_id: *u8, declared: *u64, observed: *u64) -> u64 {
    let pp : *u8 = (&CORH_PAYLOAD as u64) as *u8
    let opp : *u8 = op_id
    let mut a : u64 = 0u64
    while a < 32u64 { pp[a] = opp[a]  a = a + 1u64 }
    let mask : u32 = CORH_EV_MASK
    pp[32u64] = (mask & 0xFFu32) as u8
    pp[33u64] = ((mask >> 8u32) & 0xFFu32) as u8
    pp[34u64] = ((mask >> 16u32) & 0xFFu32) as u8
    pp[35u64] = ((mask >> 24u32) & 0xFFu32) as u8
    pp[36u64] = (CORH_EV_SEV as u8)
    corh_ser_vec(declared, 37u64)
    corh_ser_vec(observed, 85u64)
    let zp : *u8 = (&CORH_ZERO_ID as u64) as *u8
    let fr : u64 = wh_publish(zp, op_id, zp, zp, CORH_EV_REVTAG, CORH_EV_SEV as u8, CORH_EV_PILLAR, zp, 0u32, pp, 133u32, (&CORH_FRAG_ID as u64) as *u8)
    if fr != CORH_SAT { CORH_EVENTS = CORH_EVENTS + 1u64 }
    return fr
}

// ----------------- internal core verdict (admit refusal-branch + on_overrun) -----------------

fn corh_handle(op_id: *u8, declared: *u64, observed: *u64, cap: u64) -> i32 {
    let vcap : u64 = cap
    let sev : i32 = corh_severity(declared, observed)
    if sev == CORH_SEV_NONE { return CORH_OK }
    let slot : u32 = corh_alloc_slot(op_id)
    if slot == CORH_SLOT_NONE { return CORH_E_FULL }
    let sj : u64 = (slot as u64) & 0xFFFFFFFFu64
    CORH_COUNTS[sj] = CORH_COUNTS[sj] + 1u64
    CORH_EV_MASK = CORH_LAST_MASK
    CORH_EV_SEV = sev
    CORH_EV_PILLAR = CORH_PILLAR_OVERRUN
    CORH_EV_REVTAG = 1u8
    corh_witness_event(op_id, declared, observed)
    if sev == CORH_SEV_MINOR { return CORH_E_OVERRUN }
    if sev == CORH_SEV_MAJOR { CORH_QUARANTINE[sj] = 1u8  return CORH_E_QUARANTINE }
    CORH_QUARANTINE[sj] = 1u8
    if cap_verify_rights(vcap, CORH_RIGHT_AMEND) == 1u8 {
        CORH_RERATIFY[sj] = 1u8
        CORH_EV_REVTAG = 0u8
        corh_witness_event(op_id, declared, observed)
        return CORH_E_RERATIFY
    }
    return CORH_E_QUARANTINE
}

// ----------------- public enforcement surface -----------------

fn corh_admit(op_id: *u8, declared: *u64, observed: *u64, cap: u64) -> i32 @export {
    let vcap : u64 = cap
    if CORH_INITED == 0u8 { return CORH_E_NOT_INITED }
    if (op_id as u64) == 0u64 { return CORH_E_NULL }
    if (declared as u64) == 0u64 { return CORH_E_NULL }
    if (observed as u64) == 0u64 { return CORH_E_NULL }
    if corh_is_quarantined(op_id) == 1u8 {
        CORH_EV_MASK = 0u32
        CORH_EV_SEV = CORH_SEV_NONE
        CORH_EV_PILLAR = CORH_PILLAR_OVERRUN
        CORH_EV_REVTAG = 1u8
        corh_witness_event(op_id, declared, observed)
        return CORH_E_QUARANTINE
    }
    return corh_handle(op_id, declared, observed, vcap)
}

fn corh_on_overrun(ev: *u8, cap: u64) -> i32 @export {
    let vcap : u64 = cap
    if CORH_INITED == 0u8 { return CORH_E_NOT_INITED }
    if (ev as u64) == 0u64 { return CORH_E_NULL }
    let evb : u64 = ev as u64
    let opp : u64 = evb
    let dcl : u64 = evb + 33u64
    let obs : u64 = evb + 81u64
    return corh_handle(opp as *u8, dcl as *u64, obs as *u64, vcap)
}

fn corh_release(op_id: *u8, cap: u64) -> i32 @export {
    let vcap : u64 = cap
    if CORH_INITED == 0u8 { return CORH_E_NOT_INITED }
    if (op_id as u64) == 0u64 { return CORH_E_NULL }
    if cap_verify_rights(vcap, CORH_RIGHT_AMEND) != 1u8 { return CORH_E_DENIED }
    let slot : u32 = corh_find_slot(op_id)
    if slot == CORH_SLOT_NONE { return CORH_E_NULL }
    let sj : u64 = (slot as u64) & 0xFFFFFFFFu64
    CORH_QUARANTINE[sj] = 0u8
    CORH_RERATIFY[sj] = 0u8
    CORH_EV_MASK = 0u32
    CORH_EV_SEV = CORH_SEV_NONE
    CORH_EV_PILLAR = CORH_PILLAR_RELEASE
    CORH_EV_REVTAG = 1u8
    corh_witness_event(op_id, (&CORH_ZERO_VEC as u64) as *u64, (&CORH_ZERO_VEC as u64) as *u64)
    return CORH_OK
}

// ----------------- queries (W10/W12) -----------------

fn corh_overrun_count(op_id: *u8) -> u64 @export {
    if CORH_INITED == 0u8 { return 0u64 }
    if (op_id as u64) == 0u64 { return 0u64 }
    let slot : u32 = corh_find_slot(op_id)
    if slot == CORH_SLOT_NONE { return 0u64 }
    let sj : u64 = (slot as u64) & 0xFFFFFFFFu64
    return CORH_COUNTS[sj]
}

fn corh_is_quarantined(op_id: *u8) -> u8 @export {
    if CORH_INITED == 0u8 { return 0u8 }
    if (op_id as u64) == 0u64 { return 0u8 }
    let slot : u32 = corh_find_slot(op_id)
    if slot == CORH_SLOT_NONE { return 0u8 }
    let sj : u64 = (slot as u64) & 0xFFFFFFFFu64
    return CORH_QUARANTINE[sj]
}

fn corh_reratification_pending(op_id: *u8) -> u8 @export {
    if CORH_INITED == 0u8 { return 0u8 }
    if (op_id as u64) == 0u64 { return 0u8 }
    let slot : u32 = corh_find_slot(op_id)
    if slot == CORH_SLOT_NONE { return 0u8 }
    let sj : u64 = (slot as u64) & 0xFFFFFFFFu64
    return CORH_RERATIFY[sj]
}

fn corh_event_count() -> u64 @export { return CORH_EVENTS }

// =========================== self-test ===========================

fn corh_st_fill_id(p: u64, b: u8) -> i32 {
    let pp : *u8 = p as *u8
    let mut i : u64 = 0u64
    while i < 32u64 { pp[i] = b  i = i + 1u64 }
    return CORH_OK
}

fn corh_st_setup_vectors() -> i32 {
    CORH_T_DECL[0u64] = 100u64  CORH_T_DECL[1u64] = 100u64  CORH_T_DECL[2u64] = 100u64
    CORH_T_DECL[3u64] = 100u64  CORH_T_DECL[4u64] = 100u64  CORH_T_DECL[5u64] = 100u64
    CORH_T_OK[0u64] = 50u64  CORH_T_OK[1u64] = 40u64  CORH_T_OK[2u64] = 10u64
    CORH_T_OK[3u64] = 10u64  CORH_T_OK[4u64] = 10u64  CORH_T_OK[5u64] = 0u64
    CORH_T_MINOR[0u64] = 150u64  CORH_T_MINOR[1u64] = 40u64  CORH_T_MINOR[2u64] = 10u64
    CORH_T_MINOR[3u64] = 10u64  CORH_T_MINOR[4u64] = 10u64  CORH_T_MINOR[5u64] = 0u64
    CORH_T_MAJOR[0u64] = 50u64  CORH_T_MAJOR[1u64] = 250u64  CORH_T_MAJOR[2u64] = 10u64
    CORH_T_MAJOR[3u64] = 10u64  CORH_T_MAJOR[4u64] = 10u64  CORH_T_MAJOR[5u64] = 0u64
    CORH_T_CRIT[0u64] = 300u64  CORH_T_CRIT[1u64] = 40u64  CORH_T_CRIT[2u64] = 10u64
    CORH_T_CRIT[3u64] = 10u64  CORH_T_CRIT[4u64] = 10u64  CORH_T_CRIT[5u64] = 0u64
    return CORH_OK
}

// Copy 6 u64 from src (*u64) to dst byte offset (LE byte-by-byte) -- builds the ev aggregate.
fn corh_st_put_vec(dst: u64, src: u64) -> i32 {
    let dp : *u8 = dst as *u8
    let sp : *u64 = src as *u64
    let mut k : u64 = 0u64
    while k < CORH_DIM {
        let v : u64 = sp[k]
        let bo : u64 = k * 8u64
        let mut b : u64 = 0u64
        while b < 8u64 { dp[bo + b] = ((v >> (b * 8u64)) & 0xFFu64) as u8  b = b + 1u64 }
        k = k + 1u64
    }
    return CORH_OK
}

// KAT-0: uninit guards (BEFORE corh_init).
fn corh_st_k0() -> u64 {
    CORH_INITED = 0u8
    let d : u64 = &CORH_T_DECL as u64
    let mn : u64 = &CORH_T_MINOR as u64
    let opp : u64 = &CORH_T_OP as u64
    if corh_admit(opp as *u8, d as *u64, mn as *u64, 1u64) != CORH_E_NOT_INITED { return 90u64 }
    if corh_on_overrun(opp as *u8, 1u64) != CORH_E_NOT_INITED { return 91u64 }
    if corh_release(opp as *u8, 1u64) != CORH_E_NOT_INITED { return 92u64 }
    return 0u64
}

// KAT-1: admit within budget + severity NONE (the W37 gate happy path).
fn corh_st_k1() -> u64 {
    corh_init()
    corh_st_fill_id(&CORH_T_OP as u64, 0x01u8)
    let opp : u64 = &CORH_T_OP as u64
    let d : u64 = &CORH_T_DECL as u64
    let ok : u64 = &CORH_T_OK as u64
    if corh_admit(opp as *u8, d as *u64, ok as *u64, 1u64) != CORH_OK { return 1u64 }
    if corh_severity(d as *u64, ok as *u64) != CORH_SEV_NONE { return 2u64 }
    if corh_overrun_count(opp as *u8) != 0u64 { return 3u64 }
    if corh_event_count() != 0u64 { return 4u64 }
    if corh_is_quarantined(opp as *u8) != 0u8 { return 5u64 }
    return 0u64
}

// KAT-2: minor overrun -> refuse, witness, no quarantine.
fn corh_st_k2() -> u64 {
    let opp : u64 = &CORH_T_OP as u64
    let d : u64 = &CORH_T_DECL as u64
    let mn : u64 = &CORH_T_MINOR as u64
    if corh_severity(d as *u64, mn as *u64) != CORH_SEV_MINOR { return 10u64 }
    if corh_admit(opp as *u8, d as *u64, mn as *u64, 1u64) != CORH_E_OVERRUN { return 11u64 }
    if corh_overrun_count(opp as *u8) != 1u64 { return 12u64 }
    if corh_event_count() != 1u64 { return 13u64 }
    if corh_is_quarantined(opp as *u8) != 0u8 { return 14u64 }
    if corh_reratification_pending(opp as *u8) != 0u8 { return 15u64 }
    return 0u64
}

// KAT-3: major overrun -> refuse + quarantine; blocks until release.
fn corh_st_k3() -> u64 {
    let opp : u64 = &CORH_T_OP as u64
    let d : u64 = &CORH_T_DECL as u64
    let mj : u64 = &CORH_T_MAJOR as u64
    let ok : u64 = &CORH_T_OK as u64
    if corh_severity(d as *u64, mj as *u64) != CORH_SEV_MAJOR { return 20u64 }
    if corh_admit(opp as *u8, d as *u64, mj as *u64, 1u64) != CORH_E_QUARANTINE { return 21u64 }
    if corh_is_quarantined(opp as *u8) != 1u8 { return 22u64 }
    if corh_overrun_count(opp as *u8) != 2u64 { return 23u64 }
    if corh_event_count() != 2u64 { return 24u64 }
    if corh_admit(opp as *u8, d as *u64, ok as *u64, 1u64) != CORH_E_QUARANTINE { return 25u64 }
    if corh_overrun_count(opp as *u8) != 2u64 { return 26u64 }
    if corh_event_count() != 3u64 { return 27u64 }
    if corh_release(opp as *u8, 1u64) != CORH_OK { return 28u64 }
    if corh_is_quarantined(opp as *u8) != 0u8 { return 29u64 }
    if corh_event_count() != 4u64 { return 30u64 }
    if corh_admit(opp as *u8, d as *u64, ok as *u64, 1u64) != CORH_OK { return 31u64 }
    return 0u64
}

// KAT-4: critical overrun -> escalation is capability-gated (M8 privilege separation).
fn corh_st_k4() -> u64 {
    let d : u64 = &CORH_T_DECL as u64
    let cr : u64 = &CORH_T_CRIT as u64
    let op2 : u64 = &CORH_T_OP2 as u64
    let op3 : u64 = &CORH_T_OP3 as u64
    corh_st_fill_id(op2, 0x02u8)
    corh_st_fill_id(op3, 0x03u8)
    let noamend : u64 = cap_attenuate(1u64, 0x0800u64, 0u64)
    if noamend == 0u64 { return 39u64 }
    if corh_severity(d as *u64, cr as *u64) != CORH_SEV_CRITICAL { return 40u64 }
    if corh_admit(op2 as *u8, d as *u64, cr as *u64, noamend) != CORH_E_QUARANTINE { return 41u64 }
    if corh_reratification_pending(op2 as *u8) != 0u8 { return 42u64 }
    if corh_is_quarantined(op2 as *u8) != 1u8 { return 43u64 }
    if corh_admit(op3 as *u8, d as *u64, cr as *u64, 1u64) != CORH_E_RERATIFY { return 44u64 }
    if corh_is_quarantined(op3 as *u8) != 1u8 { return 45u64 }
    if corh_reratification_pending(op3 as *u8) != 1u8 { return 46u64 }
    if corh_release(op3 as *u8, noamend) != CORH_E_DENIED { return 47u64 }
    if corh_release(op3 as *u8, 1u64) != CORH_OK { return 48u64 }
    if corh_reratification_pending(op3 as *u8) != 0u8 { return 49u64 }
    return 0u64
}

// KAT-5: capability-right value pin (cap with EXACTLY 0x4000 releases; without -> DENIED).
fn corh_st_k5() -> u64 {
    let d : u64 = &CORH_T_DECL as u64
    let cr : u64 = &CORH_T_CRIT as u64
    let op4 : u64 = &CORH_T_OP4 as u64
    corh_st_fill_id(op4, 0x04u8)
    let amend_only : u64 = cap_attenuate(1u64, 0x4000u64, 0u64)
    if amend_only == 0u64 { return 50u64 }
    let noamend : u64 = cap_attenuate(1u64, 0x0800u64, 0u64)
    if corh_admit(op4 as *u8, d as *u64, cr as *u64, amend_only) != CORH_E_RERATIFY { return 51u64 }
    if corh_release(op4 as *u8, amend_only) != CORH_OK { return 52u64 }
    if corh_admit(op4 as *u8, d as *u64, cr as *u64, amend_only) != CORH_E_RERATIFY { return 53u64 }
    if corh_release(op4 as *u8, noamend) != CORH_E_DENIED { return 54u64 }
    corh_release(op4 as *u8, 1u64)
    return 0u64
}

// KAT-null: null-pointer + unknown-op guards (after init).
fn corh_st_knull() -> u64 {
    let nullp : *u8 = 0u64 as *u8
    let null64 : *u64 = 0u64 as *u64
    let d : u64 = &CORH_T_DECL as u64
    let obs : u64 = &CORH_T_OK as u64
    if corh_admit(nullp, d as *u64, obs as *u64, 1u64) != CORH_E_NULL { return 70u64 }
    if corh_on_overrun(nullp, 1u64) != CORH_E_NULL { return 71u64 }
    if corh_severity(null64, obs as *u64) != CORH_SEV_NONE { return 72u64 }
    let unk : u64 = &CORH_T_OPU as u64
    corh_st_fill_id(unk, 0xEEu8)
    if corh_overrun_count(unk as *u8) != 0u64 { return 73u64 }
    if corh_is_quarantined(unk as *u8) != 0u8 { return 74u64 }
    if corh_reratification_pending(unk as *u8) != 0u8 { return 75u64 }
    return 0u64
}

// KAT-6: positive corh_on_overrun (decode + unaligned u64 read path) -> minor refuse.
fn corh_st_k6() -> u64 {
    let evp : u64 = &CORH_T_EV as u64
    let ev : *u8 = evp as *u8
    corh_st_fill_id(evp, 0x06u8)
    ev[32u64] = 0u8
    corh_st_put_vec(evp + 33u64, &CORH_T_DECL as u64)
    corh_st_put_vec(evp + 81u64, &CORH_T_MINOR as u64)
    if corh_on_overrun(ev, 1u64) != CORH_E_OVERRUN { return 80u64 }
    if corh_overrun_count(evp as *u8) != 1u64 { return 81u64 }
    return 0u64
}

fn corh_selftest() -> u64 @export {
    wh_init(0u64)
    cap_env_init()
    corh_st_setup_vectors()
    let r0 : u64 = corh_st_k0()
    if r0 != 0u64 { return r0 }
    let r1 : u64 = corh_st_k1()
    if r1 != 0u64 { return r1 }
    let r2 : u64 = corh_st_k2()
    if r2 != 0u64 { return r2 }
    let r3 : u64 = corh_st_k3()
    if r3 != 0u64 { return r3 }
    let r4 : u64 = corh_st_k4()
    if r4 != 0u64 { return r4 }
    let r5 : u64 = corh_st_k5()
    if r5 != 0u64 { return r5 }
    let rn : u64 = corh_st_knull()
    if rn != 0u64 { return rn }
    let r6 : u64 = corh_st_k6()
    if r6 != 0u64 { return r6 }
    return 99u64
}
