/* STDLIB/iii/aether/crypto_cli.iii -- iii-crypto: THE POST-QUANTUM STACK AS A STANDING TOOL.
 *
 *   iii-crypto keygen <level> <seed-file> <pk-out> <sk-out>   ML-DSA keypair (FIPS 204)
 *   iii-crypto sign   <level> <sk-file> <file> <sig-out>      sign ANY file
 *   iii-crypto verify <level> <pk-file> <file> <sig-file>     verify ANY file   (exit 0 = VALID)
 *   iii-crypto seal   <key-file> <nonce-file> <file> <out>    ChaCha20-Poly1305 AEAD encrypt
 *   iii-crypto open   <key-file> <nonce-file> <sealed> <out>  AEAD decrypt (exit 0 = AUTHENTIC)
 *   iii-crypto hash   <file>                                  SHA-256 (FIPS 180-4)
 *
 *   level: 2 = ML-DSA-44 | 3 = ML-DSA-65 | 5 = ML-DSA-87
 *
 * III's crypto is FIPS/ACVP-conformant and KAT-gated -- and, until now, reachable ONLY by writing a
 * program that links the archive.  A post-quantum signature stack you cannot point at a file is a
 * conformance exhibit, not a capability.  This is the surface: real files in, real signatures out,
 * a real exit code you can branch on.
 *
 * DETERMINISTIC KEYGEN BY DESIGN.  The seed is a FILE the caller supplies (32 bytes), not a hidden RNG:
 * a sovereign system does not ask you to trust an entropy source you cannot audit.  Feed it 32 bytes
 * from wherever your threat model says you should (`head -c 32 /dev/urandom > seed`, a hardware token,
 * a split secret).  The same seed always yields the same keypair -- reproducible, testable, auditable.
 *
 * exit 0 = success / VALID.  1 = usage.  2 = file error.  3 = crypto refused.  4 = INVALID SIGNATURE
 * or FAILED AUTHENTICATION -- the only exit code that matters, and it is distinct on purpose.
 *
 * Hexad: kind_essence.  Ring: R0.  NIH: composes numera/mldsa + numera/chacha20_poly1305 + numera/cad.
 */
module crypto_cli

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn CreateFileA(name: u64, access: u32, share: u32, sec: u64, disp: u32, flags: u32, tmpl: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn ReadFile(h: u64, buf: u64, n: u32, read: u64, ov: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn WriteFile(h: u64, buf: u64, n: u32, written: u64, ov: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn GetFileSize(h: u64, hi: u64) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn iii_mldsa_keygen(level: u64, seed: u64, pk: u64, sk: u64) -> i32 from "mldsa.iii"
extern @abi(c-msvc-x64) fn iii_mldsa_sign_sealed(level: u64, sk: u64, msg: u64, msglen: u64, sig_out: *u8, sig_len_out: *u64) -> i32 from "mldsa.iii"
extern @abi(c-msvc-x64) fn iii_mldsa_verify(level: u64, pk: u64, msg: u64, msglen: u64, sig: u64, siglen: u64) -> i32 from "mldsa.iii"
extern @abi(c-msvc-x64) fn aead_chacha20_poly1305_init(key: *u8, nonce: *u8) -> i32 from "chacha20_poly1305.iii"
extern @abi(c-msvc-x64) fn aead_chacha20_poly1305_seal(pt: *u8, pt_len: u64, ct_out: *u8, tag_out: *u8) -> i32 from "chacha20_poly1305.iii"
extern @abi(c-msvc-x64) fn aead_chacha20_poly1305_open(ct: *u8, ct_len: u64, pt_out: *u8, tag_in: *u8) -> u8 from "chacha20_poly1305.iii"
extern @abi(c-msvc-x64) fn cad_begin(suite: u32) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_payload(payload: u64, payload_len: u64) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_final(out_32: u64) -> i32 from "cad.iii"

const MSGCAP : u64 = 16777216u64        /* 16 MiB message cap (the tool reports, never truncates silently) */
const GENERIC_READ  : u32 = 2147483648u32
const GENERIC_WRITE : u32 = 1073741824u32
const OPEN_EXISTING : u32 = 3u32
const CREATE_ALWAYS : u32 = 2u32
const INVALID_H : u64 = 18446744073709551615u64

var MSG  : [u8; 16777216]
var CT   : [u8; 16777216]
var PK   : [u8; 2592]                   /* max over levels (ML-DSA-87) */
var SK   : [u8; 4896]
var SIG  : [u8; 4628]
var SEED : [u8; 32]
var KEY  : [u8; 32]
var NONCE: [u8; 12]
var TAG  : [u8; 16]
var DIG  : [u8; 32]
var NIO  : [u32; 2]
var SLQ  : [u64; 1]
var DEC  : [u8; 24]
var PROBE: [u8; 4]

fn ps(s: u64) -> u32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { putchar(p[i] as i32)  i = i + 1u64 }
    return 1u32
}
fn nl() -> u32 { putchar(10i32)  return 1u32 }
fn pd(v: u64) -> u32 {
    if v == 0u64 { putchar(48i32)  return 1u32 }
    let mut n : u64 = v
    let mut k : u64 = 0u64
    while n > 0u64 { DEC[k] = ((n % 10u64) + 48u64) as u8  n = n / 10u64  k = k + 1u64 }
    while k > 0u64 { k = k - 1u64  putchar(DEC[k] as i32) }
    return 1u32
}
fn phex32(dp: u64) -> u32 {
    let d : *u8 = dp as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        let b : u32 = d[i] as u32
        let hi : u32 = b >> 4u32
        let lo : u32 = b & 15u32
        if hi < 10u32 { putchar((48u32 + hi) as i32) } else { putchar((87u32 + hi) as i32) }
        if lo < 10u32 { putchar((48u32 + lo) as i32) } else { putchar((87u32 + lo) as i32) }
        i = i + 1u64
    }
    return nl()
}
fn streq(a: u64, b: u64) -> u32 {
    let pa : *u8 = a as *u8
    let pb : *u8 = b as *u8
    let mut i : u64 = 0u64
    while pa[i] != 0u8 {
        if pa[i] != pb[i] { return 0u32 }
        i = i + 1u64
    }
    if pb[i] != 0u8 { return 0u32 }
    return 1u32
}
fn atou(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut v : u64 = 0u64
    let mut i : u64 = 0u64
    while p[i] != 0u8 {
        if p[i] < 48u8 { return 18446744073709551615u64 }
        if p[i] > 57u8 { return 18446744073709551615u64 }
        v = (v * 10u64) + ((p[i] as u64) - 48u64)
        i = i + 1u64
    }
    return v
}

/* read a whole file into buf.  `cap` is the buffer size; a file LARGER than cap is refused (INVALID_H),
 * but a file of EXACTLY cap bytes is read cleanly -- the overflow is detected by one probing read past
 * the fill, not by pre-emptively rejecting a full buffer (the bug that treated a 32-byte seed as an error). */
fn rdfile(path: u64, buf: u64, cap: u64) -> u64 {
    let h : u64 = CreateFileA(path, GENERIC_READ, 1u32, 0u64, OPEN_EXISTING, 0u32, 0u64)
    if h == INVALID_H { return INVALID_H }
    let mut total : u64 = 0u64
    let mut going : u8 = 1u8
    while going == 1u8 {
        if total == cap {
            /* buffer full: probe for one more byte -- if it exists, the file overflows cap */
            let okp : i32 = ReadFile(h, (&PROBE) as u64, 1u32, (&NIO) as u64, 0u64)
            if okp == 0i32 { CloseHandle(h)  return INVALID_H }
            if NIO[0u64] != 0u32 { CloseHandle(h)  return INVALID_H }   /* genuine overflow */
            going = 0u8                                                  /* exactly cap: clean EOF */
        } else {
            let mut want : u64 = 65536u64
            if total + want > cap { want = cap - total }
            let ok : i32 = ReadFile(h, buf + total, want as u32, (&NIO) as u64, 0u64)
            if ok == 0i32 { CloseHandle(h)  return INVALID_H }
            let n : u32 = NIO[0u64]
            if n == 0u32 { going = 0u8 } else { total = total + (n as u64) }
        }
    }
    CloseHandle(h)
    return total
}
/* write buf[0..n) to path.  0 ok / 1 fail. */
fn wrfile(path: u64, buf: u64, n: u64) -> u32 {
    let h : u64 = CreateFileA(path, GENERIC_WRITE, 0u32, 0u64, CREATE_ALWAYS, 0u32, 0u64)
    if h == INVALID_H { return 1u32 }
    let mut done : u64 = 0u64
    while done < n {
        let mut want : u64 = 65536u64
        if done + want > n { want = n - done }
        let ok : i32 = WriteFile(h, buf + done, want as u32, (&NIO) as u64, 0u64)
        if ok == 0i32 { CloseHandle(h)  return 1u32 }
        let w : u32 = NIO[0u64]
        if w == 0u32 { CloseHandle(h)  return 1u32 }
        done = done + (w as u64)
    }
    CloseHandle(h)
    return 0u32
}

/* FIPS-204 parameter sizes per level.  0 = unsupported level. */
fn pk_bytes(level: u64) -> u64 {
    if level == 2u64 { return 1312u64 }
    if level == 3u64 { return 1952u64 }
    if level == 5u64 { return 2592u64 }
    return 0u64
}
fn sk_bytes(level: u64) -> u64 {
    if level == 2u64 { return 2560u64 }
    if level == 3u64 { return 4032u64 }
    if level == 5u64 { return 4896u64 }
    return 0u64
}
fn sig_bytes(level: u64) -> u64 {
    if level == 2u64 { return 2420u64 }
    if level == 3u64 { return 3309u64 }
    if level == 5u64 { return 4627u64 }
    return 0u64
}

fn usage() -> u64 {
    ps("iii-crypto -- the post-quantum stack, on real files (FIPS 204 ML-DSA + ChaCha20-Poly1305)\n\n" as u64)
    ps("  iii-crypto keygen <level> <seed-file> <pk-out> <sk-out>\n" as u64)
    ps("  iii-crypto sign   <level> <sk-file> <file> <sig-out>\n" as u64)
    ps("  iii-crypto verify <level> <pk-file> <file> <sig-file>     exit 0 = VALID, 4 = INVALID\n" as u64)
    ps("  iii-crypto seal   <key-file> <nonce-file> <file> <out>\n" as u64)
    ps("  iii-crypto open   <key-file> <nonce-file> <sealed> <out>  exit 0 = AUTHENTIC, 4 = FORGED\n" as u64)
    ps("  iii-crypto hash   <file>                                  SHA-256\n\n" as u64)
    ps("  level: 2 = ML-DSA-44 | 3 = ML-DSA-65 | 5 = ML-DSA-87\n" as u64)
    ps("  seed/key are FILES you supply (32 bytes) -- no hidden RNG to trust.\n" as u64)
    ps("  keygen is DETERMINISTIC in the seed: same seed, same keypair, always.\n" as u64)
    return 1u64
}

fn main(argc: i32, argv: u64) -> u64 {
    if argc < 2i32 { return usage() }
    let av : *u64 = argv as *u64
    let cmd : u64 = av[1u64]

    /* ---------------- hash ---------------- */
    if streq(cmd, "hash" as u64) == 1u32 {
        if argc < 3i32 { return usage() }
        let n : u64 = rdfile(av[2u64], (&MSG) as u64, MSGCAP)
        if n == INVALID_H { ps("iii-crypto: cannot read: " as u64)  ps(av[2u64])  nl()  return 2u64 }
        if cad_begin(0u32) != 0i32 { return 3u64 }
        if cad_payload((&MSG) as u64, n) != 0i32 { return 3u64 }
        if cad_final((&DIG) as u64) != 0i32 { return 3u64 }
        phex32((&DIG) as u64)
        return 0u64
    }

    /* ---------------- keygen ---------------- */
    if streq(cmd, "keygen" as u64) == 1u32 {
        if argc < 6i32 { return usage() }
        let lv : u64 = atou(av[2u64])
        if pk_bytes(lv) == 0u64 { ps("iii-crypto: level must be 2, 3 or 5\n" as u64)  return 1u64 }
        let sn : u64 = rdfile(av[3u64], (&SEED) as u64, 32u64)
        if sn == INVALID_H { ps("iii-crypto: cannot read seed: " as u64)  ps(av[3u64])  nl()  return 2u64 }
        if sn != 32u64 {
            ps("iii-crypto: seed must be EXACTLY 32 bytes (got " as u64)  pd(sn)  ps(")\n" as u64)
            return 2u64
        }
        if iii_mldsa_keygen(lv, (&SEED) as u64, (&PK) as u64, (&SK) as u64) != 0i32 { return 3u64 }
        if wrfile(av[4u64], (&PK) as u64, pk_bytes(lv)) != 0u32 { ps("iii-crypto: cannot write pk\n" as u64)  return 2u64 }
        if wrfile(av[5u64], (&SK) as u64, sk_bytes(lv)) != 0u32 { ps("iii-crypto: cannot write sk\n" as u64)  return 2u64 }
        ps("ML-DSA-" as u64)  pd(lv)  ps(" keypair written: pk " as u64)  pd(pk_bytes(lv))
        ps(" B, sk " as u64)  pd(sk_bytes(lv))  ps(" B (deterministic in the seed)\n" as u64)
        return 0u64
    }

    /* ---------------- sign ---------------- */
    if streq(cmd, "sign" as u64) == 1u32 {
        if argc < 6i32 { return usage() }
        let lv : u64 = atou(av[2u64])
        if pk_bytes(lv) == 0u64 { ps("iii-crypto: level must be 2, 3 or 5\n" as u64)  return 1u64 }
        let kn : u64 = rdfile(av[3u64], (&SK) as u64, 4896u64)
        if kn == INVALID_H { ps("iii-crypto: cannot read sk: " as u64)  ps(av[3u64])  nl()  return 2u64 }
        if kn != sk_bytes(lv) {
            ps("iii-crypto: sk is " as u64)  pd(kn)  ps(" B, ML-DSA-" as u64)  pd(lv)
            ps(" expects " as u64)  pd(sk_bytes(lv))  ps(" B (wrong level?)\n" as u64)
            return 2u64
        }
        let mn : u64 = rdfile(av[4u64], (&MSG) as u64, MSGCAP)
        if mn == INVALID_H { ps("iii-crypto: cannot read: " as u64)  ps(av[4u64])  nl()  return 2u64 }
        if iii_mldsa_sign_sealed(lv, (&SK) as u64, (&MSG) as u64, mn, (&SIG) as *u8, (&SLQ) as *u64) != 0i32 { return 3u64 }
        if SLQ[0u64] != sig_bytes(lv) { return 3u64 }
        if wrfile(av[5u64], (&SIG) as u64, SLQ[0u64]) != 0u32 { ps("iii-crypto: cannot write sig\n" as u64)  return 2u64 }
        ps("signed " as u64)  pd(mn)  ps(" bytes -> " as u64)  pd(SLQ[0u64])
        ps("-byte ML-DSA-" as u64)  pd(lv)  ps(" signature\n" as u64)
        return 0u64
    }

    /* ---------------- verify ---------------- */
    if streq(cmd, "verify" as u64) == 1u32 {
        if argc < 6i32 { return usage() }
        let lv : u64 = atou(av[2u64])
        if pk_bytes(lv) == 0u64 { ps("iii-crypto: level must be 2, 3 or 5\n" as u64)  return 1u64 }
        let pn : u64 = rdfile(av[3u64], (&PK) as u64, 2592u64)
        if pn == INVALID_H { ps("iii-crypto: cannot read pk: " as u64)  ps(av[3u64])  nl()  return 2u64 }
        if pn != pk_bytes(lv) {
            ps("iii-crypto: pk is " as u64)  pd(pn)  ps(" B, ML-DSA-" as u64)  pd(lv)
            ps(" expects " as u64)  pd(pk_bytes(lv))  ps(" B (wrong level?)\n" as u64)
            return 2u64
        }
        let mn : u64 = rdfile(av[4u64], (&MSG) as u64, MSGCAP)
        if mn == INVALID_H { ps("iii-crypto: cannot read: " as u64)  ps(av[4u64])  nl()  return 2u64 }
        let sn : u64 = rdfile(av[5u64], (&SIG) as u64, 4628u64)
        if sn == INVALID_H { ps("iii-crypto: cannot read sig: " as u64)  ps(av[5u64])  nl()  return 2u64 }
        if sn != sig_bytes(lv) {
            ps("INVALID: signature is " as u64)  pd(sn)  ps(" B, ML-DSA-" as u64)  pd(lv)
            ps(" signatures are " as u64)  pd(sig_bytes(lv))  ps(" B\n" as u64)
            return 4u64
        }
        if iii_mldsa_verify(lv, (&PK) as u64, (&MSG) as u64, mn, (&SIG) as u64, sn) != 0i32 {
            ps("INVALID: signature does NOT verify against this key and this file\n" as u64)
            return 4u64
        }
        ps("VALID: ML-DSA-" as u64)  pd(lv)  ps(" signature verifies (" as u64)  pd(mn)
        ps(" bytes signed)\n" as u64)
        return 0u64
    }

    /* ---------------- seal (AEAD encrypt) ----------------
     * output layout: [16-byte Poly1305 tag][ciphertext] -- the tag first, so `open` authenticates
     * BEFORE it hands a single decrypted byte to anyone. */
    if streq(cmd, "seal" as u64) == 1u32 {
        if argc < 6i32 { return usage() }
        let kn : u64 = rdfile(av[2u64], (&KEY) as u64, 32u64)
        if kn != 32u64 { ps("iii-crypto: key must be EXACTLY 32 bytes\n" as u64)  return 2u64 }
        let nn : u64 = rdfile(av[3u64], (&NONCE) as u64, 12u64)
        if nn != 12u64 { ps("iii-crypto: nonce must be EXACTLY 12 bytes (NEVER reuse one with a key)\n" as u64)  return 2u64 }
        let mn : u64 = rdfile(av[4u64], (&MSG) as u64, MSGCAP)
        if mn == INVALID_H { ps("iii-crypto: cannot read: " as u64)  ps(av[4u64])  nl()  return 2u64 }
        if aead_chacha20_poly1305_init((&KEY) as *u8, (&NONCE) as *u8) != 0i32 { return 3u64 }
        if aead_chacha20_poly1305_seal((&MSG) as *u8, mn, (&CT) as *u8, (&TAG) as *u8) != 0i32 { return 3u64 }
        /* write [tag][ct]: two writes into one file via a staging copy in MSG (already consumed) */
        let d : *u8 = (&MSG) as *u8
        let ts : *u8 = (&TAG) as *u8
        let cs : *u8 = (&CT) as *u8
        let mut i : u64 = 0u64
        while i < 16u64 { d[i] = ts[i]  i = i + 1u64 }
        i = 0u64
        while i < mn { d[16u64 + i] = cs[i]  i = i + 1u64 }
        if wrfile(av[5u64], (&MSG) as u64, mn + 16u64) != 0u32 { ps("iii-crypto: cannot write\n" as u64)  return 2u64 }
        ps("sealed " as u64)  pd(mn)  ps(" bytes -> " as u64)  pd(mn + 16u64)
        ps(" bytes (ChaCha20-Poly1305: 16-byte tag + ciphertext)\n" as u64)
        return 0u64
    }

    /* ---------------- open (AEAD decrypt + AUTHENTICATE) ---------------- */
    if streq(cmd, "open" as u64) == 1u32 {
        if argc < 6i32 { return usage() }
        let kn : u64 = rdfile(av[2u64], (&KEY) as u64, 32u64)
        if kn != 32u64 { ps("iii-crypto: key must be EXACTLY 32 bytes\n" as u64)  return 2u64 }
        let nn : u64 = rdfile(av[3u64], (&NONCE) as u64, 12u64)
        if nn != 12u64 { ps("iii-crypto: nonce must be EXACTLY 12 bytes\n" as u64)  return 2u64 }
        let fn2 : u64 = rdfile(av[4u64], (&CT) as u64, MSGCAP)
        if fn2 == INVALID_H { ps("iii-crypto: cannot read: " as u64)  ps(av[4u64])  nl()  return 2u64 }
        if fn2 < 16u64 { ps("INVALID: sealed file is too short to hold a tag\n" as u64)  return 4u64 }
        /* split [tag][ct]: AUTHENTICATE BEFORE releasing any plaintext */
        let src : *u8 = (&CT) as *u8
        let tgd : *u8 = (&TAG) as *u8
        let mut i : u64 = 0u64
        while i < 16u64 { tgd[i] = src[i]  i = i + 1u64 }
        let ctlen : u64 = fn2 - 16u64
        let dst : *u8 = (&MSG) as *u8
        i = 0u64
        while i < ctlen { dst[i] = src[16u64 + i]  i = i + 1u64 }
        if aead_chacha20_poly1305_init((&KEY) as *u8, (&NONCE) as *u8) != 0i32 { return 3u64 }
        if aead_chacha20_poly1305_open((&MSG) as *u8, ctlen, (&CT) as *u8, (&TAG) as *u8) != 1u8 {
            ps("INVALID: authentication FAILED -- tampered file, or wrong key/nonce.\n" as u64)
            ps("  (no plaintext was written)\n" as u64)
            return 4u64
        }
        if wrfile(av[5u64], (&CT) as u64, ctlen) != 0u32 { ps("iii-crypto: cannot write\n" as u64)  return 2u64 }
        ps("AUTHENTIC: opened " as u64)  pd(ctlen)  ps(" bytes (Poly1305 tag verified)\n" as u64)
        return 0u64
    }

    ps("iii-crypto: unknown command: " as u64)  ps(cmd)  nl()
    return usage()
}
