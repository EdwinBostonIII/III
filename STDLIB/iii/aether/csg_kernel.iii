/* csg_kernel.iii -- the "UNSHATTERABLE" quadric-CSG predicate layer.
 *
 * PROBLEM.  A float B-rep CAD kernel subtracts a cylinder from a sphere by TESSELLATING the intersection curve.  The
 * curve's vertices are irrational (nested radicals); float rounds them, so the sphere-mesh and cylinder-mesh disagree
 * on whether a shared vertex is ON the surface -> the meshes' predicates become mutually inconsistent (Kettner-Mehlhorn:
 * inconsistent float predicates yield combinatorially impossible topology) -> the mesh TEARS into non-manifold geometry.
 *
 * INSIGHT.  A mesh tears not because the CURVE is hard to compute but because the PREDICATES over its points disagree.
 * So the cure is EXACT PREDICATES over EXACTLY-REPRESENTED points -- computed here by COMPOSING two already-proven III
 * organs (never reimplemented):
 *   - sqrt_sum_sign.iii :: sqrtsum_lazy3  -- exact sign of Sum a_i*sqrt(b_i), CERTIFYING the on-surface zeros float
 *                                            cancels (the incidence predicate).  [gated 2121-2147]
 *   - exact_denest.iii  :: denest_r1      -- exact rank-1 tower denest: is sqrt(a+b*sqrt d) in Q(sqrt d)?  (the exact
 *                                            triple-point corner coordinate + its rank).                  [gated 2145]
 *
 * THE LOAD-BEARING REDUCTION (membership/incidence).  A boundary point of sphere∩cylinder is  p = (x0, sy*sqrt(beta),
 * sz*sqrt(gamma))  with x0,beta,gamma rational (sy,sz in {+1,-1}).  Any third integer quadric
 *   Q(x,y,z) = qa x^2 + qb y^2 + qc z^2 + qd xy + qe xz + qf yz + qg x + qh y + qi z + qj
 * evaluated at p is EXACTLY a 4-term sum of square roots:
 *   Q(p) = [qa x0^2 + qb beta + qc gamma + qg x0 + qj]      (rational part, radicand 1)
 *        + (qd x0 + qh)*sy * sqrt(beta)
 *        + (qe x0 + qi)*sz * sqrt(gamma)
 *        + qf*sy*sz     * sqrt(beta*gamma)
 * whose sign sqrtsum_lazy3 decides EXACTLY -- returning 0 iff p lies ON Q (the on-surface incidence float misses).  n<=4
 * keeps every instance far below the n>=6 arena/false-zero regime, so the substrate's one known soundness hole is untouched.
 *
 * HONEST CLAIM (not "always manifold" -- that is false).  Exact predicates kill the FLOAT-ARTIFACT tear ("vertices miss
 * each other").  They do NOT make a genuinely degenerate input manifold: a cylinder internally tangent to the sphere
 * pinches even in exact arithmetic.  What this kernel guarantees is: (a) every predicate the boundary topology depends on
 * is computed with ZERO floating-point error, so it never EMITS a float-artifact non-manifold; and (b) a genuine
 * degeneracy (tangency pinch) is DETECTED and flagged (csg_sphere_cyl_class codes 3/4), never silently corrupted.
 *
 * Hexad: kind_form (exact geometry).  Ring: R-1.  K: 1.00.  Depends only on sqrt_sum_sign + exact_denest (+ their libs). */
module csg_kernel

extern @abi(c-msvc-x64) fn sqrtsum_lazy3(a_ptr: u64, b_ptr: u64, n: u64) -> i32 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn denest_r1(a: i64, b: i64, d: i64) -> i32 from "exact_denest.iii"
extern @abi(c-msvc-x64) fn denest_x() -> i64 from "exact_denest.iii"
extern @abi(c-msvc-x64) fn denest_y() -> i64 from "exact_denest.iii"

fn csg_isign(v: i64) -> i32 { if v > 0i64 { return 1i32 }   if v < 0i64 { return 0i32 - 1i32 }   return 0i32 }
fn csg_iabs(v: i64) -> i64 { if v < 0i64 { return 0i64 - v }   return v }

/* ─── (1) RATIONAL-POINT MEMBERSHIP.  sign(Q(x,y,z)) for an integer point in an integer quadric -- inside solid = sign<=0.
 * Integer-exact within the i64 envelope: no float, so a rational grid never mis-classifies (the raster is unshatterable). */
fn csg_quadric_eval_sign(qa: i64, qb: i64, qc: i64, qd: i64, qe: i64, qf: i64, qg: i64, qh: i64, qi: i64, qj: i64, x: i64, y: i64, z: i64) -> i32 @export {
    let v : i64 = qa*x*x + qb*y*y + qc*z*z + qd*x*y + qe*x*z + qf*y*z + qg*x + qh*y + qi*z + qj
    return csg_isign(v)
}
/* inside = (Q<=0).  returns 1 (on-or-inside) / 0 (outside). */
fn csg_inside(qa: i64, qb: i64, qc: i64, qd: i64, qe: i64, qf: i64, qg: i64, qh: i64, qi: i64, qj: i64, x: i64, y: i64, z: i64) -> i32 @export {
    let s : i32 = csg_quadric_eval_sign(qa, qb, qc, qd, qe, qf, qg, qh, qi, qj, x, y, z)
    if s > 0i32 { return 0i32 }
    return 1i32
}

/* ─── (2) BOUNDARY-POINT MEMBERSHIP / INCIDENCE (the Sum-sqrt reduction).  Exact sign of Q at p=(x0, sy*sqrt beta,
 * sz*sqrt gamma) via sqrtsum_lazy3.  Returns +1 outside / 0 exactly-on-surface / -1 inside.  0 is the certified incidence
 * float cancels -- the vertex that, shared across two surface patches, keeps the mesh manifold. */
var CSG_A : [i64; 8]   var CSG_B : [i64; 8]
fn csg_surf_point_side(qa: i64, qb: i64, qc: i64, qd: i64, qe: i64, qf: i64, qg: i64, qh: i64, qi: i64, qj: i64, x0: i64, beta: i64, gamma: i64, sy: i64, sz: i64) -> i32 @export {
    let r0 : i64 = qa*x0*x0 + qb*beta + qc*gamma + qg*x0 + qj
    let cb : i64 = (qd*x0 + qh) * sy
    let cg : i64 = (qe*x0 + qi) * sz
    let cf : i64 = qf * sy * sz
    CSG_A[0u64] = r0   CSG_B[0u64] = 1i64
    CSG_A[1u64] = cb   CSG_B[1u64] = beta
    CSG_A[2u64] = cg   CSG_B[2u64] = gamma
    CSG_A[3u64] = cf   CSG_B[3u64] = beta * gamma
    return sqrtsum_lazy3((&CSG_A) as u64, (&CSG_B) as u64, 4u64)
}

/* ─── (3) SPHERE-CYLINDER DEGENERACY CLASSIFIER (rational, integer-exact).  Sphere radius R at origin; cylinder radius r,
 * axis parallel to z, offset a along x.  The tangency condition (gradient-parallel) forces the contact at y=z=0, giving
 * |a| = R +- r : a RATIONAL equality among the integer parameters -- so denesting is NOT needed here (a common miss; the
 * denest tool's real home is the corner coordinate in (4)).  Codes:
 *   2 disjoint | 3 EXTERNAL TANGENT (pinch) | 1 transverse (smooth loop) | 4 INTERNAL TANGENT (pinch) | 0 nested (no seam).
 * Codes 3 and 4 are the genuine-degeneracy FLAGS (non-manifold pinch detected, not silently corrupted). */
fn csg_sphere_cyl_class(R: i64, a: i64, r: i64) -> i32 @export {
    let aa : i64 = csg_iabs(a)
    let sumr : i64 = R + r
    let difr : i64 = csg_iabs(R - r)
    if aa > sumr { return 2i32 }
    if aa == sumr { return 3i32 }
    if aa < difr { return 0i32 }
    if aa == difr { return 4i32 }
    return 1i32
}

/* ─── (4) TRIPLE-POINT CORNER COORDINATE via rank-1 tower denest (the denest tool's genuine home).
 * For sphere x^2+y^2+z^2=R2, cylinder (x-a)^2+y^2=r2, and tilt plane z=x, the S∩C∩plane corner solves a quadratic in x,
 * so x in Q(sqrt Delta) with Delta = 2a^2 + R2 - r2.  The corner's y-coordinate then satisfies
 *   y^2 = p + q*sqrt(Delta),   p = 2*r2 - 6*a^2 - R2,   q = 4*a           (derivation: y^2 = r2 - (x-a)^2, x = -a+sqrt Delta)
 * -- a DEPTH-2 nested radical.  denest_r1 decides EXACTLY whether it COLLAPSES to Q(sqrt Delta) (a special incidence: the
 * corner is one rank lower than generic, exact coordinate = denest_x + denest_y*sqrt Delta) or forces a genuine rank-2
 * tower (the generic triple point).  This is the exact vertex a float kernel can only approximate. */
var CORNER_P : i64   var CORNER_Q : i64   var CORNER_D : i64
fn csg_sc_plane_corner(R2: i64, a: i64, r2: i64) -> i32 @export {
    CORNER_D = 2i64*a*a + R2 - r2
    CORNER_P = 2i64*r2 - 6i64*a*a - R2
    CORNER_Q = 4i64*a
    return 0i32
}
fn csg_corner_p() -> i64 @export { return CORNER_P }
fn csg_corner_q() -> i64 @export { return CORNER_Q }
fn csg_corner_delta() -> i64 @export { return CORNER_D }
/* rank of the corner coordinate sqrt(p+q*sqrt delta): 1 collapse (DN_X/DN_Y exact) | 0 genuine rank-2 | 2 out of envelope. */
fn csg_corner_rank(p: i64, q: i64, delta: i64) -> i32 @export { return denest_r1(p, q, delta) }
fn csg_corner_x() -> i64 @export { return denest_x() }
fn csg_corner_y() -> i64 @export { return denest_y() }

/* ─── (5) CSG-TREE COMBINERS over membership booleans (regularized set ops).  A-B (difference) = inside A and NOT inside B
 * -- the sphere-minus-cylinder operator.  Boundary points on ∂B belong to the result surface (regularized closure). */
fn csg_union(in_a: i32, in_b: i32) -> i32 @export { if in_a == 1i32 { return 1i32 }   if in_b == 1i32 { return 1i32 }   return 0i32 }
fn csg_intersect(in_a: i32, in_b: i32) -> i32 @export { if in_a == 1i32 { if in_b == 1i32 { return 1i32 } }   return 0i32 }
fn csg_difference(in_a: i32, in_b: i32) -> i32 @export { if in_a == 1i32 { if in_b == 0i32 { return 1i32 } }   return 0i32 }
