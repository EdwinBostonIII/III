/* STDLIB/iii/aether/csg_tree.iii -- the ALGEBRAIC BOOLEAN OPERATIONS TREE (charter Phase 5): CSG results as
 * first-class citizens, composable ad infinitum, NEVER leaving the exact algebraic domain.
 *
 * A solid is a DAG: leaves are quadrics (the 10-coefficient integer forms csg_kernel evaluates), branches are
 * union / intersect / difference.  Membership of a point is the SIGN ALGEBRA over exact leaf signs --
 *   union = min(sa, sb) . intersect = max(sa, sb) . difference = max(sa, -sb)      (-1 in / 0 on / +1 out)
 * -- so DEPTH COMPOSES BOOLEANS, NOT ARITHMETIC: nothing accumulates, and the 1000th boolean operation is
 * EXACTLY as precise as the 1st.  There is no meshing step anywhere: the geometry IS the formula, evaluated
 * per query by the same exact substrate as every other face (csg_kernel::csg_quadric_eval_sign -> integer
 * sign; the Sigma-sqrt engine underneath for on-surface algebraic points via csg_kernel's surf predicates).
 * The float failure this kills is at the LEAF: a double rounds Q(p) at 2^53, collapsing adjacent integer
 * values (R^2 vs R^2 +- 1) into one -- the exact leaf separates them at ANY magnitude (gate 2168's twin arm). */
module csg_tree

extern @abi(c-msvc-x64) fn csg_quadric_eval_sign(qa: i64, qb: i64, qc: i64, qd: i64, qe: i64, qf: i64, qg: i64, qh: i64, qi: i64, qj: i64, x: i64, y: i64, z: i64) -> i32 from "csg_kernel.iii"

const CT_MAXN : u64 = 2048u64
const CT_LEAF : i64 = 0i64
const CT_UNION : i64 = 1i64
const CT_INTER : i64 = 2i64
const CT_DIFF : i64 = 3i64
const CT_SWEPT : i64 = 4i64                   /* 4D kinematic leaf: the swept volume of a moving sphere */

var CT_KIND : [i64; 2048]
var CT_L : [i64; 2048]   var CT_R : [i64; 2048]
var CT_Q : [i64; 20480]                       /* 10 coefficients per node (leaves) */
var CT_N : u64

fn ct_reset() -> i32 @export { CT_N = 0u64   return 0i32 }
fn ct_count() -> u64 @export { return CT_N }

/* leaf: the quadric qa x^2 + qb y^2 + qc z^2 + qd xy + qe xz + qf yz + qg x + qh y + qi z + qj.  -1 = full. */
fn ct_leaf(qa: i64, qb: i64, qc: i64, qd: i64, qe: i64, qf: i64, qg: i64, qh: i64, qi: i64, qj: i64) -> i64 @export {
    if CT_N >= CT_MAXN { return 0i64 - 1i64 }
    let n : u64 = CT_N
    CT_KIND[n] = CT_LEAF
    let b : u64 = n * 10u64
    CT_Q[b] = qa   CT_Q[b + 1u64] = qb   CT_Q[b + 2u64] = qc   CT_Q[b + 3u64] = qd   CT_Q[b + 4u64] = qe
    CT_Q[b + 5u64] = qf   CT_Q[b + 6u64] = qg   CT_Q[b + 7u64] = qh   CT_Q[b + 8u64] = qi   CT_Q[b + 9u64] = qj
    CT_N = n + 1u64
    return n as i64
}

/* a convenience leaf: the sphere |p - C|^2 <= r2 (integer center, integer squared radius). */
fn ct_sphere(cx: i64, cy: i64, cz: i64, r2: i64) -> i64 @export {
    let qj : i64 = ((cx * cx) + (cy * cy) + (cz * cz)) - r2
    return ct_leaf(1i64, 1i64, 1i64, 0i64, 0i64, 0i64, 0i64 - (2i64 * cx), 0i64 - (2i64 * cy), 0i64 - (2i64 * cz), qj)
}

/* THE SWEPT LEAF (charter Program II, Phase II): the volume covered by a sphere of squared radius r2 whose
 * center moves A -> B (a ball-nose cutter pass).  Membership of p is the sign of  min_{t in [0,1]} |p-A-tD|^2 - r2
 * (D = B-A) -- an upward parabola in t, decided EXACTLY by the clamped-vertex form: interior vertex at
 * t* = (W.D)/(D.D) gives sign(|W|^2 (D.D) - (W.D)^2 - r2 (D.D)) (D.D > 0 preserves sign); clamped ends are
 * static-sphere signs.  Pure integer arithmetic -- a toolpath pass is exact at ANY t, killing the snapshot
 * approximation (a sampled tool union leaves PHANTOM MATERIAL between samples; gate 2170's twin arm).
 * ENVELOPE: |coordinates| <= 8192 and r2 <= 2^30 keep every product within i64 (documented, gate-sized). */
fn ct_swept(ax: i64, ay: i64, az: i64, bx: i64, by: i64, bz: i64, r2: i64) -> i64 @export {
    if CT_N >= CT_MAXN { return 0i64 - 1i64 }
    let n : u64 = CT_N
    CT_KIND[n] = CT_SWEPT
    let b : u64 = n * 10u64
    CT_Q[b] = ax   CT_Q[b + 1u64] = ay   CT_Q[b + 2u64] = az
    CT_Q[b + 3u64] = bx   CT_Q[b + 4u64] = by   CT_Q[b + 5u64] = bz
    CT_Q[b + 6u64] = r2   CT_Q[b + 7u64] = 0i64   CT_Q[b + 8u64] = 0i64   CT_Q[b + 9u64] = 0i64
    CT_N = n + 1u64
    return n as i64
}

fn ct_sgn(v: i64) -> i32 { if v > 0i64 { return 1i32 }   if v < 0i64 { return 0i32 - 1i32 }   return 0i32 }

fn ct_swept_side(n: u64, x: i64, y: i64, z: i64) -> i32 {
    let b : u64 = n * 10u64
    let wx : i64 = x - CT_Q[b]   let wy : i64 = y - CT_Q[b + 1u64]   let wz : i64 = z - CT_Q[b + 2u64]
    let dx : i64 = CT_Q[b + 3u64] - CT_Q[b]   let dy : i64 = CT_Q[b + 4u64] - CT_Q[b + 1u64]   let dz : i64 = CT_Q[b + 5u64] - CT_Q[b + 2u64]
    let r2 : i64 = CT_Q[b + 6u64]
    let ww : i64 = ((wx * wx) + (wy * wy)) + (wz * wz)
    let dd : i64 = ((dx * dx) + (dy * dy)) + (dz * dz)
    if dd == 0i64 { return ct_sgn(ww - r2) }                        /* degenerate sweep: a static sphere */
    let wd : i64 = ((wx * dx) + (wy * dy)) + (wz * dz)
    if wd <= 0i64 { return ct_sgn(ww - r2) }                        /* nearest at t = 0 (the A end-cap) */
    if wd >= dd {
        let ux : i64 = wx - dx   let uy : i64 = wy - dy   let uz : i64 = wz - dz
        let uu : i64 = ((ux * ux) + (uy * uy)) + (uz * uz)
        return ct_sgn(uu - r2)                                      /* nearest at t = 1 (the B end-cap) */
    }
    return ct_sgn(((ww * dd) - (wd * wd)) - (r2 * dd))              /* interior vertex, sign-preserving x dd */
}

fn ct_node(kind: i64, l: i64, r: i64) -> i64 @export {
    if CT_N >= CT_MAXN { return 0i64 - 1i64 }
    if l < 0i64 { return 0i64 - 1i64 }
    if r < 0i64 { return 0i64 - 1i64 }
    let n : u64 = CT_N
    CT_KIND[n] = kind   CT_L[n] = l   CT_R[n] = r
    CT_N = n + 1u64
    return n as i64
}
fn ct_union(l: i64, r: i64) -> i64 @export { return ct_node(CT_UNION, l, r) }
fn ct_intersect(l: i64, r: i64) -> i64 @export { return ct_node(CT_INTER, l, r) }
fn ct_difference(l: i64, r: i64) -> i64 @export { return ct_node(CT_DIFF, l, r) }

fn ct_min(a: i32, b: i32) -> i32 { if a < b { return a }   return b }
fn ct_max(a: i32, b: i32) -> i32 { if a > b { return a }   return b }

/* EXACT membership of the integer point (x,y,z) in the solid rooted at `node`: -1 inside / 0 on / +1 outside.
 * Pure sign algebra over exact leaf signs -- depth-independent precision by construction. */
fn ct_side(node: i64, x: i64, y: i64, z: i64) -> i32 @export {
    let n : u64 = node as u64
    let k : i64 = CT_KIND[n]
    if k == CT_LEAF {
        let b : u64 = n * 10u64
        return csg_quadric_eval_sign(CT_Q[b], CT_Q[b + 1u64], CT_Q[b + 2u64], CT_Q[b + 3u64], CT_Q[b + 4u64],
                                     CT_Q[b + 5u64], CT_Q[b + 6u64], CT_Q[b + 7u64], CT_Q[b + 8u64], CT_Q[b + 9u64], x, y, z)
    }
    if k == CT_SWEPT { return ct_swept_side(n, x, y, z) }
    let sl : i32 = ct_side(CT_L[n], x, y, z)
    let sr : i32 = ct_side(CT_R[n], x, y, z)
    if k == CT_UNION { return ct_min(sl, sr) }
    if k == CT_INTER { return ct_max(sl, sr) }
    return ct_max(sl, 0i32 - sr)                                    /* difference: in A and not in B */
}
