extern @abi(c-msvc-x64) fn bigint_add(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop_arena(arena: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_div_qr(arena: u64, a: u64, b: u64) -> u64 from "bigint_div.iii"
extern @abi(c-msvc-x64) fn bigint_remainder_take() -> u64 from "bigint_div.iii"

const MAXTERMS : u64 = 4096u64

var AV : [i64; 4096]      /* coefficients a_i */
var BV : [i64; 4096]      /* radicands b_i (>= 0) */
var DEC : [u8; 24]

/* --roots / --alg state: polynomials (coeff of x^i at index i), proposed intervals, multiplicities. */
var RC  : [i64; 2048]       /* polynomial A coefficients (low -> high) */
var RC2 : [i64; 2048]       /* polynomial B coefficients (--alg-cmp)   */
var ILN : [i64; 4096]   var ILD : [i64; 4096]   var IHN : [i64; 4096]   var IHD : [i64; 4096]   var IMU : [i64; 4096]
var RW2 : i64             /* bigint-certified window count */
var RSUM : i64            /* sum of certified multiplicities */
var ADG : [i64; 2]        /* --alg register degrees (for the fresh re-set) */

/* --alg-add/--alg-mul + --roots-big state: a polynomial with LIMB-ROW coefficients (sign, limb count,
 * limbs low->high at row i*64+j), the dyadic alpha/beta refinement states, the certified gamma interval. */
var GBS : [i64; 4096]   var GBL : [i64; 4096]   var GBW : [u64; 1048576]     /* row i limb j at i*256+j */
var GB2S : [i64; 4096]   var GB2L : [i64; 4096]   var GB2W : [u64; 1048576] /* --alg-cmp polynomial A rows */
var GDEG : i64
var AAL : [i64; 2]   var AAH : [i64; 2]   var AAK : i64        /* alpha/beta: (AAL/2^AAK, AAH/2^AAK] */
var GLO : i64   var GLD : i64   var GHI : i64   var GHD : i64  /* gamma: (GLO/GLD, GHI/GHD] certified */
var AZR : [u64; 2]                                             /* operand IS exactly zero (arithmetic test) */
var DECB2 : [u8; 4990]                                         /* decimal digits scratch (bigint print) */
var RB_POS : u64   var PB_SGN : i64   var PB_OK : u64   var PB_ERR : u64
var WK2L : [i64; 12288]   var WK2H : [i64; 12288]   var WK2K : [i64; 12288]
var RBCL : u64                                                 /* --roots-big cluster-at-cap flag */
var IKD : [i64; 4096]                                          /* per-interval attained dyadic depth */

/* THE DEEP-REFINEMENT TIER (the former 2^-44 wall, dissolved): dyadic windows with BIGINT
 * numerators as signed (sign, handle) pairs in their own migrating arena, counted through
 * sturm_big's handle door (root_count2_h).  Slots: 0/1 = operand A's (lo, hi], 2/3 = B's.
 * Termination is MATHEMATICAL (distinctness / nonzero-ness is proven before refinement starts);
 * the per-input separation-bound guard (CQDMAX, a Mignotte-style over-bound) can only fire on a
 * defect, and resource exhaustion is an honest named abstention -- physics, never a wrong sign. */
var CQS : [i64; 4]   var CQH : [u64; 4]
var CQAR : u64   var CQK : i64   var CQMIG : i64   var CQE : u32   var CQDMAX : i64
var CQTS : i64   var CQTH : u64                                /* signed-add result channel */

/* --roots-big DEEP CLUSTER SPLITTING: sub-2^-24 clusters split through the handle door.  Window
 * pool rows hold the L numerator (sign/len/limbs; 64 limbs = depth to ~4000 bits); the WIDTH
 * numerator W is INVARIANT down one cluster's bisection tree (both endpoints double together),
 * so H = L + W at every depth.  Deep roots print as EXACT dyadic rationals. */
var CWS : [i64; 256]   var CWL : [i64; 256]   var CWK : [i64; 256]   var CWB : [u64; 16384]
var CWN : i64
var DRS : [i64; 64]   var DRL : [i64; 64]   var DRK : [i64; 64]   var DRW : [i64; 64]
var DRB : [u64; 4096]   var DRN : i64   var DRM : [i64; 64]
var CLL : [i64; 64]   var CLH : [i64; 64]   var CLKD : [i64; 64]   var CLC : i64
var CLDR0 : [i64; 64]   var CLDRN : [i64; 64]   var CLPOS : [i64; 64]

/* the DEEP-PINNED gamma window of the arithmetic verbs (handles live in CQAR until printed) */
var DPON : u32   var DPQ : u32   var DPKD : i64
var DPLS : i64   var DPLH : u64   var DPHS : i64   var DPHH : u64
var DPLD : u64   var DPHD : u64                                /* general-rational denominators (DPQ) */

fn ps(s: u64) -> u32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { putchar(p[i] as i32)  i = i + 1u64 }
    return 1u32
}
fn nl() -> u32 { putchar(10i32)  return 1u32 }
fn pi(v: i64) -> u32 {
    if v < 0i64 { putchar(45i32)  return pi(0i64 - v) }
    if v == 0i64 { putchar(48i32)  return 1u32 }
    let mut n : u64 = v as u64
    let mut k : u64 = 0u64
    while n > 0u64 { DEC[k] = ((n % 10u64) + 48u64) as u8  n = n / 10u64  k = k + 1u64 }
    while k > 0u64 { k = k - 1u64  putchar(DEC[k] as i32) }
    return 1u32
}

/* parse a whitespace-separated list of integers (a1 b1 a2 b2 ...) starting at str into AV/BV.
 * returns the term count n, or 0xFFFFFFFF... on a parse error (odd count, bad char, negative radicand). */
const PARSEFAIL : u64 = 18446744073709551615u64
fn parse_terms(str: u64, base: u64) -> u64 {
    let p : *u8 = str as *u8
    let mut i : u64 = 0u64
    let mut nints : u64 = 0u64          /* how many integers parsed so far (into a flat a,b,a,b stream) */
    let mut n : u64 = base              /* term index */
    while p[i] != 0u8 {
        /* skip spaces / tabs */
        while p[i] == 32u8 { i = i + 1u64 }
        while p[i] == 9u8 { i = i + 1u64 }
        if p[i] == 0u8 { i = i }
        else {
            /* one signed integer */
            let mut neg : u32 = 0u32
            if p[i] == 45u8 { neg = 1u32  i = i + 1u64 }
            else { if p[i] == 43u8 { i = i + 1u64 } }
            if p[i] < 48u8 { return PARSEFAIL }
            if p[i] > 57u8 { return PARSEFAIL }
            let mut v : i64 = 0i64
            while p[i] >= 48u8 { if p[i] <= 57u8 {
                v = (v * 10i64) + ((p[i] as i64) - 48i64)
                i = i + 1u64
            } else { return PARSEFAIL } }          /* trailing garbage ("1x") is an ERROR, never a hang */
            if neg == 1u32 { v = 0i64 - v }
            /* place: even nints -> coefficient, odd -> radicand */
            if (nints & 1u64) == 0u64 {
                if n >= MAXTERMS { return PARSEFAIL }
                AV[n] = v
            } else {
                if v < 0i64 { return PARSEFAIL }        /* radicand must be >= 0 */
                BV[n] = v
                n = n + 1u64
            }
            nints = nints + 1u64
        }
    }
    if (nints & 1u64) != 0u64 { return PARSEFAIL }      /* odd number of integers: a term without its radicand */
    return n
}

fn emit_sign(sgn: i32) -> u64 {
    if sgn < 0i32 { ps("-1  (NEGATIVE)" as u64)  nl()  ps("[exact = negative]\n" as u64)  return 1u64 }
    if sgn == 0i32 { ps("0  (EXACTLY ZERO)" as u64)  nl()  ps("[exact = zero]\n" as u64)  return 0u64 }
    ps("+1  (POSITIVE)" as u64)  nl()
    ps("[exact = positive]\n" as u64)
    return 2u64
}

/* parse EXACTLY one signed integer (leading/trailing spaces ok, nothing else).  P1_OK = 1 on success. */
var P1_OK : u32
fn parse_one(str: u64) -> i64 {
    let p : *u8 = str as *u8
    let mut i : u64 = 0u64
    P1_OK = 0u32
    while p[i] == 32u8 { i = i + 1u64 }
    let mut neg : u32 = 0u32
    if p[i] == 45u8 { neg = 1u32   i = i + 1u64 }
    else { if p[i] == 43u8 { i = i + 1u64 } }
    if p[i] < 48u8 { return 0i64 }
    if p[i] > 57u8 { return 0i64 }
    let mut v : i64 = 0i64
    while p[i] >= 48u8 {
        if p[i] > 57u8 { return 0i64 }              /* trailing garbage is an ERROR, never a hang */
        v = (v * 10i64) + ((p[i] as i64) - 48i64)
        i = i + 1u64
    }
    while p[i] == 32u8 { i = i + 1u64 }
    if p[i] != 0u8 { return 0i64 }
    P1_OK = 1u32
    if neg == 1u32 { return 0i64 - v }
    return v
}

/* print " + v" or " - |v|" */
fn ppm(v: i64) -> u32 {
    if v < 0i64 { ps(" - " as u64)  pi(0i64 - v)  return 1u32 }
    ps(" + " as u64)  pi(v)
    return 1u32
}

/* --denest a b d: decide via exact_denest::denest_r1, normalize to the PRINCIPAL root, and RE-VERIFY the
 * root by exact re-squaring IN THIS PROCESS before printing any claim. */
fn emit_denest(a: i64, b: i64, d: i64) -> u64 {
    let v : i32 = denest_r1(a, b, d)
    if v == 2i32 {
        ps("ABSTAIN: outside the exact i64 envelope (need |a| < 2^30, |b| < 2^20, 0 < d < 2^20) -- refused, not guessed\n" as u64)
        return 5u64
    }
    if v == 0i32 {
        ps("NOT A SQUARE in Q(sqrt(" as u64)  pi(d)  ps(")): sqrt(" as u64)  pi(a)  ppm(b)
        ps("*sqrt(" as u64)  pi(d)  ps(")) forces a genuine field extension (rank +1)\n" as u64)
        return 4u64
    }
    let mut x : i64 = denest_x()
    let mut y : i64 = denest_y()
    /* principal root: the engine returns x >= 0; x + y*sqrt(d) is negative iff y < 0 and d*y^2 > x^2 */
    if y < 0i64 {
        let dy2 : i64 = d * (y * y)
        let x2  : i64 = x * x
        if dy2 > x2 { x = 0i64 - x   y = 0i64 - y }
    }
    /* exact re-square: (x + y*sqrt(d))^2 = (x^2 + d*y^2) + (2xy)*sqrt(d) must reproduce (a, b) */
    let ra : i64 = x * x + d * (y * y)
    let rb : i64 = 2i64 * x * y
    if ra != a { ps("INTERNAL REFUSE: recovered root does not square back -- no claim\n" as u64)  return 6u64 }
    if rb != b { ps("INTERNAL REFUSE: recovered root does not square back -- no claim\n" as u64)  return 6u64 }
    ps("PERFECT SQUARE:  sqrt(" as u64)  pi(a)  ppm(b)  ps("*sqrt(" as u64)  pi(d)
    ps("))  =  " as u64)  pi(x)  ppm(y)  ps("*sqrt(" as u64)  pi(d)
    ps(")   [re-verified exactly: root squared back to the input]\n" as u64)
    return 0u64
}

/* ── --roots / --alg shared parsing ─────────────────────────────────────────────────────────── */

/* parse a whitespace-separated list of up to 128 signed integers into dst -- each i64-EXACT
 * (overflow-guarded accumulate: a value past |i64| is a PARSEFAIL, never a silent wrap; 19
 * digits max, so the arithmetic verbs' 2^60 envelope is REACHABLE and their ABSTAIN measurable).
 * returns the count, or PARSEFAIL -- trailing garbage is an ERROR, never a hang. */
fn parse_list(str: u64, dst: u64) -> u64 {
    let p : *u8 = str as *u8
    let d : *i64 = dst as *i64
    let mut i : u64 = 0u64
    let mut n : u64 = 0u64
    while p[i] != 0u8 {
        while p[i] == 32u8 { i = i + 1u64 }
        while p[i] == 9u8 { i = i + 1u64 }
        if p[i] == 0u8 { i = i }
        else {
            let mut neg : u32 = 0u32
            if p[i] == 45u8 { neg = 1u32  i = i + 1u64 }
            else { if p[i] == 43u8 { i = i + 1u64 } }
            if p[i] < 48u8 { return PARSEFAIL }
            if p[i] > 57u8 { return PARSEFAIL }
            let mut v : i64 = 0i64
            let mut nd : u64 = 0u64
            while p[i] >= 48u8 { if p[i] <= 57u8 {
                let dg : i64 = (p[i] as i64) - 48i64
                if v > ((9223372036854775807i64 - dg) / 10i64) { return PARSEFAIL }
                v = (v * 10i64) + dg
                nd = nd + 1u64
                if nd > 19u64 { return PARSEFAIL }
                i = i + 1u64
            } else { return PARSEFAIL } }
            if neg == 1u32 { v = 0i64 - v }
            if n >= 2048u64 { return PARSEFAIL }
            d[n] = v
            n = n + 1u64
        }
    }
    return n
}

/* degree = highest nonzero coefficient index (trailing zeros trimmed), or -1 if all zero. */
fn poly_deg(dst: u64, n: u64) -> i64 {
    let d : *i64 = dst as *i64
    let mut k : i64 = (n as i64) - 1i64
    let mut done : u8 = 0u8
    while done == 0u8 {
        if k < 0i64 { done = 1u8 } else { let c : i64 = d[k as u64]   if c != 0i64 { done = 1u8 } else { k = k - 1i64 } }
    }
    return k
}

fn poly_maxabs(dst: u64, deg: i64) -> i64 {
    let d : *i64 = dst as *i64
    let mut m : i64 = 0i64
    let mut i : i64 = 0i64
    while i <= deg {
        let c : i64 = d[i as u64]
        let mut a : i64 = c
        if a < 0i64 { a = 0i64 - a }
        if a > m { m = a }
        i = i + 1i64
    }
    return m
}

/* print an exact rational n/d (den 1 prints as the integer). */
fn pr_rat(n: i64, d: i64) -> u32 {
    pi(n)
    if d != 1i64 { putchar(47i32)  pi(d) }
    return 1u32
}

/* ── --roots: certified real-root isolation ─────────────────────────────────────────────────── */

/* ascending order of proposed intervals i,j by the low endpoint (exact cross-multiplied compare;
 * coordinates pre-bounded < 2^31 so the products are exact in i64). */
fn iv_less(i: u64, j: u64) -> u32 {
    let an : i64 = ILN[i]   let ad : i64 = ILD[i]
    let bn : i64 = ILN[j]   let bd : i64 = ILD[j]
    let x : i64 = an * bd
    let y : i64 = bn * ad
    if x < y { return 1u32 }
    return 0u32
}
fn iv_swap(i: u64, j: u64) -> u32 {
    let t0 : i64 = ILN[i]   ILN[i] = ILN[j]   ILN[j] = t0
    let t1 : i64 = ILD[i]   ILD[i] = ILD[j]   ILD[j] = t1
    let t2 : i64 = IHN[i]   IHN[i] = IHN[j]   IHN[j] = t2
    let t3 : i64 = IHD[i]   IHD[i] = IHD[j]   IHD[j] = t3
    return 0u32
}

/* copy the i64 tier's proposals out of the shared engine arrays, bound every coordinate (so the
 * exact compares below cannot overflow), sort ascending, verify pairwise disjointness.
 * 9 = ok, anything else is the final exit code (message already printed). */
fn rt_gather(n1: i64) -> u64 {
    let mut i : i64 = 0i64
    while i < n1 {
        ILN[i as u64] = iso_lo_num(i as u64)   ILD[i as u64] = iso_lo_den(i as u64)
        IHN[i as u64] = iso_hi_num(i as u64)   IHD[i as u64] = iso_hi_den(i as u64)
        i = i + 1i64
    }
    i = 0i64
    while i < n1 {
        let ln : i64 = ILN[i as u64]   let ld : i64 = ILD[i as u64]
        let hn : i64 = IHN[i as u64]   let hd : i64 = IHD[i as u64]
        let mut bad : u32 = 0u32
        if ln >= 2147483648i64 { bad = 1u32 }
        if ln <= (0i64 - 2147483648i64) { bad = 1u32 }
        if hn >= 2147483648i64 { bad = 1u32 }
        if hn <= (0i64 - 2147483648i64) { bad = 1u32 }
        if ld <= 0i64 { bad = 1u32 }
        if ld >= 2147483648i64 { bad = 1u32 }
        if hd <= 0i64 { bad = 1u32 }
        if hd >= 2147483648i64 { bad = 1u32 }
        if bad == 1u32 { ps("ABSTAIN: an isolating interval left the certifiable coordinate envelope -- refused, not guessed\n" as u64)  return 5u64 }
        i = i + 1i64
    }
    i = 0i64
    while i < n1 {
        let mut best : i64 = i
        let mut j : i64 = i + 1i64
        while j < n1 {
            if iv_less(j as u64, best as u64) == 1u32 { best = j }
            j = j + 1i64
        }
        if best != i { iv_swap(i as u64, best as u64) }
        i = i + 1i64
    }
    i = 0i64
    while i < (n1 - 1i64) {
        let hn2 : i64 = IHN[i as u64]   let hd2 : i64 = IHD[i as u64]
        let ln2 : i64 = ILN[(i + 1i64) as u64]   let ld2 : i64 = ILD[(i + 1i64) as u64]
        let a : i64 = hn2 * ld2
        let b : i64 = ln2 * hd2
        if a > b { ps("INTERNAL REFUSE: proposed intervals overlap -- no claim\n" as u64)  return 6u64 }
        i = i + 1i64
    }
    return 9u64
}

/* the bigint tier: certified window count + every proposed interval re-counted through the
 * INDEPENDENT chain.  Sets RW2.  9 = ok, else the exit code. */
fn rt_certify(coeffs: u64, deg: i64, n1: i64, lo: i64, hi: i64) -> u64 {
    let bc : i64 = sturm2_build(coeffs, deg)
    if bc < 0i64 { ps("ABSTAIN: the bigint chain refused this polynomial\n" as u64)  return 5u64 }
    let w2 : i64 = root_count2(lo, 1i64, hi, 1i64)
    RW2 = w2
    if w2 < 0i64 { ps("INTERNAL REFUSE: negative certified count -- no claim\n" as u64)  return 6u64 }
    if w2 > deg { ps("INTERNAL REFUSE: certified count exceeds the degree -- no claim\n" as u64)  return 6u64 }
    let mut i : i64 = 0i64
    while i < n1 {
        let ln : i64 = ILN[i as u64]   let ld : i64 = ILD[i as u64]
        let hn : i64 = IHN[i as u64]   let hd : i64 = IHD[i as u64]
        let r : i64 = root_count2(ln, ld, hn, hd)
        if r != 1i64 { ps("INTERNAL REFUSE: a proposed interval failed the bigint recount -- no claim\n" as u64)  return 6u64 }
        i = i + 1i64
    }
    if n1 > w2 { ps("INTERNAL REFUSE: more certified-disjoint intervals than certified roots -- no claim\n" as u64)  return 6u64 }
    if n1 < w2 {
        ps("ABSTAIN: " as u64)  pi(w2)  ps(" real roots certified in the window but only " as u64)  pi(n1)
        ps(" isolated at the dyadic depth cap (a cluster tighter than 2^-24) -- refused, not guessed\n" as u64)
        return 5u64
    }
    return 9u64
}

/* per-root multiplicity through the bigint tier (root_mult2 is self-contained per call). */
fn rt_mults(coeffs: u64, deg: i64, n1: i64) -> u64 {
    RSUM = 0i64
    let mut i : i64 = 0i64
    while i < n1 {
        let ln : i64 = ILN[i as u64]   let ld : i64 = ILD[i as u64]
        let hn : i64 = IHN[i as u64]   let hd : i64 = IHD[i as u64]
        let m : i64 = root_mult2(coeffs, deg, ln, ld, hn, hd)
        if m < 1i64 { ps("INTERNAL REFUSE: multiplicity certification failed -- no claim\n" as u64)  return 6u64 }
        IMU[i as u64] = m
        RSUM = RSUM + m
        i = i + 1i64
    }
    let s : i64 = RSUM
    if s > deg { ps("INTERNAL REFUSE: multiplicities exceed the degree -- no claim\n" as u64)  return 6u64 }
    return 9u64
}

fn rt_print(n1: i64, deg: i64, lo: i64, hi: i64, wset: u32) -> u64 {
    ps("DISTINCT REAL ROOTS in (" as u64)  pi(lo)  ps(", " as u64)  pi(hi)  ps("]: " as u64)  pi(n1)
    ps("   [every claim re-certified through the independent bigint Sturm chain]\n" as u64)
    let mut i : i64 = 0i64
    while i < n1 {
        let ln : i64 = ILN[i as u64]   let ld : i64 = ILD[i as u64]
        let hn : i64 = IHN[i as u64]   let hd : i64 = IHD[i as u64]
        let m : i64 = IMU[i as u64]
        ps("  root " as u64)  pi(i + 1i64)  ps(": in (" as u64)  pr_rat(ln, ld)  ps(", " as u64)  pr_rat(hn, hd)
        ps("]   multiplicity " as u64)  pi(m)
        if (m % 2i64) == 0i64 { ps("  -- TOUCHES the axis, no sign change (invisible to every sign-sampler)\n" as u64) }
        else { ps("  -- crosses the axis\n" as u64) }
        i = i + 1i64
    }
    let s : i64 = RSUM
    ps("  with multiplicity: " as u64)  pi(s)  ps(" of degree " as u64)  pi(deg)
    let rem : i64 = deg - s
    if rem > 0i64 {
        if wset == 0u32 { ps("  (" as u64)  pi(rem)  ps(" non-real)" as u64) }
        else { ps("  (" as u64)  pi(rem)  ps(" non-real or outside the window)" as u64) }
    }
    nl()
    return 0u64
}

/* --roots: the i64 Sturm chain PROPOSES isolating intervals; the bigint chain CERTIFIES every
 * printed claim (window count, each interval's one-root recount, each multiplicity) in-process.
 * wset = 0 -> derive the window from the Cauchy bound (covers ALL real roots, strictly). */
fn emit_roots(coeffs: u64, nc: u64, wlo: i64, whi: i64, wset: u32) -> u64 {
    let deg : i64 = poly_deg(coeffs, nc)
    if deg < 0i64 { ps("iii exact: the zero polynomial (every real is a root) -- refused\n" as u64)  return 3u64 }
    if deg == 0i64 { ps("DISTINCT REAL ROOTS: 0   (nonzero constant)\n" as u64)  return 0u64 }
    if deg > 7i64 { ps("ABSTAIN: degree > 7 is outside this surface's envelope -- refused, not guessed\n" as u64)  return 5u64 }
    let mx : i64 = poly_maxabs(coeffs, deg)
    if mx >= 1048576i64 { ps("ABSTAIN: a |coefficient| >= 2^20 is outside the envelope\n" as u64)  return 5u64 }
    let mut lo : i64 = wlo
    let mut hi : i64 = whi
    if wset == 0u32 {
        let d : *i64 = coeffs as *i64
        let mut lc : i64 = d[deg as u64]
        if lc < 0i64 { lc = 0i64 - lc }
        let b : i64 = 1i64 + ((mx + lc - 1i64) / lc)      /* Cauchy: every real root has |x| < b (strict) */
        lo = 0i64 - b
        hi = b
    }
    if lo >= hi { ps("iii exact: --roots window needs lo < hi\n" as u64)  return 3u64 }
    if lo < (0i64 - 1048576i64) { ps("ABSTAIN: window endpoint outside the envelope\n" as u64)  return 5u64 }
    if hi > 1048576i64 { ps("ABSTAIN: window endpoint outside the envelope\n" as u64)  return 5u64 }
    sturm_build(coeffs, deg)
    isolate_roots(lo, hi, 24i64)
    let n1 : i64 = iso_count()
    if n1 > deg { ps("INTERNAL REFUSE: more proposed intervals than the degree -- no claim\n" as u64)  return 6u64 }
    if n1 > 0i64 {
        let g : u64 = rt_gather(n1)
        if g != 9u64 { return g }
    }
    let c : u64 = rt_certify(coeffs, deg, n1, lo, hi)
    if c != 9u64 { return c }
    if n1 == 0i64 {
        ps("DISTINCT REAL ROOTS in (" as u64)  pi(lo)  ps(", " as u64)  pi(hi)  ps("]: 0   [bigint-certified]" as u64)
        if wset == 0u32 { ps("  (all " as u64)  pi(deg)  ps(" roots non-real)" as u64) }
        nl()
        return 0u64
    }
    let mm : u64 = rt_mults(coeffs, deg, n1)
    if mm != 9u64 { return mm }
    return rt_print(n1, deg, lo, hi, wset)
}

/* ── --alg-sign / --alg-cmp: the algebraic-number order structure, surfaced ─────────────────── */

/* is this x^2 - b (monic, b > 0) on a nonnegative interval -- i.e. the principal sqrt(b)?
 * Returns b, or 0. */
fn sqrt_shape(coeffs: u64, deg: i64, lo: i64) -> i64 {
    if deg != 2i64 { return 0i64 }
    if lo < 0i64 { return 0i64 }
    let d : *i64 = coeffs as *i64
    let c2 : i64 = d[2u64]
    let c1 : i64 = d[1u64]
    let c0 : i64 = d[0u64]
    if c2 != 1i64 { return 0i64 }
    if c1 != 0i64 { return 0i64 }
    if c0 >= 0i64 { return 0i64 }
    return 0i64 - c0
}

/* (the order verbs themselves now live PAST the closure-verb helpers -- they ride the bigint
 * chain and the sturm_big pair-gcd door at the engine's full class; the algnum register file
 * remains as the gate-2157 cross-check faculty inside them.) */

/* ── --alg-add / --alg-mul / --roots-big: the closure verbs over the limb-row bridge ───────────── */

var RSO : [i64; 64]        /* rs_*_big2's i64 out[] (fitting coefficients; the limb rows carry the rest) */

fn pw2(e: i64) -> i64 {
    let mut r : i64 = 1i64
    let mut q : i64 = 0i64
    while q < e { r = r * 2i64   q = q + 1i64 }
    return r
}

/* reduced exact rational print */
fn pr_ratr(n: i64, d: i64) -> u32 {
    let mut a : i64 = n   if a < 0i64 { a = 0i64 - a }
    let mut b : i64 = d
    while b != 0i64 { let t : i64 = a % b   a = b   b = t }
    if a == 0i64 { a = 1i64 }
    pi(n / a)
    let dd : i64 = d / a
    if dd != 1i64 { putchar(47i32)  pi(dd) }
    return 1u32
}

/* load the GBS/GBL/GBW limb rows into the bigint engine's CUR input (no build). */
fn gb_load(deg: i64) -> i32 {
    if sturm2_in_begin(deg) != 0i32 { return 0i32 - 1i32 }
    let mut i : i64 = 0i64
    while i <= deg {
        let ln : i64 = GBL[i as u64]
        let mut j : i64 = 0i64
        while j < ln { sturm2_in_limb(i, j, GBW[((i * 256i64) + j) as u64])   j = j + 1i64 }
        sturm2_in_set(i, GBS[i as u64], ln)
        i = i + 1i64
    }
    return 0i32
}

/* load an i64-coefficient polynomial into the GBS/GBL/GBW limb rows (single-limb magnitudes). */
fn gb_from_i64(cptr: u64, deg: i64) -> u32 {
    let d : *i64 = cptr as *i64
    let mut i : i64 = 0i64
    while i <= deg {
        let c : i64 = d[i as u64]
        if c == 0i64 { GBS[i as u64] = 0i64   GBL[i as u64] = 0i64 }
        else {
            let mut a : i64 = c
            let mut s : i64 = 1i64
            if a < 0i64 { a = 0i64 - a   s = 0i64 - 1i64 }
            GBS[i as u64] = s
            GBL[i as u64] = 1i64
            GBW[(i * 256i64) as u64] = a as u64
        }
        i = i + 1i64
    }
    return 1u32
}
fn gb_build(deg: i64) -> i64 {
    if gb_load(deg) != 0i32 { return 0i64 - 1i64 }
    return sturm2_build_cur()
}

/* second limb-row set (polynomial A of the order verbs): stash / load / build mirrors. */
fn gb_stash2(deg: i64) -> u32 {
    let mut i : i64 = 0i64
    while i <= deg {
        GB2S[i as u64] = GBS[i as u64]
        GB2L[i as u64] = GBL[i as u64]
        let ln : i64 = GBL[i as u64]
        let mut j : i64 = 0i64
        while j < ln { GB2W[((i * 256i64) + j) as u64] = GBW[((i * 256i64) + j) as u64]   j = j + 1i64 }
        i = i + 1i64
    }
    return 1u32
}
fn gb2_load(deg: i64) -> i32 {
    if sturm2_in_begin(deg) != 0i32 { return 0i32 - 1i32 }
    let mut i : i64 = 0i64
    while i <= deg {
        let ln : i64 = GB2L[i as u64]
        let mut j : i64 = 0i64
        while j < ln { sturm2_in_limb(i, j, GB2W[((i * 256i64) + j) as u64])   j = j + 1i64 }
        sturm2_in_set(i, GB2S[i as u64], ln)
        i = i + 1i64
    }
    return 0i32
}
fn gb2_build(deg: i64) -> i64 {
    if gb2_load(deg) != 0i32 { return 0i64 - 1i64 }
    return sturm2_build_cur()
}

/* extract i64 coefficients (single-limb, |c| < 2^20) from row set `which` (1 = GB, 2 = GB2) into
 * dst -- 1 = the polynomial is inside the gate-2157 algnum class, 0 = out (arm skipped, not faked). */
fn gb_small(which: i64, deg: i64, dst: u64) -> u32 {
    let d : *i64 = dst as *i64
    let mut i : i64 = 0i64
    while i <= deg {
        let mut s : i64 = 0i64
        let mut l : i64 = 0i64
        if which == 1i64 { s = GBS[i as u64]   l = GBL[i as u64] }
        else             { s = GB2S[i as u64]  l = GB2L[i as u64] }
        if l > 1i64 { return 0u32 }
        let mut v : i64 = 0i64
        if l == 1i64 {
            let mut w : u64 = 0u64
            if which == 1i64 { w = GBW[(i * 256i64) as u64] } else { w = GB2W[(i * 256i64) as u64] }
            if w >= 1048576u64 { return 0u32 }
            v = w as i64
            if s < 0i64 { v = 0i64 - v }
        }
        d[i as u64] = v
        i = i + 1i64
    }
    return 1u32
}

/* ── THE DEEP-REFINEMENT TIER: signed bigint dyadic windows through the handle door ─────────────
 * The former 2^-44 wall was the i64 window numerator.  Numerators are now (sign, bigint-handle)
 * pairs in a migrating arena, halved through sturm_big's root_count2_h: refinement descends to
 * any depth memory affords.  CQE marks resource exhaustion (an honest named abstention); the
 * per-input separation-bound guard (CQDMAX, a Mignotte-style over-bound) can only fire on a
 * defect, because distinctness / nonzero-ness is PROVEN before refinement ever begins. */

fn c_guard(h: u64) -> u32 { if h == 0u64 { CQE = 1u32   return 0u32 }   return 1u32 }

/* (CQTS, CQTH) := (s1,m1) + (s2,m2) in CQAR (inputs untouched; the st2_sadd law) */
fn c_sadd(s1: i64, m1: u64, s2: i64, m2: u64) -> u32 {
    if s1 == 0i64 { CQTS = s2   CQTH = bigint_copy(CQAR, m2)   return c_guard(CQTH) }
    if s2 == 0i64 { CQTS = s1   CQTH = bigint_copy(CQAR, m1)   return c_guard(CQTH) }
    if s1 == s2 { CQTS = s1   CQTH = bigint_add(CQAR, m1, m2)   return c_guard(CQTH) }
    let c : i32 = bigint_cmp(m1, m2)
    if c > 0i32 { CQTS = s1   CQTH = bigint_sub(CQAR, m1, m2)   return c_guard(CQTH) }
    if c < 0i32 { CQTS = s2   CQTH = bigint_sub(CQAR, m2, m1)   return c_guard(CQTH) }
    CQTS = 0i64   CQTH = bigint_from_u64(CQAR, 0u64)
    return c_guard(CQTH)
}

/* sign of (s1,m1) - (s2,m2), exact */
fn c_scmp(s1: i64, m1: u64, s2: i64, m2: u64) -> i32 {
    if s1 > s2 { return 1i32 }
    if s1 < s2 { return 0i32 - 1i32 }
    if s1 == 0i64 { return 0i32 }
    let c : i32 = bigint_cmp(m1, m2)
    if s1 > 0i64 { return c }
    return 0i32 - c
}

fn cq_free() -> u32 {
    if CQAR != 0u64 { bigint_drop_arena(CQAR)   arena_drop(CQAR)   CQAR = 0u64 }
    return 1u32
}

fn cq_open() -> u32 {
    CQE = 0u32   CQMIG = 0i64
    CQAR = arena_new(8388608u64)
    if CQAR == 0u64 { CQE = 1u32   return 0u32 }
    return 1u32
}

/* seed slots [base, base+1] from i64 dyadic numerators (entering the deep tier) */
fn cq_seed2(base: i64, lo: i64, hi: i64) -> u32 {
    let mut a : i64 = lo   let mut sa : i64 = 1i64
    if a < 0i64 { a = 0i64 - a   sa = 0i64 - 1i64 }
    if a == 0i64 { sa = 0i64 }
    let mut b : i64 = hi   let mut sb : i64 = 1i64
    if b < 0i64 { b = 0i64 - b   sb = 0i64 - 1i64 }
    if b == 0i64 { sb = 0i64 }
    CQH[base as u64] = bigint_from_u64(CQAR, a as u64)
    CQH[(base + 1i64) as u64] = bigint_from_u64(CQAR, b as u64)
    CQS[base as u64] = sa
    CQS[(base + 1i64) as u64] = sb
    if c_guard(CQH[base as u64]) == 0u32 { return 0u32 }
    return c_guard(CQH[(base + 1i64) as u64])
}

/* migrate the first nslots handles into a FRESH arena (bump bytes reclaimed; the gas_big law) */
fn cq_migrate(nslots: i64) -> u32 {
    let na : u64 = arena_new(8388608u64)
    if na == 0u64 { CQE = 1u32   return 0u32 }
    let mut i : i64 = 0i64
    let mut ok : u32 = 1u32
    while i < nslots {
        let nh : u64 = bigint_copy(na, CQH[i as u64])
        if nh == 0u64 { ok = 0u32 }
        CQH[i as u64] = nh
        i = i + 1i64
    }
    bigint_drop_arena(CQAR)
    arena_drop(CQAR)
    CQAR = na
    if ok == 0u32 { CQE = 1u32   return 0u32 }
    return 1u32
}

/* halve the window in slots (base, base+1) at depth CQK through the handle door (chain built). */
fn cq_halve(base: i64) -> u32 {
    let ls : i64 = CQS[base as u64]
    let lh : u64 = CQH[base as u64]
    let hs : i64 = CQS[(base + 1i64) as u64]
    let hh : u64 = CQH[(base + 1i64) as u64]
    let l2 : u64 = bigint_mul_u64(CQAR, lh, 2u64)
    if c_guard(l2) == 0u32 { return 0u32 }
    if c_sadd(ls, lh, hs, hh) == 0u32 { bigint_drop(l2)   return 0u32 }
    let ms : i64 = CQTS
    let mh : u64 = CQTH
    let c : i64 = root_count2_h(l2, ls, mh, ms, CQK + 1i64)
    if c < 0i64 { CQE = 1u32   bigint_drop(l2)   bigint_drop(mh)   return 0u32 }
    if c == 1i64 {
        bigint_drop(lh)   bigint_drop(hh)
        CQH[base as u64] = l2
        CQS[(base + 1i64) as u64] = ms   CQH[(base + 1i64) as u64] = mh
        return 1u32
    }
    let h2 : u64 = bigint_mul_u64(CQAR, hh, 2u64)
    if c_guard(h2) == 0u32 { bigint_drop(l2)   bigint_drop(mh)   return 0u32 }
    bigint_drop(lh)   bigint_drop(hh)   bigint_drop(l2)
    CQS[base as u64] = ms   CQH[base as u64] = mh
    CQH[(base + 1i64) as u64] = h2
    return 1u32
}

/* window-pool row i := |h| (sign, k recorded); 0 = row width exceeded (resource) */
fn cw_store(i: i64, h: u64, sgn: i64, k: i64) -> u32 {
    let mut ln : i64 = bigint_len_limbs(h) as i64
    if bigint_is_zero(h) == 1u8 { ln = 0i64 }
    if ln > 64i64 { return 0u32 }
    let mut s : i64 = sgn
    if ln == 0i64 { s = 0i64 }
    CWS[i as u64] = s   CWL[i as u64] = ln   CWK[i as u64] = k
    let mut j : i64 = 0i64
    while j < ln { CWB[((i * 64i64) + j) as u64] = bigint_get_limb(h, j as u64)   j = j + 1i64 }
    return 1u32
}
fn cw_load(ar: u64, i: i64) -> u64 {
    let ln : i64 = CWL[i as u64]
    if ln == 0i64 { return bigint_from_u64(ar, 0u64) }
    let h : u64 = bigint_new(ar, (ln + 1i64) as u64)
    if h == 0u64 { return 0u64 }
    let mut j : i64 = 0i64
    while j < ln { bigint_set_limb(h, j as u64, CWB[((i * 64i64) + j) as u64])   j = j + 1i64 }
    bigint_set_len(h, ln as u64)
    bigint_normalize(h)
    return h
}
fn dr_store(i: i64, h: u64, sgn: i64, k: i64, w: i64) -> u32 {
    let mut ln : i64 = bigint_len_limbs(h) as i64
    if bigint_is_zero(h) == 1u8 { ln = 0i64 }
    if ln > 64i64 { return 0u32 }
    let mut s : i64 = sgn
    if ln == 0i64 { s = 0i64 }
    DRS[i as u64] = s   DRL[i as u64] = ln   DRK[i as u64] = k   DRW[i as u64] = w
    let mut j : i64 = 0i64
    while j < ln { DRB[((i * 64i64) + j) as u64] = bigint_get_limb(h, j as u64)   j = j + 1i64 }
    return 1u32
}
fn dr_load(ar: u64, i: i64) -> u64 {
    let ln : i64 = DRL[i as u64]
    if ln == 0i64 { return bigint_from_u64(ar, 0u64) }
    let h : u64 = bigint_new(ar, (ln + 1i64) as u64)
    if h == 0u64 { return 0u64 }
    let mut j : i64 = 0i64
    while j < ln { bigint_set_limb(h, j as u64, DRB[((i * 64i64) + j) as u64])   j = j + 1i64 }
    bigint_set_len(h, ln as u64)
    bigint_normalize(h)
    return h
}

/* exact decimal of |h| (own arena; the pb_dec loop over a handle) */
fn ph_dec(h: u64) -> u32 {
    if bigint_is_zero(h) == 1u8 { putchar(48i32)   return 1u32 }
    let ar : u64 = arena_new(2097152u64)
    if ar == 0u64 { putchar(63i32)   return 0u32 }
    let mut x : u64 = bigint_copy(ar, h)
    let ten : u64 = bigint_from_u64(ar, 10u64)
    let mut k : u64 = 0u64
    let mut going : u8 = 1u8
    while going == 1u8 {
        if bigint_is_zero(x) == 1u8 { going = 0u8 }
        else { if k >= 4980u64 { going = 0u8 } else {
            let q : u64 = bigint_div_qr(ar, x, ten)
            let r : u64 = bigint_remainder_take()
            DECB2[k] = ((bigint_to_u64_lo(r) % 10u64) + 48u64) as u8
            k = k + 1u64
            bigint_drop(r)   bigint_drop(x)
            x = q
        } }
    }
    if k == 0u64 { putchar(48i32) }
    while k > 0u64 { k = k - 1u64   putchar(DECB2[k] as i32) }
    bigint_drop(x)   bigint_drop(ten)
    bigint_drop_arena(ar)
    arena_drop(ar)
    return 1u32
}
/* 2^k as a fresh handle in ar (0 on exhaustion) */
fn pw2h(ar: u64, k: i64) -> u64 {
    let mut h : u64 = bigint_from_u64(ar, 1u64)
    if h == 0u64 { return 0u64 }
    let mut b : i64 = k
    while b > 0i64 {
        let mut c : i64 = b
        if c > 63i64 { c = 63i64 }
        let mut m : u64 = 1u64
        let mut q : i64 = 0i64
        while q < c { m = m * 2u64   q = q + 1i64 }
        let nx : u64 = bigint_mul_u64(ar, h, m)
        bigint_drop(h)
        if nx == 0u64 { return 0u64 }
        h = nx
        b = b - c
    }
    return h
}
/* print the signed dyadic rational (s*|h|)/2^k exactly, in decimal */
fn ph_dyadic(ar: u64, s: i64, h: u64, k: i64) -> u32 {
    if s < 0i64 { putchar(45i32) }
    ph_dec(h)
    if k > 0i64 {
        putchar(47i32)
        let d : u64 = pw2h(ar, k)
        if d == 0u64 { putchar(63i32)   return 0u32 }
        ph_dec(d)
        bigint_drop(d)
    }
    return 1u32
}

/* split ONE cluster seed (l0, h0] at depth k0 (the input polynomial's chain is BUILT and stays
 * valid -- counting only).  Appends isolated deep windows to DR*.  Termination is mathematical:
 * a window counting > 1 holds >= 2 DISTINCT roots, which separate at finite depth (a multiple
 * root is ONE distinct root and lands in the c == 1 arm with its multiplicity intact).
 * 9 ok | 5 resource | 6 defect (past the separation over-bound). */
fn rb_deepsplit(l0: i64, h0: i64, k0: i64, dmaxr: i64) -> u64 {
    if cq_open() == 0u32 { return 5u64 }
    let w : i64 = h0 - l0
    let wh : u64 = bigint_from_u64(CQAR, w as u64)
    if wh == 0u64 { cq_free()   return 5u64 }
    let mut la : i64 = l0
    let mut sa : i64 = 1i64
    if la < 0i64 { la = 0i64 - la   sa = 0i64 - 1i64 }
    if la == 0i64 { sa = 0i64 }
    let sh : u64 = bigint_from_u64(CQAR, la as u64)
    if sh == 0u64 { cq_free()   return 5u64 }
    if cw_store(0i64, sh, sa, k0) == 0u32 { bigint_drop(sh)   cq_free()   return 5u64 }
    bigint_drop(sh)
    CWN = 1i64
    let mut code : u64 = 9u64
    while CWN > 0i64 { if code == 9u64 {
        CWN = CWN - 1i64
        let i : i64 = CWN
        let ls : i64 = CWS[i as u64]
        let k : i64 = CWK[i as u64]
        let lh : u64 = cw_load(CQAR, i)
        if lh == 0u64 { code = 5u64 }
        else {
            if c_sadd(ls, lh, 1i64, wh) == 0u32 { code = 5u64   bigint_drop(lh) }
            else {
                let hs : i64 = CQTS
                let hh : u64 = CQTH
                let c : i64 = root_count2_h(lh, ls, hh, hs, k)
                if c < 0i64 { code = 5u64 }
                else { if c == 1i64 {
                    if DRN >= 64i64 { code = 5u64 }
                    else { if dr_store(DRN, lh, ls, k, w) == 0u32 { code = 5u64 } else { DRN = DRN + 1i64 } }
                } else { if c > 1i64 {
                    if k >= dmaxr { code = 6u64 }
                    else { if (CWN + 2i64) > 256i64 { code = 5u64 }
                    else {
                        let l2 : u64 = bigint_mul_u64(CQAR, lh, 2u64)
                        if l2 == 0u64 { code = 5u64 }
                        else {
                            if c_sadd(ls, l2, 1i64, wh) == 0u32 { code = 5u64   bigint_drop(l2) }
                            else {
                                let r2s : i64 = CQTS
                                let r2h : u64 = CQTH
                                /* push the RIGHT child first so the LEFT pops first -> ascending order */
                                if cw_store(CWN, r2h, r2s, k + 1i64) == 0u32 { code = 5u64 }
                                else {
                                    CWN = CWN + 1i64
                                    if cw_store(CWN, l2, ls, k + 1i64) == 0u32 { code = 5u64 }
                                    else { CWN = CWN + 1i64 }
                                }
                                bigint_drop(r2h)   bigint_drop(l2)
                            }
                        }
                    } }
                } } }
                bigint_drop(hh)   bigint_drop(lh)
            }
        }
    } else { CWN = 0i64 } }
    cq_free()
    return code
}

/* ── the ORDER VERBS at the engine's full class (deg <= 3840, ~4930-digit coefficients) ──────────
 * SIGN: two faculties -- counting (ONE exact root_count2 against the rational 0, no refinement:
 * the an_sign_vs_rat law lifted past i64) and dyadic refinement through the same overflow-free
 * chain -- must AGREE; the exact-zero case (c0 == 0 and 0 in the isolating window) is pure
 * arithmetic.  EQUALITY (the zero problem): the sturm_big PAIR-GCD door -- gcd(A,B) has a root in
 * the window overlap iff alpha = beta -- decided ONCE, exactly, never by epsilon.  ORDER: shared-
 * depth dyadic refinement, distinctness already PROVEN, descending through the DEEP TIER to any
 * depth memory affords (no numeric cap).  The deg<=3 algnum register file (gate 2157) and the
 * Sigma-sqrt separation-bound oracle ride along as independent faculties in their classes. */

fn emit_alg_sign2(str: u64, lo: i64, hi: i64) -> u64 {
    let pn : u64 = rb_parse(str)
    if pn == PARSEFAIL { ps("iii exact: parse error in the coefficient list (decimal integers, <= 4930 digits each)\n" as u64)  return 3u64 }
    if pn == LIMBFAIL { ps("ABSTAIN: a coefficient exceeds 256 limbs -- outside the engine's row envelope\n" as u64)  return 5u64 }
    if pn == 0u64 { ps("iii exact: empty coefficient list\n" as u64)  return 3u64 }
    let deg : i64 = gb_deg(pn)
    if deg < 1i64 { ps("iii exact: --alg needs a nonconstant polynomial\n" as u64)  return 3u64 }
    if deg > 3840i64 { ps("ABSTAIN: degree > 3840 is outside the bigint-chain envelope -- refused, not guessed\n" as u64)  return 5u64 }
    if lo >= hi { ps("iii exact: --alg interval needs lo < hi\n" as u64)  return 3u64 }
    if lo < (0i64 - 1024i64) { ps("ABSTAIN: interval endpoint outside the envelope (|.| <= 1024)\n" as u64)  return 5u64 }
    if hi > 1024i64 { ps("ABSTAIN: interval endpoint outside the envelope (|.| <= 1024)\n" as u64)  return 5u64 }
    if gb_build(deg) < 0i64 { ps("ABSTAIN: the bigint chain refused the input polynomial\n" as u64)  return 5u64 }
    let v : i64 = root_count2(lo, 1i64, hi, 1i64)
    if v != 1i64 {
        ps("REFUSED: (" as u64)  pi(lo)  ps(", " as u64)  pi(hi)  ps("] holds " as u64)  pi(v)
        ps(" roots of the polynomial -- an algebraic number needs exactly 1 (isolate first: --roots)\n" as u64)
        return 4u64
    }
    /* the exact-zero case: c0 == 0 AND 0 in (lo, hi] -- the window holds ONE root and 0 IS one */
    let mut zero : u32 = 0u32
    if GBS[0u64] == 0i64 { if lo < 0i64 { if hi >= 0i64 { zero = 1u32 } } }
    /* faculty 1: COUNTING -- one exact count against the rational 0 */
    let mut s1 : i32 = 0i32
    if zero == 0u32 {
        if lo >= 0i64 { s1 = 1i32 }
        else { if hi <= 0i64 { s1 = 0i32 - 1i32 }
        else {
            let cp : i64 = root_count2(0i64, 1i64, hi, 1i64)
            if cp == 1i64 { s1 = 1i32 } else { s1 = 0i32 - 1i32 }
        } }
    }
    /* faculty 2: dyadic REFINEMENT through the same chain (one polynomial -- the chain stays
     * built).  i64 numerators to depth 40, then THE DEEP TIER: bigint numerators through the
     * handle door, to any depth memory affords.  alpha != 0 is already proven, so termination is
     * mathematical; the separation-bound guard over-bounds -log2|alpha| and fires only on a defect. */
    let mut s2 : i32 = 0i32
    if zero == 0u32 {
        let mut l : i64 = lo
        let mut h : i64 = hi
        let mut k : i64 = 0i64
        let mut und : u32 = 1u32
        while und == 1u32 {
            if l >= 0i64 { s2 = 1i32   und = 0u32 }
            else { if h <= 0i64 { s2 = 0i32 - 1i32   und = 0u32 }
            else { if k >= 40i64 { und = 2u32 }
            else {
                let d2 : i64 = pw2(k + 1i64)
                let mid : i64 = l + h
                let c : i64 = root_count2(2i64 * l, d2, mid, d2)
                if c == 1i64 { l = 2i64 * l   h = mid }
                else         { l = mid        h = 2i64 * h }
                k = k + 1i64
            } } }
        }
        if und == 2u32 {
            /* the root-magnitude lower bound |alpha| >= |c_v| / (|c_v| + H) over the trailing
             * nonzero coefficient gives depth <= 64*(ml+2) + deg + 64; over-bound generously. */
            let mut mlmax : i64 = 1i64
            let mut mi : i64 = 0i64
            while mi <= deg { if GBL[mi as u64] > mlmax { mlmax = GBL[mi as u64] }   mi = mi + 1i64 }
            let dmaxs : i64 = (64i64 * (mlmax + 2i64)) + (64i64 * deg) + 1024i64
            if cq_open() == 0u32 { ps("ABSTAIN: the deep-refinement arena is unavailable (memory) -- refused, not guessed\n" as u64)  return 5u64 }
            if cq_seed2(0i64, l, h) == 0u32 { cq_free()  ps("ABSTAIN: the deep-refinement tier exhausted memory -- refused, not guessed\n" as u64)  return 5u64 }
            CQK = k
            let mut going : u32 = 1u32
            while going == 1u32 {
                if CQS[0u64] >= 0i64 { s2 = 1i32   going = 0u32 }
                else { if CQS[1u64] <= 0i64 { s2 = 0i32 - 1i32   going = 0u32 }
                else { if CQK > dmaxs {
                    cq_free()
                    ps("INTERNAL REFUSE: refinement passed the computed separation bound -- indicates a defect; no claim\n" as u64)
                    return 6u64
                } else {
                    if cq_halve(0i64) == 0u32 {
                        cq_free()
                        ps("ABSTAIN: the deep-refinement tier exhausted memory -- refused, not guessed\n" as u64)
                        return 5u64
                    }
                    CQK = CQK + 1i64
                    CQMIG = CQMIG + 1i64
                    if CQMIG >= 128i64 {
                        CQMIG = 0i64
                        if cq_migrate(2i64) == 0u32 {
                            cq_free()
                            ps("ABSTAIN: the deep-refinement tier exhausted memory -- refused, not guessed\n" as u64)
                            return 5u64
                        }
                    }
                } } }
            }
            cq_free()
        }
    }
    if s1 != s2 { ps("INTERNAL REFUSE: the counting and refinement faculties disagree -- no claim\n" as u64)  return 6u64 }
    /* faculty 3 where the input fits the gate-2157 class: the algnum register file */
    if deg <= 3i64 { if gb_small(1i64, deg, (&RC) as u64) == 1u32 {
        an_set(0i64, (&RC) as u64, deg, lo, hi)
        if an_valid(0i64) == 1i64 {
            let a1 : i32 = an_sign_vs_rat(0i64, 0i64, 1i64)
            if a1 != s1 { ps("INTERNAL REFUSE: the algnum register file disagrees -- no claim\n" as u64)  return 6u64 }
            let a2 : i32 = an_sign(0i64)
            if a2 != s1 { ps("INTERNAL REFUSE: the algnum refinement faculty disagrees -- no claim\n" as u64)  return 6u64 }
        }
    } }
    return emit_sign(s1)
}

/* one shared-depth dyadic refinement of operand `which` (0 = A on the GB2 rows, 1 = B on the GB
 * rows) at depth k: rebuilds that operand's chain (the pool is shared), halves its window. */
fn cmp_refine(which: i64, dg: i64, k: i64) -> u64 {
    let mut bc : i64 = 0i64
    if which == 0i64 { bc = gb2_build(dg) } else { bc = gb_build(dg) }
    if bc < 0i64 { return 55u64 }
    let l : i64 = AAL[which as u64]
    let h : i64 = AAH[which as u64]
    let d2 : i64 = pw2(k + 1i64)
    let mid : i64 = l + h
    let c : i64 = root_count2(2i64 * l, d2, mid, d2)
    if c == 1i64 { AAL[which as u64] = 2i64 * l   AAH[which as u64] = mid }
    else         { AAL[which as u64] = mid        AAH[which as u64] = 2i64 * h }
    return 9u64
}

/* the total-order core: 0 EQUAL | 1 A < B | 2 A > B | 55 engine/memory refuse | 66 defect guard.
 * A = the GB2 rows (degree dga, initial window (la, ha]); B = the GB rows (dgb, (lb, hb]).
 * Order refinement: i64 numerators to depth 40, then the DEEP TIER (bigint numerators via the
 * handle door) to any depth memory affords -- distinctness is proven before refinement starts,
 * so there is NO depth abstention; CQDMAX (a per-input Mignotte-style over-bound) only names a
 * defect.  The caller frees the deep arena. */
fn cmp_core(dga: i64, dgb: i64, la: i64, ha: i64, lb: i64, hb: i64) -> u64 {
    AAL[0u64] = la   AAH[0u64] = ha
    AAL[1u64] = lb   AAH[1u64] = hb
    AAK = 0i64
    let mut eqdone : u32 = 0u32
    let mut res : u64 = 9u64
    while res == 9u64 {
        let mut dis : i32 = 0i32
        if CQAR == 0u64 {
            if AAH[0u64] <= AAL[1u64] { dis = 1i32 }
            else { if AAH[1u64] <= AAL[0u64] { dis = 2i32 } }
        } else {
            if c_scmp(CQS[1u64], CQH[1u64], CQS[2u64], CQH[2u64]) <= 0i32 { dis = 1i32 }
            else { if c_scmp(CQS[3u64], CQH[3u64], CQS[0u64], CQH[0u64]) <= 0i32 { dis = 2i32 } }
        }
        if dis == 1i32 { res = 1u64 }
        else { if dis == 2i32 { res = 2u64 }
        else {
            if eqdone == 0u32 {
                /* THE ZERO PROBLEM, decided ONCE on the initial overlap: the pair-gcd door.
                 * Stage the higher degree first (st2_prem wants degA >= degB; gcd is symmetric). */
                eqdone = 1u32
                let mut g : i64 = 0i64 - 9i64
                let mut ok : u32 = 1u32
                if dga >= dgb {
                    if gb2_load(dga) != 0i32 { ok = 0u32 }
                    if ok == 1u32 { if sturm2_pair_stash() != 0i32 { ok = 0u32 } }
                    if ok == 1u32 { if gb_load(dgb) != 0i32 { ok = 0u32 } }
                    if ok == 1u32 { g = sturm2_pair_gcd() }
                } else {
                    if gb_load(dgb) != 0i32 { ok = 0u32 }
                    if ok == 1u32 { if sturm2_pair_stash() != 0i32 { ok = 0u32 } }
                    if ok == 1u32 { if gb2_load(dga) != 0i32 { ok = 0u32 } }
                    if ok == 1u32 { g = sturm2_pair_gcd() }
                }
                if ok == 0u32 { res = 55u64 }
                else { if g < 0i64 { res = 55u64 }
                else { if g >= 1i64 {
                    /* the gcd sits in the CUR rows: build ITS chain, count the window overlap --
                     * a shared root there must be each side's unique root, so alpha = beta. */
                    if sturm2_build_cur() < 0i64 { res = 55u64 }
                    else {
                        let mut lon : i64 = la   if lb > lon { lon = lb }
                        let mut hin : i64 = ha   if hb < hin { hin = hb }
                        if lon < hin {
                            let c : i64 = root_count2(lon, 1i64, hin, 1i64)
                            if c >= 1i64 { res = 0u64 }
                        }
                    }
                } } }
            } else { if AAK < 40i64 {
                let r1 : u64 = cmp_refine(0i64, dga, AAK)
                if r1 != 9u64 { res = 55u64 }
                else {
                    let r2 : u64 = cmp_refine(1i64, dgb, AAK)
                    if r2 != 9u64 { res = 55u64 }
                    else { AAK = AAK + 1i64 }
                }
            } else {
                /* THE DEEP TIER */
                if CQAR == 0u64 {
                    if cq_open() == 0u32 { res = 55u64 }
                    else { if cq_seed2(0i64, AAL[0u64], AAH[0u64]) == 0u32 { res = 55u64 }
                    else { if cq_seed2(2i64, AAL[1u64], AAH[1u64]) == 0u32 { res = 55u64 }
                    else { CQK = AAK } } }
                }
                if res == 9u64 {
                    if CQK > CQDMAX { res = 66u64 }
                    else {
                        if gb2_build(dga) < 0i64 { res = 55u64 }
                        else { if cq_halve(0i64) == 0u32 { res = 55u64 }
                        else { if gb_build(dgb) < 0i64 { res = 55u64 }
                        else { if cq_halve(2i64) == 0u32 { res = 55u64 }
                        else {
                            CQK = CQK + 1i64
                            CQMIG = CQMIG + 1i64
                            if CQMIG >= 128i64 {
                                CQMIG = 0i64
                                if cq_migrate(4i64) == 0u32 { res = 55u64 }
                            }
                        } } } }
                    }
                }
            } }
        } }
    }
    return res
}

fn emit_alg_cmp2(stra: u64, la: i64, ha: i64, strb: u64, lb: i64, hb: i64) -> u64 {
    /* parse A into the GB rows, stash to GB2; then parse B into GB */
    let pa : u64 = rb_parse(stra)
    if pa == PARSEFAIL { ps("iii exact: parse error in polynomial A (decimal integers, <= 4930 digits each)\n" as u64)  return 3u64 }
    if pa == LIMBFAIL { ps("ABSTAIN: a coefficient of A exceeds 256 limbs -- outside the row envelope\n" as u64)  return 5u64 }
    if pa == 0u64 { ps("iii exact: empty polynomial A\n" as u64)  return 3u64 }
    let dga : i64 = gb_deg(pa)
    if dga < 1i64 { ps("iii exact: --alg needs a nonconstant polynomial (A)\n" as u64)  return 3u64 }
    if dga > 3840i64 { ps("ABSTAIN: degree(A) > 3840 is outside the bigint-chain envelope -- refused, not guessed\n" as u64)  return 5u64 }
    gb_stash2(dga)
    let pb : u64 = rb_parse(strb)
    if pb == PARSEFAIL { ps("iii exact: parse error in polynomial B (decimal integers, <= 4930 digits each)\n" as u64)  return 3u64 }
    if pb == LIMBFAIL { ps("ABSTAIN: a coefficient of B exceeds 256 limbs -- outside the row envelope\n" as u64)  return 5u64 }
    if pb == 0u64 { ps("iii exact: empty polynomial B\n" as u64)  return 3u64 }
    let dgb : i64 = gb_deg(pb)
    if dgb < 1i64 { ps("iii exact: --alg needs a nonconstant polynomial (B)\n" as u64)  return 3u64 }
    if dgb > 3840i64 { ps("ABSTAIN: degree(B) > 3840 is outside the bigint-chain envelope -- refused, not guessed\n" as u64)  return 5u64 }
    if la >= ha { ps("iii exact: --alg interval needs lo < hi (A)\n" as u64)  return 3u64 }
    if lb >= hb { ps("iii exact: --alg interval needs lo < hi (B)\n" as u64)  return 3u64 }
    if la < (0i64 - 1024i64) { ps("ABSTAIN: interval endpoint outside the envelope (|.| <= 1024)\n" as u64)  return 5u64 }
    if ha > 1024i64 { ps("ABSTAIN: interval endpoint outside the envelope (|.| <= 1024)\n" as u64)  return 5u64 }
    if lb < (0i64 - 1024i64) { ps("ABSTAIN: interval endpoint outside the envelope (|.| <= 1024)\n" as u64)  return 5u64 }
    if hb > 1024i64 { ps("ABSTAIN: interval endpoint outside the envelope (|.| <= 1024)\n" as u64)  return 5u64 }
    /* bigint-certified isolation of each operand (sound at every depth) */
    if gb2_build(dga) < 0i64 { ps("ABSTAIN: the bigint chain refused polynomial A\n" as u64)  return 5u64 }
    let va : i64 = root_count2(la, 1i64, ha, 1i64)
    if va != 1i64 {
        ps("REFUSED: A's (" as u64)  pi(la)  ps(", " as u64)  pi(ha)  ps("] holds " as u64)  pi(va)
        ps(" roots -- an algebraic number needs exactly 1 (isolate first: --roots / --roots-big)\n" as u64)
        return 4u64
    }
    if gb_build(dgb) < 0i64 { ps("ABSTAIN: the bigint chain refused polynomial B\n" as u64)  return 5u64 }
    let vb : i64 = root_count2(lb, 1i64, hb, 1i64)
    if vb != 1i64 {
        ps("REFUSED: B's (" as u64)  pi(lb)  ps(", " as u64)  pi(hb)  ps("] holds " as u64)  pi(vb)
        ps(" roots -- an algebraic number needs exactly 1 (isolate first: --roots / --roots-big)\n" as u64)
        return 4u64
    }
    /* the cross-check-faculty extractions, while the rows still hold A = GB2, B = GB */
    let smA : u32 = gb_small(2i64, dga, (&RC) as u64)
    let smB : u32 = gb_small(1i64, dgb, (&RC2) as u64)
    /* the per-input separation over-bound (Mignotte-style): root separation of coprime integer
     * polynomials exceeds 2^-(degB*log2||A|| + degA*log2||B|| + O(d log d)) -- over-bound it. */
    let mut mla : i64 = 1i64
    let mut mi : i64 = 0i64
    while mi <= dga { if GB2L[mi as u64] > mla { mla = GB2L[mi as u64] }   mi = mi + 1i64 }
    let mut mlb : i64 = 1i64
    mi = 0i64
    while mi <= dgb { if GBL[mi as u64] > mlb { mlb = GBL[mi as u64] }   mi = mi + 1i64 }
    CQDMAX = (64i64 * ((dga * (mlb + 2i64)) + (dgb * (mla + 2i64)) + dga + dgb)) + 1024i64
    /* the decision */
    let v1 : u64 = cmp_core(dga, dgb, la, ha, lb, hb)
    cq_free()
    if v1 == 55u64 { ps("ABSTAIN: the engine exhausted its resource envelope during the decision (memory) -- refused, not guessed\n" as u64)  return 5u64 }
    if v1 == 66u64 { ps("INTERNAL REFUSE: refinement passed the computed separation bound -- indicates a defect; no claim\n" as u64)  return 6u64 }
    /* antisymmetry: the WHOLE decision re-run with the roles swapped (fresh parses, fresh states) */
    let pb2 : u64 = rb_parse(strb)
    if pb2 == PARSEFAIL { return 6u64 }
    gb_stash2(dgb)
    let pa2 : u64 = rb_parse(stra)
    if pa2 == PARSEFAIL { return 6u64 }
    let v2 : u64 = cmp_core(dgb, dga, lb, hb, la, ha)
    cq_free()
    let mut anti : u32 = 0u32
    if v1 == 0u64 { if v2 == 0u64 { anti = 1u32 } }
    if v1 == 1u64 { if v2 == 2u64 { anti = 1u32 } }
    if v1 == 2u64 { if v2 == 1u64 { anti = 1u32 } }
    if anti == 0u32 { ps("INTERNAL REFUSE: antisymmetry re-verification failed -- no claim\n" as u64)  return 6u64 }
    if smA == 1u32 { if smB == 1u32 {
        /* the Sigma-sqrt separation-bound oracle where both are principal square roots */
        let ba : i64 = sqrt_shape((&RC) as u64, dga, la)
        let bb : i64 = sqrt_shape((&RC2) as u64, dgb, lb)
        if ba > 0i64 { if bb > 0i64 {
            AV[0u64] = 1i64             BV[0u64] = ba
            AV[1u64] = 0i64 - 1i64      BV[1u64] = bb
            let s3 : i32 = ui_sqrt_sum_sign(&AV as u64, &BV as u64, 2u64)
            let mut oks : u32 = 0u32
            if v1 == 0u64 { if s3 == 0i32 { oks = 1u32 } }
            if v1 == 1u64 { if s3 < 0i32 { oks = 1u32 } }
            if v1 == 2u64 { if s3 > 0i32 { oks = 1u32 } }
            if oks == 0u32 { ps("INTERNAL REFUSE: the Sigma-sqrt oracle disagrees with the Sturm order -- no claim\n" as u64)  return 6u64 }
        } }
        /* the algnum register file where BOTH operands fit the gate-2157 class */
        if dga <= 3i64 { if dgb <= 3i64 {
            an_set(0i64, (&RC) as u64, dga, la, ha)
            an_set(1i64, (&RC2) as u64, dgb, lb, hb)
            if an_valid(0i64) == 1i64 { if an_valid(1i64) == 1i64 {
                let c3 : i32 = an_cmp(0i64, 1i64)
                if c3 != 2i32 {                     /* 2 = algnum's own cap: the arm applies only when it decides */
                    let mut okn : u32 = 0u32
                    if v1 == 0u64 { if c3 == 0i32 { okn = 1u32 } }
                    if v1 == 1u64 { if c3 < 0i32 { okn = 1u32 } }
                    if v1 == 2u64 { if c3 > 0i32 { okn = 1u32 } }
                    if okn == 0u32 { ps("INTERNAL REFUSE: the algnum register file disagrees -- no claim\n" as u64)  return 6u64 }
                }
            } }
        } }
    } }
    if v1 == 0u64 {
        ps("EQUAL: the SAME algebraic number (decided by gcd -- two polynomials, one root; never epsilon)\n" as u64)
        return 0u64
    }
    if v1 == 1u64 { ps("A < B  (exact total order on real algebraic numbers)\n" as u64)  return 1u64 }
    ps("A > B  (exact total order on real algebraic numbers)\n" as u64)
    return 2u64
}

/* exact decimal print of limb-row coefficient i (bigint repeated division by 10; own dropped arena). */
fn pb_dec(i: i64) -> u32 {
    let sg : i64 = GBS[i as u64]
    if sg == 0i64 { putchar(48i32)   return 1u32 }
    if sg < 0i64 { putchar(45i32) }
    let ar : u64 = arena_new(1048576u64)
    let ln : i64 = GBL[i as u64]
    let h : u64 = bigint_new(ar, (ln + 1i64) as u64)
    let mut j : i64 = 0i64
    while j < ln { bigint_set_limb(h, j as u64, GBW[((i * 256i64) + j) as u64])   j = j + 1i64 }
    bigint_set_len(h, ln as u64)
    bigint_normalize(h)
    let ten : u64 = bigint_from_u64(ar, 10u64)
    let mut x : u64 = h
    let mut k : u64 = 0u64
    let mut going : u8 = 1u8
    while going == 1u8 {
        if bigint_is_zero(x) == 1u8 { going = 0u8 }
        else { if k >= 4980u64 { going = 0u8 } else {
            let q : u64 = bigint_div_qr(ar, x, ten)
            let r : u64 = bigint_remainder_take()
            DECB2[k] = ((bigint_to_u64_lo(r) % 10u64) + 48u64) as u8
            k = k + 1u64
            bigint_drop(r)   bigint_drop(x)
            x = q
        } }
    }
    if k == 0u64 { putchar(48i32) }
    while k > 0u64 { k = k - 1u64   putchar(DECB2[k] as i32) }
    bigint_drop(x)   bigint_drop(ten)
    bigint_drop_arena(ar)
    arena_drop(ar)
    return 1u32
}
fn gb_poly_print(deg: i64) -> u32 {
    ps("  coefficients c0..c" as u64)  pi(deg)  ps(" (low -> high): " as u64)
    let mut i : i64 = 0i64
    while i <= deg {
        if i > 0i64 { putchar(32i32) }
        pb_dec(i)
        i = i + 1i64
    }
    nl()
    return 1u32
}

/* strip factors of x (c0 == 0) -- lawful only after 0 has been PROVEN not to be the number. */
fn strip_x(cptr: u64, deg0: i64) -> i64 {
    let d : *i64 = cptr as *i64
    let mut deg : i64 = deg0
    let mut going : u8 = 1u8
    while going == 1u8 {
        let c0 : i64 = d[0u64]
        if c0 != 0i64 { going = 0u8 }
        else { if deg < 1i64 { going = 0u8 } else {
            let mut i : i64 = 0i64
            while i < deg { d[i as u64] = d[(i + 1i64) as u64]   i = i + 1i64 }
            deg = deg - 1i64
        } }
    }
    return deg
}

/* one dyadic split of refinement state `which` (0 = alpha, 1 = beta) against its own polynomial,
 * counted through the OVERFLOW-FREE bigint chain (sound at every depth, unlike an i64 chain).
 * (l/2^AAK, h/2^AAK] -> the half still holding the unique root, at denominator 2^(AAK+1). */
fn aa_refine(which: i64, cptr: u64, deg: i64) -> u64 {
    let bc : i64 = sturm2_build(cptr, deg)
    if bc < 0i64 { ps("INTERNAL REFUSE: the input chain refused during refinement -- no claim\n" as u64)  return 6u64 }
    let l : i64 = AAL[which as u64]
    let h : i64 = AAH[which as u64]
    let l2 : i64 = 2i64 * l
    let h2 : i64 = 2i64 * h
    let mid : i64 = l + h
    let d2 : i64 = pw2(AAK + 1i64)
    let c : i64 = root_count2(l2, d2, mid, d2)
    if c == 1i64 { AAL[which as u64] = l2    AAH[which as u64] = mid }
    else         { AAL[which as u64] = mid   AAH[which as u64] = h2 }
    return 9u64
}

/* gamma's window from the current dyadic states, four-value form (GLO/GLD, GHI/GHD], denominators
 * positive.  SUM: exact half-open orientation.  PRODUCT (both operands sign-definite, EITHER sign):
 * [min, max] over the four endpoint products, lower bound widened one half-step -- the mirrored
 * orientation can never lose gamma.  INVERSE (alpha sign-definite): gamma in [2^k/h, 2^k/l), the
 * lower bound widened via h+1 (one whole unit at h = -1) -- a strict outer bracket, both signs.
 * The widened windows converge because the operand intervals do.  9 ok / 5 exact-envelope left. */
fn aa_gamma(op: i64) -> u64 {
    let la : i64 = AAL[0u64]   let ha : i64 = AAH[0u64]
    let dk : i64 = pw2(AAK)
    if op == 0i64 {
        let lb : i64 = AAL[1u64]   let hb : i64 = AAH[1u64]
        GLO = la + lb   GLD = dk
        GHI = ha + hb   GHD = dk
        return 9u64
    }
    if op == 1i64 {
        let lb : i64 = AAL[1u64]   let hb : i64 = AAH[1u64]
        let mut bad : u32 = 0u32
        if la >= 2147483648i64 { bad = 1u32 }
        if la <= (0i64 - 2147483648i64) { bad = 1u32 }
        if ha >= 2147483648i64 { bad = 1u32 }
        if ha <= (0i64 - 2147483648i64) { bad = 1u32 }
        if lb >= 2147483648i64 { bad = 1u32 }
        if lb <= (0i64 - 2147483648i64) { bad = 1u32 }
        if hb >= 2147483648i64 { bad = 1u32 }
        if hb <= (0i64 - 2147483648i64) { bad = 1u32 }
        if bad == 1u32 { return 5u64 }
        let p1 : i64 = la * lb
        let p2 : i64 = la * hb
        let p3 : i64 = ha * lb
        let p4 : i64 = ha * hb
        let mut pmin : i64 = p1
        if p2 < pmin { pmin = p2 }
        if p3 < pmin { pmin = p3 }
        if p4 < pmin { pmin = p4 }
        let mut pmax : i64 = p1
        if p2 > pmax { pmax = p2 }
        if p3 > pmax { pmax = p3 }
        if p4 > pmax { pmax = p4 }
        let dd : i64 = dk * dk
        GLO = (2i64 * pmin) - 1i64   GLD = 2i64 * dd
        GHI = pmax                   GHD = dd
        return 9u64
    }
    /* op 2: inverse -- alpha is sign-definite (la >= 1 positive, or ha <= -1 negative). */
    if la >= 1i64 {
        GLO = dk   GLD = ha + 1i64
        GHI = dk   GHD = la
        return 9u64
    }
    if ha <= (0i64 - 1i64) {
        if ha == (0i64 - 1i64) { GLO = (0i64 - dk) - 1i64   GLD = 1i64 }
        else { GLO = 0i64 - dk   GLD = 0i64 - (ha + 1i64) }
        GHI = 0i64 - dk   GHD = 0i64 - la
        return 9u64
    }
    return 6u64
}

/* the Sigma-sqrt separation-bound oracle must place gamma inside the certified window.
 * SUM: d*sqrt(ba) + d*sqrt(bb) - num; PRODUCT: sqrt(ba*bb); INVERSE: 1/sqrt(ba), rewritten as
 * sign(d - num*sqrt(ba)) so the oracle's integer-term form applies (all positive here). */
fn aa_sqrtchk(op: i64, ba: i64, bb: i64) -> u64 {
    if op == 0i64 {
        AV[0u64] = GLD            BV[0u64] = ba
        AV[1u64] = GLD            BV[1u64] = bb
        AV[2u64] = 0i64 - GLO     BV[2u64] = 1i64
        let s1 : i32 = ui_sqrt_sum_sign(&AV as u64, &BV as u64, 3u64)
        if s1 != 1i32 { return 6u64 }
        AV[0u64] = GHD
        AV[1u64] = GHD
        AV[2u64] = 0i64 - GHI
        let s2 : i32 = ui_sqrt_sum_sign(&AV as u64, &BV as u64, 3u64)
        if s2 > 0i32 { return 6u64 }
        return 9u64
    }
    if op == 1i64 {
        let rad : i64 = ba * bb
        AV[0u64] = GLD            BV[0u64] = rad
        AV[1u64] = 0i64 - GLO     BV[1u64] = 1i64
        let s3 : i32 = ui_sqrt_sum_sign(&AV as u64, &BV as u64, 2u64)
        if s3 != 1i32 { return 6u64 }
        AV[0u64] = GHD
        AV[1u64] = 0i64 - GHI
        let s4 : i32 = ui_sqrt_sum_sign(&AV as u64, &BV as u64, 2u64)
        if s4 > 0i32 { return 6u64 }
        return 9u64
    }
    /* op 2: gamma = 1/sqrt(ba) > GLO/GLD  <=>  GLD - GLO*sqrt(ba) > 0  (positive case only). */
    AV[0u64] = 0i64 - GLO     BV[0u64] = ba
    AV[1u64] = GLD            BV[1u64] = 1i64
    let s5 : i32 = ui_sqrt_sum_sign(&AV as u64, &BV as u64, 2u64)
    if s5 != 1i32 { return 6u64 }
    AV[0u64] = 0i64 - GHI
    AV[1u64] = GHD
    let s6 : i32 = ui_sqrt_sum_sign(&AV as u64, &BV as u64, 2u64)
    if s6 > 0i32 { return 6u64 }
    return 9u64
}

/* arithmetic-verb loader (NO algnum dependency): parse-side envelope (deg 1..7, |c| < 2^20,
 * integer endpoints |.| <= 1024, lo < hi) + BIGINT-CERTIFIED isolation (the sturm2 chain counts
 * exactly one distinct root in (lo, hi] -- sound at every depth, so degree 7 is as proven as
 * degree 3 here).  Sets ADG[which] and AZR[which] (the number IS exactly 0: c0 == 0 and the
 * isolating interval contains 0 -- pure arithmetic, since the interval holds only ONE root). */
fn alg2_load(which: i64, coeffs: u64, nc: u64, lo: i64, hi: i64) -> u64 {
    let deg : i64 = poly_deg(coeffs, nc)
    if deg < 1i64 { ps("iii exact: --alg needs a nonconstant polynomial\n" as u64)  return 3u64 }
    if deg > 1536i64 { ps("ABSTAIN: degree > 1536 is outside the arithmetic-verb envelope -- refused, not guessed\n" as u64)  return 5u64 }
    let mx : i64 = poly_maxabs(coeffs, deg)
    if mx >= 1152921504606846976i64 { ps("ABSTAIN: a |coefficient| >= 2^60 is outside the envelope\n" as u64)  return 5u64 }
    if lo >= hi { ps("iii exact: --alg interval needs lo < hi\n" as u64)  return 3u64 }
    if lo < (0i64 - 1024i64) { ps("ABSTAIN: interval endpoint outside the envelope (|.| <= 1024)\n" as u64)  return 5u64 }
    if hi > 1024i64 { ps("ABSTAIN: interval endpoint outside the envelope (|.| <= 1024)\n" as u64)  return 5u64 }
    let bc : i64 = sturm2_build(coeffs, deg)
    if bc < 0i64 { ps("ABSTAIN: the bigint chain refused the input polynomial\n" as u64)  return 5u64 }
    let v : i64 = root_count2(lo, 1i64, hi, 1i64)
    if v != 1i64 {
        ps("REFUSED: (" as u64)  pi(lo)  ps(", " as u64)  pi(hi)  ps("] holds " as u64)  pi(v)
        ps(" roots of the polynomial -- an algebraic number needs exactly 1 (isolate first: --roots)\n" as u64)
        return 4u64
    }
    ADG[which as u64] = deg
    let d : *i64 = coeffs as *i64
    let c0 : i64 = d[0u64]
    AZR[which as u64] = 0u64
    if c0 == 0i64 { if lo < 0i64 { if hi >= 0i64 { AZR[which as u64] = 1u64 } } }
    return 9u64
}

/* --alg-add / --alg-mul / --alg-inv: gamma = alpha OP beta (INV: gamma = 1/alpha, one operand).
 * The certified-CRT resultant (or, for INV, the exact reversal rs_inv) CONSTRUCTS gamma's integer
 * defining polynomial; the CLI pins WHICH root by refining the operands through the overflow-free
 * bigint chain until R has exactly ONE root in gamma's window (root_count2-certified).  PRODUCT
 * and INVERSE work at EITHER sign: a sign-definite refinement phase separates each operand from 0
 * first, then the widened four-value windows apply.  Sqrt-shaped inputs get the Sigma-sqrt oracle
 * as an independent second faculty.  Inputs: degree <= 7 each, degA*degB <= 18 (the 16-prime
 * certified window) for the two-operand verbs.  The output (R + window) is itself a legal
 * --roots / --roots-big input class -- closure. */
/* one deep refinement round of the operand windows (chains rebuilt per operand; the pool is
 * shared).  1 ok, 0 resource (CQE holds the reason). */
fn aa_dref(op: i64, dga: i64, dgb: i64) -> u32 {
    if sturm2_build((&RC) as u64, dga) < 0i64 { CQE = 1u32   return 0u32 }
    if cq_halve(0i64) == 0u32 { return 0u32 }
    if op != 2i64 {
        if sturm2_build((&RC2) as u64, dgb) < 0i64 { CQE = 1u32   return 0u32 }
        if cq_halve(2i64) == 0u32 { return 0u32 }
    }
    CQK = CQK + 1i64
    CQMIG = CQMIG + 1i64
    if CQMIG >= 128i64 {
        CQMIG = 0i64
        let mut ns : i64 = 4i64
        if op == 2i64 { ns = 2i64 }
        if cq_migrate(ns) == 0u32 { return 0u32 }
    }
    return 1u32
}

var DP4S : [i64; 4]   var DP4H : [u64; 4]

/* THE DEEP PINNING TIER: past the i64 window formulas, operand windows become signed-handle
 * pairs; gamma's window is computed in handle arithmetic (SUM / PRODUCT dyadic through
 * root_count2_h, INVERSE general-rational through root_count2_q) and counted on R's chain.
 * On success (9) the pinned window's handles live in CQAR (DP*) until the caller prints and
 * frees.  5 resource | 6 defect (separation over-bound / lost root). */
fn aa_deep(op: i64, dga: i64, dgb: i64, rd: i64) -> u64 {
    DPON = 0u32
    if cq_open() == 0u32 { return 5u64 }
    if cq_seed2(0i64, AAL[0u64], AAH[0u64]) == 0u32 { cq_free()   return 5u64 }
    if op != 2i64 { if cq_seed2(2i64, AAL[1u64], AAH[1u64]) == 0u32 { cq_free()   return 5u64 } }
    CQK = AAK
    let mut mlr : i64 = 1i64
    let mut mi : i64 = 0i64
    while mi <= rd { if GBL[mi as u64] > mlr { mlr = GBL[mi as u64] }   mi = mi + 1i64 }
    let dmaxp : i64 = (128i64 * rd * (mlr + 2i64)) + 2048i64
    let mut code : u64 = 9u64
    let mut pinned : u32 = 0u32
    while pinned == 0u32 { if code != 9u64 { pinned = 1u32 } else {
        if CQK > dmaxp { code = 6u64 }
        else {
            /* sign-definiteness for the product/inverse window formulas */
            let mut needref : u32 = 0u32
            if op != 0i64 { if CQS[0u64] <= 0i64 { if CQS[1u64] >= 0i64 { needref = 1u32 } } }
            if op == 1i64 { if CQS[2u64] <= 0i64 { if CQS[3u64] >= 0i64 { needref = 1u32 } } }
            if needref == 1u32 {
                if aa_dref(op, dga, dgb) == 0u32 { code = 5u64 }
            } else {
                /* gamma's window in handle arithmetic */
                let mut c : i64 = 0i64 - 9i64
                let mut gls : i64 = 0i64   let mut glh : u64 = 0u64
                let mut ghs : i64 = 0i64   let mut ghh : u64 = 0u64
                let mut gld : u64 = 0u64   let mut ghd : u64 = 0u64
                let mut kd : i64 = CQK
                let mut built : u32 = 0u32
                if op == 0i64 {
                    if c_sadd(CQS[0u64], CQH[0u64], CQS[2u64], CQH[2u64]) == 0u32 { code = 5u64 }
                    else {
                        gls = CQTS   glh = CQTH
                        if c_sadd(CQS[1u64], CQH[1u64], CQS[3u64], CQH[3u64]) == 0u32 { code = 5u64   bigint_drop(glh) }
                        else { ghs = CQTS   ghh = CQTH   built = 1u32 }
                    }
                }
                if op == 1i64 {
                    /* four endpoint products, then [2*min - 1, 2*max] over 2^(2K+1) */
                    let mut pj : i64 = 0i64
                    let mut pbad2 : u32 = 0u32
                    while pj < 4i64 {
                        let ia : i64 = pj / 2i64
                        let ib : i64 = 2i64 + (pj % 2i64)
                        DP4S[pj as u64] = CQS[ia as u64] * CQS[ib as u64]
                        DP4H[pj as u64] = bigint_mul(CQAR, CQH[ia as u64], CQH[ib as u64])
                        if DP4H[pj as u64] == 0u64 { pbad2 = 1u32 }
                        pj = pj + 1i64
                    }
                    if pbad2 == 1u32 { code = 5u64 }
                    else {
                        let mut imin : i64 = 0i64
                        let mut imax : i64 = 0i64
                        pj = 1i64
                        while pj < 4i64 {
                            if c_scmp(DP4S[pj as u64], DP4H[pj as u64], DP4S[imin as u64], DP4H[imin as u64]) < 0i32 { imin = pj }
                            if c_scmp(DP4S[pj as u64], DP4H[pj as u64], DP4S[imax as u64], DP4H[imax as u64]) > 0i32 { imax = pj }
                            pj = pj + 1i64
                        }
                        let one1 : u64 = bigint_from_u64(CQAR, 1u64)
                        let d2m : u64 = bigint_mul_u64(CQAR, DP4H[imin as u64], 2u64)
                        let d2x : u64 = bigint_mul_u64(CQAR, DP4H[imax as u64], 2u64)
                        if one1 == 0u64 { code = 5u64 }
                        if d2m == 0u64 { code = 5u64 }
                        if d2x == 0u64 { code = 5u64 }
                        if code == 9u64 {
                            if c_sadd(DP4S[imin as u64], d2m, 0i64 - 1i64, one1) == 0u32 { code = 5u64 }
                            else {
                                gls = CQTS   glh = CQTH
                                ghs = DP4S[imax as u64]   ghh = d2x
                                kd = (2i64 * CQK) + 1i64
                                built = 1u32
                            }
                        }
                        if built == 0u32 { if d2x != 0u64 { bigint_drop(d2x) } }
                        if d2m != 0u64 { bigint_drop(d2m) }
                        if one1 != 0u64 { bigint_drop(one1) }
                        pj = 0i64
                        while pj < 4i64 { if DP4H[pj as u64] != 0u64 { bigint_drop(DP4H[pj as u64]) }   pj = pj + 1i64 }
                    }
                }
                let mut rn2k : u64 = 0u64                    /* op-2 round allocations, tracked once */
                let mut rone : u64 = 0u64
                let mut rsad : u64 = 0u64
                if op == 2i64 {
                    rn2k = pw2h(CQAR, CQK)
                    rone = bigint_from_u64(CQAR, 1u64)
                    if rn2k == 0u64 { code = 5u64 }
                    if rone == 0u64 { code = 5u64 }
                    if code == 9u64 {
                        if CQS[0u64] > 0i64 {
                            /* positive alpha: gamma in (2^K/(H+1), 2^K/L] */
                            if c_sadd(CQS[1u64], CQH[1u64], 1i64, rone) == 0u32 { code = 5u64 }
                            else {
                                rsad = CQTH
                                gld = rsad                           /* H+1 > 0 */
                                glh = rn2k   gls = 1i64
                                ghh = rn2k   ghs = 1i64
                                ghd = CQH[0u64]
                                built = 1u32   kd = 0i64 - 1i64      /* general-rational marker */
                            }
                        } else {
                            /* negative alpha (H <= -1 in value) */
                            let hm1 : i32 = bigint_cmp(CQH[1u64], rone)
                            if hm1 == 0i32 {
                                /* H == -1: lo = (-2^K - 1)/1 */
                                if c_sadd(1i64, rn2k, 1i64, rone) == 0u32 { code = 5u64 }
                                else {
                                    rsad = CQTH
                                    glh = rsad   gls = 0i64 - 1i64
                                    gld = rone
                                    ghh = rn2k   ghs = 0i64 - 1i64
                                    ghd = CQH[0u64]
                                    built = 1u32   kd = 0i64 - 1i64
                                }
                            } else {
                                /* |H+1| = |H| - 1 (H negative, |H| >= 2) */
                                if c_sadd(1i64, CQH[1u64], 0i64 - 1i64, rone) == 0u32 { code = 5u64 }
                                else {
                                    rsad = CQTH
                                    gld = rsad
                                    glh = rn2k   gls = 0i64 - 1i64
                                    ghh = rn2k   ghs = 0i64 - 1i64
                                    ghd = CQH[0u64]
                                    built = 1u32   kd = 0i64 - 1i64
                                }
                            }
                        }
                    }
                }
                if built == 1u32 { if code == 9u64 {
                    if gb_build(rd) < 0i64 { code = 5u64 }
                    else {
                        if kd >= 0i64 { c = root_count2_h(glh, gls, ghh, ghs, kd) }
                        else { c = root_count2_q(glh, gls, gld, ghh, ghs, ghd) }
                        if c < 0i64 { code = 5u64 }
                        else { if c == 1i64 {
                            DPON = 1u32
                            DPQ = 0u32
                            if kd < 0i64 { DPQ = 1u32 }
                            DPKD = kd
                            DPLS = gls   DPLH = glh   DPHS = ghs   DPHH = ghh
                            DPLD = gld   DPHD = ghd
                            pinned = 1u32
                        } else { if c == 0i64 { code = 6u64 } } }
                    }
                } }
                if pinned == 0u32 { if needref == 0u32 {
                    /* this round's gamma handles are dead (never drop the CQH slots) */
                    if op != 2i64 { if built == 1u32 { bigint_drop(glh)   bigint_drop(ghh) } }
                    else {
                        if rn2k != 0u64 { bigint_drop(rn2k) }
                        if rone != 0u64 { bigint_drop(rone) }
                        if rsad != 0u64 { bigint_drop(rsad) }
                    }
                    if code == 9u64 { if aa_dref(op, dga, dgb) == 0u32 { code = 5u64 } }
                } }
            }
        }
    } }
    if code != 9u64 { cq_free() }
    return code
}

fn emit_alg_arith(op: i64, nca: u64, loa: i64, hia: i64, ncb: u64, lob: i64, hib: i64) -> u64 {
    let ra : u64 = alg2_load(0i64, (&RC) as u64, nca, loa, hia)
    if ra != 9u64 { return ra }
    let mut dgb : i64 = 0i64
    if op != 2i64 {
        let rb : u64 = alg2_load(1i64, (&RC2) as u64, ncb, lob, hib)
        if rb != 9u64 { return rb }
        dgb = ADG[1u64]
    }
    let mut dga : i64 = ADG[0u64]
    let za : u64 = AZR[0u64]
    if op == 1i64 {
        let zb : u64 = AZR[1u64]
        if zb == 1u64 { ps("PRODUCT: exactly 0 (B is the zero algebraic number)\n" as u64)  return 0u64 }
        if za == 1u64 { ps("PRODUCT: exactly 0 (A is the zero algebraic number)\n" as u64)  return 0u64 }
        dga = strip_x((&RC) as u64, dga)
        dgb = strip_x((&RC2) as u64, dgb)
        if dga < 1i64 { ps("INTERNAL REFUSE: A collapsed under x-stripping -- no claim\n" as u64)  return 6u64 }
        if dgb < 1i64 { ps("INTERNAL REFUSE: B collapsed under x-stripping -- no claim\n" as u64)  return 6u64 }
    }
    if op == 2i64 {
        if za == 1u64 { ps("REFUSED: the inverse of the zero algebraic number does not exist\n" as u64)  return 4u64 }
        dga = strip_x((&RC) as u64, dga)
        if dga < 1i64 { ps("INTERNAL REFUSE: A collapsed under x-stripping -- no claim\n" as u64)  return 6u64 }
    }
    if op != 2i64 {
        let dd0 : i64 = dga * dgb
        if dd0 > 3072i64 {
            ps("ABSTAIN: degree(A) * degree(B) = " as u64)  pi(dd0)
            ps(" exceeds 3072 -- the recovery geometry's bound (the adaptive <= 2048-prime bnd certification\n" as u64)
            ps("  applies per run inside it); refused, not guessed\n" as u64)
            return 5u64
        }
    }
    let mut rd : i64 = 0i64
    if op == 0i64 { rd = rs_sum_big2((&RC) as u64, dga, (&RC2) as u64, dgb, (&RSO) as u64) }
    if op == 1i64 { rd = rs_prod_big2((&RC) as u64, dga, (&RC2) as u64, dgb, (&RSO) as u64) }
    if op == 2i64 { rd = rs_inv((&RC) as u64, dga, (&RSO) as u64) }
    if rd < 1i64 { ps("ABSTAIN: the construction engine refused (outside its certified envelope)\n" as u64)  return 5u64 }
    GDEG = rd
    if op == 2i64 { gb_from_i64((&RSO) as u64, rd) }
    else {
        let mut i : i64 = 0i64
        while i <= rd {
            let ln : i64 = rs_big_len(i)
            if ln > 64i64 { ps("ABSTAIN: a coefficient exceeds the limb-row envelope\n" as u64)  return 5u64 }
            GBS[i as u64] = rs_big_sgn(i)
            GBL[i as u64] = ln
            let mut j : i64 = 0i64
            while j < ln { GBW[((i * 256i64) + j) as u64] = rs_big_limb(i, j)   j = j + 1i64 }
            i = i + 1i64
        }
    }
    AAL[0u64] = loa   AAH[0u64] = hia
    AAL[1u64] = lob   AAH[1u64] = hib
    AAK = 0i64
    DPON = 0u32
    let mut done : u32 = 0u32
    let mut code : u64 = 9u64
    while done == 0u32 {
        /* PRODUCT/INVERSE: the window formulas need sign-definite operand intervals first */
        let mut needref : u32 = 0u32
        if op != 0i64 {
            let l0 : i64 = AAL[0u64]
            let h0 : i64 = AAH[0u64]
            if l0 < 1i64 { if h0 > (0i64 - 1i64) { needref = 1u32 } }
        }
        if op == 1i64 {
            let l1 : i64 = AAL[1u64]
            let h1 : i64 = AAH[1u64]
            if l1 < 1i64 { if h1 > (0i64 - 1i64) { needref = 1u32 } }
        }
        if needref == 0u32 {
            let ga : u64 = aa_gamma(op)
            if ga != 9u64 {
                if ga == 5u64 {
                    /* the i64 window formulas left their envelope: THE DEEP TIER takes over */
                    let dp : u64 = aa_deep(op, dga, dgb, rd)
                    if dp == 9u64 { done = 1u32 }
                    else {
                        if dp == 5u64 { ps("ABSTAIN: the deep pinning tier exhausted its resource envelope (memory) -- refused, not guessed\n" as u64) }
                        else { ps("INTERNAL REFUSE: deep pinning passed the separation bound or lost the root -- no claim\n" as u64) }
                        code = dp   done = 1u32
                    }
                }
                else { ps("INTERNAL REFUSE: the window construction failed -- no claim\n" as u64)   code = ga   done = 1u32 }
            } else {
                let bc : i64 = gb_build(rd)
                if bc < 0i64 { ps("ABSTAIN: the bigint chain refused the result polynomial\n" as u64)  code = 5u64   done = 1u32 }
                else {
                    let c : i64 = root_count2(GLO, GLD, GHI, GHD)
                    if c == 1i64 { done = 1u32 }
                    else { if c < 1i64 {
                        ps("INTERNAL REFUSE: gamma's window lost the root -- no claim\n" as u64)
                        code = 6u64   done = 1u32
                    } }
                }
            }
        }
        if done == 0u32 {
            if AAK >= 20i64 {
                /* the i64 refinement wall: THE DEEP TIER takes over (no abstention) */
                let dp2 : u64 = aa_deep(op, dga, dgb, rd)
                if dp2 == 9u64 { done = 1u32 }
                else {
                    if dp2 == 5u64 { ps("ABSTAIN: the deep pinning tier exhausted its resource envelope (memory) -- refused, not guessed\n" as u64) }
                    else { ps("INTERNAL REFUSE: deep pinning passed the separation bound or lost the root -- no claim\n" as u64) }
                    code = dp2   done = 1u32
                }
            }
            else {
                let r1 : u64 = aa_refine(0i64, (&RC) as u64, dga)
                if r1 != 9u64 { code = r1   done = 1u32 }
                else {
                    if op == 2i64 { AAK = AAK + 1i64 }
                    else {
                        let r2 : u64 = aa_refine(1i64, (&RC2) as u64, dgb)
                        if r2 != 9u64 { code = r2   done = 1u32 }
                        else { AAK = AAK + 1i64 }
                    }
                }
            }
        }
    }
    if code != 9u64 { return code }
    let ba : i64 = sqrt_shape((&RC) as u64, dga, loa)
    let mut bb : i64 = 0i64
    if op != 2i64 { bb = sqrt_shape((&RC2) as u64, dgb, lob) }
    let mut wantch : u32 = 0u32
    if op == 2i64 { if ba > 0i64 { wantch = 1u32 } }
    else { if ba > 0i64 { if bb > 0i64 { wantch = 1u32 } } }
    if DPON == 1u32 { wantch = 0u32 }                      /* deep windows: the oracle's i64 form does not apply */
    let mut oracle : u32 = 0u32
    if wantch == 1u32 {
        let sc : u64 = aa_sqrtchk(op, ba, bb)
        if sc != 9u64 { ps("INTERNAL REFUSE: the Sigma-sqrt oracle disagrees with the certified window -- no claim\n" as u64)  return 6u64 }
        oracle = 1u32
    }
    if op == 0i64 { ps("SUM  alpha + beta  is a root of the degree-" as u64) }
    if op == 1i64 { ps("PRODUCT  alpha * beta  is a root of the degree-" as u64) }
    if op == 2i64 { ps("INVERSE  1/alpha  is a root of the degree-" as u64) }
    pi(GDEG)  ps(" integer polynomial R:\n" as u64)
    gb_poly_print(GDEG)
    if DPON == 1u32 {
        ps("  isolated EXACTLY in (" as u64)
        if DPQ == 0u32 {
            ph_dyadic(CQAR, DPLS, DPLH, DPKD)
            ps(", " as u64)
            ph_dyadic(CQAR, DPHS, DPHH, DPKD)
        } else {
            if DPLS < 0i64 { putchar(45i32) }
            ph_dec(DPLH)   putchar(47i32)   ph_dec(DPLD)
            ps(", " as u64)
            if DPHS < 0i64 { putchar(45i32) }
            ph_dec(DPHH)   putchar(47i32)   ph_dec(DPHD)
        }
        ps("]   [bigint-Sturm: exactly ONE root of R in this window -- pinned through the DEEP tier]\n" as u64)
        cq_free()
    } else {
        ps("  isolated EXACTLY in (" as u64)  pr_ratr(GLO, GLD)  ps(", " as u64)  pr_ratr(GHI, GHD)
        ps("]   [bigint-Sturm: exactly ONE root of R in this window]\n" as u64)
    }
    if oracle == 1u32 { ps("  [the Sigma-sqrt separation-bound oracle independently confirms gamma lies in this window]\n" as u64) }
    ps("  (R is a resultant/reversal -- A defining polynomial, possibly non-minimal; the window pins WHICH root)\n" as u64)
    return 0u64
}

/* ── --roots-big: isolation past the i64 chain wall ─────────────────────────────────────────── */

const LIMBFAIL : u64 = 18446744073709551614u64
const RBDEP : i64 = 24i64

/* one (possibly huge) decimal token from str at RB_POS, accumulated exactly into a bigint in ar. */
fn rb_tok(str: u64, ar: u64) -> u64 {
    let p : *u8 = str as *u8
    PB_OK = 0u64   PB_SGN = 1i64
    let mut i : u64 = RB_POS
    while p[i] == 32u8 { i = i + 1u64 }
    while p[i] == 9u8 { i = i + 1u64 }
    if p[i] == 0u8 { RB_POS = i   return 0u64 }
    if p[i] == 45u8 { PB_SGN = 0i64 - 1i64   i = i + 1u64 }
    else { if p[i] == 43u8 { i = i + 1u64 } }
    if p[i] < 48u8 { PB_ERR = 1u64   RB_POS = i   return 0u64 }
    if p[i] > 57u8 { PB_ERR = 1u64   RB_POS = i   return 0u64 }
    let mut h : u64 = bigint_from_u64(ar, 0u64)
    let mut nd : u64 = 0u64
    let mut nz : u64 = 0u64
    while p[i] >= 48u8 {
        if p[i] > 57u8 { PB_ERR = 1u64   RB_POS = i   return h }
        let t : u64 = bigint_mul_u64(ar, h, 10u64)
        bigint_drop(h)
        let dgt : u64 = bigint_from_u64(ar, (p[i] as u64) - 48u64)
        let t2 : u64 = bigint_add(ar, t, dgt)
        bigint_drop(t)   bigint_drop(dgt)
        h = t2
        if p[i] != 48u8 { nz = 1u64 }
        nd = nd + 1u64
        if nd > 4930u64 { PB_ERR = 1u64   RB_POS = i   return h }
        i = i + 1u64
    }
    RB_POS = i
    PB_OK = 1u64
    if nz == 0u64 { PB_SGN = 0i64 }
    return h
}

/* the whole coefficient list -> GBS/GBL/GBW limb rows.  Count, or PARSEFAIL / LIMBFAIL. */
fn rb_parse(str: u64) -> u64 {
    RB_POS = 0u64   PB_ERR = 0u64
    let ar : u64 = arena_new(4194304u64)
    let mut n : u64 = 0u64
    let mut res : u64 = 0u64
    let mut going : u8 = 1u8
    while going == 1u8 {
        let h : u64 = rb_tok(str, ar)
        if PB_ERR == 1u64 { res = PARSEFAIL   going = 0u8 }
        else { if PB_OK == 0u64 { res = n   going = 0u8 }
        else {
            if n >= 4096u64 { res = PARSEFAIL   going = 0u8 }
            else {
                if PB_SGN == 0i64 { GBS[n] = 0i64   GBL[n] = 0i64 }
                else {
                    let ln : u64 = bigint_len_limbs(h)
                    if ln > 256u64 { res = LIMBFAIL   going = 0u8 }
                    else {
                        GBS[n] = PB_SGN
                        GBL[n] = ln as i64
                        let mut j : u64 = 0u64
                        while j < ln { GBW[(n * 256u64) + j] = bigint_get_limb(h, j)   j = j + 1u64 }
                    }
                }
                if going == 1u8 { bigint_drop(h)   n = n + 1u64 }
            }
        } }
    }
    bigint_drop_arena(ar)
    arena_drop(ar)
    return res
}

fn gb_deg(n: u64) -> i64 {
    let mut k : i64 = (n as i64) - 1i64
    let mut going : u8 = 1u8
    while going == 1u8 {
        if k < 0i64 { going = 0u8 }
        else { let s : i64 = GBS[k as u64]   if s != 0i64 { going = 0u8 } else { k = k - 1i64 } }
    }
    return k
}

/* dyadic bisection over the (already built) bigint chain: split (l/2^k, h/2^k] until each piece
 * holds exactly one distinct root; record RAW at the interval's own attained depth (ILN/IHN/IKD --
 * the caller rescales to the max depth under explicit guards).  Every doubling is pre-guarded so
 * no numerator ever leaves exact i64.  RBCL marks a cluster unsplit at the cap.  Count, or -1. */
fn rb_bisect(lo: i64, hi: i64) -> i64 {
    RBCL = 0u64
    CLC = 0i64
    DRN = 0i64
    WK2L[0u64] = lo   WK2H[0u64] = hi   WK2K[0u64] = 0i64
    let mut top : i64 = 1i64
    let mut nrec : i64 = 0i64
    let mut guard : i64 = 0i64
    while top > 0i64 {
        if guard > 20000i64 { return 0i64 - 1i64 }
        guard = guard + 1i64
        top = top - 1i64
        let l : i64 = WK2L[top as u64]
        let h : i64 = WK2H[top as u64]
        let k : i64 = WK2K[top as u64]
        let dk : i64 = pw2(k)
        let c : i64 = root_count2(l, dk, h, dk)
        if c < 0i64 { return 0i64 - 2i64 }                /* eval resource refusal -> memory abstention */
        if c == 1i64 {
            if nrec >= 3840i64 { return 0i64 - 1i64 }
            ILN[nrec as u64] = l   IHN[nrec as u64] = h   IKD[nrec as u64] = k
            nrec = nrec + 1i64
        } else { if c > 1i64 {
            let mut la : i64 = l   if la < 0i64 { la = 0i64 - la }
            let mut ha : i64 = h   if ha < 0i64 { ha = 0i64 - ha }
            let mut big : u32 = 0u32
            if la >= 2305843009213693952i64 { big = 1u32 }              /* 2^61: doubling stays exact */
            if ha >= 2305843009213693952i64 { big = 1u32 }
            let mut clrec : u32 = 0u32
            if k >= RBDEP { clrec = 1u32 }
            else { if big == 1u32 { clrec = 1u32 } }
            if clrec == 1u32 {
                /* a CLUSTER at the i64 tier's cap: recorded as a seed for the DEEP splitter */
                RBCL = 1u64
                if CLC >= 64i64 { return 0i64 - 1i64 }
                CLL[CLC as u64] = l   CLH[CLC as u64] = h   CLKD[CLC as u64] = k
                CLC = CLC + 1i64
            }
            else { if top < 12284i64 {
                let l2 : i64 = 2i64 * l
                let h2 : i64 = 2i64 * h
                let mid : i64 = l + h
                WK2L[top as u64] = l2    WK2H[top as u64] = mid   WK2K[top as u64] = k + 1i64   top = top + 1i64
                WK2L[top as u64] = mid   WK2H[top as u64] = h2    WK2K[top as u64] = k + 1i64   top = top + 1i64
            } else { return 0i64 - 1i64 } }
        } }
    }
    return nrec
}

/* rescale the raw recorded intervals to the max attained depth (uniform denominator -> plain
 * numerator compares).  9 = ok, 5 = a coordinate would leave exact i64 (abstain, never rounded). */
fn rb_rescale(nrec: i64) -> u64 {
    let mut kmax : i64 = 0i64
    let mut i : i64 = 0i64
    while i < nrec {
        let k : i64 = IKD[i as u64]
        if k > kmax { kmax = k }
        i = i + 1i64
    }
    let dmax : i64 = pw2(kmax)
    i = 0i64
    while i < nrec {
        let k : i64 = IKD[i as u64]
        let s : i64 = pw2(kmax - k)
        let ln : i64 = ILN[i as u64]
        let hn : i64 = IHN[i as u64]
        let mut la : i64 = ln   if la < 0i64 { la = 0i64 - la }
        let mut ha : i64 = hn   if ha < 0i64 { ha = 0i64 - ha }
        let lim : i64 = 4611686018427387904i64 / s                      /* 2^62 / s */
        if la >= lim { ps("ABSTAIN: interval coordinates left the exact envelope -- refused, not guessed\n" as u64)  return 5u64 }
        if ha >= lim { ps("ABSTAIN: interval coordinates left the exact envelope -- refused, not guessed\n" as u64)  return 5u64 }
        ILN[i as u64] = ln * s   ILD[i as u64] = dmax
        IHN[i as u64] = hn * s   IHD[i as u64] = dmax
        i = i + 1i64
    }
    return 9u64
}

/* per-root multiplicity through the raw-ABI door (reloads the CUR rows per interval). */
fn rb_mults(deg: i64, n: i64) -> u64 {
    RSUM = 0i64
    let mut i : i64 = 0i64
    while i < n {
        if gb_load(deg) != 0i32 { ps("INTERNAL REFUSE: row reload failed -- no claim\n" as u64)  return 6u64 }
        let ln : i64 = ILN[i as u64]   let ld : i64 = ILD[i as u64]
        let hn : i64 = IHN[i as u64]   let hd : i64 = IHD[i as u64]
        let m : i64 = root_mult2_cur(ln, ld, hn, hd)
        if m < 1i64 { ps("INTERNAL REFUSE: multiplicity certification failed -- no claim\n" as u64)  return 6u64 }
        IMU[i as u64] = m
        RSUM = RSUM + m
        i = i + 1i64
    }
    let s : i64 = RSUM
    if s > deg { ps("INTERNAL REFUSE: multiplicities exceed the degree -- no claim\n" as u64)  return 6u64 }
    return 9u64
}

/* --roots-big: real-root isolation for integer polynomials with coefficients of ANY size (decimal,
 * <= 4930 digits / 256 limbs each) to degree 60, THROUGH the bigint Sturm chain -- the tier past the
 * i64 chain wall (gate 2185).  The window is required and explicit: all claims are about (lo, hi]. */
fn emit_roots_big(str: u64, lo: i64, hi: i64) -> u64 {
    let pn : u64 = rb_parse(str)
    if pn == PARSEFAIL { ps("iii exact: parse error in the coefficient list (decimal integers, <= 4930 digits each)\n" as u64)  return 3u64 }
    if pn == LIMBFAIL { ps("ABSTAIN: a coefficient exceeds 256 limbs -- outside the engine's row envelope\n" as u64)  return 5u64 }
    if pn == 0u64 { ps("iii exact: empty coefficient list\n" as u64)  return 3u64 }
    let deg : i64 = gb_deg(pn)
    if deg < 0i64 { ps("iii exact: the zero polynomial (every real is a root) -- refused\n" as u64)  return 3u64 }
    if deg == 0i64 { ps("DISTINCT REAL ROOTS: 0   (nonzero constant)\n" as u64)  return 0u64 }
    if deg > 3840i64 { ps("ABSTAIN: degree > 3840 is outside the bigint-chain envelope -- refused, not guessed\n" as u64)  return 5u64 }
    if lo >= hi { ps("iii exact: --roots-big window needs lo < hi\n" as u64)  return 3u64 }
    if lo < (0i64 - 17592186044416i64) { ps("ABSTAIN: window endpoint outside the envelope (|.| <= 2^44)\n" as u64)  return 5u64 }
    if hi > 17592186044416i64 { ps("ABSTAIN: window endpoint outside the envelope (|.| <= 2^44)\n" as u64)  return 5u64 }
    let bc : i64 = gb_build(deg)
    if bc < 0i64 { ps("ABSTAIN: the bigint chain refused this polynomial (pool envelope)\n" as u64)  return 5u64 }
    let w : i64 = root_count2(lo, 1i64, hi, 1i64)
    if w < 0i64 { ps("INTERNAL REFUSE: negative certified count -- no claim\n" as u64)  return 6u64 }
    if w > deg { ps("INTERNAL REFUSE: certified count exceeds the degree -- no claim\n" as u64)  return 6u64 }
    if w == 0i64 {
        ps("DISTINCT REAL ROOTS in (" as u64)  pi(lo)  ps(", " as u64)  pi(hi)  ps("]: 0   [bigint-Sturm certified]\n" as u64)
        return 0u64
    }
    let nrec : i64 = rb_bisect(lo, hi)
    if nrec == (0i64 - 2i64) { ps("ABSTAIN: chain evaluation exhausted its resource envelope (memory) -- refused, not guessed\n" as u64)  return 5u64 }
    if nrec < 0i64 { ps("INTERNAL REFUSE: the bisection driver overflowed its work bounds -- no claim\n" as u64)  return 6u64 }
    /* THE DEEP SPLITTER: clusters at the i64 tier's 2^-24 cap descend through the handle door --
     * counting only, so the input's chain (built above, still standing) serves every cluster. */
    if CLC > 0i64 {
        let mut mlmax : i64 = 1i64
        let mut mz : i64 = 0i64
        while mz <= deg { if GBL[mz as u64] > mlmax { mlmax = GBL[mz as u64] }   mz = mz + 1i64 }
        let dmaxr : i64 = (128i64 * deg * (mlmax + 2i64)) + 2048i64
        let mut cz : i64 = 0i64
        while cz < CLC {
            CLDR0[cz as u64] = DRN
            let dsc : u64 = rb_deepsplit(CLL[cz as u64], CLH[cz as u64], CLKD[cz as u64], dmaxr)
            if dsc == 5u64 { ps("ABSTAIN: the deep splitter exhausted its resource envelope (memory/rows) -- refused, not guessed\n" as u64)  return 5u64 }
            if dsc != 9u64 { ps("INTERNAL REFUSE: the deep splitter passed the separation bound -- indicates a defect; no claim\n" as u64)  return 6u64 }
            CLDRN[cz as u64] = DRN - CLDR0[cz as u64]
            cz = cz + 1i64
        }
    }
    if (nrec + DRN) != w { ps("INTERNAL REFUSE: isolated-count mismatch after deep splitting -- no claim\n" as u64)  return 6u64 }
    let rs : u64 = rb_rescale(nrec)
    if rs != 9u64 { return rs }
    let mut i : i64 = 0i64
    while i < nrec {
        let mut best : i64 = i
        let mut j : i64 = i + 1i64
        while j < nrec {
            let a : i64 = ILN[j as u64]
            let b : i64 = ILN[best as u64]
            if a < b { best = j }
            j = j + 1i64
        }
        if best != i { iv_swap(i as u64, best as u64) }
        i = i + 1i64
    }
    i = 0i64
    while i < (nrec - 1i64) {
        let hn0 : i64 = IHN[i as u64]
        let ln1 : i64 = ILN[(i + 1i64) as u64]
        if hn0 > ln1 { ps("INTERNAL REFUSE: recorded intervals overlap -- no claim\n" as u64)  return 6u64 }
        i = i + 1i64
    }
    let mm : u64 = rb_mults(deg, nrec)
    if mm != 9u64 { return mm }
    /* deep multiplicities through root_mult2_cur_h (rows reloaded per root; window H = L + W) */
    if DRN > 0i64 {
        let par : u64 = arena_new(8388608u64)
        if par == 0u64 { ps("ABSTAIN: the deep multiplicity arena is unavailable (memory)\n" as u64)  return 5u64 }
        CQAR = par
        let mut dz : i64 = 0i64
        let mut dbad : u32 = 0u32
        while dz < DRN { if dbad == 0u32 {
            if gb_load(deg) != 0i32 { dbad = 1u32 }
            else {
                let lhh : u64 = dr_load(par, dz)
                if lhh == 0u64 { dbad = 1u32 }
                else {
                    let wv : u64 = bigint_from_u64(par, DRW[dz as u64] as u64)
                    if wv == 0u64 { dbad = 1u32   bigint_drop(lhh) }
                    else {
                        if c_sadd(DRS[dz as u64], lhh, 1i64, wv) == 0u32 { dbad = 1u32   bigint_drop(lhh)   bigint_drop(wv) }
                        else {
                            let m2 : i64 = root_mult2_cur_h(lhh, DRS[dz as u64], CQTH, CQTS, DRK[dz as u64])
                            bigint_drop(CQTH)   bigint_drop(lhh)   bigint_drop(wv)
                            if m2 < 1i64 { dbad = 1u32 }
                            else { DRM[dz as u64] = m2   RSUM = RSUM + m2 }
                        }
                    }
                }
            }
        }   dz = dz + 1i64 }
        bigint_drop_arena(par)
        arena_drop(par)
        CQAR = 0u64
        if dbad == 1u32 { ps("INTERNAL REFUSE: deep multiplicity certification failed -- no claim\n" as u64)  return 6u64 }
        if RSUM > deg { ps("INTERNAL REFUSE: multiplicities exceed the degree -- no claim\n" as u64)  return 6u64 }
        /* rebuild the input's chain for nothing further -- printing only below */
    }
    /* a COMMON position depth for the merge: max of the i64 windows' rescaled denominator and
     * every cluster's seed depth; both sides scale to it under explicit exactness guards */
    let mut kall : i64 = 1i64
    i = 0i64
    while i < nrec { if ILD[i as u64] > kall { kall = ILD[i as u64] }   i = i + 1i64 }   /* = 2^kmax */
    let mut cz2 : i64 = 0i64
    while cz2 < CLC { let dvc : i64 = pw2(CLKD[cz2 as u64])   if dvc > kall { kall = dvc }   cz2 = cz2 + 1i64 }
    let mut clbad : u32 = 0u32
    i = 0i64
    while i < nrec {                                        /* i64 windows -> merge positions (IKD reused) */
        let sc0 : i64 = kall / ILD[i as u64]
        let lv0 : i64 = ILN[i as u64]
        let mut la0 : i64 = lv0   if la0 < 0i64 { la0 = 0i64 - la0 }
        if la0 >= (4611686018427387904i64 / sc0) { clbad = 1u32 }
        else { IKD[i as u64] = lv0 * sc0 }
        i = i + 1i64
    }
    cz2 = 0i64
    while cz2 < CLC {
        let dv : i64 = pw2(CLKD[cz2 as u64])
        let sc : i64 = kall / dv
        let lv : i64 = CLL[cz2 as u64]
        let mut la2 : i64 = lv   if la2 < 0i64 { la2 = 0i64 - la2 }
        if la2 >= (4611686018427387904i64 / sc) { clbad = 1u32 }
        else { CLPOS[cz2 as u64] = lv * sc }
        cz2 = cz2 + 1i64
    }
    if clbad == 1u32 { ps("ABSTAIN: cluster coordinates left the exact envelope -- refused, not guessed\n" as u64)  return 5u64 }
    /* selection-sort the clusters by position (ranges travel with them) */
    cz2 = 0i64
    while cz2 < CLC {
        let mut bc2 : i64 = cz2
        let mut cj : i64 = cz2 + 1i64
        while cj < CLC { if CLPOS[cj as u64] < CLPOS[bc2 as u64] { bc2 = cj }   cj = cj + 1i64 }
        if bc2 != cz2 {
            let t0 : i64 = CLPOS[cz2 as u64]   CLPOS[cz2 as u64] = CLPOS[bc2 as u64]   CLPOS[bc2 as u64] = t0
            let t1 : i64 = CLDR0[cz2 as u64]   CLDR0[cz2 as u64] = CLDR0[bc2 as u64]   CLDR0[bc2 as u64] = t1
            let t2 : i64 = CLDRN[cz2 as u64]   CLDRN[cz2 as u64] = CLDRN[bc2 as u64]   CLDRN[bc2 as u64] = t2
        }
        cz2 = cz2 + 1i64
    }
    let total : i64 = nrec + DRN
    ps("DISTINCT REAL ROOTS in (" as u64)  pi(lo)  ps(", " as u64)  pi(hi)  ps("]: " as u64)  pi(total)
    ps("   [bigint-Sturm certified -- the tier past the i64 chain wall (gate 2185)]\n" as u64)
    let par2 : u64 = arena_new(8388608u64)
    if par2 == 0u64 { ps("ABSTAIN: the print arena is unavailable (memory)\n" as u64)  return 5u64 }
    CQAR = par2
    let mut ii : i64 = 0i64
    let mut ci : i64 = 0i64
    let mut rn : i64 = 1i64
    let mut pbad : u32 = 0u32
    while (ii < nrec) { if pbad == 0u32 {
        /* clusters positioned before the next i64 window print first */
        let mut go_cl : u32 = 0u32
        if ci < CLC { if CLPOS[ci as u64] < IKD[ii as u64] { go_cl = 1u32 } }
        if go_cl == 1u32 {
            let d0 : i64 = CLDR0[ci as u64]
            let dn : i64 = CLDRN[ci as u64]
            let mut dj : i64 = 0i64
            while dj < dn { if pbad == 0u32 {
                let idx : i64 = d0 + dj
                let lh2 : u64 = dr_load(par2, idx)
                if lh2 == 0u64 { pbad = 1u32 }
                else {
                    let wv2 : u64 = bigint_from_u64(par2, DRW[idx as u64] as u64)
                    if wv2 == 0u64 { pbad = 1u32   bigint_drop(lh2) }
                    else { if c_sadd(DRS[idx as u64], lh2, 1i64, wv2) == 0u32 { pbad = 1u32   bigint_drop(lh2)   bigint_drop(wv2) }
                    else {
                        ps("  root " as u64)  pi(rn)  ps(": in (" as u64)
                        ph_dyadic(par2, DRS[idx as u64], lh2, DRK[idx as u64])
                        ps(", " as u64)
                        ph_dyadic(par2, CQTS, CQTH, DRK[idx as u64])
                        ps("]   multiplicity " as u64)  pi(DRM[idx as u64])
                        if (DRM[idx as u64] % 2i64) == 0i64 { ps("  -- TOUCHES the axis, no sign change (invisible to every sign-sampler)\n" as u64) }
                        else { ps("  -- crosses the axis\n" as u64) }
                        rn = rn + 1i64
                        bigint_drop(CQTH)   bigint_drop(lh2)   bigint_drop(wv2)
                    } }
                }
            }   dj = dj + 1i64 }
            ci = ci + 1i64
        } else {
            let ln : i64 = ILN[ii as u64]   let ld : i64 = ILD[ii as u64]
            let hn : i64 = IHN[ii as u64]   let hd : i64 = IHD[ii as u64]
            let m : i64 = IMU[ii as u64]
            ps("  root " as u64)  pi(rn)  ps(": in (" as u64)  pr_ratr(ln, ld)  ps(", " as u64)  pr_ratr(hn, hd)
            ps("]   multiplicity " as u64)  pi(m)
            if (m % 2i64) == 0i64 { ps("  -- TOUCHES the axis, no sign change (invisible to every sign-sampler)\n" as u64) }
            else { ps("  -- crosses the axis\n" as u64) }
            rn = rn + 1i64
            ii = ii + 1i64
        }
    } else { ii = nrec } }
    /* trailing clusters */
    while (ci < CLC) { if pbad == 0u32 {
        let d0 : i64 = CLDR0[ci as u64]
        let dn : i64 = CLDRN[ci as u64]
        let mut dj : i64 = 0i64
        while dj < dn { if pbad == 0u32 {
            let idx : i64 = d0 + dj
            let lh2 : u64 = dr_load(par2, idx)
            if lh2 == 0u64 { pbad = 1u32 }
            else {
                let wv2 : u64 = bigint_from_u64(par2, DRW[idx as u64] as u64)
                if wv2 == 0u64 { pbad = 1u32   bigint_drop(lh2) }
                else { if c_sadd(DRS[idx as u64], lh2, 1i64, wv2) == 0u32 { pbad = 1u32   bigint_drop(lh2)   bigint_drop(wv2) }
                else {
                    ps("  root " as u64)  pi(rn)  ps(": in (" as u64)
                    ph_dyadic(par2, DRS[idx as u64], lh2, DRK[idx as u64])
                    ps(", " as u64)
                    ph_dyadic(par2, CQTS, CQTH, DRK[idx as u64])
                    ps("]   multiplicity " as u64)  pi(DRM[idx as u64])
                    if (DRM[idx as u64] % 2i64) == 0i64 { ps("  -- TOUCHES the axis, no sign change (invisible to every sign-sampler)\n" as u64) }
                    else { ps("  -- crosses the axis\n" as u64) }
                    rn = rn + 1i64
                    bigint_drop(CQTH)   bigint_drop(lh2)   bigint_drop(wv2)
                } }
            }
        }   dj = dj + 1i64 }
        ci = ci + 1i64
    } else { ci = CLC } }
    bigint_drop_arena(par2)
    arena_drop(par2)
    CQAR = 0u64
    if pbad == 1u32 { ps("\nINTERNAL REFUSE: the deep print path exhausted resources mid-claim\n" as u64)  return 6u64 }
    let s : i64 = RSUM
    ps("  with multiplicity: " as u64)  pi(s)  ps(" of degree " as u64)  pi(deg)
    let rem : i64 = deg - s
    if rem > 0i64 { ps("  (" as u64)  pi(rem)  ps(" non-real or outside the window)" as u64) }
    nl()
    return 0u64
}

/* the six --alg two-number args (A lo hi B lo hi) -> RC/RC2 + AP6/APN.  9 = ok, else the exit. */
var AP6 : [i64; 4]   var APN : [u64; 2]
fn parse_alg6(a2: u64, a3: u64, a4: u64, a5: u64, a6: u64, a7: u64) -> u64 {
    let ca : u64 = parse_list(a2, (&RC) as u64)
    if ca == PARSEFAIL { ps("iii exact: parse error in polynomial A\n" as u64)  return 3u64 }
    if ca == 0u64 { ps("iii exact: empty polynomial A\n" as u64)  return 3u64 }
    let la : i64 = parse_one(a3)
    if P1_OK != 1u32 { ps("iii exact: parse error in A's lo\n" as u64)  return 3u64 }
    let ha : i64 = parse_one(a4)
    if P1_OK != 1u32 { ps("iii exact: parse error in A's hi\n" as u64)  return 3u64 }
    let cb : u64 = parse_list(a5, (&RC2) as u64)
    if cb == PARSEFAIL { ps("iii exact: parse error in polynomial B\n" as u64)  return 3u64 }
    if cb == 0u64 { ps("iii exact: empty polynomial B\n" as u64)  return 3u64 }
    let lb : i64 = parse_one(a6)
    if P1_OK != 1u32 { ps("iii exact: parse error in B's lo\n" as u64)  return 3u64 }
    let hb : i64 = parse_one(a7)
    if P1_OK != 1u32 { ps("iii exact: parse error in B's hi\n" as u64)  return 3u64 }
    APN[0u64] = ca   APN[1u64] = cb
    AP6[0u64] = la   AP6[1u64] = ha   AP6[2u64] = lb   AP6[3u64] = hb
    return 9u64
}

fn exact_enter(argc: i32, argv: u64) -> u64 @export {
    let av : *u64 = argv as *u64
    if argc < 2i32 {
        ps("iii exact -- EXACT sign of a sum of square roots (no floating point anywhere)\n\n" as u64)
        ps("  iii exact \"<a1> <b1> <a2> <b2> ...\"      sign of  a1*sqrt(b1) + a2*sqrt(b2) + ...\n" as u64)
        ps("  iii exact --cmp \"<A terms>\" \"<B terms>\"   sign of (sum A) - (sum B)\n" as u64)
        ps("  iii exact --denest <a> <b> <d>            is a + b*sqrt(d) a perfect square in Q(sqrt(d))?\n" as u64)
        ps("  iii exact --roots \"<c0 c1 ... cd>\" [lo hi]   isolate ALL real roots of c0+c1*x+...+cd*x^d\n" as u64)
        ps("                                            (+ exact multiplicity), bigint-certified\n" as u64)
        ps("  iii exact --alg-sign \"<c0 ... cd>\" <lo> <hi>  sign of THE root isolated in (lo, hi]\n" as u64)
        ps("                                            (deg <= 3840, coefficients to ~4930 digits)\n" as u64)
        ps("  iii exact --alg-cmp \"<A>\" <lo> <hi> \"<B>\" <lo> <hi>   order / EQUALITY of two algebraic numbers\n" as u64)
        ps("                                            (same class; equality by the pair-gcd door)\n" as u64)
        ps("  iii exact --alg-add | --alg-mul \"<A>\" <lo> <hi> \"<B>\" <lo> <hi>   the defining polynomial +\n" as u64)
        ps("                                            certified window of alpha+beta / alpha*beta (closure;\n" as u64)
        ps("                                            deg <= 1536 each, degA*degB <= 3072, either sign)\n" as u64)
        ps("  iii exact --alg-inv \"<A>\" <lo> <hi>       the defining polynomial + certified window of 1/alpha\n" as u64)
        ps("  iii exact --roots-big \"<c0 .. cd>\" <lo> <hi>  isolation past the i64 wall: deg <= 3840, coefficients\n" as u64)
        ps("                                            to ~4930 digits (256 limbs)\n\n" as u64)
        ps("  a_i signed integer coefficient, b_i non-negative integer radicand.\n" as u64)
        ps("  exit (sign modes, --alg-sign): 1 NEGATIVE | 0 EXACTLY ZERO | 2 POSITIVE | 3 parse error.\n" as u64)
        ps("  exit (--denest):   0 square (root printed, re-verified) | 4 extension | 5 abstain | 3 parse.\n" as u64)
        ps("  exit (--roots):    0 certified | 3 parse | 5 abstain | 6 refuse (failed re-certification).\n" as u64)
        ps("  exit (--alg-cmp):  1 A<B | 0 EQUAL | 2 A>B | 4 refused | 5 abstain | 6 cross-check failed.\n" as u64)
        return 3u64
    }

    let a0 : *u8 = av[1u64] as *u8
    if a0[0u64] == 45u8 { if a0[1u64] == 45u8 {
        if a0[2u64] == 100u8 {                          /* "--denest" <a> <b> <d> */
            if argc < 5i32 { ps("iii exact: --denest needs three integers: a b d\n" as u64)  return 3u64 }
            let da : i64 = parse_one(av[2u64])
            if P1_OK != 1u32 { ps("iii exact: parse error in a\n" as u64)  return 3u64 }
            let db : i64 = parse_one(av[3u64])
            if P1_OK != 1u32 { ps("iii exact: parse error in b\n" as u64)  return 3u64 }
            let dd : i64 = parse_one(av[4u64])
            if P1_OK != 1u32 { ps("iii exact: parse error in d\n" as u64)  return 3u64 }
            return emit_denest(da, db, dd)
        }
        if a0[2u64] == 99u8 {                           /* "--cmp" <A> <B> */
            if argc < 4i32 { ps("iii exact: --cmp needs two term lists\n" as u64)  return 3u64 }
            /* A into [0,nA), then B with coefficients NEGATED appended -> sign(A - B) in one call */
            let nA : u64 = parse_terms(av[2u64], 0u64)
            if nA == PARSEFAIL { ps("iii exact: parse error in A\n" as u64)  return 3u64 }
            let nAB : u64 = parse_terms(av[3u64], nA)
            if nAB == PARSEFAIL { ps("iii exact: parse error in B\n" as u64)  return 3u64 }
            /* negate the B coefficients (indices nA..nAB) */
            let mut j : u64 = nA
            while j < nAB { AV[j] = 0i64 - AV[j]  j = j + 1u64 }
            let sgn : i32 = ui_sqrt_sum_sign(&AV as u64, &BV as u64, nAB)
            return emit_sign(sgn)
        }
        if a0[2u64] == 114u8 {                          /* "--roots" "<coeffs>" [lo hi]  |  "--roots-big" */
            if a0[7u64] == 45u8 {                       /* "--roots-big" "<coeffs>" <lo> <hi> */
                if argc < 5i32 { ps("iii exact: --roots-big needs \"<c0 c1 ... cd>\" <lo> <hi>\n" as u64)  return 3u64 }
                let bl : i64 = parse_one(av[3u64])
                if P1_OK != 1u32 { ps("iii exact: parse error in lo\n" as u64)  return 3u64 }
                let bh : i64 = parse_one(av[4u64])
                if P1_OK != 1u32 { ps("iii exact: parse error in hi\n" as u64)  return 3u64 }
                return emit_roots_big(av[2u64], bl, bh)
            }
            if argc < 3i32 { ps("iii exact: --roots needs a coefficient list \"c0 c1 ... cd\" (low -> high)\n" as u64)  return 3u64 }
            let rn : u64 = parse_list(av[2u64], (&RC) as u64)
            if rn == PARSEFAIL { ps("iii exact: parse error in the coefficient list (up to 64 integers, <= 18 digits each)\n" as u64)  return 3u64 }
            if rn == 0u64 { ps("iii exact: empty coefficient list\n" as u64)  return 3u64 }
            if argc == 3i32 { return emit_roots((&RC) as u64, rn, 0i64, 0i64, 0u32) }
            if argc < 5i32 { ps("iii exact: --roots window needs BOTH lo and hi\n" as u64)  return 3u64 }
            let wl : i64 = parse_one(av[3u64])
            if P1_OK != 1u32 { ps("iii exact: parse error in lo\n" as u64)  return 3u64 }
            let wh : i64 = parse_one(av[4u64])
            if P1_OK != 1u32 { ps("iii exact: parse error in hi\n" as u64)  return 3u64 }
            return emit_roots((&RC) as u64, rn, wl, wh, 1u32)
        }
        if a0[2u64] == 97u8 {                           /* "--alg-sign" / "--alg-cmp" */
            let mut algok : u32 = 1u32
            if a0[3u64] != 108u8 { algok = 0u32 }
            if algok == 1u32 { if a0[4u64] != 103u8 { algok = 0u32 } }
            if algok == 1u32 { if a0[5u64] != 45u8 { algok = 0u32 } }
            if algok == 1u32 { if a0[6u64] == 115u8 {   /* "--alg-sign" "<coeffs>" <lo> <hi> */
                if argc < 5i32 { ps("iii exact: --alg-sign needs \"<c0 ... cd>\" <lo> <hi>\n" as u64)  return 3u64 }
                let sl : i64 = parse_one(av[3u64])
                if P1_OK != 1u32 { ps("iii exact: parse error in lo\n" as u64)  return 3u64 }
                let sh : i64 = parse_one(av[4u64])
                if P1_OK != 1u32 { ps("iii exact: parse error in hi\n" as u64)  return 3u64 }
                return emit_alg_sign2(av[2u64], sl, sh)
            } }
            if algok == 1u32 { if a0[6u64] == 97u8 {    /* "--alg-add" "<A>" <lo> <hi> "<B>" <lo> <hi> */
                if argc < 8i32 { ps("iii exact: --alg-add needs \"<A>\" <lo> <hi> \"<B>\" <lo> <hi>\n" as u64)  return 3u64 }
                let pr : u64 = parse_alg6(av[2u64], av[3u64], av[4u64], av[5u64], av[6u64], av[7u64])
                if pr != 9u64 { return pr }
                let ala : i64 = AP6[0u64]
                let aha : i64 = AP6[1u64]
                let alb : i64 = AP6[2u64]
                let ahb : i64 = AP6[3u64]
                return emit_alg_arith(0i64, APN[0u64], ala, aha, APN[1u64], alb, ahb)
            } }
            if algok == 1u32 { if a0[6u64] == 105u8 {   /* "--alg-inv" "<A>" <lo> <hi> */
                if argc < 5i32 { ps("iii exact: --alg-inv needs \"<A>\" <lo> <hi>\n" as u64)  return 3u64 }
                let vn : u64 = parse_list(av[2u64], (&RC) as u64)
                if vn == PARSEFAIL { ps("iii exact: parse error in the coefficient list\n" as u64)  return 3u64 }
                if vn == 0u64 { ps("iii exact: empty coefficient list\n" as u64)  return 3u64 }
                let vl : i64 = parse_one(av[3u64])
                if P1_OK != 1u32 { ps("iii exact: parse error in lo\n" as u64)  return 3u64 }
                let vh : i64 = parse_one(av[4u64])
                if P1_OK != 1u32 { ps("iii exact: parse error in hi\n" as u64)  return 3u64 }
                return emit_alg_arith(2i64, vn, vl, vh, 0u64, 0i64, 0i64)
            } }
            if algok == 1u32 { if a0[6u64] == 109u8 {   /* "--alg-mul" "<A>" <lo> <hi> "<B>" <lo> <hi> */
                if argc < 8i32 { ps("iii exact: --alg-mul needs \"<A>\" <lo> <hi> \"<B>\" <lo> <hi>\n" as u64)  return 3u64 }
                let pm : u64 = parse_alg6(av[2u64], av[3u64], av[4u64], av[5u64], av[6u64], av[7u64])
                if pm != 9u64 { return pm }
                let mla : i64 = AP6[0u64]
                let mha : i64 = AP6[1u64]
                let mlb : i64 = AP6[2u64]
                let mhb : i64 = AP6[3u64]
                return emit_alg_arith(1i64, APN[0u64], mla, mha, APN[1u64], mlb, mhb)
            } }
            if algok == 1u32 { if a0[6u64] == 99u8 {    /* "--alg-cmp" "<A>" <lo> <hi> "<B>" <lo> <hi> */
                if argc < 8i32 { ps("iii exact: --alg-cmp needs \"<A>\" <lo> <hi> \"<B>\" <lo> <hi>\n" as u64)  return 3u64 }
                let la : i64 = parse_one(av[3u64])
                if P1_OK != 1u32 { ps("iii exact: parse error in A's lo\n" as u64)  return 3u64 }
                let ha : i64 = parse_one(av[4u64])
                if P1_OK != 1u32 { ps("iii exact: parse error in A's hi\n" as u64)  return 3u64 }
                let lb : i64 = parse_one(av[6u64])
                if P1_OK != 1u32 { ps("iii exact: parse error in B's lo\n" as u64)  return 3u64 }
                let hb : i64 = parse_one(av[7u64])
                if P1_OK != 1u32 { ps("iii exact: parse error in B's hi\n" as u64)  return 3u64 }
                return emit_alg_cmp2(av[2u64], la, ha, av[5u64], lb, hb)
            } }
        }
        ps("iii exact: unknown option (know --cmp, --denest, --roots, --roots-big, --alg-sign, --alg-cmp, --alg-add, --alg-mul, --alg-inv)\n" as u64)
        return 3u64
    } }

    /* single-expression form */
    let n : u64 = parse_terms(av[1u64], 0u64)
    if n == PARSEFAIL { ps("iii exact: parse error (need pairs: coefficient radicand, radicand >= 0)\n" as u64)  return 3u64 }
    if n == 0u64 { ps("0  (empty sum)" as u64)  nl()  return 0u64 }
    let sgn : i32 = ui_sqrt_sum_sign(&AV as u64, &BV as u64, n)
    return emit_sign(sgn)
}
