/* STDLIB/iii/aether/field_run.iii -- THE CAUSAL TOPOLOGY ENGINE, run live.
 * Drives the unified field (ui_field.iii) and PRINTS its actual output: self-population growing the Sierpinski,
 * the local-web relay wavefront, the quantum dimension snapping on collapse, exact irrationals self-populating,
 * structural color from geometry, exact kinematics at an irrational instant, and the binding's conserved invariant.
 * This is the engine running, not a test -- executed output. */
module field_run

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn ui_ca_seed(n: i64, pos: i64) -> i32 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_ca_step(n: i64) -> i32 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_ca_get(idx: i64) -> u8 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_relay_init(n: i64, src: i64) -> i32 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_relay_step(n: i64) -> i32 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_relay_get(idx: i64) -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_quantum_dim(counts: u64, n_states: u64, total: u64) -> u64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_dim_to_rgb(d_milli: i64) -> u32 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_kinematic_at_t(p0: i64, v0: i64, acc: i64, ta: i64, tD: i64, tc: i64) -> i32 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_kin_p() -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_kin_q() -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_kin_d() -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_cf_run(a0: i64, period: u64, period_len: i64, n_terms: i64) -> i32 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_cf_p() -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_cf_q() -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_cf_pell(d: i64) -> i64 from "ui_field.iii"
extern @abi(c-msvc-x64) fn ui_poly_area2(xs: u64, ys: u64, n: u64) -> i64 from "ui_field.iii"

var QC : [u64; 4]
var DIG : [u8; 24]
var PER : [i64; 1]
var SQX : [i64; 4]   var SQY : [i64; 4]
var T1X : [i64; 3]   var T1Y : [i64; 3]
var T2X : [i64; 3]   var T2Y : [i64; 3]

/* print a string literal up to the '~' sentinel (iii literals are not NUL-terminated; '~' is our terminator) */
fn pstr(s: *u8) -> i32 {
    let mut i : u64 = 0u64
    let mut going : u8 = 1u8
    while going == 1u8 {
        let c : u8 = s[i]
        if c == 126u8 { going = 0u8 }
        if going == 1u8 { putchar(c as i32)   i = i + 1u64 }
    }
    return 0i32
}
fn pnl() -> i32 { return putchar(10i32) }
fn psp() -> i32 { return putchar(32i32) }
fn pint(n: i64) -> i32 {
    let mut x : i64 = n
    if x < 0i64 { putchar(45i32)   x = 0i64 - x }
    if x == 0i64 { putchar(48i32)   return 0i32 }
    let mut k : i64 = 0i64
    while x > 0i64 {
        let q : i64 = x / 10i64
        DIG[k] = ((x - (q * 10i64)) + 48i64) as u8         /* low digit without % (avoids modulo-after-call) */
        x = q
        k = k + 1i64
    }
    while k > 0i64 { k = k - 1i64   putchar(DIG[k] as i32) }
    return 0i32
}

fn main() -> i32 {
    pstr("============================================================~")   pnl()
    pstr("              THE CAUSAL TOPOLOGY ENGINE                    ~")   pnl()
    pstr("        only local events, relations, and logic walls       ~")   pnl()
    pstr("============================================================~")   pnl()

    /* ---- [S] SELF-POPULATION: one local rule grows the exact Sierpinski gasket ---- */
    pnl()   pstr("[S] SELF-POPULATION  --  one local XOR rule, one seed, grows the Sierpinski:~")   pnl()
    ui_ca_seed(64i64, 32i64)
    let mut row : i64 = 0i64
    while row < 16i64 {
        psp() psp()
        let mut col : i64 = 16i64
        while col <= 48i64 {
            let v : u8 = ui_ca_get(col)
            if v == 1u8 { putchar(35i32) }                  /* '#' a live cell */
            if v == 0u8 { putchar(32i32) }                  /* ' ' a void */
            col = col + 1i64
        }
        pnl()
        ui_ca_step(64i64)
        row = row + 1i64
    }

    /* ---- [L] LOCAL WEB: the relay wavefront -- a global field from purely local hops ---- */
    pnl()   pstr("[L] LOCAL WEB  --  distance field self-assembling one local hop per tick ('.' = unreached):~")   pnl()
    ui_relay_init(12i64, 0i64)
    let mut step : i64 = 0i64
    while step < 7i64 {
        psp() psp()
        let mut i : i64 = 0i64
        while i < 12i64 {
            let d : i64 = ui_relay_get(i)
            if d >= 1000000i64 { putchar(46i32) }
            if d < 1000000i64 { pint(d) }
            psp()
            i = i + 1i64
        }
        pnl()
        ui_relay_step(12i64)
        step = step + 1i64
    }

    /* ---- [Q] QUANTUM UI: the continuous dimension snaps to the integer baseline on collapse ---- */
    pnl()   pstr("[Q] QUANTUM UI  --  Hausdorff dimension (x1000) of the state:~")   pnl()
    QC[0u64] = 1u64   QC[1u64] = 1u64   QC[2u64] = 1u64   QC[3u64] = 1u64
    pstr("    superposition |00>+|01>+|10>+|11>  ->  d = ~")   pint(ui_quantum_dim((&QC) as u64, 4u64, 4u64) as i64)   pstr("   (fractal, space-filling)~")   pnl()
    QC[0u64] = 4u64   QC[1u64] = 0u64   QC[2u64] = 0u64   QC[3u64] = 0u64
    pstr("    collapse to pure |00>             ->  d = ~")   pint(ui_quantum_dim((&QC) as u64, 4u64, 4u64) as i64)   pstr("   (SNAPPED flat to the baseline)~")   pnl()

    /* ---- [N] SELF-POPULATING NUMBERS: sqrt(2) from a finite seed, Pell-exact at every depth ---- */
    pnl()   pstr("[N] SELF-POPULATING sqrt(2) = [1;2,2,2,...]  --  finite seed, exact at any depth:~")   pnl()
    PER[0u64] = 2i64
    let mut t : i64 = 2i64
    while t <= 6i64 {
        ui_cf_run(1i64, (&PER) as u64, 1i64, t)
        pstr("    p/q = ~")   pint(ui_cf_p())   putchar(47i32)   pint(ui_cf_q())
        pstr("   ->  p^2 - 2q^2 = ~")   pint(ui_cf_pell(2i64))   pstr("  (always +-1: PROOF it is sqrt 2)~")   pnl()
        t = t + 1i64
    }

    /* ---- [C] STRUCTURAL COLOR: the wavelength/RGB is generated by the dimension, not assigned ---- */
    pnl()   pstr("[C] STRUCTURAL COLOR  --  dimension -> wavelength -> RGB (generated by topology):~")   pnl()
    let c1 : u32 = ui_dim_to_rgb(1000i64)
    pstr("    d=1.0 (predictable) -> RGB ~")   pint(((c1 >> 16u32) & 255u32) as i64)   psp()   pint(((c1 >> 8u32) & 255u32) as i64)   psp()   pint((c1 & 255u32) as i64)   pstr("   (red)~")   pnl()
    let c2 : u32 = ui_dim_to_rgb(1500i64)
    pstr("    d=1.5             -> RGB ~")   pint(((c2 >> 16u32) & 255u32) as i64)   psp()   pint(((c2 >> 8u32) & 255u32) as i64)   psp()   pint((c2 & 255u32) as i64)   pstr("   (green)~")   pnl()
    let c3 : u32 = ui_dim_to_rgb(2000i64)
    pstr("    d=2.0 (complex)    -> RGB ~")   pint(((c3 >> 16u32) & 255u32) as i64)   psp()   pint(((c3 >> 8u32) & 255u32) as i64)   psp()   pint((c3 & 255u32) as i64)   pstr("   (violet)~")   pnl()

    /* ---- [T] CONTINUOUS TIME: exact position at an irrational instant ---- */
    pnl()   pstr("[T] CONTINUOUS TIME  --  position at the IRRATIONAL instant t=(-1+sqrt3)/2:~")   pnl()
    ui_kinematic_at_t(0i64, 2i64, 0i64, 0i64 - 1i64, 3i64, 2i64)
    pstr("    p(t) = ~")   pint(ui_kin_p())   pstr(" + ~")   pint(ui_kin_q())   pstr("*sqrt(~")   pint(ui_kin_d())   pstr(")    (= -1 + sqrt3, exact -- no interpolation)~")   pnl()

    /* ---- [B] THE BINDING: the exact invariant conserved across equivalent forms ---- */
    pnl()   pstr("[B] THE BINDING  --  exact area conserved across representations (the field equation):~")   pnl()
    SQX[0u64] = 0i64   SQX[1u64] = 4i64   SQX[2u64] = 4i64   SQX[3u64] = 0i64
    SQY[0u64] = 0i64   SQY[1u64] = 0i64   SQY[2u64] = 4i64   SQY[3u64] = 4i64
    let whole : i64 = ui_poly_area2((&SQX) as u64, (&SQY) as u64, 4u64)
    T1X[0u64] = 0i64   T1X[1u64] = 4i64   T1X[2u64] = 4i64
    T1Y[0u64] = 0i64   T1Y[1u64] = 0i64   T1Y[2u64] = 4i64
    T2X[0u64] = 0i64   T2X[1u64] = 4i64   T2X[2u64] = 0i64
    T2Y[0u64] = 0i64   T2Y[1u64] = 4i64   T2Y[2u64] = 4i64
    let tri : i64 = ui_poly_area2((&T1X) as u64, (&T1Y) as u64, 3u64) + ui_poly_area2((&T2X) as u64, (&T2Y) as u64, 3u64)
    pstr("    square 2A = ~")   pint(whole)   pstr("    two triangles 2A = ~")   pint(tri)
    if whole == tri { pstr("    =>  BOUND (invariant conserved)~") }
    if whole != tri { pstr("    =>  refused~") }
    pnl()

    pnl()   pstr("============================================================~")   pnl()
    pstr("  15 faculties, exact. The lens is ground and pointed.       ~")   pnl()
    pstr("============================================================~")   pnl()
    return 0i32
}
