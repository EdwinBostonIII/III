/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\aether\fs.iii
 *
 * III STDLIB - aether::fs
 *
 * File-system IO surface, capability-gated.  Underlying ABI is the
 * Win32 file API (CreateFileA / ReadFile / WriteFile / CloseHandle /
 * SetFilePointerEx / DeleteFileA) from kernel32 - NO C runtime.  P4.4
 * removed the msvcrt POSIX layer (_open/_close/_read/_write/_lseeki64/
 * _unlink), so the stdlib no longer links the C runtime at all.
 *
 * Win32 HANDLEs are 64-bit and are stored WHOLE in the handle table (no
 * truncation to a CRT `int` fd).  The byte-count and new-position results
 * come back through by-pointer out-params, not return values, which is
 * why the two BSS scratch slots (FS_NXFER / FS_NEWPOS) exist; execution
 * is single-threaded and deterministic so reusing them per call is safe.
 * Win32 BOOL returns are nonzero=success (the inverse of the CRT calls).
 *
 * Phase C scope: open / close / read / write / seek / tell / size / delete.
 * Phase D (landed): directory enumeration (dir_open / dir_read / dir_close +
 * name / name_len / is_dir accessors) and directory create / remove (mkdir /
 * rmdir), all over the Win32 FindFirstFileA / FindNextFileA / FindClose +
 * CreateDirectoryA / RemoveDirectoryA API (kernel32, no C runtime).  These give
 * III the organ to walk its OWN source tree -- the substrate of the H13
 * one-language self-audit (sanctus/onelang.iii), which audits the tree in .iii,
 * by III, with no bash and no C cartographer.
 *
 * Hexad: kind_passage.  Ring: R-1.  K: 0.95.
 */

module aether_fs

/* --- Win32 file API (kernel32) - the only OS membrane; no C runtime --- */

extern @abi(c-msvc-x64) fn CreateFileA(name: *u8, access: u32, share: u32, sec: u64, disp: u32, flags: u32, tmpl: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn ReadFile(h: u64, buf: *u8, n: u32, nread: u64, ovl: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn WriteFile(h: u64, buf: *u8, n: u32, nwritten: u64, ovl: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn SetFilePointerEx(h: u64, dist: i64, newptr: u64, method: u32) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn DeleteFileA(name: *u8) -> i32 from "kernel32"

/* Win32 directory enumeration + creation (kernel32) -- Phase D.  FindFirstFileA
 * returns a SEARCH handle (released with FindClose, NOT CloseHandle) and loads
 * the first matching entry into the WIN32_FIND_DATAA out-param; FindNextFileA
 * advances it (BOOL 0 == no-more, like every Win32 BOOL).  The find_data param
 * is passed as a raw u64 address of FS_FIND (the same by-pointer idiom as the
 * FS_NXFER / FS_NEWPOS out-params below). */
extern @abi(c-msvc-x64) fn FindFirstFileA(pattern: *u8, find_data: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn FindNextFileA(h: u64, find_data: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn FindClose(h: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CreateDirectoryA(name: *u8, sec: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn RemoveDirectoryA(name: *u8) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn GetLastError() -> u32 from "kernel32"

extern @abi(c-msvc-x64) fn cap_verify_rights(id: u64, required: u64) -> u8 from "capability.iii"
extern @abi(c-msvc-x64) fn handle_alloc(kind: u8, fd: u64, cap_id: u64) -> u64 from "handle.iii"
extern @abi(c-msvc-x64) fn handle_close(id: u64) -> i32 from "handle.iii"
extern @abi(c-msvc-x64) fn handle_drop(id: u64) -> i32 from "handle.iii"
extern @abi(c-msvc-x64) fn handle_fd(id: u64) -> u64 from "handle.iii"
extern @abi(c-msvc-x64) fn handle_verify(id: u64, required: u64) -> u8 from "handle.iii"

const FS_OK         : i32 = 0i32
const FS_E_BADID    : i32 = -1i32
const FS_E_DENIED   : i32 = -2i32
const FS_E_OPEN     : i32 = -3i32
const FS_E_IO       : i32 = -4i32

const FS_MODE_READ   : u32 = 1u32
const FS_MODE_WRITE  : u32 = 2u32
const FS_MODE_APPEND : u32 = 3u32

/* Win32 dwDesiredAccess */
const FS_GENERIC_READ  : u32 = 0x80000000u32
const FS_GENERIC_WRITE : u32 = 0x40000000u32
const FS_APPEND_DATA   : u32 = 0x00000004u32   /* FILE_APPEND_DATA */
/* Win32 dwShareMode: SHARE_READ | SHARE_WRITE */
const FS_SHARE_RW      : u32 = 0x00000003u32
/* Win32 dwCreationDisposition */
const FS_CREATE_ALWAYS : u32 = 2u32            /* create new / truncate existing */
const FS_OPEN_EXISTING : u32 = 3u32            /* fail if absent                 */
const FS_OPEN_ALWAYS   : u32 = 4u32            /* open or create (append)        */
/* Win32 dwFlagsAndAttributes */
const FS_ATTR_NORMAL   : u32 = 0x00000080u32
/* Win32 INVALID_HANDLE_VALUE = (HANDLE)-1 */
const FS_INVALID_HANDLE : u64 = 0xFFFFFFFFFFFFFFFFu64

/* SetFilePointerEx dwMoveMethod == CRT SEEK_* (0/1/2), so whence passes through */
const FS_SEEK_SET : u32 = 0u32
const FS_SEEK_CUR : u32 = 1u32
const FS_SEEK_END : u32 = 2u32

const FS_RIGHT_READ   : u64 = 0x0002u64
const FS_RIGHT_WRITE  : u64 = 0x0004u64
const FS_RIGHT_CREATE : u64 = 0x0008u64

/* Phase D directory enumeration.  WIN32_FIND_DATAA is 320 bytes; the two fields
 * we read are dwFileAttributes (DWORD @ 0) and cFileName (CHAR[260], NUL-term
 * @ 44).  FILE_ATTRIBUTE_DIRECTORY = 0x10.  FindFirstFile failure returns
 * INVALID_HANDLE_VALUE (-1 == FS_INVALID_HANDLE), never 0 -- so a failed search
 * never aliases handle id 0.  ERROR_ALREADY_EXISTS (183) makes mkdir idempotent. */
const FS_FIND_SIZE      : u64 = 320u64
const FS_FIND_NAME_OFF  : u64 = 44u64
const FS_ATTR_DIRECTORY : u32 = 0x00000010u32
const FS_DIR_KIND       : u8  = 5u8        /* handle kind: dir search (FindClose path) */
const FS_PAT_MAX        : u64 = 1024u64    /* "<dir>\*\0" search-pattern bound (W8) */
const FS_NAME_MAX       : u64 = 260u64     /* MAX_PATH cFileName bound */
const FS_ERROR_ALREADY_EXISTS : u32 = 183u32

/* --- by-pointer out-param scratch (single-threaded; deterministic reuse) --- */

var FS_NXFER  : [u8; 8]    /* ReadFile/WriteFile lpNumberOfBytesTransferred (DWORD) */
var FS_NEWPOS : [u8; 8]    /* SetFilePointerEx lpNewFilePointer (LARGE_INTEGER)     */

/* Phase D directory-search scratch (single active search; the same single-
 * threaded, deterministic-reuse contract as FS_NXFER / FS_NEWPOS).  The
 * one-active-search discipline -- read ALL entries of a directory, close it,
 * THEN recurse -- keeps one FS_FIND + one FS_FIND_PENDING correct: FS_FIND is
 * fully drained into the caller's own storage before any nested fs_dir_open,
 * and at most one search handle is live at a time (bounded handle table). */
var FS_FIND         : [u8; 320]   /* WIN32_FIND_DATAA */
var FS_DIRPAT       : [u8; 1024]  /* "<dir>\*\0" search pattern */
var FS_FIND_PENDING : u8 = 0u8    /* 1 = the FindFirstFile entry is loaded, not yet consumed */

fn fs_xfer_count() -> u32 {
    let b0 : u32 = FS_NXFER[0] as u32
    let b1 : u32 = FS_NXFER[1] as u32
    let b2 : u32 = FS_NXFER[2] as u32
    let b3 : u32 = FS_NXFER[3] as u32
    return b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32)
}

fn fs_newpos() -> u64 {
    let b0 : u64 = FS_NEWPOS[0] as u64
    let b1 : u64 = FS_NEWPOS[1] as u64
    let b2 : u64 = FS_NEWPOS[2] as u64
    let b3 : u64 = FS_NEWPOS[3] as u64
    let b4 : u64 = FS_NEWPOS[4] as u64
    let b5 : u64 = FS_NEWPOS[5] as u64
    let b6 : u64 = FS_NEWPOS[6] as u64
    let b7 : u64 = FS_NEWPOS[7] as u64
    return b0 | (b1 << 8u64) | (b2 << 16u64) | (b3 << 24u64) | (b4 << 32u64) | (b5 << 40u64) | (b6 << 48u64) | (b7 << 56u64)
}

fn fs_open(cap_id: u64, path: u64, mode: u32) -> u64 @export {
    let mut required : u64 = 0u64
    let mut access : u32 = 0u32
    let mut disp : u32 = 0u32
    if mode == FS_MODE_READ {
        required = FS_RIGHT_READ
        access = FS_GENERIC_READ
        disp = FS_OPEN_EXISTING
    }
    if mode == FS_MODE_WRITE {
        required = FS_RIGHT_WRITE | FS_RIGHT_CREATE
        access = FS_GENERIC_WRITE
        disp = FS_CREATE_ALWAYS
    }
    if mode == FS_MODE_APPEND {
        required = FS_RIGHT_WRITE
        access = FS_APPEND_DATA
        disp = FS_OPEN_ALWAYS
    }
    if required == 0u64 { return 0u64 }
    if cap_verify_rights(cap_id, required) == 0u8 { return 0u64 }
    let p_path : *u8 = path as *u8
    let h : u64 = CreateFileA(p_path, access, FS_SHARE_RW, 0u64, disp, FS_ATTR_NORMAL, 0u64)
    if h == FS_INVALID_HANDLE { return 0u64 }
    let id : u64 = handle_alloc(1u8, h, cap_id)
    if id == 0u64 { CloseHandle(h) }   /* [W14-FIX] handle table full -> close the OS file handle
                                        * we just opened instead of leaking it (the file would stay
                                        * locked until process exit; net_tcp_connect_ipv4 already
                                        * does this on its own alloc-fail path). */
    return id
}

/* Delete a file by path. Deletion is a write-class mutation, so it requires
 * the WRITE right on the capability. (fs_open WRITE mode additionally requires
 * CREATE to make/truncate the target; deletion needs only WRITE -- it removes an
 * existing name, it does not create one.) Path-based (like fs_open), not handle-based — there is
 * no open descriptor to delete. Returns FS_OK on success, FS_E_DENIED if the
 * capability lacks WRITE, FS_E_IO if the underlying delete fails (e.g. the
 * file does not exist or is locked). RITCHIE Stage 1.X (Phase D ops, brought
 * forward to support deterministic corpus cleanup). */
fn fs_delete(cap_id: u64, path: u64) -> i32 @export {
    if cap_verify_rights(cap_id, FS_RIGHT_WRITE) == 0u8 { return FS_E_DENIED }
    let p_path : *u8 = path as *u8
    let rc : i32 = DeleteFileA(p_path)   /* Win32 BOOL: 0 = failure */
    if rc == 0i32 { return FS_E_IO }
    return FS_OK
}

fn fs_close(handle_id: u64) -> i32 @export {
    let h : u64 = handle_fd(handle_id)
    let rc : i32 = CloseHandle(h)        /* Win32 BOOL: 0 = failure */
    /* FREE the handle-table slot (not merely mark-closed): handle_close retains
     * the slot "for audit" but nothing ever reaps it, so a program opening >64
     * files/dirs would exhaust the 64-slot table (the onelang tree-walk hit this
     * at the 65th directory).  handle_drop is the reaper; the OS handle is already
     * closed, so re-querying the id is meaningless -- dropping is strictly correct. */
    handle_drop(handle_id)
    if rc == 0i32 { return FS_E_IO }
    return FS_OK
}

/* mig3 boundary SOURCE: read fills `buf` with untrusted file bytes -- buf is
 * @sovereign_value @sovereign_out (the same recv/read out-buffer taint law). */
fn fs_read(handle_id: u64, buf: u64 @sovereign_value @sovereign_out, n: u64) -> u64 @export {
    if handle_verify(handle_id, FS_RIGHT_READ) == 0u8 { return 0u64 }
    let h : u64 = handle_fd(handle_id)
    let bp : *u8 = buf as *u8
    let n32 : u32 = (n & 0xFFFFFFFFu64) as u32
    let ok : i32 = ReadFile(h, bp, n32, (&FS_NXFER) as u64, 0u64)
    if ok == 0i32 { return 0u64 }
    return fs_xfer_count() as u64
}

/* mig3 boundary SINK: write emits `buf` OUTWARD to the file, so it may carry
 * sovereign data -- buf is @sovereign_value (read-only sink, not @sovereign_out). */
fn fs_write(handle_id: u64, buf: u64 @sovereign_value, n: u64) -> u64 @export {
    if handle_verify(handle_id, FS_RIGHT_WRITE) == 0u8 { return 0u64 }
    let h : u64 = handle_fd(handle_id)
    let bp : *u8 = buf as *u8
    let n32 : u32 = (n & 0xFFFFFFFFu64) as u32
    let ok : i32 = WriteFile(h, bp, n32, (&FS_NXFER) as u64, 0u64)
    if ok == 0i32 { return 0u64 }
    return fs_xfer_count() as u64
}

fn fs_seek(handle_id: u64, off: u64, whence: u32) -> i32 @export {
    if handle_verify(handle_id, FS_RIGHT_READ) == 0u8 { return FS_E_DENIED }
    let h : u64 = handle_fd(handle_id)
    let d : i64 = off as i64
    let ok : i32 = SetFilePointerEx(h, d, 0u64, whence)   /* Win32 BOOL: 0 = failure */
    if ok == 0i32 { return FS_E_IO }
    return FS_OK
}

fn fs_tell(handle_id: u64) -> u64 @export {
    if handle_verify(handle_id, FS_RIGHT_READ) == 0u8 { return 0xFFFFFFFFFFFFFFFFu64 }
    let h : u64 = handle_fd(handle_id)
    let ok : i32 = SetFilePointerEx(h, 0i64, (&FS_NEWPOS) as u64, FS_SEEK_CUR)
    if ok == 0i32 { return 0xFFFFFFFFFFFFFFFFu64 }   /* query failed -> sentinel, not a stale FS_NEWPOS */
    return fs_newpos()
}

fn fs_size(handle_id: u64) -> u64 @export {
    if handle_verify(handle_id, FS_RIGHT_READ) == 0u8 { return 0xFFFFFFFFFFFFFFFFu64 }
    let h : u64 = handle_fd(handle_id)
    /* save current pos -> seek END (size) -> restore.  Every seek is checked: an
     * unchecked failure would return a stale FS_NEWPOS as the "size" OR, worst, leave
     * the file pointer stranded at END (the restore failed) and silently corrupt the
     * next read/write on this handle.  On any failure: return the sentinel. */
    let ok1 : i32 = SetFilePointerEx(h, 0i64, (&FS_NEWPOS) as u64, FS_SEEK_CUR)
    if ok1 == 0i32 { return 0xFFFFFFFFFFFFFFFFu64 }
    let saved : u64 = fs_newpos()
    let ok2 : i32 = SetFilePointerEx(h, 0i64, (&FS_NEWPOS) as u64, FS_SEEK_END)
    if ok2 == 0i32 { return 0xFFFFFFFFFFFFFFFFu64 }
    let sz : u64 = fs_newpos()
    let sd : i64 = saved as i64
    let ok3 : i32 = SetFilePointerEx(h, sd, 0u64, FS_SEEK_SET)
    if ok3 == 0i32 { return 0xFFFFFFFFFFFFFFFFu64 }
    return sz
}

/* === Phase D: directory enumeration (FindFirstFileA / FindNextFileA / FindClose) ===
 *
 * The one-active-search contract (obeyed by sanctus/onelang.iii's tree walk):
 *   let h : u64 = fs_dir_open(cap, dirpath)      -- opens "<dirpath>\*"; 0 on failure
 *   while fs_dir_read(h) == 1u8 {                -- 1 => FS_FIND holds a valid entry
 *       let name : u64  = fs_dir_name()          -- *u8 into FS_FIND (transient: copy NOW)
 *       let isdir : u8  = fs_dir_is_dir()        -- 1 if FILE_ATTRIBUTE_DIRECTORY
 *       ... copy `name` into caller storage BEFORE the next fs_dir_read ...
 *   }
 *   fs_dir_close(h)                              -- FindClose + handle_close
 * Every entry (incl. "." and "..") is returned; the caller filters them. */

/* Open a directory search.  Copies `path` (NUL-terminated) into FS_DIRPAT,
 * appends "\*\0", FindFirstFileA's it, and -- on success -- latches the first
 * entry as pending.  Returns a dir handle (kind FS_DIR_KIND) or 0 on cap-deny,
 * open-failure, or a full handle table. */
fn fs_dir_open(cap_id: u64, path: u64) -> u64 @export {
    let cap : u64 = cap_id
    if cap_verify_rights(cap, FS_RIGHT_READ) == 0u8 { return 0u64 }
    let p : *u8 = path as *u8
    /* copy the path up to its NUL; reserve 3 bytes for the "\*\0" suffix (W8 bound) */
    let mut n : u64 = 0u64
    let mut go : u8 = 1u8
    while go == 1u8 {
        let c : u8 = p[n]
        if c == 0u8 { go = 0u8 }
        if go == 1u8 { if n >= (FS_PAT_MAX - 4u64) { go = 0u8 } }
        if go == 1u8 { FS_DIRPAT[n] = c   n = n + 1u64 }
    }
    FS_DIRPAT[n]        = 0x5Cu8   /* '\' */
    FS_DIRPAT[n + 1u64] = 0x2Au8   /* '*' */
    FS_DIRPAT[n + 2u64] = 0x00u8
    let h : u64 = FindFirstFileA((&FS_DIRPAT as u64) as *u8, (&FS_FIND as u64))
    if h == FS_INVALID_HANDLE { return 0u64 }   /* INVALID_HANDLE_VALUE = -1, never 0 */
    FS_FIND_PENDING = 1u8
    let id : u64 = handle_alloc(FS_DIR_KIND, h, cap)
    if id == 0u64 { FS_FIND_PENDING = 0u8 ; FindClose(h) }   /* [W14-FIX] table full -> release the
                                        * search handle (FindClose, not CloseHandle) + clear the
                                        * pending flag, instead of leaking the dir-search handle. */
    return id
}

/* Advance the search.  1 if FS_FIND now holds a valid entry, 0 if exhausted or
 * the cap was revoked.  The FIRST call returns the entry FindFirstFileA already
 * loaded (pending); subsequent calls FindNextFileA into FS_FIND. */
fn fs_dir_read(handle_id: u64) -> u8 @export {
    if handle_verify(handle_id, FS_RIGHT_READ) == 0u8 { return 0u8 }
    if FS_FIND_PENDING == 1u8 { FS_FIND_PENDING = 0u8   return 1u8 }
    let h : u64 = handle_fd(handle_id)
    let ok : i32 = FindNextFileA(h, (&FS_FIND as u64))
    if ok == 0i32 { return 0u8 }
    return 1u8
}

/* Pointer (as u64) to the current entry's cFileName (NUL-terminated) inside
 * FS_FIND.  Transient: valid only until the next fs_dir_read / fs_dir_close. */
fn fs_dir_name() -> u64 @export {
    return (&FS_FIND as u64) + FS_FIND_NAME_OFF
}

/* Length of the current entry's cFileName (excluding the NUL), bounded by 260. */
fn fs_dir_name_len() -> u64 @export {
    let bp : *u8 = ((&FS_FIND as u64) + FS_FIND_NAME_OFF) as *u8
    let mut i : u64 = 0u64
    let mut go : u8 = 1u8
    while go == 1u8 {
        if i >= FS_NAME_MAX { go = 0u8 }
        if go == 1u8 { if bp[i] == 0u8 { go = 0u8 } }
        if go == 1u8 { i = i + 1u64 }
    }
    return i
}

/* 1 if the current entry is a directory (FILE_ATTRIBUTE_DIRECTORY set in the
 * dwFileAttributes DWORD at FS_FIND[0..4), little-endian). */
fn fs_dir_is_dir() -> u8 @export {
    let b0 : u32 = FS_FIND[0] as u32
    let b1 : u32 = FS_FIND[1] as u32
    let b2 : u32 = FS_FIND[2] as u32
    let b3 : u32 = FS_FIND[3] as u32
    let attr : u32 = b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32)
    if (attr & FS_ATTR_DIRECTORY) != 0u32 { return 1u8 }
    return 0u8
}

/* Close a directory search.  Uses FindClose (NOT CloseHandle -- a search handle
 * is not a file handle) then releases the handle-table slot and clears pending. */
fn fs_dir_close(handle_id: u64) -> i32 @export {
    let h : u64 = handle_fd(handle_id)
    let rc : i32 = FindClose(h)
    /* FREE the slot (dir search handles are ephemeral): a tree walk opens one
     * search per directory, so retaining slots would exhaust the 64-slot table on
     * any tree with >64 directories.  Drop reclaims it -> at most one search slot
     * live at a time under the read-all-then-close-then-recurse discipline. */
    handle_drop(handle_id)
    FS_FIND_PENDING = 0u8
    if rc == 0i32 { return FS_E_IO }
    return FS_OK
}

/* Create a directory.  Requires the CREATE right (a directory is a created
 * name).  An already-existing directory is treated as success (idempotent
 * mkdir), so deterministic test-tree setup is safely re-runnable. */
fn fs_mkdir(cap_id: u64, path: u64) -> i32 @export {
    let cap : u64 = cap_id
    if cap_verify_rights(cap, FS_RIGHT_CREATE) == 0u8 { return FS_E_DENIED }
    let p : *u8 = path as *u8
    let rc : i32 = CreateDirectoryA(p, 0u64)
    if rc != 0i32 { return FS_OK }
    let e : u32 = GetLastError()
    if e == FS_ERROR_ALREADY_EXISTS { return FS_OK }
    return FS_E_IO
}

/* Remove an (empty) directory.  Removal is a write-class mutation -> the WRITE
 * right (mirrors fs_delete, which maps file deletion onto WRITE). */
fn fs_rmdir(cap_id: u64, path: u64) -> i32 @export {
    let cap : u64 = cap_id
    if cap_verify_rights(cap, FS_RIGHT_WRITE) == 0u8 { return FS_E_DENIED }
    let p : *u8 = path as *u8
    let rc : i32 = RemoveDirectoryA(p)
    if rc == 0i32 { return FS_E_IO }
    return FS_OK
}
