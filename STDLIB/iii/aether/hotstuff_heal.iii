/* aether/hotstuff_heal.iii — V1 Stage 5 (gospel L24438): partition-heal driver.
 *
 * When a node rejoins after a network partition, its local witness-chain segment
 * diverges from canonical at the partition boundary.  The V1-closure heal driver
 * RECORDS the divergence for operator review (it does not auto-merge): the
 * substrate degrades to operator review rather than to silent inconsistency.
 * V3 Phase Eighteen elaborates this with bisimulation-backed automatic merge via
 * numera/bisimulation_witness.iii (cp_branch_merge); the V1 version operates
 * without bisimulation, exactly as the gospel prescribes for V1 closure.
 *
 * Hexad: kind_witness + kind_federation.  Ring: R0.  K: 1.00.
 */
module aether_hotstuff_heal

const HH_OK            : i32 =  0i32
const HH_E_NULL        : i32 = -1i32
const HH_E_FULL        : i32 = -2i32
const HH_E_BAD_IDX     : i32 = -3i32

const HH_MAX_PARTITIONS : u64 = 4096u64

const HH_STATUS_PENDING  : u8 = 0u8
const HH_STATUS_ACCEPTED : u8 = 1u8
const HH_STATUS_REJECTED : u8 = 2u8

var HH_PART_LOCAL  : [u8; 131072]   /* 4096 * 32 — local segment head */
var HH_PART_CANON  : [u8; 131072]   /* 4096 * 32 — canonical segment head */
var HH_PART_VIEW   : [u64; 4096]    /* divergence view */
var HH_PART_STATUS : [u8; 4096]
var HH_PART_COUNT  : u64 = 0u64

fn hh_init() -> i32 @export {
    HH_PART_COUNT = 0u64
    return HH_OK
}

/* Record a partition divergence for operator review.  Returns the record index,
 * or -1 (as u64 0xFFF...) on a full log. */
fn hh_record_partition(local_head: *u8, canonical_head: *u8, divergence_view: u64) -> i32 @export {
    if (local_head as u64) == 0u64 { return HH_E_NULL }
    if (canonical_head as u64) == 0u64 { return HH_E_NULL }
    if HH_PART_COUNT >= HH_MAX_PARTITIONS { return HH_E_FULL }
    let idx : u64 = HH_PART_COUNT
    let mut j : u64 = 0u64
    while j < 32u64 {
        HH_PART_LOCAL[idx * 32u64 + j] = local_head[j]
        HH_PART_CANON[idx * 32u64 + j] = canonical_head[j]
        j = j + 1u64
    }
    HH_PART_VIEW[idx] = divergence_view
    HH_PART_STATUS[idx] = HH_STATUS_PENDING
    HH_PART_COUNT = idx + 1u64
    return idx as i32
}

fn hh_partition_count() -> u32 @export { return HH_PART_COUNT as u32 }

fn hh_get_partition(idx: u64, out_local: *u8, out_canon: *u8, out_view: *u64) -> i32 @export {
    if idx >= HH_PART_COUNT { return HH_E_BAD_IDX }
    if (out_local as u64) == 0u64 { return HH_E_NULL }
    if (out_canon as u64) == 0u64 { return HH_E_NULL }
    if (out_view as u64) == 0u64 { return HH_E_NULL }
    let mut j : u64 = 0u64
    while j < 32u64 {
        out_local[j] = HH_PART_LOCAL[idx * 32u64 + j]
        out_canon[j] = HH_PART_CANON[idx * 32u64 + j]
        j = j + 1u64
    }
    out_view[0u64] = HH_PART_VIEW[idx]
    return HH_OK
}

/* Operator review outcome: HH_STATUS_ACCEPTED (merge into canonical) or
 * HH_STATUS_REJECTED.  (V3 replaces the operator step with bisimulation.) */
fn hh_resolve(idx: u64, decision: u8) -> i32 @export {
    if idx >= HH_PART_COUNT { return HH_E_BAD_IDX }
    HH_PART_STATUS[idx] = decision
    return HH_OK
}

fn hh_partition_status(idx: u64) -> i32 @export {
    if idx >= HH_PART_COUNT { return HH_E_BAD_IDX }
    return HH_PART_STATUS[idx] as i32
}

fn hh_pending_count() -> u32 @export {
    let mut c : u32 = 0u32
    let mut i : u64 = 0u64
    while i < HH_PART_COUNT {
        if HH_PART_STATUS[i] == HH_STATUS_PENDING { c = c + 1u32 }
        i = i + 1u64
    }
    return c
}

/* Self-test (99 = pass): record two partitions, round-trip, resolve, pending count. */
var HH_KAT_L1 : [u8; 32]
var HH_KAT_C1 : [u8; 32]
var HH_KAT_L2 : [u8; 32]
var HH_KAT_C2 : [u8; 32]
var HH_KAT_OL : [u8; 32]
var HH_KAT_OC : [u8; 32]
var HH_KAT_OV : [u64; 1]

fn hh_selftest() -> u64 @export {
    hh_init()
    let mut i : u64 = 0u64
    while i < 32u64 {
        HH_KAT_L1[i] = (i + 1u64) as u8   HH_KAT_C1[i] = (i + 100u64) as u8
        HH_KAT_L2[i] = (i + 50u64) as u8  HH_KAT_C2[i] = (i + 150u64) as u8
        i = i + 1u64
    }
    if hh_record_partition((&HH_KAT_L1 as u64) as *u8, (&HH_KAT_C1 as u64) as *u8, 42u64) != 0i32 { return 1u64 }
    if hh_record_partition((&HH_KAT_L2 as u64) as *u8, (&HH_KAT_C2 as u64) as *u8, 77u64) != 1i32 { return 2u64 }
    if hh_partition_count() != 2u32 { return 3u64 }
    /* round-trip partition 0 */
    if hh_get_partition(0u64, (&HH_KAT_OL as u64) as *u8, (&HH_KAT_OC as u64) as *u8, (&HH_KAT_OV as u64) as *u64) != 0i32 { return 4u64 }
    if HH_KAT_OV[0] != 42u64 { return 5u64 }
    i = 0u64
    while i < 32u64 {
        if HH_KAT_OL[i] != HH_KAT_L1[i] { return 6u64 }
        if HH_KAT_OC[i] != HH_KAT_C1[i] { return 7u64 }
        i = i + 1u64
    }
    /* both pending initially */
    if hh_pending_count() != 2u32 { return 8u64 }
    /* resolve partition 0 -> accepted */
    if hh_resolve(0u64, HH_STATUS_ACCEPTED) != 0i32 { return 9u64 }
    if hh_partition_status(0u64) != 1i32 { return 10u64 }
    if hh_pending_count() != 1u32 { return 11u64 }
    /* partition 1 still pending, view 77 */
    if hh_get_partition(1u64, (&HH_KAT_OL as u64) as *u8, (&HH_KAT_OC as u64) as *u8, (&HH_KAT_OV as u64) as *u64) != 0i32 { return 12u64 }
    if HH_KAT_OV[0] != 77u64 { return 13u64 }
    /* bad index rejected */
    if hh_get_partition(2u64, (&HH_KAT_OL as u64) as *u8, (&HH_KAT_OC as u64) as *u8, (&HH_KAT_OV as u64) as *u64) == 0i32 { return 14u64 }
    return 99u64
}
