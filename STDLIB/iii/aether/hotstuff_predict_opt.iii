/* STDLIB/iii/aether/hotstuff_predict_opt.iii -- APOTHEOSIS C.11: the tournament QUORUM OPTIMIZER.
 *
 * The conservative k=1 predictive quorum becomes a provably load-balanced selection: a TOURNAMENT
 * over each peer's SEALED availability fact picks the 2f+1 most-available peers for the predictive
 * quorum, with a Byzantine-availability guarantee by construction.
 *
 * THE NO-ML INVARIANT (the non-negotiable): peer scores are SEALED FACTS supplied as a DATA INPUT
 * (`hpo_set_fact` -- e.g. a sealed failure/latency certificate), NEVER observed-and-adapted at
 * runtime. A consensus layer that LEARNS whom to trust from observed traffic is an attack surface
 * an adversary trains; the selection here is a PURE, DETERMINISTIC function of the sealed facts --
 * it has no internal observation state, so it cannot be trained. (Same discipline as nous: the
 * trainer is out-of-tree; the artifact consumes only sealed weights.)
 *
 * Byzantine-availability by construction: selecting exactly 2f+1 peers means even if f are
 * Byzantine, f+1 honest remain available -- enough to make progress. Safety is UNCHANGED (the mhash
 * vote-block match in hotstuff.iii). Compiler-UNREFERENCED -> LIBNATIVE.  Hexad: kind_sensitivity.
 * Ring: R0.  NIH: composes hotstuff_unified (quorum) only; integer compares.  K: 1.00. */
module aether_hotstuff_predict_opt

extern @abi(c-msvc-x64) fn hsu_quorum(n: u32) -> u32 from "hotstuff_unified.iii"

const HPO_MAX : u32 = 256u32

var HPO_FAIL : [u64; 256]   /* per-peer SEALED failure score (lower = more available); a DATA INPUT */
var HPO_SEL  : [u8;  256]   /* 1 = selected into the predictive quorum */
var HPO_N    : [u32; 1]

fn hpo_reset(n: u32) -> i32 @export {
    let nn : u32 = n
    HPO_N[0u64] = nn
    let mut i : u64 = 0u64
    while i < (HPO_MAX as u64) { HPO_FAIL[i] = 0u64  HPO_SEL[i] = 0u8  i = i + 1u64 }
    return 0i32
}

/* set peer p's SEALED availability fact (lower failscore = more available).  A data input -- the
 * fact crosses the boundary sealed; this module never observes or updates it. */
fn hpo_set_fact(p: u32, failscore: u64) -> i32 @export {
    if p >= HPO_MAX { return 0i32 - 1i32 }
    HPO_FAIL[p as u64] = failscore
    return 0i32
}

/* select the 2f+1 most-available peers (lowest sealed failscore; ties broken by lower index, so the
 * choice is DETERMINISTIC).  Returns the quorum size selected.  Pure over the sealed facts. */
fn hpo_best_quorum(n: u32) -> u32 @export {
    let mut nn : u32 = n
    if nn > HPO_MAX { nn = HPO_MAX }     /* bound the working count -> the loops never index past 256 */
    let q : u32 = hsu_quorum(nn)
    let mut i : u64 = 0u64
    while i < (HPO_MAX as u64) { HPO_SEL[i] = 0u8  i = i + 1u64 }
    let mut picked : u32 = 0u32
    while picked < q {
        let mut bestp : u32 = 0xFFFFFFFFu32
        let mut bestf : u64 = 0u64
        let mut found : u8 = 0u8                   /* existence is a FLAG, not the failscore magnitude */
        let mut p : u32 = 0u32
        while p < nn {
            if HPO_SEL[p as u64] == 0u8 {
                let fp : u64 = HPO_FAIL[p as u64]
                if found == 0u8 { bestf = fp  bestp = p  found = 1u8 }   /* first available = lowest index */
                else { if fp < bestf { bestf = fp  bestp = p } }         /* strict < -> lower index wins ties */
            }
            p = p + 1u32
        }
        if found == 0u8 { return picked }   /* fewer than q peers available (a MAX-failscore peer is still selectable) */
        HPO_SEL[bestp as u64] = 1u8
        picked = picked + 1u32
    }
    return picked
}

fn hpo_selected(p: u32) -> u8 @export {
    if p >= HPO_MAX { return 0u8 }
    return HPO_SEL[p as u64]
}

/* Byzantine-availability: the selected set must be at least the BFT quorum 2f+1, so f Byzantine
 * members leave f+1 honest available.  1 = the guarantee holds. */
fn hpo_byzantine_available(n: u32) -> u8 @export {
    let mut nn : u32 = n
    if nn > HPO_MAX { nn = HPO_MAX }     /* bound -> no OOB index past 256 */
    let mut sel : u32 = 0u32
    let mut p : u32 = 0u32
    while p < nn { if HPO_SEL[p as u64] == 1u8 { sel = sel + 1u32 }  p = p + 1u32 }
    if sel >= hsu_quorum(nn) { return 1u8 }
    return 0u8
}

/* Self-test: the tournament picks the most-available 2f+1 by SEALED fact; the selection is
 * DETERMINISTIC (the no-ML arm) and FACT-DRIVEN (different sealed facts -> different selection);
 * Byzantine-availability holds.  99 = pass. */
fn hpo_predict_opt_selftest() -> u64 @export {
    /* n=7 -> f=2 -> quorum 5.  Sealed facts (failscore): peer 5 best, 6 worst. */
    hpo_reset(7u32)
    hpo_set_fact(0u32, 50u64)  hpo_set_fact(1u32, 10u64)  hpo_set_fact(2u32, 30u64)
    hpo_set_fact(3u32, 20u64)  hpo_set_fact(4u32, 40u64)  hpo_set_fact(5u32,  5u64)
    hpo_set_fact(6u32, 60u64)
    if hpo_best_quorum(7u32) != 5u32 { return 1u64 }
    /* the 5 most-available {5,1,3,2,4} selected; the 2 worst {0,6} NOT */
    if hpo_selected(5u32) != 1u8 { return 2u64 }
    if hpo_selected(1u32) != 1u8 { return 3u64 }
    if hpo_selected(3u32) != 1u8 { return 4u64 }
    if hpo_selected(2u32) != 1u8 { return 5u64 }
    if hpo_selected(4u32) != 1u8 { return 6u64 }
    if hpo_selected(0u32) != 0u8 { return 7u64 }   /* failscore 50 -> excluded */
    if hpo_selected(6u32) != 0u8 { return 8u64 }   /* failscore 60 -> excluded */
    /* Byzantine-availability: 5 selected >= quorum 5 -> f=2 Byzantine leaves 3 honest */
    if hpo_byzantine_available(7u32) != 1u8 { return 9u64 }
    /* DETERMINISM (no-ML): re-run on the SAME sealed facts -> the SAME selection */
    hpo_best_quorum(7u32)
    if hpo_selected(5u32) != 1u8 { return 10u64 }
    if hpo_selected(0u32) != 0u8 { return 11u64 }
    /* FACT-DRIVEN: re-seal peer 0 as the most-available -> it enters, the ex-5th (peer 4) leaves.
     * (Proves selection follows the SEALED facts, not a constant -- and is NOT a learned memory:
     *  the change comes from the input fact, deterministically, not from observed history.) */
    hpo_set_fact(0u32, 1u64)
    hpo_best_quorum(7u32)
    if hpo_selected(0u32) != 1u8 { return 12u64 }   /* now most-available -> selected */
    if hpo_selected(4u32) != 0u8 { return 13u64 }   /* dropped (now 6th-best) */

    /* TIE-BREAK DIRECTION (the deterministic <-not-<= choice): n=4 (q=3), ALL failscore 10 -> the
     * LOWEST indices {0,1,2} win, peer 3 excluded.  A `<=` mutant would pick {1,2,3} -> this arm flips. */
    hpo_reset(4u32)
    hpo_set_fact(0u32, 10u64)  hpo_set_fact(1u32, 10u64)
    hpo_set_fact(2u32, 10u64)  hpo_set_fact(3u32, 10u64)
    if hpo_best_quorum(4u32) != 3u32 { return 14u64 }
    if hpo_selected(0u32) != 1u8 { return 15u64 }   /* lowest index wins the tie (a <= mutant drops peer 0) */
    if hpo_selected(1u32) != 1u8 { return 16u64 }
    if hpo_selected(2u32) != 1u8 { return 17u64 }
    if hpo_selected(3u32) != 0u8 { return 18u64 }   /* highest index excluded by the strict-< tie-break */

    /* MAX-failscore peers are still SELECTABLE (existence via the found flag, not the magnitude):
     * facts {10,20,MAX,MAX} -> the full 2f+1=3 quorum still fills (the old bestf=MAX impl under-filled to 2). */
    hpo_reset(4u32)
    hpo_set_fact(0u32, 10u64)  hpo_set_fact(1u32, 20u64)
    hpo_set_fact(2u32, 0xFFFFFFFFFFFFFFFFu64)  hpo_set_fact(3u32, 0xFFFFFFFFFFFFFFFFu64)
    if hpo_best_quorum(4u32) != 3u32 { return 19u64 }
    if hpo_byzantine_available(4u32) != 1u8 { return 20u64 }
    return 99u64
}
