/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\aether\http.iii
 *
 * III STDLIB - aether::http
 *
 * Lattice plan Step 0054 -- capability-based server/client surface
 * carrying the lattice's Crystal-HTTP header (X-Crystal-HTTP) on every
 * response.  The header value is the closure_root of the build that
 * served the response, letting peer clients verify they're talking to
 * a substrate sharing their R1 specification root.
 *
 *   http_format_crystal_header(out_buf, out_cap, root_ptr) -> u64
 *      Emits "X-Crystal-HTTP: <hex32>\r\n" into out_buf.  Returns the
 *      bytes written, or 0 on overflow.
 *
 *   http_response_with_crystal(arena, raw_base, raw_len) -> u64
 *      Wraps http_parse_response and additionally records the
 *      Crystal-HTTP header (if present in the input) into a side
 *      table accessible via http_response_crystal_root_byte.
 *
 *   http_response_crystal_root_byte(id, i) -> u32
 *      Returns the i-th byte (0..31) of the Crystal-HTTP root for
 *      response `id`, or 0x100 if absent.
 *
 * Hexad: kind_substance.  Ring: R0.  K: 0.95.
 */

module aether_http

extern @abi(c-msvc-x64) fn http_parse_response(arena: u64, raw_base: u64, raw_len: u64) -> u64 from "http_client.iii"
extern @abi(c-msvc-x64) fn http_response_header_find_ci(id: u64, name_base: u64, name_len: u64) -> i64 from "http_client.iii"
extern @abi(c-msvc-x64) fn http_response_header_value_base(id: u64, hdr_idx: u64) -> u64 from "http_client.iii"
extern @abi(c-msvc-x64) fn http_response_header_value_len(id: u64, hdr_idx: u64) -> u64 from "http_client.iii"

const AETHER_HTTP_OK         : i32 = 0i32
const AETHER_HTTP_E_OVERFLOW : u64 = 0u64

const CRYSTAL_HTTP_NAME_LEN : u64 = 16u64        /* "X-Crystal-HTTP" + nul */

var CRYSTAL_HEADER_NAME : [u8; 16]
var CRYSTAL_HEADER_INIT : u8 = 0u8

const AETHER_HTTP_RESP_MAX_FOR_CRYSTAL : u32 = 64u32

var AETHER_HTTP_CRYSTAL_ROOT  : [u8; 2048]    /* 64 responses × 32 bytes */
var AETHER_HTTP_CRYSTAL_LIVE  : [u8; 64]

fn http_init_crystal_name() -> u32 {
    if CRYSTAL_HEADER_INIT == 1u8 { return 0u32 }
    CRYSTAL_HEADER_NAME[0u64]  =  88u8     /* X */
    CRYSTAL_HEADER_NAME[1u64]  =  45u8     /* - */
    CRYSTAL_HEADER_NAME[2u64]  =  67u8     /* C */
    CRYSTAL_HEADER_NAME[3u64]  = 114u8     /* r */
    CRYSTAL_HEADER_NAME[4u64]  = 121u8     /* y */
    CRYSTAL_HEADER_NAME[5u64]  = 115u8     /* s */
    CRYSTAL_HEADER_NAME[6u64]  = 116u8     /* t */
    CRYSTAL_HEADER_NAME[7u64]  =  97u8     /* a */
    CRYSTAL_HEADER_NAME[8u64]  = 108u8     /* l */
    CRYSTAL_HEADER_NAME[9u64]  =  45u8     /* - */
    CRYSTAL_HEADER_NAME[10u64] =  72u8     /* H */
    CRYSTAL_HEADER_NAME[11u64] =  84u8     /* T */
    CRYSTAL_HEADER_NAME[12u64] =  84u8     /* T */
    CRYSTAL_HEADER_NAME[13u64] =  80u8     /* P */
    CRYSTAL_HEADER_NAME[14u64] = 0u8
    CRYSTAL_HEADER_NAME[15u64] = 0u8
    CRYSTAL_HEADER_INIT = 1u8
    return 0u32
}

/* Hex nibble (0-15) → ASCII '0'..'9','a'..'f'. */
fn http_hex_nibble(n: u32) -> u32 {
    if n < 10u32 { return n + 48u32 }
    return (n - 10u32) + 97u32
}

fn http_format_crystal_header(out_buf: u64, out_cap: u64, root_ptr: u64) -> u64 @export {
    if out_buf == 0u64 { return AETHER_HTTP_E_OVERFLOW }
    if root_ptr == 0u64 { return AETHER_HTTP_E_OVERFLOW }
    /* Header is "X-Crystal-HTTP: " (16 chars) + 64 hex digits + "\r\n" (2)
     * = 82 bytes. */
    if out_cap < 82u64 { return AETHER_HTTP_E_OVERFLOW }
    let p : *u8 = out_buf as *u8
    p[0u64]  =  88u8 ; p[1u64]  =  45u8 ; p[2u64]  =  67u8 ; p[3u64]  = 114u8
    p[4u64]  = 121u8 ; p[5u64]  = 115u8 ; p[6u64]  = 116u8 ; p[7u64]  =  97u8
    p[8u64]  = 108u8 ; p[9u64]  =  45u8 ; p[10u64] =  72u8 ; p[11u64] =  84u8
    p[12u64] =  84u8 ; p[13u64] =  80u8 ; p[14u64] =  58u8 ; p[15u64] =  32u8
    let r : *u8 = root_ptr as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        let b : u8 = r[i]
        let hi_n : u32 = ((b as u32) >> 4u32) & 0xFu32
        let lo_n : u32 = (b as u32) & 0xFu32
        p[16u64 + i * 2u64]        = http_hex_nibble(hi_n) as u8
        p[16u64 + i * 2u64 + 1u64] = http_hex_nibble(lo_n) as u8
        i = i + 1u64
    }
    p[80u64] = 13u8        /* \r */
    p[81u64] = 10u8        /* \n */
    return 82u64
}

fn http_response_with_crystal(arena: u64, raw_base: u64, raw_len: u64) -> u64 @export {
    let resp : u64 = http_parse_response(arena, raw_base, raw_len)
    if resp == 0u64 { return 0u64 }
    /* Look for X-Crystal-HTTP header. */
    http_init_crystal_name()
    let hidx : i64 = http_response_header_find_ci(resp, &CRYSTAL_HEADER_NAME as u64, 14u64)
    if hidx != -1i64 {
        /* [X19] range-check BEFORE the (resp-1)&0xFF mask -- the 0xFF mask permits 0..255 but the
         * crystal arrays hold only AETHER_HTTP_RESP_MAX_FOR_CRYSTAL (64) slots.  The old `slot >= 64`
         * check (kept below) catches resp in [65,256], but `& 0xFF` WRAPS, so resp in [257,320] would
         * alias onto live slots [0,63].  Range-checking the id first closes the wrap window
         * correct-by-construction (matches omnia/promote + numera/q128_f64). */
        if resp > (AETHER_HTTP_RESP_MAX_FOR_CRYSTAL as u64) { return resp }
        let slot : u64 = (resp - 1u64) & 0xFFu64
        if slot >= (AETHER_HTTP_RESP_MAX_FOR_CRYSTAL as u64) { return resp }
        let slot_u32 : u32 = slot as u32
        let hidx_u64 : u64 = (hidx as u64) & 0xFFFFFFFFu64
        let vbase : u64 = http_response_header_value_base(resp, hidx_u64)
        let vlen  : u64 = http_response_header_value_len(resp, hidx_u64)
        if vbase != 0u64 {
            if vlen >= 64u64 {
                let p : *u8 = vbase as *u8
                let mut j : u32 = 0u32
                while j < 32u32 {
                    let nib_hi : u32 = p[(j as u64) * 2u64] as u32
                    let nib_lo : u32 = p[(j as u64) * 2u64 + 1u64] as u32
                    let mut hi_n : u32 = 0u32
                    if nib_hi >= 48u32 {
                        if nib_hi <= 57u32 { hi_n = nib_hi - 48u32 }
                    }
                    if nib_hi >= 97u32 {
                        if nib_hi <= 102u32 { hi_n = nib_hi - 97u32 + 10u32 }
                    }
                    let mut lo_n : u32 = 0u32
                    if nib_lo >= 48u32 {
                        if nib_lo <= 57u32 { lo_n = nib_lo - 48u32 }
                    }
                    if nib_lo >= 97u32 {
                        if nib_lo <= 102u32 { lo_n = nib_lo - 97u32 + 10u32 }
                    }
                    AETHER_HTTP_CRYSTAL_ROOT[slot_u32 * 32u32 + j] = (((hi_n << 4u32) | lo_n) & 0xFFu32) as u8
                    j = j + 1u32
                }
                AETHER_HTTP_CRYSTAL_LIVE[slot_u32] = 1u8
            }
        }
    }
    return resp
}

fn http_response_crystal_root_byte(id: u64, i: u32) -> u32 @export {
    if id == 0u64 { return 0x100u32 }
    if i >= 32u32 { return 0x100u32 }
    /* [X19] range-check before the mask -- a fabricated id in [257,320] would `& 0xFF`-wrap onto a
     * live slot [0,63] and READ another response's crystal byte.  Closes the wrap the `slot >= 64`
     * check below misses. */
    if id > (AETHER_HTTP_RESP_MAX_FOR_CRYSTAL as u64) { return 0x100u32 }
    let slot : u64 = (id - 1u64) & 0xFFu64
    if slot >= (AETHER_HTTP_RESP_MAX_FOR_CRYSTAL as u64) { return 0x100u32 }
    let slot_u32 : u32 = slot as u32
    if AETHER_HTTP_CRYSTAL_LIVE[slot_u32] == 0u8 { return 0x100u32 }
    return AETHER_HTTP_CRYSTAL_ROOT[slot_u32 * 32u32 + i] as u32
}
