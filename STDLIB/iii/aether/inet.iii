/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\aether\inet.iii
 *
 * III STDLIB - aether::inet
 *
 * IPv4 parsing and formatting.  Restricted to dotted-quad form
 * (e.g. "192.0.2.1").  IPv6 lives in a separate module due to
 * complexity.
 *
 *   inet_parse_ipv4(src:*u8, src_len:u64) -> u32        -- network-order u32
 *      Returns 0xFFFFFFFFu32 on parse error (reserved as broadcast,
 *      treat 0u32 also as valid 0.0.0.0).  Use inet_last_error() to
 *      distinguish parse failure (1) from valid 255.255.255.255 (0).
 *   inet_format_ipv4(builder_id:u64, ip:u32) -> i32      -- "a.b.c.d"
 *   inet_last_error() -> u32                             -- 0 ok, 1 fail
 *
 * Hexad: kind_form.  Ring: R3.  K: 1.00.
 */

module aether_inet

extern @abi(c-msvc-x64) fn builder_push_byte(id: u64, b: u32) -> i32 from "builder.iii"

const INET_OK : i32 = 0i32
var INET_LAST_ERROR : u32 = 0u32

fn inet_last_error() -> u32 @export { return INET_LAST_ERROR }

/* Parse a single decimal octet starting at *off.  Updates *off via
 * INET_PARSE_OFF module var.  Returns octet value or 256 on error. */
var INET_PARSE_OFF : u64 = 0u64

fn inet_parse_octet(p: *u8, p_len: u64, start: u64) -> u32 {
    INET_PARSE_OFF = start
    if start >= p_len { return 256u32 }
    let mut value : u32 = 0u32
    let mut digits : u32 = 0u32
    let mut i : u64 = start
    let mut going : u8 = 1u8
    while going == 1u8 {
        if i >= p_len { going = 0u8 }
        if going == 1u8 {
            let c : u32 = p[i] as u32
            if c < 48u32 { going = 0u8 }
            if going == 1u8 {
                if c > 57u32 { going = 0u8 }
                if going == 1u8 {
                    value = value * 10u32 + (c - 48u32)
                    digits = digits + 1u32
                    i = i + 1u64
                    if value > 255u32 { return 256u32 }
                    if digits > 3u32   { return 256u32 }
                }
            }
        }
    }
    if digits == 0u32 { return 256u32 }
    INET_PARSE_OFF = i
    return value
}

fn inet_parse_ipv4(src: *u8, src_len: u64) -> u32 @export {
    INET_LAST_ERROR = 0u32
    let mut off : u64 = 0u64
    let o0 : u32 = inet_parse_octet(src, src_len, off)
    if o0 > 255u32 { INET_LAST_ERROR = 1u32; return 0u32 }
    off = INET_PARSE_OFF
    if off >= src_len { INET_LAST_ERROR = 1u32; return 0u32 }
    if src[off] != 46u8 { INET_LAST_ERROR = 1u32; return 0u32 }
    off = off + 1u64

    let o1 : u32 = inet_parse_octet(src, src_len, off)
    if o1 > 255u32 { INET_LAST_ERROR = 1u32; return 0u32 }
    off = INET_PARSE_OFF
    if off >= src_len { INET_LAST_ERROR = 1u32; return 0u32 }
    if src[off] != 46u8 { INET_LAST_ERROR = 1u32; return 0u32 }
    off = off + 1u64

    let o2 : u32 = inet_parse_octet(src, src_len, off)
    if o2 > 255u32 { INET_LAST_ERROR = 1u32; return 0u32 }
    off = INET_PARSE_OFF
    if off >= src_len { INET_LAST_ERROR = 1u32; return 0u32 }
    if src[off] != 46u8 { INET_LAST_ERROR = 1u32; return 0u32 }
    off = off + 1u64

    let o3 : u32 = inet_parse_octet(src, src_len, off)
    if o3 > 255u32 { INET_LAST_ERROR = 1u32; return 0u32 }
    off = INET_PARSE_OFF
    if off != src_len { INET_LAST_ERROR = 1u32; return 0u32 }   /* trailing garbage */

    return (o0 << 24u32) | (o1 << 16u32) | (o2 << 8u32) | o3
}

fn inet_emit_octet(builder_id: u64, octet: u32) -> i32 {
    let v : u32 = octet & 0xFFu32
    if v >= 100u32 {
        let h : u32 = v / 100u32
        let t : u32 = (v / 10u32) - (h * 10u32)
        let o : u32 = v - (h * 100u32) - (t * 10u32)
        builder_push_byte(builder_id, 48u32 + h)
        builder_push_byte(builder_id, 48u32 + t)
        builder_push_byte(builder_id, 48u32 + o)
    }
    if v >= 10u32 {
        if v < 100u32 {
            let t : u32 = v / 10u32
            let o : u32 = v - (t * 10u32)
            builder_push_byte(builder_id, 48u32 + t)
            builder_push_byte(builder_id, 48u32 + o)
        }
    }
    if v < 10u32 {
        builder_push_byte(builder_id, 48u32 + v)
    }
    return INET_OK
}

fn inet_format_ipv4(builder_id: u64, ip: u32) -> i32 @export {
    let o0 : u32 = (ip >> 24u32) & 0xFFu32
    let o1 : u32 = (ip >> 16u32) & 0xFFu32
    let o2 : u32 = (ip >>  8u32) & 0xFFu32
    let o3 : u32 = ip & 0xFFu32
    inet_emit_octet(builder_id, o0)
    builder_push_byte(builder_id, 46u32)
    inet_emit_octet(builder_id, o1)
    builder_push_byte(builder_id, 46u32)
    inet_emit_octet(builder_id, o2)
    builder_push_byte(builder_id, 46u32)
    inet_emit_octet(builder_id, o3)
    return INET_OK
}
