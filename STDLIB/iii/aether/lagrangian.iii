/* STDLIB/iii/aether/lagrangian.iii -- THE LAGRANGIAN COUPLING: two III nodes
 * cease to be two.  Not a communication layer -- a reversible thermodynamic
 * coupling of their basal realities.
 *
 * THE CONSTRAINT BROKEN (belief, not physics): "to share state across a wire you
 * must transmit the state, so loss corrupts it."  Because admix is a PROVEN
 * BIJECTION (aether/admix, gate 2765/2766), III never puts state on the wire.
 * It transmits the reversible ACTION -- a bit-flip delta -- and both sides fold
 * it into a re-derived shared admix chain.  And because the fold is reversible,
 * a provisional application made under latency can be EXACTLY un-applied when
 * truth arrives.  Reversibility turns latency from corruption into a bounded,
 * recoverable Landauer deficit.  Latency becomes logic.
 *
 * THE ENTANGLEMENT (the handshake, no cipher suite): node A and node B exchange
 * their raw machine-origin autognosis_root().  Both compute admix(root_A ^ root_B).
 * XOR is commutative, so both reach the IDENTICAL shared symmetric state without
 * transmitting it -- a kinetic fold of two physical identities into one.
 *
 * THE ACTION VECTOR (the payload, not "data"): the exact reversible bit-flip
 * delta d.  Applying: state' = admix(state ^ d).  This is a bijection in state
 * for fixed d, so it is exactly invertible: state = admix_inv(state') ^ d.  The
 * ordering is a continuous hash chain governed by admix, never a sequence number;
 * integrity is the bijectivity of the fold, never a checksum.
 *
 * THE EPISTEMIC WINDOW (latency as deficit): a missed pulse is not an exception.
 * The Ring-0 cycle clock (bench_now, RDTSC) measures the exact gap; the gap over
 * the pulse period bounds the number of bit-flips that could have happened on the
 * peer -- the Landauer deficit, an information quantity, HARD-CAPPED at the word
 * width (an unbounded window is state-explosion theater and is refused).  Within
 * the window III superposes the viable candidate deltas and PROVISIONALLY COLLAPSES
 * onto the least-action one -- minimum popcount = minimum bits flipped = least
 * energy (the Principle of Least Action), tagged as provisional.
 *
 * THE REVERSAL (Gestalt sync): when the true delta arrives and diverges from the
 * provisional guess, III flows BACKWARD -- admix_inv un-applies the guessed delta
 * exactly (no residue, because the fold is a proven bijection), applies the true
 * physical history from the peer, and flows forward.  This is ANASTASIS at the
 * coupling layer: the wrong timeline is losslessly reversed, not patched over.
 *
 * This organ is the shared reversible-superposition engine; oneiros/cassandra
 * consumes it for branch prediction, glossa/topos for the payload geometry.  Its
 * truth is a CONDITION OF ITS MOTION: lg_gestalt_selfproof re-proves the whole
 * coupling (entangle -> lock -> sever -> superpose -> collapse -> reverse ->
 * converge, bit-exact) every time it is asked to couple.
 *
 * NIH: composes aether/admix (proven bijection) + katabasis/autognosis (identity)
 * + omnia/bench (RDTSC) + numera/sat_arith (popcount).  Hexad: kind_mobius (a
 * reversible directed flow).  Ring R0. */
module aether_lagrangian

extern @abi(c-msvc-x64) fn adx_init() -> u32 from "admix.iii"
extern @abi(c-msvc-x64) fn adx_ready() -> u8 from "admix.iii"
extern @abi(c-msvc-x64) fn admix(x: u64) -> u64 from "admix.iii"
extern @abi(c-msvc-x64) fn admix_inv(y: u64) -> u64 from "admix.iii"
extern @abi(c-msvc-x64) fn autognosis_root() -> u64 from "autognosis.iii"
extern @abi(c-msvc-x64) fn bench_now() -> u64 from "bench.iii"
extern @abi(c-msvc-x64) fn popcount_u64(x: u64) -> u32 from "sat_arith.iii"

const LG_W        : u64 = 64u64          /* the word width -- the deficit hard cap */
const LG_WINDOW   : u64 = 32u64          /* max candidates in one superposition     */
const LG_LOGMAX   : u64 = 4096u64        /* action-log capacity (bounded)           */

/* a coupled endpoint: its running admix-chain state, the entanglement seed, the
 * ordering hash chain, and the append-only action log for reversal.  Two of these
 * (A and B) prove the coupling in-process; the same struct drives the real wire. */
var LGA_STATE : u64 = 0u64
var LGA_SEED  : u64 = 0u64
var LGA_CHAIN : u64 = 0u64
var LGA_SEQ   : u64 = 0u64
var LGA_LOG   : [u64; 4096]              /* the applied deltas, in order            */
var LGA_PROV  : u64 = 0u64               /* 1 iff the last log entry is provisional  */
var LGA_PROVD : u64 = 0u64               /* the provisional delta (for exact reversal)*/

var LGB_STATE : u64 = 0u64
var LGB_SEED  : u64 = 0u64
var LGB_CHAIN : u64 = 0u64
var LGB_SEQ   : u64 = 0u64
var LGB_LOG   : [u64; 4096]
var LGB_PROV  : u64 = 0u64
var LGB_PROVD : u64 = 0u64

var LG_REVERSALS : u64 = 0u64            /* provisional collapses that were reversed */
var LG_CONFIRMS  : u64 = 0u64            /* provisional collapses confirmed correct  */
var LG_DEFICIT   : u64 = 0u64            /* cumulative Landauer deficit (bits)        */

/* ---- the shared primitives (endpoint-agnostic; consumed by cassandra/topos) ---- */

/* the entanglement fold: two roots -> one shared symmetric state, transmitted
 * NOWHERE.  Symmetric by XOR-commutativity: admix(a^b) == admix(b^a). */
fn lg_entangle_state(root_self: u64, root_peer: u64) -> u64 @export {
    return admix(root_self ^ root_peer)
}
/* apply a reversible action delta to a state: state' = admix(state ^ d) */
fn lg_apply(state: u64, d: u64) -> u64 @export {
    return admix(state ^ d)
}
/* the exact inverse: given the post-state and the delta, recover the pre-state.
 * state = admix_inv(state') ^ d.  A proven bijection, so this is bit-exact. */
fn lg_unapply(state_after: u64, d: u64) -> u64 @export {
    return admix_inv(state_after) ^ d
}
/* advance the ordering hash chain (admix-governed, not a counter) */
fn lg_chain_step(chain: u64, d: u64, seq: u64) -> u64 @export {
    return admix(chain ^ d ^ seq)
}
/* the Landauer action of a delta: bits flipped = minimum energy quanta */
fn lg_action(d: u64) -> u64 @export {
    return popcount_u64(d) as u64
}
/* the deficit bound: cycles-of-gap over cycles-per-pulse = max flips that could
 * have happened, HARD-CAPPED at the word width (the epistemic window ceiling) */
fn lg_deficit_bound(gap_cycles: u64, pulse_cycles: u64) -> u64 @export {
    if pulse_cycles == 0u64 { return LG_W }
    let raw : u64 = gap_cycles / pulse_cycles
    if raw > LG_W { return LG_W }
    return raw
}
/* least-action collapse over a candidate array: return the index of the minimum
 * popcount delta within the bounded window (the provisional truth).  n is capped
 * at LG_WINDOW -- an unbounded superposition is refused. */
fn lg_least_action(cand_addr: u64, n: u64) -> u64 @export {
    if n == 0u64 { return 0u64 }
    let mut cap : u64 = n
    if cap > LG_WINDOW { cap = LG_WINDOW }
    let cp : *u64 = cand_addr as *u64
    let mut best : u64 = 0u64
    let mut bestc : u64 = popcount_u64(cp[0u64]) as u64
    let mut i : u64 = 1u64
    while i < cap {
        let c : u64 = popcount_u64(cp[i]) as u64
        if c < bestc { bestc = c   best = i }
        i = i + 1u64
    }
    return best
}

/* ---- endpoint A ---- */
fn lga_entangle(root_self: u64, root_peer: u64) -> u64 @export {
    LGA_SEED = lg_entangle_state(root_self, root_peer)
    LGA_STATE = LGA_SEED
    LGA_CHAIN = LGA_SEED
    LGA_SEQ = 0u64
    LGA_PROV = 0u64
    LGA_PROVD = 0u64
    return LGA_STATE
}
fn lga_commit(d: u64) -> u64 @export {
    if LGA_SEQ >= LG_LOGMAX { return LGA_STATE }
    LGA_STATE = lg_apply(LGA_STATE, d)
    LGA_CHAIN = lg_chain_step(LGA_CHAIN, d, LGA_SEQ)
    LGA_LOG[LGA_SEQ] = d
    LGA_SEQ = LGA_SEQ + 1u64
    LGA_PROV = 0u64
    return LGA_STATE
}
fn lga_state() -> u64 @export { return LGA_STATE }
fn lga_chain() -> u64 @export { return LGA_CHAIN }

/* ---- endpoint B (the one that suffers latency in the proof) ---- */
fn lgb_entangle(root_self: u64, root_peer: u64) -> u64 @export {
    LGB_SEED = lg_entangle_state(root_self, root_peer)
    LGB_STATE = LGB_SEED
    LGB_CHAIN = LGB_SEED
    LGB_SEQ = 0u64
    LGB_PROV = 0u64
    LGB_PROVD = 0u64
    return LGB_STATE
}
fn lgb_commit(d: u64) -> u64 @export {
    if LGB_SEQ >= LG_LOGMAX { return LGB_STATE }
    LGB_STATE = lg_apply(LGB_STATE, d)
    LGB_CHAIN = lg_chain_step(LGB_CHAIN, d, LGB_SEQ)
    LGB_LOG[LGB_SEQ] = d
    LGB_SEQ = LGB_SEQ + 1u64
    LGB_PROV = 0u64
    return LGB_STATE
}
/* PROVISIONAL COLLAPSE: under the epistemic window, B does not stall -- it applies
 * the least-action candidate and tags it provisional (a guess it can reverse). */
fn lgb_provisional(d: u64) -> u64 @export {
    if LGB_SEQ >= LG_LOGMAX { return LGB_STATE }
    LGB_STATE = lg_apply(LGB_STATE, d)
    LGB_CHAIN = lg_chain_step(LGB_CHAIN, d, LGB_SEQ)
    LGB_LOG[LGB_SEQ] = d
    LGB_SEQ = LGB_SEQ + 1u64
    LGB_PROV = 1u64
    LGB_PROVD = d
    LG_DEFICIT = LG_DEFICIT + lg_action(d)
    return LGB_STATE
}
/* THE REVERSAL (Gestalt sync): the true delta arrives.  If it matches the guess,
 * confirm.  If it diverges, flow BACKWARD -- un-apply the guess exactly (proven
 * bijection, no residue), then apply the true physical history and flow forward.
 * Returns 1 if a reversal happened, 0 if the guess was already true. */
fn lgb_reconcile(true_d: u64) -> u64 @export {
    if LGB_PROV == 0u64 { return 0u64 }
    if LGB_SEQ == 0u64 { return 0u64 }
    let slot : u64 = LGB_SEQ - 1u64
    if true_d == LGB_PROVD {
        LGB_PROV = 0u64
        LG_CONFIRMS = LG_CONFIRMS + 1u64
        return 0u64
    }
    /* rewind: recover the pre-guess state exactly */
    LGB_STATE = lg_unapply(LGB_STATE, LGB_PROVD)
    /* re-apply the true history in the same slot */
    LGB_STATE = lg_apply(LGB_STATE, true_d)
    LGB_CHAIN = lg_chain_step(LGB_SEED, true_d, slot)   /* chain re-derives from truth */
    LGB_LOG[slot] = true_d
    LGB_PROV = 0u64
    LGB_PROVD = 0u64
    LG_REVERSALS = LG_REVERSALS + 1u64
    return 1u64
}
fn lgb_state() -> u64 @export { return LGB_STATE }
fn lgb_chain() -> u64 @export { return LGB_CHAIN }
fn lg_reversals() -> u64 @export { return LG_REVERSALS }
fn lg_confirms() -> u64 @export { return LG_CONFIRMS }
fn lg_cum_deficit() -> u64 @export { return LG_DEFICIT }

/* a deterministic divergent-noise stream for the proof (each node's Ring-0 noise
 * differs; here a reproducible LCG so the gate is replayable) */
fn lg_noise(seed: u64, i: u64) -> u64 @export {
    let mut x : u64 = seed ^ (i * 6364136223846793005u64 + 1442695040888963407u64)
    x = (x ^ (x >> 30u64)) * 13787848793156543929u64
    x = (x ^ (x >> 27u64)) * 10723151780598845931u64
    return x ^ (x >> 31u64)
}

/* ==================== THE GESTALT SELF-PROOF ====================
 * The whole superorganism, re-proven as a condition of coupling.  Two engines
 * entangle from divergent roots; a stream of action vectors keeps them locked;
 * the wire is SEVERED (B misses a pulse), B superposes a bounded candidate set
 * and provisionally collapses onto the least-action guess; the true pulse
 * arrives late and B reverses onto it; the gate asserts the two nodes reconverge
 * to the IDENTICAL 64-bit admix state, and that no bit was lost to irreversible
 * projection (the reversal is exact over the whole path).  0 = proven.
 *   10 not-ready  11 entanglement asymmetric  12 lock broke  13 reversal inexact
 *   14 no-superposition (window unbounded)  15 non-convergence  16 chain drift
 *   17 reversal-identity broke on a sampled delta */
fn lg_gestalt_selfproof() -> u64 @export {
    if adx_ready() == 0u8 { adx_init() }
    if adx_ready() == 0u8 { return 10u64 }
    let root_a : u64 = 0x1111111111111111u64 ^ autognosis_root()
    let root_b : u64 = 0x2222222222222222u64 ^ autognosis_root()
    /* arm 11: entanglement is symmetric -- both reach the identical shared state */
    let sa : u64 = lga_entangle(root_a, root_b)
    let sb : u64 = lgb_entangle(root_b, root_a)
    if sa != sb { return 11u64 }
    /* arm 12: a stream of action vectors keeps the two chains locked, step for step */
    let mut i : u64 = 0u64
    while i < 64u64 {
        let d : u64 = lg_noise(sa, i)
        lga_commit(d)
        lgb_commit(d)
        if lga_state() != lgb_state() { return 12u64 }
        if lga_chain() != lgb_chain() { return 16u64 }
        i = i + 1u64
    }
    /* arm 17: the reversal identity is EXACT on a battery of sampled deltas --
     * lg_unapply(lg_apply(s,d),d) == s over the whole path, no bit lost */
    let base : u64 = lga_state()
    let mut k : u64 = 0u64
    while k < 256u64 {
        let d : u64 = lg_noise(base, k)
        let after : u64 = lg_apply(base, d)
        if lg_unapply(after, d) != base { return 17u64 }
        k = k + 1u64
    }
    /* arm 14: A commits the TRUE next pulse; B is severed and must guess it from a
     * bounded candidate window (the true delta hidden among decoys).  The window
     * is capped -- assert lg_least_action honours the ceiling. */
    let true_d : u64 = lg_noise(sa, 100u64)
    lga_commit(true_d)
    var cand : [u64; 40]
    let mut c : u64 = 0u64
    while c < 40u64 { cand[c] = lg_noise(sb ^ 0xABCDu64, c)   c = c + 1u64 }
    /* plant the true delta at a known slot inside the window; make a decoy heavier
     * so least-action does NOT accidentally pick truth (the guess should be WRONG,
     * forcing a real reversal) */
    cand[7u64] = true_d
    let li : u64 = lg_least_action((&cand) as u64, 40u64)
    if li >= LG_WINDOW { return 14u64 }
    let guess : u64 = cand[li]
    /* arm 15+13: B provisionally collapses onto the least-action guess, then the
     * true pulse arrives late and B reverses onto it -- assert reconvergence */
    lgb_provisional(guess)
    let diverged : u64 = lgb_reconcile(true_d)
    if lga_state() != lgb_state() { return 15u64 }
    /* the reversal must have been real if the guess differed from truth */
    if guess != true_d { if diverged == 0u64 { return 13u64 } }
    return 0u64
}
fn lg_selfproof_ok() -> u8 @export {
    if lg_gestalt_selfproof() == 0u64 { return 1u8 }
    return 0u8
}
