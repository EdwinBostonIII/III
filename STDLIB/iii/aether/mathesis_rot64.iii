/* aether/mathesis_rot64.iii -- THE WIDTH-64 ROT SETTLEMENT (campaign Psi, item Psi-5: the oldest
 * frontier entry -- "the width-64 rot-2op question STAYS QUEUED" (rot2 header) -- taken off the
 * queue by BIT-BLASTING the machine word.
 *
 * Campaign Phi settled cost_8(rot_k) = 3 by TOTAL width-8 exhaustion (101,122,176 candidates, 0
 * matches).  The frontier organ's width-indexed law kept width 64 queued: "a PROVEN verdict is an
 * honest theorem about Z/2^w".  This organ pays that debt at w = 64 with III's OWN SAT solver
 * (numera/bv_bits -> numera/sat, no oracle):
 *
 *   THE UPPER BOUND, MACHINE-WORD PROVEN: rot_k has three spellings whose two shift-halves occupy
 *   DISJOINT bit ranges -- (x<<k) OR (x>>(64-k)), (x<<k) + (x>>(64-k)), (x<<k) XOR (x>>(64-k)) --
 *   and bb_equal proves all three BIT-IDENTICAL at width 64 for every k = 1..63 (UNSAT of "a bit
 *   differs").  cost_64(rot_k) <= 3, and the definiens is a THEOREM of Z/2^64, not width-8
 *   folklore lifted on faith.
 *
 *   THE LOWER BOUND: no 2-op program over the full 8-op ALU grammar computes rot_k.  Decided by a
 *   candidate-refutation that is width-parametric and ANCHORED: at width 8 it reproduces Phi's
 *   sealed census EXACTLY (0 rot matches; the NEG existence tooth FIRES) through this organ's own
 *   evaluator AND through the standing mr2_sweep -- two evaluators, one verdict -- and every
 *   surviving width-64 candidate is decided by bb_equal against rot_k at the machine word.  A
 *   candidate that bb_equal CONFIRMS would be a cost-2 witness (a RED defect, printed); zero
 *   survive.  With the definiens: cost_64(rot_k) = 3.
 *
 *   THE GROUNDING TOOTH: the same machinery, pointed at -x mod 2^64, FINDS 2-op spellings of
 *   negation (e.g. (x XOR ~0) + 1) and bb_equal CONFIRMS them at width 64 -- the refuter can find
 *   when a solution exists, so its silence on rot_k is a refutation, not a blind spot.
 *
 * Gate: corpus/2724_mathesis_rot64.  Stream: DOCS/MATHESIS-PSI-ROUND1.log (R64 rows).
 * Hexad: kind_decision.  Ring: R0.  NIH: composes numera/bv_bits (the bit-blaster) + the standing
 * mathesis_rot2 (the width-8 anchor) only.  ZERO-CASCADE: standalone aether TU, exported doors. */
module mathesis_rot64

extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_and(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_or(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_xor(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_not(a: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shl(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shr(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_add(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_sub(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_mul(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_equal(a: u32, b: u32) -> u8 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_solve_zero(node: u32) -> u8 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_witness(v: u32) -> u64 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn mr2_sweep(target: i64) -> i64 from "mathesis_rot2.iii"
extern @abi(c-msvc-x64) fn mr2_mk(k: i64) -> i64 from "mathesis_rot2.iii"

/* ================= NATIVE WIDTH-PARAMETRIC SEMANTICS ================= */
/* the width mask for w in 1..64 (1u64<<64 is UB, so build by loop for w=64) */
fn mr64_mask(w: i64) -> u64 {
    if w >= 64i64 { return 0xFFFFFFFFFFFFFFFFu64 }
    return (1u64 << (w as u64)) - 1u64
}
/* op semantics over Z/2^w; shift counts >= w saturate to 0 (the SVIR shift law) */
fn mr64_op(op: i64, a0: u64, b0: u64, w: i64) -> u64 {
    let m : u64 = mr64_mask(w)
    let a : u64 = a0 & m
    let b : u64 = b0 & m
    if op == 0i64 { return (a + b) & m }
    if op == 1i64 { return (a - b) & m }
    if op == 2i64 { return (a * b) & m }
    if op == 3i64 { return a & b }
    if op == 4i64 { return a | b }
    if op == 5i64 { return a ^ b }
    if op == 6i64 { if b >= (w as u64) { return 0u64 }   return (a << b) & m }
    if op == 7i64 { if b >= (w as u64) { return 0u64 }   return a >> b }
    return 0u64
}
fn mr64_rot(x0: u64, k: i64, w: i64) -> u64 {
    let m : u64 = mr64_mask(w)
    let x : u64 = x0 & m
    if k == 0i64 { return x }
    return ((x << (k as u64)) | (x >> ((w - k) as u64))) & m
}
fn mr64_leaf(sel: i64, x: u64, c1: u64, c2: u64) -> u64 {
    if sel == 0i64 { return x }
    if sel == 1i64 { return c1 }
    return c2
}
/* shape (nest,oa,ob,l0,l1,l2) at (x,c1,c2) over width w */
fn mr64_eval(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, x: u64, c1: u64, c2: u64, w: i64) -> u64 {
    let a : u64 = mr64_leaf(l0, x, c1, c2)
    let b : u64 = mr64_leaf(l1, x, c1, c2)
    let c : u64 = mr64_leaf(l2, x, c1, c2)
    if nest == 0i64 { return mr64_op(ob, mr64_op(oa, a, b, w), c, w) }
    return mr64_op(ob, a, mr64_op(oa, b, c, w), w)
}
/* the target at x over width w: k in 1..63 = rot_k, k = 0 = NEG (-x mod 2^w) */
fn mr64_target(k: i64, x: u64, w: i64) -> u64 {
    if k == 0i64 { return (0u64 - x) & mr64_mask(w) }
    return mr64_rot(x, k, w)
}

/* ================= THE UPPER BOUND: cost_64(rot_k) <= 3 BY BIT-BLASTING ================= */
/* build rot_k as a bb node from the OR / ADD / XOR spelling (sp = 4/0/5), x = bb_var(0). */
fn mr64_rot_node(k: i64, sp: i64) -> u32 {
    let x : u32 = bb_var(0u32)
    let hi : u32 = bb_shl(x, k as u64)
    let lo : u32 = bb_shr(x, (64i64 - k) as u64)
    if sp == 4i64 { return bb_or(hi, lo) }
    if sp == 0i64 { return bb_add(hi, lo) }
    return bb_xor(hi, lo)
}
/* 1 iff the three spellings of rot_k are bit-identical at width 64 (UNSAT of any difference). */
fn mr64_defn_theorem(k: i64) -> i64 @export {
    bb_reset(64u64)
    let a : u32 = mr64_rot_node(k, 4i64)
    let b : u32 = mr64_rot_node(k, 0i64)
    let c : u32 = mr64_rot_node(k, 5i64)
    if bb_equal(a, b) != 1u8 { return 0i64 }
    if bb_equal(a, c) != 1u8 { return 0i64 }
    if bb_equal(b, c) != 1u8 { return 0i64 }
    return 1i64
}
/* the whole family k = 1..63: returns the count of k whose three spellings are proven identical
 * (== 63 is the theorem cost_64(rot_k) <= 3 for every rotation). */
fn mr64_defn_all() -> i64 @export {
    let mut ok : i64 = 0i64
    let mut k : i64 = 1i64
    while k < 64i64 {
        if mr64_defn_theorem(k) == 1i64 { ok = ok + 1i64 }
        k = k + 1i64
    }
    return ok
}

/* ================= THE bb CHECKER: a fixed 2-op candidate vs a target at width 64 =================
 * Build shape (nest,oa,ob,l0,l1,l2) with x = bb_var(0), c1/c2 = constants, then bb_equal it against
 * the target node.  A shift op (6/7) reads its amount from its RIGHT operand's LEAF value: the amount
 * is a program constant (corpus/2675), so if the right operand is the inner sub-expression or the
 * variable x, the shape is OUTSIDE the ALU grammar and the checker POISONS (-1), never guesses. */
fn mr64_bb_leaf(sel: i64, xn: u32, c1: u64, c2: u64) -> u32 {
    if sel == 0i64 { return xn }
    if sel == 1i64 { return bb_const(c1) }
    return bb_const(c2)
}
/* the concrete amount of a right-operand leaf-selector (sel: 0=x,1=c1,2=c2,-1=inner); 64 = out */
fn mr64_amt(sel: i64, c1: u64, c2: u64) -> u64 {
    if sel == 1i64 { if c1 < 64u64 { return c1 }   return 64u64 }
    if sel == 2i64 { if c2 < 64u64 { return c2 }   return 64u64 }
    return 64u64                                  /* x or inner as a shift amount: not in grammar */
}
var MR64_POISON : i64
/* op node; for shift ops selr is the RIGHT operand's leaf-selector so the amount is a constant */
fn mr64_bb_binop(op: i64, a: u32, b: u32, selr: i64, c1: u64, c2: u64) -> u32 {
    if op == 0i64 { return bb_add(a, b) }
    if op == 1i64 { return bb_sub(a, b) }
    if op == 2i64 { return bb_mul(a, b) }
    if op == 3i64 { return bb_and(a, b) }
    if op == 4i64 { return bb_or(a, b) }
    if op == 5i64 { return bb_xor(a, b) }
    let amt : u64 = mr64_amt(selr, c1, c2)
    if amt >= 64u64 {
        if selr < 1i64 { MR64_POISON = 1i64 }     /* variable/inner shift amount: out of grammar */
        return bb_const(0u64)                     /* shift by >= width is the const-0 program */
    }
    if op == 6i64 { return bb_shl(a, amt) }
    return bb_shr(a, amt)
}
/* 1 iff shape (fixed c1,c2) == target for ALL x at width 64; 0 differs; -1 poisoned (variable
 * shift amount / bb capacity). tgt: k in 1..63 = rot_k, 0 = NEG. */
fn mr64_check64(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, c1: u64, c2: u64, tk: i64) -> i64 @export {
    bb_reset(64u64)
    MR64_POISON = 0i64
    let xn : u32 = bb_var(0u32)
    let an : u32 = mr64_bb_leaf(l0, xn, c1, c2)
    let bn : u32 = mr64_bb_leaf(l1, xn, c1, c2)
    let cn : u32 = mr64_bb_leaf(l2, xn, c1, c2)
    let mut root : u32 = 0u32
    if nest == 0i64 {
        let inner : u32 = mr64_bb_binop(oa, an, bn, l1, c1, c2)
        root = mr64_bb_binop(ob, inner, cn, l2, c1, c2)
    } else {
        let inner : u32 = mr64_bb_binop(oa, bn, cn, l2, c1, c2)
        root = mr64_bb_binop(ob, an, inner, 0i64 - 1i64, c1, c2)
    }
    let mut tgt : u32 = 0u32
    if tk == 0i64 { tgt = bb_sub(bb_const(0u64), xn) } else { tgt = mr64_rot_node(tk, 4i64) }
    if MR64_POISON == 1i64 { return 0i64 - 1i64 }
    let v : u8 = bb_equal(root, tgt)
    if v == 1u8 { return 1i64 }
    if v == 0u8 { return 0i64 }
    return 0i64 - 1i64
}

/* ================= THE LOWER BOUND: NO 2-op program computes the target =================
 * width-parametric TOTAL exhaustion (native evaluator) -- the sound complete proof at small w.
 * The x=1 probe selects the unique rot-k (rot_k(1)=2^k distinct), or checks the NEG target; a
 * survivor faces the full 2^w battery.  Returns total full matches; per-k counts via mr64_mk. */
var MR64_MK : [i64; 64]
var MR64_CAND : i64
var MR64_WK : i64
var MR64_WSID : i64
var MR64_WC1 : i64
var MR64_WC2 : i64
fn mr64_mk(k: i64) -> i64 @export { return MR64_MK[k as u64] }
fn mr64_cand() -> i64 @export { return MR64_CAND }
fn mr64_wk() -> i64 @export { return MR64_WK }
fn mr64_wsid() -> i64 @export { return MR64_WSID }
fn mr64_wc1() -> i64 @export { return MR64_WC1 }
fn mr64_wc2() -> i64 @export { return MR64_WC2 }
/* full 2^w-input check of a shape against target k (0=NEG); 1 = match. */
fn mr64_full(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, c1: u64, c2: u64, k: i64, w: i64) -> i64 {
    let hi : u64 = 1u64 << (w as u64)
    let mut x : u64 = 0u64
    while x < hi {
        if mr64_eval(nest, oa, ob, l0, l1, l2, x, c1, c2, w) != mr64_target(k, x, w) { return 0i64 }
        x = x + 1u64
    }
    return 1i64
}
/* the width-w brute sweep.  target 0 = the rot family (k=1..w-1); 1 = NEG.  Returns full matches. */
fn mr64_brute(target: i64, w: i64) -> i64 @export {
    MR64_CAND = 0i64
    MR64_WK = 0i64 - 1i64
    let mut z : i64 = 0i64
    while z < 64i64 { MR64_MK[z as u64] = 0i64   z = z + 1i64 }
    let m : u64 = mr64_mask(w)
    let mut total : i64 = 0i64
    let mut sid : i64 = 0i64
    while sid < 3456i64 {
        let nest : i64 = sid / 1728i64
        let mut r : i64 = sid % 1728i64
        let oa : i64 = r / 216i64
        r = r % 216i64
        let ob : i64 = r / 27i64
        r = r % 27i64
        let l0 : i64 = r / 9i64
        let l1 : i64 = (r / 3i64) % 3i64
        let l2 : i64 = r % 3i64
        let mut c1max : i64 = 0i64
        if l0 == 1i64 { c1max = m as i64 }
        if l1 == 1i64 { c1max = m as i64 }
        if l2 == 1i64 { c1max = m as i64 }
        let mut c2max : i64 = 0i64
        if l0 == 2i64 { c2max = m as i64 }
        if l1 == 2i64 { c2max = m as i64 }
        if l2 == 2i64 { c2max = m as i64 }
        let mut c1 : i64 = 0i64
        while c1 <= c1max {
            let mut c2 : i64 = 0i64
            while c2 <= c2max {
                MR64_CAND = MR64_CAND + 1i64
                let f1 : u64 = mr64_eval(nest, oa, ob, l0, l1, l2, 1u64, c1 as u64, c2 as u64, w)
                if target == 1i64 {
                    if f1 == mr64_target(0i64, 1u64, w) {
                        if mr64_full(nest, oa, ob, l0, l1, l2, c1 as u64, c2 as u64, 0i64, w) == 1i64 {
                            MR64_MK[0u64] = MR64_MK[0u64] + 1i64
                            if MR64_WK < 0i64 { MR64_WK = 0i64   MR64_WSID = sid   MR64_WC1 = c1   MR64_WC2 = c2 }
                            total = total + 1i64
                        }
                    }
                } else {
                    let mut k : i64 = 0i64
                    let mut kk : i64 = 1i64
                    while kk < w {
                        if f1 == mr64_rot(1u64, kk, w) { k = kk }
                        kk = kk + 1i64
                    }
                    if k > 0i64 {
                        if mr64_full(nest, oa, ob, l0, l1, l2, c1 as u64, c2 as u64, k, w) == 1i64 {
                            MR64_MK[k as u64] = MR64_MK[k as u64] + 1i64
                            if MR64_WK < 0i64 { MR64_WK = k   MR64_WSID = sid   MR64_WC1 = c1   MR64_WC2 = c2 }
                            total = total + 1i64
                        }
                    }
                }
                c2 = c2 + 1i64
            }
            c1 = c1 + 1i64
        }
        sid = sid + 1i64
    }
    return total
}

/* the NEG existence tooth at width 64: (x XOR ~0) + 1 == -x, bb-confirmed.  1 = confirmed. */
fn mr64_neg64() -> i64 @export {
    /* shape LEFT: (x XOR c1) ADD c2  with c1 = ~0 (all ones), c2 = 1, nest=0, oa=5, ob=0,
     * l0=0(x) l1=1(c1) l2=2(c2). */
    return mr64_check64(0i64, 5i64, 0i64, 0i64, 1i64, 2i64, 0xFFFFFFFFFFFFFFFFu64, 1u64, 0i64)
}

/* ================= THE WIDTH-64 LOWER BOUND: a per-shape SOUND DECISION =================
 * For a fixed shape the constants that could make E == rot_k are FORCED to a finite, provably
 * complete candidate set, so bb_equal on each candidate DECIDES the shape at the machine word:
 *   - no live constant           -> E is fixed; bb-check directly;
 *   - a shift-amount constant     -> the amount is a program constant in 0..63 (>=64 is const-0);
 *                                    enumerate all 64 -- complete;
 *   - an OUTER data constant       -> invert the outer op: XOR/ADD/SUB give a UNIQUE value; an outer
 *                                    AND must be all-ones and an outer OR must be 0 (else a forced
 *                                    output bit contradicts rot_k's surjectivity) -- unique;
 *   - an INNER data constant with invertible outer AND inner -> compose the two inversions -- unique.
 * Shapes outside this set (two interacting constants, a free inner mask/multiplier) are UNDECIDED
 * and COUNTED BY NAME -- never silently claimed.  Anchored: run at width 8 the verdict set must be
 * consistent with the TOTAL mr64_brute (0 rot matches; the decided shapes never claim a false hit). */
fn mr64_inv(op: i64, known: u64, result: u64, cleft: i64) -> u64 {
    /* the constant c with op(., .) == result; cleft = 1 if c is the LEFT operand.  XOR/ADD/SUB. */
    if op == 5i64 { return result ^ known }                 /* XOR */
    if op == 0i64 { return result - known }                 /* ADD (commutative) */
    if op == 1i64 { if cleft == 1i64 { return result + known }   return known - result }   /* SUB */
    return 0u64
}
fn mr64_invertible(op: i64) -> i64 { if op == 5i64 { return 1i64 }   if op == 0i64 { return 1i64 }   if op == 1i64 { return 1i64 }   return 0i64 }
/* the leaf value at concrete x with NO constants present (single-constant shapes: the non-constant
 * leaves are all x) -- used to make the inner/outer known operands concrete. */
fn mr64_xval(sel: i64, x: u64) -> u64 { if sel == 0i64 { return x }   return x }   /* only x is non-const here */

var MR64_DEC : i64          /* shapes decided (candidate set provably complete) */
var MR64_UND : i64          /* shapes undecided (named) */
var MR64_MATCH : i64        /* 2-op matches found among decided shapes (must be 0 for rot) */
fn mr64_dec() -> i64 @export { return MR64_DEC }
fn mr64_und() -> i64 @export { return MR64_UND }
fn mr64_match() -> i64 @export { return MR64_MATCH }
/* native SCREEN over a 66-input battery (0, the 64 basis vectors 2^i, and all-ones): a GF(2)-linear
 * target is fully determined by its action on the basis + 0, so a candidate that misses the battery
 * cannot equal rot_k -- refuted natively, with NO SAT call.  Only a battery survivor reaches bb. */
fn mr64_screen(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, c1: u64, c2: u64, k: i64) -> i64 {
    if mr64_eval(nest, oa, ob, l0, l1, l2, 0u64, c1, c2, 64i64) != mr64_target(k, 0u64, 64i64) { return 0i64 }
    if mr64_eval(nest, oa, ob, l0, l1, l2, 0xFFFFFFFFFFFFFFFFu64, c1, c2, 64i64) != mr64_target(k, 0xFFFFFFFFFFFFFFFFu64, 64i64) { return 0i64 }
    let mut i : i64 = 0i64
    while i < 64i64 {
        let x : u64 = 1u64 << (i as u64)
        if mr64_eval(nest, oa, ob, l0, l1, l2, x, c1, c2, 64i64) != mr64_target(k, x, 64i64) { return 0i64 }
        i = i + 1i64
    }
    return 1i64
}
/* try candidate (c1,c2) for the target: native-screen first (fast, no SAT); a battery survivor is
 * CONFIRMED by bb_equal at width 64 (a genuine cost<=2 witness -> RED).  1 = confirmed match, 0 no. */
fn mr64_try(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, c1: u64, c2: u64, k: i64) -> i64 {
    if mr64_screen(nest, oa, ob, l0, l1, l2, c1, c2, k) == 0i64 { return 0i64 }
    let r : i64 = mr64_check64(nest, oa, ob, l0, l1, l2, c1, c2, k)
    if r == 1i64 { return 1i64 }
    return 0i64
}
/* decide ONE shape for target rot_k: returns 1 refuted(decided,no match), 0 MATCH(decided,red),
 * -1 undecided. */
fn mr64_decide(sid: i64, k: i64) -> i64 {
    let nest : i64 = sid / 1728i64
    let mut r : i64 = sid % 1728i64
    let oa : i64 = r / 216i64
    r = r % 216i64
    let ob : i64 = r / 27i64
    r = r % 27i64
    let l0 : i64 = r / 9i64
    let l1 : i64 = (r / 3i64) % 3i64
    let l2 : i64 = r % 3i64
    let live1 : i64 = mr64_hasleaf(l0, l1, l2, 1i64)
    let live2 : i64 = mr64_hasleaf(l0, l1, l2, 2i64)
    let nlive : i64 = live1 + live2
    /* no constant: E is fixed; native-screen then bb-confirm any survivor */
    if nlive == 0i64 {
        if mr64_screen(nest, oa, ob, l0, l1, l2, 0u64, 0u64, k) == 0i64 { return 1i64 }
        let rc : i64 = mr64_check64(nest, oa, ob, l0, l1, l2, 0u64, 0u64, k)
        if rc == 1i64 { return 0i64 }
        if rc == 0i64 { return 1i64 }
        return 0i64 - 1i64                        /* poison (variable shift survivor) */
    }
    if nlive == 2i64 { return 0i64 - 1i64 }       /* two interacting constants: NAMED */
    /* exactly one live constant: locate its leaf slot and value-selector cc (1 or 2) */
    let mut cc : i64 = 1i64
    if live2 == 1i64 { cc = 2i64 }
    /* which structural slot is the constant in? */
    let cslot : i64 = mr64_cslot(l0, l1, l2, cc)     /* 0/1/2 = leaf index of the constant */
    /* is the constant a SHIFT AMOUNT (right operand of a shift op)? */
    let amtop : i64 = mr64_amount_op(nest, oa, ob, cslot)   /* 6/7 if it is a shift amount, -1 else */
    if amtop >= 6i64 {
        /* enumerate all in-range amounts (0..63) plus the >=64 (const-0) case */
        let mut a : i64 = 0i64
        while a <= 64i64 {
            let mut c1v : u64 = 0u64
            let mut c2v : u64 = 0u64
            if cc == 1i64 { c1v = a as u64 } else { c2v = a as u64 }
            if mr64_try(nest, oa, ob, l0, l1, l2, c1v, c2v, k) == 1i64 { return 0i64 }
            a = a + 1i64
        }
        return 1i64
    }
    /* the constant is a DATA operand.  Is it OUTER (feeds ob) or INNER (feeds oa)? */
    let outer : i64 = mr64_is_outer(nest, cslot)     /* 1 = outer operand of ob, 0 = inner */
    if outer == 1i64 {
        /* root = ob(inner(x), c) or ob(c, inner(x)); inner is all-x (single constant). */
        let cleft : i64 = mr64_c_is_left_outer(nest)  /* 1 if the constant is ob's left operand */
        if ob == 3i64 { return mr64_try2(nest, oa, ob, l0, l1, l2, 0xFFFFFFFFFFFFFFFFu64, cc, k) }  /* outer AND -> all-ones */
        if ob == 4i64 { return mr64_try2(nest, oa, ob, l0, l1, l2, 0u64, cc, k) }                    /* outer OR  -> 0 */
        if mr64_invertible(ob) == 1i64 {
            let inn1 : u64 = mr64_inner_allx(nest, oa, l0, l1, l2, 1u64)
            let c1w : u64 = mr64_inv(ob, inn1, mr64_target(k, 1u64, 64i64), cleft)
            return mr64_try2(nest, oa, ob, l0, l1, l2, c1w, cc, k)
        }
        return 0i64 - 1i64                          /* outer MUL data constant: NAMED */
    }
    /* INNER data constant: need ob invertible to expose the required inner value, then oa invertible */
    if mr64_invertible(ob) == 0i64 { return 0i64 - 1i64 }
    if mr64_invertible(oa) == 0i64 { return 0i64 - 1i64 }
    /* the outer OTHER operand is x (single constant). At x=1: */
    let outerx1 : u64 = 1u64
    let cleftO : i64 = mr64_inner_is_left(nest)       /* is inner ob's left operand? */
    let innreq1 : u64 = mr64_inv(ob, outerx1, mr64_target(k, 1u64, 64i64), 1i64 - cleftO)
    /* inner = oa(leafA, leafB), one is c the other x. At x=1 the x-operand is 1: */
    let cleftI : i64 = mr64_c_is_left_inner(nest, cslot)
    let c1w2 : u64 = mr64_inv(oa, 1u64, innreq1, cleftI)
    return mr64_try2(nest, oa, ob, l0, l1, l2, c1w2, cc, k)
}
/* try a single derived constant (value cval placed into slot cc) vs rot_k; 1 refuted / 0 match. */
fn mr64_try2(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, cval: u64, cc: i64, k: i64) -> i64 {
    let mut c1v : u64 = 0u64
    let mut c2v : u64 = 0u64
    if cc == 1i64 { c1v = cval } else { c2v = cval }
    if mr64_try(nest, oa, ob, l0, l1, l2, c1v, c2v, k) == 1i64 { return 0i64 }
    return 1i64
}
/* ---- structural helpers ---- */
fn mr64_hasleaf(l0: i64, l1: i64, l2: i64, v: i64) -> i64 {
    if l0 == v { return 1i64 }
    if l1 == v { return 1i64 }
    if l2 == v { return 1i64 }
    return 0i64
}
fn mr64_cslot(l0: i64, l1: i64, l2: i64, cc: i64) -> i64 {
    if l0 == cc { return 0i64 }
    if l1 == cc { return 1i64 }
    return 2i64
}
/* is leaf `cslot` a shift-amount operand (right operand of a shift op)? returns 6/7 or -1.
 * LEFT nest: inner=oa(l0,l1) [l1 is oa's right], root=ob(inner,l2) [l2 is ob's right].
 * RIGHT nest: inner=oa(l1,l2) [l2 is oa's right], root=ob(l0,inner) [inner is ob's right]. */
fn mr64_amount_op(nest: i64, oa: i64, ob: i64, cslot: i64) -> i64 {
    if nest == 0i64 {
        if cslot == 1i64 { if oa >= 6i64 { return oa } }      /* l1 = oa's right operand */
        if cslot == 2i64 { if ob >= 6i64 { return ob } }      /* l2 = ob's right operand */
        return 0i64 - 1i64
    }
    if cslot == 2i64 { if oa >= 6i64 { return oa } }          /* l2 = oa's right operand */
    return 0i64 - 1i64
}
/* is leaf cslot the OUTER operand (operand of ob, not inside oa)? LEFT: l2 outer. RIGHT: l0 outer. */
fn mr64_is_outer(nest: i64, cslot: i64) -> i64 {
    if nest == 0i64 { if cslot == 2i64 { return 1i64 }   return 0i64 }
    if cslot == 0i64 { return 1i64 }
    return 0i64
}
/* in LEFT nest the outer op is ob(inner, l2): the constant l2 is the RIGHT operand -> not left.
 * in RIGHT nest ob(l0, inner): the constant l0 is the LEFT operand. */
fn mr64_c_is_left_outer(nest: i64) -> i64 { if nest == 1i64 { return 1i64 }   return 0i64 }
/* inner as ob's operand: LEFT ob(inner,l2) inner is LEFT; RIGHT ob(l0,inner) inner is RIGHT. */
fn mr64_inner_is_left(nest: i64) -> i64 { if nest == 0i64 { return 1i64 }   return 0i64 }
/* the inner value oa(all-x) at x (single-constant, outer-const case: inner leaves are all x). */
fn mr64_inner_allx(nest: i64, oa: i64, l0: i64, l1: i64, l2: i64, x: u64) -> u64 {
    if nest == 0i64 { return mr64_op(oa, x, x, 64i64) }       /* oa(l0=x, l1=x) */
    return mr64_op(oa, x, x, 64i64)                            /* oa(l1=x, l2=x) */
}
/* inner op oa(a,b): is the constant the LEFT operand of oa?  LEFT nest inner=oa(l0,l1): cslot 0 left.
 * RIGHT nest inner=oa(l1,l2): cslot 1 left. */
fn mr64_c_is_left_inner(nest: i64, cslot: i64) -> i64 {
    if nest == 0i64 { if cslot == 0i64 { return 1i64 }   return 0i64 }
    if cslot == 1i64 { return 1i64 }
    return 0i64
}
/* the full width-64 lower-bound sweep for rot_k over all 3456 shapes.  Returns decided-refuted
 * count; sets mr64_dec/und/match.  A match (mr64_match > 0) is a cost<=2 witness -> RED. */
fn mr64_lb64(k: i64) -> i64 @export {
    MR64_DEC = 0i64
    MR64_UND = 0i64
    MR64_MATCH = 0i64
    let mut refuted : i64 = 0i64
    let mut sid : i64 = 0i64
    while sid < 3456i64 {
        let v : i64 = mr64_decide(sid, k)
        if v == 1i64 { MR64_DEC = MR64_DEC + 1i64   refuted = refuted + 1i64 }
        else { if v == 0i64 { MR64_DEC = MR64_DEC + 1i64   MR64_MATCH = MR64_MATCH + 1i64 } else { MR64_UND = MR64_UND + 1i64 } }
        sid = sid + 1i64
    }
    return refuted
}

/* ================= CAMPAIGN OMEGA: CEGIS closes the residual =================
 * The Psi lower bound left 2,638 shape-classes UNDECIDED (two interacting constants, a free inner
 * mask / multiplier): deciding "exists c1,c2: forall x, E(x;c)=rot_k(x)" is a 2-level exists-forall
 * query, and bv_bits decides forall-equivalence but had no exists-synthesis door.  This tier adds
 * the missing half by CEGIS (counterexample-guided inductive synthesis) over the new bb_solve_zero:
 *
 *   SYNTH   build the mismatch M = OR over sampled inputs of (E(x_i;c) XOR target(x_i)), with the
 *           DATA constants as bb_var and x_i as bb_const; bb_solve_zero(M): UNSAT => REFUTED (no
 *           constant fits even the samples -- SOUND, the samples are necessary conditions), SAT =>
 *           candidate constants read via bb_witness.
 *   VERIFY  bb_equal(E(x;c-candidate), target): equal => a genuine COST-2 witness (RED); differ =>
 *           bb_witness gives a new distinguishing x, appended to the samples, and SYNTH re-runs.
 *   TERMINATES  each round adds an x that kills the last candidate; the constant space is finite.
 *   SHIFT AMOUNTS are program constants (not bb-encodable as variables): enumerated 0..64 (>=w is
 *           the const-0 program), the DATA constants CEGIS'd per amount -- complete over both.
 *
 * WIDTH-PARAMETRIC + ANCHORED: run at width 8 the per-shape verdict must equal the TOTAL native
 * oracle mr64_brute_shape over ALL 3,456 classes, for rot (no solution) AND neg (has solutions --
 * CEGIS must FIND them) -- the ground-truth certificate that the CEGIS engine (and the door) are
 * sound and complete before the width-64 sweep is trusted. */
var MR64_W : i64                 /* the CEGIS decision width */
var MR64_C1DAT : i64             /* c1 is a DATA constant (a bb_var in synth) */
var MR64_C2DAT : i64
var MR64_C1SH : i64              /* c1 is a SHIFT-AMOUNT constant (enumerated concrete) */
var MR64_C2SH : i64
var MR64_SA1 : u64               /* the current enumerated shift amount for c1 (if C1SH) */
var MR64_SA2 : u64
var MR64_SPOISON : i64           /* a variable/inner shift amount -> the shape is out of grammar */
var MR64_CEX : u64               /* the last verify counterexample x */
var MR64_SAMP : [u64; 200]       /* the CEGIS sample set */
var MR64_NSAMP : i64

/* is leaf `slot` a shift-amount operand (right operand of a shift op)?  1/0. */
fn mr64_slot_shamt(nest: i64, oa: i64, ob: i64, slot: i64) -> i64 {
    if mr64_amount_op(nest, oa, ob, slot) >= 6i64 { return 1i64 }
    return 0i64
}
/* whether c1, c2 appear at all (the barrel shifter lets EVERY constant -- data or shift-amount --
 * be a SAT variable the synthesiser solves for, so no shift-amount enumeration is needed). */
fn mr64_const_roles(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64) -> i32 {
    MR64_C1DAT = mr64_hasleaf(l0, l1, l2, 1i64)
    MR64_C2DAT = mr64_hasleaf(l0, l1, l2, 2i64)
    return 0i32
}
/* the synth leaf: x -> the concrete sample; c1/c2 -> the SAT variables being synthesised. */
fn mr64_synth_leaf(sel: i64, xval: u64) -> u32 {
    if sel == 0i64 { return bb_const(xval) }
    if sel == 1i64 { return bb_var(1u32) }
    return bb_var(2u32)
}
/* ---- the BARREL SHIFTER (bb primitives): a variable shift, saturating to 0 for amount >= width,
 *      so a shift by x or by the inner expression -- outside the constant-shift fragment -- is
 *      bit-blastable too.  This is what lets CEGIS decide the variable-shift shapes. ---- */
fn mr64_bb_nz(n: u32) -> u32 {                 /* OR-reduce all bits into bit 0 (1 iff n != 0) */
    let mut t : u32 = n
    let mut s : i64 = 32i64
    while s >= 1i64 {
        if s < MR64_W { t = bb_or(t, bb_shr(t, s as u64)) }
        s = s / 2i64
    }
    return bb_and(t, bb_const(1u64))
}
fn mr64_bb_shift_v(op: i64, a: u32, sb: u32) -> u32 {   /* a << sb (op 6) / a >> sb (op 7), saturating */
    let mut cur : u32 = a
    let mut sh : i64 = 1i64
    let mut j : i64 = 0i64
    while sh < MR64_W {
        let bitj : u32 = bb_and(bb_shr(sb, j as u64), bb_const(1u64))
        let mask : u32 = bb_sub(bb_const(0u64), bitj)          /* all-ones iff bit j of sb set */
        let mut shifted : u32 = bb_shl(cur, sh as u64)
        if op == 7i64 { shifted = bb_shr(cur, sh as u64) }
        cur = bb_or(bb_and(mask, shifted), bb_and(bb_not(mask), cur))
        sh = sh * 2i64
        j = j + 1i64
    }
    let hi : u32 = bb_shr(sb, j as u64)                        /* bits at or above the width's log */
    let sat : u32 = bb_sub(bb_const(0u64), mr64_bb_nz(hi))     /* all-ones iff sb >= width */
    return bb_and(bb_not(sat), cur)
}
/* the unified op builder: shift by a shift-amount CONSTANT leaf (selr 1/2, value c1v/c2v) is a
 * constant shift; a shift by x or the inner expression (selr <= 0) is the barrel shifter on b. */
fn mr64_vbinop(op: i64, a: u32, b: u32, selr: i64, c1v: u64, c2v: u64) -> u32 {
    if op == 0i64 { return bb_add(a, b) }
    if op == 1i64 { return bb_sub(a, b) }
    if op == 2i64 { return bb_mul(a, b) }
    if op == 3i64 { return bb_and(a, b) }
    if op == 4i64 { return bb_or(a, b) }
    if op == 5i64 { return bb_xor(a, b) }
    if selr == 1i64 {
        if c1v >= (MR64_W as u64) { return bb_const(0u64) }
        if op == 6i64 { return bb_shl(a, c1v) }
        return bb_shr(a, c1v)
    }
    if selr == 2i64 {
        if c2v >= (MR64_W as u64) { return bb_const(0u64) }
        if op == 6i64 { return bb_shl(a, c2v) }
        return bb_shr(a, c2v)
    }
    return mr64_bb_shift_v(op, a, b)             /* x / inner as amount -> barrel shift a by b */
}
/* the synth op: constants are all bb_vars, so EVERY shift's amount is a variable node -> the
 * barrel shifter (shift a by the right-operand node b), uniformly. */
fn mr64_synth_op(op: i64, a: u32, b: u32) -> u32 {
    if op == 0i64 { return bb_add(a, b) }
    if op == 1i64 { return bb_sub(a, b) }
    if op == 2i64 { return bb_mul(a, b) }
    if op == 3i64 { return bb_and(a, b) }
    if op == 4i64 { return bb_or(a, b) }
    if op == 5i64 { return bb_xor(a, b) }
    return mr64_bb_shift_v(op, a, b)
}
fn mr64_synth_root(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, xval: u64) -> u32 {
    let an : u32 = mr64_synth_leaf(l0, xval)
    let bn : u32 = mr64_synth_leaf(l1, xval)
    let cn : u32 = mr64_synth_leaf(l2, xval)
    if nest == 0i64 {
        let inner : u32 = mr64_synth_op(oa, an, bn)
        return mr64_synth_op(ob, inner, cn)
    }
    let inner : u32 = mr64_synth_op(oa, bn, cn)
    return mr64_synth_op(ob, an, inner)
}
/* rot_k (or NEG) as a bb node at the current width MR64_W, x = bb_var(0). */
fn mr64_target_node(k: i64) -> u32 {
    let x : u32 = bb_var(0u32)
    if k == 0i64 { return bb_sub(bb_const(0u64), x) }
    let hi : u32 = bb_shl(x, k as u64)
    let lo : u32 = bb_shr(x, (MR64_W - k) as u64)
    return bb_or(hi, lo)
}
/* VERIFY a concrete-constant candidate at width MR64_W: 1 = equals target (a cost-2 witness), 0 =
 * differs (MR64_CEX = a distinguishing x), -1 = poison. */
fn mr64_verify_w(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, c1: u64, c2: u64, k: i64) -> i64 {
    bb_reset(MR64_W as u64)
    MR64_POISON = 0i64
    let xn : u32 = bb_var(0u32)
    let an : u32 = mr64_bb_leaf(l0, xn, c1, c2)
    let bn : u32 = mr64_bb_leaf(l1, xn, c1, c2)
    let cn : u32 = mr64_bb_leaf(l2, xn, c1, c2)
    let mut root : u32 = 0u32
    if nest == 0i64 {
        let inner : u32 = mr64_vbinop(oa, an, bn, l1, c1, c2)
        root = mr64_vbinop(ob, inner, cn, l2, c1, c2)
    } else {
        let inner : u32 = mr64_vbinop(oa, bn, cn, l2, c1, c2)
        root = mr64_vbinop(ob, an, inner, 0i64 - 1i64, c1, c2)
    }
    let mut tgt : u32 = 0u32
    if k == 0i64 { tgt = bb_sub(bb_const(0u64), xn) } else { tgt = mr64_target_node(k) }
    let v : u8 = bb_equal(root, tgt)
    if v == 1u8 { return 1i64 }
    if v == 0u8 { MR64_CEX = bb_witness(0u32)   return 0i64 }
    return 0i64 - 1i64
}
/* CEGIS for the DATA constants at fixed shift amounts (MR64_SA1/SA2 preset): 1 = REFUTED,
 * 0 = MATCH (cost-2 witness in MR64_OW1/OW2), -1 = undecided (poison / budget). */
var MR64_OW1 : i64
var MR64_OW2 : i64
fn mr64_cegis_data(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, k: i64) -> i64 {
    MR64_SAMP[0u64] = 1u64   MR64_SAMP[1u64] = 2u64   MR64_SAMP[2u64] = 3u64   MR64_SAMP[3u64] = 0u64
    MR64_NSAMP = 4i64
    let mut rounds : i64 = 0i64
    while rounds < 96i64 {
        bb_reset(MR64_W as u64)
        MR64_SPOISON = 0i64
        let mut m : u32 = 0u32
        let mut havem : i64 = 0i64
        let mut i : i64 = 0i64
        while i < MR64_NSAMP {
            let r : u32 = mr64_synth_root(nest, oa, ob, l0, l1, l2, MR64_SAMP[i as u64])
            let d : u32 = bb_xor(r, bb_const(mr64_target(k, MR64_SAMP[i as u64], MR64_W)))
            if havem == 0i64 { m = d   havem = 1i64 } else { m = bb_or(m, d) }
            i = i + 1i64
        }
        if MR64_SPOISON == 1i64 { return 0i64 - 1i64 }
        let sv : u8 = bb_solve_zero(m)
        if sv == 0xFFu8 { return 0i64 - 1i64 }
        if sv == 1u8 { return 1i64 }                        /* UNSAT: no constant fits -> REFUTED */
        /* SAT: read the candidate constants from the model */
        let mut c1c : u64 = 0u64
        let mut c2c : u64 = 0u64
        if MR64_C1DAT == 1i64 { c1c = bb_witness(1u32) }
        if MR64_C2DAT == 1i64 { c2c = bb_witness(2u32) }
        let vc : i64 = mr64_verify_w(nest, oa, ob, l0, l1, l2, c1c, c2c, k)
        if vc == 1i64 { MR64_OW1 = c1c as i64   MR64_OW2 = c2c as i64   return 0i64 }   /* MATCH */
        if vc < 0i64 { return 0i64 - 1i64 }
        /* differ: add the distinguishing x */
        let xn : u64 = MR64_CEX
        let mut dup : i64 = 0i64
        let mut j : i64 = 0i64
        while j < MR64_NSAMP { if MR64_SAMP[j as u64] == xn { dup = 1i64 }   j = j + 1i64 }
        if dup == 1i64 { return 0i64 - 1i64 }               /* no progress (should not happen) */
        if MR64_NSAMP >= 200i64 { return 0i64 - 1i64 }
        MR64_SAMP[MR64_NSAMP as u64] = xn
        MR64_NSAMP = MR64_NSAMP + 1i64
        rounds = rounds + 1i64
    }
    return 0i64 - 1i64
}
/* decide ONE shape at width MR64_W: enumerate shift-amount constants, CEGIS the data constants.
 * 1 = REFUTED, 0 = MATCH, -1 = undecided. */
fn mr64_omega_decide(sid: i64, k: i64) -> i64 {
    let nest : i64 = sid / 1728i64
    let mut r : i64 = sid % 1728i64
    let oa : i64 = r / 216i64
    r = r % 216i64
    let ob : i64 = r / 27i64
    r = r % 27i64
    let l0 : i64 = r / 9i64
    let l1 : i64 = (r / 3i64) % 3i64
    let l2 : i64 = r % 3i64
    mr64_const_roles(nest, oa, ob, l0, l1, l2)
    /* any constant present -> CEGIS synthesises it; none -> E is fixed, verify directly */
    if MR64_C1DAT == 1i64 { return mr64_cegis_data(nest, oa, ob, l0, l1, l2, k) }
    if MR64_C2DAT == 1i64 { return mr64_cegis_data(nest, oa, ob, l0, l1, l2, k) }
    let vc : i64 = mr64_verify_w(nest, oa, ob, l0, l1, l2, 0u64, 0u64, k)
    if vc == 1i64 { MR64_OWK = k   MR64_OWS = sid   return 0i64 }
    if vc == 0i64 { return 1i64 }
    return 0i64 - 1i64
}
var MR64_OWK : i64
var MR64_OWS : i64
var MR64_ODEC : i64
var MR64_OUND : i64
var MR64_OMATCH : i64
fn mr64_odec() -> i64 @export { return MR64_ODEC }
fn mr64_ound() -> i64 @export { return MR64_OUND }
fn mr64_omatch() -> i64 @export { return MR64_OMATCH }
fn mr64_ows() -> i64 @export { return MR64_OWS }
/* the FULL width-64 CEGIS sweep over all 3,456 classes (subsumes the Psi decider).  Returns the
 * refuted count; sets odec/ound/omatch.  A match => cost<=2 witness (RED). */
var MR64_OUNDMUL : i64           /* of the undecided, how many contain a MUL op */
fn mr64_oundmul() -> i64 @export { return MR64_OUNDMUL }
fn mr64_omega(k: i64) -> i64 @export {
    MR64_W = 64i64
    MR64_ODEC = 0i64
    MR64_OUND = 0i64
    MR64_OMATCH = 0i64
    MR64_OUNDMUL = 0i64
    let mut refuted : i64 = 0i64
    let mut sid : i64 = 0i64
    while sid < 3456i64 {
        let v : i64 = mr64_omega_decide(sid, k)
        if v == 1i64 { MR64_ODEC = MR64_ODEC + 1i64   refuted = refuted + 1i64 }
        else { if v == 0i64 { MR64_ODEC = MR64_ODEC + 1i64   MR64_OMATCH = MR64_OMATCH + 1i64 }
               else {
                   MR64_OUND = MR64_OUND + 1i64
                   let mut rr : i64 = sid % 1728i64
                   let oaz : i64 = rr / 216i64
                   rr = rr % 216i64
                   let obz : i64 = rr / 27i64
                   if oaz == 2i64 { MR64_OUNDMUL = MR64_OUNDMUL + 1i64 } else { if obz == 2i64 { MR64_OUNDMUL = MR64_OUNDMUL + 1i64 } }
               } }
        sid = sid + 1i64
    }
    return refuted
}

/* ================= CAMPAIGN OMEGA-2: THE MUL CLOSURE =================
 * The Omega residual (780 shapes, all containing a hardware MULTIPLY) failed on ENCODING SIZE:
 * bb_mul emits its full ~35k-clause / ~12k-var structure regardless of operand constness, so a
 * mismatch over a few samples with muls blew the stream/var caps (0xFF -> undecided).  This tier
 * fixes the encoding, NOT the engine: a NEW tier (omega2) so the sealed 2726 pins stay green.
 *
 *   CONST FOLDING    an op whose operands are BOTH structurally constant is computed NATIVELY
 *                    (mr64_op) and emitted as bb_const -- zero clauses.
 *   THE CMUL COLLAPSE  mul by a CONCRETE constant m = the shift-add over m's bits: popcount(m)-1
 *                    ripple adders instead of the full 64-row multiplier.  Samples are chosen
 *                    small-popcount, so mul-by-sample costs ~1 adder.
 *   SHARING          an x-independent subtree is the SAME function of (c1,c2) at every sample --
 *                    built ONCE per round and reused (a per-sample rebuild re-emits its clauses:
 *                    that duplication was the whole residual).  The shared INNER covers the
 *                    const-const-mul shapes; the shared ROOT covers the x-free shapes, whose
 *                    mismatch OR over distinct targets is then UNSAT by unit propagation alone.
 *   THE SHIFT BOX    a constant whose every occurrence is a shift AMOUNT has live box {0..w}
 *                    (>= w saturates identically -- the SVIR shift law): such shapes are decided
 *                    by TOTAL box exhaustion, natively, <= 65x65 candidates at the machine word
 *                    (bb_equal on battery survivors: concrete shifts encode as zero-clause bit
 *                    remaps).  Subsumes the no-constant shapes (empty boxes = one candidate).
 *   THE BUDGET       a per-sample FULL multiplier (outer mul, const co-operand, an inner mixing
 *                    x and a constant) costs ~35k clauses / ~147k stream words: three fill the
 *                    UNCHANGED bv_bits envelope (the sealed 2726 pins depend on those caps), so
 *                    exactly those shapes run permanent seeds {0, 2^63} (t(0)=0 forces the
 *                    zero-divisor structure; t(2^63)=1 forces the multiplier constant ODD) plus
 *                    one sliding refinement slot (UNSAT over a sample SUBSET is still a sound
 *                    refutation); every other shape gets the full 200-sample budget.
 *   THE NATIVE SCAN  a candidate from the model is first attacked NATIVELY (mr64_eval over a
 *                    low-popcount battery) -- most counterexamples are found without a SAT call,
 *                    and the samples they add keep the next round's encoding small.
 *
 * The certificate discipline is unchanged: mr64_validate8b must equal the TOTAL width-8 oracle
 * over all 3,456 shapes for rot AND neg (0 disagreements, 0 undecided) before width 64 is
 * trusted. */
var MR64_BC : i64                /* constness of the node just built by mr64_op2/leaf builders */
var MR64_BV : u64                /* its concrete value when MR64_BC == 1 */

/* mul by a CONCRETE constant: shift-add over the bits of m (masked to the width). */
fn mr64_cmul(a: u32, m0: u64) -> u32 {
    let m : u64 = m0 & mr64_mask(MR64_W)
    if m == 0u64 { return bb_const(0u64) }
    let mut acc : u32 = 0u32
    let mut have : i64 = 0i64
    let mut j : i64 = 0i64
    while j < MR64_W {
        if ((m >> (j as u64)) & 1u64) == 1u64 {
            let t : u32 = bb_shl(a, j as u64)
            if have == 0i64 { acc = t   have = 1i64 } else { acc = bb_add(acc, t) }
        }
        j = j + 1i64
    }
    return acc
}

/* op(a,b) with structural constness (ac/av, bc/bv describe the operands); the RESULT's
 * constness/value is left in MR64_BC/MR64_BV.  Every path sets both. */
fn mr64_op2(op: i64, a: u32, ac: i64, av: u64, b: u32, bc: i64, bv: u64) -> u32 {
    if ac == 1i64 { if bc == 1i64 {
        MR64_BC = 1i64
        MR64_BV = mr64_op(op, av, bv, MR64_W)
        return bb_const(MR64_BV)
    } }
    MR64_BC = 0i64
    MR64_BV = 0u64
    if op == 0i64 { return bb_add(a, b) }
    if op == 1i64 { return bb_sub(a, b) }
    if op == 2i64 {
        if ac == 1i64 { return mr64_cmul(b, av) }
        if bc == 1i64 { return mr64_cmul(a, bv) }
        return bb_mul(a, b)
    }
    if op == 3i64 { return bb_and(a, b) }
    if op == 4i64 { return bb_or(a, b) }
    if op == 5i64 { return bb_xor(a, b) }
    /* shifts: a concrete amount is a constant shift (>= width saturates to the const-0 node --
     * the RESULT is constant even though a is variable); a variable amount is the barrel. */
    if bc == 1i64 {
        if bv >= (MR64_W as u64) { MR64_BC = 1i64   MR64_BV = 0u64   return bb_const(0u64) }
        if op == 6i64 { return bb_shl(a, bv) }
        return bb_shr(a, bv)
    }
    return mr64_bb_shift_v(op, a, b)
}

/* the omega2 SYNTH root at concrete sample xval: x -> const, c1/c2 -> bb_var(1)/(2) -- unless the
 * constant is PINNED (the hybrid box): a pinned constant is a concrete leaf, so every operation
 * on it folds or cmuls exactly like a sample. */
var MR64_PIN1 : i64 = 0i64 - 1i64      /* pin c1 to this value when >= 0 (the hybrid box) */
var MR64_PIN2 : i64 = 0i64 - 1i64
fn mr64_s2leaf(sel: i64, xval: u64) -> u32 {
    if sel == 0i64 {
        MR64_BC = 1i64
        MR64_BV = xval & mr64_mask(MR64_W)
        return bb_const(MR64_BV)
    }
    if sel == 1i64 { if MR64_PIN1 >= 0i64 {
        MR64_BC = 1i64
        MR64_BV = (MR64_PIN1 as u64) & mr64_mask(MR64_W)
        return bb_const(MR64_BV)
    } }
    if sel == 2i64 { if MR64_PIN2 >= 0i64 {
        MR64_BC = 1i64
        MR64_BV = (MR64_PIN2 as u64) & mr64_mask(MR64_W)
        return bb_const(MR64_BV)
    } }
    MR64_BC = 0i64
    MR64_BV = 0u64
    return bb_var(sel as u32)
}
fn mr64_synth2_root(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, xval: u64) -> u32 {
    let an : u32 = mr64_s2leaf(l0, xval)
    let ac : i64 = MR64_BC
    let av : u64 = MR64_BV
    let bn : u32 = mr64_s2leaf(l1, xval)
    let bc2 : i64 = MR64_BC
    let bv2 : u64 = MR64_BV
    let cn : u32 = mr64_s2leaf(l2, xval)
    let cc : i64 = MR64_BC
    let cv : u64 = MR64_BV
    if nest == 0i64 {
        let inner : u32 = mr64_op2(oa, an, ac, av, bn, bc2, bv2)
        let ic : i64 = MR64_BC
        let iv : u64 = MR64_BV
        return mr64_op2(ob, inner, ic, iv, cn, cc, cv)
    }
    let inner : u32 = mr64_op2(oa, bn, bc2, bv2, cn, cc, cv)
    let ic2 : i64 = MR64_BC
    let iv2 : u64 = MR64_BV
    return mr64_op2(ob, an, ac, av, inner, ic2, iv2)
}

/* the omega2 VERIFY root at concrete constants: x -> bb_var(0), c1/c2 -> const */
fn mr64_v2leaf(sel: i64, c1: u64, c2: u64) -> u32 {
    if sel == 0i64 {
        MR64_BC = 0i64
        MR64_BV = 0u64
        return bb_var(0u32)
    }
    MR64_BC = 1i64
    if sel == 1i64 { MR64_BV = c1 & mr64_mask(MR64_W) } else { MR64_BV = c2 & mr64_mask(MR64_W) }
    return bb_const(MR64_BV)
}
fn mr64_verify2(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, c1: u64, c2: u64, k: i64) -> i64 {
    bb_reset(MR64_W as u64)
    let an : u32 = mr64_v2leaf(l0, c1, c2)
    let ac : i64 = MR64_BC
    let av : u64 = MR64_BV
    let bn : u32 = mr64_v2leaf(l1, c1, c2)
    let bc2 : i64 = MR64_BC
    let bv2 : u64 = MR64_BV
    let cn : u32 = mr64_v2leaf(l2, c1, c2)
    let cc : i64 = MR64_BC
    let cv : u64 = MR64_BV
    let mut root : u32 = 0u32
    if nest == 0i64 {
        let inner : u32 = mr64_op2(oa, an, ac, av, bn, bc2, bv2)
        let ic : i64 = MR64_BC
        let iv : u64 = MR64_BV
        root = mr64_op2(ob, inner, ic, iv, cn, cc, cv)
    } else {
        let inner : u32 = mr64_op2(oa, bn, bc2, bv2, cn, cc, cv)
        let ic2 : i64 = MR64_BC
        let iv2 : u64 = MR64_BV
        root = mr64_op2(ob, an, ac, av, inner, ic2, iv2)
    }
    let tgt : u32 = mr64_target_node(k)
    let v : u8 = bb_equal(root, tgt)
    if v == 1u8 { return 1i64 }
    if v == 0u8 { MR64_CEX = bb_witness(0u32)   return 0i64 }
    return 0i64 - 1i64
}

/* ---- SHARING: build the x-independent INNER once per round (per bb_reset).  Both its leaves
 * are constants, which in the SYNTH phase are bb_vars -- so the inner (e.g. c1*c2: a full
 * width-64 multiplier) would otherwise be re-emitted per sample.  The shared node carries
 * synth-constness 0 (it contains solver variables). ---- */
var MR64_SHIN : u32
var MR64_SHHAVE : i64
fn mr64_synth2_shared(nest: i64, oa: i64, l0: i64, l1: i64, l2: i64) -> i32 {
    MR64_SHHAVE = 0i64
    let mut la : i64 = l0
    let mut lb : i64 = l1
    if nest == 1i64 { la = l1   lb = l2 }
    if la == 0i64 { return 0i32 }
    if lb == 0i64 { return 0i32 }
    let an : u32 = mr64_s2leaf(la, 0u64)
    let ac : i64 = MR64_BC
    let av : u64 = MR64_BV
    let bn : u32 = mr64_s2leaf(lb, 0u64)
    MR64_SHIN = mr64_op2(oa, an, ac, av, bn, MR64_BC, MR64_BV)
    MR64_SHHAVE = 1i64
    return 0i32
}
/* the synth root using the round's shared inner when one exists */
fn mr64_synth2_root2(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, xval: u64) -> u32 {
    if MR64_SHHAVE == 0i64 { return mr64_synth2_root(nest, oa, ob, l0, l1, l2, xval) }
    let mut third : i64 = l2
    if nest == 1i64 { third = l0 }
    let tn : u32 = mr64_s2leaf(third, xval)
    let tc : i64 = MR64_BC
    let tv : u64 = MR64_BV
    if nest == 0i64 { return mr64_op2(ob, MR64_SHIN, 0i64, 0u64, tn, tc, tv) }
    return mr64_op2(ob, tn, tc, tv, MR64_SHIN, 0i64, 0u64)
}

/* the NATIVE counterexample scan: attack a concrete candidate with a low-popcount battery
 * (0..7, every 2^j, then heavier probes), ordered so the sample it contributes keeps the next
 * synth encoding SMALL.  1 = found (MR64_CEX set), 0 = battery exhausted. */
fn mr64_native_cex(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, c1: u64, c2: u64, k: i64) -> i64 {
    let mut t : i64 = 0i64
    while t < 8i64 {
        if mr64_eval(nest, oa, ob, l0, l1, l2, t as u64, c1, c2, MR64_W) != mr64_target(k, t as u64, MR64_W) {
            MR64_CEX = t as u64
            return 1i64
        }
        t = t + 1i64
    }
    let mut j : i64 = 3i64
    while j < MR64_W {
        let x : u64 = 1u64 << (j as u64)
        if mr64_eval(nest, oa, ob, l0, l1, l2, x, c1, c2, MR64_W) != mr64_target(k, x, MR64_W) {
            MR64_CEX = x
            return 1i64
        }
        j = j + 1i64
    }
    j = 1i64
    while j < MR64_W {
        let x2 : u64 = (1u64 << (j as u64)) + 1u64
        if mr64_eval(nest, oa, ob, l0, l1, l2, x2, c1, c2, MR64_W) != mr64_target(k, x2, MR64_W) {
            MR64_CEX = x2
            return 1i64
        }
        j = j + 1i64
    }
    let m : u64 = mr64_mask(MR64_W)
    if mr64_eval(nest, oa, ob, l0, l1, l2, m, c1, c2, MR64_W) != mr64_target(k, m, MR64_W) { MR64_CEX = m   return 1i64 }
    let am : u64 = 0xAAAAAAAAAAAAAAAAu64 & m
    if mr64_eval(nest, oa, ob, l0, l1, l2, am, c1, c2, MR64_W) != mr64_target(k, am, MR64_W) { MR64_CEX = am   return 1i64 }
    let fm : u64 = 0x5555555555555555u64 & m
    if mr64_eval(nest, oa, ob, l0, l1, l2, fm, c1, c2, MR64_W) != mr64_target(k, fm, MR64_W) { MR64_CEX = fm   return 1i64 }
    return 0i64
}

/* the omega2 CEGIS: sharing + the per-sample-multiplier budget (psmul shapes: seeds {0,1,2^63},
 * cap 5, sliding window; others: the full budget), native-scan-first refinement.
 * 1 = REFUTED, 0 = MATCH, -1 = undecided. */
fn mr64_cegis2(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, k: i64, psmul: i64) -> i64 {
    let mut cap : i64 = 200i64
    if psmul == 1i64 {
        /* seeds {0, 2^(w-1)} are permanent (t(0) = 0 forces the zero-divisor structure;
         * t(2^(w-1)) = 1 forces the multiplier constant ODD -- and the top-bit seed MUST be
         * width-relative: a fixed 2^63 masks to 0 at width 8 and collapses the window); slot 2
         * starts at 1 and is the sliding refinement slot.  cap 3 = three full multipliers, the
         * proven-feasible envelope of the UNCHANGED bv_bits caps (the sealed 2726 pins depend on
         * those caps: they must not move). */
        MR64_SAMP[0u64] = 0u64   MR64_SAMP[1u64] = 1u64 << ((MR64_W - 1i64) as u64)   MR64_SAMP[2u64] = 1u64
        MR64_NSAMP = 3i64
        cap = 3i64
    } else {
        MR64_SAMP[0u64] = 1u64   MR64_SAMP[1u64] = 2u64   MR64_SAMP[2u64] = 3u64   MR64_SAMP[3u64] = 0u64
        MR64_NSAMP = 4i64
    }
    let mut xfree : i64 = 1i64
    if l0 == 0i64 { xfree = 0i64 }
    if l1 == 0i64 { xfree = 0i64 }
    if l2 == 0i64 { xfree = 0i64 }
    let mut rounds : i64 = 0i64
    while rounds < 96i64 {
        bb_reset(MR64_W as u64)
        mr64_synth2_shared(nest, oa, l0, l1, l2)
        /* an x-free shape's ROOT is x-independent: build it once; the mismatch OR over two
         * distinct targets then forces root == t_i for BOTH -- UNSAT by propagation alone */
        let mut shroot : u32 = 0u32
        let mut havesh : i64 = 0i64
        if xfree == 1i64 { shroot = mr64_synth2_root2(nest, oa, ob, l0, l1, l2, 0u64)   havesh = 1i64 }
        let mut mnode : u32 = 0u32
        let mut havem : i64 = 0i64
        let mut i : i64 = 0i64
        while i < MR64_NSAMP {
            let mut r : u32 = shroot
            if havesh == 0i64 { r = mr64_synth2_root2(nest, oa, ob, l0, l1, l2, MR64_SAMP[i as u64]) }
            let d : u32 = bb_xor(r, bb_const(mr64_target(k, MR64_SAMP[i as u64], MR64_W)))
            if havem == 0i64 { mnode = d   havem = 1i64 } else { mnode = bb_or(mnode, d) }
            i = i + 1i64
        }
        let sv : u8 = bb_solve_zero(mnode)
        if sv == 0xFFu8 { return 0i64 - 1i64 }
        if sv == 1u8 { return 1i64 }                        /* UNSAT: REFUTED */
        let mut c1c : u64 = 0u64
        let mut c2c : u64 = 0u64
        if MR64_PIN1 >= 0i64 { c1c = MR64_PIN1 as u64 }
        else { if MR64_C1DAT == 1i64 { c1c = bb_witness(1u32) } }
        if MR64_PIN2 >= 0i64 { c2c = MR64_PIN2 as u64 }
        else { if MR64_C2DAT == 1i64 { c2c = bb_witness(2u32) } }
        /* native scan first; the full bb verify only when the battery is silent */
        let mut cex : i64 = mr64_native_cex(nest, oa, ob, l0, l1, l2, c1c, c2c, k)
        if cex == 0i64 {
            let vc : i64 = mr64_verify2(nest, oa, ob, l0, l1, l2, c1c, c2c, k)
            if vc == 1i64 { MR64_OW1 = c1c as i64   MR64_OW2 = c2c as i64   return 0i64 }   /* MATCH */
            if vc < 0i64 { return 0i64 - 1i64 }
            cex = 1i64
        }
        /* fold the counterexample in (dup impossible: the model satisfied every sample) */
        if MR64_NSAMP < cap {
            MR64_SAMP[MR64_NSAMP as u64] = MR64_CEX
            MR64_NSAMP = MR64_NSAMP + 1i64
        } else {
            /* sliding window: overwrite the oldest refinement slot (the seeds stay) */
            let mut base : i64 = 3i64
            if psmul == 1i64 { base = 2i64 }
            MR64_SAMP[(base + (rounds % (cap - base))) as u64] = MR64_CEX
        }
        rounds = rounds + 1i64
    }
    return 0i64 - 1i64
}

/* THE SHIFT-BOX EXHAUSTION: when every constant occurrence sits in a shift-AMOUNT slot, the
 * live box is {0..w} per constant (every amount >= w saturates to the SAME const-0 program --
 * the SVIR shift law), so the WHOLE candidate space is <= (w+1)^2 representatives: decide by
 * total exhaustion, natively (battery), with bb_equal on survivors (concrete shift amounts
 * encode as pure bit remaps -- zero clauses).  Sound AND complete; subsumes the no-constant
 * shapes (an absent constant's box is {0}).  1 = REFUTED, 0 = MATCH, -1 = poison. */
fn mr64_shiftbox(nest: i64, oa: i64, ob: i64, l0: i64, l1: i64, l2: i64, k: i64) -> i64 {
    let mut c1hi : i64 = 0i64
    if MR64_C1DAT == 1i64 { c1hi = MR64_W }
    let mut c2hi : i64 = 0i64
    if MR64_C2DAT == 1i64 { c2hi = MR64_W }
    let mut c1 : i64 = 0i64
    while c1 <= c1hi {
        let mut c2 : i64 = 0i64
        while c2 <= c2hi {
            let cex : i64 = mr64_native_cex(nest, oa, ob, l0, l1, l2, c1 as u64, c2 as u64, k)
            if cex == 0i64 {
                let vc : i64 = mr64_verify2(nest, oa, ob, l0, l1, l2, c1 as u64, c2 as u64, k)
                if vc == 1i64 { MR64_OW1 = c1   MR64_OW2 = c2   return 0i64 }
                if vc < 0i64 { return 0i64 - 1i64 }
            }
            c2 = c2 + 1i64
        }
        c1 = c1 + 1i64
    }
    return 1i64
}

/* decide ONE shape with the omega2 engine: shift-amount-only constants -> the box exhaustion;
 * everything else -> CEGIS with the sharing + per-sample-multiplier budget. */
fn mr64_omega2_decide(sid: i64, k: i64) -> i64 @export {
    let nest : i64 = sid / 1728i64
    let mut r : i64 = sid % 1728i64
    let oa : i64 = r / 216i64
    r = r % 216i64
    let ob : i64 = r / 27i64
    r = r % 27i64
    let l0 : i64 = r / 9i64
    let l1 : i64 = (r / 3i64) % 3i64
    let l2 : i64 = r % 3i64
    mr64_const_roles(nest, oa, ob, l0, l1, l2)
    /* every constant occurrence in a shift-amount slot?  (nest 0: l1 under oa, l2 under ob;
     * nest 1: l2 under oa.  l0 is always a data slot; nest 1's l1 likewise; a shift whose
     * amount is the INNER expression is the barrel case, not a constant slot.) */
    let mut shonly : i64 = 1i64
    if l0 != 0i64 { shonly = 0i64 }
    if nest == 0i64 {
        if l1 != 0i64 { if oa != 6i64 { if oa != 7i64 { shonly = 0i64 } } }
        if l2 != 0i64 { if ob != 6i64 { if ob != 7i64 { shonly = 0i64 } } }
    } else {
        if l1 != 0i64 { shonly = 0i64 }
        if l2 != 0i64 { if oa != 6i64 { if oa != 7i64 { shonly = 0i64 } } }
    }
    if shonly == 1i64 { return mr64_shiftbox(nest, oa, ob, l0, l1, l2, k) }
    /* THE HYBRID BOX -- the shift/multiply coupling: one constant is a shift AMOUNT (live box
     * {0..w}: >= w saturates) in a shape that ALSO multiplies, so the plain CEGIS meets a barrel
     * shifter TIMES a full multiplier per sample.  Pinning the amount constant to each box value
     * makes every multiplier operand concrete (fold / cmul) or x-free (shared): the sub-question
     * per pin is a cheap one-constant CEGIS.  The >= w tail is the constant-0 function -- the
     * saturated operand feeds an absorbing op (0*y = 0) or the saturation IS the outer op -- so
     * the w representative covers the whole tail, data occurrences of the pinned constant
     * included (they are annihilated).  Cases:
     *   A' (nest 0)  E = (l0 * l1) >> c_a   (outer shift amount, mul inner)
     *   B  (nest 0)  E = (l0 << c_a) * l2   (inner shift amount, outer mul, const co-operand)
     *   B' (nest 1)  E = l0 * (l1 << c_a)   (mirrored; l0 = x is a cmul, no hybrid needed) */
    let mut hyb : i64 = 0i64
    if nest == 0i64 {
        if oa == 2i64 { if l2 != 0i64 { if ob == 6i64 { hyb = l2 }   if ob == 7i64 { hyb = l2 } } }
        if hyb == 0i64 { if ob == 2i64 { if l2 != 0i64 { if l1 != 0i64 {
            if oa == 6i64 { hyb = l1 }
            if oa == 7i64 { hyb = l1 }
        } } } }
    } else {
        if ob == 2i64 { if l0 != 0i64 { if l2 != 0i64 {
            if oa == 6i64 { hyb = l2 }
            if oa == 7i64 { hyb = l2 }
        } } }
    }
    if hyb != 0i64 {
        let mut anyund : i64 = 0i64
        let mut v : i64 = 0i64
        while v <= MR64_W {
            if hyb == 1i64 { MR64_PIN1 = v } else { MR64_PIN2 = v }
            let rc : i64 = mr64_cegis2(nest, oa, ob, l0, l1, l2, k, 0i64)
            MR64_PIN1 = 0i64 - 1i64
            MR64_PIN2 = 0i64 - 1i64
            if rc == 0i64 { return 0i64 }          /* MATCH (witness in MR64_OW1/OW2) */
            if rc < 0i64 { anyund = 1i64 }
            v = v + 1i64
        }
        if anyund == 1i64 { return 0i64 - 1i64 }
        return 1i64
    }
    /* the budget class: an outer MUL whose co-operand is a constant and whose inner MIXES x and
     * a constant emits one FULL multiplier per sample -- everything else's muls fold (all-x
     * inner: a per-sample constant, so the outer mul is a cmul), cmul (concrete co-operand), or
     * share (x-free inner: built once per round) */
    let mut ia : i64 = l0
    let mut ib : i64 = l1
    if nest == 1i64 { ia = l1   ib = l2 }
    let mut innerhasx : i64 = 0i64
    if ia == 0i64 { innerhasx = 1i64 }
    if ib == 0i64 { innerhasx = 1i64 }
    let mut innerallx : i64 = 0i64
    if ia == 0i64 { if ib == 0i64 { innerallx = 1i64 } }
    let mut third : i64 = l2
    if nest == 1i64 { third = l0 }
    let mut psmul : i64 = 0i64
    if ob == 2i64 { if third != 0i64 { if innerhasx == 1i64 { if innerallx == 0i64 { psmul = 1i64 } } } }
    return mr64_cegis2(nest, oa, ob, l0, l1, l2, k, psmul)
}
var MR64_O2DEC : i64
var MR64_O2UND : i64
var MR64_O2MATCH : i64
var MR64_UNDS : [i64; 256]       /* the undecided sids, recorded (a refusal keeps its coordinates) */
var MR64_UNDN : i64
fn mr64_o2dec() -> i64 @export { return MR64_O2DEC }
fn mr64_o2und() -> i64 @export { return MR64_O2UND }
fn mr64_o2match() -> i64 @export { return MR64_O2MATCH }
fn mr64_undn() -> i64 @export { return MR64_UNDN }
fn mr64_undat(i: i64) -> i64 @export {
    if i < 0i64 { return 0i64 - 1i64 }
    if i >= MR64_UNDN { return 0i64 - 1i64 }
    return MR64_UNDS[i as u64]
}
fn mr64_o2rec(sid: i64) -> i32 {
    if MR64_UNDN < 256i64 { MR64_UNDS[MR64_UNDN as u64] = sid   MR64_UNDN = MR64_UNDN + 1i64 }
    MR64_O2UND = MR64_O2UND + 1i64
    return 0i32
}
/* the FULL width-64 omega2 sweep */
fn mr64_omega2(k: i64) -> i64 @export {
    MR64_W = 64i64
    MR64_O2DEC = 0i64
    MR64_O2UND = 0i64
    MR64_O2MATCH = 0i64
    MR64_UNDN = 0i64
    let mut refuted : i64 = 0i64
    let mut sid : i64 = 0i64
    while sid < 3456i64 {
        let v : i64 = mr64_omega2_decide(sid, k)
        if v == 1i64 { MR64_O2DEC = MR64_O2DEC + 1i64   refuted = refuted + 1i64 }
        else { if v == 0i64 { MR64_O2DEC = MR64_O2DEC + 1i64   MR64_O2MATCH = MR64_O2MATCH + 1i64 } else { mr64_o2rec(sid) } }
        sid = sid + 1i64
    }
    return refuted
}
/* ---- Omega-3: THE UNIVERSAL RANGE DOOR -- the full-settlement sweep for EVERY k in
 * [klo..khi], accumulated.  Returns the refuted total; undecided/match totals are separate
 * counters, never averaged away.  62 sweeps at ~1 min each lift cost64(rot_k) = 3 from the
 * settled k = 1 to the WHOLE rotation family. ---- */
var MR64_O3REF : i64
var MR64_O3UND : i64
var MR64_O3MATCH : i64
fn mr64_o3ref() -> i64 @export { return MR64_O3REF }
fn mr64_o3und() -> i64 @export { return MR64_O3UND }
fn mr64_o3match() -> i64 @export { return MR64_O3MATCH }
fn mr64_omega3(klo: i64, khi: i64) -> i64 @export {
    MR64_O3REF = 0i64
    MR64_O3UND = 0i64
    MR64_O3MATCH = 0i64
    let mut k : i64 = klo
    while k <= khi {
        let rf : i64 = mr64_omega2(k)
        MR64_O3REF = MR64_O3REF + rf
        MR64_O3UND = MR64_O3UND + MR64_O2UND
        MR64_O3MATCH = MR64_O3MATCH + MR64_O2MATCH
        k = k + 1i64
    }
    return MR64_O3REF
}

/* the omega2 width-8 validation against the total oracle (the certificate) */
var MR64_V2UND : i64
fn mr64_val2_und() -> i64 @export { return MR64_V2UND }
fn mr64_validate8b(k: i64) -> i64 @export {
    MR64_W = 8i64
    MR64_V2UND = 0i64
    let mut bad : i64 = 0i64
    let mut sid : i64 = 0i64
    while sid < 3456i64 {
        let ce : i64 = mr64_omega2_decide(sid, k)
        let br : i64 = mr64_brute_shape(sid, k, 8i64)
        if ce == 1i64 { if br != 0i64 { bad = bad + 1i64 } }
        else { if ce == 0i64 { if br != 1i64 { bad = bad + 1i64 } }
               else { MR64_V2UND = MR64_V2UND + 1i64 } }
        sid = sid + 1i64
    }
    return bad
}

/* ---- the width-8 GROUND-TRUTH ORACLE: does ANY (c1,c2) make shape sid compute target k? ---- */
fn mr64_brute_shape(sid: i64, k: i64, w: i64) -> i64 {
    let nest : i64 = sid / 1728i64
    let mut r : i64 = sid % 1728i64
    let oa : i64 = r / 216i64
    r = r % 216i64
    let ob : i64 = r / 27i64
    r = r % 27i64
    let l0 : i64 = r / 9i64
    let l1 : i64 = (r / 3i64) % 3i64
    let l2 : i64 = r % 3i64
    let m : i64 = mr64_mask(w) as i64
    let mut c1max : i64 = 0i64
    if l0 == 1i64 { c1max = m }
    if l1 == 1i64 { c1max = m }
    if l2 == 1i64 { c1max = m }
    let mut c2max : i64 = 0i64
    if l0 == 2i64 { c2max = m }
    if l1 == 2i64 { c2max = m }
    if l2 == 2i64 { c2max = m }
    let mut c1 : i64 = 0i64
    while c1 <= c1max {
        let mut c2 : i64 = 0i64
        while c2 <= c2max {
            if mr64_full(nest, oa, ob, l0, l1, l2, c1 as u64, c2 as u64, k, w) == 1i64 { return 1i64 }
            c2 = c2 + 1i64
        }
        c1 = c1 + 1i64
    }
    return 0i64
}
/* THE VALIDATION at width 8: CEGIS verdict must equal the total oracle for EVERY shape, for rot
 * AND neg.  Returns the number of DISAGREEMENTS (0 = the engine is sound+complete at width 8);
 * mr64_val_und() = shapes CEGIS left undecided at width 8 (must also be 0). */
var MR64_VUND : i64
fn mr64_val_und() -> i64 @export { return MR64_VUND }
fn mr64_validate8(k: i64) -> i64 @export {
    MR64_W = 8i64
    MR64_VUND = 0i64
    let mut bad : i64 = 0i64
    let mut sid : i64 = 0i64
    while sid < 3456i64 {
        let ce : i64 = mr64_omega_decide(sid, k)
        let br : i64 = mr64_brute_shape(sid, k, 8i64)   /* 1 = has a solution, 0 = none */
        if ce == 1i64 { if br != 0i64 { bad = bad + 1i64 } }         /* refuted but a solution exists */
        else { if ce == 0i64 { if br != 1i64 { bad = bad + 1i64 } }  /* matched but no solution exists */
               else { MR64_VUND = MR64_VUND + 1i64 } }               /* undecided at width 8 */
        sid = sid + 1i64
    }
    return bad
}
