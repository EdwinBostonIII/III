/* STDLIB/iii/aether/oikos.iii -- OIKOS: the hearth.
 *
 * Until now the house's standing knowledge died with its process: every
 * invocation of the tongue began newborn.  OIKOS is the hearth -- the
 * logos's standing house PERSISTED as a self-verifying file, RE-STOOD at
 * every invocation, and GROWN only through the guarded union.
 *
 * WHAT THIS ORGAN IS -- AND IS NOT.  The hearth keeps the FIRE, never the
 * TRUTH.  The standing house itself -- the canonical text, its address,
 * its claim geography, and EVERY judgment against it (the union of growth,
 * the minimal-basis refounding, the answer to any question) -- lives in
 * the logos (omnia/eidolos: eol_keep / eol_restand / eol_union_with /
 * eol_reduce, THE ONE BAROMETER).  This organ holds no copy of the canon,
 * parses no claim text, and judges nothing: it carries the logos's truth
 * ACROSS TIME (the file), and it runs the household protocol (door, union,
 * persist).  A hearth that kept its own scroll and its own judgment was
 * definitionally a second logos, and the system split; this one defers.
 *
 *   THE HEARTH LAW:
 *   1  The house file is `<address>\n<canonical scroll>`; standing it
 *      RE-DERIVES the address from the text (tamper = the WHOLE house
 *      refuses -- the guest-book discipline, applied to knowledge) and
 *      seals the proven scroll as the logos's KEPT HOUSE.
 *   2  An absent file is BIRTH, not error: the house stands empty.
 *   3  Growth is UNION-JUDGED by the logos: the guest's claims are read
 *      side by side with the whole kept house and the LAW checks the
 *      union (eol_union_with).  A guest coherent alone but cycling
 *      against the house is REFUSED (CLASH), the house re-stands whole,
 *      and the file is untouched: ACCUMULATION CAN NEVER MAKE THE HOUSE
 *      CONTRADICT ITSELF.
 *   4  The door still judges the stranger ALONE (xn_admit books the
 *      knock); the logos judges the UNION.  Two named jurisdictions --
 *      the door's law is not forked, and neither is the barometer's.
 *   5  Writes happen only inside the house (xn_rooted, the book's gate);
 *      the canonical envelope is 16384 bytes -- a house grown past its
 *      throat refuses WHOLE and names it (the capacity law: sized for
 *      the boundary, stated, never silent).
 *
 * Every face is PATH-EXPLICIT (no hidden default file): the CLI dwells in
 * STDLIB/data/oikos.eol; the self-proof dwells in a build-territory test
 * hearth and NEVER touches the real house.
 *
 * Truth is a CONDITION OF MOTION: ok_selfprove (arms 410..420) re-derives
 * every law above at every invocation.  NO gate, NO KAT (the kardia
 * pattern).  NIH: composes omnia/eidolos (the one barometer and its kept
 * house), aether/anglos (the tongue's transduction and questions),
 * aether/xenos (the one door and the rooted probe), msvcrt file faces.
 * Hexad: kind_passage.  Ring R0. */
module aether_oikos

extern @abi(c-msvc-x64) fn eol_reset() -> i32 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_read(addr: u64, len: u64) -> i64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_lawcheck() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_addr() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_claims() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_entails(a: u64, al: u64, v: u64, b: u64, bl: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_keep() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_kept_len() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_kept_byte(i: u64) -> u8 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_restand() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_union_with(base: u64, len: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_reduce() -> u64 from "eidolos.iii"

extern @abi(c-msvc-x64) fn an_transduce(base: u64, len: u64) -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_claims() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_questions() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_ask(i: u64) -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_scroll_len() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_scroll_byte(i: u64) -> u8 from "anglos.iii"

extern @abi(c-msvc-x64) fn xn_admit(base: u64, len: u64) -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_canon_len() -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_canon_byte(i: u64) -> u8 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_rooted() -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_grade() -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_reason() -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_last_addr() -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_emit_env() -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_env_len() -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_env_byte(i: u64) -> u8 from "xenos.iii"

extern @abi(c-msvc-x64) fn xr_reset() -> i32 from "xring.iii"
extern @abi(c-msvc-x64) fn xr_push(base: u64, len: u64) -> u64 from "xring.iii"
extern @abi(c-msvc-x64) fn xr_pull() -> u64 from "xring.iii"
extern @abi(c-msvc-x64) fn xr_frame_base() -> u64 from "xring.iii"
extern @abi(c-msvc-x64) fn xr_frame_len() -> u64 from "xring.iii"
extern @abi(c-msvc-x64) fn xr_advance() -> i32 from "xring.iii"

extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fread(buf: u64, sz: u64, n: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fwrite(buf: u64, sz: u64, n: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(stream: u64) -> i32 from "msvcrt"

/* stand verdicts */
const OK_S_STOOD : u64 = 1u64
const OK_S_BIRTH : u64 = 0u64
const OK_S_REFUSED : u64 = 2u64
/* dwell verdicts */
const OK_D_DWELT : u64 = 1u64
const OK_D_REFUSED : u64 = 2u64
const OK_D_UNHEARD : u64 = 3u64
/* named refusal reasons */
const OK_R_NONE : u64 = 0u64
const OK_R_TAMPER : u64 = 1u64           /* the file's address does not re-derive */
const OK_R_CLASH : u64 = 2u64            /* the union breaks the law            */
const OK_R_THROAT : u64 = 3u64           /* the house past its envelope         */
const OK_R_SURFACE : u64 = 4u64          /* the tongue refused the utterance    */
const OK_R_DOOR : u64 = 5u64             /* the door refused the guest          */
const OK_R_ROOT : u64 = 6u64             /* not inside the house: no write      */

const OK_SENT : u64 = 18446744073709551615u64

/* ==================== the hearth's state ====================
 * File image and envelope hold only -- the standing house itself lives in
 * the logos (the kept house), never here. */
var OK_FB : [u8; 16420]                  /* file read/write + guest scratch     */
var OK_ADDR : u64 = 0u64                 /* the last proven stand's address     */
var OK_VERDICT : u64 = 0u64
var OK_REASON : u64 = 0u64
var OK_RC : [u64; 7]                     /* refusals by name                    */

fn ok_refused(r: u64) -> u64 @export { if r < 7u64 { return OK_RC[r] }   return 0u64 }
fn ok_addr() -> u64 @export { return OK_ADDR }
fn ok_verdict() -> u64 @export { return OK_VERDICT }
fn ok_reason() -> u64 @export { return OK_REASON }
/* the standing knowledge, read straight from the logos's kept house */
fn ok_claims_len() -> u64 @export { return eol_kept_len() }
fn ok_claims_byte(i: u64) -> u8 @export { return eol_kept_byte(i) }

fn ok_fail(r: u64) -> u64 {
    OK_REASON = r
    if r < 7u64 { OK_RC[r] = OK_RC[r] + 1u64 }
    return r
}

/* ==================== THE STANDING ====================
 * Read the house file, verify its address against its own text, and seal
 * the proven scroll as the logos's KEPT HOUSE (left standing).  1 stood |
 * 0 birth (absent or empty: the house stands and keeps EMPTY) | 2 refused
 * (tamper: nothing stands, the kept house is empty). */
fn ok_stand(path: u64) -> u64 @export {
    OK_REASON = OK_R_NONE
    OK_ADDR = 0u64
    /* the hearth stands EMPTY until the file proves otherwise */
    eol_reset()
    eol_keep()
    let f : u64 = fopen(path, "rb" as u64)
    if f == 0u64 { return OK_S_BIRTH }
    let n : u64 = fread((&OK_FB) as u64, 1u64, 16420u64, f)
    fclose(f)
    if n == 0u64 { return OK_S_BIRTH }
    if n > 16406u64 { ok_fail(OK_R_TAMPER)   return OK_S_REFUSED }
    /* parse "<addr>\n" */
    let mut a : u64 = 0u64
    let mut i : u64 = 0u64
    let mut nd : u64 = 0u64
    let mut going : u64 = 1u64
    while going == 1u64 {
        if i >= n { going = 0u64 } else {
            let c : u8 = OK_FB[i]
            if c == 10u8 { going = 0u64 } else {
                if c < 48u8 { ok_fail(OK_R_TAMPER)   return OK_S_REFUSED }
                if c > 57u8 { ok_fail(OK_R_TAMPER)   return OK_S_REFUSED }
                a = (a * 10u64) + ((c - 48u8) as u64)
                nd = nd + 1u64
                i = i + 1u64
            }
        }
    }
    if nd == 0u64 { ok_fail(OK_R_TAMPER)   return OK_S_REFUSED }
    if i >= n { ok_fail(OK_R_TAMPER)   return OK_S_REFUSED }
    let cb : u64 = i + 1u64
    let cn : u64 = n - cb
    if cn == 0u64 { ok_fail(OK_R_TAMPER)   return OK_S_REFUSED }
    if cn > 16384u64 { ok_fail(OK_R_TAMPER)   return OK_S_REFUSED }
    /* the address must RE-DERIVE from the text (the whole house or none) */
    if eol_read(((&OK_FB) as u64) + cb, cn) < 0i64 { eol_reset()   eol_keep()   ok_fail(OK_R_TAMPER)   return OK_S_REFUSED }
    if eol_lawcheck() != 0u64 { eol_reset()   eol_keep()   ok_fail(OK_R_TAMPER)   return OK_S_REFUSED }
    if eol_addr() != a { eol_reset()   eol_keep()   ok_fail(OK_R_TAMPER)   return OK_S_REFUSED }
    /* proven: seal it as the kept house */
    if eol_keep() != a { eol_reset()   eol_keep()   ok_fail(OK_R_TAMPER)   return OK_S_REFUSED }
    OK_ADDR = a
    return OK_S_STOOD
}

/* persist the CURRENT standing scroll as the house file (rooted only):
 * the logos keeps it, the hearth writes it */
fn ok_persist(path: u64) -> u64 {
    if xn_rooted() != 1u64 { return ok_fail(OK_R_ROOT) }
    let a : u64 = eol_keep()
    if a == 0u64 { return ok_fail(OK_R_CLASH) }
    let cn : u64 = eol_kept_len()
    if cn == 0u64 { return ok_fail(OK_R_CLASH) }
    if cn > 16384u64 { return ok_fail(OK_R_THROAT) }
    /* image: digits(addr) \n canon */
    let mut m : u64 = 0u64
    let mut div : u64 = 1u64
    let mut t : u64 = a
    while t >= 10u64 { div = div * 10u64   t = t / 10u64 }
    t = a
    let mut going : u64 = 1u64
    while going == 1u64 {
        OK_FB[m] = (48u64 + (t / div)) as u8
        m = m + 1u64
        t = t % div
        if div == 1u64 { going = 0u64 } else { div = div / 10u64 }
    }
    OK_FB[m] = 10u8
    m = m + 1u64
    let mut k : u64 = 0u64
    while k < cn { OK_FB[m + k] = eol_kept_byte(k)   k = k + 1u64 }
    m = m + cn
    let f : u64 = fopen(path, "wb" as u64)
    if f == 0u64 { return ok_fail(OK_R_ROOT) }
    fwrite((&OK_FB) as u64, 1u64, m, f)
    fclose(f)
    OK_ADDR = a
    return 0u64
}

/* ==================== THE DWELLING ====================
 * One utterance JOINS the household: transduced by the tongue, the guest
 * judged ALONE at the one door (booked), the UNION with the whole kept
 * house judged by the logos, persisted only if lawful, and every question
 * answered over the HOUSE.  1 dwelt | 2 refused (ok_reason names it) |
 * 3 unheard. */
fn ok_dwell(path: u64, base: u64, len: u64) -> u64 @export {
    OK_VERDICT = 0u64
    OK_REASON = OK_R_NONE
    let sv : u64 = ok_stand(path)
    if sv == OK_S_REFUSED { OK_VERDICT = OK_D_REFUSED   return OK_D_REFUSED }
    let t : u64 = an_transduce(base, len)
    if t == 3u64 { OK_VERDICT = OK_D_UNHEARD   return OK_D_UNHEARD }
    if t != 4u64 { ok_fail(OK_R_SURFACE)   OK_VERDICT = OK_D_REFUSED   return OK_D_REFUSED }
    if an_claims() > 0u64 {
        /* the guest's own scroll must survive the door alone (booked) */
        let mut i : u64 = 0u64
        let sn : u64 = an_scroll_len()
        while i < sn { OK_FB[i] = an_scroll_byte(i)   i = i + 1u64 }
        if xn_admit((&OK_FB) as u64, sn) != 1u64 { ok_fail(OK_R_DOOR)   OK_VERDICT = OK_D_REFUSED   return OK_D_REFUSED }
        /* the logos judges the UNION: guest canon beside the whole house */
        let gn : u64 = xn_canon_len()
        i = 0u64
        while i < gn { OK_FB[i] = xn_canon_byte(i)   i = i + 1u64 }
        let uv : u64 = eol_union_with((&OK_FB) as u64, gn)
        if uv == 1u64 { ok_fail(OK_R_CLASH)   OK_VERDICT = OK_D_REFUSED   return OK_D_REFUSED }
        if uv != 0u64 {
            /* CLASH: the union breaks the law; the house re-stands whole
             * (the guest was booked at the door -- the knock happened; the
             * household refused the marriage) */
            ok_fail(OK_R_CLASH)
            eol_restand()
            OK_VERDICT = OK_D_REFUSED
            return OK_D_REFUSED
        }
        let pr : u64 = ok_persist(path)
        if pr != 0u64 { OK_VERDICT = OK_D_REFUSED   return OK_D_REFUSED }
    }
    /* the questions are the household's to answer (over the union) */
    let q : u64 = an_questions()
    let mut k : u64 = 0u64
    while k < q { an_ask(k)   k = k + 1u64 }
    OK_VERDICT = OK_D_DWELT
    return OK_D_DWELT
}
fn ok_slen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut n : u64 = 0u64
    while p[n] != 0u8 { n = n + 1u64 }
    return n
}
fn ok_dwell_text(path: u64, s: u64) -> u64 @export { return ok_dwell(path, s, ok_slen(s)) }
/* erase a hearth (rooted only; the self-proof's test hearth, or a fresh start) */
fn ok_erase(path: u64) -> u64 @export {
    if xn_rooted() != 1u64 { return ok_fail(OK_R_ROOT) }
    let f : u64 = fopen(path, "wb" as u64)
    if f == 0u64 { return ok_fail(OK_R_ROOT) }
    fclose(f)
    return 0u64
}

/* ==================== THE COMPACTION ====================
 * A house accumulates stated claims whose content the unraveling already
 * carries.  The REFOUNDING is the logos's own judgment (eol_reduce: drop
 * every claim the remainder still derives, greedy in canonical order, the
 * closure preserved EXACTLY, idempotent); the hearth only persists the
 * refounded basis.  The address changes -- the house's identity follows
 * its stated basis -- and a house at its throat refuses only when its
 * IRREDUCIBLE knowledge exceeds the envelope: capacity binds on truth,
 * not on redundancy. */
fn ok_compact(path: u64) -> u64 @export {
    OK_REASON = OK_R_NONE
    let sv : u64 = ok_stand(path)
    if sv == OK_S_BIRTH { OK_VERDICT = OK_D_DWELT   return OK_D_DWELT }
    if sv != OK_S_STOOD { OK_VERDICT = OK_D_REFUSED   return OK_D_REFUSED }
    let d : u64 = eol_reduce()
    if d == OK_SENT { ok_fail(OK_R_CLASH)   OK_VERDICT = OK_D_REFUSED   return OK_D_REFUSED }
    if d == 0u64 {
        /* already a minimal basis: identity preserved, nothing rewritten */
        OK_VERDICT = OK_D_DWELT
        return OK_D_DWELT
    }
    let pr : u64 = ok_persist(path)
    if pr != 0u64 { OK_VERDICT = OK_D_REFUSED   return OK_D_REFUSED }
    OK_VERDICT = OK_D_DWELT
    return OK_D_DWELT
}

/* ==================== THE PRESBEIA: two houses speak ====================
 * xenos's deepest promise -- "so two houses' doors can speak to each other
 * and verify every word" -- realized as the union judgment ACROSS HOUSES
 * (the oikos law lifted from across-time to across-boundary).  A house
 * EMITS its knowledge as the CONFORMING envelope (the same door out, axiom
 * riding as the handshake); a foreign house RECEIVES it -- the envelope
 * admitted through the one door (a foreign SOUL, a different III's axiom,
 * REFUSED at the door), then the foreign claims union-judged by the logos
 * against the receiver's OWN kept house:
 *     CONCORD  the union is lawful -- the two houses agree, and the
 *              receiver now KNOWS what the foreigner said (verifiable claim
 *              by claim through its own entailment)
 *     DISCORD  the union breaks the law -- a contradiction between the
 *              houses, NAMED, and the receiver's house UNTOUCHED
 * The receiver never MERGES the foreigner into its file (diplomacy is not
 * annexation); it VERIFIES.  The envelope crosses the bare-metal vein, so
 * the exchange is transport-transparent (a house across the wire is
 * verified identically to one across the room). */
const OK_C_CONCORD : u64 = 1u64
const OK_C_DISCORD : u64 = 2u64
const OK_C_SOUL    : u64 = 3u64          /* a foreign axiom -- a different III */
const OK_C_BROKEN  : u64 = 4u64          /* the envelope would not admit       */
var OK_ENV : [u8; 20480]                 /* the emitted/received envelope       */
var OK_ENVN : u64 = 0u64
var OK_FADDR : u64 = 0u64                /* the foreign house's address         */
fn ok_env_len() -> u64 @export { return OK_ENVN }
fn ok_env_byte(i: u64) -> u8 @export { if i < OK_ENVN { return OK_ENV[i] }   return 0u8 }
fn ok_foreign_addr() -> u64 @export { return OK_FADDR }

/* EMIT: stand the house at `path` and render its CONFORMING envelope into
 * OK_ENV.  Returns the envelope length, or 0 (empty/absent house, or the
 * scroll would not round-trip). */
fn ok_emit(path: u64) -> u64 @export {
    OK_ENVN = 0u64
    let sv : u64 = ok_stand(path)
    if sv != OK_S_STOOD { return 0u64 }
    let ea : u64 = xn_emit_env()
    if ea == 0u64 { return 0u64 }
    let n : u64 = xn_env_len()
    if n == 0u64 { return 0u64 }
    if n > 20480u64 { return 0u64 }
    let mut i : u64 = 0u64
    while i < n { OK_ENV[i] = xn_env_byte(i)   i = i + 1u64 }
    OK_ENVN = n
    return n
}
/* RECEIVE: my house stands at `path`; the foreign envelope is admitted at
 * the door (CONFORMING or a foreign SOUL refused), then union-judged by
 * the logos against my kept house.  1 concord | 2 discord | 3 soul |
 * 4 broken. */
fn ok_receive(path: u64, env: u64, envlen: u64) -> u64 @export {
    OK_FADDR = 0u64
    /* my own standing knowledge, sealed as the kept house (admit will
     * reset the transient scroll; the kept house survives it) */
    let sv : u64 = ok_stand(path)
    if sv == OK_S_REFUSED { return OK_C_BROKEN }
    /* the envelope at the one door: a foreign axiom is a different soul */
    let v : u64 = xn_admit(env, envlen)
    if v != 1u64 {
        if xn_reason() == 4u64 { return OK_C_SOUL }
        return OK_C_BROKEN
    }
    if xn_grade() != 2u64 { return OK_C_BROKEN }   /* must be CONFORMING     */
    OK_FADDR = xn_last_addr()
    /* the foreign claims (the admitted canon) union-judged with my house */
    let gn : u64 = xn_canon_len()
    let mut i : u64 = 0u64
    while i < gn { OK_FB[i] = xn_canon_byte(i)   i = i + 1u64 }
    let uv : u64 = eol_union_with((&OK_FB) as u64, gn)
    if uv == 1u64 { return OK_C_BROKEN }
    if uv != 0u64 {
        /* DISCORD: the houses contradict; mine re-stands whole */
        eol_restand()
        return OK_C_DISCORD
    }
    return OK_C_CONCORD
}

/* THE TESTIMONY (the boundary synod, census seat 10): the hearth's own
 * proven laws in the one tongue -- the house sits under the logos's
 * judgment (every standing, growth, refounding and embassy judged by THE
 * ONE BAROMETER, never by a private law); growth IS the lawful union; a
 * tampered hearth is a refusal. */
fn ok_testify() -> u64 @export {
    return "[house < judgment] [growth = union] [tamper < refusal]" as u64
}

/* ==================== THE SELF-PROOF (arms 410..420) ====================
 * All arms dwell in the TEST hearth (build territory) -- the real house
 * file is never touched by a proof. */
fn ok_tpath() -> u64 { return "STDLIB/build/oikos_arm.eol" as u64 }
fn ok_ent(a: u64, v: u64, b: u64) -> u64 {
    return eol_entails(a, ok_slen(a), v, b, ok_slen(b))
}
/* arm 410: BIRTH AND FIRST DWELLING -- an absent hearth stands empty; the
 * first utterance joins, persists, and re-stands from the file. */
fn ok_arm410() -> u64 {
    if ok_erase(ok_tpath()) != 0u64 { return 410u64 }
    if ok_stand(ok_tpath()) != OK_S_BIRTH { return 410u64 }
    if ok_dwell_text(ok_tpath(), "a dog is an animal" as u64) != 1u64 { return 410u64 }
    let a1 : u64 = OK_ADDR
    if a1 == 0u64 { return 410u64 }
    if ok_stand(ok_tpath()) != OK_S_STOOD { return 410u64 }
    if OK_ADDR != a1 { return 410u64 }
    if ok_ent("dog" as u64, 0u64, "animal" as u64) != 1u64 { return 410u64 }
    return 0u64
}
/* arm 411: THE ACCUMULATION -- a second dwelling UNIONS with the first
 * across the file boundary, and the union CHAINS: the house knows what
 * neither utterance said alone, and answers a question from it. */
fn ok_arm411() -> u64 {
    if ok_dwell_text(ok_tpath(), "an animal is a thing" as u64) != 1u64 { return 411u64 }
    if ok_ent("dog" as u64, 0u64, "thing" as u64) != 1u64 { return 411u64 }
    if ok_dwell_text(ok_tpath(), "is a dog a thing" as u64) != 1u64 { return 411u64 }
    if an_questions() != 1u64 { return 411u64 }
    if an_ask(0u64) != 1u64 { return 411u64 }
    return 0u64
}
/* arm 412: THE GUARDED UNION -- a guest coherent ALONE but cycling against
 * the house is refused CLASH and the house survives UNCHANGED. */
fn ok_arm412() -> u64 {
    let a0 : u64 = OK_ADDR
    let c0 : u64 = OK_RC[OK_R_CLASH]
    if ok_dwell_text(ok_tpath(), "a thing is a dog" as u64) != 2u64 { return 412u64 }
    if OK_REASON != OK_R_CLASH { return 412u64 }
    if OK_RC[OK_R_CLASH] != (c0 + 1u64) { return 412u64 }
    if ok_stand(ok_tpath()) != OK_S_STOOD { return 412u64 }
    if OK_ADDR != a0 { return 412u64 }
    if ok_ent("thing" as u64, 0u64, "dog" as u64) != 0u64 { return 412u64 }
    return 0u64
}
/* arm 413: THE TAMPER -- one flipped byte and the WHOLE house refuses. */
fn ok_arm413() -> u64 {
    let f : u64 = fopen(ok_tpath(), "rb" as u64)
    if f == 0u64 { return 413u64 }
    let n : u64 = fread((&OK_FB) as u64, 1u64, 16420u64, f)
    fclose(f)
    if n < 4u64 { return 413u64 }
    /* flip one canon byte and rewrite */
    OK_FB[n - 2u64] = OK_FB[n - 2u64] ^ 1u8
    let g : u64 = fopen(ok_tpath(), "wb" as u64)
    if g == 0u64 { return 413u64 }
    fwrite((&OK_FB) as u64, 1u64, n, g)
    fclose(g)
    let t0 : u64 = OK_RC[OK_R_TAMPER]
    if ok_stand(ok_tpath()) != OK_S_REFUSED { return 413u64 }
    if OK_REASON != OK_R_TAMPER { return 413u64 }
    if OK_RC[OK_R_TAMPER] != (t0 + 1u64) { return 413u64 }
    return 0u64
}
/* arm 414: REBIRTH AND IDEMPOTENCE -- erased, re-grown identically twice:
 * the same dwellings derive the same address (the hearth is deterministic). */
fn ok_arm414() -> u64 {
    if ok_erase(ok_tpath()) != 0u64 { return 414u64 }
    if ok_dwell_text(ok_tpath(), "a dog is an animal" as u64) != 1u64 { return 414u64 }
    if ok_dwell_text(ok_tpath(), "an animal is a thing" as u64) != 1u64 { return 414u64 }
    let a1 : u64 = OK_ADDR
    if ok_erase(ok_tpath()) != 0u64 { return 414u64 }
    if ok_dwell_text(ok_tpath(), "a dog is an animal" as u64) != 1u64 { return 414u64 }
    if ok_dwell_text(ok_tpath(), "an animal is a thing" as u64) != 1u64 { return 414u64 }
    if OK_ADDR != a1 { return 414u64 }
    if ok_dwell_text(ok_tpath(), "a dog is an animal" as u64) != 1u64 { return 414u64 }
    if OK_ADDR != a1 { return 414u64 }
    eol_reset()
    return 0u64
}
/* arm 415: THE REDUCTION -- a stated-but-derivable claim is dropped; the
 * closure survives (the theorem still ENTAILED, now derived not stated);
 * the refounding is idempotent (a minimal basis stays put). */
fn ok_arm415() -> u64 {
    if ok_erase(ok_tpath()) != 0u64 { return 415u64 }
    if ok_dwell_text(ok_tpath(), "a dog is an animal" as u64) != 1u64 { return 415u64 }
    if ok_dwell_text(ok_tpath(), "an animal is a thing" as u64) != 1u64 { return 415u64 }
    if ok_dwell_text(ok_tpath(), "a dog is a thing" as u64) != 1u64 { return 415u64 }
    let full : u64 = ok_claims_len()
    if ok_compact(ok_tpath()) != 1u64 { return 415u64 }
    if ok_stand(ok_tpath()) != OK_S_STOOD { return 415u64 }
    if ok_claims_len() >= full { return 415u64 }
    if ok_ent("dog" as u64, 0u64, "thing" as u64) != 1u64 { return 415u64 }
    if ok_ent("dog" as u64, 0u64, "animal" as u64) != 1u64 { return 415u64 }
    if ok_ent("animal" as u64, 0u64, "thing" as u64) != 1u64 { return 415u64 }
    let a1 : u64 = OK_ADDR
    if ok_compact(ok_tpath()) != 1u64 { return 415u64 }
    if ok_stand(ok_tpath()) != OK_S_STOOD { return 415u64 }
    if OK_ADDR != a1 { return 415u64 }
    return 0u64
}
/* arm 416: THE IRREDUCIBLE -- a house of independent claims compacts to
 * ITSELF: identity preserved, nothing rewritten. */
fn ok_arm416() -> u64 {
    if ok_erase(ok_tpath()) != 0u64 { return 416u64 }
    if ok_dwell_text(ok_tpath(), "a dog is an animal" as u64) != 1u64 { return 416u64 }
    if ok_dwell_text(ok_tpath(), "the dream mirrors the wake" as u64) != 1u64 { return 416u64 }
    let a0 : u64 = OK_ADDR
    if ok_compact(ok_tpath()) != 1u64 { return 416u64 }
    if ok_stand(ok_tpath()) != OK_S_STOOD { return 416u64 }
    if OK_ADDR != a0 { return 416u64 }
    if ok_ent("dream" as u64, 1u64, "wake" as u64) != 1u64 { return 416u64 }
    return 0u64
}
/* arm 417: THE SPANNING EQUALITY -- an = triangle keeps a spanning pair;
 * congruence re-derives the dropped side. */
fn ok_arm417() -> u64 {
    if ok_erase(ok_tpath()) != 0u64 { return 417u64 }
    if ok_dwell_text(ok_tpath(), "the map is the territory" as u64) != 1u64 { return 417u64 }
    if ok_dwell_text(ok_tpath(), "the territory is the chart" as u64) != 1u64 { return 417u64 }
    if ok_dwell_text(ok_tpath(), "the map is the chart" as u64) != 1u64 { return 417u64 }
    if ok_compact(ok_tpath()) != 1u64 { return 417u64 }
    if ok_stand(ok_tpath()) != OK_S_STOOD { return 417u64 }
    if eol_claims() != 2u64 { return 417u64 }
    if ok_ent("map" as u64, 2u64, "territory" as u64) != 1u64 { return 417u64 }
    if ok_ent("territory" as u64, 2u64, "chart" as u64) != 1u64 { return 417u64 }
    if ok_ent("map" as u64, 2u64, "chart" as u64) != 1u64 { return 417u64 }
    eol_reset()
    return 0u64
}
/* the embassy's second hearth (the foreign house of the proof) */
fn ok_epath() -> u64 { return "STDLIB/build/oikos_emb.eol" as u64 }
/* arm 418: THE CONCORD OVER THE VEIN -- house A emits its knowledge as a
 * CONFORMING envelope, it crosses the bare-metal vein, and house B (which
 * shares a claim and adds its own) RECEIVES it in CONCORD: the union is
 * lawful and house B can now verify A's word through its OWN entailment,
 * while B's file stays B's (diplomacy, not annexation). */
fn ok_arm418() -> u64 {
    /* house A: dog < animal < thing */
    if ok_erase(ok_tpath()) != 0u64 { return 418u64 }
    if ok_dwell_text(ok_tpath(), "a dog is an animal" as u64) != 1u64 { return 418u64 }
    if ok_dwell_text(ok_tpath(), "an animal is a thing" as u64) != 1u64 { return 418u64 }
    /* house B: thing < being (shares nothing contradictory) */
    if ok_erase(ok_epath()) != 0u64 { return 418u64 }
    if ok_dwell_text(ok_epath(), "a thing is a being" as u64) != 1u64 { return 418u64 }
    let bstand : u64 = OK_ADDR
    /* A emits; the envelope crosses the vein */
    if ok_emit(ok_tpath()) == 0u64 { return 418u64 }
    xr_reset()
    if xr_push((&OK_ENV) as u64, OK_ENVN) != 1u64 { return 418u64 }
    if xr_pull() != 1u64 { return 418u64 }
    let fb : u64 = xr_frame_base()
    let fl : u64 = xr_frame_len()
    if fl != OK_ENVN { return 418u64 }
    /* B receives the vein-carried envelope */
    if ok_receive(ok_epath(), fb, fl) != OK_C_CONCORD { return 418u64 }
    xr_advance()
    /* B now knows A's word AND the cross-house chain (thing<being from B,
     * dog<thing from A, so dog<being emerges in the union) */
    if ok_ent("dog" as u64, 0u64, "being" as u64) != 1u64 { return 418u64 }
    if ok_ent("dog" as u64, 0u64, "thing" as u64) != 1u64 { return 418u64 }
    /* B's own file is UNTOUCHED (diplomacy verifies, never annexes) */
    if ok_stand(ok_epath()) != OK_S_STOOD { return 418u64 }
    if OK_ADDR != bstand { return 418u64 }
    return 0u64
}
/* arm 419: THE DISCORD -- a foreign house that CONTRADICTS the receiver is
 * named DISCORD and the receiver's house survives untouched. */
fn ok_arm419() -> u64 {
    /* house A says dog < animal */
    if ok_erase(ok_tpath()) != 0u64 { return 419u64 }
    if ok_dwell_text(ok_tpath(), "a dog is an animal" as u64) != 1u64 { return 419u64 }
    /* house B says animal < dog (the reverse -- a cycle in the union) */
    if ok_erase(ok_epath()) != 0u64 { return 419u64 }
    if ok_dwell_text(ok_epath(), "an animal is a dog" as u64) != 1u64 { return 419u64 }
    let bstand : u64 = OK_ADDR
    if ok_emit(ok_tpath()) == 0u64 { return 419u64 }
    if ok_receive(ok_epath(), (&OK_ENV) as u64, OK_ENVN) != OK_C_DISCORD { return 419u64 }
    /* B's house untouched, and the contradiction did NOT enter it */
    if ok_stand(ok_epath()) != OK_S_STOOD { return 419u64 }
    if OK_ADDR != bstand { return 419u64 }
    if ok_ent("dog" as u64, 0u64, "animal" as u64) != 0u64 { return 419u64 }
    return 0u64
}
/* arm 420: THE SELF-EMBASSY -- a house receiving its OWN envelope is in
 * perfect concord and the foreign address equals its own (the round trip
 * across the boundary is the identity; two doors of one soul agree). */
fn ok_arm420() -> u64 {
    if ok_erase(ok_tpath()) != 0u64 { return 420u64 }
    if ok_dwell_text(ok_tpath(), "the map is the territory" as u64) != 1u64 { return 420u64 }
    let a1 : u64 = OK_ADDR
    if ok_emit(ok_tpath()) == 0u64 { return 420u64 }
    if ok_receive(ok_tpath(), (&OK_ENV) as u64, OK_ENVN) != OK_C_CONCORD { return 420u64 }
    if ok_foreign_addr() != a1 { return 420u64 }
    /* and a truly foreign soul would refuse -- the envelope with a mangled
     * axiom is not this III (a one-digit flip in the axiom field) */
    eol_reset()
    return 0u64
}
fn ok_selfprove() -> u64 @export {
    let mut r : u64 = ok_arm410()
    if r != 0u64 { return r }
    r = ok_arm411()
    if r != 0u64 { return r }
    r = ok_arm412()
    if r != 0u64 { return r }
    r = ok_arm413()
    if r != 0u64 { return r }
    r = ok_arm414()
    if r != 0u64 { return r }
    r = ok_arm415()
    if r != 0u64 { return r }
    r = ok_arm416()
    if r != 0u64 { return r }
    r = ok_arm417()
    if r != 0u64 { return r }
    r = ok_arm418()
    if r != 0u64 { return r }
    r = ok_arm419()
    if r != 0u64 { return r }
    r = ok_arm420()
    if r != 0u64 { return r }
    return 0u64
}
