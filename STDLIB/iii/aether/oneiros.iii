/* aether/oneiros.iii -- THE ONEIROS TIER: the dream that must wake.
 *
 * WHAT THIS ORGAN IS: the crucible in which an OWED law (die-battery-equal but
 * not yet joined by the sealed legislature -- the gap census of gate 2749) is
 * temporarily BELIEVED, and belief is subjected to the die's own reality until
 * it either DIES -- leaving a concrete, forever-checkable witness (u,v), the
 * wreckage of the false world -- or earns HEAT: the right to face the sovereign
 * prover.  Its aspects:
 *
 *   THE CALCULUS   an independent two-path term walker (the fj mutual-distrust
 *                  pattern): the DIE path executes atoms as real instructions
 *                  (ia_apply1/2), the DEFINIENS path evaluates the pure-.iii
 *                  twins (ia_def1/2).  Where the two paths ever split on a
 *                  reported fact, the organ REFUSES (sentinel) -- a bridge
 *                  violation is five-alarm news, never a footnote.
 *   THE CENSUS     the owed-law derivation re-performed from the public doors
 *                  (ia_* + cgphys_*), an implementation INDEPENDENT of gate
 *                  2749's -- their agreement on this die is a standing two-path
 *                  fact the arm checks every run.
 *   THE CRUCIBLE   derived-point falsification: evaluation points GENERATED by
 *                  the term algebra itself -- (u,v) = (t1@pt, t2@pt) over the
 *                  enumerated universe on the electrons -- replacing the fixed
 *                  authored battery with self-authored falsifiers.  THE
 *                  UNFORESEEN LAW: no fixed test set; the falsifier field is
 *                  the image of the algebra.  Exhaustive stratum E (every
 *                  size<=2 generator pair over the full 16x16 battery grid --
 *                  the fairness floor every law receives) + seeded stratum S
 *                  (splitmix64; uniform points and images of random universe
 *                  terms).  THE REPLAY LAW: the seed is taken from die jitter
 *                  but RECORDED -- every dream replays bit-identically from
 *                  its receipt (nondeterministic acquisition, deterministic
 *                  replay).  THE PRISTINE-WITNESS LAW: a kill is only reported
 *                  after re-evaluating BOTH sides at (u,v) from the law's own
 *                  pristine serialization through BOTH evaluator paths.
 *   THE RIPPLE     UNORIENTED bounded joinability under the sealed rows -- the
 *                  orientation-free reasoning THE INERT COROLLARY (gate 2749,
 *                  katabasis/nomos_admit.iii) proved friction-directional
 *                  admission can never perform.  A join = the law is an
 *                  equational consequence of PROVEN rows: prediction "iii-prove
 *                  will prove it", top of the docket.  THE CONSOLIDATION
 *                  THEOREM (why no assumed-law rewriting exists here): a chain
 *                  refutation under an assumed law L reduces, at its first
 *                  value-flip step, to a direct counterexample of L at the
 *                  values of the step's bindings (substitution lemma, sealed
 *                  steps value-preserving) -- so RIPPLE-KILL is a subset of
 *                  CRUCIBLE-KILL at equal generator budget, and kill authority
 *                  lives in ONE mechanism.  The ripple serves the POSITIVE
 *                  direction only.  On a KILLED law a join is impossible
 *                  (derivable-from-proven implies true); finding one anyway is
 *                  the SOUNDNESS SENTINEL firing.
 *   THE WOMB       the seraphic arm (the ser_antiunify lineage lifted to the
 *                  ISA tier): anti-unification of sealed row PAIRS births
 *                  schemas (subterm metavariables), instantiated over the term
 *                  pool into CONJECTURES beyond the enumerator's size wall --
 *                  generalize from proven truth, project into unexplored
 *                  space, then face the same crucible as everything else.  A
 *                  schema is never sealed; only its proven instances can be.
 *   THE NOUS       the heat ledger -- attention, never truth (the tau wall):
 *                  docket order = (joinable first, then crucible survivors) x
 *                  measured single-term friction floors (fj self-races through
 *                  the ser door) x canonical index.  Heat orders SPEND; the
 *                  only seats of truth remain iii-prove + nomos_seal.sh.
 *
 * THE ANNIHILATION LAW: assumption death is sealed-grade truth (a checkable
 * witness point); assumption survival is only heat.  The organ never writes
 * the legislature; it only kills (with witnesses) and orders (with receipts).
 *
 * Controls, every run: the injected FALSE law AND(x,y)=OR(x,y) MUST die with a
 * two-path-confirmed witness (the kill arm is proven armed), and every sealed
 * one-variable row MUST survive the full exhaustive stratum (a kill against a
 * 2^64-PROVEN row = the prover and the die in contradiction = sentinel).
 *
 * ONEIROS_CERT: FNV-1a over seed + census + every ledger row's structural
 * outcome (sers, status, witness, join depth, dose, provenance) + the sealed
 * set id.  Floors and timings are EXCLUDED (jitter is provenance, never
 * content) -- same seed, same die, same seal => byte-identical cert.
 *
 * Exit (oz_run): 0 ADMITTED | 2 SENTINEL (a two-path split, a sealed-row kill,
 * or a killed-law join) | 3 CONTROL-SILENT (the false law survived) | 5
 * ENVELOPE (universe/rules outside the named caps).
 *
 * NIH: composes aether/isa_ontogenesis + COMPILER/BOOT/cg_phys_rules +
 * aether/isa_friction_judge (ser race door) + omnia bench, via EXPORTED doors
 * only.  Hexad: kind_essence.  Ring: R0. */
module aether_oneiros

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn ia_init() -> i64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_atom_arity(id: i64) -> i64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_apply1(atom: i64, a: u64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_apply2(atom: i64, a: u64, b: u64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_def1(atom: i64, a: u64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_def2(atom: i64, a: u64, b: u64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_tcount(m: i64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_term_ser(t_idx: u64, out_addr: u64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn cgphys_nrules() -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_set_id() -> u64 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_dear_len(i: u32) -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_cheap_len(i: u32) -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_dear_b(i: u32, j: u32) -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn cgphys_rule_cheap_b(i: u32, j: u32) -> u32 from "cg_phys_rules.iii"
extern @abi(c-msvc-x64) fn fj_race_sers(pa: u64, la: u64, pb: u64, lb: u64, reps: u64, trials: i64) -> i64 from "isa_friction_judge.iii"
extern @abi(c-msvc-x64) fn fj_lhs_floor() -> u64 from "isa_friction_judge.iii"
extern @abi(c-msvc-x64) fn fj_rhs_floor() -> u64 from "isa_friction_judge.iii"
extern @abi(c-msvc-x64) fn bench_now() -> u64 from "bench.iii"

/* ---- printers (house voice) ---- */
fn ps(s: u64) -> u32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }
    return 1u32
}
fn pu(v: u64) -> i32 {
    if v >= 10u64 { pu(v / 10u64) }
    putchar((48u64 + (v % 10u64)) as i32)
    return 0i32
}

/* ===================================================================
 * THE CALCULUS -- three ser registers (A = law lhs, B = law rhs, P =
 * probe), one cursor, two walker paths.  Module-scope scratch only
 * (the organ idiom -- local arrays miscompile). */
var OZ_A   : [u8; 32]
var OZ_ALN : u64 = 0u64
var OZ_B   : [u8; 32]
var OZ_BLN : u64 = 0u64
var OZ_P   : [u8; 32]
var OZ_PLN : u64 = 0u64
var OZ_W   : u64 = 0u64          /* which register the walker reads: 0 A | 1 B | 2 P */
var OZ_C   : u64 = 0u64
var OZ_X   : u64 = 0u64
var OZ_Y   : u64 = 0u64
var OZ_BAD : u64 = 0u64

fn oz_len() -> u64 {
    if OZ_W == 0u64 { return OZ_ALN }
    if OZ_W == 1u64 { return OZ_BLN }
    return OZ_PLN
}
fn oz_rd() -> u8 {
    let mut b : u8 = 255u8
    if OZ_W == 0u64 { b = OZ_A[OZ_C] }
    if OZ_W == 1u64 { b = OZ_B[OZ_C] }
    if OZ_W == 2u64 { b = OZ_P[OZ_C] }
    OZ_C = OZ_C + 1u64
    return b
}
fn oz_walk_die() -> u64 {
    if OZ_C >= oz_len() { OZ_BAD = 1u64   return 0u64 }
    let b : u8 = oz_rd()
    if b == 0u8 { return OZ_X }
    if b == 1u8 { return OZ_Y }
    let id : i64 = (b as i64) - 2i64
    if ia_atom_arity(id) == 1i64 { return ia_apply1(id, oz_walk_die()) }
    let l : u64 = oz_walk_die()
    return ia_apply2(id, l, oz_walk_die())
}
fn oz_walk_def() -> u64 {
    if OZ_C >= oz_len() { OZ_BAD = 1u64   return 0u64 }
    let b : u8 = oz_rd()
    if b == 0u8 { return OZ_X }
    if b == 1u8 { return OZ_Y }
    let id : i64 = (b as i64) - 2i64
    if ia_atom_arity(id) == 1i64 { return ia_def1(id, oz_walk_def()) }
    let l : u64 = oz_walk_def()
    return ia_def2(id, l, oz_walk_def())
}
fn oz_eval_die(x: u64, y: u64) -> u64 {
    OZ_C = 0u64
    OZ_X = x
    OZ_Y = y
    return oz_walk_die()
}
fn oz_eval_def(x: u64, y: u64) -> u64 {
    OZ_C = 0u64
    OZ_X = x
    OZ_Y = y
    return oz_walk_def()
}

/* the published battery -- byte-identical to gate 2749's bat() and the taxis
 * tier's tx_bat(): the pre-stated global sieve values */
fn oz_bat(k: u64) -> u64 {
    if k == 0u64 { return 0u64 }
    if k == 1u64 { return 1u64 }
    if k == 2u64 { return 2u64 }
    if k == 3u64 { return 18446744073709551615u64 }
    if k == 4u64 { return 9223372036854775808u64 }
    if k == 5u64 { return 12297829382473034410u64 }
    if k == 6u64 { return 6148914691236517205u64 }
    if k == 7u64 { return 4294967295u64 }
    if k == 8u64 { return 18446744069414584320u64 }
    if k == 9u64 { return 81985529216486895u64 }
    if k == 10u64 { return 16045690984833335023u64 }
    if k == 11u64 { return 9223372036854775809u64 }
    if k == 12u64 { return 9223372036854775807u64 }
    if k == 13u64 { return 42u64 }
    if k == 14u64 { return 1000003u64 }
    return 32768u64
}
/* die-path signature over the published 16x4 grid of register w (the 2749 sig) */
fn oz_sig_w(w: u64) -> u64 {
    OZ_W = w
    let mut h : u64 = 14695981039346656037u64
    let mut kx : u64 = 0u64
    while kx < 16u64 {
        let mut ky : u64 = 0u64
        while ky < 4u64 {
            let v : u64 = oz_eval_die(oz_bat(kx), oz_bat(ky * 5u64))
            h = (h ^ v) * 1099511628211u64
            h = (h ^ (v >> 32u64)) * 1099511628211u64
            ky = ky + 1u64
        }
        kx = kx + 1u64
    }
    return h
}

/* ===================================================================
 * THE SEALED ROWS -- one-variable rows only (two-variable twins carry
 * their rule through the x/y twin; same skip as gate 2749). */
var OZR_D    : [u8; 2048]
var OZR_C    : [u8; 2048]
var OZR_DL   : [u64; 32]
var OZR_CL   : [u64; 32]
var OZR_N    : u64 = 0u64
var OZR_SKIP : u64 = 0u64

fn ozr_load() -> i64 {
    OZR_N = 0u64
    OZR_SKIP = 0u64
    let n : u64 = cgphys_nrules() as u64
    let mut i : u64 = 0u64
    while i < n {
        let dl : u64 = cgphys_rule_dear_len(i as u32) as u64
        let cl : u64 = cgphys_rule_cheap_len(i as u32) as u64
        let mut twov : u64 = 0u64
        let mut j : u64 = 0u64
        while j < dl {
            let b : u32 = cgphys_rule_dear_b(i as u32, j as u32)
            if b == 1u32 { twov = 1u64 }
            OZR_D[(OZR_N * 64u64) + j] = b as u8
            j = j + 1u64
        }
        j = 0u64
        while j < cl {
            let b2 : u32 = cgphys_rule_cheap_b(i as u32, j as u32)
            if b2 == 1u32 { twov = 1u64 }
            OZR_C[(OZR_N * 64u64) + j] = b2 as u8
            j = j + 1u64
        }
        if twov == 1u64 { OZR_SKIP = OZR_SKIP + 1u64 } else {
            OZR_DL[OZR_N] = dl
            OZR_CL[OZR_N] = cl
            OZR_N = OZR_N + 1u64
        }
        i = i + 1u64
    }
    return 0i64
}

/* ===================================================================
 * THE WORKING TERM + match/rewrite (side-parameterized: side 0 = the
 * dear pattern, side 1 = the cheap pattern; rewriting splices the
 * OTHER side -- the unoriented door the ripple needs; normalization
 * uses side 0 only = strategy A of gate 2749). */
var OZT   : [u8; 32]
var OZT_L : u64 = 0u64
var OZB   : [u8; 64]
var OZM_S    : u64 = 0u64
var OZM_L    : u64 = 0u64
var OZM_SEEN : u64 = 0u64

fn ozt_sublen(p: u64) -> u64 {
    let b : u8 = OZT[p]
    if b < 2u8 { return 1u64 }
    let id : i64 = (b as i64) - 2i64
    if ia_atom_arity(id) == 1i64 { return 1u64 + ozt_sublen(p + 1u64) }
    let l : u64 = ozt_sublen(p + 1u64)
    return 1u64 + l + ozt_sublen(p + 1u64 + l)
}
fn ozt_pat_b(r: u64, side: u64, k: u64) -> u8 {
    if side == 0u64 { return OZR_D[(r * 64u64) + k] }
    return OZR_C[(r * 64u64) + k]
}
fn ozt_pat_l(r: u64, side: u64) -> u64 {
    if side == 0u64 { return OZR_DL[r] }
    return OZR_CL[r]
}
fn ozt_match(r: u64, p: u64, side: u64) -> u64 {
    OZM_SEEN = 0u64
    let pl : u64 = ozt_pat_l(r, side)
    let mut ri : u64 = 0u64
    let mut ti : u64 = p
    while ri < pl {
        if ti >= OZT_L { return 0u64 }
        let rb : u8 = ozt_pat_b(r, side, ri)
        if rb == 0u8 {
            let sl : u64 = ozt_sublen(ti)
            if OZM_SEEN == 0u64 {
                OZM_S = ti
                OZM_L = sl
                OZM_SEEN = 1u64
            } else {
                if sl != OZM_L { return 0u64 }
                let mut k : u64 = 0u64
                while k < sl {
                    if OZT[OZM_S + k] != OZT[ti + k] { return 0u64 }
                    k = k + 1u64
                }
            }
            ti = ti + sl
        } else {
            if OZT[ti] != rb { return 0u64 }
            ti = ti + 1u64
        }
        ri = ri + 1u64
    }
    return 1u64
}
/* rewrite the JUST-MATCHED (r,p,side) occurrence to the other side; refuses
 * (returns 0, OZT untouched) past the 30-byte envelope */
fn ozt_rewrite(r: u64, p: u64, side: u64) -> u64 {
    let span : u64 = ozt_sublen(p)
    let oth : u64 = 1u64 - side
    let ol : u64 = ozt_pat_l(r, oth)
    let mut expd : u64 = 0u64
    let mut ci : u64 = 0u64
    while ci < ol {
        if ozt_pat_b(r, oth, ci) == 0u8 { expd = expd + OZM_L } else { expd = expd + 1u64 }
        ci = ci + 1u64
    }
    let nl : u64 = (p + expd) + (OZT_L - (p + span))
    if nl > 30u64 { return 0u64 }
    let mut o : u64 = 0u64
    let mut i : u64 = 0u64
    while i < p { OZB[o] = OZT[i]   o = o + 1u64   i = i + 1u64 }
    ci = 0u64
    while ci < ol {
        let cb : u8 = ozt_pat_b(r, oth, ci)
        if cb == 0u8 {
            let mut k : u64 = 0u64
            while k < OZM_L { OZB[o] = OZT[OZM_S + k]   o = o + 1u64   k = k + 1u64 }
        } else {
            OZB[o] = cb
            o = o + 1u64
        }
        ci = ci + 1u64
    }
    i = p + span
    while i < OZT_L { OZB[o] = OZT[i]   o = o + 1u64   i = i + 1u64 }
    OZT_L = o
    i = 0u64
    while i < o { OZT[i] = OZB[i]   i = i + 1u64 }
    return 1u64
}
/* strategy A: leftmost position, lowest rule, dear -> cheap, to fixpoint */
fn ozt_norm() -> u64 {
    let mut steps : u64 = 0u64
    let mut go : u64 = 1u64
    while go == 1u64 {
        if steps > 64u64 { return 9999u64 }
        go = 0u64
        let mut p : u64 = 0u64
        while p < OZT_L {
            if go == 0u64 {
                let mut r : u64 = 0u64
                while r < OZR_N {
                    if go == 0u64 {
                        if ozt_match(r, p, 0u64) == 1u64 {
                            ozt_rewrite(r, p, 0u64)
                            steps = steps + 1u64
                            go = 1u64
                        }
                    }
                    r = r + 1u64
                }
            }
            p = p + 1u64
        }
    }
    return steps
}

/* ===================================================================
 * THE CENSUS -- every term of size <= 4 on the live die, quotiented
 * semantically (die signature) and syntactically (sealed canonical).
 * An implementation independent of gate 2749's; the arm cross-checks. */
var OZC_ORIG  : [u8; 32768]
var OZC_ORIGL : [u8; 4096]
var OZC_CAN   : [u8; 32768]
var OZC_CANL  : [u8; 4096]
var OZC_SIG   : [u64; 4096]
var OZC_NT   : u64 = 0u64
var OZC_SEM  : u64 = 0u64
var OZC_CANN : u64 = 0u64

fn oz_census() -> u64 {
    let mut prefix : u64 = 0u64
    let mut m : i64 = 1i64
    while m <= 4i64 { prefix = prefix + ia_tcount(m)   m = m + 1i64 }
    if prefix < 100u64 { return 5u64 }
    if prefix > 4096u64 { return 5u64 }
    OZC_NT = 0u64
    let mut t : u64 = 0u64
    while t < prefix {
        OZ_ALN = ia_term_ser(t, (&OZ_A) as u64)
        if OZ_ALN < 1u64 { return 5u64 }
        if OZ_ALN > 4u64 { return 5u64 }
        let mut i : u64 = 0u64
        while i < OZ_ALN { OZC_ORIG[(t * 8u64) + i] = OZ_A[i]   i = i + 1u64 }
        OZC_ORIGL[t] = OZ_ALN as u8
        OZC_SIG[t] = oz_sig_w(0u64)
        i = 0u64
        while i < OZ_ALN { OZT[i] = OZ_A[i]   i = i + 1u64 }
        OZT_L = OZ_ALN
        if ozt_norm() > 4096u64 { return 5u64 }
        i = 0u64
        while i < OZT_L { OZC_CAN[(t * 8u64) + i] = OZT[i]   i = i + 1u64 }
        OZC_CANL[t] = OZT_L as u8
        OZC_NT = OZC_NT + 1u64
        t = t + 1u64
    }
    /* distinct signatures, distinct canonicals; soundness: same canonical
     * on different terms must mean same signature (else sentinel-grade) */
    OZC_SEM = 0u64
    OZC_CANN = 0u64
    let mut a : u64 = 0u64
    while a < OZC_NT {
        let mut firstS : u64 = 1u64
        let mut firstC : u64 = 1u64
        let mut b : u64 = 0u64
        while b < a {
            if OZC_SIG[b] == OZC_SIG[a] { firstS = 0u64 }
            if OZC_CANL[b] == OZC_CANL[a] {
                let mut eq : u64 = 1u64
                let mut k : u64 = 0u64
                while k < (OZC_CANL[a] as u64) {
                    if OZC_CAN[(b * 8u64) + k] != OZC_CAN[(a * 8u64) + k] { eq = 0u64 }
                    k = k + 1u64
                }
                if eq == 1u64 {
                    firstC = 0u64
                    if OZC_SIG[b] != OZC_SIG[a] { OZ_SENT = OZ_SENT + 1u64 }
                }
            }
            b = b + 1u64
        }
        OZC_SEM = OZC_SEM + firstS
        OZC_CANN = OZC_CANN + firstC
        a = a + 1u64
    }
    return 0u64
}

/* ===================================================================
 * THE LEDGER -- owed laws (census) + conjectures (womb), one pipeline.
 * status: 0 pending | 1 KILLED-E | 2 KILLED-S | 3 JOINABLE | 4 SURVIVED */
var OZO_A    : [u8; 16384]
var OZO_B    : [u8; 16384]
var OZO_AL   : [u8; 1024]
var OZO_BL   : [u8; 1024]
var OZO_ST   : [u8; 1024]
var OZO_PROV : [u8; 1024]
var OZO_JD   : [u8; 1024]
var OZO_WU   : [u64; 1024]
var OZO_WV   : [u64; 1024]
var OZO_DOSE : [u64; 1024]
var OZO_FA   : [u64; 1024]
var OZO_FB   : [u64; 1024]
var OZO_N    : u64 = 0u64
var OZO_CEN  : u64 = 0u64        /* census-born prefix of the ledger */
var OZO_OVF  : u64 = 0u64

fn ozo_append(prov: u64) -> u64 {
    /* stages OZ_A/OZ_B into the ledger; 1 = stored */
    if OZO_N >= 1024u64 { OZO_OVF = OZO_OVF + 1u64   return 0u64 }
    let r : u64 = OZO_N
    let mut i : u64 = 0u64
    while i < OZ_ALN { OZO_A[(r * 16u64) + i] = OZ_A[i]   i = i + 1u64 }
    i = 0u64
    while i < OZ_BLN { OZO_B[(r * 16u64) + i] = OZ_B[i]   i = i + 1u64 }
    OZO_AL[r] = OZ_ALN as u8
    OZO_BL[r] = OZ_BLN as u8
    OZO_ST[r] = 0u8
    OZO_PROV[r] = prov as u8
    OZO_JD[r] = 0u8
    OZO_WU[r] = 0u64
    OZO_WV[r] = 0u64
    OZO_DOSE[r] = 0u64
    OZO_FA[r] = 0u64
    OZO_FB[r] = 0u64
    OZO_N = OZO_N + 1u64
    return 1u64
}
fn oz_law_load(i: u64) -> i64 {
    let mut k : u64 = 0u64
    OZ_ALN = OZO_AL[i] as u64
    while k < OZ_ALN { OZ_A[k] = OZO_A[(i * 16u64) + k]   k = k + 1u64 }
    k = 0u64
    OZ_BLN = OZO_BL[i] as u64
    while k < OZ_BLN { OZ_B[k] = OZO_B[(i * 16u64) + k]   k = k + 1u64 }
    return 0i64
}
/* the owed extraction: within each signature class, the class head's
 * canonical vs each FIRST occurrence of a distinct other canonical */
fn oz_owed_extract() -> u64 {
    let mut a : u64 = 0u64
    while a < OZC_NT {
        let mut h : u64 = a
        let mut b : u64 = 0u64
        while b < a {
            if h == a { if OZC_SIG[b] == OZC_SIG[a] { h = b } }
            b = b + 1u64
        }
        if h != a {
            /* canonical of a differs from head's AND is first in its class? */
            let mut diff : u64 = 0u64
            if OZC_CANL[h] != OZC_CANL[a] { diff = 1u64 }
            if diff == 0u64 {
                let mut k : u64 = 0u64
                while k < (OZC_CANL[a] as u64) {
                    if OZC_CAN[(h * 8u64) + k] != OZC_CAN[(a * 8u64) + k] { diff = 1u64 }
                    k = k + 1u64
                }
            }
            if diff == 1u64 {
                let mut first : u64 = 1u64
                b = 0u64
                while b < a {
                    if OZC_SIG[b] == OZC_SIG[a] {
                        if OZC_CANL[b] == OZC_CANL[a] {
                            let mut eq : u64 = 1u64
                            let mut k2 : u64 = 0u64
                            while k2 < (OZC_CANL[a] as u64) {
                                if OZC_CAN[(b * 8u64) + k2] != OZC_CAN[(a * 8u64) + k2] { eq = 0u64 }
                                k2 = k2 + 1u64
                            }
                            if eq == 1u64 { first = 0u64 }
                        }
                    }
                    b = b + 1u64
                }
                if first == 1u64 {
                    let mut k3 : u64 = 0u64
                    OZ_ALN = OZC_CANL[h] as u64
                    while k3 < OZ_ALN { OZ_A[k3] = OZC_CAN[(h * 8u64) + k3]   k3 = k3 + 1u64 }
                    k3 = 0u64
                    OZ_BLN = OZC_CANL[a] as u64
                    while k3 < OZ_BLN { OZ_B[k3] = OZC_CAN[(a * 8u64) + k3]   k3 = k3 + 1u64 }
                    ozo_append(0u64)
                }
            }
        }
        a = a + 1u64
    }
    OZO_CEN = OZO_N
    return OZO_N
}

/* ===================================================================
 * THE GENERATORS -- every size<=2 term, its value precomputed over the
 * FULL 16x16 battery grid (the crucible's fairness floor; richer than
 * the 16x4 sieve grid by design, pre-stated). */
var OZG_SS : [u8; 128]
var OZG_SL : [u64; 32]
var OZG_V  : [u64; 8192]
var OZG_N  : u64 = 0u64

fn oz_gen_table() -> u64 {
    let mut prefix : u64 = 0u64
    let mut m : i64 = 1i64
    while m <= 2i64 { prefix = prefix + ia_tcount(m)   m = m + 1i64 }
    if prefix < 2u64 { return 5u64 }
    if prefix > 32u64 { return 5u64 }
    OZG_N = prefix
    let mut g : u64 = 0u64
    while g < OZG_N {
        OZ_PLN = ia_term_ser(g, (&OZ_P) as u64)
        if OZ_PLN < 1u64 { return 5u64 }
        if OZ_PLN > 2u64 { return 5u64 }
        let mut i : u64 = 0u64
        while i < OZ_PLN { OZG_SS[(g * 4u64) + i] = OZ_P[i]   i = i + 1u64 }
        OZG_SL[g] = OZ_PLN
        OZ_W = 2u64
        let mut kx : u64 = 0u64
        while kx < 16u64 {
            let mut ky : u64 = 0u64
            while ky < 16u64 {
                OZG_V[(g * 256u64) + ((kx * 16u64) + ky)] = oz_eval_die(oz_bat(kx), oz_bat(ky))
                ky = ky + 1u64
            }
            kx = kx + 1u64
        }
        g = g + 1u64
    }
    return 0u64
}

/* ===================================================================
 * THE CRUCIBLE */
var OZ_SENT : u64 = 0u64
var OZ_LWU  : u64 = 0u64
var OZ_LWV  : u64 = 0u64
var OZ_LDOSE : u64 = 0u64
var OZ_KILL : u64 = 0u64
var OZ_SURV : u64 = 0u64
var OZ_JOIN : u64 = 0u64

/* believe the loaded law at one point; 1 = the belief DIES here (witness in
 * OZ_LWU/LWV, confirmed through both pristine paths), 0 = holds, -1 = sentinel */
fn oz_check_at(u: u64, v: u64) -> i64 {
    OZ_W = 0u64
    let av : u64 = oz_eval_die(u, v)
    OZ_W = 1u64
    let bv : u64 = oz_eval_die(u, v)
    if OZ_BAD == 1u64 { OZ_SENT = OZ_SENT + 1u64   OZ_BAD = 0u64   return 0i64 - 1i64 }
    if av == bv { return 0i64 }
    OZ_W = 0u64
    let ad : u64 = oz_eval_def(u, v)
    OZ_W = 1u64
    let bd : u64 = oz_eval_def(u, v)
    if OZ_BAD == 1u64 { OZ_SENT = OZ_SENT + 1u64   OZ_BAD = 0u64   return 0i64 - 1i64 }
    if ad != av { OZ_SENT = OZ_SENT + 1u64   return 0i64 - 1i64 }
    if bd != bv { OZ_SENT = OZ_SENT + 1u64   return 0i64 - 1i64 }
    OZ_LWU = u
    OZ_LWV = v
    return 1i64
}
/* the exhaustive stratum over the loaded law: every generator pair, every
 * grid point; 1 = killed (dose so far in OZ_LDOSE) */
fn oz_sweep_e() -> u64 {
    OZ_LDOSE = 0u64
    let mut gi : u64 = 0u64
    while gi < OZG_N {
        let mut gj : u64 = 0u64
        while gj < OZG_N {
            let mut pt : u64 = 0u64
            while pt < 256u64 {
                OZ_LDOSE = OZ_LDOSE + 1u64
                let r : i64 = oz_check_at(OZG_V[(gi * 256u64) + pt], OZG_V[(gj * 256u64) + pt])
                if r == 1i64 { return 1u64 }
                pt = pt + 1u64
            }
            gj = gj + 1u64
        }
        gi = gi + 1u64
    }
    return 0u64
}
/* the seeded stratum: uniform points and images of random universe terms
 * at random battery corners -- deterministic given the recorded seed */
var OZ_RNG : u64 = 0u64
fn oz_sm64() -> u64 {
    OZ_RNG = OZ_RNG + 11400714819323198485u64
    let mut z : u64 = OZ_RNG
    z = (z ^ (z >> 30u64)) * 13787848793156543929u64
    z = (z ^ (z >> 27u64)) * 10723151780598845931u64
    return z ^ (z >> 31u64)
}
fn oz_probe_eval(t: u64, x: u64, y: u64) -> u64 {
    OZ_PLN = OZC_ORIGL[t] as u64
    let mut i : u64 = 0u64
    while i < OZ_PLN { OZ_P[i] = OZC_ORIG[(t * 8u64) + i]   i = i + 1u64 }
    OZ_W = 2u64
    return oz_eval_die(x, y)
}
fn oz_sweep_s(fuel: u64) -> u64 {
    OZ_LDOSE = 0u64
    let mut d : u64 = 0u64
    while d < fuel {
        let r0 : u64 = oz_sm64()
        let mut u : u64 = 0u64
        let mut v : u64 = 0u64
        if (r0 & 1u64) == 0u64 {
            u = oz_sm64()
            v = oz_sm64()
        } else {
            let t1 : u64 = oz_sm64() % OZC_NT
            let t2 : u64 = oz_sm64() % OZC_NT
            let bx : u64 = oz_bat(oz_sm64() & 15u64)
            let by : u64 = oz_bat(oz_sm64() & 15u64)
            u = oz_probe_eval(t1, bx, by)
            v = oz_probe_eval(t2, bx, by)
        }
        OZ_LDOSE = OZ_LDOSE + 1u64
        let r : i64 = oz_check_at(u, v)
        if r == 1i64 { return 1u64 }
        d = d + 1u64
    }
    return 0u64
}

/* ===================================================================
 * THE RIPPLE -- unoriented bounded joinability under the sealed rows */
var OZF_S  : [u8; 4096]
var OZF_L  : [u8; 256]
var OZF_SD : [u8; 256]
var OZF_DP : [u8; 256]
var OZF_N   : u64 = 0u64
var OZF_OVF : u64 = 0u64
var OZF_HIT : u64 = 0u64         /* join depth when found, else 0 */

/* stage OZT into the frontier; detects a JOIN against the other side */
fn ozf_add(side: u64, depth: u64) -> u64 {
    let mut f : u64 = 0u64
    while f < OZF_N {
        if (OZF_L[f] as u64) == OZT_L {
            let mut eq : u64 = 1u64
            let mut k : u64 = 0u64
            while k < OZT_L {
                if OZF_S[(f * 16u64) + k] != OZT[k] { eq = 0u64 }
                k = k + 1u64
            }
            if eq == 1u64 {
                if (OZF_SD[f] as u64) != side {
                    if OZF_HIT == 0u64 { OZF_HIT = depth }
                    return 1u64
                }
                return 0u64
            }
        }
        f = f + 1u64
    }
    if OZF_N >= 256u64 { OZF_OVF = OZF_OVF + 1u64   return 0u64 }
    let r : u64 = OZF_N
    let mut i : u64 = 0u64
    while i < OZT_L { OZF_S[(r * 16u64) + i] = OZT[i]   i = i + 1u64 }
    OZF_L[r] = OZT_L as u8
    OZF_SD[r] = side as u8
    OZF_DP[r] = depth as u8
    OZF_N = OZF_N + 1u64
    return 0u64
}
fn ozf_take(f: u64) -> i64 {
    OZT_L = OZF_L[f] as u64
    let mut i : u64 = 0u64
    while i < OZT_L { OZT[i] = OZF_S[(f * 16u64) + i]   i = i + 1u64 }
    return 0i64
}
/* joinability of the LOADED law (OZ_A/OZ_B); returns join depth or 0 */
fn oz_ripple() -> u64 {
    OZF_N = 0u64
    OZF_HIT = 0u64
    let mut i : u64 = 0u64
    OZT_L = OZ_ALN
    while i < OZ_ALN { OZT[i] = OZ_A[i]   i = i + 1u64 }
    ozf_add(0u64, 0u64)
    i = 0u64
    OZT_L = OZ_BLN
    while i < OZ_BLN { OZT[i] = OZ_B[i]   i = i + 1u64 }
    ozf_add(1u64, 0u64)
    if OZF_HIT != 0u64 { return OZF_HIT }
    let mut f : u64 = 0u64
    while f < OZF_N {
        if OZF_HIT != 0u64 { return OZF_HIT }
        let dep : u64 = OZF_DP[f] as u64
        if dep < 3u64 {
            ozf_take(f)
            let flen : u64 = OZT_L
            let mut p : u64 = 0u64
            while p < flen {
                let mut r : u64 = 0u64
                while r < OZR_N {
                    let mut dir : u64 = 0u64
                    while dir < 2u64 {
                        if ozt_match(r, p, dir) == 1u64 {
                            if ozt_rewrite(r, p, dir) == 1u64 {
                                if OZT_L <= 12u64 { ozf_add(OZF_SD[f] as u64, dep + 1u64) }
                                ozf_take(f)
                            }
                        }
                        dir = dir + 1u64
                    }
                    r = r + 1u64
                }
                p = p + 1u64
            }
        }
        f = f + 1u64
    }
    return OZF_HIT
}

/* ===================================================================
 * THE WOMB -- anti-unification of sealed row pairs into schemas;
 * instantiation over the generator pool into conjectures. */
var OZA_1  : [u8; 32]
var OZA_1L : u64 = 0u64
var OZA_2  : [u8; 32]
var OZA_2L : u64 = 0u64
var OZA_C1 : u64 = 0u64
var OZA_C2 : u64 = 0u64
var OZMV1  : [u8; 32]
var OZMV1L : [u64; 2]
var OZMV2  : [u8; 32]
var OZMV2L : [u64; 2]
var OZMV_N : u64 = 0u64
var OZE    : [u8; 32]
var OZE_N  : u64 = 0u64
var OZW_PA  : [u8; 2048]
var OZW_PB  : [u8; 2048]
var OZW_PAL : [u8; 64]
var OZW_PBL : [u8; 64]
var OZW_MC  : [u8; 64]
var OZW_N       : u64 = 0u64
var OZW_OVF     : u64 = 0u64
var OZW_DEG     : u64 = 0u64
var OZW_BORN    : u64 = 0u64
var OZW_ALREADY : u64 = 0u64
var OZW_SIGREJ  : u64 = 0u64
var OZW_DUP     : u64 = 0u64
var OZW_TRIV    : u64 = 0u64
var OZJ    : [u8; 32]
var OZJ_N  : u64 = 0u64
var OZK1   : [u8; 32]
var OZK1_N : u64 = 0u64
var OZK2   : [u8; 32]
var OZK2_N : u64 = 0u64

fn oz_s1len(p: u64) -> u64 {
    let b : u8 = OZA_1[p]
    if b < 2u8 { return 1u64 }
    let id : i64 = (b as i64) - 2i64
    if ia_atom_arity(id) == 1i64 { return 1u64 + oz_s1len(p + 1u64) }
    let l : u64 = oz_s1len(p + 1u64)
    return 1u64 + l + oz_s1len(p + 1u64 + l)
}
fn oz_s2len(p: u64) -> u64 {
    let b : u8 = OZA_2[p]
    if b < 2u8 { return 1u64 }
    let id : i64 = (b as i64) - 2i64
    if ia_atom_arity(id) == 1i64 { return 1u64 + oz_s2len(p + 1u64) }
    let l : u64 = oz_s2len(p + 1u64)
    return 1u64 + l + oz_s2len(p + 1u64 + l)
}
fn oz_mv_get(p1: u64, l1: u64, p2: u64, l2: u64) -> i64 {
    let mut m : u64 = 0u64
    while m < OZMV_N {
        if OZMV1L[m] == l1 { if OZMV2L[m] == l2 {
            let mut eq : u64 = 1u64
            let mut k : u64 = 0u64
            while k < l1 {
                if OZMV1[(m * 16u64) + k] != OZA_1[p1 + k] { eq = 0u64 }
                k = k + 1u64
            }
            k = 0u64
            while k < l2 {
                if OZMV2[(m * 16u64) + k] != OZA_2[p2 + k] { eq = 0u64 }
                k = k + 1u64
            }
            if eq == 1u64 { return m as i64 }
        } }
        m = m + 1u64
    }
    if OZMV_N >= 2u64 { return 0i64 - 1i64 }
    let r : u64 = OZMV_N
    let mut k2 : u64 = 0u64
    while k2 < l1 { OZMV1[(r * 16u64) + k2] = OZA_1[p1 + k2]   k2 = k2 + 1u64 }
    k2 = 0u64
    while k2 < l2 { OZMV2[(r * 16u64) + k2] = OZA_2[p2 + k2]   k2 = k2 + 1u64 }
    OZMV1L[r] = l1
    OZMV2L[r] = l2
    OZMV_N = OZMV_N + 1u64
    return r as i64
}
fn oz_au_emit(b: u8) -> i64 {
    if OZE_N < 30u64 { OZE[OZE_N] = b   OZE_N = OZE_N + 1u64   return 0i64 }
    return 0i64 - 1i64
}
fn oz_au_rec() -> u64 {
    if OZA_C1 >= OZA_1L { return 0u64 }
    if OZA_C2 >= OZA_2L { return 0u64 }
    let b1 : u8 = OZA_1[OZA_C1]
    let b2 : u8 = OZA_2[OZA_C2]
    if b1 == b2 {
        OZA_C1 = OZA_C1 + 1u64
        OZA_C2 = OZA_C2 + 1u64
        oz_au_emit(b1)
        if b1 < 2u8 { return 1u64 }
        let id : i64 = (b1 as i64) - 2i64
        if ia_atom_arity(id) == 1i64 { return oz_au_rec() }
        if oz_au_rec() == 0u64 { return 0u64 }
        return oz_au_rec()
    }
    let l1 : u64 = oz_s1len(OZA_C1)
    let l2 : u64 = oz_s2len(OZA_C2)
    let mv : i64 = oz_mv_get(OZA_C1, l1, OZA_C2, l2)
    if mv < 0i64 { return 0u64 }
    oz_au_emit((250i64 + mv) as u8)
    OZA_C1 = OZA_C1 + l1
    OZA_C2 = OZA_C2 + l2
    return 1u64
}
fn oz_au_side(i: u64, j: u64, side: u64) -> u64 {
    /* load row i / row j (dear side 0, cheap side 1) into the AU registers */
    let mut k : u64 = 0u64
    if side == 0u64 {
        OZA_1L = OZR_DL[i]
        while k < OZA_1L { OZA_1[k] = OZR_D[(i * 64u64) + k]   k = k + 1u64 }
        k = 0u64
        OZA_2L = OZR_DL[j]
        while k < OZA_2L { OZA_2[k] = OZR_D[(j * 64u64) + k]   k = k + 1u64 }
    } else {
        OZA_1L = OZR_CL[i]
        while k < OZA_1L { OZA_1[k] = OZR_C[(i * 64u64) + k]   k = k + 1u64 }
        k = 0u64
        OZA_2L = OZR_CL[j]
        while k < OZA_2L { OZA_2[k] = OZR_C[(j * 64u64) + k]   k = k + 1u64 }
    }
    OZA_C1 = 0u64
    OZA_C2 = 0u64
    OZE_N = 0u64
    if oz_au_rec() == 0u64 { return 0u64 }
    if OZA_C1 != OZA_1L { return 0u64 }
    if OZA_C2 != OZA_2L { return 0u64 }
    return 1u64
}
fn oz_pat_mv(addr: u64, n: u64) -> u64 {
    let p : *u8 = addr as *u8
    let mut c : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n { if p[i] >= 250u8 { c = c + 1u64 }   i = i + 1u64 }
    return c
}
fn oz_womb_gen() -> u64 {
    OZW_N = 0u64
    OZW_OVF = 0u64
    OZW_DEG = 0u64
    let mut i : u64 = 0u64
    while i < OZR_N {
        let mut j : u64 = i + 1u64
        while j < OZR_N {
            OZMV_N = 0u64
            let mut ok : u64 = oz_au_side(i, j, 0u64)
            let mut pal : u64 = 0u64
            if ok == 1u64 {
                pal = OZE_N
                let mut k : u64 = 0u64
                while k < pal { OZW_PA[(OZW_N * 32u64) + k] = OZE[k]   k = k + 1u64 }
                ok = oz_au_side(i, j, 1u64)   /* SHARED metavar table across sides */
            }
            if ok == 1u64 {
                let pbl : u64 = OZE_N
                let mut k2 : u64 = 0u64
                while k2 < pbl { OZW_PB[(OZW_N * 32u64) + k2] = OZE[k2]   k2 = k2 + 1u64 }
                /* refuse degenerate schemas: no metavar (the pair itself), a
                 * bare-metavar law, or lhs == rhs pattern */
                let mut deg : u64 = 0u64
                if OZMV_N == 0u64 { deg = 1u64 }
                if pal == 1u64 { if OZW_PA[OZW_N * 32u64] >= 250u8 { if pbl == 1u64 { deg = 1u64 } } }
                if pal == pbl {
                    let mut same : u64 = 1u64
                    let mut k3 : u64 = 0u64
                    while k3 < pal {
                        if OZW_PA[(OZW_N * 32u64) + k3] != OZW_PB[(OZW_N * 32u64) + k3] { same = 0u64 }
                        k3 = k3 + 1u64
                    }
                    if same == 1u64 { deg = 1u64 }
                }
                if deg == 1u64 { OZW_DEG = OZW_DEG + 1u64 } else {
                    /* dedup vs stored schemas */
                    let mut dup : u64 = 0u64
                    let mut s : u64 = 0u64
                    while s < OZW_N {
                        if (OZW_PAL[s] as u64) == pal { if (OZW_PBL[s] as u64) == pbl {
                            let mut eq : u64 = 1u64
                            let mut k4 : u64 = 0u64
                            while k4 < pal {
                                if OZW_PA[(s * 32u64) + k4] != OZW_PA[(OZW_N * 32u64) + k4] { eq = 0u64 }
                                k4 = k4 + 1u64
                            }
                            k4 = 0u64
                            while k4 < pbl {
                                if OZW_PB[(s * 32u64) + k4] != OZW_PB[(OZW_N * 32u64) + k4] { eq = 0u64 }
                                k4 = k4 + 1u64
                            }
                            if eq == 1u64 { dup = 1u64 }
                        } }
                        s = s + 1u64
                    }
                    if dup == 0u64 {
                        if OZW_N >= 64u64 { OZW_OVF = OZW_OVF + 1u64 } else {
                            OZW_PAL[OZW_N] = pal as u8
                            OZW_PBL[OZW_N] = pbl as u8
                            OZW_MC[OZW_N] = OZMV_N as u8
                            OZW_N = OZW_N + 1u64
                        }
                    }
                }
            }
            j = j + 1u64
        }
        i = i + 1u64
    }
    return OZW_N
}
/* splice schema s with metavar assignments (POOL indices m0, m1) into OZ_A/OZ_B.
 * The pool is the census store itself (global term indexing: entries 0..17 ARE
 * the generators): 1-metavar schemas range over the whole size<=3 pool, the
 * 2-metavar plane stays on the size<=2 pool (pre-stated budget, counted). */
fn oz_splice(s: u64, side: u64, m0: u64, m1: u64) -> u64 {
    let mut n : u64 = OZW_PAL[s] as u64
    if side == 1u64 { n = OZW_PBL[s] as u64 }
    let mut o : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n {
        let mut b : u8 = 0u8
        if side == 0u64 { b = OZW_PA[(s * 32u64) + i] } else { b = OZW_PB[(s * 32u64) + i] }
        if b >= 250u8 {
            let mut g : u64 = m0
            if b == 251u8 { g = m1 }
            let gl : u64 = OZC_ORIGL[g] as u64
            let mut k : u64 = 0u64
            while k < gl {
                if o < 16u64 {
                    if side == 0u64 { OZ_A[o] = OZC_ORIG[(g * 8u64) + k] } else { OZ_B[o] = OZC_ORIG[(g * 8u64) + k] }
                    o = o + 1u64
                } else { return 99u64 }
                k = k + 1u64
            }
        } else {
            if o < 16u64 {
                if side == 0u64 { OZ_A[o] = b } else { OZ_B[o] = b }
                o = o + 1u64
            } else { return 99u64 }
        }
        i = i + 1u64
    }
    if side == 0u64 { OZ_ALN = o } else { OZ_BLN = o }
    return o
}
/* single-variable candidates: erase WHICH variable (y-only -> x form) */
fn oz_lnorm() -> i64 {
    let mut mask : u64 = 0u64
    let mut i : u64 = 0u64
    while i < OZ_ALN { if OZ_A[i] < 2u8 { mask = mask | (1u64 << (OZ_A[i] as u64)) }   i = i + 1u64 }
    i = 0u64
    while i < OZ_BLN { if OZ_B[i] < 2u8 { mask = mask | (1u64 << (OZ_B[i] as u64)) }   i = i + 1u64 }
    if mask == 2u64 {
        i = 0u64
        while i < OZ_ALN { if OZ_A[i] < 2u8 { OZ_A[i] = 0u8 }   i = i + 1u64 }
        i = 0u64
        while i < OZ_BLN { if OZ_B[i] < 2u8 { OZ_B[i] = 0u8 }   i = i + 1u64 }
    }
    return 0i64
}
/* sieve + stage one womb candidate currently in OZ_A/OZ_B */
fn oz_cand() -> i64 {
    oz_lnorm()
    /* trivial: byte-identical sides */
    if OZ_ALN == OZ_BLN {
        let mut eq : u64 = 1u64
        let mut i : u64 = 0u64
        while i < OZ_ALN { if OZ_A[i] != OZ_B[i] { eq = 0u64 }   i = i + 1u64 }
        if eq == 1u64 { OZW_TRIV = OZW_TRIV + 1u64   return 0i64 }
    }
    /* the die sieve: both sides must agree on the published grid */
    let sa : u64 = oz_sig_w(0u64)
    let sb : u64 = oz_sig_w(1u64)
    if sa != sb { OZW_SIGREJ = OZW_SIGREJ + 1u64   return 0i64 }
    /* canonicalize both sides under the sealed rows */
    let mut i2 : u64 = 0u64
    OZT_L = OZ_ALN
    while i2 < OZ_ALN { OZT[i2] = OZ_A[i2]   i2 = i2 + 1u64 }
    if ozt_norm() > 4096u64 { OZ_SENT = OZ_SENT + 1u64   return 0i64 }
    OZK1_N = OZT_L
    i2 = 0u64
    while i2 < OZT_L { OZK1[i2] = OZT[i2]   i2 = i2 + 1u64 }
    i2 = 0u64
    OZT_L = OZ_BLN
    while i2 < OZ_BLN { OZT[i2] = OZ_B[i2]   i2 = i2 + 1u64 }
    if ozt_norm() > 4096u64 { OZ_SENT = OZ_SENT + 1u64   return 0i64 }
    OZK2_N = OZT_L
    i2 = 0u64
    while i2 < OZT_L { OZK2[i2] = OZT[i2]   i2 = i2 + 1u64 }
    /* already a consequence: identical canonicals */
    if OZK1_N == OZK2_N {
        let mut eq2 : u64 = 1u64
        i2 = 0u64
        while i2 < OZK1_N { if OZK1[i2] != OZK2[i2] { eq2 = 0u64 }   i2 = i2 + 1u64 }
        if eq2 == 1u64 { OZW_ALREADY = OZW_ALREADY + 1u64   return 0i64 }
    }
    /* the conjecture is the CANONICAL pair (what the prover would face) */
    OZ_ALN = OZK1_N
    i2 = 0u64
    while i2 < OZK1_N { OZ_A[i2] = OZK1[i2]   i2 = i2 + 1u64 }
    OZ_BLN = OZK2_N
    i2 = 0u64
    while i2 < OZK2_N { OZ_B[i2] = OZK2[i2]   i2 = i2 + 1u64 }
    /* dedup vs the whole ledger, both orders */
    let mut l : u64 = 0u64
    while l < OZO_N {
        let al : u64 = OZO_AL[l] as u64
        let bl : u64 = OZO_BL[l] as u64
        if al == OZ_ALN { if bl == OZ_BLN {
            let mut eq3 : u64 = 1u64
            let mut k : u64 = 0u64
            while k < al { if OZO_A[(l * 16u64) + k] != OZ_A[k] { eq3 = 0u64 }   k = k + 1u64 }
            k = 0u64
            while k < bl { if OZO_B[(l * 16u64) + k] != OZ_B[k] { eq3 = 0u64 }   k = k + 1u64 }
            if eq3 == 1u64 { OZW_DUP = OZW_DUP + 1u64   return 0i64 }
        } }
        if al == OZ_BLN { if bl == OZ_ALN {
            let mut eq4 : u64 = 1u64
            let mut k2 : u64 = 0u64
            while k2 < al { if OZO_A[(l * 16u64) + k2] != OZ_B[k2] { eq4 = 0u64 }   k2 = k2 + 1u64 }
            k2 = 0u64
            while k2 < bl { if OZO_B[(l * 16u64) + k2] != OZ_A[k2] { eq4 = 0u64 }   k2 = k2 + 1u64 }
            if eq4 == 1u64 { OZW_DUP = OZW_DUP + 1u64   return 0i64 }
        } }
        l = l + 1u64
    }
    if ozo_append(1u64) == 1u64 { OZW_BORN = OZW_BORN + 1u64 }
    return 0i64
}
var OZW_P3 : u64 = 0u64          /* the size<=3 pool bound (census prefix) */
fn oz_womb_inst() -> u64 {
    OZW_P3 = 0u64
    let mut m : i64 = 1i64
    while m <= 3i64 { OZW_P3 = OZW_P3 + ia_tcount(m)   m = m + 1i64 }
    if OZW_P3 > OZC_NT { OZW_P3 = OZC_NT }
    let mut s : u64 = 0u64
    while s < OZW_N {
        let mut lim : u64 = OZW_P3
        if (OZW_MC[s] as u64) >= 2u64 { lim = OZG_N }
        let mut m0 : u64 = 0u64
        while m0 < lim {
            if (OZW_MC[s] as u64) >= 2u64 {
                let mut m1 : u64 = 0u64
                while m1 < OZG_N {
                    if oz_splice(s, 0u64, m0, m1) <= 16u64 { if oz_splice(s, 1u64, m0, m1) <= 16u64 { oz_cand() } }
                    m1 = m1 + 1u64
                }
            } else {
                if oz_splice(s, 0u64, m0, 0u64) <= 16u64 { if oz_splice(s, 1u64, m0, 0u64) <= 16u64 { oz_cand() } }
            }
            m0 = m0 + 1u64
        }
        s = s + 1u64
    }
    return OZW_BORN
}

/* ===================================================================
 * THE SEED (die jitter, recorded), THE METERS, THE DOCKET, THE CERT */
var OZ_SEED : u64 = 0u64
fn oz_seed_die() -> u64 {
    let mut h : u64 = 14695981039346656037u64
    let mut spin : u64 = 1u64
    let mut r : u64 = 0u64
    while r < 64u64 {
        let t0 : u64 = bench_now()
        let lim : u64 = 64u64 + (h & 255u64)
        let mut k : u64 = 0u64
        while k < lim { spin = (spin * 6364136223846793005u64) + 1442695040888963407u64   k = k + 1u64 }
        let t1 : u64 = bench_now()
        h = (h ^ (t1 - t0)) * 1099511628211u64
        h = h ^ (spin >> 61u64)
        r = r + 1u64
    }
    if h == 0u64 { h = 1u64 }
    return h
}
/* measured single-term floors through the friction judge's ser door: a term
 * SELF-RACE passes the truth leg trivially and yields its honest floor --
 * heat only ever orders spend (the tau wall), so band jitter is provenance */
fn oz_meter(i: u64) -> i64 {
    oz_law_load(i)
    let va : i64 = fj_race_sers((&OZ_A) as u64, OZ_ALN, (&OZ_A) as u64, OZ_ALN, 2u64, 3i64)
    if va >= 0i64 { OZO_FA[i] = fj_lhs_floor() }
    oz_law_load(i)
    let vb : i64 = fj_race_sers((&OZ_B) as u64, OZ_BLN, (&OZ_B) as u64, OZ_BLN, 2u64, 3i64)
    if vb >= 0i64 { OZO_FB[i] = fj_lhs_floor() }
    return 0i64
}
var OZD_ORD : [u64; 1024]
var OZD_N   : u64 = 0u64
fn oz_heat_class(i: u64) -> u64 {
    if OZO_ST[i] == 3u8 { return 2u64 }
    if OZO_ST[i] == 4u8 { return 1u64 }
    return 0u64
}
fn oz_docket() -> u64 {
    OZD_N = 0u64
    let mut i : u64 = 0u64
    while i < OZO_N {
        if oz_heat_class(i) > 0u64 { OZD_ORD[OZD_N] = i   OZD_N = OZD_N + 1u64 }
        i = i + 1u64
    }
    /* selection order: class desc, floor-sum desc, ledger index asc */
    let mut a : u64 = 0u64
    while a < OZD_N {
        let mut best : u64 = a
        let mut b : u64 = a + 1u64
        while b < OZD_N {
            let ib : u64 = OZD_ORD[b]
            let ibest : u64 = OZD_ORD[best]
            let cb : u64 = oz_heat_class(ib)
            let cbest : u64 = oz_heat_class(ibest)
            let mut take : u64 = 0u64
            if cb > cbest { take = 1u64 }
            if cb == cbest {
                let fb : u64 = OZO_FA[ib] + OZO_FB[ib]
                let fbest : u64 = OZO_FA[ibest] + OZO_FB[ibest]
                if fb > fbest { take = 1u64 }
                if fb == fbest { if ib < ibest { take = 1u64 } }
            }
            if take == 1u64 { best = b }
            b = b + 1u64
        }
        if best != a {
            let tmp : u64 = OZD_ORD[a]
            OZD_ORD[a] = OZD_ORD[best]
            OZD_ORD[best] = tmp
        }
        a = a + 1u64
    }
    return OZD_N
}
var OZ_CERTV : u64 = 0u64
fn oz_cmix(b: u64) -> i64 {
    OZ_CERTV = (OZ_CERTV ^ (b & 255u64)) * 1099511628211u64
    return 0i64
}
fn oz_cmix64(v: u64) -> i64 {
    let mut w : u64 = 0u64
    while w < 8u64 { oz_cmix(v >> (w * 8u64))   w = w + 1u64 }
    return 0i64
}
fn oz_cert_compute() -> u64 {
    OZ_CERTV = 14695981039346656037u64
    oz_cmix64(OZ_SEED)
    oz_cmix64(cgphys_set_id())
    oz_cmix64(OZC_NT)
    oz_cmix64(OZC_SEM)
    oz_cmix64(OZC_CANN)
    oz_cmix64(OZO_N)
    oz_cmix64(OZW_BORN)
    let mut i : u64 = 0u64
    while i < OZO_N {
        let al : u64 = OZO_AL[i] as u64
        let bl : u64 = OZO_BL[i] as u64
        let mut k : u64 = 0u64
        while k < al { oz_cmix(OZO_A[(i * 16u64) + k] as u64)   k = k + 1u64 }
        oz_cmix(31u64)
        k = 0u64
        while k < bl { oz_cmix(OZO_B[(i * 16u64) + k] as u64)   k = k + 1u64 }
        oz_cmix(30u64)
        oz_cmix(OZO_ST[i] as u64)
        oz_cmix(OZO_PROV[i] as u64)
        oz_cmix(OZO_JD[i] as u64)
        oz_cmix64(OZO_WU[i])
        oz_cmix64(OZO_WV[i])
        oz_cmix64(OZO_DOSE[i])
        i = i + 1u64
    }
    return OZ_CERTV
}

/* ---- law spelling printer over the ledger ---- */
var OZP_I : u64 = 0u64
var OZP_S : u64 = 0u64
var OZP_C : u64 = 0u64
var OZP_L : u64 = 0u64
fn ozp_walk() -> i64 {
    if OZP_C >= OZP_L { return 0i64 }
    let mut b : u8 = 0u8
    if OZP_S == 0u64 { b = OZO_A[(OZP_I * 16u64) + OZP_C] } else { b = OZO_B[(OZP_I * 16u64) + OZP_C] }
    OZP_C = OZP_C + 1u64
    if b == 0u8 { putchar(120i32)   return 0i64 }
    if b == 1u8 { putchar(121i32)   return 0i64 }
    let id : i64 = (b as i64) - 2i64
    putchar(97i32)
    pu(id as u64)
    putchar(40i32)
    ozp_walk()
    if ia_atom_arity(id) == 2i64 { putchar(44i32)   ozp_walk() }
    putchar(41i32)
    return 0i64
}
fn ozp_law(i: u64) -> i64 {
    OZP_I = i
    OZP_S = 0u64
    OZP_C = 0u64
    OZP_L = OZO_AL[i] as u64
    ozp_walk()
    ps("  ==  " as u64)
    OZP_S = 1u64
    OZP_C = 0u64
    OZP_L = OZO_BL[i] as u64
    ozp_walk()
    return 0i64
}

/* ===================================================================
 * THE CONTROLS -- the kill arm proven armed, the sealed rows immune */
var OZ_CTRLOK : u64 = 0u64
fn oz_ctrl() -> u64 {
    /* positive: AND(x,y) = OR(x,y) must DIE with a confirmed witness */
    OZ_A[0u64] = 10u8
    OZ_A[1u64] = 0u8
    OZ_A[2u64] = 1u8
    OZ_ALN = 3u64
    OZ_B[0u64] = 11u8
    OZ_B[1u64] = 0u8
    OZ_B[2u64] = 1u8
    OZ_BLN = 3u64
    if oz_sweep_e() != 1u64 { return 0u64 }
    /* negative: every sealed one-variable row survives the WHOLE stratum --
     * a kill against a 2^64-proven row is the prover and the die in
     * contradiction (the soundness sentinel) */
    let mut r : u64 = 0u64
    while r < OZR_N {
        let mut k : u64 = 0u64
        OZ_ALN = OZR_DL[r]
        while k < OZ_ALN { OZ_A[k] = OZR_D[(r * 64u64) + k]   k = k + 1u64 }
        k = 0u64
        OZ_BLN = OZR_CL[r]
        while k < OZ_BLN { OZ_B[k] = OZR_C[(r * 64u64) + k]   k = k + 1u64 }
        if oz_sweep_e() == 1u64 { OZ_SENT = OZ_SENT + 1u64   return 0u64 }
        r = r + 1u64
    }
    return 1u64
}

/* ===================================================================
 * THE RUN */
fn oz_run(dreamfuel: u64, seed: u64) -> u64 @export {
    ia_init()
    OZ_SENT = 0u64
    OZ_KILL = 0u64
    OZ_SURV = 0u64
    OZ_JOIN = 0u64
    OZ_BAD = 0u64
    OZO_N = 0u64
    OZO_CEN = 0u64
    OZO_OVF = 0u64
    OZW_BORN = 0u64
    OZW_ALREADY = 0u64
    OZW_SIGREJ = 0u64
    OZW_DUP = 0u64
    OZW_TRIV = 0u64
    OZ_CTRLOK = 0u64
    ps("== THE ONEIROS TIER: the dream that must wake (assume -> collapse -> witness | corroborate -> heat) ==\n" as u64)
    ozr_load()
    if OZR_N < 10u64 { ps("oneiros: sealed rules under 10 -- refused\n" as u64)   return 5u64 }
    ps("sealed legislature: " as u64)
    pu(OZR_N)
    ps(" one-variable rows (skipped two-variable twins " as u64)
    pu(OZR_SKIP)
    ps(")   set id " as u64)
    pu(cgphys_set_id())
    putchar(10i32)
    OZ_SEED = seed
    if OZ_SEED == 0u64 {
        OZ_SEED = oz_seed_die()
        ps("SEED=" as u64)
        pu(OZ_SEED)
        ps("  (die jitter, RECORDED -- the replay law: this receipt re-runs bit-identically)\n" as u64)
    } else {
        ps("SEED=" as u64)
        pu(OZ_SEED)
        ps("  (replayed)\n" as u64)
    }
    OZ_RNG = OZ_SEED
    if oz_gen_table() != 0u64 { ps("oneiros: generator envelope refused\n" as u64)   return 5u64 }
    ps("generators: " as u64)
    pu(OZG_N)
    ps(" size<=2 terms, values precomputed over the FULL 16x16 grid = " as u64)
    pu(OZG_N * OZG_N * 256u64)
    ps(" derived points per believed law (stratum E, the fairness floor)\n" as u64)
    /* THE CONTROL PHASE -- the crucible must kill the false and spare the proven */
    OZ_CTRLOK = oz_ctrl()
    if OZ_CTRLOK == 1u64 {
        ps("controls: AND(x,y)=OR(x,y) DIED at (x=" as u64)
        pu(OZ_LWU)
        ps(", y=" as u64)
        pu(OZ_LWV)
        ps(") two-path-confirmed; all " as u64)
        pu(OZR_N)
        ps(" sealed rows SURVIVED the whole stratum\n" as u64)
    } else {
        ps("controls: FAILED (kill arm silent or a sealed row died)\n" as u64)
    }
    /* THE CENSUS */
    if oz_census() != 0u64 { ps("oneiros: census envelope refused\n" as u64)   return 5u64 }
    oz_owed_extract()
    ps("census: terms " as u64)
    pu(OZC_NT)
    ps("  semantic classes " as u64)
    pu(OZC_SEM)
    ps("  canonical classes " as u64)
    pu(OZC_CANN)
    ps("  OWED " as u64)
    pu(OZO_CEN)
    putchar(10i32)
    if (OZC_CANN - OZC_SEM) != OZO_CEN {
        ps("oneiros: owed extraction disagrees with the gap identity -- refused\n" as u64)
        OZ_SENT = OZ_SENT + 1u64
    }
    /* THE WOMB */
    oz_womb_gen()
    oz_womb_inst()
    ps("womb: " as u64)
    pu(OZW_N)
    ps(" schemas (deg " as u64)
    pu(OZW_DEG)
    ps(", ovf " as u64)
    pu(OZW_OVF)
    ps(") -> born " as u64)
    pu(OZW_BORN)
    ps(" conjectures  [already-law " as u64)
    pu(OZW_ALREADY)
    ps(", sig-rejected " as u64)
    pu(OZW_SIGREJ)
    ps(", trivial " as u64)
    pu(OZW_TRIV)
    ps(", dup " as u64)
    pu(OZW_DUP)
    ps(", ledger-ovf " as u64)
    pu(OZO_OVF)
    ps("]\n" as u64)
    /* THE CRUCIBLE -- stratum E for every belief (the fairness floor) */
    let mut i : u64 = 0u64
    let mut printedk : u64 = 0u64
    while i < OZO_N {
        oz_law_load(i)
        if oz_sweep_e() == 1u64 {
            OZO_ST[i] = 1u8
            OZO_WU[i] = OZ_LWU
            OZO_WV[i] = OZ_LWV
            OZO_DOSE[i] = OZO_DOSE[i] + OZ_LDOSE
            OZ_KILL = OZ_KILL + 1u64
            if printedk < 8u64 {
                ps("  ANNIHILATED[E] " as u64)
                ozp_law(i)
                ps("   at (x=" as u64)
                pu(OZ_LWU)
                ps(", y=" as u64)
                pu(OZ_LWV)
                ps(")" as u64)
                if OZO_PROV[i] == 1u8 { ps("  [womb-born]" as u64) }
                putchar(10i32)
                printedk = printedk + 1u64
            }
        } else {
            OZO_DOSE[i] = OZO_DOSE[i] + OZ_LDOSE
        }
        i = i + 1u64
    }
    /* stratum S on the still-standing beliefs */
    i = 0u64
    while i < OZO_N {
        if OZO_ST[i] == 0u8 {
            oz_law_load(i)
            if oz_sweep_s(dreamfuel) == 1u64 {
                OZO_ST[i] = 2u8
                OZO_WU[i] = OZ_LWU
                OZO_WV[i] = OZ_LWV
                OZ_KILL = OZ_KILL + 1u64
                if printedk < 8u64 {
                    ps("  ANNIHILATED[S] " as u64)
                    ozp_law(i)
                    ps("   at (x=" as u64)
                    pu(OZ_LWU)
                    ps(", y=" as u64)
                    pu(OZ_LWV)
                    ps(")" as u64)
                    if OZO_PROV[i] == 1u8 { ps("  [womb-born]" as u64) }
                    putchar(10i32)
                    printedk = printedk + 1u64
                }
            }
            OZO_DOSE[i] = OZO_DOSE[i] + OZ_LDOSE
        }
        i = i + 1u64
    }
    /* THE RIPPLE -- joins predict the prover; a join on a KILLED belief is
     * the soundness sentinel (derivable-from-proven cannot be false) */
    i = 0u64
    while i < OZO_N {
        oz_law_load(i)
        let jd : u64 = oz_ripple()
        if jd != 0u64 {
            if OZO_ST[i] == 0u8 {
                OZO_ST[i] = 3u8
                OZO_JD[i] = jd as u8
                OZ_JOIN = OZ_JOIN + 1u64
            } else {
                OZ_SENT = OZ_SENT + 1u64
                ps("  SENTINEL: killed belief joins the sealed system -- prover and die in contradiction\n" as u64)
            }
        }
        i = i + 1u64
    }
    /* the still-standing remainder SURVIVED the dream */
    i = 0u64
    while i < OZO_N {
        if OZO_ST[i] == 0u8 { OZO_ST[i] = 4u8   OZ_SURV = OZ_SURV + 1u64 }
        i = i + 1u64
    }
    /* THE METERS + THE DOCKET */
    i = 0u64
    while i < OZO_N {
        if oz_heat_class(i) > 0u64 { oz_meter(i) }
        i = i + 1u64
    }
    oz_docket()
    ps("crucible: annihilated " as u64)
    pu(OZ_KILL)
    ps(" beliefs (each leaves a checkable witness), survivors " as u64)
    pu(OZ_SURV)
    ps(", joinable-under-sealed " as u64)
    pu(OZ_JOIN)
    ps(" (prediction: iii-prove PROVES these)\n" as u64)
    ps("THE DOCKET (heat = attention, never truth -- the tau wall; top 16 of " as u64)
    pu(OZD_N)
    ps("):\n" as u64)
    i = 0u64
    while i < OZD_N {
        if i < 16u64 {
            let li : u64 = OZD_ORD[i]
            ps("  #" as u64)
            pu(i)
            if OZO_ST[li] == 3u8 { ps(" JOINABLE(d" as u64)   pu(OZO_JD[li] as u64)   ps(")" as u64) } else { ps(" SURVIVED" as u64) }
            if OZO_PROV[li] == 1u8 { ps(" WOMB" as u64) } else { ps(" CENSUS" as u64) }
            ps("  floors " as u64)
            pu(OZO_FA[li])
            ps("/" as u64)
            pu(OZO_FB[li])
            ps("  dose " as u64)
            pu(OZO_DOSE[li])
            ps("   " as u64)
            ozp_law(li)
            putchar(10i32)
        }
        i = i + 1u64
    }
    oz_cert_compute()
    ps("ONEIROS-CERT=" as u64)
    pu(OZ_CERTV)
    ps("  SENTINEL=" as u64)
    pu(OZ_SENT)
    ps("  (cert excludes floors/timings: same seed, same die, same seal => identical)\n" as u64)
    if OZ_SENT > 0u64 { return 2u64 }
    if OZ_CTRLOK != 1u64 { return 3u64 }
    return 0u64
}

/* ===================================================================
 * THE DOORS (the gate and the driver read the organ, never its stdout) */
fn oz_owed() -> u64 @export { return OZO_CEN }
fn oz_n() -> u64 @export { return OZO_N }
fn oz_kill() -> u64 @export { return OZ_KILL }
fn oz_surv() -> u64 @export { return OZ_SURV }
fn oz_join() -> u64 @export { return OZ_JOIN }
fn oz_sent() -> u64 @export { return OZ_SENT }
fn oz_terms() -> u64 @export { return OZC_NT }
fn oz_sem() -> u64 @export { return OZC_SEM }
fn oz_can() -> u64 @export { return OZC_CANN }
fn oz_cert() -> u64 @export { return OZ_CERTV }
fn oz_seed_used() -> u64 @export { return OZ_SEED }
fn oz_ctrl_ok() -> u64 @export { return OZ_CTRLOK }
fn oz_womb_schemas() -> u64 @export { return OZW_N }
fn oz_womb_born() -> u64 @export { return OZW_BORN }
fn oz_womb_already() -> u64 @export { return OZW_ALREADY }
fn oz_womb_sigrej() -> u64 @export { return OZW_SIGREJ }
fn oz_status(i: u64) -> u64 @export { if i < OZO_N { return OZO_ST[i] as u64 }   return 255u64 }
fn oz_prov(i: u64) -> u64 @export { if i < OZO_N { return OZO_PROV[i] as u64 }   return 255u64 }
fn oz_wu(i: u64) -> u64 @export { if i < OZO_N { return OZO_WU[i] }   return 0u64 }
fn oz_wv(i: u64) -> u64 @export { if i < OZO_N { return OZO_WV[i] }   return 0u64 }
fn oz_dose(i: u64) -> u64 @export { if i < OZO_N { return OZO_DOSE[i] }   return 0u64 }
fn oz_jdepth(i: u64) -> u64 @export { if i < OZO_N { return OZO_JD[i] as u64 }   return 0u64 }
fn oz_floor_a(i: u64) -> u64 @export { if i < OZO_N { return OZO_FA[i] }   return 0u64 }
fn oz_floor_b(i: u64) -> u64 @export { if i < OZO_N { return OZO_FB[i] }   return 0u64 }
fn oz_docket_n() -> u64 @export { return OZD_N }
fn oz_ord(k: u64) -> u64 @export { if k < OZD_N { return OZD_ORD[k] }   return 18446744073709551615u64 }
fn oz_ser(i: u64, side: u64, out_addr: u64) -> u64 @export {
    if i >= OZO_N { return 0u64 }
    let o : *u8 = out_addr as *u8
    let mut n : u64 = OZO_AL[i] as u64
    if side == 1u64 { n = OZO_BL[i] as u64 }
    let mut k : u64 = 0u64
    while k < n {
        if side == 0u64 { o[k] = OZO_A[(i * 16u64) + k] } else { o[k] = OZO_B[(i * 16u64) + k] }
        k = k + 1u64
    }
    return n
}
