/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\aether\pattern_set_federation.iii
 *
 * III STDLIB - aether::pattern_set_federation
 *
 * Phase 2 Step E of v1.0 pivot: sealed pattern-set federation surface.
 *
 * A federated pattern set is a sealed `.iii` pattern bundle identified
 * by its mhash and anchored to a FOUNDERS-ANCHOR-descended ancestry
 * chain.  Three operations:
 *   - PUBLISH: a node registers a locally-held pattern set, exposing it
 *     by mhash for peers to discover and fetch.
 *   - DISCOVER: peers enumerate available pattern sets via their
 *     advertised mhashes (this module's public registry).
 *   - FETCH: a peer pulls the pattern set bytes over a sealed_channel
 *     (capability-handshake gated), verifies the mhash matches the
 *     advertised seal, and verifies ancestry traces to a known anchor
 *     via fed_seal.
 *
 * For v1.0 the in-memory registry holds (mhash, tier, local_set_id)
 * triples.  Real network transport piggybacks on aether/sealed_channel +
 * aether/cap_handshake; for now the FETCH path consumes a sealed-channel
 * stream and exercises the verification chain.
 *
 * Hexad: kind_passage (federation is movement across sovereignty boundaries).
 * Ring: R0.  K: 1.00.
 */

module aether_pattern_set_federation

extern @abi(c-msvc-x64) fn pattern_set_global() -> u64 from "pattern_table.iii"
extern @abi(c-msvc-x64) fn pattern_set_verify(set_ptr: u64) -> u8 from "pattern_table.iii"

extern @abi(c-msvc-x64) fn fed_seal_lookup_anchor(child_tier: u32, child_root_ptr: u64) -> u32 from "fed_seal.iii"
extern @abi(c-msvc-x64) fn fed_seal_anchor_byte(slot: u32, child_or_parent: u32, idx: u32) -> u32 from "fed_seal.iii"

extern @abi(c-msvc-x64) fn sc_send(channel_id: u64, plaintext_ptr: u64, len: u32, tag_out_ptr: u64) -> i32 from "sealed_channel.iii"
extern @abi(c-msvc-x64) fn sc_recv(channel_id: u64, ciphertext_ptr: u64, len: u32, tag_in_ptr: u64) -> i32 from "sealed_channel.iii"

extern @abi(c-msvc-x64) fn sha256_oneshot(in_ptr: *u8, in_len: u64, out_32: *u8) -> u32 from "sha256.iii"

const PSF_OK            : i32 =  0i32
const PSF_E_NULL        : i32 = -1i32
const PSF_E_FULL        : i32 = -2i32
const PSF_E_BAD_HANDLE  : i32 = -3i32
const PSF_E_HASH_MISMATCH : i32 = -4i32
const PSF_E_NO_ANCESTRY : i32 = -5i32
const PSF_E_NO_CHANNEL  : i32 = -6i32

const PSF_NOT_FOUND     : u32 = 0xFFFFFFFFu32

/* Registry capacity: 64 federated pattern sets. */
const PSF_SLOTS : u32 = 64u32

/* Storage. */
var PSF_MHASH    : [u8;  2048]   /* 64 * 32 -- 32-byte mhash per slot */
var PSF_TIER     : [u32; 64]     /* tier in the federation hierarchy */
var PSF_LOCAL_ID : [u64; 64]     /* local pattern_set handle if imported, 0 = external */
var PSF_LIVE     : [u8;  64]
var PSF_USED     : u32 = 0u32

/* Scratch for fetch-payload buffering.  Held module-scope so iiis-0
 * doesn't need to allocate large stack frames. */
var PSF_FETCH_BUF  : [u8; 4096]   /* payload buffer for in-flight transfer */
var PSF_FETCH_TAG  : [u8; 16]
var PSF_FETCH_HASH : [u8; 32]     /* recomputed hash for verification */

fn _psf_slot_of_handle(handle: u64) -> u32 {
    let l_h : u64 = handle
    if l_h == 0u64 { return PSF_NOT_FOUND }
    let s : u64 = l_h - 1u64
    if s >= (PSF_SLOTS as u64) { return PSF_NOT_FOUND }
    let si : u32 = s as u32
    if PSF_LIVE[si] == 0u8 { return PSF_NOT_FOUND }
    return si
}

fn _psf_alloc_slot() -> u32 {
    let mut i : u32 = 0u32
    while i < PSF_SLOTS {
        if PSF_LIVE[i] == 0u8 { return i }
        i = (i + 1u32) & 0xFFFFFFFFu32
    }
    return PSF_NOT_FOUND
}

fn _psf_copy_mhash_in(slot: u32, src_ptr: u64) -> i32 {
    let off : u64 = (slot as u64) * 32u64
    let dst_p : *u8 = ((&PSF_MHASH) as u64 + off) as *u8
    let src_p : *u8 = src_ptr as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        dst_p[i] = src_p[i]
        i = i + 1u64
    }
    return PSF_OK
}

fn _psf_mhash_eq(slot: u32, other_ptr: u64) -> u8 {
    let off : u64 = (slot as u64) * 32u64
    let a_p : *u8 = ((&PSF_MHASH) as u64 + off) as *u8
    let b_p : *u8 = other_ptr as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        if a_p[i] != b_p[i] { return 0u8 }
        i = i + 1u64
    }
    return 1u8
}

/* PUBLISH: register a locally-held pattern set into the federation
 * registry.  The caller supplies the canonical 32-byte mhash (the
 * sealed identity) and the tier in the federation hierarchy.  Returns
 * a handle (slot+1) or 0 on failure. */
fn pattern_set_fed_publish(local_set_id: u64, tier: u32, mhash_ptr: u64) -> u64 @export {
    if mhash_ptr == 0u64 { return 0u64 }
    /* W4.2 (ANCESTRY INVARIANT, complete): the (tier, mhash) pair MUST trace to a known
     * FOUNDERS-ANCHOR-descended anchor in the fed_seal chain BEFORE a slot is allocated -- the
     * identical gate pattern_set_fed_fetch enforces inbound and verify_ancestry checks post-hoc.
     * The outbound publish path previously skipped it, leaving a bootstrap hole where a local
     * caller could register an unvouched (tier, mhash).  Callers MUST fed_seal_anchor(...) the
     * mhash first; an unanchored publish is REJECTED with 0 (no slot allocated). */
    let anchor_slot : u32 = fed_seal_lookup_anchor(tier, mhash_ptr)
    if anchor_slot == 0xFFFFFFFFu32 { return 0u64 }
    let s : u32 = _psf_alloc_slot()
    if s == PSF_NOT_FOUND { return 0u64 }
    _psf_copy_mhash_in(s, mhash_ptr)
    PSF_TIER[s]     = tier
    PSF_LOCAL_ID[s] = local_set_id
    PSF_LIVE[s]     = 1u8
    if PSF_USED < PSF_SLOTS { PSF_USED = PSF_USED + 1u32 }
    return (s as u64) + 1u64
}

fn pattern_set_fed_count() -> u32 @export {
    return PSF_USED
}

fn pattern_set_fed_capacity() -> u32 @export {
    return PSF_SLOTS
}

/* DISCOVER: return the handle of the i-th live entry, or 0 if none. */
fn pattern_set_fed_at(idx: u32) -> u64 @export {
    let l_idx : u32 = idx
    let mut found : u32 = 0u32
    let mut i : u32 = 0u32
    while i < PSF_SLOTS {
        if PSF_LIVE[i] == 1u8 {
            if found == l_idx { return (i as u64) + 1u64 }
            found = (found + 1u32) & 0xFFFFFFFFu32
        }
        i = (i + 1u32) & 0xFFFFFFFFu32
    }
    return 0u64
}

/* Read one byte of the mhash for inspection. */
fn pattern_set_fed_mhash_byte(handle: u64, idx: u32) -> u32 @export {
    let s : u32 = _psf_slot_of_handle(handle)
    if s == PSF_NOT_FOUND { return 0x100u32 }
    if idx >= 32u32 { return 0x100u32 }
    let off : u64 = (s as u64) * 32u64 + (idx as u64)
    let p : *u8 = ((&PSF_MHASH) as u64 + off) as *u8
    return (p[0u64] as u32) & 0xFFu32
}

fn pattern_set_fed_tier(handle: u64) -> u32 @export {
    let s : u32 = _psf_slot_of_handle(handle)
    if s == PSF_NOT_FOUND { return 0xFFFFFFFFu32 }
    return PSF_TIER[s]
}

fn pattern_set_fed_local_id(handle: u64) -> u64 @export {
    let s : u32 = _psf_slot_of_handle(handle)
    if s == PSF_NOT_FOUND { return 0u64 }
    return PSF_LOCAL_ID[s]
}

/* VERIFY ANCESTRY: check that this pattern set's (tier, mhash) is
 * anchored in the fed_seal chain.  Returns 1 if anchored, 0 if not.
 * This is the structural ancestry gate that prevents arbitrary peers
 * from injecting unvouched pattern sets. */
fn pattern_set_fed_verify_ancestry(handle: u64) -> u8 @export {
    let s : u32 = _psf_slot_of_handle(handle)
    if s == PSF_NOT_FOUND { return 0u8 }
    let off : u64 = (s as u64) * 32u64
    let mhash_ptr : u64 = (&PSF_MHASH) as u64 + off
    let anchor_slot : u32 = fed_seal_lookup_anchor(PSF_TIER[s], mhash_ptr)
    if anchor_slot == 0xFFFFFFFFu32 { return 0u8 }
    return 1u8
}

/* FETCH: pull a pattern-set payload from a peer over a sealed_channel.
 * Wire format: [u32 LE length][payload bytes].  After receive, recompute
 * SHA-256(payload) and compare with the advertised mhash.  Mismatch =>
 * PSF_E_HASH_MISMATCH.
 *
 * peer_ch is the sealed_channel handle (must already be established via
 * capability handshake).  target_mhash_ptr is the 32-byte expected
 * mhash.  expected_tier is the federation tier of the source.
 *
 * Returns a new federation handle on success, 0 on failure. */
fn pattern_set_fed_fetch(peer_ch: u64, target_mhash_ptr: u64, expected_tier: u32, payload_len: u32) -> u64 @export {
    if peer_ch == 0u64 { return 0u64 }
    if target_mhash_ptr == 0u64 { return 0u64 }
    if payload_len > 4096u32 { return 0u64 }
    let plen : u32 = payload_len

    /* Receive the payload bytes from the sealed channel. */
    let buf : u64 = (&PSF_FETCH_BUF) as u64
    let tag : u64 = (&PSF_FETCH_TAG) as u64
    let rv : i32 = sc_recv(peer_ch, buf, plen, tag)
    if rv != 0i32 { return 0u64 }

    /* Recompute the hash and compare against the advertised mhash. */
    sha256_oneshot(buf as *u8, (plen as u64) & 0xFFFFFFFFu64, (&PSF_FETCH_HASH) as *u8)
    let expected : *u8 = target_mhash_ptr as *u8
    let computed : *u8 = (&PSF_FETCH_HASH) as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        if computed[i] != expected[i] { return 0u64 }
        i = i + 1u64
    }

    /* W4.2 (ENHANCE-17): ANCESTRY gate.  A correct hash proves integrity, not provenance --
     * the fetch previously omitted its OWN ancestry check, so any peer with a well-formed
     * payload was admitted.  Now the fetched (tier, mhash) MUST trace to a known FOUNDERS-
     * ANCHOR-descended anchor in the fed_seal chain; an unvouched set is REJECTED before any
     * slot is allocated (the same gate pattern_set_fed_verify_ancestry enforces post-import). */
    let anchor_slot : u32 = fed_seal_lookup_anchor(expected_tier, target_mhash_ptr)
    if anchor_slot == 0xFFFFFFFFu32 { return 0u64 }

    /* Hash matches.  Allocate a federation slot and register the (mhash,
     * tier, local_id=0) triple.  local_id is 0 because the payload has
     * not been imported into the local pattern_table yet — that's a
     * separate IMPORT step. */
    let s : u32 = _psf_alloc_slot()
    if s == PSF_NOT_FOUND { return 0u64 }
    _psf_copy_mhash_in(s, target_mhash_ptr)
    PSF_TIER[s]     = expected_tier
    PSF_LOCAL_ID[s] = 0u64
    PSF_LIVE[s]     = 1u8
    if PSF_USED < PSF_SLOTS { PSF_USED = PSF_USED + 1u32 }
    return (s as u64) + 1u64
}

/* SEND: serialise + transmit a locally-held federation entry's payload
 * to a peer.  The caller supplies the sealed_channel handle and the
 * 4096-byte payload buffer.  This module copies the payload into the
 * scratch buffer, encrypts it via sc_send, and writes the auth tag. */
fn pattern_set_fed_send(peer_ch: u64, payload_ptr: u64, payload_len: u32) -> i32 @export {
    if peer_ch == 0u64 { return PSF_E_NO_CHANNEL }
    if payload_ptr == 0u64 { return PSF_E_NULL }
    if payload_len > 4096u32 { return PSF_E_FULL }
    let plen : u32 = payload_len

    let dst_p : *u8 = (&PSF_FETCH_BUF) as *u8
    let src_p : *u8 = payload_ptr as *u8
    let mut i : u64 = 0u64
    let l_plen : u64 = (plen as u64) & 0xFFFFFFFFu64
    while i < l_plen {
        dst_p[i] = src_p[i]
        i = i + 1u64
    }

    let buf : u64 = (&PSF_FETCH_BUF) as u64
    let tag : u64 = (&PSF_FETCH_TAG) as u64
    return sc_send(peer_ch, buf, plen, tag)
}

/* RESET: clear all federation registry entries.  Does NOT touch the
 * underlying sealed channels or local pattern sets. */
fn pattern_set_fed_reset() -> i32 @export {
    let mut i : u32 = 0u32
    while i < PSF_SLOTS {
        PSF_LIVE[i]     = 0u8
        PSF_TIER[i]     = 0u32
        PSF_LOCAL_ID[i] = 0u64
        let off : u64 = (i as u64) * 32u64
        let p : *u8 = ((&PSF_MHASH) as u64 + off) as *u8
        let mut j : u64 = 0u64
        while j < 32u64 {
            p[j] = 0u8
            j = j + 1u64
        }
        i = (i + 1u32) & 0xFFFFFFFFu32
    }
    PSF_USED = 0u32
    return PSF_OK
}
