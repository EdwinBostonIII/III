/* STDLIB/iii/aether/proxenos.iii -- PROXENOS: the sponsor at the door.
 *
 * In the law of xenia the proxenos is the citizen who VOUCHES for a
 * stranger: the guest does not enter on its own word.  This organ is the
 * trust tier for UNTRUSTED PROPOSERS -- a language model, a wild feed, any
 * mouth whose word is not evidence.  The door (xenos) judges COHERENCE:
 * any coherent claim-array may enter as UNSIGNED, novelty and all.  The
 * sponsor judges DERIVABILITY: a proposal passes ONLY if the house can
 * RE-DERIVE every claim of it from what already stands.  Two orthogonal
 * axes, stated plainly:
 *
 *     the door   asks  CAN this be law?        (coherence)
 *     the sponsor asks IS this already law?    (derivability)
 *
 * THE SPONSOR'S LAW:
 *   1  The proposal arrives in the bounded tongue (English) and is CARRIED
 *      to the threshold by anglos (an_transduce) -- the door NOT knocked.
 *   2  Every claim is judged by THE ONE BAROMETER (eol_judge_claim) over
 *      the logos's KEPT house -- the house sealed whole at the start, then
 *      re-stood fresh for every claim, so no claim's parse or interning
 *      ever colours another.  The unraveling counts: a claim never
 *      literally stated but DERIVED (transitivity, congruence, the mirror)
 *      is CONFIRMED.  The sponsor holds no copy of the canon and splits no
 *      claim text of its own: judgment belongs to the logos.
 *   3  ALL claims derivable -> CONFIRMED: the proposal knocks at the one
 *      door (the confirmation is an EVENT, booked in the guest-book), and
 *      the house re-stands WHOLE from the kept house -- confirming a
 *      subset never narrows the scroll.
 *   4  ANY claim underivable -> NOVEL, WHOLE (the mixed proposal admits
 *      nothing -- the whole-utterance law at the trust tier).  The novel
 *      claims are NOT knowledge and NOT admitted; they are READABLE as the
 *      QUESTION HARVEST -- what an untrusted mouth would have the house
 *      believe is exactly what the house should next seek to derive or
 *      refute (the zetesis seam: a future asking organ consumes this
 *      surface; today it is counted and readable, never silent).
 *   5  A proposal the surface cannot carry at all (command, modality,
 *      alien bytes...) is REFUSED with anglos's own named reason; a
 *      proposal with no statement (questions only) is REFUSED -- asking
 *      is the tongue's own face, not the sponsor's.
 *
 * A model can therefore NEVER inject novelty into the house through this
 * organ -- it can only CONFIRM what the house derives, or hand the house
 * QUESTIONS.  That is the honest shape of "an AI smooths the boundary":
 * the machine consumes the model without ever trusting it.
 *
 * Truth is a CONDITION OF MOTION: px_selfprove (arms 400..404, 421..424)
 * re-derives every law above at every invocation.  NO gate, NO KAT (the
 * kardia pattern).  NIH: composes aether/anglos (the tongue), aether/xenos
 * (THE ONE DOOR), omnia/eidolos (THE ONE BAROMETER and its kept house).
 * Hexad: kind_passage.  Ring R0. */
module aether_proxenos

extern @abi(c-msvc-x64) fn an_transduce(base: u64, len: u64) -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_hear_text(s: u64) -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_verdict() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_reason() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_claims() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_questions() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_claim_len(i: u64) -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_claim_byte(i: u64, k: u64) -> u8 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_scroll_len() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_scroll_byte(i: u64) -> u8 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_addr() -> u64 from "anglos.iii"

extern @abi(c-msvc-x64) fn xn_admit(base: u64, len: u64) -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_last_addr() -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_last_epoch() -> u64 from "xenos.iii"

extern @abi(c-msvc-x64) fn eol_reset() -> i32 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_read(addr: u64, len: u64) -> i64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_write() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_out_len() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_out_byte(i: u64) -> u8 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_addr() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_entails(a: u64, al: u64, v: u64, b: u64, bl: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_keep() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_restand() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_judge_claim(base: u64, len: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_verify(base: u64, len: u64, expect: u64) -> u64 from "eidolos.iii"

extern @abi(c-msvc-x64) fn xn_rooted() -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fread(buf: u64, sz: u64, n: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fwrite(buf: u64, sz: u64, n: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(stream: u64) -> i32 from "msvcrt"

const PX_SENT : u64 = 18446744073709551615u64
/* verdicts */
const PX_V_CONFIRMED : u64 = 1u64        /* every claim re-derived; booked     */
const PX_V_NOVEL     : u64 = 2u64        /* not knowledge -- a question harvest */
const PX_V_REFUSED   : u64 = 3u64        /* the surface refused it (an_reason) */

/* ==================== the sponsor's state ====================
 * No copy of the house canon lives here -- the standing knowledge is the
 * logos's kept house, sealed at propose and re-stood by the barometer. */
var PX_SCR : [u8; 8192]                  /* the proposal scroll (for the knock)  */
var PX_CT : [u8; 1088]                   /* one claim's text, judged whole       */

var PX_VERDICT : u64 = 0u64
var PX_ADDR : u64 = 0u64                 /* the confirmation's booked address    */
var PX_NIDX : [u64; 16]                  /* novel claim indexes (into anglos)    */
var PX_NN : u64 = 0u64
/* totals (every proposal counted, never silent) */
var PX_TCONF : u64 = 0u64
var PX_TNOV : u64 = 0u64
var PX_TREF : u64 = 0u64

/* ==================== THE SPONSORSHIP ==================== */
fn px_propose(base: u64, len: u64) -> u64 @export {
    PX_VERDICT = 0u64
    PX_ADDR = 0u64
    PX_NN = 0u64
    let t : u64 = an_transduce(base, len)
    if t != 4u64 { PX_VERDICT = PX_V_REFUSED   PX_TREF = PX_TREF + 1u64   return PX_V_REFUSED }
    if an_claims() == 0u64 { PX_VERDICT = PX_V_REFUSED   PX_TREF = PX_TREF + 1u64   return PX_V_REFUSED }
    /* seal the house's FULL standing knowledge as the logos's kept house
     * (the barometer re-stands it fresh for every claim; the knock will
     * replace the transient scroll; the house must never narrow by
     * confirming).  An incoherent standing scroll cannot vouch: the empty
     * house is kept instead and every claim judges novel. */
    if eol_keep() == 0u64 {
        eol_reset()
        eol_keep()
    }
    /* the test: every claim must RE-DERIVE from what stands */
    let nc : u64 = an_claims()
    let mut ci : u64 = 0u64
    while ci < nc {
        let cl : u64 = an_claim_len(ci)
        let mut ok : u64 = 0u64
        if cl > 0u64 { if cl <= 1088u64 {
            let mut k : u64 = 0u64
            while k < cl { PX_CT[k] = an_claim_byte(ci, k)   k = k + 1u64 }
            if eol_judge_claim((&PX_CT) as u64, cl) == 1u64 { ok = 1u64 }
        } }
        if ok == 0u64 {
            if PX_NN < 16u64 { PX_NIDX[PX_NN] = ci   PX_NN = PX_NN + 1u64 }
        }
        ci = ci + 1u64
    }
    if PX_NN > 0u64 {
        /* NOVEL, WHOLE: nothing admitted; the question harvest stands */
        PX_VERDICT = PX_V_NOVEL
        PX_TNOV = PX_TNOV + 1u64
        return PX_V_NOVEL
    }
    /* CONFIRMED: the knock is the event (booked at the one door) */
    let sn : u64 = an_scroll_len()
    let mut i : u64 = 0u64
    while i < sn { PX_SCR[i] = an_scroll_byte(i)   i = i + 1u64 }
    let v : u64 = xn_admit((&PX_SCR) as u64, sn)
    if v != 1u64 { PX_VERDICT = PX_V_REFUSED   PX_TREF = PX_TREF + 1u64   return PX_V_REFUSED }
    PX_ADDR = xn_last_addr()
    /* the house re-stands WHOLE (confirmation never narrows the scroll) */
    if eol_restand() == 0u64 { PX_VERDICT = PX_V_REFUSED   PX_TREF = PX_TREF + 1u64   return PX_V_REFUSED }
    PX_VERDICT = PX_V_CONFIRMED
    PX_TCONF = PX_TCONF + 1u64
    return PX_V_CONFIRMED
}
fn px_slen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut n : u64 = 0u64
    while p[n] != 0u8 { n = n + 1u64 }
    return n
}
fn px_propose_text(s: u64) -> u64 @export { return px_propose(s, px_slen(s)) }

/* ==================== the sponsor's surface ==================== */
fn px_verdict() -> u64 @export { return PX_VERDICT }
fn px_addr() -> u64 @export { return PX_ADDR }
fn px_novel_count() -> u64 @export { return PX_NN }
fn px_novel_idx(j: u64) -> u64 @export { if j < PX_NN { return PX_NIDX[j] }   return PX_SENT }
/* totals: 0 confirmed | 1 novel | 2 refused */
fn px_stat(k: u64) -> u64 @export {
    if k == 0u64 { return PX_TCONF }
    if k == 1u64 { return PX_TNOV }
    if k == 2u64 { return PX_TREF }
    return 0u64
}

/* THE TESTIMONY (the boundary synod, census seat 10): the sponsor's own
 * proven laws -- a proposal is an utterance at the threshold, novelty
 * converts to questions, confirmation IS re-derivation. */
fn px_testify() -> u64 @export {
    return "[proposal < utterance] [novelty = question] [confirmation = rederivation]" as u64
}

/* ==================== THE EROTEMA: the question-ledger ====================
 * A proposal's novelty is not knowledge -- but it is not nothing.  It is
 * exactly what an untrusted mouth would have the house believe and the
 * house could NOT derive: the next thing to seek or refute.  THE EROTEMA
 * persists that harvest with the zetesis/guest-book discipline -- a
 * self-verifying journal (STDLIB/data/erotema.jrnl) whose every line is
 * `<address> <question-claim>`, the address the eol_addr of the claim text
 * so a tampered question is a RED question (the whole ledger refuses; the
 * verification is the logos's own eol_verify).  Appends are content-
 * addressed and IDEMPOTENT (the same open question never doubles); an
 * absent ledger is a lawful BIRTH.  This is the honest "zetesis seam": the
 * machine's durable account of the questions untrusted mouths pressed on
 * it -- a future seeking pass (or a human) works it down; a confirmed-
 * later question simply stops re-appearing as the house grows.  The
 * ledger is HISTORY, not truth: nothing here is admitted, ever. */
var PX_JB : [u8; 16384]                  /* ledger read buffer                  */
var PX_LINE : [u8; 512]                  /* one line build                      */
var PX_QC : [u8; 256]                    /* canonical question claim            */
var PX_QCN : u64 = 0u64
var PX_LADDR : u64 = 0u64                /* last verified line address          */
var PX_TJOURNAL : u64 = 0u64             /* questions journaled, lifetime       */
var PX_JN : u64 = 0u64                   /* bytes held from the last verify     */
fn px_ledger_len() -> u64 @export { return PX_JN }
fn px_ledger_byte(i: u64) -> u8 @export { if i < PX_JN { return PX_JB[i] }   return 0u8 }

/* canonicalize novel claim ci into PX_QC and return its address (0 = bad) */
fn px_qcanon(ci: u64) -> u64 {
    PX_QCN = 0u64
    let n : u64 = an_claim_len(ci)
    if n == 0u64 { return 0u64 }
    if n > 256u64 { return 0u64 }
    let mut i : u64 = 0u64
    while i < n { PX_QC[i] = an_claim_byte(ci, i)   i = i + 1u64 }
    eol_reset()
    if eol_read((&PX_QC) as u64, n) < 0i64 { eol_reset()   return 0u64 }
    let a : u64 = eol_addr()
    if a == 0u64 { eol_reset()   return 0u64 }
    eol_write()
    let cn : u64 = eol_out_len()
    if cn == 0u64 { eol_reset()   return 0u64 }
    if cn > 256u64 { eol_reset()   return 0u64 }
    i = 0u64
    while i < cn { PX_QC[i] = eol_out_byte(i)   i = i + 1u64 }
    PX_QCN = cn
    eol_reset()
    return a
}
/* the exclusive end of the line starting at `off` in PX_JB[0,jn) -- the
 * index of its terminating '\n', or jn if the last line is unterminated. */
fn px_line_end(off: u64, jn: u64) -> u64 {
    let mut e : u64 = off
    while e < jn {
        if PX_JB[e] == 10u8 { return e }
        e = e + 1u64
    }
    return jn
}
/* the claim-start offset within a line [off,end): index just past the first
 * space, or `end` (no space -> malformed, caller rejects on cn==0). */
fn px_claim_start(off: u64, end: u64) -> u64 {
    let mut s : u64 = off
    while s < end {
        if PX_JB[s] == 32u8 { return s + 1u64 }
        s = s + 1u64
    }
    return end
}
/* verify one ledger line [off,end): "<digits> <claim>" whose claim's
 * address re-derives to <digits> -- the logos's own verification.  Sets
 * PX_LADDR.  0 ok | 1 tamper. */
fn px_vline(off: u64, end: u64) -> u64 {
    if (end - off) < 3u64 { return 1u64 }
    let cb : u64 = px_claim_start(off, end)
    if cb >= end { return 1u64 }
    /* the address digits are [off, cb-1) */
    let mut a : u64 = 0u64
    let mut nd : u64 = 0u64
    let mut i : u64 = off
    while i < (cb - 1u64) {
        let c : u8 = PX_JB[i]
        if c < 48u8 { return 1u64 }
        if c > 57u8 { return 1u64 }
        a = (a * 10u64) + ((c - 48u8) as u64)
        nd = nd + 1u64
        i = i + 1u64
    }
    if nd == 0u64 { return 1u64 }
    let cn : u64 = end - cb
    if cn == 0u64 { return 1u64 }
    if eol_verify(((&PX_JB) as u64) + cb, cn, a) != 1u64 { return 1u64 }
    PX_LADDR = a
    return 0u64
}
/* verify the whole ledger; returns line count, or PX_SENT on tamper. */
fn px_erotema_verify(path: u64) -> u64 @export {
    let f : u64 = fopen(path, "rb" as u64)
    if f == 0u64 { return 0u64 }
    let jn : u64 = fread((&PX_JB) as u64, 1u64, 16384u64, f)
    fclose(f)
    PX_JN = 0u64
    if jn >= 16384u64 { return PX_SENT }
    let mut off : u64 = 0u64
    let mut kc : u64 = 0u64
    while off < jn {
        let end : u64 = px_line_end(off, jn)
        if end == off { return PX_SENT }
        if px_vline(off, end) != 0u64 { return PX_SENT }
        kc = kc + 1u64
        off = end + 1u64
    }
    PX_JN = jn
    return kc
}
/* is canonical claim PX_QC[0,PX_QCN) already a line in PX_JB[0,jn)? */
fn px_present(jn: u64) -> u64 {
    let mut off : u64 = 0u64
    while off < jn {
        let end : u64 = px_line_end(off, jn)
        let cb : u64 = px_claim_start(off, end)
        if cb < end {
            let cn : u64 = end - cb
            if cn == PX_QCN {
                let mut same : u64 = 1u64
                let mut b : u64 = 0u64
                while b < PX_QCN {
                    if PX_JB[cb + b] != PX_QC[b] { same = 0u64   b = PX_QCN }
                    b = b + 1u64
                }
                if same == 1u64 { return 1u64 }
            }
        }
        off = end + 1u64
    }
    return 0u64
}
/* append every novel claim of the LAST proposal to the ledger, idempotently.
 * Returns the number of NEW questions written (0 = all already present, or
 * not rooted, or nothing novel).  A tampered ledger is refused (no write). */
fn px_harvest_journal(path: u64) -> u64 @export {
    if PX_NN == 0u64 { return 0u64 }
    if xn_rooted() != 1u64 { return 0u64 }
    if px_erotema_verify(path) == PX_SENT { return 0u64 }
    let mut jn : u64 = 0u64
    let f : u64 = fopen(path, "rb" as u64)
    if f != 0u64 {
        jn = fread((&PX_JB) as u64, 1u64, 16384u64, f)
        fclose(f)
        if jn >= 16384u64 { return 0u64 }
    }
    let mut written : u64 = 0u64
    let mut j : u64 = 0u64
    while j < PX_NN {
        let ci : u64 = PX_NIDX[j]
        let a : u64 = px_qcanon(ci)
        if a != 0u64 {
            if px_present(jn) == 0u64 {
                /* build "<addr> <claim>\n" and append */
                let mut m : u64 = 0u64
                let mut div : u64 = 1u64
                let mut t : u64 = a
                while t >= 10u64 { div = div * 10u64   t = t / 10u64 }
                t = a
                let mut going : u64 = 1u64
                while going == 1u64 {
                    PX_LINE[m] = (48u64 + (t / div)) as u8
                    m = m + 1u64
                    t = t % div
                    if div == 1u64 { going = 0u64 } else { div = div / 10u64 }
                }
                PX_LINE[m] = 32u8   m = m + 1u64
                let mut k : u64 = 0u64
                while k < PX_QCN { PX_LINE[m] = PX_QC[k]   m = m + 1u64   k = k + 1u64 }
                PX_LINE[m] = 10u8   m = m + 1u64
                let g : u64 = fopen(path, "ab" as u64)
                if g != 0u64 {
                    fwrite((&PX_LINE) as u64, 1u64, m, g)
                    fclose(g)
                    /* mirror into the image so a later dup in THIS harvest
                     * is seen as present (idempotent within one call too) */
                    let mut w : u64 = 0u64
                    while w < m { if jn < 16384u64 { PX_JB[jn] = PX_LINE[w]   jn = jn + 1u64 }   w = w + 1u64 }
                    written = written + 1u64
                    PX_TJOURNAL = PX_TJOURNAL + 1u64
                }
            }
        }
        j = j + 1u64
    }
    return written
}
fn px_journaled() -> u64 @export { return PX_TJOURNAL }

/* ==================== THE ANAGNORISIS: recognition ====================
 * The erotema accumulates what the house could not derive.  But knowledge
 * grows -- and a question the house can NOW derive is no longer open: it is
 * RECOGNIZED (the machine's word for "I have come to know this").  Sweep
 * the ledger against the logos's KEPT house (the caller seals it -- the
 * hearth's stand, or any grown scroll kept whole): every question the
 * house now entails is RETIRED (dropped from the ledger, its derivation
 * the witness); the rest remain open.  The ledger is rewritten to the
 * survivors, still self-verifying.  This closes the epistemic loop --
 * propose, question, (the house grows), recognize, retire -- so the
 * erotema is a LIVE agenda that shrinks toward zero as the mind learns,
 * never a dead pile.
 *
 * Each question is judged by THE ONE BAROMETER (eol_judge_claim), which
 * re-stands the kept house before every test, so one question's parse
 * never colours the next.  A retired question is NOT admitted anywhere --
 * recognition is derivation, and the house already holds the knowledge
 * that makes it derivable. */
var PX_OUT : [u8; 16384]                 /* the rewritten (survivor) ledger     */
var PX_RECOG : u64 = 0u64                /* recognized this sweep               */
fn px_recognized() -> u64 @export { return PX_RECOG }

/* recognize: sweep the ledger against the kept house.  Retires every
 * derivable question; rewrites the ledger to the survivors.  Returns the
 * number RECOGNIZED, or PX_SENT on a tampered/absent-rooted ledger (no
 * rewrite). */
fn px_recognize(path: u64) -> u64 @export {
    PX_RECOG = 0u64
    if xn_rooted() != 1u64 { return PX_SENT }
    let vc : u64 = px_erotema_verify(path)
    if vc == PX_SENT { return PX_SENT }
    if vc == 0u64 { return 0u64 }
    /* px_erotema_verify left the bytes and length in PX_JB / PX_JN */
    let jn : u64 = PX_JN
    let mut off : u64 = 0u64
    let mut outn : u64 = 0u64
    let mut recog : u64 = 0u64
    while off < jn {
        let end : u64 = px_line_end(off, jn)
        let cb : u64 = px_claim_start(off, end)
        let mut keep : u64 = 1u64
        if cb < end {
            let cn : u64 = end - cb
            if eol_judge_claim(((&PX_JB) as u64) + cb, cn) == 1u64 { keep = 0u64   recog = recog + 1u64 }
        }
        if keep == 1u64 {
            /* copy the whole line (with its newline) to the survivor buffer */
            let mut k : u64 = off
            while k < end { if outn < 16384u64 { PX_OUT[outn] = PX_JB[k]   outn = outn + 1u64 }   k = k + 1u64 }
            if outn < 16384u64 { PX_OUT[outn] = 10u8   outn = outn + 1u64 }
        }
        off = end + 1u64
    }
    eol_reset()
    if recog == 0u64 { return 0u64 }
    /* rewrite the ledger to the survivors (may be empty -- a fully learned
     * agenda is a truncated file, lawful) */
    let g : u64 = fopen(path, "wb" as u64)
    if g == 0u64 { return PX_SENT }
    if outn > 0u64 { fwrite((&PX_OUT) as u64, 1u64, outn, g) }
    fclose(g)
    PX_RECOG = recog
    return recog
}

/* ==================== THE SELF-PROOF (arms 400..404, 421..424) ==================== */
fn px_ent(a: u64, v: u64, b: u64) -> u64 {
    return eol_entails(a, px_slen(a), v, b, px_slen(b))
}
/* arm 400: THE CONFIRMATION -- a proposal never literally stated but
 * DERIVED (transitivity) is confirmed, booked at the one door, and the
 * house re-stands WHOLE: the old knowledge survives its own confirmation. */
fn px_arm400() -> u64 {
    if an_hear_text("a dog is an animal and an animal is a thing" as u64) != 1u64 { return 400u64 }
    let s : u64 = an_addr()
    if s == 0u64 { return 400u64 }
    if px_propose_text("a dog is a thing" as u64) != 1u64 { return 400u64 }
    if px_addr() == 0u64 { return 400u64 }
    if px_addr() == s { return 400u64 }
    if eol_addr() != s { return 400u64 }
    if px_ent("dog" as u64, 0u64, "animal" as u64) != 1u64 { return 400u64 }
    if px_ent("dog" as u64, 0u64, "thing" as u64) != 1u64 { return 400u64 }
    return 0u64
}
/* arm 401: THE NOVELTY -- an underivable proposal admits NOTHING; the
 * door is untouched and the claim stands readable as a question. */
fn px_arm401() -> u64 {
    if an_hear_text("a dog is an animal and an animal is a thing" as u64) != 1u64 { return 401u64 }
    let xh : u64 = xn_last_addr()
    if px_propose_text("a dog is a machine" as u64) != 2u64 { return 401u64 }
    if xn_last_addr() != xh { return 401u64 }
    if px_novel_count() != 1u64 { return 401u64 }
    if px_novel_idx(0u64) != 0u64 { return 401u64 }
    if an_claim_len(0u64) != 15u64 { return 401u64 }
    if an_claim_byte(0u64, 0u64) != 91u8 { return 401u64 }
    return 0u64
}
/* arm 402: THE WHOLE-PROPOSAL LAW -- one underivable claim poisons the
 * proposal: the derivable companion is NOT admitted either. */
fn px_arm402() -> u64 {
    if an_hear_text("a dog is an animal and an animal is a thing" as u64) != 1u64 { return 402u64 }
    let xh : u64 = xn_last_addr()
    if px_propose_text("a dog is an animal and a dog is a machine" as u64) != 2u64 { return 402u64 }
    if an_claims() != 2u64 { return 402u64 }
    if px_novel_count() != 1u64 { return 402u64 }
    if px_novel_idx(0u64) != 1u64 { return 402u64 }
    if xn_last_addr() != xh { return 402u64 }
    return 0u64
}
/* arm 403: THE SURFACE PASSES THROUGH -- a proposal the tongue refuses
 * (a command) or one with no statement (a bare question) is REFUSED with
 * the named reason; nothing is tested, nothing admitted. */
fn px_arm403() -> u64 {
    let r0 : u64 = px_stat(2u64)
    if px_propose_text("send the key" as u64) != 3u64 { return 403u64 }
    if an_verdict() != 2u64 { return 403u64 }
    if an_reason() != 2u64 { return 403u64 }
    if px_propose_text("is a dog an animal" as u64) != 3u64 { return 403u64 }
    if px_stat(2u64) != (r0 + 2u64) { return 403u64 }
    return 0u64
}
/* arm 404: DETERMINISM AND THE EMPTY HOUSE -- the same proposal sponsors
 * identically twice; over an empty scroll nothing can be confirmed (the
 * sponsor cannot vouch from nothing). */
fn px_arm404() -> u64 {
    if an_hear_text("a dog is an animal" as u64) != 1u64 { return 404u64 }
    if px_propose_text("a dog is an animal" as u64) != 1u64 { return 404u64 }
    let a1 : u64 = px_addr()
    if px_propose_text("a dog is an animal" as u64) != 1u64 { return 404u64 }
    if px_addr() != a1 { return 404u64 }
    eol_reset()
    if px_propose_text("a dog is an animal" as u64) != 2u64 { return 404u64 }
    if px_novel_count() != 1u64 { return 404u64 }
    eol_reset()
    return 0u64
}
/* the erotema self-proof dwells in a build-territory ledger, never the
 * real one. */
fn px_jpath() -> u64 { return "STDLIB/build/erotema_arm.jrnl" as u64 }
fn px_jerase() -> u64 {
    if xn_rooted() != 1u64 { return 1u64 }
    let f : u64 = fopen(px_jpath(), "wb" as u64)
    if f == 0u64 { return 1u64 }
    fclose(f)
    return 0u64
}
/* arm 421: THE HARVEST JOURNALED -- a novel proposal's questions are
 * written to the self-verifying ledger, the ledger verifies, and a
 * SECOND journaling of the same harvest writes NOTHING (idempotent). */
fn px_arm421() -> u64 {
    if px_jerase() != 0u64 { return 421u64 }
    if px_erotema_verify(px_jpath()) != 0u64 { return 421u64 }   /* birth: empty */
    eol_reset()
    if an_hear_text("a dog is an animal" as u64) != 1u64 { return 421u64 }
    if px_propose_text("a dog is a machine" as u64) != 2u64 { return 421u64 }
    if px_novel_count() != 1u64 { return 421u64 }
    if px_harvest_journal(px_jpath()) != 1u64 { return 421u64 }
    if px_erotema_verify(px_jpath()) != 1u64 { return 421u64 }
    /* idempotent: the same open question never doubles */
    if an_hear_text("a dog is an animal" as u64) != 1u64 { return 421u64 }
    if px_propose_text("a dog is a machine" as u64) != 2u64 { return 421u64 }
    if px_harvest_journal(px_jpath()) != 0u64 { return 421u64 }
    if px_erotema_verify(px_jpath()) != 1u64 { return 421u64 }
    return 0u64
}
/* arm 422: THE ACCUMULATING LEDGER -- a second, different novelty grows
 * the ledger to two lines; each remains self-verifying. */
fn px_arm422() -> u64 {
    if an_hear_text("a dog is an animal" as u64) != 1u64 { return 422u64 }
    if px_propose_text("a dog is a mineral" as u64) != 2u64 { return 422u64 }
    if px_harvest_journal(px_jpath()) != 1u64 { return 422u64 }
    if px_erotema_verify(px_jpath()) != 2u64 { return 422u64 }
    return 0u64
}
/* arm 423: THE TAMPER -- one flipped byte in a journaled question and the
 * WHOLE ledger refuses (a red question), and no append proceeds over it. */
fn px_arm423() -> u64 {
    let f : u64 = fopen(px_jpath(), "rb" as u64)
    if f == 0u64 { return 423u64 }
    let n : u64 = fread((&PX_JB) as u64, 1u64, 16384u64, f)
    fclose(f)
    if n < 2u64 { return 423u64 }
    PX_JB[n - 2u64] = PX_JB[n - 2u64] ^ 1u8
    let g : u64 = fopen(px_jpath(), "wb" as u64)
    if g == 0u64 { return 423u64 }
    fwrite((&PX_JB) as u64, 1u64, n, g)
    fclose(g)
    if px_erotema_verify(px_jpath()) != PX_SENT { return 423u64 }
    /* a harvest over a tampered ledger writes nothing */
    if an_hear_text("a dog is an animal" as u64) != 1u64 { return 423u64 }
    if px_propose_text("a dog is a vapour" as u64) != 2u64 { return 423u64 }
    if px_harvest_journal(px_jpath()) != 0u64 { return 423u64 }
    /* restore a clean ledger so the arm leaves no red state behind */
    if px_jerase() != 0u64 { return 423u64 }
    eol_reset()
    return 0u64
}
/* arm 424: THE ANAGNORISIS -- the loop closed.  A mouth proposes two
 * novelties over a small house; both are journaled as open questions.  The
 * house then GROWS to derive exactly one of them; a sweep RECOGNIZES that
 * one, retires it, and leaves the other open -- the erotema is a live
 * agenda that shrinks as the mind learns. */
fn px_arm424() -> u64 {
    if px_jerase() != 0u64 { return 424u64 }
    eol_reset()
    /* a small house: dog < animal.  propose dog<thing and dog<mineral --
     * both NOVEL (the house cannot derive either yet) */
    if an_hear_text("a dog is an animal" as u64) != 1u64 { return 424u64 }
    if px_propose_text("a dog is a thing and a dog is a mineral" as u64) != 2u64 { return 424u64 }
    if px_novel_count() != 2u64 { return 424u64 }
    if px_harvest_journal(px_jpath()) != 2u64 { return 424u64 }
    if px_erotema_verify(px_jpath()) != 2u64 { return 424u64 }
    /* THE HOUSE GROWS: animal < thing.  Now dog<thing is DERIVABLE
     * (transitive) but dog<mineral is still not.  Seal the grown house as
     * the logos's KEPT house -- recognition judges over the one barometer. */
    eol_reset()
    if eol_read("[dog < animal] [animal < thing]" as u64, 31u64) < 0i64 { return 424u64 }
    if eol_keep() == 0u64 { return 424u64 }
    /* SWEEP: recognize what the grown house now derives */
    let rec : u64 = px_recognize(px_jpath())
    if rec != 1u64 { return 424u64 }
    if px_recognized() != 1u64 { return 424u64 }
    /* one question retired, one remains -- and the survivor is dog<mineral */
    if px_erotema_verify(px_jpath()) != 1u64 { return 424u64 }
    /* a second sweep recognizes NOTHING more (the survivor is still open) */
    eol_reset()
    if eol_read("[dog < animal] [animal < thing]" as u64, 31u64) < 0i64 { return 424u64 }
    if eol_keep() == 0u64 { return 424u64 }
    if px_recognize(px_jpath()) != 0u64 { return 424u64 }
    if px_erotema_verify(px_jpath()) != 1u64 { return 424u64 }
    if px_jerase() != 0u64 { return 424u64 }
    eol_reset()
    return 0u64
}
fn px_selfprove() -> u64 @export {
    let mut r : u64 = px_arm400()
    if r != 0u64 { return r }
    r = px_arm401()
    if r != 0u64 { return r }
    r = px_arm402()
    if r != 0u64 { return r }
    r = px_arm403()
    if r != 0u64 { return r }
    r = px_arm404()
    if r != 0u64 { return r }
    r = px_arm421()
    if r != 0u64 { return r }
    r = px_arm422()
    if r != 0u64 { return r }
    r = px_arm423()
    if r != 0u64 { return r }
    r = px_arm424()
    if r != 0u64 { return r }
    return 0u64
}
