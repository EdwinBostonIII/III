/* THE BORN CROSS-ORACLE (the kyma seam, from the pz side).  kyma holds an
 * amplitude as four integer coordinates in Z[zeta], zeta = e^{i pi/4}, over
 * a global 1/sqrt2^K.  pz_from_zeta4 VALUES that encoding in the tower:
 * zeta = (1+i)/sqrt2, zeta^2 = i, zeta^3 = (-1+i)/sqrt2.  Two independent
 * engines then meet: |z|^2 by the TOWER (re^2+im^2 through the pair field)
 * versus |z|^2 by the RING (z zbar = A + B sqrt2 with A = sum a_i^2,
 * B = a0a1+a1a2+a2a3-a0a3 -- pure integer combinatorics).  One truth. */
fn pz_from_zeta4(a0: i64, a1: i64, a2: i64, a3: i64, kk: u64) -> u64 @export {
    let s2 : u64 = py_sqrt(py_el_from_i64(2i64, 0u64))
    let i2 : u64 = py_div(py_el_from_i64(1i64, 0u64), s2)
    let re : u64 = py_add(py_el_from_i64(a0, 0u64), py_mul(py_el_from_i64(a1 - a3, 0u64), i2))
    let im : u64 = py_add(py_el_from_i64(a2, 0u64), py_mul(py_el_from_i64(a1 + a3, 0u64), i2))
    let mut sc : u64 = py_el_from_i64(1i64, 0u64)
    let mut t : u64 = 0u64
    while t < kk { sc = py_mul(sc, i2)   t = t + 1u64 }
    return pz_mk(py_mul(re, sc), py_mul(im, sc))
}
