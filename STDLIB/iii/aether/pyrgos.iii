    let n1 : u64 = py_add(py_el_from_i64(6i64, 0u64), py_mul(py_el_from_i64(3i64, 0u64), s2))
    if py_cmp(pz_norm2(w), n1) != 0i64 { return 194u64 }
    /* (2,-1,3,1): A = 4+1+9+1 = 15, B = -2-3+3-2 = -4 */
    let v : u64 = pz_from_zeta4(2i64, 0i64 - 1i64, 3i64, 1i64, 0u64)
    let n2 : u64 = py_sub(py_el_from_i64(15i64, 0u64), py_mul(py_el_from_i64(4i64, 0u64), s2))
    if py_cmp(pz_norm2(v), n2) != 0i64 { return 194u64 }
    /* Brahmagupta over the ring elements too: |wv|^2 = |w|^2 |v|^2 */
    if py_cmp(pz_norm2(pz_mul(w, v)), py_mul(n1, n2)) != 0i64 { return 194u64 }
    /* THE BORN CHECK: H|0> amplitudes (1,0,0,0)/sqrt2^1 -- each weight is
     * EXACTLY 1/2 and the state resolves to certainty (sum 1); a T-phased
     * amplitude zeta/sqrt2 keeps weight 1/2 (unitary phase invariance) */
    let ha : u64 = pz_from_zeta4(1i64, 0i64, 0i64, 0i64, 1u64)
    let half : u64 = py_el_from_rat(py_rat_frac(1i64, 2i64), 0u64)
    if py_cmp(pz_norm2(ha), half) != 0i64 { return 194u64 }
    if py_cmp(py_add(pz_norm2(ha), pz_norm2(ha)), py_el_from_i64(1i64, 0u64)) != 0i64 { return 194u64 }
    let ta : u64 = pz_from_zeta4(0i64, 1i64, 0i64, 0i64, 1u64)
    if py_cmp(pz_norm2(ta), half) != 0i64 { return 194u64 }
    if PY_ERR != 0u64 { return 194u64 }
    return 0u64
}
/* 2x2 complex-matrix cells (multi-out through module cells, the house
 * pattern): R = A*B, and the quadratic form psi-dagger B psi for the state
 * (S0, S1).  Index order 0=00 1=01 2=10 3=11. */
var PM_A0 : u64 = 0u64   var PM_A1 : u64 = 0u64
var PM_A2 : u64 = 0u64   var PM_A3 : u64 = 0u64
var PM_B0 : u64 = 0u64   var PM_B1 : u64 = 0u64
var PM_B2 : u64 = 0u64   var PM_B3 : u64 = 0u64
var PM_R0 : u64 = 0u64   var PM_R1 : u64 = 0u64
var PM_R2 : u64 = 0u64   var PM_R3 : u64 = 0u64
var PM_S0 : u64 = 0u64   var PM_S1 : u64 = 0u64
fn pm_mul2() -> i32 {
    PM_R0 = pz_add(pz_mul(PM_A0, PM_B0), pz_mul(PM_A1, PM_B2))
    PM_R1 = pz_add(pz_mul(PM_A0, PM_B1), pz_mul(PM_A1, PM_B3))
    PM_R2 = pz_add(pz_mul(PM_A2, PM_B0), pz_mul(PM_A3, PM_B2))
    PM_R3 = pz_add(pz_mul(PM_A2, PM_B1), pz_mul(PM_A3, PM_B3))
    return 0i32
}
fn pm_qform2() -> u64 {
    let w0 : u64 = pz_add(pz_mul(PM_B0, PM_S0), pz_mul(PM_B1, PM_S1))
    let w1 : u64 = pz_add(pz_mul(PM_B2, PM_S0), pz_mul(PM_B3, PM_S1))
    return pz_add(pz_mul(pz_conj(PM_S0), w0), pz_mul(pz_conj(PM_S1), w1))
}
fn py_arm192() -> u64 {
    /* THE PAULI ALGEBRA, exact: sx^2 = sy^2 = sz^2 = I; sx sy = i sz and
     * sy sx = -i sz (NON-COMMUTATIVITY as algebra -- the matrices are held
     * apart exactly, no epsilon); [sx,sy] = 2i sz; {sx,sy} = 0; and the
     * Hadamard conjugation H sx H = sz with H = (1/sqrt2)(1 1; 1 -1) -- the
     * 1/sqrt2 is a TOWER element, not a float. */
    py_reset()
    let z00 : u64 = pz_zero()
    let one : u64 = pz_one()
    let mone : u64 = pz_from_i64(0i64 - 1i64, 0i64)
    let sx1 : u64 = pz_from_i64(1i64, 0i64)
    let syl : u64 = pz_from_i64(0i64, 0i64 - 1i64)
    let syh : u64 = pz_from_i64(0i64, 1i64)
    /* sx = (0,1;1,0)  sy = (0,-i;i,0)  sz = (1,0;0,-1) */
    PM_A0 = z00   PM_A1 = sx1   PM_A2 = sx1   PM_A3 = z00
    PM_B0 = z00   PM_B1 = sx1   PM_B2 = sx1   PM_B3 = z00
    pm_mul2()
    if pz_eq(PM_R0, one) != 1u32 { return 192u64 }
    if pz_eq(PM_R1, z00) != 1u32 { return 192u64 }
    if pz_eq(PM_R2, z00) != 1u32 { return 192u64 }
    if pz_eq(PM_R3, one) != 1u32 { return 192u64 }
    PM_A0 = z00   PM_A1 = syl   PM_A2 = syh   PM_A3 = z00
    PM_B0 = z00   PM_B1 = syl   PM_B2 = syh   PM_B3 = z00
    pm_mul2()
    if pz_eq(PM_R0, one) != 1u32 { return 192u64 }
    if pz_eq(PM_R3, one) != 1u32 { return 192u64 }
    PM_A0 = one   PM_A1 = z00   PM_A2 = z00   PM_A3 = mone
    PM_B0 = one   PM_B1 = z00   PM_B2 = z00   PM_B3 = mone
    pm_mul2()
    if pz_eq(PM_R0, one) != 1u32 { return 192u64 }
    if pz_eq(PM_R3, one) != 1u32 { return 192u64 }
    /* sx sy = i sz = (i,0;0,-i) */
    PM_A0 = z00   PM_A1 = sx1   PM_A2 = sx1   PM_A3 = z00
    PM_B0 = z00   PM_B1 = syl   PM_B2 = syh   PM_B3 = z00
    pm_mul2()
    let xy0 : u64 = PM_R0
    let xy1 : u64 = PM_R1
    let xy2 : u64 = PM_R2
    let xy3 : u64 = PM_R3
    if pz_eq(xy0, syh) != 1u32 { return 192u64 }
    if pz_eq(xy1, z00) != 1u32 { return 192u64 }
    if pz_eq(xy2, z00) != 1u32 { return 192u64 }
    if pz_eq(xy3, syl) != 1u32 { return 192u64 }
    /* sy sx = -i sz -- and it DIFFERS from sx sy: non-commutativity */
    PM_A0 = z00   PM_A1 = syl   PM_A2 = syh   PM_A3 = z00
    PM_B0 = z00   PM_B1 = sx1   PM_B2 = sx1   PM_B3 = z00
    pm_mul2()
    let yx0 : u64 = PM_R0
    let yx3 : u64 = PM_R3
    if pz_eq(yx0, syl) != 1u32 { return 192u64 }
    if pz_eq(yx3, syh) != 1u32 { return 192u64 }
    if pz_eq(xy0, yx0) != 0u32 { return 192u64 }
    /* [sx,sy] = 2i sz;  {sx,sy} = 0 */
    if pz_eq(pz_sub(xy0, yx0), pz_from_i64(0i64, 2i64)) != 1u32 { return 192u64 }
    if pz_eq(pz_sub(xy3, yx3), pz_from_i64(0i64, 0i64 - 2i64)) != 1u32 { return 192u64 }
    if pz_eqz(pz_add(xy0, yx0)) != 1u32 { return 192u64 }
    if pz_eqz(pz_add(xy3, yx3)) != 1u32 { return 192u64 }
    /* Hadamard: exact 1/sqrt2 entries; H^2 = I; H sx H = sz */
    let hs : u64 = py_div(py_el_from_i64(1i64, 0u64), py_sqrt(py_el_from_i64(2i64, 0u64)))
    if py_h() != 1u64 { return 192u64 }
    let hz : u64 = pz_from_el(hs)
    let hn : u64 = pz_neg(hz)
    PM_A0 = hz   PM_A1 = hz   PM_A2 = hz   PM_A3 = hn
    PM_B0 = hz   PM_B1 = hz   PM_B2 = hz   PM_B3 = hn
    pm_mul2()
    if pz_eq(PM_R0, one) != 1u32 { return 192u64 }
    if pz_eq(PM_R1, z00) != 1u32 { return 192u64 }
    if pz_eq(PM_R2, z00) != 1u32 { return 192u64 }
    if pz_eq(PM_R3, one) != 1u32 { return 192u64 }
    PM_A0 = hz   PM_A1 = hz   PM_A2 = hz   PM_A3 = hn
    PM_B0 = z00   PM_B1 = sx1   PM_B2 = sx1   PM_B3 = z00
    pm_mul2()
    PM_A0 = PM_R0   PM_A1 = PM_R1   PM_A2 = PM_R2   PM_A3 = PM_R3
    PM_B0 = hz   PM_B1 = hz   PM_B2 = hz   PM_B3 = hn
    pm_mul2()
    if pz_eq(PM_R0, one) != 1u32 { return 192u64 }
    if pz_eq(PM_R1, z00) != 1u32 { return 192u64 }
    if pz_eq(PM_R2, z00) != 1u32 { return 192u64 }
    if pz_eq(PM_R3, mone) != 1u32 { return 192u64 }
    if PY_ERR != 0u64 { return 192u64 }
    return 0u64
}
fn py_arm193() -> u64 {
    /* THE UNCERTAINTY PRINCIPLE AS AN EXACT IDENTITY.  On the unnormalized
     * complex state psi = (3, 1+i):  <sx> = <sy> = 6/11, <sz> = 7/11,
     * Var(sx) = Var(sy) = 85/121, and
     *   Robertson  Var(sx)Var(sy) - (1/4)|<[sx,sy]>|^2 = 1296/14641 > 0
     *     (STRICT -- the machine holds the gap exactly), while
     *   Schrodinger Var(sx)Var(sy) = (1/4)|<[sx,sy]>|^2
     *                              + ((1/2)<{sx,sy}> - <sx><sy>)^2
     *     holds as an EQUALITY (pure qubit states saturate it).
     * On the eigenstate-adjacent psi2 = (1,0) Robertson itself is TIGHT.
     * Every expectation is asserted REAL (im exactly 0) before use. */
    py_reset()
    let z00 : u64 = pz_zero()
    let sx1 : u64 = pz_from_i64(1i64, 0i64)
    let syl : u64 = pz_from_i64(0i64, 0i64 - 1i64)
    let syh : u64 = pz_from_i64(0i64, 1i64)
    let one : u64 = py_el_from_i64(1i64, 0u64)
    let s0 : u64 = pz_from_i64(3i64, 0i64)
    let s1 : u64 = pz_from_i64(1i64, 1i64)
    let nel : u64 = py_add(pz_norm2(s0), pz_norm2(s1))
    if py_cmp(nel, py_el_from_i64(11i64, 0u64)) != 0i64 { return 193u64 }
    PM_S0 = s0   PM_S1 = s1
    /* <sx> */
    PM_B0 = z00   PM_B1 = sx1   PM_B2 = sx1   PM_B3 = z00
    let vx : u64 = pm_qform2()
    if pz_is_real(vx) != 1u32 { return 193u64 }
    let ex : u64 = py_div(pz_re(vx), nel)
    if py_cmp(ex, py_el_from_rat(py_rat_frac(6i64, 11i64), 0u64)) != 0i64 { return 193u64 }
    /* <sy> */
    PM_B0 = z00   PM_B1 = syl   PM_B2 = syh   PM_B3 = z00
    let vy : u64 = pm_qform2()
    if pz_is_real(vy) != 1u32 { return 193u64 }
    let ey : u64 = py_div(pz_re(vy), nel)
    if py_cmp(ey, py_el_from_rat(py_rat_frac(6i64, 11i64), 0u64)) != 0i64 { return 193u64 }
    /* <sz> via the commutator matrix [sx,sy] = 2i sz: anti-Hermitian, so the
     * expectation is PURELY IMAGINARY -- asserted, then read off */
    PM_B0 = pz_from_i64(0i64, 2i64)   PM_B1 = z00
    PM_B2 = z00   PM_B3 = pz_from_i64(0i64, 0i64 - 2i64)
    let vc : u64 = pm_qform2()
    if py_el_sign(pz_re(vc)) != 0i64 { return 193u64 }
    let cim : u64 = py_div(pz_im(vc), nel)
    if py_cmp(cim, py_el_from_rat(py_rat_frac(14i64, 11i64), 0u64)) != 0i64 { return 193u64 }
    /* the anticommutator {sx,sy} = 0: its expectation must be EXACTLY zero */
    PM_B0 = z00   PM_B1 = z00   PM_B2 = z00   PM_B3 = z00
    let va : u64 = pm_qform2()
    if pz_eqz(va) != 1u32 { return 193u64 }
    /* variances (sx^2 = sy^2 = I, proven in arm 192): V = 1 - <A>^2 */
    let varx : u64 = py_sub(one, py_mul(ex, ex))
    let vary : u64 = py_sub(one, py_mul(ey, ey))
    if py_cmp(varx, py_el_from_rat(py_rat_frac(85i64, 121i64), 0u64)) != 0i64 { return 193u64 }
    let lhs : u64 = py_mul(varx, vary)
    let quarter : u64 = py_el_from_rat(py_rat_frac(1i64, 4i64), 0u64)
    let rhsr : u64 = py_mul(quarter, py_mul(cim, cim))
    /* ROBERTSON, strict: the gap is EXACTLY 1296/14641 */
    let gap : u64 = py_sub(lhs, rhsr)
    if py_sign(gap) != 1i64 { return 193u64 }
    if py_cmp(gap, py_el_from_rat(py_rat_frac(1296i64, 14641i64), 0u64)) != 0i64 { return 193u64 }
    /* SCHRODINGER, equality: lhs == rhsr + (0 - <sx><sy>)^2 */
    let cov : u64 = py_sub(py_el_new(0u64), py_mul(ex, ey))
    if py_cmp(lhs, py_add(rhsr, py_mul(cov, cov))) != 0i64 { return 193u64 }
    /* the tight pole: psi2 = (1,0) -- Robertson saturates */
    PM_S0 = pz_one()   PM_S1 = z00
    PM_B0 = z00   PM_B1 = sx1   PM_B2 = sx1   PM_B3 = z00
    let vx2 : u64 = pm_qform2()
    if pz_eqz(vx2) != 1u32 { return 193u64 }
    PM_B0 = pz_from_i64(0i64, 2i64)   PM_B1 = z00
    PM_B2 = z00   PM_B3 = pz_from_i64(0i64, 0i64 - 2i64)
    let vc2 : u64 = pm_qform2()
    if py_el_sign(pz_re(vc2)) != 0i64 { return 193u64 }
    let ci2 : u64 = pz_im(vc2)
    if py_cmp(ci2, py_el_from_i64(2i64, 0u64)) != 0i64 { return 193u64 }
    /* Var(sx) = Var(sy) = 1; (1/4)|<[..]>|^2 = 1: the bound is met with 0 gap */
    let gap2 : u64 = py_sub(one, py_mul(quarter, py_mul(ci2, ci2)))
    if py_sign(gap2) != 0i64 { return 193u64 }
    if PY_ERR != 0u64 { return 193u64 }
    return 0u64
}
fn py_selfprove() -> u64 @export {
    let a0 : u64 = py_arm180()
    if a0 != 0u64 { return a0 }
    let a1 : u64 = py_arm181()
    if a1 != 0u64 { return a1 }
    let a2 : u64 = py_arm182()
    if a2 != 0u64 { return a2 }
    let a3 : u64 = py_arm183()
    if a3 != 0u64 { return a3 }
    let a4 : u64 = py_arm184()
    if a4 != 0u64 { return a4 }
    let a5 : u64 = py_arm185()
    if a5 != 0u64 { return a5 }
    let a6 : u64 = py_arm186()
    if a6 != 0u64 { return a6 }
    let a7 : u64 = py_arm187()
    if a7 != 0u64 { return a7 }
    let a8 : u64 = py_arm188()
    if a8 != 0u64 { return a8 }
    let a9 : u64 = py_arm189()
    if a9 != 0u64 { return a9 }
    let a10 : u64 = py_arm190()
    if a10 != 0u64 { return a10 }
    let a11 : u64 = py_arm191()
    if a11 != 0u64 { return a11 }
    let a12 : u64 = py_arm192()
    if a12 != 0u64 { return a12 }
    let a13 : u64 = py_arm193()
    if a13 != 0u64 { return a13 }
    let a14 : u64 = py_arm194()
    if a14 != 0u64 { return a14 }
    let a15 : u64 = py_arm195()
    if a15 != 0u64 { return a15 }
    return 0u64
}
