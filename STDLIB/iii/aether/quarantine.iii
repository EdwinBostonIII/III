// C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\aether\quarantine.iii
//
// III STDLIB - aether::quarantine
// Transactional sandbox over authoritative state. Writes are journaled; reads
// consult the journal first and fall through to underlying state on miss.
// q_commit applies the journal in insertion order and captures an undo journal
// so the commit is reversible (q_rollback). q_abort discards the journal. Every
// transition is a witnessed fragment chained to the enter fragment; mint and
// apply are capability-gated (CAP_RIGHT_AMEND, 0x4000).
//
// Hexad: kind_motion + kind_witness.  Ring: R0.  K: 0.99.
// Discipline: W2 (<=4 params), W8 (sized arenas), W10/W12 (sentinel returns),
// W13 (<=20 locals -- commit split into helpers), W14 (sentinel-flag loops, no
// break), W15 (no recursion). Non-reentrant (module-scope scratch; serialized
// authoritative-state ops, same discipline as identifier.iii / witness_hook.iii).
//
// Traps avoided: 1 (single-line fn sigs), 2 (QUAR_ prefix on every const/var),
// 3 (signed compares == / != only; ordering only on u32/u64), 4 (mask before
// pointer math), 5 (byte-store through *u8), 6/17 (no nested block comments),
// 7 (no local var arrays -- all scratch module-scope), 9 (ASCII -- in comments),
// 13 (deep algorithms split into flat helpers), 14 (var is reserved -- not used
// as an identifier here).

module aether_quarantine

extern @abi(c-msvc-x64) fn ident_from_bytes(input: *u8, in_len: u64, out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_copy(src: *u8, dst: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn wh_publish(producer: *u8, opid: *u8, in_commit: *u8, out_commit: *u8, revtag: u8, phase: u8, pillar: u16, antecedents: *u8, n_ante: u32, payload: *u8, payload_len: u32, out_frag_id: *u8) -> u64 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn wh_chain_root(out_id: *u8) -> i32 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn wh_get_frag_id(idx: u64, out_id: *u8) -> i32 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn cap_verify_rights(id: u64, required: u64) -> u8 from "capability.iii"

// selftest-only externs (witness + capability bootstrap; resolve at link)
extern @abi(c-msvc-x64) fn wh_init(initial_time: u64) -> i32 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent_id: u64, rights_mask: u64, expires_at: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn ident_eq(a: *u8, b: *u8) -> u8 from "identifier.iii"

const QUAR_OK            : i32 =  0i32
const QUAR_E_FULL        : i32 = -1i32
const QUAR_E_BAD         : i32 = -2i32
const QUAR_E_STATE       : i32 = -3i32
const QUAR_E_BOUNDS      : i32 = -4i32
const QUAR_E_CAP         : i32 = -5i32   // capability denied (M8)
const QUAR_E_WITNESS     : i32 = -6i32   // wh_publish returned the u64 fail sentinel (M6)

const QUAR_MAX_SLOTS     : u32 = 256u32
const QUAR_MAX_JENT      : u32 = 65536u32
const QUAR_DATA_AREA     : u32 = 1048576u32      // 1 MiB packed forward journal
const QUAR_UNDO_AREA     : u32 = 1048576u32      // 1 MiB packed undo journal (M9)
const QUAR_SENT          : u32 = 0xFFFFFFFFu32
const QUAR_WH_FAIL       : u64 = 0xFFFFFFFFFFFFFFFFu64  // wh_publish failure sentinel

const QUAR_STATE_OPEN      : u8 = 0u8
const QUAR_STATE_COMMIT    : u8 = 1u8
const QUAR_STATE_ABORT     : u8 = 2u8
const QUAR_STATE_ROLLBACK  : u8 = 3u8
const QUAR_STATE_INVALID   : u8 = 0xFFu8

// capability right required to open / apply a quarantine over authoritative
// state. Bit value MUST equal aether/capability.iii CAP_RIGHT_AMEND (0x4000);
// declared locally as a literal (iiis has no cross-module const import).
const QUAR_RIGHT_AMEND    : u64 = 0x4000u64

const QUAR_PILLAR         : u16 = 1u16   // witness pillar id for quarantine ops

var QUAR_LIVE          : [u8;  256]
var QUAR_STATE         : [u8;  256]
var QUAR_REGION_BASE   : [u64; 256]
var QUAR_REGION_LEN    : [u64; 256]
var QUAR_JOUR_START    : [u32; 256]
var QUAR_JOUR_END      : [u32; 256]
var QUAR_UNDO_START    : [u32; 256]
var QUAR_UNDO_END      : [u32; 256]
var QUAR_ENTER_FRAG    : [u64; 256]
var QUAR_COMMIT_FRAG   : [u64; 256]
var QUAR_ENTER_ID      : [u8;  8192]
var QUAR_COMMIT_ID     : [u8;  8192]

var QUAR_JE_ADDR       : [u64; 65536]
var QUAR_JE_LEN        : [u32; 65536]
var QUAR_JE_DATA_OFF   : [u32; 65536]
var QUAR_UE_ADDR       : [u64; 65536]
var QUAR_UE_LEN        : [u32; 65536]
var QUAR_UE_DATA_OFF   : [u32; 65536]

var QUAR_DATA          : [u8;  1048576]
var QUAR_UNDO          : [u8;  1048576]
var QUAR_JE_USED       : u32 = 0u32
var QUAR_DATA_USED     : u32 = 0u32
var QUAR_UE_USED       : u32 = 0u32
var QUAR_UNDO_USED     : u32 = 0u32

var QUAR_PRODUCER      : [u8; 32]
var QUAR_OPID_ENTER    : [u8; 32]
var QUAR_OPID_COMMIT   : [u8; 32]
var QUAR_OPID_ABORT    : [u8; 32]
var QUAR_OPID_ROLLBACK : [u8; 32]
var QUAR_INITED        : u8 = 0u8

var QUAR_DESC          : [u8; 16]
var QUAR_IN_C          : [u8; 32]
var QUAR_OUT_C         : [u8; 32]
var QUAR_FID           : [u8; 32]
var QUAR_SUMBUF        : [u8; 786432]
var QUAR_ABORTBUF      : [u8; 64]

// ---- self-test scratch ----
var QUAR_KAT_REGION    : [u8; 256]
var QUAR_KAT_OUT       : [u8; 64]
var QUAR_KAT_ID_E      : [u8; 32]
var QUAR_KAT_ID_C      : [u8; 32]
var QUAR_KAT_W3        : [u8; 8]

// =====================================================================
// internal helpers (not @export)
// =====================================================================

// 32-byte-id slot pointer into QUAR_ENTER_ID. Mask slot before pointer math
// (Trap 4): u32 in an 8-byte slot may carry garbage in the high 4 bytes.
fn q_enter_id_ptr(slot: u32) -> *u8 {
    let off : u64 = ((slot as u64) & 0xFFFFFFFFu64) * 32u64
    return ((&QUAR_ENTER_ID as u64) + off) as *u8
}

fn q_commit_id_ptr(slot: u32) -> *u8 {
    let off : u64 = ((slot as u64) & 0xFFFFFFFFu64) * 32u64
    return ((&QUAR_COMMIT_ID as u64) + off) as *u8
}

// Linear free-slot scan. W14: sentinel-flag style (early return on hit), no
// break. Returns slot id in [0,255] or QUAR_SENT if the table is full.
fn q_alloc_slot() -> u32 {
    let mut i : u32 = 0u32
    while i < QUAR_MAX_SLOTS {
        if QUAR_LIVE[i] == 0u8 { return i }
        i = i + 1u32
    }
    return QUAR_SENT
}

// Overflow-safe region containment (M5): true iff [addr, addr+len) lies wholly
// inside [base, base+rlen). Computed without ever forming addr+len or base+rlen
// so a near-2^64 region cannot wrap. Returns 1 (in) / 0 (out) -- W10.
fn q_in_region(slot: u32, addr: u64, len: u32) -> u8 {
    let base : u64 = QUAR_REGION_BASE[slot]
    let rlen : u64 = QUAR_REGION_LEN[slot]
    let l64  : u64 = (len as u64) & 0xFFFFFFFFu64
    if addr < base { return 0u8 }
    if l64 > rlen { return 0u8 }
    let off  : u64 = addr - base
    let room : u64 = rlen - l64
    if off > room { return 0u8 }
    return 1u8
}

// Resolve ONE byte at byte_addr for an open slot: journal-first (newest entry
// covering it wins), else underlying state. Split out of q_journal_read to keep
// nesting shallow (Trap 13). W14: the found flag both drives the scan condition
// and skips further work; no break. Stores the resolved byte through out_p.
fn q_resolve_byte(slot: u32, byte_addr: u64, out_p: *u8) -> i32 {
    let start : u32 = QUAR_JOUR_START[slot]
    let mut j : u32 = QUAR_JOUR_END[slot]
    let mut found : u8 = 0u8
    while j > start {
        if found == 0u8 {
            let e : u32 = j - 1u32
            let ja : u64 = QUAR_JE_ADDR[e]
            let jl : u64 = (QUAR_JE_LEN[e] as u64) & 0xFFFFFFFFu64
            let hit : u8 = q_byte_in_entry(byte_addr, ja, jl)
            if hit == 1u8 {
                let doff : u64 = (QUAR_JE_DATA_OFF[e] as u64) & 0xFFFFFFFFu64
                let di   : u64 = doff + (byte_addr - ja)
                out_p[0u64] = QUAR_DATA[di]
                found = 1u8
            }
        }
        j = j - 1u32
    }
    if found == 0u8 {
        let sp : *u8 = byte_addr as *u8
        out_p[0u64] = sp[0u64]
    }
    return QUAR_OK
}

// byte_addr in [ja, ja+jl) without forming ja+jl (overflow-safe). 1 / 0.
fn q_byte_in_entry(byte_addr: u64, ja: u64, jl: u64) -> u8 {
    if byte_addr < ja { return 0u8 }
    let d : u64 = byte_addr - ja
    if d < jl { return 1u8 }
    return 0u8
}

// Capture pre-commit (undo) bytes for every forward entry of slot, BEFORE any
// apply (M9 atomicity: refuse on overflow before mutating). W13: own helper.
// Returns QUAR_OK or QUAR_E_FULL.
fn q_capture_undo(slot: u32) -> i32 {
    let start : u32 = QUAR_JOUR_START[slot]
    let end   : u32 = QUAR_JOUR_END[slot]
    QUAR_UNDO_START[slot] = QUAR_UE_USED
    let mut j : u32 = start
    let mut fail : i32 = QUAR_OK
    while j < end {
        if fail == QUAR_OK {
            let addr : u64 = QUAR_JE_ADDR[j]
            let len  : u32 = QUAR_JE_LEN[j]
            let l64  : u64 = (len as u64) & 0xFFFFFFFFu64
            if QUAR_UE_USED >= QUAR_MAX_JENT { fail = QUAR_E_FULL }
            if fail == QUAR_OK {
                if (QUAR_UNDO_USED + len) > QUAR_UNDO_AREA { fail = QUAR_E_FULL }
            }
            if fail == QUAR_OK { q_capture_one(j, addr, l64) }
        }
        j = j + 1u32
    }
    if fail == QUAR_OK { QUAR_UNDO_END[slot] = QUAR_UE_USED }
    return fail
}

// Record one undo entry: snapshot current underlying bytes at [addr,addr+l64)
// into QUAR_UNDO and append the undo-entry metadata. Flat (Trap 13).
fn q_capture_one(fwd_j: u32, addr: u64, l64: u64) -> i32 {
    let ue : u32 = QUAR_UE_USED
    QUAR_UE_ADDR[ue]     = addr
    QUAR_UE_LEN[ue]      = QUAR_JE_LEN[fwd_j]
    QUAR_UE_DATA_OFF[ue] = QUAR_UNDO_USED
    let dst_off : u64 = (QUAR_UNDO_USED as u64) & 0xFFFFFFFFu64
    let sp : *u8 = addr as *u8
    let mut k : u64 = 0u64
    while k < l64 {
        QUAR_UNDO[dst_off + k] = sp[k]
        k = k + 1u64
    }
    QUAR_UNDO_USED = QUAR_UNDO_USED + (l64 as u32)
    QUAR_UE_USED   = ue + 1u32
    return QUAR_OK
}

// Apply the forward journal to underlying state in insertion order (byte-wise,
// *u8 stores -- Trap 5). W13: own helper. Always QUAR_OK (bounds checked at
// q_journal_write time; undo already captured).
fn q_apply_forward(slot: u32) -> i32 {
    let start : u32 = QUAR_JOUR_START[slot]
    let end   : u32 = QUAR_JOUR_END[slot]
    let mut j : u32 = start
    while j < end {
        let addr : u64 = QUAR_JE_ADDR[j]
        let l64  : u64 = (QUAR_JE_LEN[j] as u64) & 0xFFFFFFFFu64
        let doff : u64 = (QUAR_JE_DATA_OFF[j] as u64) & 0xFFFFFFFFu64
        let dp : *u8 = addr as *u8
        let mut k : u64 = 0u64
        while k < l64 {
            dp[k] = QUAR_DATA[doff + k]
            k = k + 1u64
        }
        j = j + 1u32
    }
    return QUAR_OK
}

// Re-apply the undo journal in REVERSE insertion order (overlapping writes
// restore the true pre-commit state). W14 flag-loop (no break).
fn q_apply_undo_reverse(slot: u32) -> i32 {
    let start : u32 = QUAR_UNDO_START[slot]
    let mut j : u32 = QUAR_UNDO_END[slot]
    while j > start {
        let e : u32 = j - 1u32
        let addr : u64 = QUAR_UE_ADDR[e]
        let l64  : u64 = (QUAR_UE_LEN[e] as u64) & 0xFFFFFFFFu64
        let doff : u64 = (QUAR_UE_DATA_OFF[e] as u64) & 0xFFFFFFFFu64
        let dp : *u8 = addr as *u8
        let mut k : u64 = 0u64
        while k < l64 {
            dp[k] = QUAR_UNDO[doff + k]
            k = k + 1u64
        }
        j = j - 1u32
    }
    return QUAR_OK
}

// Build the commit out_commit pre-image in QUAR_SUMBUF: per forward entry,
// 8-byte LE addr followed by 4-byte LE len (12 bytes/entry). Returns the
// pre-image length in bytes. Byte-wise *u8 stores (Trap 5).
fn q_build_sumbuf(slot: u32) -> u32 {
    let start : u32 = QUAR_JOUR_START[slot]
    let end   : u32 = QUAR_JOUR_END[slot]
    let sp : *u8 = (&QUAR_SUMBUF as u64) as *u8
    let mut off : u32 = 0u32
    let mut j : u32 = start
    while j < end {
        let addr : u64 = QUAR_JE_ADDR[j]
        let len  : u32 = QUAR_JE_LEN[j]
        let o64  : u64 = (off as u64) & 0xFFFFFFFFu64
        sp[o64 + 0u64] = (addr & 0xFFu64) as u8
        sp[o64 + 1u64] = ((addr >> 8u64)  & 0xFFu64) as u8
        sp[o64 + 2u64] = ((addr >> 16u64) & 0xFFu64) as u8
        sp[o64 + 3u64] = ((addr >> 24u64) & 0xFFu64) as u8
        sp[o64 + 4u64] = ((addr >> 32u64) & 0xFFu64) as u8
        sp[o64 + 5u64] = ((addr >> 40u64) & 0xFFu64) as u8
        sp[o64 + 6u64] = ((addr >> 48u64) & 0xFFu64) as u8
        sp[o64 + 7u64] = ((addr >> 56u64) & 0xFFu64) as u8
        sp[o64 + 8u64]  = (len & 0xFFu32) as u8
        sp[o64 + 9u64]  = ((len >> 8u32)  & 0xFFu32) as u8
        sp[o64 + 10u64] = ((len >> 16u32) & 0xFFu32) as u8
        sp[o64 + 11u64] = ((len >> 24u32) & 0xFFu32) as u8
        off = off + 12u32
        j = j + 1u32
    }
    return off
}

// Build "abort"/"rollbk" tag (5/6 bytes) followed by the 32-byte enter id into
// QUAR_ABORTBUF. tag_len is the prefix length. Returns total pre-image length.
fn q_build_abortbuf(slot: u32, tag_len: u32) -> u32 {
    let bp : *u8 = (&QUAR_ABORTBUF as u64) as *u8
    let ep : *u8 = q_enter_id_ptr(slot)
    let mut i : u64 = 0u64
    while i < 32u64 {
        let t64 : u64 = (tag_len as u64) & 0xFFFFFFFFu64
        bp[t64 + i] = ep[i]
        i = i + 1u64
    }
    return tag_len + 32u32
}

// Store the little-endian 8-byte region_base then 8-byte region_len into the
// 16-byte module-scope QUAR_DESC. Byte-wise *u8 stores (Trap 5).
fn q_build_desc(region_base: u64, region_len: u64) -> i32 {
    let dp : *u8 = (&QUAR_DESC as u64) as *u8
    let mut i : u64 = 0u64
    while i < 8u64 {
        dp[i]        = ((region_base >> (i * 8u64)) & 0xFFu64) as u8
        dp[i + 8u64] = ((region_len  >> (i * 8u64)) & 0xFFu64) as u8
        i = i + 1u64
    }
    return QUAR_OK
}

// =====================================================================
// public API
// =====================================================================

// Idempotent table reset + canonical id derivation. STATE seeded to INVALID so
// a never-entered slot reports invalid (fixes gospel's ambiguous q_status).
fn q_init() -> i32 @export {
    let mut i : u32 = 0u32
    while i < QUAR_MAX_SLOTS {
        QUAR_LIVE[i]  = 0u8
        QUAR_STATE[i] = QUAR_STATE_INVALID
        i = i + 1u32
    }
    QUAR_JE_USED   = 0u32
    QUAR_DATA_USED = 0u32
    QUAR_UE_USED   = 0u32
    QUAR_UNDO_USED = 0u32
    // Canonical ids = Keccak256 of fixed ASCII (bit-identical every run, M10).
    ident_from_bytes("aether::quarantine" as *u8, 18u64, (&QUAR_PRODUCER as u64) as *u8)
    ident_from_bytes("aether::quarantine::enter" as *u8, 25u64, (&QUAR_OPID_ENTER as u64) as *u8)
    ident_from_bytes("aether::quarantine::commit" as *u8, 26u64, (&QUAR_OPID_COMMIT as u64) as *u8)
    ident_from_bytes("aether::quarantine::abort" as *u8, 25u64, (&QUAR_OPID_ABORT as u64) as *u8)
    ident_from_bytes("aether::quarantine::rollback" as *u8, 28u64, (&QUAR_OPID_ROLLBACK as u64) as *u8)
    QUAR_INITED = 1u8
    return QUAR_OK
}

// Capability-gated mint of a writable sandbox. Returns slot id [0,255] or
// QUAR_SENT on cap-deny / table-full / witness-fail. The minted open slot IS
// the attenuated write authority for the transaction (capability-as-handle).
fn q_enter(cap: u64, region_base: u64, region_len: u64) -> u32 @export {
    if QUAR_INITED == 0u8 { q_init() }
    // M8 cap gate: only an AMEND holder over authoritative state may open a
    // writable sandbox. Without this any caller could quarantine all memory.
    if cap_verify_rights(cap, QUAR_RIGHT_AMEND) != 1u8 { return QUAR_SENT }
    let slot : u32 = q_alloc_slot()
    if slot == QUAR_SENT { return QUAR_SENT }
    QUAR_LIVE[slot]        = 1u8
    QUAR_STATE[slot]       = QUAR_STATE_OPEN
    QUAR_REGION_BASE[slot] = region_base
    QUAR_REGION_LEN[slot]  = region_len
    QUAR_JOUR_START[slot]  = QUAR_JE_USED
    QUAR_JOUR_END[slot]    = QUAR_JE_USED
    q_build_desc(region_base, region_len)
    wh_chain_root((&QUAR_IN_C as u64) as *u8)
    ident_from_bytes((&QUAR_DESC as u64) as *u8, 16u64, (&QUAR_OUT_C as u64) as *u8)
    let frag : u64 = wh_publish((&QUAR_PRODUCER as u64) as *u8, (&QUAR_OPID_ENTER as u64) as *u8, (&QUAR_IN_C as u64) as *u8, (&QUAR_OUT_C as u64) as *u8, 0u8, 0u8, QUAR_PILLAR, (&QUAR_DESC as u64) as *u8, 0u32, (&QUAR_DESC as u64) as *u8, 16u32, (&QUAR_FID as u64) as *u8)
    // M6 witness gate: a transition that fails to witness REFUSES (revert slot)
    // rather than proceeding with an uninitialised fragment id.
    if frag == QUAR_WH_FAIL {
        QUAR_LIVE[slot]  = 0u8
        QUAR_STATE[slot] = QUAR_STATE_INVALID
        return QUAR_SENT
    }
    QUAR_ENTER_FRAG[slot] = frag
    ident_copy((&QUAR_FID as u64) as *u8, q_enter_id_ptr(slot))
    return slot
}

// Record a write into the slot's forward journal (no cap arg: the open slot is
// the authority minted at q_enter). Append-only.
fn q_journal_write(slot: u32, addr: u64, data: *u8, len: u32) -> i32 @export {
    if slot >= QUAR_MAX_SLOTS { return QUAR_E_BAD }
    if QUAR_LIVE[slot] == 0u8 { return QUAR_E_BAD }
    if QUAR_STATE[slot] != QUAR_STATE_OPEN { return QUAR_E_STATE }
    if q_in_region(slot, addr, len) == 0u8 { return QUAR_E_BOUNDS }
    if QUAR_JE_USED >= QUAR_MAX_JENT { return QUAR_E_FULL }
    if (QUAR_DATA_USED + len) > QUAR_DATA_AREA { return QUAR_E_FULL }
    let je : u32 = QUAR_JE_USED
    QUAR_JE_ADDR[je]     = addr
    QUAR_JE_LEN[je]      = len
    QUAR_JE_DATA_OFF[je] = QUAR_DATA_USED
    let doff : u64 = (QUAR_DATA_USED as u64) & 0xFFFFFFFFu64
    let l64  : u64 = (len as u64) & 0xFFFFFFFFu64
    let mut k : u64 = 0u64
    while k < l64 {
        QUAR_DATA[doff + k] = data[k]
        k = k + 1u64
    }
    QUAR_DATA_USED      = QUAR_DATA_USED + len
    QUAR_JE_USED        = je + 1u32
    QUAR_JOUR_END[slot] = QUAR_JE_USED
    return QUAR_OK
}

// Journal-first read with underlying-state fall-through, resolved byte by byte
// (newest covering entry wins). No fragment emitted on read (M10 preserved).
fn q_journal_read(slot: u32, addr: u64, out: *u8, len: u32) -> i32 @export {
    if slot >= QUAR_MAX_SLOTS { return QUAR_E_BAD }
    if QUAR_LIVE[slot] == 0u8 { return QUAR_E_BAD }
    if QUAR_STATE[slot] != QUAR_STATE_OPEN { return QUAR_E_STATE }
    if q_in_region(slot, addr, len) == 0u8 { return QUAR_E_BOUNDS }
    let l64 : u64 = (len as u64) & 0xFFFFFFFFu64
    let mut i : u64 = 0u64
    while i < l64 {
        let byte_addr : u64 = addr + i
        let op : *u8 = ((out as u64) + i) as *u8
        q_resolve_byte(slot, byte_addr, op)
        i = i + 1u64
    }
    return QUAR_OK
}

// Capability-gated apply (re-verifies AMEND -- cap may have been revoked since
// enter, M9/M8). Captures the undo journal BEFORE overwriting so the commit is
// reversible via q_rollback. Publishes the commit fragment chained to enter.
fn q_commit(cap: u64, slot: u32) -> i32 @export {
    if slot >= QUAR_MAX_SLOTS { return QUAR_E_BAD }
    if QUAR_LIVE[slot] == 0u8 { return QUAR_E_BAD }
    if QUAR_STATE[slot] != QUAR_STATE_OPEN { return QUAR_E_STATE }
    if cap_verify_rights(cap, QUAR_RIGHT_AMEND) != 1u8 { return QUAR_E_CAP }
    let cu : i32 = q_capture_undo(slot)
    if cu != QUAR_OK { return cu }
    q_apply_forward(slot)
    QUAR_STATE[slot] = QUAR_STATE_COMMIT
    let plen : u32 = q_build_sumbuf(slot)
    let plen64 : u64 = (plen as u64) & 0xFFFFFFFFu64
    ident_from_bytes((&QUAR_SUMBUF as u64) as *u8, plen64, (&QUAR_OUT_C as u64) as *u8)
    wh_chain_root((&QUAR_IN_C as u64) as *u8)
    let frag : u64 = wh_publish((&QUAR_PRODUCER as u64) as *u8, (&QUAR_OPID_COMMIT as u64) as *u8, (&QUAR_IN_C as u64) as *u8, (&QUAR_OUT_C as u64) as *u8, 0u8, 0u8, QUAR_PILLAR, q_enter_id_ptr(slot), 1u32, (&QUAR_SUMBUF as u64) as *u8, plen, (&QUAR_FID as u64) as *u8)
    if frag == QUAR_WH_FAIL { return QUAR_E_WITNESS }
    QUAR_COMMIT_FRAG[slot] = frag
    ident_copy((&QUAR_FID as u64) as *u8, q_commit_id_ptr(slot))
    QUAR_LIVE[slot] = 0u8
    return QUAR_OK
}

// Discard the journal, mark aborted, publish the abort fragment. No cap:
// aborting never mutates authoritative state (always safe, M5).
fn q_abort(slot: u32) -> i32 @export {
    if slot >= QUAR_MAX_SLOTS { return QUAR_E_BAD }
    if QUAR_LIVE[slot] == 0u8 { return QUAR_E_BAD }
    if QUAR_STATE[slot] != QUAR_STATE_OPEN { return QUAR_E_STATE }
    QUAR_STATE[slot] = QUAR_STATE_ABORT
    wh_chain_root((&QUAR_IN_C as u64) as *u8)
    // out_commit = Keccak256("abort" || enter_id), 5 + 32 = 37 bytes.
    let bp : *u8 = (&QUAR_ABORTBUF as u64) as *u8
    bp[0u64] = 97u8
    bp[1u64] = 98u8
    bp[2u64] = 111u8
    bp[3u64] = 114u8
    bp[4u64] = 116u8
    let plen : u32 = q_build_abortbuf(slot, 5u32)
    let plen64 : u64 = (plen as u64) & 0xFFFFFFFFu64
    ident_from_bytes((&QUAR_ABORTBUF as u64) as *u8, plen64, (&QUAR_OUT_C as u64) as *u8)
    let frag : u64 = wh_publish((&QUAR_PRODUCER as u64) as *u8, (&QUAR_OPID_ABORT as u64) as *u8, (&QUAR_IN_C as u64) as *u8, (&QUAR_OUT_C as u64) as *u8, 1u8, 0u8, QUAR_PILLAR, q_enter_id_ptr(slot), 1u32, (&QUAR_ABORTBUF as u64) as *u8, plen, (&QUAR_FID as u64) as *u8)
    if frag == QUAR_WH_FAIL { return QUAR_E_WITNESS }
    QUAR_LIVE[slot] = 0u8
    return QUAR_OK
}

// Reverse a committed slot: re-apply the undo journal in reverse insertion
// order, restoring pre-commit bytes; publish a rollback fragment naming the
// commit fragment as antecedent. Cap-gated (AMEND). M9 closure.
fn q_rollback(cap: u64, slot: u32) -> i32 @export {
    if slot >= QUAR_MAX_SLOTS { return QUAR_E_BAD }
    if QUAR_STATE[slot] != QUAR_STATE_COMMIT { return QUAR_E_STATE }
    if cap_verify_rights(cap, QUAR_RIGHT_AMEND) != 1u8 { return QUAR_E_CAP }
    q_apply_undo_reverse(slot)
    QUAR_STATE[slot] = QUAR_STATE_ROLLBACK
    wh_chain_root((&QUAR_IN_C as u64) as *u8)
    // out_commit = Keccak256("rollbk" || enter_id), 6 + 32 = 38 bytes.
    let bp : *u8 = (&QUAR_ABORTBUF as u64) as *u8
    bp[0u64] = 114u8
    bp[1u64] = 111u8
    bp[2u64] = 108u8
    bp[3u64] = 108u8
    bp[4u64] = 98u8
    bp[5u64] = 107u8
    let plen : u32 = q_build_abortbuf(slot, 6u32)
    let plen64 : u64 = (plen as u64) & 0xFFFFFFFFu64
    ident_from_bytes((&QUAR_ABORTBUF as u64) as *u8, plen64, (&QUAR_OUT_C as u64) as *u8)
    let frag : u64 = wh_publish((&QUAR_PRODUCER as u64) as *u8, (&QUAR_OPID_ROLLBACK as u64) as *u8, (&QUAR_IN_C as u64) as *u8, (&QUAR_OUT_C as u64) as *u8, 1u8, 0u8, QUAR_PILLAR, q_commit_id_ptr(slot), 1u32, (&QUAR_ABORTBUF as u64) as *u8, plen, (&QUAR_FID as u64) as *u8)
    if frag == QUAR_WH_FAIL { return QUAR_E_WITNESS }
    return QUAR_OK
}

// 0=open, 1=committed, 2=aborted, 3=rolled-back, 0xFF=invalid. Single return;
// q_init seeds STATE to 0xFF so never-entered slots report invalid.
fn q_status(slot: u32) -> u8 @export {
    if slot >= QUAR_MAX_SLOTS { return QUAR_STATE_INVALID }
    return QUAR_STATE[slot]
}

// =====================================================================
// self-test (99 = pass; otherwise the failing step number)
// =====================================================================
fn q_selftest() -> u64 @export {
    wh_init(0u64)
    q_init()
    let cap : u64 = cap_env_init()
    let base : u64 = (&QUAR_KAT_REGION as u64)
    let rp : *u8 = base as *u8
    let outp : *u8 = (&QUAR_KAT_OUT as u64) as *u8

    // zero the underlying region, then pre-set the witness bytes.
    let mut z : u64 = 0u64
    while z < 256u64 {
        rp[z] = 0u8
        z = z + 1u64
    }
    rp[9u64] = 0x11u8

    // ---- KAT-1: journal-first read, no underlying touch ----
    let slot : u32 = q_enter(cap, base, 256u64)
    if slot != 0u32 { return 1u64 }
    if q_status(0u32) != QUAR_STATE_OPEN { return 2u64 }

    let wp : *u8 = (&QUAR_KAT_W3 as u64) as *u8
    wp[0u64] = 0xAAu8
    wp[1u64] = 0xBBu8
    wp[2u64] = 0xCCu8
    if q_journal_write(0u32, base + 10u64, wp, 3u32) != QUAR_OK { return 3u64 }

    if q_journal_read(0u32, base + 10u64, outp, 3u32) != QUAR_OK { return 4u64 }
    if outp[0u64] != 0xAAu8 { return 5u64 }
    if outp[1u64] != 0xBBu8 { return 6u64 }
    if outp[2u64] != 0xCCu8 { return 7u64 }

    // read 4 bytes spanning the boundary: byte0 = underlying 0x11, 1..3 journal.
    if q_journal_read(0u32, base + 9u64, outp, 4u32) != QUAR_OK { return 8u64 }
    if outp[0u64] != 0x11u8 { return 9u64 }
    if outp[1u64] != 0xAAu8 { return 10u64 }
    if outp[2u64] != 0xBBu8 { return 11u64 }
    if outp[3u64] != 0xCCu8 { return 12u64 }

    // ---- KAT-2: commit applies + abort discards + status ----
    // before commit the writes were journaled, not applied:
    if rp[10u64] != 0x00u8 { return 13u64 }
    if rp[11u64] != 0x00u8 { return 14u64 }
    if rp[12u64] != 0x00u8 { return 15u64 }
    if q_commit(cap, 0u32) != QUAR_OK { return 16u64 }
    if rp[10u64] != 0xAAu8 { return 17u64 }
    if rp[11u64] != 0xBBu8 { return 18u64 }
    if rp[12u64] != 0xCCu8 { return 19u64 }
    if q_status(0u32) != QUAR_STATE_COMMIT { return 20u64 }

    // abort discards an open transaction's writes:
    let slot1 : u32 = q_enter(cap, base, 256u64)
    if slot1 == QUAR_SENT { return 21u64 }
    wp[0u64] = 0x99u8
    if q_journal_write(slot1, base + 20u64, wp, 1u32) != QUAR_OK { return 22u64 }
    if q_abort(slot1) != QUAR_OK { return 23u64 }
    if rp[20u64] != 0x00u8 { return 24u64 }
    if q_status(slot1) != QUAR_STATE_ABORT { return 25u64 }

    // ---- KAT-3: rollback reverses a commit (M9) ----
    rp[30u64] = 0x55u8
    let slot2 : u32 = q_enter(cap, base, 256u64)
    if slot2 == QUAR_SENT { return 26u64 }
    wp[0u64] = 0x77u8
    if q_journal_write(slot2, base + 30u64, wp, 1u32) != QUAR_OK { return 27u64 }
    if q_commit(cap, slot2) != QUAR_OK { return 28u64 }
    if rp[30u64] != 0x77u8 { return 29u64 }
    if q_rollback(cap, slot2) != QUAR_OK { return 30u64 }
    if rp[30u64] != 0x55u8 { return 31u64 }
    if q_status(slot2) != QUAR_STATE_ROLLBACK { return 32u64 }

    // ---- KAT-4: capability denial fails closed (M8/M5) ----
    // attenuate to FS_READ only (no AMEND); enter must refuse, commit must deny.
    let bad : u64 = cap_attenuate(cap, 0x0002u64, 0u64)
    if bad == 0u64 { return 33u64 }
    if q_enter(bad, base, 256u64) != QUAR_SENT { return 34u64 }
    // open a real slot, then try to commit it with the bad cap: E_CAP, region
    // unchanged. base+40 is journaled 0xEE; underlying must stay 0x00.
    let slot3 : u32 = q_enter(cap, base, 256u64)
    if slot3 == QUAR_SENT { return 35u64 }
    wp[0u64] = 0xEEu8
    if q_journal_write(slot3, base + 40u64, wp, 1u32) != QUAR_OK { return 36u64 }
    if q_commit(bad, slot3) != QUAR_E_CAP { return 37u64 }
    if rp[40u64] != 0x00u8 { return 38u64 }
    if q_status(slot3) != QUAR_STATE_OPEN { return 39u64 }
    // clean up slot3 so it does not leak into the determinism re-run.
    if q_abort(slot3) != QUAR_OK { return 40u64 }

    // ---- KAT-5: witness chaining (M6/M10) ----
    // the commit fragment of slot 0 names the enter fragment as its antecedent:
    // re-read the enter id by its recorded fragment index and compare with the
    // stored enter id pointer (32 bytes).
    let ide : *u8 = (&QUAR_KAT_ID_E as u64) as *u8
    if wh_get_frag_id(QUAR_ENTER_FRAG[0], ide) != 0i32 { return 41u64 }
    if ident_eq(ide, q_enter_id_ptr(0u32)) != 1u8 { return 42u64 }
    // and the commit id was recorded (non-equal to enter id -- distinct frag):
    let idc : *u8 = (&QUAR_KAT_ID_C as u64) as *u8
    if wh_get_frag_id(QUAR_COMMIT_FRAG[0], idc) != 0i32 { return 43u64 }
    if ident_eq(idc, q_commit_id_ptr(0u32)) != 1u8 { return 44u64 }

    return 99u64
}
