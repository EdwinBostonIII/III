/* STDLIB/iii/aether/reach_core.iii -- The Reach: the resolver + emit.
 *
 * The network redefined as content-addressed transport: reach(address) -> value | typed-GAP,
 * emit(value) -> address.  THE ADDRESS IS THE INTEGRITY PROOF: every value any tier returns is
 * re-hashed (cad) and checked against the requested address; a tier whose bytes mismatch is
 * SKIPPED (its result discarded, the next tier tried), so a corrupt disk entry, a poisoned cache,
 * a torn shared-memory slot, or a lying remote can NEVER be blessed.  You cannot be lied to about
 * content, at any tier.
 *
 * Backend lattice, nearest-first (latency order): L0 memo (own RAM) -> L2 ipc (shared RAM, sibling
 * III processes) -> L1 store (disk, persistent + shared) -> L4 remote (HTTP / far peer).  The first
 * tier holding a VALID copy wins; a hit from a farther tier is written back DOWN into the nearer
 * ones (cache-fill).  emit publishes to memo + ipc + store, so a value is instantly reachable by
 * sibling processes (via shared RAM) and durable (on disk).  The remote tier is LAST and OPTIONAL:
 * no endpoint / refused / no DIAL right -> it reports offline and reach degrades to a typed GAP, so
 * III keeps FULL LOCAL capacity offline (the "no wifi handicap" property, structural).  Cap-gated
 * per the M31 IO-membrane (corpus 687): reach needs READ; emit needs READ|WRITE|CREATE; the L4 tier
 * additionally needs NET_RIGHT_DIAL (far-reach is its own right).
 *
 * Hexad: kind_passage.  Ring: R-1.  NIH: backend_memo + backend_ipc + reach_store + backend_remote +
 * cad + uncertainty + capability only.  Determinism: the immutable-by-address path is reproducible
 * (same address -> same value or same GAP); integer-only; ==/!= compares; single-line fns; params->locals. */
module aether_reach_core

extern @abi(c-msvc-x64) fn backend_memo_get(addr: u64, out: u64, max: u64, out_len: u64) -> i32 from "backend_memo.iii"
extern @abi(c-msvc-x64) fn backend_memo_put(addr: u64, buf: u64, len: u64) -> i32 from "backend_memo.iii"
extern @abi(c-msvc-x64) fn backend_ipc_get(addr: u64, out: u64, max: u64, out_len: u64) -> i32 from "backend_ipc.iii"
extern @abi(c-msvc-x64) fn backend_ipc_put(addr: u64, buf: u64, len: u64) -> i32 from "backend_ipc.iii"
extern @abi(c-msvc-x64) fn reach_store_get(addr: u64, cap: u64, out: u64, max: u64, out_len: u64) -> i32 from "reach_store.iii"
extern @abi(c-msvc-x64) fn reach_store_put(addr: u64, buf: u64, len: u64, cap: u64) -> i32 from "reach_store.iii"
extern @abi(c-msvc-x64) fn backend_remote_get(addr: u64, cap: u64, out: u64, max: u64, out_len: u64) -> i32 from "backend_remote.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_eq(a: *u8, b: *u8) -> u8 from "cad.iii"
extern @abi(c-msvc-x64) fn cap_verify_rights(id: u64, required: u64) -> u8 from "capability.iii"
extern @abi(c-msvc-x64) fn unc_gap_root(kind: u8, reason: u32) -> u32 from "uncertainty.iii"

const REACH_OK     : i32 = 0i32
const REACH_GAP    : i32 = 1i32
const REACH_DENIED : i32 = 2i32

const REACH_SUITE        : u32 = 0u32
const REACH_RIGHT_READ   : u64 = 0x0002u64
const REACH_EMIT_RIGHTS  : u64 = 0x000Eu64    /* READ|WRITE|CREATE */

const REACH_UNC_HOLE        : u8  = 1u8
const REACH_REASON_NOTFOUND : u32 = 0x52001u32
const REACH_TIER_OK         : i32 = 0i32

var REACH_VBUF : [u8; 32]

/* write u32 v as 4 little-endian bytes into ptr (byte-by-byte; dodges the u32-pointer-store trap). */
fn _reach_put_u32le(v: u32, ptr: u64) -> u64 {
    let p : *u8 = ptr as *u8
    let vv : u32 = v
    p[0] = (vv & 0xFFu32) as u8
    p[1] = ((vv >> 8u32) & 0xFFu32) as u8
    p[2] = ((vv >> 16u32) & 0xFFu32) as u8
    p[3] = ((vv >> 24u32) & 0xFFu32) as u8
    return 0u64
}

/* integrity gate: 1 iff the got_len bytes at out re-hash (cad) to the requested address.  Applied
 * to WHATEVER any backend tier returns -- own RAM, shared RAM, disk, wire -- before it is blessed. */
fn _reach_verify(out: u64, got_len: u64, addr: u64) -> u8 {
    let o : u64 = out
    let gl : u64 = got_len
    let a : u64 = addr
    cad_oneshot(REACH_SUITE, o as *u8, gl, (&REACH_VBUF as u64) as *u8)
    return cad_eq((&REACH_VBUF as u64) as *u8, a as *u8)
}

/* emit(value) -> address: content-address (cad) into out_addr (32 bytes); publish to disk (durable),
 * shared RAM (sibling-visible), and own RAM.  Idempotent.  REACH_DENIED if the cap lacks emit rights. */
fn reach_emit(buf: u64, len: u64, cap: u64, out_addr: u64) -> i32 @export {
    let b : u64 = buf
    let n : u64 = len
    let c : u64 = cap
    let oa : u64 = out_addr
    if cap_verify_rights(c, REACH_EMIT_RIGHTS) == 0u8 { return REACH_DENIED }
    cad_oneshot(REACH_SUITE, b as *u8, n, oa as *u8)
    let rc : i32 = reach_store_put(oa, b, n, c)
    if rc != REACH_TIER_OK { return REACH_GAP }
    backend_ipc_put(oa, b, n)
    backend_memo_put(oa, b, n)
    return REACH_OK
}

/* reach(address) -> value | GAP: resolve nearest-first (L0 memo -> L2 ipc -> L1 store -> L4 remote),
 * re-hashing each tier's bytes; the first VALID copy wins and is cache-filled DOWN into the nearer
 * tiers; else REACH_GAP (*out_gid set, *out_len 0).  REACH_DENIED if the cap lacks READ.  A tier that
 * returns mismatching bytes is skipped, never returned. */
fn reach(addr: u64, cap: u64, out: u64, max: u64, out_len: u64, out_gid: u64) -> i32 @export {
    let a : u64 = addr
    let c : u64 = cap
    let o : u64 = out
    let mx : u64 = max
    let ol : u64 = out_len
    let og : u64 = out_gid
    let olp : *u64 = ol as *u64
    olp[0] = 0u64
    if cap_verify_rights(c, REACH_RIGHT_READ) == 0u8 { return REACH_DENIED }
    let m : i32 = backend_memo_get(a, o, mx, ol)
    if m == REACH_TIER_OK {
        if _reach_verify(o, olp[0], a) == 1u8 { return REACH_OK }
        olp[0] = 0u64
    }
    let mi : i32 = backend_ipc_get(a, o, mx, ol)
    if mi == REACH_TIER_OK {
        if _reach_verify(o, olp[0], a) == 1u8 {
            backend_memo_put(a, o, olp[0])
            return REACH_OK
        }
        olp[0] = 0u64
    }
    let rc : i32 = reach_store_get(a, c, o, mx, ol)
    if rc == REACH_TIER_OK {
        if _reach_verify(o, olp[0], a) == 1u8 {
            backend_ipc_put(a, o, olp[0])
            backend_memo_put(a, o, olp[0])
            return REACH_OK
        }
        olp[0] = 0u64
    }
    let r4 : i32 = backend_remote_get(a, c, o, mx, ol)
    if r4 == REACH_TIER_OK {
        if _reach_verify(o, olp[0], a) == 1u8 {
            reach_store_put(a, o, olp[0], c)
            backend_ipc_put(a, o, olp[0])
            backend_memo_put(a, o, olp[0])
            return REACH_OK
        }
        olp[0] = 0u64
    }
    let gid : u32 = unc_gap_root(REACH_UNC_HOLE, REACH_REASON_NOTFOUND)
    _reach_put_u32le(gid, og)
    return REACH_GAP
}

/* ===== harmony item 6: WITNESS THE REACH (the unbuilt Phase-2 of III-THE-REACH-ARCHITECTURE) ==========
 * reach_core and the provenance spine (witness_hook) were disconnected: every reach/emit was supposed to
 * leave a replayable, auditable fragment, but never did.  These wrappers wrap the existing plain ops and,
 * AFTER the cap-gate AND AFTER the result is known, publish a DETERMINISTIC witness fragment binding ONLY
 * reproducible facts -- op_id = cad(op name), in_commit / out_commit = content addresses.  A DENIED op
 * records NOTHING (the cap-gate precedes witnessing: an unauthorized caller must not be able to append to
 * -- or exhaust -- the provenance spine), and a GAP records a PROOF-OF-ABSENCE (out_commit = a fixed MISS
 * sentinel that no cad output can equal).  Deterministic: identical sequences from an initialized spine
 * publish identical fragments (the at-clock is a logical, deterministic counter).
 *
 * THE PROOF-CARRYING CONTRACT IS HONEST: wh_publish CAN fail (spine uninitialized, fragment table full,
 * payload area exhausted).  A witnessed op whose fragment could NOT be published returns REACH_UNWITNESSED
 * instead of its plain result -- the operation's effects STAND (emit is idempotent; reach's out/out_len/
 * out_gid are already filled, so OK vs GAP remains recoverable from *out_gid), but the caller KNOWS the
 * provenance claim failed and can wh_init / fail-stop.  Silently returning OK with no fragment would be
 * exactly the half-built gate this increment exists to close.
 * Composes only the already-exported reach + cad + witness_hook organs. */
extern @abi(c-msvc-x64) fn wh_publish(producer: *u8, opid: *u8, in_commit: *u8, out_commit: *u8, revtag: u8, phase: u8, pillar: u16, antecedents: *u8, n_ante: u32, payload: *u8, payload_len: u32, out_frag_id: *u8) -> u64 from "witness_hook.iii"

const REACH_UNWITNESSED : i32 = 3i32                       /* op succeeded; provenance could NOT be recorded */
const REACH_WH_FAIL     : u64 = 0xFFFFFFFFFFFFFFFFu64      /* wh_publish's refusal sentinel */

var REACH_W_PROD : [u8; 32]    /* producer id  = cad("reach_core") */
var REACH_W_OPID : [u8; 32]    /* operation id = cad(op name) */
var REACH_W_MISS : [u8; 32]    /* proof-of-absence sentinel (out_commit for a GAP) */
var REACH_W_FID  : [u8; 32]    /* scratch: the published fragment id */
var REACH_W_PRODNAME : [u8; 10] = [114u8,101u8,97u8,99u8,104u8,95u8,99u8,111u8,114u8,101u8]   /* "reach_core" */
var REACH_W_OPEMIT   : [u8; 10] = [114u8,101u8,97u8,99u8,104u8,46u8,101u8,109u8,105u8,116u8]   /* "reach.emit" */
var REACH_W_OPGET    : [u8;  9] = [114u8,101u8,97u8,99u8,104u8,46u8,103u8,101u8,116u8]          /* "reach.get"  */

/* the MISS sentinel = 0x4D ('M') x 32 -- a fixed non-address: it is the cad of nothing, so a GAP's
 * out_commit is unambiguously "absent" and can never collide with a real content address. */
fn _reach_w_miss() -> u64 {
    let p : *u8 = (&REACH_W_MISS as u64) as *u8
    let mut i : u64 = 0u64
    while i < 32u64 { p[i] = 0x4Du8 ; i = i + 1u64 }
    return 0u64
}

/* emit, then (iff OK) witness: in_commit = out_commit = out_addr (= cad(value)).
 * REACH_UNWITNESSED if the fragment could not be published (effects stand; provenance missing). */
fn reach_emit_witnessed(buf: u64, len: u64, cap: u64, out_addr: u64) -> i32 @export {
    let rc : i32 = reach_emit(buf, len, cap, out_addr)
    if rc != REACH_OK { return rc }                                  /* DENIED/GAP -> no provenance */
    cad_oneshot(REACH_SUITE, (&REACH_W_PRODNAME as u64) as *u8, 10u64, (&REACH_W_PROD as u64) as *u8)
    cad_oneshot(REACH_SUITE, (&REACH_W_OPEMIT as u64) as *u8, 10u64, (&REACH_W_OPID as u64) as *u8)
    let widx : u64 = wh_publish((&REACH_W_PROD as u64) as *u8, (&REACH_W_OPID as u64) as *u8,
               out_addr as *u8, out_addr as *u8,
               0u8, 0u8, 0u16,
               (&REACH_W_PROD as u64) as *u8, 0u32,
               0u64 as *u8, 0u32,
               (&REACH_W_FID as u64) as *u8)
    if widx == REACH_WH_FAIL { return REACH_UNWITNESSED }            /* the proof-carrying contract is honest */
    return rc
}

/* reach, then (iff NOT DENIED) witness: out_commit = addr if FOUND, else the MISS sentinel (proof-of-absence).
 * REACH_UNWITNESSED if the fragment could not be published (out/out_len/out_gid already filled, so the
 * caller still has the answer; the provenance claim is honestly reported failed). */
fn reach_witnessed(addr: u64, cap: u64, out: u64, max: u64, out_len: u64, out_gid: u64) -> i32 @export {
    let rc : i32 = reach(addr, cap, out, max, out_len, out_gid)
    if rc == REACH_DENIED { return rc }                              /* cap-gate precedes witnessing */
    _reach_w_miss()
    cad_oneshot(REACH_SUITE, (&REACH_W_PRODNAME as u64) as *u8, 10u64, (&REACH_W_PROD as u64) as *u8)
    cad_oneshot(REACH_SUITE, (&REACH_W_OPGET as u64) as *u8, 9u64, (&REACH_W_OPID as u64) as *u8)
    let mut oc : u64 = addr
    if rc != REACH_OK { oc = (&REACH_W_MISS as u64) }
    let widx : u64 = wh_publish((&REACH_W_PROD as u64) as *u8, (&REACH_W_OPID as u64) as *u8,
               addr as *u8, oc as *u8,
               0u8, 0u8, 0u16,
               (&REACH_W_PROD as u64) as *u8, 0u32,
               0u64 as *u8, 0u32,
               (&REACH_W_FID as u64) as *u8)
    if widx == REACH_WH_FAIL { return REACH_UNWITNESSED }            /* the proof-carrying contract is honest */
    return rc
}
