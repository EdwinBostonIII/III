/* STDLIB/iii/aether/resultant.iii -- RESULTANT ELIMINATION: the algebraic closure of ADDITION (charter
 * Program III Vector VII).  Given alpha with integer minimal-ish polynomial f (degree m) and beta with g
 * (degree n), gamma = alpha + beta is a root of  R(t) = Res_x( f(x), g(t - x) )  -- an integer polynomial
 * of degree m*n.  The substrate stops being able only to COMPARE algebraic numbers: it can now CONSTRUCT
 * the defining polynomial of a sum, feed it back to sturm/algnum, and continue -- roots become closed
 * under +.
 *
 * THE CONSTRUCTION (the charter's fixed spec): evaluate R at the m*n+1 integer points t = 0..D as PURE
 * INTEGER Sylvester determinants (Bareiss fraction-free elimination -- every division exact), then recover
 * the integer coefficients by solving the Vandermonde system with the SAME determinant engine (Cramer;
 * the divisions are asserted exact -- a non-integer coefficient is a refused result, never a rounded one).
 * The leading coefficient is normalized positive.  All arithmetic is overflow-GUARDED (sticky RS_OVF ->
 * refuse); the v1 envelope is small degrees/coefficients (m*n <= 8, entries within the guarded products) --
 * the bigint determinant engine is the charted v2.  Products and inverses recompose the same way (charted). */
module resultant

const RS_MAXN : i64 = 9i64

var RS_M : [i64; 100]                            /* the working matrix (up to 9x9, row-major, stride 10) */
var RS_OVF : i64

fn rs_abs(x: i64) -> u64 { if x < 0i64 { return (0i64 - x) as u64 }   return x as u64 }
fn rs_mul(a: i64, b: i64) -> i64 {
    if a == 0i64 { return 0i64 }
    if b == 0i64 { return 0i64 }
    let ua : u64 = rs_abs(a)   let ub : u64 = rs_abs(b)
    if ub > (9223372036854775807u64 / ua) { RS_OVF = 1i64   return 0i64 }
    return a * b
}
fn rs_add(a: i64, b: i64) -> i64 {
    if a == 0i64 { return b }
    if b == 0i64 { return a }
    let mut pa : u8 = 0u8   if a > 0i64 { pa = 1u8 }
    let mut pb : u8 = 0u8   if b > 0i64 { pb = 1u8 }
    if pa != pb { return a + b }
    let ua : u64 = rs_abs(a)   let ub : u64 = rs_abs(b)
    if pa == 1u8 { if (ua + ub) > 9223372036854775807u64 { RS_OVF = 1i64   return 0i64 }   return a + b }
    if (ua + ub) > 9223372036854775808u64 { RS_OVF = 1i64   return 0i64 }
    return a + b
}

/* Bareiss fraction-free determinant of the n x n matrix in RS_M (destructive).  Exact-integer throughout. */
fn rs_det(n: i64) -> i64 {
    let mut sign : i64 = 1i64
    let mut prev : i64 = 1i64
    let mut k : i64 = 0i64
    while k < (n - 1i64) {
        /* pivot: if M[k][k] == 0, swap in a lower row with a nonzero entry in column k */
        let pkk : i64 = RS_M[((k * 10i64) + k) as u64]
        if pkk == 0i64 {
            let mut r : i64 = k + 1i64
            let mut found : i64 = 0i64 - 1i64
            while r < n {
                if found < 0i64 { let v : i64 = RS_M[((r * 10i64) + k) as u64]   if v != 0i64 { found = r } }
                r = r + 1i64
            }
            if found < 0i64 { return 0i64 }                        /* a zero column: det == 0 */
            let mut c : i64 = 0i64
            while c < n {
                let t : i64 = RS_M[((k * 10i64) + c) as u64]
                RS_M[((k * 10i64) + c) as u64] = RS_M[((found * 10i64) + c) as u64]
                RS_M[((found * 10i64) + c) as u64] = t
                c = c + 1i64
            }
            sign = 0i64 - sign
        }
        let p : i64 = RS_M[((k * 10i64) + k) as u64]
        let mut i : i64 = k + 1i64
        while i < n {
            let mut j : i64 = k + 1i64
            while j < n {
                let a : i64 = rs_mul(RS_M[((i * 10i64) + j) as u64], p)
                let b : i64 = rs_mul(RS_M[((i * 10i64) + k) as u64], RS_M[((k * 10i64) + j) as u64])
                let num : i64 = rs_add(a, 0i64 - b)
                RS_M[((i * 10i64) + j) as u64] = num / prev       /* Bareiss: exact division */
                j = j + 1i64
            }
            i = i + 1i64
        }
        prev = p
        k = k + 1i64
    }
    return rs_mul(sign, RS_M[(((n - 1i64) * 10i64) + (n - 1i64)) as u64])
}

/* h(x) = g(t - x): h[i] = sum_{j>=i} g[j] * C(j,i) * t^(j-i) * (-1)^i */
var RS_H : [i64; 10]
fn rs_shift(gp: u64, degg: i64, t: i64) -> i32 {
    let g : *i64 = gp as *i64
    let mut i : i64 = 0i64
    while i <= degg {
        let mut acc : i64 = 0i64
        let mut j : i64 = i
        while j <= degg {
            /* C(j,i) */
            let mut binom : i64 = 1i64
            let mut q : i64 = 0i64
            while q < i { binom = rs_mul(binom, j - q)   q = q + 1i64 }
            q = 1i64
            while q <= i { binom = binom / q   q = q + 1i64 }
            /* t^(j-i) */
            let mut pw : i64 = 1i64
            q = 0i64
            while q < (j - i) { pw = rs_mul(pw, t)   q = q + 1i64 }
            acc = rs_add(acc, rs_mul(rs_mul(g[j as u64], binom), pw))
            j = j + 1i64
        }
        let mut v : i64 = acc
        if (i % 2i64) != 0i64 { v = 0i64 - v }                    /* (-1)^i */
        RS_H[i as u64] = v
        i = i + 1i64
    }
    return 0i32
}

/* Res_x(f, h) as the (m+n) Sylvester determinant */
fn rs_res_at(fp: u64, degf: i64, degg: i64) -> i64 {
    let f : *i64 = fp as *i64
    let n : i64 = degf + degg
    let mut r : i64 = 0i64
    while r < n { let mut c : i64 = 0i64   while c < n { RS_M[((r * 10i64) + c) as u64] = 0i64   c = c + 1i64 }   r = r + 1i64 }
    r = 0i64
    while r < degg {                                              /* degg rows of f, shifted */
        let mut k : i64 = 0i64
        while k <= degf { RS_M[((r * 10i64) + (r + k)) as u64] = f[(degf - k) as u64]   k = k + 1i64 }
        r = r + 1i64
    }
    r = 0i64
    while r < degf {                                              /* degf rows of h, shifted */
        let mut k : i64 = 0i64
        while k <= degg { RS_M[(((degg + r) * 10i64) + (r + k)) as u64] = RS_H[(degg - k) as u64]   k = k + 1i64 }
        r = r + 1i64
    }
    return rs_det(n)
}

/* h(x) = x^degg * g(t/x)  (the PRODUCT composition): coefficient of x^k is g_{degg-k} * t^(degg-k).
 * True x-degree degg requires g(0) != 0 (checked by the rs_prod wrapper). */
fn rs_shift_prod(gp: u64, degg: i64, t: i64) -> i32 {
    let g : *i64 = gp as *i64
    let mut k : i64 = 0i64
    while k <= degg {
        RS_H[k as u64] = rs_mul(g[(degg - k) as u64], rs_powi(t, degg - k))
        k = k + 1i64
    }
    return 0i32
}

/* gamma = alpha OP beta: out[0..m*n] gets the integer defining polynomial (leading coefficient positive).
 * op 0 = SUM (h = g(t-x)), op 1 = PRODUCT (h = x^degg g(t/x)).
 * Returns the degree m*n, or -1 refused (overflow / non-integer interpolation / degree too large). */
var RS_R : [i64; 10]
fn rs_gamma(fp: u64, degf: i64, gp: u64, degg: i64, outp: u64, op: i64) -> i64 {
    RS_OVF = 0i64
    let D : i64 = degf * degg
    if D < 1i64 { return 0i64 - 1i64 }
    if D > 8i64 { return 0i64 - 1i64 }
    if (degf + degg) > 8i64 { return 0i64 - 1i64 }
    let fchk : *i64 = fp as *i64
    let gchk : *i64 = gp as *i64
    let flead : i64 = fchk[degf as u64]
    let glead : i64 = gchk[degg as u64]
    if flead == 0i64 { return 0i64 - 1i64 }                /* a zero lead degenerates the Sylvester */
    if glead == 0i64 { return 0i64 - 1i64 }
    let mut t : i64 = 0i64
    while t <= D {
        if op == 0i64 { rs_shift(gp, degg, t) }
        if op == 1i64 { rs_shift_prod(gp, degg, t) }
        RS_R[t as u64] = rs_res_at(fp, degf, degg)
        t = t + 1i64
    }
    if RS_OVF != 0i64 { return 0i64 - 1i64 }
    /* Cramer over the Vandermonde V[t][i] = t^i:  det(V) then det(V_i) with column i replaced by R */
    let n : i64 = D + 1i64
    let mut r2 : i64 = 0i64
    while r2 < n { let mut c2 : i64 = 0i64   while c2 < n { RS_M[((r2 * 10i64) + c2) as u64] = rs_powi(r2, c2)   c2 = c2 + 1i64 }   r2 = r2 + 1i64 }
    let dv : i64 = rs_det(n)
    if dv == 0i64 { return 0i64 - 1i64 }
    let out : *i64 = outp as *i64
    let mut i : i64 = 0i64
    while i <= D {
        r2 = 0i64
        while r2 < n {
            let mut c2 : i64 = 0i64
            while c2 < n {
                let mut v : i64 = rs_powi(r2, c2)
                if c2 == i { v = RS_R[r2 as u64] }
                RS_M[((r2 * 10i64) + c2) as u64] = v
                c2 = c2 + 1i64
            }
            r2 = r2 + 1i64
        }
        let di : i64 = rs_det(n)
        let q : i64 = di / dv
        if rs_mul(q, dv) != di { return 0i64 - 1i64 }             /* the coefficient MUST be an integer */
        out[i as u64] = q
        i = i + 1i64
    }
    if RS_OVF != 0i64 { return 0i64 - 1i64 }
    if out[D as u64] < 0i64 {
        i = 0i64
        while i <= D { out[i as u64] = 0i64 - out[i as u64]   i = i + 1i64 }
    }
    return D
}
fn rs_sum(fp: u64, degf: i64, gp: u64, degg: i64, outp: u64) -> i64 @export {
    return rs_gamma(fp, degf, gp, degg, outp, 0i64)
}
fn rs_prod(fp: u64, degf: i64, gp: u64, degg: i64, outp: u64) -> i64 @export {
    let g : *i64 = gp as *i64
    let g0 : i64 = g[0u64]
    if g0 == 0i64 { return 0i64 - 1i64 }                   /* x | g: true x-degree would collapse */
    return rs_gamma(fp, degf, gp, degg, outp, 1i64)
}

/* gamma = 1/alpha: the reversed polynomial x^degf * f(1/x), lead normalized positive.  Exact, no
 * engine: the roots of the reversal are exactly the inverses.  Refuses f(0) == 0 (0 among conjugates). */
fn rs_inv(fp: u64, degf: i64, outp: u64) -> i64 @export {
    let f : *i64 = fp as *i64
    let out : *i64 = outp as *i64
    let f0 : i64 = f[0u64]
    if f0 == 0i64 { return 0i64 - 1i64 }
    if degf < 1i64 { return 0i64 - 1i64 }
    let mut i : i64 = 0i64
    while i <= degf { out[i as u64] = f[(degf - i) as u64]   i = i + 1i64 }
    let ld : i64 = out[degf as u64]
    if ld < 0i64 {
        i = 0i64
        while i <= degf { out[i as u64] = 0i64 - out[i as u64]   i = i + 1i64 }
    }
    return degf
}

fn rs_gcd(a0: i64, b0: i64) -> i64 {
    let mut a : i64 = a0   if a < 0i64 { a = 0i64 - a }
    let mut b : i64 = b0   if b < 0i64 { b = 0i64 - b }
    while b != 0i64 { let r : i64 = a % b   a = b   b = r }
    return a
}

/* strip the integer content (rational scaling introduces it: e.g. alpha * 1/2 yields content 4);
 * lead normalized positive.  Returns the content stripped, or -1 on a zero polynomial. */
fn rs_primitive(outp: u64, deg: i64) -> i64 @export {
    let out : *i64 = outp as *i64
    let mut c : i64 = 0i64
    let mut i : i64 = 0i64
    while i <= deg { c = rs_gcd(c, out[i as u64])   i = i + 1i64 }
    if c == 0i64 { return 0i64 - 1i64 }
    i = 0i64
    while i <= deg { out[i as u64] = out[i as u64] / c   i = i + 1i64 }
    let ld : i64 = out[deg as u64]
    if ld < 0i64 {
        i = 0i64
        while i <= deg { out[i as u64] = 0i64 - out[i as u64]   i = i + 1i64 }
    }
    return c
}

fn rs_powi(b: i64, e: i64) -> i64 {
    let mut r : i64 = 1i64
    let mut q : i64 = 0i64
    while q < e { r = rs_mul(r, b)   q = q + 1i64 }
    return r
}

/* ═════════ v2: THE MODULAR-CRT DETERMINANT ENGINE (the charter's "bigint determinant engine") ═════════
 * Same construction as rs_sum, unbounded intermediates: every Sylvester value R(t) is computed mod
 * 256 SELF-GENERATED 30-bit primes (rs_pinit: deterministic trial division, gate-pinned) -- i64
 * products never exceed 2^60 -- the coefficient residues are recovered per prime by LAGRANGE
 * interpolation (rs_recover), and the integers by Garner CRT into UNSIGNED bigints in a
 * per-coefficient dropped arena.
 * SOUNDNESS: |coeff_i| <= ||R||_1 <= prod_rows(row 1-norm of the t-polynomial Sylvester)  [permanent
 * bound]; we CERTIFY bound_bits + 2 <= 7424 <= bits(P) BEFORE trusting centered reconstruction, and
 * re-check  sum_i q_i t^i == R(t)  mod every prime afterwards.  Recovery geometry: D <= 384 (385
 * nodes, stride-385 matrices; operands degree <= 192 each) -- the bnd certification is PER RUN, so
 * the window refuses honestly whenever a coefficient bound exceeds 7424 bits, at ANY D.  Refusals
 * (-1): degrees beyond storage, zero leading input coefficients, bound not certifiable, or a
 * recovered coefficient beyond i64 out. */

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(arena: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_add(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_sub(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mul_u64(arena: u64, a: u64, scalar: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_cmp(a: u64, b: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_len_limbs(id: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_get_limb(id: u64, i: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_to_u64_lo(id: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_is_zero(id: u64) -> u8 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop_arena(arena: u64) -> i32 from "bigint.iii"

/* raw bigint-output rows (V-I.2): filled when RSB_WANT == 1 (rs_*_big2) */
var RSB_WANT : i64
var RSB_SGN : [i64; 386]   var RSB_LEN : [i64; 386]   var RSB_FIT : [i64; 386]
var RSB_LIMB : [u64; 49408]                              /* coefficient i limb j at i*128+j -- 128-limb
                                                          * rows (8192 bits) COVER the 7424-bit window:
                                                          * everything the bound certifies is deliverable */

/* THE SELF-GENERATING, SELF-CERTIFYING PRIME WINDOW: the 256 largest primes below 2^30, GENERATED
 * at first use by deterministic trial division (exact for n < 2^30: divisors <= 2^15) -- no table
 * to transcribe wrong, ever.  The first 16 generated primes ARE the historical hardcoded table
 * (gate-pinned in 2186), so every sealed output stays byte-identical: a value X with |X| < P16/2
 * reconstructs to the SAME centered integer under the larger P256.  Primes 17..256 lift the
 * certified ceiling 464 -> 7424 bits (256 primes, each > 2^29 -> bits(prod) > 256*29). */
const RS_NP : i64 = 256i64
var RS_PRIMES : [i64; 256]
var RS_PINIT : i64
fn rs_isp30(n: i64) -> i64 {
    if (n % 2i64) == 0i64 { return 0i64 }
    let mut d : i64 = 3i64
    while (d * d) <= n {
        if (n % d) == 0i64 { return 0i64 }
        d = d + 2i64
    }
    return 1i64
}
fn rs_pinit() -> i32 {
    if RS_PINIT != 0i64 { return 0i32 }
    let mut n : i64 = 1073741823i64                        /* 2^30 - 1, descending */
    let mut k : i64 = 0i64
    while k < RS_NP {
        if rs_isp30(n) == 1i64 { RS_PRIMES[k as u64] = n   k = k + 1i64 }
        n = n - 2i64
    }
    RS_PINIT = 1i64
    return 0i32
}
/* the generated table, readable for gate pinning */
fn rs_prime(i: i64) -> i64 @export {
    rs_pinit()
    if i < 0i64 { return 0i64 }
    if i >= RS_NP { return 0i64 }
    return RS_PRIMES[i as u64]
}
fn rs_modp(v: i64, p: i64) -> i64 { let m : i64 = v % p   if m < 0i64 { return m + p }   return m }
fn rs_minv(a0: i64, p: i64) -> i64 {                       /* extended Euclid; gcd(a0,p)=1 assumed */
    let mut t : i64 = 0i64    let mut nt : i64 = 1i64
    let mut r : i64 = p       let mut nr : i64 = rs_modp(a0, p)
    while nr != 0i64 {
        let q : i64 = r / nr
        let t2 : i64 = t - (q * nt)    t = nt   nt = t2
        let r2 : i64 = r - (q * nr)    r = nr   nr = r2
    }
    if t < 0i64 { t = t + p }
    return t
}
fn rs_powmod(b: i64, e: i64, p: i64) -> i64 {
    let bm : i64 = rs_modp(b, p)
    let mut r : i64 = 1i64
    let mut q : i64 = 0i64
    while q < e { r = (r * bm) % p   q = q + 1i64 }
    return r
}
fn rs_bits(v0: i64) -> i64 {
    let mut v : i64 = v0
    let mut b : i64 = 0i64
    while v > 0i64 { v = v / 2i64   b = b + 1i64 }
    return b
}

var RS_MM : [i64; 148225]                                 /* modular working matrix, stride 385 */
var RS_HM : [i64; 386]                                     /* h(x) = g(t-x) mod p */
var RS_RMOD : [i64; 98560]                                /* R(t) mod p_l at index t*256+l (t<=384) */
var RS_CR : [i64; 256]                                    /* current coefficient residues */
var RS_Q : [i64; 386]                                     /* recovered integer coefficients */
var RS_ND : [i64; 386]                                    /* interpolation nodes (row r samples t = RS_ND[r]) */

/* Gauss determinant mod p of the n x n matrix in RS_MM (destructive) */
fn rs_det_mod(n: i64, p: i64) -> i64 {
    let mut det : i64 = 1i64
    let mut k : i64 = 0i64
    while k < n {
        let pkk : i64 = RS_MM[((k * 385i64) + k) as u64]
        if pkk == 0i64 {
            let mut found : i64 = 0i64 - 1i64
            let mut r : i64 = k + 1i64
            while r < n {
                if found < 0i64 { let v : i64 = RS_MM[((r * 385i64) + k) as u64]   if v != 0i64 { found = r } }
                r = r + 1i64
            }
            if found < 0i64 { return 0i64 }
            let mut c : i64 = 0i64
            while c < n {
                let t : i64 = RS_MM[((k * 385i64) + c) as u64]
                RS_MM[((k * 385i64) + c) as u64] = RS_MM[((found * 385i64) + c) as u64]
                RS_MM[((found * 385i64) + c) as u64] = t
                c = c + 1i64
            }
            det = rs_modp(0i64 - det, p)
        }
        let pv : i64 = RS_MM[((k * 385i64) + k) as u64]
        det = (det * pv) % p
        let inv : i64 = rs_minv(pv, p)
        let mut i : i64 = k + 1i64
        while i < n {
            let fct : i64 = (RS_MM[((i * 385i64) + k) as u64] * inv) % p
            if fct != 0i64 {
                let mut j : i64 = k
                while j < n {
                    let sub : i64 = (fct * RS_MM[((k * 385i64) + j) as u64]) % p
                    RS_MM[((i * 385i64) + j) as u64] = rs_modp(RS_MM[((i * 385i64) + j) as u64] - sub, p)
                    j = j + 1i64
                }
            }
            i = i + 1i64
        }
        k = k + 1i64
    }
    return det
}

/* C(j,i) by the interleaved multiplicative formula (every prefix is itself a binomial
 * coefficient, so each division is exact) with the STICKY overflow guard: past the i64 range
 * (C(j,i)*j wraps around degree ~61) the caller's RS_OVF fallback takes over -- a silent wrap
 * can never reach a bound. */
fn rs_binom(j: i64, i: i64) -> i64 {
    let mut b : i64 = 1i64
    let mut q : i64 = 0i64
    while q < i {
        b = rs_mul(b, j - q) / (q + 1i64)
        q = q + 1i64
    }
    return b
}

/* Pascal's triangle mod p to degree dg (additive recurrence -- exact residues at ANY degree,
 * no inverses): C(j,i) mod p at RS_PAS[j*193 + i].  Filled once per prime by rs_gamma_big. */
var RS_PAS : [i64; 148225]
fn rs_pascal(dg: i64, p: i64) -> i32 {
    let mut j : i64 = 0i64
    while j <= dg {
        RS_PAS[(j * 385i64) as u64] = 1i64
        RS_PAS[((j * 385i64) + j) as u64] = 1i64
        let mut i : i64 = 1i64
        while i < j {
            let s2 : i64 = RS_PAS[(((j - 1i64) * 385i64) + (i - 1i64)) as u64] + RS_PAS[(((j - 1i64) * 385i64) + i) as u64]
            RS_PAS[((j * 385i64) + i) as u64] = rs_modp(s2, p)
            i = i + 1i64
        }
        j = j + 1i64
    }
    return 0i32
}

fn rs_shift_mod(gp: u64, degg: i64, t: i64, p: i64) -> i32 {
    let g : *i64 = gp as *i64
    let tm : i64 = rs_modp(t, p)
    let mut i : i64 = 0i64
    while i <= degg {
        let mut acc : i64 = 0i64
        let mut j : i64 = i
        while j <= degg {
            let binom : i64 = RS_PAS[((j * 385i64) + i) as u64]
            let mut pw : i64 = 1i64
            let mut q : i64 = 0i64
            while q < (j - i) { pw = (pw * tm) % p   q = q + 1i64 }
            let gm : i64 = rs_modp(g[j as u64], p)
            acc = (acc + ((gm * binom) % p) * pw) % p
            j = j + 1i64
        }
        if (i % 2i64) != 0i64 { acc = rs_modp(0i64 - acc, p) }
        RS_HM[i as u64] = acc
        i = i + 1i64
    }
    return 0i32
}

/* value of the (nonnegative) bigint mod p, by limb walk high->low */
fn rs_bigmod(id: u64, p: i64) -> i64 {
    let pu : u64 = p as u64
    let b32 : u64 = 4294967296u64 % pu
    let pw64 : u64 = (b32 * b32) % pu                      /* 2^64 mod p; operands < 2^30 */
    let mut r : u64 = 0u64
    let mut i : u64 = bigint_len_limbs(id)
    while i > 0u64 {
        i = i - 1u64
        let lm : u64 = bigint_get_limb(id, i)
        r = ((r * pw64) + (lm % pu)) % pu
    }
    return r as i64
}

fn rs_shift_prod_mod(gp: u64, degg: i64, t: i64, p: i64) -> i32 {
    let g : *i64 = gp as *i64
    let mut k : i64 = 0i64
    while k <= degg {
        let gm : i64 = rs_modp(g[(degg - k) as u64], p)
        RS_HM[k as u64] = (gm * rs_powmod(t, degg - k, p)) % p
        k = k + 1i64
    }
    return 0i32
}

/* gamma = alpha OP beta beyond the i64 envelope.  op 0 = SUM, op 1 = PRODUCT. */
fn rs_gamma_big(fp: u64, degf: i64, gp: u64, degg: i64, outp: u64, op: i64) -> i64 {
    rs_pinit()
    let f : *i64 = fp as *i64
    let g : *i64 = gp as *i64
    let out : *i64 = outp as *i64
    let D : i64 = degf * degg
    if D < 1i64 { return 0i64 - 1i64 }
    if D > 384i64 { return 0i64 - 1i64 }                   /* recovery geometry: 385 nodes, stride-385 matrix */
    if degf > 192i64 { return 0i64 - 1i64 }
    if degg > 192i64 { return 0i64 - 1i64 }
    let flead : i64 = f[degf as u64]
    let glead : i64 = g[degg as u64]
    if flead == 0i64 { return 0i64 - 1i64 }
    if glead == 0i64 { return 0i64 - 1i64 }

    /* ── the certified coefficient bound: ||R||_1 <= (frow)^degg * (hrow)^degf ── */
    RS_OVF = 0i64
    let mut frow : i64 = 0i64
    let mut j : i64 = 0i64
    while j <= degf { let mut av : i64 = f[j as u64]   if av < 0i64 { av = 0i64 - av }   frow = rs_add(frow, av)   j = j + 1i64 }
    let mut hrow : i64 = 0i64
    let mut i : i64 = 0i64
    if op == 0i64 {
        while i <= degg {
            let mut hi : i64 = 0i64
            j = i
            while j <= degg {
                let binom : i64 = rs_binom(j, i)           /* exact at every prefix; deg-48 safe */
                let mut gv : i64 = g[j as u64]
                if gv < 0i64 { gv = 0i64 - gv }
                hi = rs_add(hi, rs_mul(gv, binom))
                j = j + 1i64
            }
            hrow = rs_add(hrow, hi)
            i = i + 1i64
        }
    }
    if op == 1i64 {                                        /* prod entry x^k = g_{degg-k} t^(degg-k): 1-norm |g| */
        while i <= degg {
            let mut gv : i64 = g[i as u64]
            if gv < 0i64 { gv = 0i64 - gv }
            hrow = rs_add(hrow, gv)
            i = i + 1i64
        }
    }
    let mut bnd : i64 = 0i64
    if RS_OVF == 0i64 { bnd = (degg * rs_bits(frow)) + (degf * rs_bits(hrow)) }
    else {
        /* the exact row-norm sums overflowed i64 (large coefficients / degrees): fall back to a
         * SOUND bits-domain OVER-bound -- log2(sum) <= log2(max) + log2(count), and for the SUM
         * shape log2(h_i mass) <= degg + 1 (binomial row mass).  Over-bounding only narrows
         * acceptance; the exact path is untouched wherever it could already certify. */
        RS_OVF = 0i64
        let mut mxf : i64 = 0i64
        let mut j5 : i64 = 0i64
        while j5 <= degf { let mut av2 : i64 = f[j5 as u64]   if av2 < 0i64 { av2 = 0i64 - av2 }   if av2 > mxf { mxf = av2 }   j5 = j5 + 1i64 }
        let mut mxg : i64 = 0i64
        j5 = 0i64
        while j5 <= degg { let mut gv2 : i64 = g[j5 as u64]   if gv2 < 0i64 { gv2 = 0i64 - gv2 }   if gv2 > mxg { mxg = gv2 }   j5 = j5 + 1i64 }
        let bf : i64 = rs_bits(mxf) + rs_bits(degf + 1i64)
        let mut bh : i64 = rs_bits(mxg) + rs_bits(degg + 1i64)
        if op == 0i64 { bh = bh + degg + 1i64 }
        bnd = (degg * bf) + (degf * bh)
    }
    if (bnd + 2i64) > 7424i64 { return 0i64 - 1i64 }

    /* ── per-prime residues of R(t) for t = 0..D ── */
    let mut nd0 : i64 = 0i64
    while nd0 <= D { RS_ND[nd0 as u64] = nd0   nd0 = nd0 + 1i64 }
    let mut l : i64 = 0i64
    while l < 256i64 {
        let p : i64 = RS_PRIMES[l as u64]
        if op == 0i64 { rs_pascal(degg, p) }               /* C(j,i) mod p for the shift rows */
        let mut t : i64 = 0i64
        while t <= D {
            if op == 0i64 { rs_shift_mod(gp, degg, t, p) }
            if op == 1i64 { rs_shift_prod_mod(gp, degg, t, p) }
            let n : i64 = degf + degg
            let mut r : i64 = 0i64
            while r < n { let mut c : i64 = 0i64   while c < n { RS_MM[((r * 385i64) + c) as u64] = 0i64   c = c + 1i64 }   r = r + 1i64 }
            r = 0i64
            while r < degg {
                let mut k : i64 = 0i64
                while k <= degf { RS_MM[((r * 385i64) + (r + k)) as u64] = rs_modp(f[(degf - k) as u64], p)   k = k + 1i64 }
                r = r + 1i64
            }
            r = 0i64
            while r < degf {
                let mut k : i64 = 0i64
                while k <= degg { RS_MM[(((degg + r) * 385i64) + (r + k)) as u64] = RS_HM[(degg - k) as u64]   k = k + 1i64 }
                r = r + 1i64
            }
            RS_RMOD[((t * 256i64) + l) as u64] = rs_det_mod(n, p)
            t = t + 1i64
        }
        l = l + 1i64
    }

    /* ── per-coefficient modular Cramer + Garner CRT + consistency (the factored pipeline) ── */
    if rs_recover(D) < 0i64 { return 0i64 - 1i64 }
    if rs_consist(D) < 0i64 { return 0i64 - 1i64 }
    let mut ld : i64 = RS_Q[D as u64]
    if RSB_WANT == 1i64 { ld = RSB_SGN[D as u64] }
    if ld < 0i64 {
        i = 0i64
        while i <= D {
            RS_Q[i as u64] = 0i64 - RS_Q[i as u64]
            if RSB_WANT == 1i64 { RSB_SGN[i as u64] = 0i64 - RSB_SGN[i as u64] }
            i = i + 1i64
        }
    }
    i = 0i64
    while i <= D { out[i as u64] = RS_Q[i as u64]   i = i + 1i64 }
    return D
}
/* residue of raw coefficient row i mod p (limb walk, sign applied) */
fn rs_rawmod(i: i64, p: i64) -> i64 {
    let pu : u64 = p as u64
    let b32 : u64 = 4294967296u64 % pu
    let pw64 : u64 = (b32 * b32) % pu
    let mut r : u64 = 0u64
    let mut j : i64 = RSB_LEN[i as u64]
    while j > 0i64 {
        j = j - 1i64
        let lm : u64 = RSB_LIMB[((i as u64) * 128u64) + (j as u64)]
        r = ((r * pw64) + (lm % pu)) % pu
    }
    let mut v : i64 = r as i64
    let sg : i64 = RSB_SGN[i as u64]
    if sg < 0i64 { if v != 0i64 { v = p - v } }
    return v
}

/* (the Vandermonde-determinant precheck retired with the Cramer recovery: the LAGRANGE recovery
 * below guards node distinctness directly -- a zero denominator prod_{s!=r}(t_r - t_s) mod p IS
 * det(V) == 0 mod p, refused at the same surface.) */

/* ── THE CRT KERNEL (one substrate, shared by the 1D and the trivariate pipelines) ──
 * Garner CRT + centered reconstruction of ONE integer from the 64 residues in RS_CR, allocating in
 * the caller's arena (all transient handles dropped before return).  Leaves the value in module
 * scratch: RS_CT_SGN (-1/0/+1), RS_CT_LEN (limbs; 0 for the zero value; if > 64 the limbs are NOT
 * copied -- the caller must treat that as beyond storage), RS_CT_FIT (magnitude fits i64),
 * RS_CT_LO (low limb), RS_CT_LIMB[0..RS_CT_LEN). */
var RS_CT_SGN : i64   var RS_CT_LEN : i64   var RS_CT_FIT : i64   var RS_CT_LO : u64
var RS_CT_LIMB : [u64; 128]
fn rs_crt_center(ar: u64) -> i32 {
    let cr0 : i64 = RS_CR[0u64]
    let mut X : u64 = bigint_from_u64(ar, cr0 as u64)
    let mut PB : u64 = bigint_from_u64(ar, RS_PRIMES[0u64] as u64)
    let mut l : i64 = 1i64
    while l < 256i64 {
        let p : i64 = RS_PRIMES[l as u64]
        let mut pm : i64 = 1i64                            /* prod_{j<l} p_j mod p */
        let mut jj : i64 = 0i64
        while jj < l { pm = (pm * (RS_PRIMES[jj as u64] % p)) % p   jj = jj + 1i64 }
        let xm : i64 = rs_bigmod(X, p)
        let crl : i64 = RS_CR[l as u64]
        let m : i64 = (rs_modp(crl - xm, p) * rs_minv(pm, p)) % p
        let t1 : u64 = bigint_mul_u64(ar, PB, m as u64)
        let t2 : u64 = bigint_add(ar, X, t1)
        bigint_drop(X)   bigint_drop(t1)
        X = t2
        let t3 : u64 = bigint_mul_u64(ar, PB, RS_PRIMES[l as u64] as u64)
        bigint_drop(PB)
        PB = t3
        l = l + 1i64
    }
    let Y : u64 = bigint_sub(ar, PB, X)                    /* PB is now the full P; X in [0,P) */
    let cw : i32 = bigint_cmp(X, Y)
    let mut sgn : i64 = 1i64
    let mut mag : u64 = X
    if cw > 0i32 { sgn = 0i64 - 1i64   mag = Y }
    let ln : u64 = bigint_len_limbs(mag)
    let mut zln : u64 = ln
    if bigint_is_zero(mag) == 1u8 { zln = 0u64 }
    let mut fits : i64 = 1i64
    if zln > 1u64 { fits = 0i64 }
    let lo : u64 = bigint_to_u64_lo(mag)
    if lo > 9223372036854775807u64 { fits = 0i64 }
    let mut sg2 : i64 = sgn
    if zln == 0u64 { sg2 = 0i64 }
    RS_CT_SGN = sg2   RS_CT_LEN = zln as i64   RS_CT_FIT = fits   RS_CT_LO = lo
    if zln <= 128u64 {
        let mut j2 : u64 = 0u64
        while j2 < zln { RS_CT_LIMB[j2] = bigint_get_limb(mag, j2)   j2 = j2 + 1u64 }
    }
    bigint_drop(X)   bigint_drop(Y)   bigint_drop(PB)
    return 0i32
}

/* per-prime LAGRANGE interpolation + Garner CRT: RS_RMOD -> RS_Q
 * (+ the RSB_* raw rows when RSB_WANT).  The interpolating polynomial mod p is UNIQUE, so every
 * recovered residue -- and hence every CRT output -- is byte-identical to the Cramer/Vandermonde
 * recovery this replaces, at O(n^2) per prime instead of O(n^4); rs_consist still re-checks
 * every node mod every prime afterwards, so a recovery defect is a REFUSAL, never a wrong
 * coefficient.  The CRT runs in a PER-COEFFICIENT arena (the rs3_crt_rows law): the Garner
 * chain's transient allocations are dominated by the prime-product chain (~130 KB at 256 primes)
 * plus the value's own limbs (<= 116; a NEGATIVE value walks full-width, ~370-900 KB) -- a bump
 * arena SHARED across coefficients would grow with D+1 (D = 384: tens of MB, past any fixed size)
 * while the per-coefficient peak stays bounded (2 MiB arena, >= 2x the worst walk).
 * -1 refused (degenerate nodes / arena unavailable / output width without RSB_WANT / row
 * overflow). */
var RS_LM2 : [i64; 392]                                    /* master polynomial (x - t_0)...(x - t_D) mod p:
                                                            * degree D+1 -> index D+1 <= 385 (the [200] of the
                                                            * D<=192 era would SILENTLY overflow at D > 198 --
                                                            * caught by this rung's widening audit) */
var RS_LQ2 : [i64; 392]                                    /* master / (x - t_r) */
var RS_LCR : [i64; 98816]                                  /* recovered residues: coeff i, prime l at i*256+l */
fn rs_recover(D: i64) -> i64 {
    let nv : i64 = D + 1i64
    let mut l : i64 = 0i64
    while l < 256i64 {
        let p : i64 = RS_PRIMES[l as u64]
        /* master M(x) = prod_r (x - t_r) mod p, built incrementally in place */
        RS_LM2[0u64] = 1i64
        let mut md : i64 = 0i64
        let mut r : i64 = 0i64
        while r < nv {
            let tm : i64 = rs_modp(RS_ND[r as u64], p)
            RS_LM2[(md + 1i64) as u64] = 0i64
            let mut j : i64 = md + 1i64
            while j >= 1i64 {
                let v : i64 = rs_modp(RS_LM2[(j - 1i64) as u64] - ((tm * RS_LM2[j as u64]) % p), p)
                RS_LM2[j as u64] = v
                j = j - 1i64
            }
            RS_LM2[0u64] = rs_modp(0i64 - ((tm * RS_LM2[0u64]) % p), p)
            md = md + 1i64
            r = r + 1i64
        }
        /* zero this prime's residue column */
        let mut i0 : i64 = 0i64
        while i0 <= D { RS_LCR[((i0 * 256i64) + l) as u64] = 0i64   i0 = i0 + 1i64 }
        /* per node: Q_r = M/(x - t_r) by synthetic division; d_r = Q_r(t_r); accumulate w_r * Q_r */
        r = 0i64
        while r < nv {
            let tm : i64 = rs_modp(RS_ND[r as u64], p)
            RS_LQ2[D as u64] = RS_LM2[nv as u64]
            let mut j2 : i64 = D - 1i64
            while j2 >= 0i64 {
                RS_LQ2[j2 as u64] = rs_modp(RS_LM2[(j2 + 1i64) as u64] + ((tm * RS_LQ2[(j2 + 1i64) as u64]) % p), p)
                j2 = j2 - 1i64
            }
            /* d_r = Q_r(t_r) = prod_{s != r}(t_r - t_s): zero IFF nodes degenerate -> refuse */
            let mut dr : i64 = 0i64
            let mut j3 : i64 = D
            while j3 >= 0i64 { dr = rs_modp((dr * tm) + RS_LQ2[j3 as u64], p)   j3 = j3 - 1i64 }
            if dr == 0i64 { return 0i64 - 1i64 }
            let w : i64 = (RS_RMOD[((r * 256i64) + l) as u64] * rs_minv(dr, p)) % p
            let mut j4 : i64 = 0i64
            while j4 <= D {
                let acc : i64 = rs_modp(RS_LCR[((j4 * 256i64) + l) as u64] + ((w * RS_LQ2[j4 as u64]) % p), p)
                RS_LCR[((j4 * 256i64) + l) as u64] = acc
                j4 = j4 + 1i64
            }
            r = r + 1i64
        }
        l = l + 1i64
    }
    let mut i : i64 = 0i64
    while i <= D {
        let mut l2 : i64 = 0i64
        while l2 < 256i64 { RS_CR[l2 as u64] = RS_LCR[((i * 256i64) + l2) as u64]   l2 = l2 + 1i64 }
        let ar : u64 = arena_new(2097152u64)
        if ar == 0u64 { return 0i64 - 1i64 }
        rs_crt_center(ar)
        bigint_drop_arena(ar)
        arena_drop(ar)
        let ctl : i64 = RS_CT_LEN
        let ctf : i64 = RS_CT_FIT
        if RSB_WANT == 1i64 {
            if ctl > 128i64 { return 0i64 - 1i64 }
            RSB_SGN[i as u64] = RS_CT_SGN   RSB_LEN[i as u64] = ctl   RSB_FIT[i as u64] = ctf
            let mut j2 : i64 = 0i64
            while j2 < ctl { RSB_LIMB[((i as u64) * 128u64) + (j2 as u64)] = RS_CT_LIMB[j2 as u64]   j2 = j2 + 1i64 }
        }
        if ctf == 0i64 {
            if RSB_WANT == 0i64 { return 0i64 - 1i64 }
            RS_Q[i as u64] = 0i64
        } else {
            let mut qv : i64 = RS_CT_LO as i64
            if RS_CT_SGN < 0i64 { qv = 0i64 - qv }
            RS_Q[i as u64] = qv
        }
        i = i + 1i64
    }
    return 0i64
}

/* sum_i q_i * node^i == R(node) mod EVERY prime, at every node.  -1 on any mismatch. */
fn rs_consist(D: i64) -> i64 {
    let mut l : i64 = 0i64
    while l < 256i64 {
        let p : i64 = RS_PRIMES[l as u64]
        let mut t : i64 = 0i64
        while t <= D {
            let mut acc : i64 = 0i64
            let mut i : i64 = 0i64
            while i <= D {
                let mut ri : i64 = 0i64
                if RSB_WANT == 1i64 { ri = rs_rawmod(i, p) } else { ri = rs_modp(RS_Q[i as u64], p) }
                acc = (acc + (ri * rs_powmod(RS_ND[t as u64], i, p))) % p
                i = i + 1i64
            }
            let rv : i64 = RS_RMOD[((t * 256i64) + l) as u64]
            if acc != rv { return 0i64 - 1i64 }
            t = t + 1i64
        }
        l = l + 1i64
    }
    return 0i64
}

/* ═════════ MULTIVARIATE ELIMINATION (Turing-next N-1): Res_u of two BIVARIATE integer polynomials
 * f(u,t), g(u,t) -- grids with the coefficient of u^i t^j at [i*8 + j] -- as an integer polynomial
 * in t, through the SAME 16-prime evaluation/interpolation pipeline: Sylvester entries are grid rows
 * evaluated at the node mod p.  Nodes SKIP any integer where either u-leading coefficient vanishes
 * over Z (a degenerate Sylvester computes the wrong resultant there -- the classical hazard, handled
 * by node selection, never by hoping).  D = fdu*gdt + gdu*fdt bounds deg_t Res; D = 0 is allowed --
 * a CONSTANT resultant is the strongest possible statement (the outcome is independent of the
 * surviving variable: the universal quantifier, cashed). */
fn rs_gr_evalmod(gp: u64, row: i64, dt: i64, t: i64, p: i64) -> i64 {
    let g : *i64 = gp as *i64
    let tm : i64 = rs_modp(t, p)
    let mut acc : i64 = 0i64
    let mut j : i64 = dt
    while j >= 0i64 {
        acc = ((acc * tm) + rs_modp(g[((row * 8i64) + j) as u64], p)) % p
        j = j - 1i64
    }
    return acc
}
fn rs_gr_evali(gp: u64, row: i64, dt: i64, t: i64) -> i64 {
    let g : *i64 = gp as *i64
    let mut acc : i64 = 0i64
    let mut j : i64 = dt
    while j >= 0i64 { acc = rs_add(rs_mul(acc, t), g[((row * 8i64) + j) as u64])   j = j - 1i64 }
    return acc
}
fn rs_elim(fp: u64, fdu: i64, fdt: i64, gp: u64, gdu: i64, gdt: i64, outp: u64) -> i64 @export {
    rs_pinit()
    RSB_WANT = 0i64
    let f : *i64 = fp as *i64
    let g : *i64 = gp as *i64
    let out : *i64 = outp as *i64
    if fdu < 1i64 { return 0i64 - 1i64 }
    if gdu < 1i64 { return 0i64 - 1i64 }
    if fdu > 7i64 { return 0i64 - 1i64 }
    if gdu > 7i64 { return 0i64 - 1i64 }
    if fdt < 0i64 { return 0i64 - 1i64 }
    if gdt < 0i64 { return 0i64 - 1i64 }
    if fdt > 7i64 { return 0i64 - 1i64 }
    if gdt > 7i64 { return 0i64 - 1i64 }
    let D : i64 = (fdu * gdt) + (gdu * fdt)
    if D > 18i64 { return 0i64 - 1i64 }
    if (fdu + gdu) > 18i64 { return 0i64 - 1i64 }
    /* the u-leading rows must be nonzero polynomials */
    let mut lfnz : i64 = 0i64
    let mut j : i64 = 0i64
    while j <= fdt { if f[((fdu * 8i64) + j) as u64] != 0i64 { lfnz = 1i64 }   j = j + 1i64 }
    if lfnz == 0i64 { return 0i64 - 1i64 }
    let mut lgnz : i64 = 0i64
    j = 0i64
    while j <= gdt { if g[((gdu * 8i64) + j) as u64] != 0i64 { lgnz = 1i64 }   j = j + 1i64 }
    if lgnz == 0i64 { return 0i64 - 1i64 }
    /* certified coefficient bound: ||Res||_1 <= (grid 1-norm of f)^gdu * (grid 1-norm of g)^fdu */
    RS_OVF = 0i64
    let mut fnorm : i64 = 0i64
    let mut i : i64 = 0i64
    while i <= fdu { j = 0i64   while j <= fdt { let mut av : i64 = f[((i * 8i64) + j) as u64]   if av < 0i64 { av = 0i64 - av }   fnorm = rs_add(fnorm, av)   j = j + 1i64 }   i = i + 1i64 }
    let mut gnorm : i64 = 0i64
    i = 0i64
    while i <= gdu { j = 0i64   while j <= gdt { let mut av : i64 = g[((i * 8i64) + j) as u64]   if av < 0i64 { av = 0i64 - av }   gnorm = rs_add(gnorm, av)   j = j + 1i64 }   i = i + 1i64 }
    if RS_OVF != 0i64 { return 0i64 - 1i64 }
    let bnd : i64 = (gdu * rs_bits(fnorm)) + (fdu * rs_bits(gnorm))
    if (bnd + 2i64) > 7424i64 { return 0i64 - 1i64 }
    /* node selection: D+1 integers where BOTH u-leads are nonzero over Z */
    let mut nd : i64 = 0i64
    let mut tc : i64 = 0i64
    while nd <= D {
        if tc > (D + 9i64) { return 0i64 - 1i64 }
        let lf : i64 = rs_gr_evali(fp, fdu, fdt, tc)
        let lg : i64 = rs_gr_evali(gp, gdu, gdt, tc)
        if RS_OVF != 0i64 { return 0i64 - 1i64 }
        let mut ok : i64 = 1i64
        if lf == 0i64 { ok = 0i64 }
        if lg == 0i64 { ok = 0i64 }
        if ok == 1i64 { RS_ND[nd as u64] = tc   nd = nd + 1i64 }
        tc = tc + 1i64
    }
    /* per-prime residues at the nodes */
    let mut l : i64 = 0i64
    while l < 256i64 {
        let p : i64 = RS_PRIMES[l as u64]
        let mut r : i64 = 0i64
        while r <= D {
            let tv : i64 = RS_ND[r as u64]
            let n : i64 = fdu + gdu
            let mut r0 : i64 = 0i64
            while r0 < n { let mut c0 : i64 = 0i64   while c0 < n { RS_MM[((r0 * 385i64) + c0) as u64] = 0i64   c0 = c0 + 1i64 }   r0 = r0 + 1i64 }
            r0 = 0i64
            while r0 < gdu {
                let mut k : i64 = 0i64
                while k <= fdu { RS_MM[((r0 * 385i64) + (r0 + k)) as u64] = rs_gr_evalmod(fp, fdu - k, fdt, tv, p)   k = k + 1i64 }
                r0 = r0 + 1i64
            }
            r0 = 0i64
            while r0 < fdu {
                let mut k : i64 = 0i64
                while k <= gdu { RS_MM[(((gdu + r0) * 385i64) + (r0 + k)) as u64] = rs_gr_evalmod(gp, gdu - k, gdt, tv, p)   k = k + 1i64 }
                r0 = r0 + 1i64
            }
            RS_RMOD[((r * 256i64) + l) as u64] = rs_det_mod(n, p)
            r = r + 1i64
        }
        l = l + 1i64
    }
    if rs_recover(D) < 0i64 { return 0i64 - 1i64 }
    if rs_consist(D) < 0i64 { return 0i64 - 1i64 }
    let ld : i64 = RS_Q[D as u64]
    if ld < 0i64 {
        i = 0i64
        while i <= D { RS_Q[i as u64] = 0i64 - RS_Q[i as u64]   i = i + 1i64 }
    }
    i = 0i64
    while i <= D { out[i as u64] = RS_Q[i as u64]   i = i + 1i64 }
    return D
}
fn rs_sum_big(fp: u64, degf: i64, gp: u64, degg: i64, outp: u64) -> i64 @export {
    RSB_WANT = 0i64
    return rs_gamma_big(fp, degf, gp, degg, outp, 0i64)
}
fn rs_prod_big(fp: u64, degf: i64, gp: u64, degg: i64, outp: u64) -> i64 @export {
    let g : *i64 = gp as *i64
    let g0 : i64 = g[0u64]
    if g0 == 0i64 { return 0i64 - 1i64 }
    RSB_WANT = 0i64
    return rs_gamma_big(fp, degf, gp, degg, outp, 1i64)
}

/* ═════════ THE BIGINT OUTPUT ABI (Turing charter V-I.2): coefficients BEYOND i64 delivered, not
 * refused -- as raw sign/limb rows (the same shape sturm_big's sturm2_in_* rows consume).  The i64
 * out[] still receives the coefficients that fit; the ones that do not are marked (rs_big_fit(i)==0)
 * and readable exactly via rs_big_sgn/len/limb.  The mod-every-prime consistency check runs on the
 * FULL values (limb-walk residues), so the delivered bigints carry the same certificate. ═════════ */
fn rs_big_sgn(i: i64) -> i64 @export { return RSB_SGN[i as u64] }
fn rs_big_len(i: i64) -> i64 @export { return RSB_LEN[i as u64] }
fn rs_big_fit(i: i64) -> i64 @export { return RSB_FIT[i as u64] }
fn rs_big_limb(i: i64, j: i64) -> u64 @export { return RSB_LIMB[((i * 128i64) + j) as u64] }
fn rs_sum_big2(fp: u64, degf: i64, gp: u64, degg: i64, outp: u64) -> i64 @export {
    RSB_WANT = 1i64
    let d : i64 = rs_gamma_big(fp, degf, gp, degg, outp, 0i64)
    RSB_WANT = 0i64
    return d
}
fn rs_prod_big2(fp: u64, degf: i64, gp: u64, degg: i64, outp: u64) -> i64 @export {
    let g : *i64 = gp as *i64
    let g0 : i64 = g[0u64]
    if g0 == 0i64 { return 0i64 - 1i64 }
    RSB_WANT = 1i64
    let d : i64 = rs_gamma_big(fp, degf, gp, degg, outp, 1i64)
    RSB_WANT = 0i64
    return d
}

/* ═════════ TRIVARIATE ELIMINATION (Vector I): Res_z of two TRIVARIATE integer polynomials
 * F(z,x,y), G(z,x,y) -- grids with the coefficient of z^k x^i y^j at [k*25 + i*5 + j] (each degree
 * <= 4) -- as a BIVARIATE integer polynomial R(x,y), out grid coefficient of x^a y^b at [a*33 + b],
 * through the SAME certified 16-prime pipeline factored onto a TENSOR grid: per prime, the
 * fixed-layout Sylvester determinant is evaluated at the (Dx+1)*(Dy+1) integer nodes (r,s) in
 * 0..Dx x 0..Dy, the bivariate coefficients are recovered by two-stage Lagrange interpolation
 * (in x per y-node, then in y), Garner-CRT reconstructed per coefficient through rs_crt_center,
 * and re-checked against EVERY node residue mod EVERY prime before delivery.
 *
 * SOUNDNESS.  (1) The interpolated object is det(Syl_z(F,G)) AS A POLYNOMIAL in (x,y): det is a
 * polynomial in the matrix entries and evaluation at (r,s) is a ring homomorphism Z[x,y] -> Z, so
 * det(Syl evaluated) == (det Syl)(r,s) UNCONDITIONALLY -- tensor nodes need only be DISTINCT
 * (0..Dx, 0..Dy), never lead-tested: the classical degenerate-specialization hazard concerns the
 * resultant of the SPECIALIZED (degree-dropped) polynomials, a matrix this pipeline never builds.
 * (2) deg_x R <= Dx = gdz*fdx + fdz*gdx and deg_y R <= Dy = gdz*fdy + fdz*gdy (a determinant takes
 * ONE entry per row).  (3) ||R||_1 <= Fnorm^gdz * Gnorm^fdz (the permanent bound over row 1-norms),
 * CERTIFIED against the 16-prime window before centered CRT is trusted.  (4) GEOMETRY: every common
 * zero of F and G projects into {R = 0} (shadow completeness: where both z-leads vanish the first
 * Sylvester column is zero; otherwise Res specializes up to a nonzero lead power); the CONVERSE
 * needs the lead conditions -- extraneous shadow points can appear only where BOTH z-leads vanish.
 * The delivered polynomial is the TRUE determinant -- sign canonical, NOT lead-normalized (unlike
 * rs_elim): R(x,y) IS det Syl_z(F,G), coefficient for coefficient.
 * Refusals (-1): z-degree outside [1,4], x/y-degree outside [0,4], an identically-zero z-lead grid
 * row (the declared degree must be TRUE), Dx or Dy beyond 32, norm overflow, bound beyond the prime
 * window, or (strict rs_elim3 only) a recovered coefficient beyond i64.  rs_elim3_big delivers
 * EVERY coefficient as raw sign/limb rows (<= 8 limbs -- guaranteed by rs3's OWN 464-bit ceiling, kept:
 * the same shape a b3_slice feeds into sturm_big's sturm2_in_* rows; the 8-limb row geometry is
 * WHY rs3 keeps 464 while the 1D pipeline certifies to 7424). ═════════ */

var RS3_DX : i64   var RS3_DY : i64
var RS3_RES : [i64; 278784]                                 /* node dets: ((r*(Dy+1)+s)*256 + l) */
var RS3_CMOD : [i64; 278784]                                /* coeff residues: ((a*(Dy+1)+b)*256 + l) */
var RS3_XST : [i64; 1089]                                  /* stage-1 x-coeffs at (a*(Dy+1)+s) */
var RS3_CRES : [i64; 1089]                                 /* per-prime recovered-coeff residues */
var RS3_LM : [i64; 35]                                     /* Lagrange master polynomial */
var RS3_LQ : [i64; 34]                                     /* master / (x - node) */
var RS3_LV : [i64; 34]   var RS3_LC : [i64; 34]            /* one line: values in, coeffs out */
var RS3B_SGN : [i64; 1089]   var RS3B_LEN : [i64; 1089]   var RS3B_FIT : [i64; 1089]
var RS3B_LIMB : [u64; 8712]                                /* coefficient m limb j at m*8+j */
var RS3_WANT : i64

fn rs3_dx() -> i64 @export { return RS3_DX }
fn rs3_dy() -> i64 @export { return RS3_DY }
fn rs3_big_sgn(a: i64, b: i64) -> i64 @export { return RS3B_SGN[((a * (RS3_DY + 1i64)) + b) as u64] }
fn rs3_big_len(a: i64, b: i64) -> i64 @export { return RS3B_LEN[((a * (RS3_DY + 1i64)) + b) as u64] }
fn rs3_big_fit(a: i64, b: i64) -> i64 @export { return RS3B_FIT[((a * (RS3_DY + 1i64)) + b) as u64] }
fn rs3_big_limb(a: i64, b: i64, j: i64) -> u64 @export { return RS3B_LIMB[((((a * (RS3_DY + 1i64)) + b) * 8i64) + j) as u64] }

/* z-coefficient row k of a trivariate grid, evaluated at integer (x,y) = (r,s) mod p: nested Horner. */
fn rs3_cvalmod(mp: u64, k: i64, dx: i64, dy: i64, r: i64, s: i64, p: i64) -> i64 {
    let m : *i64 = mp as *i64
    let rm : i64 = rs_modp(r, p)
    let sm : i64 = rs_modp(s, p)
    let mut acc : i64 = 0i64
    let mut i : i64 = dx
    while i >= 0i64 {
        let mut inner : i64 = 0i64
        let mut j : i64 = dy
        while j >= 0i64 {
            inner = ((inner * sm) + rs_modp(m[((k * 25i64) + (i * 5i64) + j) as u64], p)) % p
            j = j - 1i64
        }
        acc = ((acc * rm) + inner) % p
        i = i - 1i64
    }
    return acc
}

/* Lagrange interpolation over the nodes 0..D mod p: values RS3_LV[0..D] -> coefficients RS3_LC[0..D].
 * Master M(x) = prod_r (x - r); per node i, Q_i = M/(x - i) by synthetic division, d_i = Q_i(i) =
 * prod_{j != i} (i - j) != 0 mod p (|i - j| <= 32 << p); C += v_i * d_i^{-1} * Q_i.  O(D^2). */
fn rs3_lagr(D: i64, p: i64) -> i32 {
    RS3_LM[0u64] = 1i64
    let mut dm : i64 = 0i64
    let mut r : i64 = 0i64
    while r <= D {
        let rm : i64 = rs_modp(r, p)
        RS3_LM[(dm + 1i64) as u64] = 0i64
        let mut i : i64 = dm
        while i >= 0i64 {
            let mi : i64 = RS3_LM[i as u64]
            RS3_LM[(i + 1i64) as u64] = (RS3_LM[(i + 1i64) as u64] + mi) % p
            RS3_LM[i as u64] = rs_modp(0i64 - ((rm * mi) % p), p)
            i = i - 1i64
        }
        dm = dm + 1i64
        r = r + 1i64
    }
    let mut a : i64 = 0i64
    while a <= D { RS3_LC[a as u64] = 0i64   a = a + 1i64 }
    let mut nd : i64 = 0i64
    while nd <= D {
        let im : i64 = rs_modp(nd, p)
        RS3_LQ[D as u64] = RS3_LM[(D + 1i64) as u64]
        let mut k : i64 = D - 1i64
        while k >= 0i64 {
            RS3_LQ[k as u64] = (RS3_LM[(k + 1i64) as u64] + ((im * RS3_LQ[(k + 1i64) as u64]) % p)) % p
            k = k - 1i64
        }
        let mut dv : i64 = 0i64
        k = D
        while k >= 0i64 { dv = ((dv * im) + RS3_LQ[k as u64]) % p   k = k - 1i64 }
        let vi : i64 = RS3_LV[nd as u64]
        let w : i64 = (rs_modp(vi, p) * rs_minv(dv, p)) % p
        k = 0i64
        while k <= D { RS3_LC[k as u64] = (RS3_LC[k as u64] + ((w * RS3_LQ[k as u64]) % p)) % p   k = k + 1i64 }
        nd = nd + 1i64
    }
    return 0i32
}

/* the z-lead grid row of a trivariate poly must be a NONZERO bivariate polynomial */
fn rs3_leadchk(mp: u64, dz: i64, dx: i64, dy: i64) -> i64 {
    let m : *i64 = mp as *i64
    let mut nz : i64 = 0i64
    let mut i : i64 = 0i64
    while i <= dx {
        let mut j : i64 = 0i64
        while j <= dy {
            let v : i64 = m[((dz * 25i64) + (i * 5i64) + j) as u64]
            if v != 0i64 { nz = 1i64 }
            j = j + 1i64
        }
        i = i + 1i64
    }
    return nz
}

/* guarded grid 1-norm (all coefficients, all z-rows) */
fn rs3_norm(mp: u64, dz: i64, dx: i64, dy: i64) -> i64 {
    let m : *i64 = mp as *i64
    let mut nrm : i64 = 0i64
    let mut k : i64 = 0i64
    while k <= dz {
        let mut i : i64 = 0i64
        while i <= dx {
            let mut j : i64 = 0i64
            while j <= dy {
                let mut av : i64 = m[((k * 25i64) + (i * 5i64) + j) as u64]
                if av < 0i64 { av = 0i64 - av }
                nrm = rs_add(nrm, av)
                j = j + 1i64
            }
            i = i + 1i64
        }
        k = k + 1i64
    }
    return nrm
}

/* per-prime node determinants into RS3_RES (fixed-layout Sylvester, entries by nested Horner) */
fn rs3_nodes(fp: u64, fdz: i64, fdx: i64, fdy: i64, gp: u64, gdz: i64, gdx: i64, gdy: i64, Dx: i64, Dy: i64) -> i32 {
    let n : i64 = fdz + gdz
    let Dy1 : i64 = Dy + 1i64
    let mut l : i64 = 0i64
    while l < 256i64 {
        let p : i64 = RS_PRIMES[l as u64]
        let mut r : i64 = 0i64
        while r <= Dx {
            let mut s : i64 = 0i64
            while s <= Dy {
                let mut r0 : i64 = 0i64
                while r0 < n { let mut c0 : i64 = 0i64   while c0 < n { RS_MM[((r0 * 385i64) + c0) as u64] = 0i64   c0 = c0 + 1i64 }   r0 = r0 + 1i64 }
                r0 = 0i64
                while r0 < gdz {
                    let mut kk : i64 = 0i64
                    while kk <= fdz { RS_MM[((r0 * 385i64) + (r0 + kk)) as u64] = rs3_cvalmod(fp, fdz - kk, fdx, fdy, r, s, p)   kk = kk + 1i64 }
                    r0 = r0 + 1i64
                }
                r0 = 0i64
                while r0 < fdz {
                    let mut kk : i64 = 0i64
                    while kk <= gdz { RS_MM[(((gdz + r0) * 385i64) + (r0 + kk)) as u64] = rs3_cvalmod(gp, gdz - kk, gdx, gdy, r, s, p)   kk = kk + 1i64 }
                    r0 = r0 + 1i64
                }
                RS3_RES[((((r * Dy1) + s) * 256i64) + l) as u64] = rs_det_mod(n, p)
                s = s + 1i64
            }
            r = r + 1i64
        }
        l = l + 1i64
    }
    return 0i32
}

/* two-stage tensor interpolation per prime: RS3_RES -> RS3_CMOD */
fn rs3_interp(Dx: i64, Dy: i64) -> i32 {
    let Dy1 : i64 = Dy + 1i64
    let mut l : i64 = 0i64
    while l < 256i64 {
        let p : i64 = RS_PRIMES[l as u64]
        let mut s : i64 = 0i64
        while s <= Dy {
            let mut r : i64 = 0i64
            while r <= Dx { RS3_LV[r as u64] = RS3_RES[((((r * Dy1) + s) * 256i64) + l) as u64]   r = r + 1i64 }
            rs3_lagr(Dx, p)
            let mut a : i64 = 0i64
            while a <= Dx { RS3_XST[((a * Dy1) + s) as u64] = RS3_LC[a as u64]   a = a + 1i64 }
            s = s + 1i64
        }
        let mut a2 : i64 = 0i64
        while a2 <= Dx {
            let mut s2 : i64 = 0i64
            while s2 <= Dy { RS3_LV[s2 as u64] = RS3_XST[((a2 * Dy1) + s2) as u64]   s2 = s2 + 1i64 }
            rs3_lagr(Dy, p)
            let mut b : i64 = 0i64
            while b <= Dy { RS3_CMOD[((((a2 * Dy1) + b) * 256i64) + l) as u64] = RS3_LC[b as u64]   b = b + 1i64 }
            a2 = a2 + 1i64
        }
        l = l + 1i64
    }
    return 0i32
}

/* Garner CRT per coefficient (per-coefficient arena -- the bump arena never shrinks, and ncoef can
 * be 1089: a single shared arena would grow without bound).  Sized for the WORST Garner walk: a
 * NEGATIVE coefficient's partial value X tracks ~P itself at every step (the centered value is
 * P - |c|), so all three transients run full width -- ~97 KB at 128 primes; 1 MiB is 10x that.
 * (65536 sufficed at 64 primes and exhausted at 128 -- the 2473/2474 finding.)  Rows ALWAYS
 * delivered.  -1 on a row beyond 8 limbs (impossible under the certified bound -- an engine
 * defect, refused not masked). */
fn rs3_crt_rows(ncoef: i64) -> i64 {
    let mut m : i64 = 0i64
    while m < ncoef {
        let mut l : i64 = 0i64
        while l < 256i64 { RS_CR[l as u64] = RS3_CMOD[((m * 256i64) + l) as u64]   l = l + 1i64 }
        let ar : u64 = arena_new(2097152u64)
        rs_crt_center(ar)
        bigint_drop_arena(ar)
        arena_drop(ar)
        let ctl : i64 = RS_CT_LEN
        if ctl > 8i64 { return 0i64 - 1i64 }
        RS3B_SGN[m as u64] = RS_CT_SGN   RS3B_LEN[m as u64] = ctl   RS3B_FIT[m as u64] = RS_CT_FIT
        let mut j : i64 = 0i64
        while j < ctl { RS3B_LIMB[((m * 8i64) + j) as u64] = RS_CT_LIMB[j as u64]   j = j + 1i64 }
        m = m + 1i64
    }
    return 0i64
}

/* residue of raw row m mod p (limb walk, sign applied) */
fn rs3_rawmod(m: i64, p: i64) -> i64 {
    let pu : u64 = p as u64
    let b32 : u64 = 4294967296u64 % pu
    let pw64 : u64 = (b32 * b32) % pu
    let mut r : u64 = 0u64
    let mut j : i64 = RS3B_LEN[m as u64]
    while j > 0i64 {
        j = j - 1i64
        let lm : u64 = RS3B_LIMB[((m * 8i64) + j) as u64]
        r = ((r * pw64) + (lm % pu)) % pu
    }
    let mut v : i64 = r as i64
    let sg : i64 = RS3B_SGN[m as u64]
    if sg < 0i64 { if v != 0i64 { v = p - v } }
    return v
}

/* sum_{a,b} c_ab r^a s^b == the node determinant, at EVERY node mod EVERY prime (limb-walk residues
 * of the FULL delivered values -- the certificate covers the raw rows, not just the i64 shadows). */
fn rs3_consist(Dx: i64, Dy: i64) -> i64 {
    let Dy1 : i64 = Dy + 1i64
    let ncoef : i64 = (Dx + 1i64) * Dy1
    let mut l : i64 = 0i64
    while l < 256i64 {
        let p : i64 = RS_PRIMES[l as u64]
        let mut m : i64 = 0i64
        while m < ncoef { RS3_CRES[m as u64] = rs3_rawmod(m, p)   m = m + 1i64 }
        let mut r : i64 = 0i64
        while r <= Dx {
            let rm : i64 = rs_modp(r, p)
            let mut s : i64 = 0i64
            while s <= Dy {
                let sm : i64 = rs_modp(s, p)
                let mut acc : i64 = 0i64
                let mut a : i64 = Dx
                while a >= 0i64 {
                    let mut inner : i64 = 0i64
                    let mut b : i64 = Dy
                    while b >= 0i64 { inner = ((inner * sm) + RS3_CRES[((a * Dy1) + b) as u64]) % p   b = b - 1i64 }
                    acc = ((acc * rm) + inner) % p
                    a = a - 1i64
                }
                let rv : i64 = RS3_RES[((((r * Dy1) + s) * 256i64) + l) as u64]
                if acc != rv { return 0i64 - 1i64 }
                s = s + 1i64
            }
            r = r + 1i64
        }
        l = l + 1i64
    }
    return 0i64
}

fn rs_gamma3(fp: u64, fdz: i64, fdx: i64, fdy: i64, gp: u64, gdz: i64, gdx: i64, gdy: i64, outp: u64) -> i64 {
    rs_pinit()
    if fdz < 1i64 { return 0i64 - 1i64 }
    if gdz < 1i64 { return 0i64 - 1i64 }
    if fdz > 4i64 { return 0i64 - 1i64 }
    if gdz > 4i64 { return 0i64 - 1i64 }
    if fdx < 0i64 { return 0i64 - 1i64 }
    if fdx > 4i64 { return 0i64 - 1i64 }
    if fdy < 0i64 { return 0i64 - 1i64 }
    if fdy > 4i64 { return 0i64 - 1i64 }
    if gdx < 0i64 { return 0i64 - 1i64 }
    if gdx > 4i64 { return 0i64 - 1i64 }
    if gdy < 0i64 { return 0i64 - 1i64 }
    if gdy > 4i64 { return 0i64 - 1i64 }
    let Dx : i64 = (gdz * fdx) + (fdz * gdx)
    let Dy : i64 = (gdz * fdy) + (fdz * gdy)
    if Dx > 32i64 { return 0i64 - 1i64 }
    if Dy > 32i64 { return 0i64 - 1i64 }
    let lf : i64 = rs3_leadchk(fp, fdz, fdx, fdy)
    if lf == 0i64 { return 0i64 - 1i64 }
    let lg : i64 = rs3_leadchk(gp, gdz, gdx, gdy)
    if lg == 0i64 { return 0i64 - 1i64 }
    RS_OVF = 0i64
    let fnorm : i64 = rs3_norm(fp, fdz, fdx, fdy)
    let gnorm : i64 = rs3_norm(gp, gdz, gdx, gdy)
    if RS_OVF != 0i64 { return 0i64 - 1i64 }
    let bnd : i64 = (gdz * rs_bits(fnorm)) + (fdz * rs_bits(gnorm))
    if (bnd + 2i64) > 464i64 { return 0i64 - 1i64 }
    RS3_DX = Dx   RS3_DY = Dy
    let Dy1 : i64 = Dy + 1i64
    rs3_nodes(fp, fdz, fdx, fdy, gp, gdz, gdx, gdy, Dx, Dy)
    rs3_interp(Dx, Dy)
    let ncoef : i64 = (Dx + 1i64) * Dy1
    let rc : i64 = rs3_crt_rows(ncoef)
    if rc < 0i64 { return 0i64 - 1i64 }
    let cc : i64 = rs3_consist(Dx, Dy)
    if cc < 0i64 { return 0i64 - 1i64 }
    let out : *i64 = outp as *i64
    let mut m : i64 = 0i64
    while m < ncoef {
        let ft : i64 = RS3B_FIT[m as u64]
        let a : i64 = m / Dy1
        let b : i64 = m % Dy1
        if ft == 0i64 {
            if RS3_WANT == 0i64 { return 0i64 - 1i64 }
            out[((a * 33i64) + b) as u64] = 0i64
        } else {
            let ln : i64 = RS3B_LEN[m as u64]
            let mut qv : i64 = 0i64
            if ln > 0i64 { qv = RS3B_LIMB[(m * 8i64) as u64] as i64 }
            let sg : i64 = RS3B_SGN[m as u64]
            if sg < 0i64 { qv = 0i64 - qv }
            out[((a * 33i64) + b) as u64] = qv
        }
        m = m + 1i64
    }
    return 0i64
}
fn rs_elim3(fp: u64, fdz: i64, fdx: i64, fdy: i64, gp: u64, gdz: i64, gdx: i64, gdy: i64, outp: u64) -> i64 @export {
    RS3_WANT = 0i64
    return rs_gamma3(fp, fdz, fdx, fdy, gp, gdz, gdx, gdy, outp)
}
fn rs_elim3_big(fp: u64, fdz: i64, fdx: i64, fdy: i64, gp: u64, gdz: i64, gdx: i64, gdy: i64, outp: u64) -> i64 @export {
    RS3_WANT = 1i64
    let d : i64 = rs_gamma3(fp, fdz, fdx, fdy, gp, gdz, gdx, gdy, outp)
    RS3_WANT = 0i64
    return d
}
