/* aether/reversibility.iii -- THE REVERSIBILITY HUNT: III autonomously discovers the
 * INFORMATION-CONSERVING fragment of its own operation space.
 *
 * The unifying fact under rva (the verifier), billiard (reversible physics), the NOMOS
 * involutions, intent's Oracle of Rejection, and the friction cost: an operation either
 * PRESERVES information (a bijection -- reversible, self-recoverable, Landauer heat floor
 * ZERO) or DESTROYS it (a measurable deficit = bits erased, the thermodynamic cost).
 * rva PROVES a caller-supplied (f, g) pair; this organ is the missing layer -- it SEES
 * the opportunity, it does not need to be handed f or g.
 *
 * THE HUNT (autonomous, non-guided, GENUINE):
 *   (1) ENUMERATE: walk isa_ontogenesis's fair term enumeration over THIS die's live
 *       atoms (the index<->term bijection; I pick no operation).  Each term is a unary
 *       operation f(x) = term(x, 0).
 *   (2) BUILD in bv_bits with true mod-2^W closure -- the atoms via their base-op
 *       definiens (NOT/NEG/AND/OR/XOR/ADD/SUB/MUL/SHL/SHR/ANDN and the BMI singletons
 *       BLSI=x&-x, BLSMSK=x^(x-1), BLSR=x&(x-1)).  The count/deposit atoms (POPCNT/
 *       LZCNT/TZCNT/PDEP/PEXT) are individually IRREVERSIBLE many->few maps and are not
 *       bit-blastable -- terms using them are SKIPPED by name (honest, never a fake pass).
 *   (3) DECIDE by EXHAUSTIVE INJECTIVITY over the FULL 2^W domain: with true mod-2^W
 *       semantics, domain = codomain, so injective <=> BIJECTION.  2x is correctly 2-to-1
 *       (loses the top bit) and REFUSED; x^2 is correctly non-injective and REFUSED.  This
 *       is genuine reversibility, decided by exhaustion, not retrieved from a catalog.
 *   (4) INVOLUTION: bb_equal(f(f(x)), x) -- PROVEN over all 2^W that the operation undoes
 *       ITSELF (the do-and-undo-at-net-zero primitive; NOMOS's NOT/NEG are the first two).
 *   (5) DEFICIT: for an irreversible f, the largest fiber -> bits erased (Landauer, MEASURED).
 *
 * A reversible found here is width-parametric for the algebraic families and promotable to
 * rva's full-2^64 SMT proof + admission -- discovery FEEDS the verifier, never duplicates
 * it.  Novelty is ADJUDICATED downstream (SOVEREIGN/FIRST-COMPUTED; NOVEL reserved for what
 * survives).  Hexad: kind_essence.  Ring: R0.  NIH: composes isa_ontogenesis + numera/bv_bits. */
module aether_reversibility

extern @abi(c-msvc-x64) fn ia_init() -> i64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_tcount(m: i64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_term_ser(t_idx: u64, out_addr: u64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_atom_arity(id: i64) -> i64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_apply1(atom: i64, a: u64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn ia_apply2(atom: i64, a: u64, b: u64) -> u64 from "isa_ontogenesis.iii"
extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_not(a: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_and(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_or(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_xor(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_add(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_sub(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_mul(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shl(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shr(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_equal(a: u32, b: u32) -> u8 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_set_input(v: u32, val: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_eval(t: u32) -> u64 from "bv_bits.iii"

const RV_W    : u64 = 13u64                /* full domain 2^13 = 8192 -- injective <=> bijection */
const RV_N    : u64 = 8192u64
const RV_HN   : u64 = 16384u64
const RV_SENT : u64 = 18446744073709551615u64

/* ---- build the term (ser in RV_SER) as a bb node over the given input node.  Sets
 * RV_UNSUP=1 if a count/deposit atom or a variable shift (not bit-blastable) is hit. ---- */
var RV_SER   : [u8; 64]
var RV_SLN   : u64 = 0u64
var RV_CUR   : u64 = 0u64
var RV_UNSUP : u64 = 0u64
var RV_INPUT : u32 = 0u32
var RV_YC    : u64 = 0u64
fn rv_shift_amt(n: u32) -> u64 {
    /* a bit-blastable shift needs a CONSTANT amount: same value regardless of x.
     * (for size<=3 terms the amount subterm is a leaf/single atom, so a 2-point
     * check settles constness; a variable shift is not bit-blastable -> UNSUP.) */
    bb_set_input(0u32, 0u64)
    let v0 : u64 = bb_eval(n)
    bb_set_input(0u32, 1u64)
    let v1 : u64 = bb_eval(n)
    if v0 == v1 { return v0 & 63u64 }
    RV_UNSUP = 1u64
    return 0u64
}
fn rv_build() -> u32 {
    if RV_CUR >= RV_SLN { RV_UNSUP = 1u64   return bb_const(0u64) }
    let b : u8 = RV_SER[RV_CUR]
    RV_CUR = RV_CUR + 1u64
    if b == 0u8 { return RV_INPUT }
    if b == 1u8 { return bb_const(RV_YC) }
    let atom : i64 = (b as i64) - 2i64
    if ia_atom_arity(atom) == 1i64 {
        let a : u32 = rv_build()
        if atom == 0i64 { return bb_not(a) }
        if atom == 1i64 { return bb_sub(bb_const(0u64), a) }
        if atom == 2i64 { return bb_and(a, bb_sub(bb_const(0u64), a)) }              /* BLSI  */
        if atom == 3i64 { return bb_xor(a, bb_sub(a, bb_const(1u64))) }              /* BLSMSK */
        if atom == 4i64 { return bb_and(a, bb_sub(a, bb_const(1u64))) }              /* BLSR  */
        RV_UNSUP = 1u64                                                              /* POPCNT/LZCNT/TZCNT */
        return bb_const(0u64)
    }
    let a : u32 = rv_build()
    let c : u32 = rv_build()
    if atom == 8i64  { return bb_and(a, c) }
    if atom == 9i64  { return bb_or(a, c) }
    if atom == 10i64 { return bb_xor(a, c) }
    if atom == 11i64 { return bb_add(a, c) }
    if atom == 12i64 { return bb_sub(a, c) }
    if atom == 13i64 { return bb_mul(a, c) }
    if atom == 14i64 { return bb_shl(a, rv_shift_amt(c)) }
    if atom == 15i64 { return bb_shr(a, rv_shift_amt(c)) }
    if atom == 16i64 { return bb_and(bb_not(a), c) }                                 /* ANDN */
    RV_UNSUP = 1u64                                                                  /* PDEP/PEXT */
    return bb_const(0u64)
}

/* injectivity hash-set (generation-stamped, open addressing) */
var RV_HV  : [u64; 16384]
var RV_HG  : [u64; 16384]
var RV_HC  : [u64; 16384]
var RV_GEN : u64 = 0u64
fn rv_hins(v: u64) -> u64 {
    let mut h : u64 = (v ^ (v >> 33u64)) * 12297829382473034411u64
    h = (h ^ (h >> 29u64)) % RV_HN
    let mut probe : u64 = 0u64
    while probe < RV_HN {
        let s : u64 = (h + probe) % RV_HN
        if RV_HG[s] != RV_GEN { RV_HG[s] = RV_GEN   RV_HV[s] = v   RV_HC[s] = 1u64   return 0u64 }
        if RV_HV[s] == v { RV_HC[s] = RV_HC[s] + 1u64   return RV_HC[s] }
        probe = probe + 1u64
    }
    return RV_SENT
}

var RV_REV_N   : u64 = 0u64
var RV_INV_N   : u64 = 0u64
var RV_MAXDEF  : u64 = 0u64
var RV_EXAM    : u64 = 0u64
var RV_SKIP    : u64 = 0u64
var RV_NONTRIV : u64 = 0u64                /* reversibles that USE a nonlinear/BMI atom */
var RV_REVSER  : [u8; 4096]
var RV_REVLEN  : [u64; 64]
var RV_REVINV  : [u8; 64]
var RV_REVNL   : [u8; 64]
var RV_REVY    : [u64; 64]
var RV_REVSTORE : u64 = 0u64
/* the second-operand parameter sweep: the shift amounts / operand constants that turn
 * XOR(x,SHL(x,y)) into the xorshift x^(x<<y), MUL(x,y) into x*y, etc.  III sweeps the
 * parameter space fairly; it does not hand-pick a value. */
var RV_YVALS : [u64; 24] = [0u64, 1u64, 2u64, 3u64, 4u64, 5u64, 6u64, 7u64, 8u64, 9u64, 11u64, 13u64, 1u64, 3u64, 5u64, 7u64, 9u64, 15u64, 255u64, 12u64, 10u64, 6u64, 2u64, 4u64]
const RV_NY : u64 = 12u64

/* does the current ser use a nonlinear (MUL) or BMI (BLSI/BLSMSK/BLSR) atom? */
fn rv_uses_nonlinear() -> u64 {
    let mut i : u64 = 0u64
    while i < RV_SLN {
        let b : u8 = RV_SER[i]
        if b >= 2u8 { let id : i64 = (b as i64) - 2i64
            if id == 13i64 { return 1u64 }
            if id == 2i64 { return 1u64 }   if id == 3i64 { return 1u64 }   if id == 4i64 { return 1u64 } }
        i = i + 1u64
    }
    return 0u64
}

/* ==== THE AUTONOMOUS INVERSION: III recovers a reversible LINEAR op's inverse ITSELF.
 * It is handed only the forward bb node f (no inverse, no label); it probes f's GF(2)
 * matrix on the electrons (f(e_j) ^ f(0) = column j), inverts it by Gaussian elimination
 * over GF(2), builds the inverse operation, and PROVES bb_equal(g(f(x)), x) over all 2^W.
 * The forward/inverse matrix DENSITY (1s per row = GF(2) op-count) is the friction
 * asymmetry: a bijection cheap forward but dear to undo is a COMPUTATIONAL DIODE -- the
 * reversibility(bijection) x taxis(friction) object, sovereign to this die. ==== */
var RV_MCOL : [u64; 64]
var RV_MROW : [u64; 64]
var RV_MINV : [u64; 64]
var RV_WRK  : [u64; 64]
var RV_MC   : u64 = 0u64
var RV_FWDD : u64 = 0u64
var RV_INVD : u64 = 0u64
var RV_MAXASYM : u64 = 0u64                 /* max inverse/forward density ratio (x100) seen */
var RV_DIODE_SER : [u8; 64]                 /* the ser of the sharpest computational diode */
var RV_DIODE_LEN : u64 = 0u64
var RV_DIODE_Y   : u64 = 0u64
var RV_DIODE_FWD : u64 = 0u64
var RV_DIODE_INV : u64 = 0u64
var RV_LINREV    : u64 = 0u64               /* linear reversibles whose inverse III PROVED */
var RV_DIODE_COUNT : u64 = 0u64             /* reversibles whose inverse is strictly DENSER (diodes) */
fn rv_bit(v: u64, i: u64) -> u64 { return (v >> i) & 1u64 }
/* probe f (a built bb node) for GF(2)-affine structure; 1 iff affine (verified on a battery) */
fn rv_probe(f: u32) -> u64 {
    bb_set_input(0u32, 0u64)
    RV_MC = bb_eval(f)
    let mut j : u64 = 0u64
    while j < RV_W { bb_set_input(0u32, 1u64 << j)   RV_MCOL[j] = bb_eval(f) ^ RV_MC   j = j + 1u64 }
    let mut i : u64 = 0u64
    while i < RV_W {
        let mut r : u64 = 0u64
        j = 0u64
        while j < RV_W { if rv_bit(RV_MCOL[j], i) == 1u64 { r = r | (1u64 << j) }   j = j + 1u64 }
        RV_MROW[i] = r
        i = i + 1u64
    }
    let mut s : u64 = 1u64
    let mut ok : u64 = 1u64
    let mut t : u64 = 0u64
    while t < 48u64 {
        s = (s * 6364136223846793005u64) + 1442695040888963407u64
        let v : u64 = s & (RV_N - 1u64)
        let mut mv : u64 = 0u64
        let mut k : u64 = 0u64
        while k < RV_W { if rv_bit(v, k) == 1u64 { mv = mv ^ RV_MCOL[k] }   k = k + 1u64 }
        bb_set_input(0u32, v)
        if (mv ^ RV_MC) != bb_eval(f) { ok = 0u64 }
        t = t + 1u64
    }
    return ok
}
/* invert RV_MROW into RV_MINV over GF(2); 1 iff full rank */
fn rv_gauss() -> u64 {
    let mut i : u64 = 0u64
    while i < RV_W { RV_MINV[i] = 1u64 << i   RV_WRK[i] = RV_MROW[i]   i = i + 1u64 }
    let mut col : u64 = 0u64
    while col < RV_W {
        let mut pr : u64 = col
        let mut found : u64 = 0u64
        let mut scan : u64 = col
        while scan < RV_W { if found == 0u64 { if rv_bit(RV_WRK[scan], col) == 1u64 { pr = scan   found = 1u64 } }   scan = scan + 1u64 }
        if found == 0u64 { return 0u64 }
        let tw : u64 = RV_WRK[col]   RV_WRK[col] = RV_WRK[pr]   RV_WRK[pr] = tw
        let ti : u64 = RV_MINV[col]   RV_MINV[col] = RV_MINV[pr]   RV_MINV[pr] = ti
        let mut r : u64 = 0u64
        while r < RV_W { if r != col { if rv_bit(RV_WRK[r], col) == 1u64 { RV_WRK[r] = RV_WRK[r] ^ RV_WRK[col]   RV_MINV[r] = RV_MINV[r] ^ RV_MINV[col] } }   r = r + 1u64 }
        col = col + 1u64
    }
    return 1u64
}
/* build g(y) = Minv.(y ^ c) as a bb node; g_i = parity(Minv[i] & (y^c)) at bit i */
fn rv_build_inv(yc: u32) -> u32 {
    let mut g : u32 = bb_const(0u64)
    let mut i : u64 = 0u64
    while i < RV_W {
        let mut acc : u32 = bb_const(0u64)
        let mut j : u64 = 0u64
        while j < RV_W { if rv_bit(RV_MINV[i], j) == 1u64 { acc = bb_xor(acc, bb_and(bb_shr(yc, j), bb_const(1u64))) }   j = j + 1u64 }
        g = bb_xor(g, bb_shl(acc, i))
        i = i + 1u64
    }
    return g
}
fn rv_density(is_inv: u64) -> u64 {
    let mut n : u64 = 0u64
    let mut i : u64 = 0u64
    while i < RV_W {
        let mut row : u64 = RV_MROW[i]
        if is_inv == 1u64 { row = RV_MINV[i] }
        let mut j : u64 = 0u64
        while j < RV_W { if rv_bit(row, j) == 1u64 { n = n + 1u64 }   j = j + 1u64 }
        i = i + 1u64
    }
    return n
}
/* for the current reversible op (built as node f), if it is LINEAR, construct+PROVE the
 * inverse and record the friction asymmetry; track the sharpest computational diode. */
fn rv_characterize(f: u32) -> i32 {
    if rv_probe(f) == 0u64 { return 0i32 }
    if rv_gauss() == 0u64 { return 0i32 }
    let yc : u32 = bb_xor(f, bb_const(RV_MC))
    let g : u32 = rv_build_inv(yc)
    if bb_equal(g, bb_var(0u32)) != 1u8 { return 0i32 }
    RV_LINREV = RV_LINREV + 1u64
    RV_FWDD = rv_density(0u64)
    RV_INVD = rv_density(1u64)
    /* a COMPUTATIONAL DIODE is a PARAMETRIZED reversible (uses y) whose inverse is
     * strictly DENSER than the forward -- cheap to compute, dear to undo.  Identity
     * and y-independent ops are not diodes. */
    let mut usesy : u64 = 0u64
    let mut si : u64 = 0u64
    while si < RV_SLN { if RV_SER[si] == 1u8 { usesy = 1u64 }   si = si + 1u64 }
    if usesy == 0u64 { return 0i32 }
    if RV_INVD <= RV_FWDD { return 0i32 }
    RV_DIODE_COUNT = RV_DIODE_COUNT + 1u64
    let asym : u64 = (RV_INVD * 100u64) / (RV_FWDD + 1u64)
    if asym > RV_MAXASYM {
        RV_MAXASYM = asym
        RV_DIODE_LEN = RV_SLN
        RV_DIODE_Y = RV_YC
        RV_DIODE_FWD = RV_FWDD
        RV_DIODE_INV = RV_INVD
        let mut i : u64 = 0u64
        while i < RV_SLN { RV_DIODE_SER[i] = RV_SER[i]   i = i + 1u64 }
    }
    return 0i32
}
/* decide the current term.  2 = involution, 1 = reversible, 0 = irreversible, 9 = skipped */
fn rv_decide() -> u64 {
    bb_reset(RV_W)
    RV_UNSUP = 0u64
    RV_INPUT = bb_var(0u32)
    RV_CUR = 0u64
    let f : u32 = rv_build()
    if RV_UNSUP != 0u64 { RV_SKIP = RV_SKIP + 1u64   return 9u64 }
    RV_GEN = RV_GEN + 1u64
    let mut injective : u64 = 1u64
    let mut maxfiber : u64 = 1u64
    let mut x : u64 = 0u64
    while x < RV_N {
        bb_set_input(0u32, x)
        let fx : u64 = bb_eval(f)
        let mult : u64 = rv_hins(fx)
        if mult != 0u64 { injective = 0u64   if mult > maxfiber { maxfiber = mult } }
        x = x + 1u64
    }
    if injective == 0u64 {
        let mut def : u64 = 0u64
        let mut mm : u64 = 1u64
        while mm < maxfiber { mm = mm << 1u64   def = def + 1u64 }
        if def > RV_MAXDEF { RV_MAXDEF = def }
        return 0u64
    }
    /* bijection over 2^W.  INVOLUTION: build f(f(x)) by substitution and PROVE == x. */
    RV_REV_N = RV_REV_N + 1u64
    RV_INPUT = f
    RV_CUR = 0u64
    let ff : u32 = rv_build()
    let mut invol : u64 = 0u64
    if RV_UNSUP == 0u64 { if bb_equal(ff, bb_var(0u32)) == 1u8 { invol = 1u64   RV_INV_N = RV_INV_N + 1u64 } }
    let nl : u64 = rv_uses_nonlinear()
    if nl == 1u64 { RV_NONTRIV = RV_NONTRIV + 1u64 }
    /* AUTONOMOUS INVERSION: if this reversible is LINEAR, recover its inverse by
     * Gaussian elimination over the probed GF(2) matrix, PROVE it, and record the
     * friction asymmetry (the sharpest becomes the computational diode). */
    rv_characterize(f)
    /* store only PARAMETRIZED non-trivial finds: the term must USE the parameter y
     * (contain leaf 1) with a nonzero value, so the reversible is x^(x<<k), x*c, etc.
     * -- the non-obvious finds, not the y-independent involutions NOT(NOT(x)). */
    let mut natoms : u64 = 0u64
    let mut usesy : u64 = 0u64
    let mut ai : u64 = 0u64
    while ai < RV_SLN { if RV_SER[ai] >= 2u8 { natoms = natoms + 1u64 }   if RV_SER[ai] == 1u8 { usesy = 1u64 }   ai = ai + 1u64 }
    if RV_REVSTORE < 40u64 { if natoms >= 1u64 { if usesy == 1u64 { if RV_YC != 0u64 { if nl == 1u64 {
        let base : u64 = RV_REVSTORE * 64u64
        let mut i : u64 = 0u64
        while i < RV_SLN { RV_REVSER[base + i] = RV_SER[i]   i = i + 1u64 }
        RV_REVLEN[RV_REVSTORE] = RV_SLN
        if invol == 1u64 { RV_REVINV[RV_REVSTORE] = 1u8 } else { RV_REVINV[RV_REVSTORE] = 0u8 }
        if nl == 1u64 { RV_REVNL[RV_REVSTORE] = 1u8 } else { RV_REVNL[RV_REVSTORE] = 0u8 }
        RV_REVY[RV_REVSTORE] = RV_YC
        RV_REVSTORE = RV_REVSTORE + 1u64
    } } } } }
    if invol == 1u64 { return 2u64 }
    return 1u64
}
fn rv_hunt(maxsize: i64) -> i32 @export {
    ia_init()
    RV_REV_N = 0u64   RV_INV_N = 0u64   RV_MAXDEF = 0u64   RV_EXAM = 0u64
    RV_SKIP = 0u64    RV_NONTRIV = 0u64  RV_REVSTORE = 0u64  RV_GEN = 0u64
    RV_MAXASYM = 0u64  RV_LINREV = 0u64  RV_DIODE_COUNT = 0u64  RV_DIODE_LEN = 0u64  RV_DIODE_FWD = 0u64  RV_DIODE_INV = 0u64
    let mut i : u64 = 0u64
    while i < RV_HN { RV_HG[i] = 0u64   i = i + 1u64 }
    let mut prefix : u64 = 0u64
    let mut m : i64 = 1i64
    while m <= maxsize { prefix = prefix + ia_tcount(m)   m = m + 1i64 }
    let mut t : u64 = 0u64
    while t < prefix {
        RV_SLN = ia_term_ser(t, (&RV_SER) as u64)
        if RV_SLN > 0u64 { if RV_SLN <= 32u64 {
            /* sweep the second-operand parameter (shift amount / operand constant) */
            let mut yi : u64 = 0u64
            while yi < RV_NY {
                RV_YC = RV_YVALS[yi]
                rv_decide()
                RV_EXAM = RV_EXAM + 1u64
                yi = yi + 1u64
            }
        } }
        t = t + 1u64
    }
    return 0i32
}
/* count occurrences of the x leaf (byte 0) in the current serialization -- the RECONVERGENCE
 * of the term (how many distinct positions x fans out to). */
fn rv_xfanout() -> u64 {
    let mut n : u64 = 0u64
    let mut i : u64 = 0u64
    while i < RV_SLN { if RV_SER[i] == 0u8 { n = n + 1u64 }   i = i + 1u64 }
    return n
}
/* ==== THE COMPUTATIONAL-DIODE HUNT ====
 * Reversibility of a LINEAR map is decided by matrix RANK (W+1 probes + Gaussian
 * elimination) -- NO 2^W brute force -- so this reaches the larger RECONVERGENT terms
 * (x fanned out to >=2 leaves) where diodes actually live, which rv_hunt's exhaustive
 * injectivity cannot afford.  III derives the structural law itself: a single-x linear
 * reversible is always an identity-matrix translation (sparse inverse, zero friction);
 * a COMPUTATIONAL DIODE -- a bijection cheap forward, dear to undo -- NEEDS x to fan out
 * through >=2 distinct linear paths.  So it searches exactly that sublattice.  The xorshift
 * x^(x>>k), core of every PRNG, is the first non-obvious inhabitant it finds and PROVES. */
fn rv_diode_hunt(maxsize: i64) -> i32 @export {
    ia_init()
    RV_MAXASYM = 0u64  RV_LINREV = 0u64  RV_DIODE_COUNT = 0u64  RV_DIODE_LEN = 0u64  RV_DIODE_FWD = 0u64  RV_DIODE_INV = 0u64
    RV_EXAM = 0u64
    let mut prefix : u64 = 0u64
    let mut m : i64 = 1i64
    while m <= maxsize { prefix = prefix + ia_tcount(m)   m = m + 1i64 }
    let mut t : u64 = 0u64
    while t < prefix {
        RV_SLN = ia_term_ser(t, (&RV_SER) as u64)
        if RV_SLN > 0u64 { if RV_SLN <= 32u64 { if rv_xfanout() >= 2u64 {
            let mut yi : u64 = 0u64
            while yi < RV_NY {
                RV_YC = RV_YVALS[yi]
                bb_reset(RV_W)
                RV_UNSUP = 0u64
                RV_INPUT = bb_var(0u32)
                RV_CUR = 0u64
                let f : u32 = rv_build()
                if RV_UNSUP == 0u64 { rv_characterize(f) }
                RV_EXAM = RV_EXAM + 1u64
                yi = yi + 1u64
            }
        } } }
        t = t + 1u64
    }
    return 0i32
}
/* apply unary atom `id` to bb node a (the involution-candidate base ops only) */
fn rv_apply1(id: i64, a: u32) -> u32 {
    if id == 0i64 { return bb_not(a) }                       /* NOT  */
    if id == 1i64 { return bb_sub(bb_const(0u64), a) }       /* NEG  */
    if id == 2i64 { return bb_and(a, bb_sub(bb_const(0u64), a)) }   /* BLSI   */
    if id == 3i64 { return bb_xor(a, bb_sub(a, bb_const(1u64))) }   /* BLSMSK */
    if id == 4i64 { return bb_and(a, bb_sub(a, bb_const(1u64))) }   /* BLSR   */
    return a
}
/* PROVE atom(atom(x)) == x over all 2^W.  This is EXACTLY the property cg_r3's
 * r3_nomos_collapse relies on to fold NOT(NOT(e))->e and NEG(NEG(e))->e: the discovery
 * kernel here and the compiler's reversible-core rewrite are ONE law, cross-proven.  Returns
 * 1 iff `id` is an involution (self-inverse) -- 1 for NOT/NEG, 0 for BLSI/BLSMSK/BLSR. */
fn rv_prove_involution(id: i64) -> u64 @export {
    bb_reset(RV_W)
    let x : u32 = bb_var(0u32)
    let inner : u32 = rv_apply1(id, x)
    let outer : u32 = rv_apply1(id, inner)
    if bb_equal(outer, x) == 1u8 { return 1u64 }
    return 0u64
}
fn rv_find_param(i: u64) -> u64 @export { if i < RV_REVSTORE { return RV_REVY[i] }  return 0u64 }
fn rv_examined() -> u64 @export { return RV_EXAM }
fn rv_reversible() -> u64 @export { return RV_REV_N }
fn rv_involutions() -> u64 @export { return RV_INV_N }
fn rv_max_deficit() -> u64 @export { return RV_MAXDEF }
fn rv_skipped() -> u64 @export { return RV_SKIP }
fn rv_nonlinear_reversibles() -> u64 @export { return RV_NONTRIV }
fn rv_find_count() -> u64 @export { return RV_REVSTORE }
fn rv_find_len(i: u64) -> u64 @export { if i < RV_REVSTORE { return RV_REVLEN[i] }  return 0u64 }
fn rv_find_byte(i: u64, j: u64) -> u8 @export { if i < RV_REVSTORE { if j < 64u64 { return RV_REVSER[(i * 64u64) + j] } }  return 0u8 }
fn rv_find_involution(i: u64) -> u8 @export { if i < RV_REVSTORE { return RV_REVINV[i] }  return 0u8 }
fn rv_find_nonlinear(i: u64) -> u8 @export { if i < RV_REVSTORE { return RV_REVNL[i] }  return 0u8 }
fn rv_linear_inverted() -> u64 @export { return RV_LINREV }
fn rv_diode_count() -> u64 @export { return RV_DIODE_COUNT }
fn rv_max_asymmetry() -> u64 @export { return RV_MAXASYM }
fn rv_diode_len() -> u64 @export { return RV_DIODE_LEN }
fn rv_diode_byte(j: u64) -> u8 @export { if j < 64u64 { return RV_DIODE_SER[j] }  return 0u8 }
fn rv_diode_param() -> u64 @export { return RV_DIODE_Y }
fn rv_diode_fwd() -> u64 @export { return RV_DIODE_FWD }
fn rv_diode_inv() -> u64 @export { return RV_DIODE_INV }

/* ===== THE NONLINEAR INVERSION (2026-07-17): closing rv_characterize's gap ====
 * rv_characterize inverts LINEAR reversibles by probing the GF(2) matrix and
 * Gaussian-eliminating -- but a MUL-odd bijection is NONLINEAR over GF(2)
 * (rv_probe returns 0), so the hunt FINDS x*c reversible yet leaves it
 * un-inverted.  This is the one nonlinear subclass with a closed inverse:
 * multiplication by an ODD constant is a unit in Z/2^64, and its inverse is
 * computed by III itself via Newton iteration  y <- y*(2 - c*y)  (quadratic
 * convergence: y0=c is exact to 3 bits, 5 doublings reach 64).  The inverse is
 * VERIFIED in-organ by round-trip over a battery + walking bits + LCG, and is
 * offered to the ceremony for the numera/bv_ring polynomial-identity proof over
 * all 2^64 (the bit-blast miter times out on double 64x64 MUL -- MEASURED, so
 * the ring judge is the right engine, not iii-prove).  An EVEN c has no inverse
 * (returns 0): its Landauer deficit is exactly tz(c) bits, the erased low zeros. */
fn rv_mul_inverse(c: u64) -> u64 @export {
    if (c & 1u64) == 0u64 { return 0u64 }
    let mut y : u64 = c
    let mut i : u64 = 0u64
    while i < 5u64 {
        y = y * (2u64 - (c * y))
        i = i + 1u64
    }
    return y
}
/* the Landauer deficit in bits of MUL-c: 0 for odd c (reversible), tz(c) for
 * even c (the low zero bits the multiply erases). */
fn rv_mul_deficit(c: u64) -> u64 @export {
    if (c & 1u64) == 1u64 { return 0u64 }
    if c == 0u64 { return 64u64 }
    let mut v : u64 = c
    let mut t : u64 = 0u64
    while (v & 1u64) == 0u64 { v = v >> 1u64   t = t + 1u64 }
    return t
}
/* in-organ round-trip verification of the synthesized mul inverse: cinv*(c*x)==x
 * over the 13-value battery + all 64 walking bits + 128 LCG points.  Returns 1
 * iff the inverse undoes the multiply everywhere sampled (a structural bijection
 * cannot fail; a 0 is a synthesis bug, loud).  0 immediately for even c. */
var RV_MB : [u64; 13] = [0u64, 1u64, 2u64, 18446744073709551615u64, 9223372036854775808u64, 12297829382473034410u64, 6148914691236517205u64, 4294967295u64, 18446744069414584320u64, 81985529216486895u64, 16045690984833335023u64, 9223372036854775809u64, 9223372036854775807u64]
fn rv_mul_roundtrip(c: u64) -> u8 @export {
    if (c & 1u64) == 0u64 { return 0u8 }
    let ci : u64 = rv_mul_inverse(c)
    let mut k : u64 = 0u64
    while k < 13u64 {
        let v : u64 = RV_MB[k]
        if ((v * c) * ci) != v { return 0u8 }
        k = k + 1u64
    }
    k = 0u64
    while k < 64u64 {
        let w : u64 = 1u64 << k
        if ((w * c) * ci) != w { return 0u8 }
        k = k + 1u64
    }
    let mut x : u64 = 88172645463325252u64
    k = 0u64
    while k < 128u64 {
        x = (x ^ (x >> 30u64)) * 13787848793156543929u64
        x = (x ^ (x >> 27u64)) * 10723151780598845931u64
        x = x ^ (x >> 31u64)
        if ((x * c) * ci) != x { return 0u8 }
        k = k + 1u64
    }
    return 1u8
}

/* ==== THE UNIVERSAL REVERSIBLE GATE, THIRD ROUTE (2026-07-17) ====
 * The Toffoli/CCNOT (a,b,c) -> (a,b,c^(a&b)) packed into one word: bit2=a,
 * bit1=b, bit0=c, so t(x) = x ^ ((x>>1)&(x>>2)&1).  primweb proves it
 * self-inverse by SAT (pw_toffoli_self_inverse, gate 1758); weave_graph
 * re-proves it by the melted signature (ws_toffoli_selfinverse, gate 1797);
 * THIS kernel proves it by EXHAUSTION over all 2^13 -- the third independent
 * route.  The substrate verb asserts all three agree in ONE binary: the
 * universal reversible primitive is one law wherever it is spoken. */
fn rv_toffoli_node(inp: u32) -> u32 {
    let ab : u32 = bb_and(bb_shr(inp, 1u64), bb_shr(inp, 2u64))
    return bb_xor(inp, bb_and(ab, bb_const(1u64)))
}
fn rv_prove_toffoli() -> u64 @export {
    bb_reset(RV_W)
    let x : u32 = bb_var(0u32)
    let t : u32 = rv_toffoli_node(x)
    let tt : u32 = rv_toffoli_node(t)
    if bb_equal(tt, x) != 1u8 { return 0u64 }        /* involution: t(t(x)) == x, all 2^13 */
    if bb_equal(t, x) == 1u8 { return 0u64 }         /* biting: t is NOT the identity */
    return 1u64
}
/* universality: with the c wire forced to 1, the Toffoli's c-output IS NAND(a,b):
 * bit0(t(x|1)) == 1 ^ (bit1(x) & bit2(x)), proven over all 2^13. */
fn rv_prove_toffoli_nand() -> u64 @export {
    bb_reset(RV_W)
    let x : u32 = bb_var(0u32)
    let u : u32 = bb_or(x, bb_const(1u64))
    let lhs : u32 = bb_and(rv_toffoli_node(u), bb_const(1u64))
    let ab : u32 = bb_and(bb_and(bb_shr(x, 1u64), bb_shr(x, 2u64)), bb_const(1u64))
    let rhs : u32 = bb_xor(ab, bb_const(1u64))
    if bb_equal(lhs, rhs) == 1u8 { return 1u64 }
    return 0u64
}

/* ==== THE WALKER LENT (2026-07-17): symmetria borrows this kernel's builder.
 * rv_table8 builds a serialized term (y bound to yv) at TRUE mod-2^8 semantics
 * and fills the caller's 256-byte value table; rv_bij13 re-decides the same
 * operation's bijectivity at W=13 by exhaustion (width-stability, the kernel's
 * own standard).  The group organ never re-implements term semantics: one
 * walker, one truth. ==== */
fn rv_table8(ser_addr: u64, len: u64, yv: u64, out_addr: u64) -> u64 @export {
    if len == 0u64 { return 0u64 }
    if len > 32u64 { return 0u64 }
    let sp : *u8 = ser_addr as *u8
    let mut i : u64 = 0u64
    while i < len { RV_SER[i] = sp[i]   i = i + 1u64 }
    RV_SLN = len
    RV_YC = yv
    bb_reset(8u64)
    RV_UNSUP = 0u64
    RV_INPUT = bb_var(0u32)
    RV_CUR = 0u64
    let f : u32 = rv_build()
    if RV_UNSUP != 0u64 { return 0u64 }
    let op : *u8 = out_addr as *u8
    let mut x : u64 = 0u64
    while x < 256u64 {
        bb_set_input(0u32, x)
        op[x] = (bb_eval(f) & 255u64) as u8
        x = x + 1u64
    }
    return 1u64
}
/* ==================== THE FRONTIER (2026-07-17) ====================
 * The bb walker's honest boundary -- the count/deposit atoms (POPCNT/LZCNT/
 * TZCNT/PDEP/PEXT) it SKIPS as not bit-blastable -- is exactly where no
 * existing theory reaches: not GF(2) linear algebra, not the triangular
 * (T-function) invertibility theory, not its bit-mirrored dual, not the
 * hash-finalizer catalog.  This arm hunts CUBE PERMUTATIONS UNDER TRUE DIE
 * SEMANTICS: terms evaluated by the real instructions (ia_apply), domain =
 * the 2^13 cube, and an operation qualifies only if it is a SELF-MAP of the
 * cube (measured, not assumed) that is INJECTIVE by exhaustion -- a genuine
 * permutation, no truncation ring, no catalog.
 *
 * THE PRE-STATED GLOBAL CRITERIA (declared before any run; no target named):
 *   ENUMERATE  isa_ontogenesis's fair index<->term bijection, sizes 1..max,
 *              second operand y swept over the kernel's declared RV_YVALS
 *              prefix -- the same sweep discipline as every other arm.
 *   DECIDE     self-map + injectivity over ALL 2^13 inputs on the die.
 *   EXPLAIN    each permutation is then attacked by every theory III can
 *              name, each test EXHAUSTIVE on the stored value table:
 *                affine       f(x) == f(0) XOR (+)_{j in x} (f(e_j) XOR f(0))
 *                triangular   flipping input bit j never moves an output bit
 *                             below j (the T-function class, invertibility
 *                             charted by Klimov-Shamir)
 *                anti-tri     the bit-mirrored dual (the SHR world)
 *                factorable   f == b(a(x)) for explained permutations a, b
 *                             of THIS run's own registry (depth 2, both
 *                             orders -- the composite/finalizer shapes)
 *   FRONTIER   what survives every explanation is a CERTIFIED-UNEXPLAINED
 *              conservation operation of this die.  For each, III hunts a
 *              CLOSED-FORM inverse in the same fair space (first find in
 *              fair order = the canonical inverse; none in budget = OWED,
 *              docketed, never faked).
 * All counters are printed; caps are named; refusals are counted.  ==== */
var RF_SER  : [u8; 64]
var RF_SLN  : u64 = 0u64
var RF_CUR  : u64 = 0u64
var RF_VX   : u64 = 0u64
var RF_VY   : u64 = 0u64
/* RF_WMASK == 0 : the INTERVAL cube {0..2^W-1} under TRUE 64-bit arithmetic (an op whose
 * result escapes the interval fails the self-map filter -- so only interval-preserving ops
 * qualify).  RF_WMASK == 2^W-1 : the TORUS Z/2^W -- every intermediate is reduced mod 2^W
 * after the real instruction executes, so MUL-odd and the wrap-around bijections live here.
 * This second world is exactly the ring bv_bits models -- EXCEPT bv_bits cannot bit-blast
 * POPCNT/TZCNT/LZCNT/PDEP/PEXT, so a torus term USING those atoms is territory no bit-blast
 * catalog can reach.  The die still executes the real instruction; only the reduction differs. */
var RF_WMASK : u64 = 0u64
fn rf_walk() -> u64 {
    if RF_CUR >= RF_SLN { return 0u64 }
    let b : u8 = RF_SER[RF_CUR]
    RF_CUR = RF_CUR + 1u64
    if b == 0u8 { return RF_VX }
    if b == 1u8 { return RF_VY }
    let atom : i64 = (b as i64) - 2i64
    let a : u64 = rf_walk()
    if ia_atom_arity(atom) == 1i64 {
        let r1 : u64 = ia_apply1(atom, a)
        if RF_WMASK != 0u64 { return r1 & RF_WMASK }
        return r1
    }
    let c : u64 = rf_walk()
    let r2 : u64 = ia_apply2(atom, a, c)
    if RF_WMASK != 0u64 { return r2 & RF_WMASK }
    return r2
}
fn rf_eval(x: u64, y: u64) -> u64 {
    RF_CUR = 0u64
    RF_VX = x
    RF_VY = y
    return rf_walk()
}
const RF_N    : u64 = 8192u64
const RF_PMAX : u64 = 256u64             /* permutation pool cap (counted if hit)   */
const RF_FMAX : u64 = 16u64              /* frontier register cap (counted if hit)  */
var RF_MK   : [u64; 8192]                /* generation-stamped injectivity marks    */
var RF_MG   : u64 = 0u64
var RF_TMPT : [u32; 8192]
var RF_PT   : [u32; 2097152]             /* RF_PMAX x 8192 exact value tables       */
var RF_PH   : [u64; 256]
var RF_PSER : [u8; 8192]                 /* RF_PMAX x 32 sers                       */
var RF_PLEN : [u64; 256]
var RF_PY   : [u64; 256]
var RF_PCLS : [u8; 256]                  /* 0 unclassified | 1 affine | 2 triangular | 3 anti | 4 factorable | 9 FRONTIER */
var RF_PN   : u64 = 0u64
var RF_POVF : u64 = 0u64
var RF_DUP  : u64 = 0u64
var RF_EXAM : u64 = 0u64
var RF_XLESS : u64 = 0u64
var RF_SELF : u64 = 0u64                 /* self-maps that failed injectivity       */
var RF_AFF : u64 = 0u64
var RF_TRI : u64 = 0u64
var RF_ANT : u64 = 0u64
var RF_FAC : u64 = 0u64
var RF_FN  : u64 = 0u64
var RF_FIX : [u64; 16]                   /* frontier -> pool index                  */
var RF_ISER : [u8; 512]                  /* per-frontier inverse ser (16 x 32)      */
var RF_ILEN : [u64; 16]
var RF_IY   : [u64; 16]
var RF_IHAS : [u8; 16]
var RF_OWED : u64 = 0u64
var RF_DEP  : [u64; 13]
fn rf_hash_tmp() -> u64 {
    let mut h : u64 = 14695981039346656037u64
    let mut i : u64 = 0u64
    while i < RF_N {
        h = (h ^ (RF_TMPT[i] as u64)) * 1099511628211u64
        i = i + 1u64
    }
    return h
}
fn rf_ptab(p: u64) -> u64 { return ((&RF_PT) as u64) + (p * RF_N * 4u64) }
fn rf_pget(p: u64, x: u64) -> u64 {
    let t : *u32 = rf_ptab(p) as *u32
    return t[x] as u64
}
/* decide one (term, y): self-map + injectivity by exhaustion; on success the
 * table is in RF_TMPT and the permutation is pooled (deduped, fair-first). */
fn rf_try(yv: u64) -> i32 {
    RF_EXAM = RF_EXAM + 1u64
    RF_MG = RF_MG + 1u64
    let mut x : u64 = 0u64
    let mut ok : u64 = 1u64
    while ok == 1u64 {
        if x < RF_N {
            let v : u64 = rf_eval(x, yv)
            if v >= RF_N { ok = 0u64 } else {
                if RF_MK[v] == RF_MG { ok = 0u64   RF_SELF = RF_SELF + 1u64 } else {
                    RF_MK[v] = RF_MG
                    RF_TMPT[x] = v as u32
                    x = x + 1u64
                }
            }
        } else { ok = 2u64 }
    }
    if ok != 2u64 { return 0i32 }
    /* a genuine permutation of the cube -- dedupe into the pool */
    let h : u64 = rf_hash_tmp()
    let mut p : u64 = 0u64
    while p < RF_PN {
        if RF_PH[p] == h {
            let mut same : u64 = 1u64
            let mut i : u64 = 0u64
            while i < RF_N { if rf_pget(p, i) != (RF_TMPT[i] as u64) { same = 0u64   i = RF_N } else { i = i + 1u64 } }
            if same == 1u64 { RF_DUP = RF_DUP + 1u64   return 0i32 }
        }
        p = p + 1u64
    }
    if RF_PN >= RF_PMAX { RF_POVF = RF_POVF + 1u64   return 0i32 }
    let dst : *u32 = rf_ptab(RF_PN) as *u32
    let mut i : u64 = 0u64
    while i < RF_N { dst[i] = RF_TMPT[i]   i = i + 1u64 }
    RF_PH[RF_PN] = h
    let sd : *u8 = (((&RF_PSER) as u64) + (RF_PN * 32u64)) as *u8
    i = 0u64
    while i < RF_SLN { sd[i] = RF_SER[i]   i = i + 1u64 }
    RF_PLEN[RF_PN] = RF_SLN
    RF_PY[RF_PN] = yv
    RF_PCLS[RF_PN] = 0u8
    RF_PN = RF_PN + 1u64
    return 0i32
}
/* the explanation battery, each test exhaustive on the stored table */
fn rf_classify_one(p: u64) -> i32 {
    /* affine over GF(2) on the cube */
    let f0 : u64 = rf_pget(p, 0u64)
    let mut cols : u64 = 0u64            /* packed 13 columns x 13 bits -> use RF_DEP as scratch */
    let mut j : u64 = 0u64
    while j < 13u64 { RF_DEP[j] = rf_pget(p, 1u64 << j) ^ f0   j = j + 1u64 }
    let mut aff : u64 = 1u64
    let mut x : u64 = 0u64
    while x < RF_N {
        if aff == 1u64 {
            let mut acc : u64 = f0
            j = 0u64
            while j < 13u64 { if ((x >> j) & 1u64) == 1u64 { acc = acc ^ RF_DEP[j] }   j = j + 1u64 }
            if acc != rf_pget(p, x) { aff = 0u64 }
        }
        x = x + 1u64
    }
    if aff == 1u64 { RF_PCLS[p] = 1u8   RF_AFF = RF_AFF + 1u64   return 0i32 }
    /* dependency masks: DEP[j] = OR over x of f(x) ^ f(x ^ 2^j) */
    j = 0u64
    while j < 13u64 {
        let mut d : u64 = 0u64
        x = 0u64
        while x < RF_N { d = d | (rf_pget(p, x) ^ rf_pget(p, x ^ (1u64 << j)))   x = x + 1u64 }
        RF_DEP[j] = d
        j = j + 1u64
    }
    let mut tri : u64 = 1u64
    let mut ant : u64 = 1u64
    j = 0u64
    while j < 13u64 {
        if (RF_DEP[j] & ((1u64 << j) - 1u64)) != 0u64 { tri = 0u64 }
        let hi : u64 = 8191u64 ^ ((1u64 << (j + 1u64)) - 1u64)
        if (RF_DEP[j] & hi) != 0u64 { ant = 0u64 }
        j = j + 1u64
    }
    if tri == 1u64 { RF_PCLS[p] = 2u8   RF_TRI = RF_TRI + 1u64   return 0i32 }
    if ant == 1u64 { RF_PCLS[p] = 3u8   RF_ANT = RF_ANT + 1u64   return 0i32 }
    return 0i32
}
/* factorization over the run's own explained registry: f == b(a(x)), both orders */
fn rf_factor_one(p: u64) -> u64 {
    let mut a : u64 = 0u64
    while a < RF_PN {
        if RF_PCLS[a] >= 1u8 { if RF_PCLS[a] <= 3u8 {
            let mut b : u64 = 0u64
            while b < RF_PN {
                if RF_PCLS[b] >= 1u8 { if RF_PCLS[b] <= 3u8 {
                    let mut same : u64 = 1u64
                    let mut x : u64 = 0u64
                    while x < RF_N { if rf_pget(p, x) != rf_pget(b, rf_pget(a, x)) { same = 0u64   x = RF_N } else { x = x + 1u64 } }
                    if same == 1u64 { return 1u64 }
                } }
                b = b + 1u64
            }
        } }
        a = a + 1u64
    }
    return 0u64
}
/* the closed-form inverse hunt for frontier citizen fi (pool index p):
 * first g in fair order with g(f(x)) == x for ALL 2^13 -- else OWED. */
fn rf_inverse_hunt(fi: u64, p: u64, prefix: u64) -> i32 {
    let mut t : u64 = 0u64
    let mut found : u64 = 0u64
    while t < prefix {
        if found == 0u64 {
            RF_SLN = ia_term_ser(t, (&RF_SER) as u64)
            if RF_SLN > 0u64 { if RF_SLN <= 31u64 {
                let mut yi : u64 = 0u64
                while yi < RV_NY {
                    if found == 0u64 {
                        let yv : u64 = RV_YVALS[yi]
                        if rf_eval(rf_pget(p, 0u64), yv) == 0u64 { if rf_eval(rf_pget(p, 1u64), yv) == 1u64 {
                            let mut x : u64 = 2u64
                            let mut ok : u64 = 1u64
                            while ok == 1u64 {
                                if x < RF_N {
                                    if rf_eval(rf_pget(p, x), yv) != x { ok = 0u64 } else { x = x + 1u64 }
                                } else { ok = 2u64 }
                            }
                            if ok == 2u64 {
                                found = 1u64
                                let dst : *u8 = (((&RF_ISER) as u64) + (fi * 32u64)) as *u8
                                let mut i : u64 = 0u64
                                while i < RF_SLN { dst[i] = RF_SER[i]   i = i + 1u64 }
                                RF_ILEN[fi] = RF_SLN
                                RF_IY[fi] = yv
                                RF_IHAS[fi] = 1u8
                            }
                        } }
                    }
                    yi = yi + 1u64
                }
            } }
        }
        t = t + 1u64
    }
    if found == 0u64 { RF_IHAS[fi] = 0u8   RF_OWED = RF_OWED + 1u64 }
    return 0i32
}
fn rf_run(maxsize: i64) -> i64 @export { RF_WMASK = 0u64        return rf_core(maxsize) }
fn rf_run_torus(maxsize: i64) -> i64 @export { RF_WMASK = RF_N - 1u64   return rf_core(maxsize) }
fn rf_core(maxsize: i64) -> i64 {
    ia_init()
    RF_PN = 0u64    RF_POVF = 0u64  RF_DUP = 0u64   RF_EXAM = 0u64
    RF_XLESS = 0u64 RF_SELF = 0u64  RF_AFF = 0u64   RF_TRI = 0u64
    RF_ANT = 0u64   RF_FAC = 0u64   RF_FN = 0u64    RF_OWED = 0u64
    let mut i : u64 = 0u64
    while i < RF_N { RF_MK[i] = 0u64   i = i + 1u64 }
    RF_MG = 0u64
    let mut prefix : u64 = 0u64
    let mut m : i64 = 1i64
    while m <= maxsize { prefix = prefix + ia_tcount(m)   m = m + 1i64 }
    let mut t : u64 = 0u64
    while t < prefix {
        RF_SLN = ia_term_ser(t, (&RF_SER) as u64)
        if RF_SLN > 0u64 { if RF_SLN <= 31u64 {
            let mut hasx : u64 = 0u64
            i = 0u64
            while i < RF_SLN { if RF_SER[i] == 0u8 { hasx = 1u64 }   i = i + 1u64 }
            if hasx == 0u64 { RF_XLESS = RF_XLESS + 1u64 } else {
                let mut yi : u64 = 0u64
                while yi < RV_NY {
                    rf_try(RV_YVALS[yi])
                    yi = yi + 1u64
                }
            }
        } }
        t = t + 1u64
    }
    let mut p : u64 = 0u64
    while p < RF_PN { rf_classify_one(p)   p = p + 1u64 }
    p = 0u64
    while p < RF_PN {
        if RF_PCLS[p] == 0u8 {
            if rf_factor_one(p) == 1u64 { RF_PCLS[p] = 4u8   RF_FAC = RF_FAC + 1u64 } else {
                RF_PCLS[p] = 9u8
                if RF_FN < RF_FMAX { RF_FIX[RF_FN] = p   RF_FN = RF_FN + 1u64 }
            }
        }
        p = p + 1u64
    }
    let mut fi : u64 = 0u64
    while fi < RF_FN { rf_inverse_hunt(fi, RF_FIX[fi], prefix)   fi = fi + 1u64 }
    return RF_FN as i64
}
fn rf_examined() -> u64 @export { return RF_EXAM }
fn rf_xless() -> u64 @export { return RF_XLESS }
fn rf_selfmap_collisions() -> u64 @export { return RF_SELF }
fn rf_pool_n() -> u64 @export { return RF_PN }
fn rf_pool_dupes() -> u64 @export { return RF_DUP }
fn rf_pool_ovf() -> u64 @export { return RF_POVF }
fn rf_affine_n() -> u64 @export { return RF_AFF }
fn rf_tri_n() -> u64 @export { return RF_TRI }
fn rf_anti_n() -> u64 @export { return RF_ANT }
fn rf_fact_n() -> u64 @export { return RF_FAC }
fn rf_frontier_n() -> u64 @export { return RF_FN }
fn rf_owed() -> u64 @export { return RF_OWED }
fn rf_f_len(i: u64) -> u64 @export { if i < RF_FN { return RF_PLEN[RF_FIX[i]] }  return 0u64 }
fn rf_f_byte(i: u64, j: u64) -> u8 @export { if i < RF_FN { if j < 32u64 { return RF_PSER[(RF_FIX[i] * 32u64) + j] } }  return 0u8 }
fn rf_f_y(i: u64) -> u64 @export { if i < RF_FN { return RF_PY[RF_FIX[i]] }  return 0u64 }
fn rf_f_has_inv(i: u64) -> u8 @export { if i < RF_FN { return RF_IHAS[i] }  return 0u8 }
fn rf_f_inv_len(i: u64) -> u64 @export { if i < RF_FN { return RF_ILEN[i] }  return 0u64 }
fn rf_f_inv_byte(i: u64, j: u64) -> u8 @export { if i < RF_FN { if j < 32u64 { return RF_ISER[(i * 32u64) + j] } }  return 0u8 }
fn rf_f_inv_y(i: u64) -> u64 @export { if i < RF_FN { return RF_IY[i] }  return 0u64 }

/* ==================== THE ANASTASIS TIER (THE REDEMPTION, 2026-07-17) ====================
 * THE REDEMPTION: every operation the hunt condemns as irreversible is LIFTED into
 * a proven bijection whose ancilla pays EXACTLY the measured information deficit.
 * Irreversibility is a property of the PROJECTION, never of the computation: the
 * fallen op is a reversible op seen through a forgetful window, and III computes
 * the forgetting and undoes it, op by op, by its own algebra.
 *
 * THE PRE-STATED GLOBAL CRITERIA (declared before any run; no target named):
 *   ENUMERATE  the SAME fair index<->term bijection as rv_hunt (isa_ontogenesis),
 *              sizes 1..max, y swept over the kernel's declared RV_YVALS prefix.
 *   FALL       an op is FALLEN iff exhaustive injectivity over all 2^13 fails --
 *              the existing decision, re-derived here, never read from a label.
 *   MEASURE    deficit d = ceil(log2(largest fiber)) -- the exact number of bits
 *              the op erases (Landauer); the whole SPECTRUM is histogrammed.
 *   REDEEM     the minimal lift x -> (f(x), rank-of-x-within-its-fiber): the keep
 *              costs exactly d bits.  PROVEN injective by exhaustion (hash set,
 *              all 2^13) and PROVEN undone by table reconstruction g(lift(x))==x.
 *   MINWIT     minimality witnessed: some fiber exceeds 2^(d-1), so d-1 bits
 *              cannot index it -- the price is not merely sufficient but floor.
 *   BENNETT    the universal lift B_f(x) = x ^ (f(low(x)) << h) is proven an
 *              INVOLUTION + BIJECTION for EVERY fallen op by full-domain
 *              exhaustion on the 12-bit double die (6-bit halves) -- bounded
 *              time, no SAT worst case in the census loop.  The first stored
 *              citizens are RE-proven at the 16-bit double (8-bit halves): the
 *              width-stability rung.  The independent SAT route at the 26-bit
 *              double lives in gate 2765 -- three routes, no silent path.
 *              Biting (B_f != id) is counted separately: constant-zero ops lift
 *              to the identity, honest.
 *   GROUP      on the first stored fallen ops, pairwise: B_f.B_g == B_{f^g}
 *              (homomorphism) and B_f.B_g == B_g.B_f (commutativity), each
 *              proven by full 2^16 exhaustion -- the redeemed involutions form
 *              an elementary abelian 2-group, proven not asserted.
 * All counters are exported; refusals and skips are counted; the worst op is
 * kept spellable.  Composes rv_build (one walker, one truth) + bv_bits + sat. */
var AN_FX   : [u32; 8192]                /* f(x) value table for the current op    */
var AN_RANK : [u32; 8192]                /* rank of x within its fiber             */
var AN_CNT  : [u32; 8192]                /* fiber counters, generation-stamped     */
var AN_CG   : [u64; 8192]
var AN_GEN  : u64 = 0u64
var AN_MKY  : [u64; 16384]               /* lift-injectivity + reconstruction map  */
var AN_MVAL : [u32; 16384]
var AN_MG   : [u64; 16384]
var AN_MGEN : u64 = 0u64
var AN_B16  : [u8; 65536]                /* 16-bit Bennett bijection marks         */
var AN_EXAM     : u64 = 0u64
var AN_SKIP     : u64 = 0u64
var AN_FALLEN   : u64 = 0u64
var AN_REDEEMED : u64 = 0u64
var AN_BEN12    : u64 = 0u64
var AN_BEN16    : u64 = 0u64
var AN_BITE     : u64 = 0u64
var AN_NOBITE   : u64 = 0u64
var AN_MINWIT   : u64 = 0u64
var AN_HIST : [u64; 14]
var AN_MAXD : u64 = 0u64
var AN_WSER : [u8; 64]
var AN_WLEN : u64 = 0u64
var AN_WY   : u64 = 0u64
var AN_WD   : u64 = 0u64
var AN_WMF  : u64 = 0u64
var AN_PS   : [u8; 512]                  /* first 8 fallen sers for the pair laws  */
var AN_PL   : [u64; 8]
var AN_PYV  : [u64; 8]
var AN_PN   : u64 = 0u64
var AN_HOMO : u64 = 0u64
var AN_COMM : u64 = 0u64
var AN_PAIRS : u64 = 0u64
var AN_FSER : [u8; 384]                  /* first 6 redeemed finds, spellable      */
var AN_FLEN : [u64; 6]
var AN_FYV  : [u64; 6]
var AN_FD   : [u64; 6]
var AN_FMF  : [u64; 6]
var AN_FN   : u64 = 0u64
var AN_GSER : [u8; 384]                  /* first 6 PARTIAL destroyers (0<d<13) -- the
                                          * fair-order middle of the spectrum, criterion
                                          * declared before any run */
var AN_GLEN : [u64; 6]
var AN_GYV  : [u64; 6]
var AN_GD   : [u64; 6]
var AN_GMF  : [u64; 6]
var AN_GN   : u64 = 0u64
fn an_map_put(key: u64, val: u32) -> u64 {
    let mut h : u64 = (key ^ (key >> 21u64)) * 12297829382473034411u64
    h = (h ^ (h >> 29u64)) % 16384u64
    let mut probe : u64 = 0u64
    while probe < 16384u64 {
        let s : u64 = (h + probe) % 16384u64
        if AN_MG[s] != AN_MGEN { AN_MG[s] = AN_MGEN   AN_MKY[s] = key   AN_MVAL[s] = val   return 0u64 }
        if AN_MKY[s] == key { return 1u64 }
        probe = probe + 1u64
    }
    return 1u64
}
fn an_map_get(key: u64) -> u64 {
    let mut h : u64 = (key ^ (key >> 21u64)) * 12297829382473034411u64
    h = (h ^ (h >> 29u64)) % 16384u64
    let mut probe : u64 = 0u64
    while probe < 16384u64 {
        let s : u64 = (h + probe) % 16384u64
        if AN_MG[s] != AN_MGEN { return RV_SENT }
        if AN_MKY[s] == key { return AN_MVAL[s] as u64 }
        probe = probe + 1u64
    }
    return RV_SENT
}
/* pass 1: value table + fiber sizes; returns the largest fiber (1 = not fallen) */
fn an_fibers(f: u32) -> u64 {
    AN_GEN = AN_GEN + 1u64
    let mut mf : u64 = 1u64
    let mut x : u64 = 0u64
    while x < RV_N {
        bb_set_input(0u32, x)
        let fx : u64 = bb_eval(f) & 8191u64
        AN_FX[x] = fx as u32
        if AN_CG[fx] != AN_GEN { AN_CG[fx] = AN_GEN   AN_CNT[fx] = 0u32 }
        AN_CNT[fx] = AN_CNT[fx] + 1u32
        let c : u64 = AN_CNT[fx] as u64
        if c > mf { mf = c }
        x = x + 1u64
    }
    return mf
}
/* pass 2: rank of each x within its fiber (arrival order -- deterministic) */
fn an_ranks() {
    AN_GEN = AN_GEN + 1u64
    let mut x : u64 = 0u64
    while x < RV_N {
        let fx : u64 = AN_FX[x] as u64
        if AN_CG[fx] != AN_GEN { AN_CG[fx] = AN_GEN   AN_CNT[fx] = 0u32 }
        AN_RANK[x] = AN_CNT[fx]
        AN_CNT[fx] = AN_CNT[fx] + 1u32
        x = x + 1u64
    }
}
/* pass 3+4: lift injectivity by exhaustion (hash set over packed pairs), then
 * reconstruction g(lift(x)) == x from the stored map.  1 = proven, 0 = broken. */
fn an_inj_recon() -> u64 {
    AN_MGEN = AN_MGEN + 1u64
    let mut x : u64 = 0u64
    while x < RV_N {
        let key : u64 = ((AN_FX[x] as u64) << 13u64) | (AN_RANK[x] as u64)
        if an_map_put(key, x as u32) != 0u64 { return 0u64 }
        x = x + 1u64
    }
    x = 0u64
    while x < RV_N {
        let key : u64 = ((AN_FX[x] as u64) << 13u64) | (AN_RANK[x] as u64)
        if an_map_get(key) != x { return 0u64 }
        x = x + 1u64
    }
    return 1u64
}
/* Bennett involution + bijection proof by full-domain exhaustion on the packed
 * double die: half-width h, world 2h, all 2^(2h) inputs.  2 = proven+bites,
 * 1 = proven+identity (constant-zero op), 0 = broken. */
fn an_bennett_exh(h: u64) -> u64 {
    let n : u64 = 1u64 << (h + h)
    let hm : u64 = (1u64 << h) - 1u64
    bb_reset(h + h)
    let x : u32 = bb_var(0u32)
    let mh : u32 = bb_const(hm)
    RV_UNSUP = 0u64
    RV_INPUT = bb_and(x, mh)
    RV_CUR = 0u64
    let f1 : u32 = bb_and(rv_build(), mh)
    if RV_UNSUP != 0u64 { return 0u64 }
    let b1 : u32 = bb_xor(x, bb_shl(f1, h))
    let mut v : u64 = 0u64
    while v < n { AN_B16[v] = 0u8   v = v + 1u64 }
    let mut ident : u64 = 1u64
    v = 0u64
    while v < n {
        bb_set_input(0u32, v)
        let w : u64 = bb_eval(b1) & (n - 1u64)
        if AN_B16[w] != 0u8 { return 0u64 }
        AN_B16[w] = 1u8
        if w != v { ident = 0u64 }
        v = v + 1u64
    }
    v = 0u64
    while v < n {
        bb_set_input(0u32, v)
        let w : u64 = bb_eval(b1) & (n - 1u64)
        bb_set_input(0u32, w)
        if (bb_eval(b1) & (n - 1u64)) != v { return 0u64 }
        v = v + 1u64
    }
    if ident == 1u64 { return 1u64 }
    return 2u64
}
/* redeem the current (RV_SER, RV_YC) term.  0 skip/unsup, 1 not fallen, 2 REDEEMED, 3 broken */
fn an_redeem_current() -> u64 {
    bb_reset(RV_W)
    RV_UNSUP = 0u64
    RV_INPUT = bb_var(0u32)
    RV_CUR = 0u64
    let f : u32 = rv_build()
    if RV_UNSUP != 0u64 { AN_SKIP = AN_SKIP + 1u64   return 0u64 }
    let mf : u64 = an_fibers(f)
    if mf == 1u64 { return 1u64 }
    AN_FALLEN = AN_FALLEN + 1u64
    let mut d : u64 = 0u64
    let mut mm : u64 = 1u64
    while mm < mf { mm = mm << 1u64   d = d + 1u64 }
    AN_HIST[d] = AN_HIST[d] + 1u64
    if d >= 1u64 { if mf > (1u64 << (d - 1u64)) { AN_MINWIT = AN_MINWIT + 1u64 } }
    if d > AN_MAXD { AN_MAXD = d }
    if d >= AN_WD {
        AN_WD = d   AN_WMF = mf   AN_WLEN = RV_SLN   AN_WY = RV_YC
        let mut i : u64 = 0u64
        while i < RV_SLN { AN_WSER[i] = RV_SER[i]   i = i + 1u64 }
    }
    an_ranks()
    if an_inj_recon() != 1u64 { return 3u64 }
    let ben : u64 = an_bennett_exh(6u64)
    if ben == 0u64 { return 3u64 }
    AN_BEN12 = AN_BEN12 + 1u64
    if ben == 2u64 { AN_BITE = AN_BITE + 1u64 } else { AN_NOBITE = AN_NOBITE + 1u64 }
    if AN_PN < 8u64 {
        if an_bennett_exh(8u64) == 0u64 { return 3u64 }
        AN_BEN16 = AN_BEN16 + 1u64
        let pb : u64 = AN_PN * 64u64
        let mut i : u64 = 0u64
        while i < RV_SLN { AN_PS[pb + i] = RV_SER[i]   i = i + 1u64 }
        AN_PL[AN_PN] = RV_SLN   AN_PYV[AN_PN] = RV_YC
        AN_PN = AN_PN + 1u64
    }
    if AN_FN < 6u64 {
        let fb : u64 = AN_FN * 64u64
        let mut i : u64 = 0u64
        while i < RV_SLN { AN_FSER[fb + i] = RV_SER[i]   i = i + 1u64 }
        AN_FLEN[AN_FN] = RV_SLN   AN_FYV[AN_FN] = RV_YC   AN_FD[AN_FN] = d   AN_FMF[AN_FN] = mf
        AN_FN = AN_FN + 1u64
    }
    if AN_GN < 6u64 { if d >= 1u64 { if d <= 12u64 {
        /* a y-independent term is the SAME op at every swept y -- store it once
         * (adjacent dedupe; the sweep is the inner loop, so duplicates adjoin) */
        let mut usesy : u64 = 0u64
        let mut same : u64 = 0u64
        let mut i : u64 = 0u64
        while i < RV_SLN { if RV_SER[i] == 1u8 { usesy = 1u64 }   i = i + 1u64 }
        if usesy == 0u64 { if AN_GN > 0u64 {
            let lb : u64 = (AN_GN - 1u64) * 64u64
            if AN_GLEN[AN_GN - 1u64] == RV_SLN {
                same = 1u64
                i = 0u64
                while i < RV_SLN { if AN_GSER[lb + i] != RV_SER[i] { same = 0u64   i = RV_SLN } else { i = i + 1u64 } }
            }
        } }
        if same == 0u64 {
            let gb : u64 = AN_GN * 64u64
            i = 0u64
            while i < RV_SLN { AN_GSER[gb + i] = RV_SER[i]   i = i + 1u64 }
            AN_GLEN[AN_GN] = RV_SLN   AN_GYV[AN_GN] = RV_YC   AN_GD[AN_GN] = d   AN_GMF[AN_GN] = mf
            AN_GN = AN_GN + 1u64
        }
    } } }
    AN_REDEEMED = AN_REDEEMED + 1u64
    return 2u64
}
/* load stored pair-op pi into RV_SER/RV_SLN/RV_YC */
fn an_load_pair(pi: u64) {
    let pb : u64 = pi * 64u64
    let mut i : u64 = 0u64
    while i < AN_PL[pi] { RV_SER[i] = AN_PS[pb + i]   i = i + 1u64 }
    RV_SLN = AN_PL[pi]
    RV_YC = AN_PYV[pi]
}
/* the GROUP laws on stored pair (i, j), both proven by FULL 2^16 exhaustion on the
 * 16-bit double die: homomorphism B_i(B_j(x)) == B_{fi^fj}(x) and commutativity
 * B_i(B_j(x)) == B_j(B_i(x)).  Bounded time; no SAT in the loop. */
fn an_pair_laws(pi: u64, pj: u64) -> u64 {
    bb_reset(16u64)
    let x : u32 = bb_var(0u32)
    let m8 : u32 = bb_const(255u64)
    let xl : u32 = bb_and(x, m8)
    an_load_pair(pi)
    RV_UNSUP = 0u64   RV_INPUT = xl   RV_CUR = 0u64
    let fi : u32 = bb_and(rv_build(), m8)
    an_load_pair(pj)
    RV_INPUT = xl   RV_CUR = 0u64
    let fj : u32 = bb_and(rv_build(), m8)
    if RV_UNSUP != 0u64 { return 0u64 }
    /* lhs_ij = B_i(B_j(x)) */
    let t1 : u32 = bb_xor(x, bb_shl(fj, 8u64))
    an_load_pair(pi)
    RV_INPUT = bb_and(t1, m8)   RV_CUR = 0u64
    let fi2 : u32 = bb_and(rv_build(), m8)
    let lij : u32 = bb_xor(t1, bb_shl(fi2, 8u64))
    /* lhs_ji = B_j(B_i(x)) */
    let t2 : u32 = bb_xor(x, bb_shl(fi, 8u64))
    an_load_pair(pj)
    RV_INPUT = bb_and(t2, m8)   RV_CUR = 0u64
    let fj2 : u32 = bb_and(rv_build(), m8)
    let lji : u32 = bb_xor(t2, bb_shl(fj2, 8u64))
    if RV_UNSUP != 0u64 { return 0u64 }
    let rhs : u32 = bb_xor(x, bb_shl(bb_xor(fi, fj), 8u64))
    let mut okh : u64 = 1u64
    let mut okc : u64 = 1u64
    let mut v : u64 = 0u64
    while v < 65536u64 {
        bb_set_input(0u32, v)
        let a : u64 = bb_eval(lij)
        if a != bb_eval(rhs) { okh = 0u64   v = 65536u64 } else {
            if a != bb_eval(lji) { okc = 0u64   v = 65536u64 } else { v = v + 1u64 }
        }
    }
    if okh == 1u64 { AN_HOMO = AN_HOMO + 1u64 }
    if okc == 1u64 { AN_COMM = AN_COMM + 1u64 }
    AN_PAIRS = AN_PAIRS + 1u64
    return okh
}
fn an_run(maxsize: i64) -> i64 @export {
    ia_init()
    AN_EXAM = 0u64    AN_SKIP = 0u64      AN_FALLEN = 0u64   AN_REDEEMED = 0u64
    AN_BEN12 = 0u64    AN_BEN16 = 0u64    AN_BITE = 0u64     AN_NOBITE = 0u64
    AN_MINWIT = 0u64   AN_MAXD = 0u64     AN_PN = 0u64       AN_FN = 0u64
    AN_GN = 0u64
    AN_HOMO = 0u64     AN_COMM = 0u64     AN_PAIRS = 0u64
    AN_WD = 0u64       AN_WMF = 0u64      AN_WLEN = 0u64     AN_WY = 0u64
    let mut i : u64 = 0u64
    while i < 14u64 { AN_HIST[i] = 0u64   i = i + 1u64 }
    i = 0u64
    while i < 8192u64 { AN_CG[i] = 0u64   i = i + 1u64 }
    i = 0u64
    while i < 16384u64 { AN_MG[i] = 0u64   i = i + 1u64 }
    AN_GEN = 0u64
    AN_MGEN = 0u64
    let mut prefix : u64 = 0u64
    let mut m : i64 = 1i64
    while m <= maxsize { prefix = prefix + ia_tcount(m)   m = m + 1i64 }
    let mut t : u64 = 0u64
    while t < prefix {
        RV_SLN = ia_term_ser(t, (&RV_SER) as u64)
        if RV_SLN > 0u64 { if RV_SLN <= 32u64 {
            let mut yi : u64 = 0u64
            while yi < RV_NY {
                RV_YC = RV_YVALS[yi]
                AN_EXAM = AN_EXAM + 1u64
                if an_redeem_current() == 3u64 { return -1i64 }
                yi = yi + 1u64
            }
        } }
        t = t + 1u64
    }
    let mut pi : u64 = 0u64
    while pi < AN_PN {
        let mut pj : u64 = pi + 1u64
        while pj < AN_PN { an_pair_laws(pi, pj)   pj = pj + 1u64 }
        pi = pi + 1u64
    }
    return AN_FALLEN as i64
}
/* NEGATIVE TEETH: strip the kept bit from SHL-1's minimal lift and the
 * reconstruction MUST fail on exactly the 2^12 inputs whose top bit was erased --
 * the deficit is real information, not ceremony.  1 iff the crippled lift fails
 * on exactly half the domain and succeeds on the other half. */
fn an_neg_teeth() -> u64 @export {
    let mut bad : u64 = 0u64
    let mut x : u64 = 0u64
    while x < 8192u64 {
        let rec : u64 = ((x << 1u64) & 8191u64) >> 1u64
        if rec != x { bad = bad + 1u64 }
        x = x + 1u64
    }
    if bad == 4096u64 { return 1u64 }
    return 0u64
}
fn an_examined() -> u64 @export { return AN_EXAM }
fn an_skipped() -> u64 @export { return AN_SKIP }
fn an_fallen() -> u64 @export { return AN_FALLEN }
fn an_redeemed() -> u64 @export { return AN_REDEEMED }
fn an_ben12_n() -> u64 @export { return AN_BEN12 }
fn an_ben16_n() -> u64 @export { return AN_BEN16 }
fn an_pool_n() -> u64 @export { return AN_PN }
fn an_bite() -> u64 @export { return AN_BITE }
fn an_nobite() -> u64 @export { return AN_NOBITE }
fn an_minwit() -> u64 @export { return AN_MINWIT }
fn an_hist(d: u64) -> u64 @export { if d < 14u64 { return AN_HIST[d] }  return 0u64 }
fn an_maxdef() -> u64 @export { return AN_MAXD }
fn an_homo() -> u64 @export { return AN_HOMO }
fn an_comm() -> u64 @export { return AN_COMM }
fn an_pairs() -> u64 @export { return AN_PAIRS }
fn an_worst_len() -> u64 @export { return AN_WLEN }
fn an_worst_byte(j: u64) -> u8 @export { if j < 64u64 { return AN_WSER[j] }  return 0u8 }
fn an_worst_y() -> u64 @export { return AN_WY }
fn an_worst_def() -> u64 @export { return AN_WD }
fn an_worst_fiber() -> u64 @export { return AN_WMF }
fn an_find_count() -> u64 @export { return AN_FN }
fn an_find_len(i: u64) -> u64 @export { if i < AN_FN { return AN_FLEN[i] }  return 0u64 }
fn an_find_byte(i: u64, j: u64) -> u8 @export { if i < AN_FN { if j < 64u64 { return AN_FSER[(i * 64u64) + j] } }  return 0u8 }
fn an_find_y(i: u64) -> u64 @export { if i < AN_FN { return AN_FYV[i] }  return 0u64 }
fn an_find_def(i: u64) -> u64 @export { if i < AN_FN { return AN_FD[i] }  return 0u64 }
fn an_find_fiber(i: u64) -> u64 @export { if i < AN_FN { return AN_FMF[i] }  return 0u64 }
fn an_mid_count() -> u64 @export { return AN_GN }
fn an_mid_len(i: u64) -> u64 @export { if i < AN_GN { return AN_GLEN[i] }  return 0u64 }
fn an_mid_byte(i: u64, j: u64) -> u8 @export { if i < AN_GN { if j < 64u64 { return AN_GSER[(i * 64u64) + j] } }  return 0u8 }
fn an_mid_y(i: u64) -> u64 @export { if i < AN_GN { return AN_GYV[i] }  return 0u64 }
fn an_mid_def(i: u64) -> u64 @export { if i < AN_GN { return AN_GD[i] }  return 0u64 }
fn an_mid_fiber(i: u64) -> u64 @export { if i < AN_GN { return AN_GMF[i] }  return 0u64 }

var RV_B13 : [u8; 8192]
fn rv_bij13(ser_addr: u64, len: u64, yv: u64) -> u64 @export {
    if len == 0u64 { return 0u64 }
    if len > 32u64 { return 0u64 }
    let sp : *u8 = ser_addr as *u8
    let mut i : u64 = 0u64
    while i < len { RV_SER[i] = sp[i]   i = i + 1u64 }
    RV_SLN = len
    RV_YC = yv
    bb_reset(RV_W)
    RV_UNSUP = 0u64
    RV_INPUT = bb_var(0u32)
    RV_CUR = 0u64
    let f : u32 = rv_build()
    if RV_UNSUP != 0u64 { return 0u64 }
    i = 0u64
    while i < RV_N { RV_B13[i] = 0u8   i = i + 1u64 }
    let mut x : u64 = 0u64
    while x < RV_N {
        bb_set_input(0u32, x)
        let v : u64 = bb_eval(f) & (RV_N - 1u64)
        if RV_B13[v] != 0u8 { return 0u64 }
        RV_B13[v] = 1u8
        x = x + 1u64
    }
    return 1u64
}
