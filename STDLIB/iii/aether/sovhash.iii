/* STDLIB/iii/aether/sovhash.iii -- the III-AUTHORED vertex of the author-diversity witness triangle.
 *
 * `sovhash <file>` prints the plain FIPS 180-4 SHA-256 of the file's bytes as 64 lowercase hex
 * chars + newline -- the exact first field of GNU `sha256sum` and the digest line of Microsoft
 * `certutil -hashfile <file> SHA256`.  Three implementations of three INDEPENDENT authorships
 * (this repo's numera/cad, GNU coreutils, Microsoft Windows) must agree byte-for-byte on every
 * sealed trust anchor; any lie in one is exposed by the other two.  Driven by
 * scripts/author_diversity_gate.sh (AXIS B).
 *
 * Streaming: cad_begin(SHA256) -> cad_payload per 64 KiB chunk -> cad_final.  cad_domain is
 * deliberately NOT called -- no domain byte, so the digest is the RAW hash of the file bytes
 * (byte-identical to the external tools).  numera/cad is the ONE content-address (H2).
 *
 * exit 0 = hash printed;  2 = usage;  3 = open failed;  4 = read failed;  5 = cad refused.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.  NIH: composes numera/cad only.
 */
module sovhash

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn CreateFileA(name: u64, access: u32, share: u32, sec: u64, disp: u32, flags: u32, tmpl: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn ReadFile(h: u64, buf: u64, n: u32, read: u64, ov: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn cad_begin(suite: u32) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_payload(payload: u64, payload_len: u64) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_final(out_32: u64) -> i32 from "cad.iii"

var SH_BUF : [u8; 65536]      /* one read chunk */
var SH_NREAD : [u32; 2]       /* ReadFile out-param (LPDWORD) */
var SH_DIG : [u8; 32]         /* the digest */

fn pstr(sp: u64) -> i32 {
    let s : *u8 = sp as *u8
    let mut i : u64 = 0u64
    while s[i] != 0u8 { putchar(s[i] as i32)   i = i + 1u64 }
    return 0i32
}

fn phex32(dp: u64) -> i32 {
    let d : *u8 = dp as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        let b : u32 = d[i] as u32
        let hi : u32 = b >> 4u32
        let lo : u32 = b & 15u32
        if hi < 10u32 { putchar((48u32 + hi) as i32) } else { putchar((87u32 + hi) as i32) }   /* 87+10='a' */
        if lo < 10u32 { putchar((48u32 + lo) as i32) } else { putchar((87u32 + lo) as i32) }
        i = i + 1u64
    }
    putchar(10i32)
    return 0i32
}

fn main(argc: i32, argv: u64) -> u64 {
    if argc < 2i32 {
        pstr("usage: sovhash <file>   (plain SHA-256, hex, via III numera/cad)" as u64)
        putchar(10i32)
        return 2u64
    }
    let av : *u64 = argv as *u64
    let path : u64 = av[1u64]

    /* GENERIC_READ = 0x80000000, FILE_SHARE_READ = 1, OPEN_EXISTING = 3 */
    let h : u64 = CreateFileA(path, 2147483648u32, 1u32, 0u64, 3u32, 0u32, 0u64)
    if h == 18446744073709551615u64 {                       /* INVALID_HANDLE_VALUE */
        pstr("sovhash: cannot open: " as u64)   pstr(path)   putchar(10i32)
        return 3u64
    }

    if cad_begin(0u32) != 0i32 { CloseHandle(h)   return 5u64 }
    let mut going : u8 = 1u8
    while going == 1u8 {
        let ok : i32 = ReadFile(h, (&SH_BUF) as u64, 65536u32, (&SH_NREAD) as u64, 0u64)
        if ok == 0i32 { CloseHandle(h)   return 4u64 }
        let n : u32 = SH_NREAD[0u64]
        if n == 0u32 { going = 0u8 }
        else {
            if cad_payload((&SH_BUF) as u64, n as u64) != 0i32 { CloseHandle(h)   return 5u64 }
        }
    }
    CloseHandle(h)
    if cad_final((&SH_DIG) as u64) != 0i32 { return 5u64 }
    phex32((&SH_DIG) as u64)
    return 0u64
}
