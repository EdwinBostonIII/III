/* STDLIB/iii/aether/sqrt_sum_sign.iii -- GENERAL exact sign of a sum of square roots, sign(sum_i a_i sqrt(b_i)), for
 * ARBITRARY n, certified by a separation bound (algebraic-integer norm >= 1).
 *
 * SEPARATION BOUND (rigorous): E = sum a_i sqrt(b_i) is an algebraic integer of degree d <= 2^n.  If E != 0 its norm
 * (product of d conjugates, each a sign-variant E_eps bounded by M = sum |a_i|*ceil(sqrt b_i)) is a NONZERO integer,
 * so |E| = |norm| / prod(other d-1 conjugates) >= 1/M^(d-1) >= 1/M^(2^n - 1) =: 1/T.
 * ALGORITHM: approximate E*2^p with r_i = floor(sqrt(b_i * 2^(2p))) (bigint isqrt), error |~E - E*2^p| < A = sum|a_i|;
 * pick p with 2^p > 2*A*T; then |~E| > A -> sign(~E), else (|~E| <= A) -> |E| < 1/T <= separation -> E is EXACTLY 0.
 *
 * HONEST SCOPE: a NEW capability (handles n>=3 AND certifies exact zeros that float cancels) -- NOT a speedup of the
 * n<=2 coverage path (there the symbolic square-twice in ui_exact_big is far cheaper).  Precision is exponential in n
 * (the 2^n-1 exponent is inherent: the sum-of-roots sign problem is not known polynomial-bit).
 *
 * THE LADDER (sqrtsum_lazy3, dispatch order = cost order; every tier sound-or-abstain, the bottom total):
 *   Tier 1    adaptive i64 interval        hardware speed on any non-straddle;
 *   Tier 2    radical canonicalization     structural zeros / single surd, small radicands, no bigint;
 *   Tier 3    MULTIQUADRATIC GALOIS TOWER  kfield.iii weld: bounded-rank exact sign, pure guarded i64, NO
 *             separation bound (abstains on rank>3 / overflow -- never guesses; runs before the bigint tiers
 *             because it allocates nothing; the "2.5"/"3" labels are historical, dispatch is by cost);
 *   Tier 2.5  adaptive precision           bigint interval doubled to the instance's true need p~log(1/|E|);
 *   Tier 4    separation bound (oracle)    ui_sqrt_sum_sign, arbitrary n, exponential, certifies exact zeros.
 * LIVE CONSUMERS: eidos/ripple_eidolon (exact real-order verb of the eidolon ripple, gate 2133) and the aether
 * faces (csg_kernel, delaunay, algnum, aether_lens, aether_world, q23_sign->cyclotomic_se3/collide, verb_geom),
 * all through this one kernel -- gates run_sqrtsum_kats.sh / run_ripple_kats.sh / run_aether_lens_kats.sh. */
module sqrt_sum_sign

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(arena: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_copy(arena: u64, src: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_add(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_sub(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mul(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_cmp(a: u64, b: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_is_zero(id: u64) -> u8 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_shl_bits(arena: u64, a: u64, bits: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_shr_bits(arena: u64, a: u64, bits: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_len_limbs(id: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_get_limb(id: u64, i: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop_arena(arena: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn kf_multiquadratic_sign(a_ptr: u64, b_ptr: u64, n: u64) -> i32 from "kfield.iii"

/* bit length of a bigint (position of the highest set bit), robust to a non-normalised top limb */
fn bi_bitlen(N: u64) -> u64 {
    let len : u64 = bigint_len_limbs(N)
    let mut i : u64 = len
    while i > 0u64 {
        let limb : u64 = bigint_get_limb(N, i - 1u64)
        if limb != 0u64 {
            let mut bl : u64 = 0u64
            let mut t : u64 = limb
            while t > 0u64 { t = t >> 1u64   bl = bl + 1u64 }
            return ((i - 1u64) * 64u64) + bl
        }
        i = i - 1u64
    }
    return 0u64
}

/* floor(sqrt(N)) as a fresh bigint in arena ar.  Base-4 digit-by-digit: only add/sub/cmp/shift (no div, no mul). */
/* floor(sqrt(N)).  Handle-FRUGAL: every intermediate is dropped, so the live count stays ~6 (III's bigint handle
 * table is only 64 slots) and callers can chain many isqrt + ops without exhausting it. */
fn bigint_isqrt(ar: u64, N: u64) -> u64 @export {
    if bigint_is_zero(N) == 1u8 { return bigint_from_u64(ar, 0u64) }
    let bl : u64 = bi_bitlen(N)
    /* The base-4 digit loop allocates ~bl/2 intermediates that bigint_drop frees from the HANDLE TABLE but NOT from
     * the arena (a bump allocator -- bytes are reclaimed only by arena_drop).  Run it in a SUB-ARENA sized to the input
     * (~bl^2 bytes, generous) and copy only the result back, so the caller's arena does not accumulate ~bl^2 bytes per
     * isqrt.  That accumulation overflowed ui_sqrt_sum_sign's 16 MB arena at high precision (the n>=6 sqrt-sum-sign
     * FALSE-ZERO: 7 isqrts at p~2300 bits exhausted the arena -> degenerate handles -> psum==nsum -> wrong 0).  Now
     * isqrt is memory-frugal for EVERY caller and any precision -- no n ceiling. */
    let sub : u64 = arena_new((bl * bl) + 16777216u64)
    let k : u64 = (bl - 1u64) / 2u64                                  /* largest k with 4^k <= N */
    let one : u64 = bigint_from_u64(sub, 1u64)
    let mut bit : u64 = bigint_shl_bits(sub, one, 2u64 * k)
    bigint_drop(one)
    let mut res : u64 = bigint_from_u64(sub, 0u64)
    let mut n : u64 = bigint_copy(sub, N)
    while bigint_is_zero(bit) == 0u8 {
        let rb : u64 = bigint_add(sub, res, bit)
        let c : i32 = bigint_cmp(n, rb)                              /* capture BEFORE mutating n */
        let mut ge : u8 = 0u8                                        /* n >= rb, via > and == (i32 >= is the ordering trap) */
        if c > 0i32 { ge = 1u8 }
        if c == 0i32 { ge = 1u8 }
        if ge == 1u8 {
            let nn : u64 = bigint_sub(sub, n, rb)
            bigint_drop(n)   n = nn
            let sr : u64 = bigint_shr_bits(sub, res, 1u64)
            let nr : u64 = bigint_add(sub, sr, bit)
            bigint_drop(sr)   bigint_drop(res)   res = nr
        }
        if ge == 0u8 {
            let nr : u64 = bigint_shr_bits(sub, res, 1u64)
            bigint_drop(res)   res = nr
        }
        bigint_drop(rb)
        let nb : u64 = bigint_shr_bits(sub, bit, 2u64)
        bigint_drop(bit)   bit = nb
    }
    bigint_drop(n)
    let result : u64 = bigint_copy(ar, res)                          /* the only value that escapes the sub-arena */
    bigint_drop(res)
    bigint_drop_arena(sub)   arena_drop(sub)
    return result
}

fn iabs64(x: i64) -> u64 { if x < 0i64 { return (0i64 - x) as u64 }   return x as u64 }
fn isign64(x: i64) -> i32 { if x > 0i64 { return 1i32 }   if x < 0i64 { return 0i32 - 1i32 }   return 0i32 }

/* plain-u64 floor(sqrt(N)) -- NO bigint, NO arena, NO handles: the fast Tier-1 primitive. */
fn u64_isqrt(N: u64) -> u64 {
    if N == 0u64 { return 0u64 }
    let mut bl : u64 = 0u64   let mut t : u64 = N
    while t > 0u64 { t = t >> 1u64   bl = bl + 1u64 }
    let k : u64 = (bl - 1u64) / 2u64
    let mut bit : u64 = 1u64 << (2u64 * k)
    let mut res : u64 = 0u64
    let mut n : u64 = N
    while bit != 0u64 {
        let rb : u64 = res + bit
        let mut ge : u8 = 0u8
        if n >= rb { ge = 1u8 }
        if ge == 1u8 { n = n - rb   res = (res >> 1u64) + bit }
        if ge == 0u8 { res = res >> 1u64 }
        bit = bit >> 2u64
    }
    return res
}

/* TIER COUNTERS: how many sign decisions resolved on the fast i64 interval vs escalated to exact bigint.
 * The whole thesis is FASTCT >> EXACTCT -- bigint demoted from default to last-resort. */
var FASTCT : u64 = 0u64
var CANONCT : u64 = 0u64
var EXACTCT : u64 = 0u64
var KFCT : u64 = 0u64                     /* decided by the kfield Galois-tower tier (pure i64, no bigint) */
var KFABST : u64 = 0u64                   /* kfield tier attempted but ABSTAINED (rank>3 / envelope) -> fell through */
var BIQCT : u64 = 0u64                    /* decided by the low-surd bi-quadratic squaring rung (O(1) bigint; also counted in EXACTCT) */
fn lazy_fast_count() -> u64 @export { return FASTCT }
fn lazy_canon_count() -> u64 @export { return CANONCT }
fn lazy_exact_count() -> u64 @export { return EXACTCT }
fn lazy_kf_count() -> u64 @export { return KFCT }
fn lazy_kf_abstain_count() -> u64 @export { return KFABST }
fn lazy_biq_count() -> u64 @export { return BIQCT }
fn lazy_reset_counts() -> i32 @export { FASTCT = 0u64   CANONCT = 0u64   EXACTCT = 0u64   KFCT = 0u64   KFABST = 0u64   BIQCT = 0u64   return 0i32 }

/* ═══ TIER 0 -- THE LOW-SURD FAST-EXACT SIGNERS (folded here from ui_exact_big.iii / ui_exact_bigsign.iii: the
 * two-live-kernels redundancy ends -- ONE kernel, and the n<=2 iterated-squaring signers are its low-surd tiers).
 * For <=2 surds the ITERATED SQUARING is exact, finite, O(1) bigint -- NO separation bound, NO precision knob,
 * ANY coefficient magnitude.  The UI/coverage path (ui_arc_cover2d_big, ui_exact_sym, ui_exact_bigcov, field_run full)
 * consumes these exports directly; sqrtsum_lazy3 dispatches them for any raw <=2-surd query. ═══ */

/* sign(u + v*sqrt D), u,v signed i64, D>=0 -- EXACT via bigint (handles u^2, v^2*D far beyond i64). */
fn ui_bsign1(u: i64, v: i64, dD: i64) -> i32 @export {
    let su : i32 = isign64(u)
    let sv : i32 = isign64(v)
    if v == 0i64 { return su }
    if dD == 0i64 { return su }
    if su == 0i32 { return sv }
    if su == sv { return su }
    /* opposite signs: the larger magnitude wins -- |u|^2  vs  v^2 * D  (both as bigints) */
    let ar : u64 = arena_new(65536u64)
    let bu : u64 = bigint_from_u64(ar, iabs64(u))
    let bu2 : u64 = bigint_mul(ar, bu, bu)
    let bv : u64 = bigint_from_u64(ar, iabs64(v))
    let bv2 : u64 = bigint_mul(ar, bv, bv)
    let bD : u64 = bigint_from_u64(ar, dD as u64)
    let bv2D : u64 = bigint_mul(ar, bv2, bD)
    let c : i32 = bigint_cmp(bu2, bv2D)
    bigint_drop_arena(ar)
    arena_drop(ar)
    if c > 0i32 { return su }
    if c < 0i32 { return sv }
    return 0i32
}

/* sign(an + bn*sqrt D1 + cn*sqrt D2) -- the DEGREE-4 (bi-quadratic) sign, in arbitrary-precision bigint.  The
 * proven reduction: level 1 = sign(an + bn sqrt D1) [ui_bsign1]; if it opposes cn*sqrt D2, the winner is decided
 * by the level-2 single-D sign of u + v sqrt D1, u = an^2+bn^2 D1 - cn^2 D2, v = 2 an bn -- u,v BIGINT, so the
 * nested squaring (pp^2 ~ 1e62 at screen scale) never overflows. */
fn ui_sign_bi_big(an: i64, bn: i64, dD1: i64, cn: i64, dD2: i64) -> i32 @export {
    let sP : i32 = ui_bsign1(an, bn, dD1)
    if cn == 0i64 { return sP }
    if dD2 == 0i64 { return sP }
    let sC : i32 = isign64(cn)
    if sP == 0i32 { return sC }
    if sP == sC { return sP }
    /* opposite: s2 = sign(u + v sqrt D1), u = an^2+bn^2 D1 - cn^2 D2, v = 2 an bn (bigint) */
    let ar : u64 = arena_new(262144u64)
    let bD1 : u64 = bigint_from_u64(ar, dD1 as u64)
    let ban : u64 = bigint_from_u64(ar, iabs64(an))
    let bbn : u64 = bigint_from_u64(ar, iabs64(bn))
    let bcn : u64 = bigint_from_u64(ar, iabs64(cn))
    let an2 : u64 = bigint_mul(ar, ban, ban)
    let bn2D1 : u64 = bigint_mul(ar, bigint_mul(ar, bbn, bbn), bD1)
    let cn2D2 : u64 = bigint_mul(ar, bigint_mul(ar, bcn, bcn), bigint_from_u64(ar, dD2 as u64))
    let pos : u64 = bigint_add(ar, an2, bn2D1)                 /* an^2 + bn^2 D1 (>= 0) */
    let cu : i32 = bigint_cmp(pos, cn2D2)
    let mut su : i32 = 0i32
    let mut absu : u64 = 0u64
    if cu > 0i32 { su = 1i32         absu = bigint_sub(ar, pos, cn2D2) }
    if cu < 0i32 { su = 0i32 - 1i32  absu = bigint_sub(ar, cn2D2, pos) }
    let sv : i32 = isign64(an) * isign64(bn)
    let mut s2 : i32 = 0i32
    if sv == 0i32 { s2 = su }
    if sv != 0i32 {
        if su == 0i32 { s2 = sv }
        if su == sv { s2 = su }
        if su != sv {
            if su != 0i32 {
                /* |u|^2 vs v^2 D1 = (2|an||bn|)^2 D1 */
                let absv : u64 = bigint_mul(ar, bigint_mul(ar, ban, bbn), bigint_from_u64(ar, 2u64))
                let u2 : u64 = bigint_mul(ar, absu, absu)
                let v2D1 : u64 = bigint_mul(ar, bigint_mul(ar, absv, absv), bD1)
                let c2 : i32 = bigint_cmp(u2, v2D1)
                if c2 > 0i32 { s2 = su }
                if c2 < 0i32 { s2 = sv }
            }
        }
    }
    bigint_drop_arena(ar)
    arena_drop(ar)
    if s2 > 0i32 { return sP }
    if s2 < 0i32 { return sC }
    return 0i32
}

fn ui_bsgnv(s: i64) -> i32 { if s > 0i64 { return 1i32 }   if s < 0i64 { return 0i32 - 1i32 }   return 0i32 }

/* sign(asg*am + bsg*bm*sqrt(dD)), dD >= 0, am/bm magnitudes (bigint handles in ar), asg/bsg in {-1,0,1}. */
fn ui_bigsign_surd(ar: u64, asg: i64, am: u64, bsg: i64, bm: u64, dD: i64) -> i32 {
    if dD == 0i64 { return ui_bsgnv(asg) }
    if asg == 0i64 { return ui_bsgnv(bsg) }
    if bsg == 0i64 { return ui_bsgnv(asg) }
    if asg == bsg { return ui_bsgnv(asg) }
    let am2 : u64 = bigint_mul(ar, am, am)
    let bm2d : u64 = bigint_mul(ar, bigint_mul(ar, bm, bm), bigint_from_u64(ar, dD as u64))
    let c : i32 = bigint_cmp(am2, bm2d)
    if c > 0i32 { return ui_bsgnv(asg) }
    if c < 0i32 { return ui_bsgnv(bsg) }
    return 0i32
}

/* sign(an + bn*sqrt(dhi) + cn*sqrt(dlo)), an/bn/cn signed BIGINTS (sign + magnitude-handle pairs, caller arena),
 * dhi/dlo >= 0 small integers.  The bigint-coefficient port of the same proven squaring reduction; the exact
 * 2-surd decider under the render-scale coverage rounder (biground) and adaptive_sign_big's 2-class fast path. */
fn ui_bigsign2(ar: u64, ansg: i64, anm: u64, bnsg: i64, bnm: u64, dhi: i64, cnsg: i64, cnm: u64, dlo: i64) -> i32 @export {
    let sP : i32 = ui_bigsign_surd(ar, ansg, anm, bnsg, bnm, dhi)
    if cnsg == 0i64 { return sP }
    if dlo == 0i64 { return sP }
    let sC : i32 = ui_bsgnv(cnsg)
    if sP == 0i32 { return sC }
    if sP == sC { return sP }
    /* opposite signs: sign(P + cn*sqrt(dlo)) = sign(P) iff P^2 > cn^2*dlo.
     * P^2 = (an^2 + bn^2*dhi) + (2*an*bn)*sqrt(dhi); compare to cn^2*dlo (rational) -> a single-surd sign. */
    let an2 : u64 = bigint_mul(ar, anm, anm)
    let bn2dhi : u64 = bigint_mul(ar, bigint_mul(ar, bnm, bnm), bigint_from_u64(ar, dhi as u64))
    let ppA : u64 = bigint_add(ar, an2, bn2dhi)
    let cn2dlo : u64 = bigint_mul(ar, bigint_mul(ar, cnm, cnm), bigint_from_u64(ar, dlo as u64))
    let cc : i32 = bigint_cmp(ppA, cn2dlo)
    let mut rsg : i64 = 0i64
    let mut rmag : u64 = ppA
    if cc > 0i32 { rsg = 1i64        rmag = bigint_sub(ar, ppA, cn2dlo) }
    if cc < 0i32 { rsg = 0i64 - 1i64 rmag = bigint_sub(ar, cn2dlo, ppA) }
    let ppBsg : i64 = ansg * bnsg
    let ppBm : u64 = bigint_mul(ar, bigint_mul(ar, anm, bnm), bigint_from_u64(ar, 2u64))
    let s2 : i32 = ui_bigsign_surd(ar, rsg, rmag, ppBsg, ppBm, dhi)
    if s2 > 0i32 { return sP }
    if s2 < 0i32 { return sC }
    return 0i32
}

/* raw low-surd SHAPE probe for the dispatcher: sum rational terms (b==1) into SS_AN (overflow-checked), collect
 * up to TWO surd terms (b>1).  1 = shape fits (the bi-quadratic rung applies); 0 = refuse (negative/overflow/
 * more than 2 surds) -> the caller falls through.  b==0 or a==0 terms contribute nothing and are skipped. */
var SS_AN : i64   var SS_B1A : i64   var SS_B1D : i64   var SS_B2A : i64   var SS_B2D : i64
var SS_OVF : u32
fn ss_add_ck(a: i64, b: i64) -> i64 {
    if a == 0i64 { return b }
    if b == 0i64 { return a }
    let mut pa : u8 = 0u8   if a > 0i64 { pa = 1u8 }
    let mut pb : u8 = 0u8   if b > 0i64 { pb = 1u8 }
    if pa != pb { return a + b }
    let ua : u64 = iabs64(a)   let ub : u64 = iabs64(b)
    if pa == 1u8 {
        if (ua + ub) > 9223372036854775807u64 { SS_OVF = 1u32   return 0i64 }
        return a + b
    }
    if ua > 9223372036854775807u64 { SS_OVF = 1u32   return 0i64 }
    if ub > 9223372036854775807u64 { SS_OVF = 1u32   return 0i64 }
    if (ua + ub) > 9223372036854775808u64 { SS_OVF = 1u32   return 0i64 }
    return a + b
}
fn ss_shape2(a_ptr: u64, b_ptr: u64, n: u64) -> i32 {
    if n > 16u64 { return 0i32 }
    SS_AN = 0i64   SS_B1A = 0i64   SS_B1D = 0i64   SS_B2A = 0i64   SS_B2D = 0i64   SS_OVF = 0u32
    let pa : *i64 = a_ptr as *i64
    let pb : *i64 = b_ptr as *i64
    let mut ns : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n {
        let ai : i64 = pa[i]
        let bi : i64 = pb[i]
        if ai != 0i64 { if bi != 0i64 {
            if bi < 0i64 { return 0i32 }
            if bi == 1i64 {
                SS_AN = ss_add_ck(SS_AN, ai)
                if SS_OVF != 0u32 { return 0i32 }
            }
            if bi > 1i64 {
                if ns == 0u64 { SS_B1A = ai   SS_B1D = bi   ns = 1u64 }
                else { if ns == 1u64 { SS_B2A = ai   SS_B2D = bi   ns = 2u64 } else { return 0i32 } }
            }
        } }
        i = i + 1u64
    }
    return 1i32
}

/* squarefree split: b = s^2 * d with d squarefree; sets SFS=s, SFD=d.  Trial-divide square factors (cheap for small b). */
var SFS : u64   var SFD : u64
fn squarefree_part(b: u64) -> i32 {
    let mut d : u64 = b
    let mut s : u64 = 1u64
    let mut k : u64 = 2u64
    while (k * k) <= d {
        let kk : u64 = k * k
        let q : u64 = d / kk
        let mut divides : u8 = 0u8
        if (d - (q * kk)) == 0u64 { divides = 1u8 }
        if divides == 1u8 { d = q   s = s * k }
        if divides == 0u8 { k = k + 1u64 }
    }
    SFS = s   SFD = d
    return 0i32
}

/* TIER 2 -- radical canonicalization: reduce sum a_i sqrt(b_i) to collected-like-surds sum c_d sqrt(d) (d squarefree),
 * then decide by STRUCTURE: 0 = all c_d cancel (exact zero, no bigint); +-1 = a single surd; 2 = >=2 surds (undecided,
 * fall through to Tier 3).  ACCEPT-ONLY: never falsely rejects -- "2" just means "not proven here". */
var CD : [u64; 16]   var CC : [i64; 16]
fn sqrtsum_canon_decide(a_ptr: u64, b_ptr: u64, n: u64) -> i32 {
    let pa : *i64 = a_ptr as *i64
    let pb : *i64 = b_ptr as *i64
    let mut m : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n {
        let ai : i64 = pa[i]
        let bu : u64 = pb[i] as u64
        if ai != 0i64 {
            if bu != 0u64 {
                squarefree_part(bu)
                let d : u64 = SFD
                let coeff : i64 = ai * (SFS as i64)
                let mut fidx : u64 = 0u64   let mut hit : u8 = 0u8
                let mut j : u64 = 0u64
                while j < m {
                    if CD[j] == d { fidx = j   hit = 1u8 }
                    j = j + 1u64
                }
                if hit == 1u8 { CC[fidx] = CC[fidx] + coeff }
                if hit == 0u8 { CD[m] = d   CC[m] = coeff   m = m + 1u64 }
            }
        }
        i = i + 1u64
    }
    let mut nz : u64 = 0u64   let mut last : u64 = 0u64
    let mut j : u64 = 0u64
    while j < m {
        if CC[j] != 0i64 { nz = nz + 1u64   last = j }
        j = j + 1u64
    }
    if nz == 0u64 { return 0i32 }                        /* all surds cancelled -> EXACT structural zero */
    if nz == 1u64 { return isign64(CC[last]) }           /* one surd sqrt(d>0) -> sign of its coefficient */
    return 2i32                                          /* >= 2 distinct surds -> undecided here */
}

/* THE THREE-TIER LAZY SIGN (Attacks 1 + 3 killed):
 *   Tier 1  -- adaptive i64 interval (scale F = (60 - maxbitlen)/2, so ANY b_i rides the fast path; no fixed ceiling);
 *   Tier 2  -- radical canonicalization, gated to SMALL radicands (so factoring is cheap, no e-graph saturation);
 *   Tier 3  -- the separation-bound bigint, only when both above abstain. */
fn sqrtsum_lazy3(a_ptr: u64, b_ptr: u64, n: u64) -> i32 @export {
    let pa : *i64 = a_ptr as *i64
    let pb : *i64 = b_ptr as *i64
    let mut maxbl : u64 = 1u64
    let mut allsmall : u8 = 1u8
    let mut bad : u8 = 0u8
    let mut i : u64 = 0u64
    while i < n {
        let ai : i64 = pa[i]
        let bi : i64 = pb[i]
        if isign64(bi) == (0i32 - 1i32) { bad = 1u8 }
        if iabs64(ai) >= (1u64 << 20u64) { bad = 1u8 }
        let bu : u64 = bi as u64
        let mut bl : u64 = 0u64   let mut t : u64 = bu
        while t > 0u64 { t = t >> 1u64   bl = bl + 1u64 }
        if bl > maxbl { maxbl = bl }
        if bu >= (1u64 << 20u64) { allsmall = 0u8 }
        i = i + 1u64
    }
    if bad == 1u8 {
        /* TIER 0 -- any-magnitude coefficients but a low-surd SHAPE: <=2 surd terms decide by the exact O(1)
         * bi-quadratic squaring instead of the exponential separation bound (negative radicands refuse). */
        if ss_shape2(a_ptr, b_ptr, n) == 1i32 {
            EXACTCT = EXACTCT + 1u64   BIQCT = BIQCT + 1u64
            return ui_sign_bi_big(SS_AN, SS_B1A, SS_B1D, SS_B2A, SS_B2D)
        }
        EXACTCT = EXACTCT + 1u64
        return ui_sqrt_sum_sign(a_ptr, b_ptr, n)
    }
    let mut F : u64 = 1u64
    if maxbl < 58u64 { F = (60u64 - maxbl) / 2u64 }      /* RELATIVE windowing -- precision adapts to magnitude */
    if F == 0u64 { F = 1u64 }
    let mut elo : i64 = 0i64   let mut ehi : i64 = 0i64
    i = 0u64
    while i < n {
        let ai : i64 = pa[i]
        let bu : u64 = pb[i] as u64
        let silo : u64 = u64_isqrt(bu << (2u64 * F))
        let sihi : u64 = silo + 1u64
        let sa : i32 = isign64(ai)
        if sa == 1i32 { elo = elo + (ai * (silo as i64))   ehi = ehi + (ai * (sihi as i64)) }
        if sa == (0i32 - 1i32) { elo = elo + (ai * (sihi as i64))   ehi = ehi + (ai * (silo as i64)) }
        i = i + 1u64
    }
    if isign64(elo) == 1i32 { FASTCT = FASTCT + 1u64   return 1i32 }
    if isign64(ehi) == (0i32 - 1i32) { FASTCT = FASTCT + 1u64   return 0i32 - 1i32 }
    if allsmall == 1u8 {
        let r : i32 = sqrtsum_canon_decide(a_ptr, b_ptr, n)
        if r != 2i32 { CANONCT = CANONCT + 1u64   return r }
        /* TIER 3 -- the multiquadratic GALOIS TOWER (kfield weld).  After canon abstains (>=2 independent surds,
         * so the value is provably NONZERO), try the bounded-rank tower: F2-embed the surds into K = Q(sqrtA,
         * sqrtB, sqrtC) and sign by pure guarded i64 squaring down the tower -- NO separation bound, NO arena.
         * 2 = abstain (rank > 3 / i64 envelope) -> fall through to the bigint tiers.  Sound by the differential
         * gate 2159 (identical to ui_sqrt_sum_sign wherever it answers). */
        let kr : i32 = kf_multiquadratic_sign(a_ptr, b_ptr, n)
        if kr != 2i32 { KFCT = KFCT + 1u64   return kr }
        KFABST = KFABST + 1u64
    }
    /* TIER 0 -- low-surd shape at any radicand magnitude: <=2 surd terms decide by the exact O(1) bi-quadratic
     * squaring (the folded ui_exact_big path) instead of the adaptive doubling loop. */
    if ss_shape2(a_ptr, b_ptr, n) == 1i32 {
        EXACTCT = EXACTCT + 1u64   BIQCT = BIQCT + 1u64
        return ui_sign_bi_big(SS_AN, SS_B1A, SS_B1D, SS_B2A, SS_B2D)
    }
    EXACTCT = EXACTCT + 1u64
    /* TIER 2.5 is the escalation target for >=3-surd shapes: the adaptive engine pays the instance's true
     * precision and only falls to the exponential separation bound if its cap is hit -- same answer, never slower.
     * This makes sqrtsum_adaptive_sign LOAD-BEARING in the shipped dispatcher that verb_geom consumes. */
    return sqrtsum_adaptive_sign(a_ptr, b_ptr, n)
}

/* ATTACK 2 killed -- TRANSCENDENTAL CONTAMINATION handled by a provenance-aware TRISTATE.  Decides
 * sign(sum a_i sqrt(b_i) + pi_coeff * pi).  The interval (now including pi's bracket) decides +1/-1 at hardware speed
 * whenever it doesn't straddle 0.  On a straddle: if pi_coeff==0 the value is ALGEBRAIC -> certify exactly via Tier 3
 * (may be 0); if pi_coeff!=0 the value is TRANSCENDENTAL -> return 2 = UNKNOWN, an HONEST bounded answer (Richardson:
 * a transcendental zero is undecidable -- NEVER a panic, NEVER a false zero).  pi bracketed at 2^-20: [PILO,PIHI]. */
var PILO : u64 = 3294198u64                                 /* floor(pi * 2^20) */
var PIHI : u64 = 3294199u64
fn sqrtsum_pi_sign(a_ptr: u64, b_ptr: u64, n: u64, pi_coeff: i64) -> i32 @export {
    let pa : *i64 = a_ptr as *i64
    let pb : *i64 = b_ptr as *i64
    let f : u64 = 20u64
    let mut elo : i64 = 0i64   let mut ehi : i64 = 0i64
    let mut i : u64 = 0u64
    while i < n {
        let ai : i64 = pa[i]
        let bu : u64 = pb[i] as u64
        let silo : u64 = u64_isqrt(bu << (2u64 * f))
        let sihi : u64 = silo + 1u64
        let sa : i32 = isign64(ai)
        if sa == 1i32 { elo = elo + (ai * (silo as i64))   ehi = ehi + (ai * (sihi as i64)) }
        if sa == (0i32 - 1i32) { elo = elo + (ai * (sihi as i64))   ehi = ehi + (ai * (silo as i64)) }
        i = i + 1u64
    }
    let sp : i32 = isign64(pi_coeff)
    if sp == 1i32 { elo = elo + (pi_coeff * (PILO as i64))   ehi = ehi + (pi_coeff * (PIHI as i64)) }
    if sp == (0i32 - 1i32) { elo = elo + (pi_coeff * (PIHI as i64))   ehi = ehi + (pi_coeff * (PILO as i64)) }
    if isign64(elo) == 1i32 { return 1i32 }
    if isign64(ehi) == (0i32 - 1i32) { return 0i32 - 1i32 }
    if pi_coeff == 0i64 { return ui_sqrt_sum_sign(a_ptr, b_ptr, n) }   /* algebraic -> exact (may certify 0) */
    return 2i32                                                        /* transcendental straddle -> honest UNKNOWN */
}

/* THE LAZY EXACT-REAL SIGN: Tier 1 = bigint-free i64 interval at 2^-20; if it does NOT straddle 0 (and stays in i64
 * range) the sign is returned at hardware speed.  Otherwise escalate to Tier 3 (the separation-bound bigint, exact).
 * Same answer as ui_sqrt_sum_sign always -- but bigint runs only on the rare straddle / out-of-range input. */
fn sqrtsum_lazy_sign(a_ptr: u64, b_ptr: u64, n: u64) -> i32 @export {
    let pa : *i64 = a_ptr as *i64
    let pb : *i64 = b_ptr as *i64
    let f : u64 = 20u64                                          /* fractional bits of the interval */
    let lim : u64 = 1u64 << (64u64 - (2u64 * f))                 /* b_i must be < 2^24 for the u64 isqrt at 2f bits */
    let mut elo : i64 = 0i64                                     /* lower bound of E * 2^f */
    let mut ehi : i64 = 0i64                                     /* upper bound of E * 2^f */
    let mut escalate : u8 = 0u8
    let mut i : u64 = 0u64
    while i < n {
        let ai : i64 = pa[i]
        let bi : i64 = pb[i]
        if isign64(bi) == (0i32 - 1i32) { escalate = 1u8 }       /* negative radicand -> not handled here */
        let bu : u64 = bi as u64
        if bu >= lim { escalate = 1u8 }                          /* radicand too large for the fast path */
        if iabs64(ai) >= (1u64 << 20u64) { escalate = 1u8 }      /* coefficient too large -> i64 sum could overflow */
        if escalate == 0u8 {
            let silo : u64 = u64_isqrt(bu << (2u64 * f))         /* floor(sqrt(b_i)*2^f) */
            let sihi : u64 = silo + 1u64
            let sa : i32 = isign64(ai)
            if sa == 1i32 {
                elo = elo + (ai * (silo as i64))
                ehi = ehi + (ai * (sihi as i64))
            }
            if sa == (0i32 - 1i32) {
                elo = elo + (ai * (sihi as i64))                 /* a_i<0: a_i*sihi is the LOWER bound */
                ehi = ehi + (ai * (silo as i64))
            }
        }
        i = i + 1u64
    }
    let mut r : i32 = 0i32
    if escalate == 0u8 {
        if isign64(elo) == 1i32 { r = 1i32 }                     /* interval entirely > 0 */
        if isign64(ehi) == (0i32 - 1i32) { r = 0i32 - 1i32 }     /* interval entirely < 0 */
    }
    if r != 0i32 {
        FASTCT = FASTCT + 1u64
        return r                                                 /* TIER 1: hardware-speed, no bigint */
    }
    EXACTCT = EXACTCT + 1u64
    return ui_sqrt_sum_sign(a_ptr, b_ptr, n)                     /* TIER 3: exact bigint, only on a straddle */
}

/* sign(sum_{i<n} a[i]*sqrt(b[i])) -- EXACT for arbitrary n, via the separation bound.  a[i] signed i64, b[i] >= 0.
 * Returns +1 / 0 / -1.  Certifies EXACT ZEROS (where float cancels).  All bigint intermediates are dropped to stay
 * inside the 64-slot handle table. */
fn ui_sqrt_sum_sign(a_ptr: u64, b_ptr: u64, n: u64) -> i32 @export {
    let pa : *i64 = a_ptr as *i64
    let pb : *i64 = b_ptr as *i64
    let ar : u64 = arena_new(16777216u64)
    let one : u64 = bigint_from_u64(ar, 1u64)

    /* Phase 1: A = sum|a_i| ; M = sum |a_i|*(floor(sqrt b_i)+1)  [ceil-safe upper bound on sqrt b_i] */
    let mut A : u64 = bigint_from_u64(ar, 0u64)
    let mut M : u64 = bigint_from_u64(ar, 0u64)
    let mut i : u64 = 0u64
    while i < n {
        let aa : u64 = iabs64(pa[i])
        if aa != 0u64 {
            let aabig : u64 = bigint_from_u64(ar, aa)
            let nA : u64 = bigint_add(ar, A, aabig)
            bigint_drop(A)   A = nA
            let bibig : u64 = bigint_from_u64(ar, pb[i] as u64)
            let si : u64 = bigint_isqrt(ar, bibig)
            bigint_drop(bibig)
            let si1 : u64 = bigint_add(ar, si, one)
            bigint_drop(si)
            let term : u64 = bigint_mul(ar, aabig, si1)
            bigint_drop(si1)   bigint_drop(aabig)
            let nM : u64 = bigint_add(ar, M, term)
            bigint_drop(M)   bigint_drop(term)   M = nM
        }
        i = i + 1u64
    }

    /* Phase 2: T = M^(2^n - 1) */
    let e : u64 = (1u64 << n) - 1u64
    let mut T : u64 = bigint_from_u64(ar, 1u64)
    let mut j : u64 = 0u64
    while j < e {
        let nT : u64 = bigint_mul(ar, T, M)
        bigint_drop(T)   T = nT
        j = j + 1u64
    }

    /* Phase 3: p with 2^p > 2*A*T */
    let AT : u64 = bigint_mul(ar, A, T)
    let thresh : u64 = bigint_add(ar, AT, AT)
    bigint_drop(AT)   bigint_drop(T)   bigint_drop(M)
    let p : u64 = bi_bitlen(thresh) + 1u64
    bigint_drop(thresh)
    let twop : u64 = 2u64 * p

    /* Phase 4: psum = sum_{a_i>0} a_i*r_i , nsum = sum_{a_i<0} |a_i|*r_i ,  r_i = floor(sqrt(b_i << 2p)) */
    let mut psum : u64 = bigint_from_u64(ar, 0u64)
    let mut nsum : u64 = bigint_from_u64(ar, 0u64)
    i = 0u64
    while i < n {
        let aa : u64 = iabs64(pa[i])
        let sa : i32 = isign64(pa[i])
        if aa != 0u64 {
            if pb[i] != 0i64 {
                let bibig : u64 = bigint_from_u64(ar, pb[i] as u64)
                let bishift : u64 = bigint_shl_bits(ar, bibig, twop)
                bigint_drop(bibig)
                let ri : u64 = bigint_isqrt(ar, bishift)
                bigint_drop(bishift)
                let aabig : u64 = bigint_from_u64(ar, aa)
                let term : u64 = bigint_mul(ar, aabig, ri)
                bigint_drop(aabig)   bigint_drop(ri)
                if sa == 1i32 {
                    let nP : u64 = bigint_add(ar, psum, term)
                    bigint_drop(psum)   psum = nP
                }
                if sa == (0i32 - 1i32) {
                    let nN : u64 = bigint_add(ar, nsum, term)
                    bigint_drop(nsum)   nsum = nN
                }
                bigint_drop(term)
            }
        }
        i = i + 1u64
    }

    /* Phase 5: |psum-nsum| > A -> sign ; else EXACTLY 0 (|E| < 1/T <= separation) */
    let cs : i32 = bigint_cmp(psum, nsum)
    let mut result : i32 = 0i32
    if cs > 0i32 {
        let diff : u64 = bigint_sub(ar, psum, nsum)
        if bigint_cmp(diff, A) > 0i32 { result = 1i32 }
        bigint_drop(diff)
    }
    if cs < 0i32 {
        let diff : u64 = bigint_sub(ar, nsum, psum)
        if bigint_cmp(diff, A) > 0i32 { result = 0i32 - 1i32 }
        bigint_drop(diff)
    }
    bigint_drop(psum)   bigint_drop(nsum)   bigint_drop(A)   bigint_drop(one)
    bigint_drop_arena(ar)
    arena_drop(ar)                                          /* release the region too (was leaked) -- safe under a per-pixel loop */
    return result
}

/* sign(sum_{i<n} sgn[i]*|mag[i]|*sqrt(b[i])) with BIGINT coefficient magnitudes -- the render-scale N-surd sign.  Same
 * separation bound as ui_sqrt_sum_sign, but each |a_i| is a caller-owned bigint HANDLE (mag[i]) with its sign in sgn[i]
 * (+1/-1/0), so coefficients that overflow i64 (the extremum-column SUM cov_A+cov_B cross-products) are exact.  b[i]>=0
 * stay i64 (the crossing discriminants fit i64 to ~coord 4e4).  sgn[i]==0 skips the term.  Returns +1/0/-1; certifies
 * exact zeros.  Caller owns mag[i] (never dropped here).  This is the finisher under ui_arc_cover_full's extremum sum. */
fn ui_sqrt_sum_sign_big(mag_ptr: u64, sgn_ptr: u64, b_ptr: u64, n: u64) -> i32 @export {
    let pmag : *u64 = mag_ptr as *u64
    let psgn : *i64 = sgn_ptr as *i64
    let pb : *i64 = b_ptr as *i64
    let ar : u64 = arena_new(16777216u64)
    let one : u64 = bigint_from_u64(ar, 1u64)

    /* Phase 1: A = sum|a_i| ; M = sum |a_i|*(floor(sqrt b_i)+1) */
    let mut A : u64 = bigint_from_u64(ar, 0u64)
    let mut M : u64 = bigint_from_u64(ar, 0u64)
    let mut i : u64 = 0u64
    while i < n {
        if psgn[i] != 0i64 {
            let amag : u64 = pmag[i]
            let nA : u64 = bigint_add(ar, A, amag)
            bigint_drop(A)   A = nA
            let bibig : u64 = bigint_from_u64(ar, pb[i] as u64)
            let si : u64 = bigint_isqrt(ar, bibig)
            bigint_drop(bibig)
            let si1 : u64 = bigint_add(ar, si, one)
            bigint_drop(si)
            let term : u64 = bigint_mul(ar, amag, si1)
            bigint_drop(si1)
            let nM : u64 = bigint_add(ar, M, term)
            bigint_drop(M)   bigint_drop(term)   M = nM
        }
        i = i + 1u64
    }

    /* Phase 2: T = M^(2^n - 1) */
    let e : u64 = (1u64 << n) - 1u64
    let mut T : u64 = bigint_from_u64(ar, 1u64)
    let mut j : u64 = 0u64
    while j < e {
        let nT : u64 = bigint_mul(ar, T, M)
        bigint_drop(T)   T = nT
        j = j + 1u64
    }

    /* Phase 3: p with 2^p > 2*A*T */
    let AT : u64 = bigint_mul(ar, A, T)
    let thresh : u64 = bigint_add(ar, AT, AT)
    bigint_drop(AT)   bigint_drop(T)   bigint_drop(M)
    let p : u64 = bi_bitlen(thresh) + 1u64
    bigint_drop(thresh)
    let twop : u64 = 2u64 * p

    /* Phase 4: psum = sum_{sgn>0} |a_i|*r_i ; nsum = sum_{sgn<0} |a_i|*r_i ; r_i = floor(sqrt(b_i << 2p)) */
    let mut psum : u64 = bigint_from_u64(ar, 0u64)
    let mut nsum : u64 = bigint_from_u64(ar, 0u64)
    i = 0u64
    while i < n {
        let sgni : i64 = psgn[i]
        if sgni != 0i64 {
            if pb[i] != 0i64 {
                let bibig : u64 = bigint_from_u64(ar, pb[i] as u64)
                let bishift : u64 = bigint_shl_bits(ar, bibig, twop)
                bigint_drop(bibig)
                let ri : u64 = bigint_isqrt(ar, bishift)
                bigint_drop(bishift)
                let term : u64 = bigint_mul(ar, pmag[i], ri)
                bigint_drop(ri)
                if sgni > 0i64 { let nP : u64 = bigint_add(ar, psum, term)   bigint_drop(psum)   psum = nP }
                if sgni < 0i64 { let nN : u64 = bigint_add(ar, nsum, term)   bigint_drop(nsum)   nsum = nN }
                bigint_drop(term)
            }
        }
        i = i + 1u64
    }

    /* Phase 5: |psum-nsum| > A -> sign ; else EXACTLY 0 */
    let cs : i32 = bigint_cmp(psum, nsum)
    let mut result : i32 = 0i32
    if cs > 0i32 {
        let diff : u64 = bigint_sub(ar, psum, nsum)
        if bigint_cmp(diff, A) > 0i32 { result = 1i32 }
        bigint_drop(diff)
    }
    if cs < 0i32 {
        let diff : u64 = bigint_sub(ar, nsum, psum)
        if bigint_cmp(diff, A) > 0i32 { result = 0i32 - 1i32 }
        bigint_drop(diff)
    }
    bigint_drop(psum)   bigint_drop(nsum)   bigint_drop(A)   bigint_drop(one)
    bigint_drop_arena(ar)
    arena_drop(ar)
    return result
}

/* ─── TIER 2.5 — LINEAR INDEPENDENCE + ADAPTIVE PRECISION.  The direct attack on the exponential separation bound.
 * After canonicalizing to distinct squarefree radicands, {√d} are ℚ-LINEARLY INDEPENDENT, so Σ c_j √d_j is EXACTLY 0
 * iff every collected c_j vanishes (decided FREE — no bound) and ANY survivor makes the sum NONZERO.  A nonzero sum is
 * separated from 0 by DOUBLING interval precision to the instance's true need p ~ log(1/|E|), never the a-priori
 * M^(2ⁿ⁻¹).  Same answer as ui_sqrt_sum_sign, but it pays the instance cost, not the worst case.
 *   HONEST SCOPE: this does NOT solve PosSLP — the WORST-CASE p is unchanged (a pathologically-near-zero instance can
 *   still need ~2ⁿ bits).  The win is per-instance: generic / non-degenerate inputs (the robot-arm case) resolve in
 *   tens of bits where the separation bound demands thousands.  SOUNDNESS is unconditional: m≥2 ⇒ nonzero, so
 *   result==0 after the loop can ONLY mean 'capped before separation' → it falls to the exact engine, never a false 0. */
var ADAPT_LAST_P : u64 = 0u64
fn sqrtsum_last_p() -> u64 @export { return ADAPT_LAST_P }

/* collect distinct squarefree radicands into CD[]/CC[] (reuses this file's squarefree_part); returns survivor count. */
fn sqrtsum_canon_collect(a_ptr: u64, b_ptr: u64, n: u64) -> u64 {
    let pa : *i64 = a_ptr as *i64
    let pb : *i64 = b_ptr as *i64
    let mut m : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n {
        let ai : i64 = pa[i]
        let bu : u64 = pb[i] as u64
        if ai != 0i64 { if bu != 0u64 {
            squarefree_part(bu)
            let d : u64 = SFD
            let coeff : i64 = ai * (SFS as i64)
            let mut hit : u8 = 0u8   let mut fj : u64 = 0u64   let mut j : u64 = 0u64
            while j < m { if CD[j] == d { fj = j   hit = 1u8 }   j = j + 1u64 }
            if hit == 1u8 { CC[fj] = CC[fj] + coeff } else { CD[m] = d   CC[m] = coeff   m = m + 1u64 }
        } }
        i = i + 1u64
    }
    let mut w : u64 = 0u64   let mut r : u64 = 0u64
    while r < m { let cr : i64 = CC[r]   if cr != 0i64 { CD[w] = CD[r]   CC[w] = cr   w = w + 1u64 }   r = r + 1u64 }
    return w
}

fn sqrtsum_adaptive_sign(a_ptr: u64, b_ptr: u64, n: u64) -> i32 @export {
    let m : u64 = sqrtsum_canon_collect(a_ptr, b_ptr, n)
    ADAPT_LAST_P = 0u64
    if m == 0u64 { return 0i32 }                               /* all surds cancelled -> EXACT zero, FREE */
    if m == 1u64 { let c0 : i64 = CC[0u64]   return isign64(c0) }   /* single surd sqrt(d>0) -> sign of its coeff, FREE */
    let ar : u64 = arena_new(33554432u64)
    let mut p : u64 = 8u64
    let mut result : i32 = 0i32
    let mut done : u8 = 0u8
    while done == 0u8 {
        let twop : u64 = 2u64 * p
        let mut pL : u64 = bigint_from_u64(ar, 0u64)   let mut pH : u64 = bigint_from_u64(ar, 0u64)
        let mut nL : u64 = bigint_from_u64(ar, 0u64)   let mut nH : u64 = bigint_from_u64(ar, 0u64)
        let mut j : u64 = 0u64
        while j < m {
            let cj : i64 = CC[j]                               /* HOIST before the signed compare (iii array-index-in->0 trap) */
            let bd : u64 = bigint_from_u64(ar, CD[j])
            let bsh : u64 = bigint_shl_bits(ar, bd, twop)   bigint_drop(bd)
            let L : u64 = bigint_isqrt(ar, bsh)   bigint_drop(bsh)         /* floor(sqrt(d) * 2^p) */
            let one : u64 = bigint_from_u64(ar, 1u64)
            let L1 : u64 = bigint_add(ar, L, one)   bigint_drop(one)
            let cabs : u64 = bigint_from_u64(ar, iabs64(cj))
            let tL : u64 = bigint_mul(ar, cabs, L)                         /* |c|*floor (lower for |c|*sqrt d) */
            let tH : u64 = bigint_mul(ar, cabs, L1)                        /* |c|*(floor+1) (upper)           */
            bigint_drop(cabs)   bigint_drop(L)   bigint_drop(L1)
            if cj > 0i64 {
                let a2 : u64 = bigint_add(ar, pL, tL)   bigint_drop(pL)   pL = a2
                let b2 : u64 = bigint_add(ar, pH, tH)   bigint_drop(pH)   pH = b2
            } else {
                let a2 : u64 = bigint_add(ar, nL, tL)   bigint_drop(nL)   nL = a2
                let b2 : u64 = bigint_add(ar, nH, tH)   bigint_drop(nH)   nH = b2
            }
            bigint_drop(tL)   bigint_drop(tH)
            j = j + 1u64
        }
        /* E in [pL - nH , pH - nL].  pL>nH => E>0 ; pH<nL => E<0 ; else double precision. */
        if bigint_cmp(pL, nH) > 0i32 { result = 1i32   done = 1u8 }
        if done == 0u8 { if bigint_cmp(pH, nL) < 0i32 { result = 0i32 - 1i32   done = 1u8 } }
        bigint_drop(pL)   bigint_drop(pH)   bigint_drop(nL)   bigint_drop(nH)
        if done == 1u8 { ADAPT_LAST_P = p }
        if done == 0u8 { p = p * 2u64   if p > 500000u64 { done = 1u8 } }   /* CAP = performance knob ONLY */
    }
    bigint_drop_arena(ar)   arena_drop(ar)
    if result == 0i32 { return ui_sqrt_sum_sign(a_ptr, b_ptr, n) }   /* capped before separation -> exact fallback, never a false zero */
    return result
}

/* ─── TIER 2.5, BIGINT-COEFFICIENT.  sqrtsum_adaptive_sign_big decides sign(Σ sgn[i]·|mag[i]|·√b[i]) with mag[i] a
 * caller-owned BIGINT handle (the render-scale case ui_sqrt_sum_sign_big serves -- glyph cross-products overflow i64),
 * by the SAME linear-independence + adaptive-precision method: SIGNED-bigint squarefree canonicalization (EXACT zero iff
 * every class coeff cancels -- FREE), then double the bigint interval precision to the instance's need.  Falls back to
 * ui_sqrt_sum_sign_big only if the cap is hit.  Each interval iteration uses its OWN sub-arena to bound the bump-allocator
 * accumulation (drop frees handles, not bytes).  Same answer as ui_sqrt_sum_sign_big, without its a-priori M^(2ⁿ⁻¹). */
var AB_SFS : i64   var AB_SFD : i64
fn ab_sqfree(v: i64) -> i32 {
    let mut d : i64 = v   let mut s : i64 = 1i64   let mut k : i64 = 2i64
    while k * k <= d { let kk : i64 = k * k   let q : i64 = d / kk   if d - q * kk == 0i64 { d = q   s = s * k } else { k = k + 1i64 } }
    AB_SFS = s   AB_SFD = d   return 0i32
}
var CMAG : [u64; 16]   var CSGN : [i64; 16]   var CRAD : [i64; 16]   var NCLS : u64

/* signed add of (bmag,bsgn) into class j; bigints in arena ar. */
fn cls_add(ar: u64, j: u64, bmag: u64, bsgn: i64) -> i32 {
    let asgn : i64 = CSGN[j]
    if bsgn == 0i64 { return 0i32 }
    if asgn == 0i64 { let nw : u64 = bigint_copy(ar, bmag)   bigint_drop(CMAG[j])   CMAG[j] = nw   CSGN[j] = bsgn   return 0i32 }
    if asgn == bsgn { let nw : u64 = bigint_add(ar, CMAG[j], bmag)   bigint_drop(CMAG[j])   CMAG[j] = nw   return 0i32 }
    let c : i32 = bigint_cmp(CMAG[j], bmag)
    if c > 0i32 { let nw : u64 = bigint_sub(ar, CMAG[j], bmag)   bigint_drop(CMAG[j])   CMAG[j] = nw   return 0i32 }
    if c < 0i32 { let nw : u64 = bigint_sub(ar, bmag, CMAG[j])   bigint_drop(CMAG[j])   CMAG[j] = nw   CSGN[j] = bsgn   return 0i32 }
    let z : u64 = bigint_from_u64(ar, 0u64)   bigint_drop(CMAG[j])   CMAG[j] = z   CSGN[j] = 0i64   return 0i32
}

fn canon_big(ar: u64, mag_ptr: u64, sgn_ptr: u64, b_ptr: u64, n: u64) -> u64 {
    let pm : *u64 = mag_ptr as *u64   let ps : *i64 = sgn_ptr as *i64   let pb : *i64 = b_ptr as *i64
    NCLS = 0u64
    let mut i : u64 = 0u64
    while i < n {
        let si : i64 = ps[i]
        if si != 0i64 {
            let bi : i64 = pb[i]
            ab_sqfree(bi)
            let c : i64 = AB_SFS   let d : i64 = AB_SFD
            let cbig : u64 = bigint_from_u64(ar, c as u64)
            let magp : u64 = bigint_mul(ar, pm[i], cbig)
            bigint_drop(cbig)
            let mut j : u64 = 0u64   let mut hit : u8 = 0u8   let mut fj : u64 = 0u64
            while j < NCLS { if CRAD[j] == d { fj = j   hit = 1u8 }   j = j + 1u64 }
            if hit == 0u8 { CRAD[NCLS] = d   CMAG[NCLS] = bigint_from_u64(ar, 0u64)   CSGN[NCLS] = 0i64   fj = NCLS   NCLS = NCLS + 1u64 }
            cls_add(ar, fj, magp, si)
            bigint_drop(magp)
        }
        i = i + 1u64
    }
    return NCLS
}

fn sqrtsum_adaptive_sign_big(mag_ptr: u64, sgn_ptr: u64, b_ptr: u64, n: u64) -> i32 @export {
    let ar : u64 = arena_new(16777216u64)
    canon_big(ar, mag_ptr, sgn_ptr, b_ptr, n)
    let mut nz : u64 = 0u64   let mut lastj : u64 = 0u64   let mut j : u64 = 0u64
    while j < NCLS { let cs : i64 = CSGN[j]   if cs != 0i64 { nz = nz + 1u64   lastj = j }   j = j + 1u64 }
    if nz == 0u64 { bigint_drop_arena(ar)   arena_drop(ar)   return 0i32 }
    if nz == 1u64 { let s : i64 = CSGN[lastj]   bigint_drop_arena(ar)   arena_drop(ar)   if s > 0i64 { return 1i32 }   return 0i32 - 1i32 }
    if nz == 2u64 {
        /* TIER 0' -- TWO classes decide by the exact O(1) bigint squaring (the folded ui_bigsign2), not the
         * doubling loop: rational class (rad 1) -> an; the surd class(es) -> (bn, dhi) / (cn, dlo). */
        let mut j1 : u64 = 99u64   let mut j2 : u64 = 99u64
        let mut k1 : u64 = 0u64
        while k1 < NCLS {
            let cs1 : i64 = CSGN[k1]
            if cs1 != 0i64 { if j1 == 99u64 { j1 = k1 } else { j2 = k1 } }
            k1 = k1 + 1u64
        }
        let r1 : i64 = CRAD[j1]   let r2c : i64 = CRAD[j2]
        let mut res2 : i32 = 0i32
        if r1 == 1i64 {
            res2 = ui_bigsign2(ar, CSGN[j1], CMAG[j1], CSGN[j2], CMAG[j2], r2c, 0i64, CMAG[j1], 0i64)
        } else { if r2c == 1i64 {
            res2 = ui_bigsign2(ar, CSGN[j2], CMAG[j2], CSGN[j1], CMAG[j1], r1, 0i64, CMAG[j2], 0i64)
        } else {
            let zh : u64 = bigint_from_u64(ar, 0u64)
            res2 = ui_bigsign2(ar, 0i64, zh, CSGN[j1], CMAG[j1], r1, CSGN[j2], CMAG[j2], r2c)
        } }
        bigint_drop_arena(ar)   arena_drop(ar)
        return res2
    }
    let mut p : u64 = 8u64   let mut result : i32 = 0i32   let mut done : u8 = 0u8
    while done == 0u8 {
        let iar : u64 = arena_new(16777216u64)
        let twop : u64 = 2u64 * p
        let mut pL : u64 = bigint_from_u64(iar, 0u64)   let mut pH : u64 = bigint_from_u64(iar, 0u64)
        let mut nL : u64 = bigint_from_u64(iar, 0u64)   let mut nH : u64 = bigint_from_u64(iar, 0u64)
        let mut k : u64 = 0u64
        while k < NCLS {
            let cs : i64 = CSGN[k]
            if cs != 0i64 {
                let bd : u64 = bigint_from_u64(iar, CRAD[k] as u64)
                let bsh : u64 = bigint_shl_bits(iar, bd, twop)   bigint_drop(bd)
                let L : u64 = bigint_isqrt(iar, bsh)   bigint_drop(bsh)
                let one : u64 = bigint_from_u64(iar, 1u64)
                let L1 : u64 = bigint_add(iar, L, one)   bigint_drop(one)
                let tL : u64 = bigint_mul(iar, CMAG[k], L)
                let tH : u64 = bigint_mul(iar, CMAG[k], L1)
                bigint_drop(L)   bigint_drop(L1)
                if cs > 0i64 {
                    let a2 : u64 = bigint_add(iar, pL, tL)   bigint_drop(pL)   pL = a2
                    let b2 : u64 = bigint_add(iar, pH, tH)   bigint_drop(pH)   pH = b2
                } else {
                    let a2 : u64 = bigint_add(iar, nL, tL)   bigint_drop(nL)   nL = a2
                    let b2 : u64 = bigint_add(iar, nH, tH)   bigint_drop(nH)   nH = b2
                }
                bigint_drop(tL)   bigint_drop(tH)
            }
            k = k + 1u64
        }
        if bigint_cmp(pL, nH) > 0i32 { result = 1i32   done = 1u8 }
        if done == 0u8 { if bigint_cmp(pH, nL) < 0i32 { result = 0i32 - 1i32   done = 1u8 } }
        bigint_drop_arena(iar)   arena_drop(iar)
        if done == 0u8 { p = p * 2u64   if p > 200000u64 { done = 1u8 } }
    }
    bigint_drop_arena(ar)   arena_drop(ar)
    if result == 0i32 { return ui_sqrt_sum_sign_big(mag_ptr, sgn_ptr, b_ptr, n) }   /* capped -> exact fallback */
    return result
}
