extern @abi(c-msvc-x64) fn GetCurrentDirectoryA(n: u32, buf: u64) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn SetCurrentDirectoryA(path: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn GetEnvironmentVariableA(name: u64, buf: u64, n: u32) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn FindFirstFileA(pat: u64, data: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn FindNextFileA(h: u64, data: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn FindClose(h: u64) -> i32 from "kernel32"

const SH_INVALID : u64 = 18446744073709551615u64

var SH_PLAIN : u32 = 0u32          /* plain-mode flag (driver reads it) */
var SH_TMP   : [u8; 1024]          /* scratch: cwd / env value / arg copy */
var SH_FIND  : [u8; 320]           /* WIN32_FIND_DATAA (cFileName @ +44) */
var SH_STG   : [u8; 262144]        /* staging for proc stdout copy */

fn shell_plain() -> u32 @export { return SH_PLAIN }
fn shell_set_plain(v: u32) -> i32 @export { SH_PLAIN = v   return 0i32 }

/* copy token i (NUL-terminated) into SH_TMP; returns its length */
fn sh_tok_to_tmp(i: u64) -> u64 {
    let n : u64 = vb_tok_len(i)
    let p : *u8 = vb_tok_ptr(i) as *u8
    let mut k : u64 = 0u64
    while k < n {
        if k < 1023u64 { SH_TMP[k] = p[k] }
        k = k + 1u64
    }
    let mut m : u64 = n
    if m > 1023u64 { m = 1023u64 }
    SH_TMP[m] = 0u8
    return m
}

fn sh_cd() -> i32 {
    if vb_ntok() < 2u64 { vb_emit("cd: missing directory\n" as u64, 22u64)   return 0i32 }
    sh_tok_to_tmp(1u64)
    if SetCurrentDirectoryA((&SH_TMP) as u64) == 0i32 {
        vb_emit("cd: no such directory: " as u64, 23u64)
        vb_emit((&SH_TMP) as u64, vb_tok_len(1u64))
        vb_emit("\n" as u64, 1u64)
    }
    return 0i32
}

fn sh_pwd() -> i32 {
    let n : u32 = GetCurrentDirectoryA(1024u32, (&SH_TMP) as u64)
    vb_emit((&SH_TMP) as u64, n as u64)
    vb_emit("\n" as u64, 1u64)
    return 0i32
}

fn sh_env() -> i32 {
    if vb_ntok() < 2u64 { vb_emit("env: missing NAME\n" as u64, 18u64)   return 0i32 }
    sh_tok_to_tmp(1u64)
    /* read into SH_STG (env value may be long, e.g. PATH) */
    let n : u32 = GetEnvironmentVariableA((&SH_TMP) as u64, (&SH_STG) as u64, 262144u32)
    if n == 0u32 {
        vb_emit("env: not set: " as u64, 14u64)
        vb_emit((&SH_TMP) as u64, vb_tok_len(1u64))
        vb_emit("\n" as u64, 1u64)
    } else {
        vb_emit((&SH_STG) as u64, n as u64)
        vb_emit("\n" as u64, 1u64)
    }
    return 0i32
}

/* ls [pattern]: default "*"; emit each cFileName + newline */
fn sh_ls() -> i32 {
    if vb_ntok() >= 2u64 { sh_tok_to_tmp(1u64) }
    else { SH_TMP[0u64] = 42u8   SH_TMP[1u64] = 0u8 }        /* "*" */
    let h : u64 = FindFirstFileA((&SH_TMP) as u64, (&SH_FIND) as u64)
    if h == SH_INVALID { vb_emit("ls: no matches\n" as u64, 15u64)   return 0i32 }
    let mut more : u32 = 1u32
    while more == 1u32 {
        /* cFileName at +44, NUL-terminated */
        let base : u64 = ((&SH_FIND) as u64) + 44u64
        let bp : *u8 = base as *u8
        let mut k : u64 = 0u64
        let mut scan : u32 = 1u32
        while scan == 1u32 {
            if k >= 260u64 { scan = 0u32 }
            else {
                if bp[k] == 0u8 { scan = 0u32 }
                else { k = k + 1u64 }
            }
        }
        vb_emit(base, k)
        vb_emit("\n" as u64, 1u64)
        if FindNextFileA(h, (&SH_FIND) as u64) == 0i32 { more = 0u32 }
    }
    FindClose(h)
    return 0i32
}

/* gate: native cockpit over the cone system.  `gate` alone shows the VERIFIED.tsv tallies;
 * `gate <kat>` shows one KAT's ledger status -- all read natively (no grep/awk). */
fn sh_gate() -> i32 {
    if gate_ledger_load("STDLIB/build/VERIFIED.tsv" as u64) != 0i32 {
        vb_emit("gate: no ledger at STDLIB/build/VERIFIED.tsv (run verify_cone.sh first)\n" as u64, 66u64)
        return 0i32
    }
    if vb_ntok() >= 2u64 {
        let klen : u64 = vb_tok_len(1u64)
        let st : u32 = gate_status(vb_tok_ptr(1u64), klen)
        vb_emit("gate " as u64, 5u64)
        vb_emit(vb_tok_ptr(1u64), klen)
        vb_emit(": " as u64, 2u64)
        if st == 1u32 { vb_emit("PASS\n" as u64, 5u64) }
        else { if st == 2u32 { vb_emit("WRONG\n" as u64, 6u64) }
        else { if st == 3u32 { vb_emit("PASS-family\n" as u64, 12u64) }
        else { vb_emit("absent (not yet verified)\n" as u64, 26u64) } } }
    } else {
        vb_emit("gate ledger: PASS=" as u64, 18u64)
        vb_emit_num(gate_count_pass())
        vb_emit(" WRONG=" as u64, 7u64)
        vb_emit_num(gate_count_wrong())
        vb_emit("\n" as u64, 1u64)
    }
    return 0i32
}

/* seal: drive the existing province router (seal_route.sh) -- reuse, don't reimplement.  The
 * raw line's tail (after "seal ") names the changed files; seal_route decides organ vs compiler. */
fn sh_seal() -> i32 {
    /* build "bash STDLIB/scripts/seal_route.sh <tail>" from the raw line after the verb token */
    let tail_off : u64 = 5u64                    /* len("seal ") when args present */
    let mut o : u64 = 0u64
    let pfx : *u8 = "bash STDLIB/scripts/seal_route.sh " as *u8
    while o < 34u64 { SH_TMP[o] = pfx[o]   o = o + 1u64 }
    let ll : u64 = vb_line_len()
    let lp : *u8 = vb_line_ptr() as *u8
    if ll > tail_off {
        let mut i : u64 = tail_off
        while i < ll {
            if o < 1020u64 { SH_TMP[o] = lp[i]   o = o + 1u64 }
            i = i + 1u64
        }
    }
    SH_TMP[o] = 0u8
    let rc : i32 = proc_run((&SH_TMP) as u64, 0u64, 120000u32)
    if rc < 0i32 { vb_emit("seal: cannot spawn seal_route.sh\n" as u64, 32u64)   return 0i32 }
    let mut olen : u64 = proc_out_len()
    if olen > 262144u64 { olen = 262144u64 }
    proc_out_copy((&SH_STG) as u64, 0u64, olen)
    vb_emit((&SH_STG) as u64, olen)
    return 0i32
}

/* tree: build a one-level tree of the target dir (arg or cwd) and emit its lossless plain
 * projection to the transcript.  In a console the driver would blit the VT frame with arrow-nav;
 * in plain mode the same model renders as text (Collapse Law).  A directory entry becomes a
 * parent node; files are leaves. */
fn sh_tree() -> i32 {
    /* pattern into SH_TMP: "<arg>\*" or "*" */
    if vb_ntok() >= 2u64 {
        let al : u64 = vb_tok_len(1u64)
        let ap : *u8 = vb_tok_ptr(1u64) as *u8
        let mut i : u64 = 0u64
        while i < al { if i < 1000u64 { SH_TMP[i] = ap[i] }   i = i + 1u64 }
        SH_TMP[al] = 92u8            /* \ */
        SH_TMP[al + 1u64] = 42u8     /* * */
        SH_TMP[al + 2u64] = 0u8
    } else {
        SH_TMP[0u64] = 42u8   SH_TMP[1u64] = 0u8    /* "*" */
    }
    tree_reset()
    let root : i64 = tree_add(0i64 - 1i64, "." as u64, 1u64)
    let h : u64 = FindFirstFileA((&SH_TMP) as u64, (&SH_FIND) as u64)
    if h == SH_INVALID { vb_emit("tree: no entries\n" as u64, 16u64)   return 0i32 }
    let mut more : u32 = 1u32
    while more == 1u32 {
        let base : u64 = ((&SH_FIND) as u64) + 44u64
        let bp : *u8 = base as *u8
        /* skip "." and ".." */
        let mut skip : u32 = 0u32
        if bp[0u64] == 46u8 { if bp[1u64] == 0u8 { skip = 1u32 }   if bp[1u64] == 46u8 { if bp[2u64] == 0u8 { skip = 1u32 } } }
        if skip == 0u32 {
            let mut k : u64 = 0u64
            let mut scan : u32 = 1u32
            while scan == 1u32 {
                if k >= 260u64 { scan = 0u32 }
                else { if bp[k] == 0u8 { scan = 0u32 } else { k = k + 1u64 } }
            }
            tree_add(root, base, k)
        }
        if FindNextFileA(h, (&SH_FIND) as u64) == 0i32 { more = 0u32 }
    }
    FindClose(h)
    tree_rebuild_visible()
    let n : u64 = tree_render_plain((&SH_STG) as u64)
    vb_emit((&SH_STG) as u64, n)
    return 0i32
}

/* external: run the raw line captured (pipe mode), copy child stdout to transcript + "exit N". */
fn sh_extern() -> i32 {
    let rc : i32 = proc_run(vb_line_ptr(), 0u64, 60000u32)
    if rc < 0i32 {
        vb_emit("stoma: cannot spawn: " as u64, 21u64)
        vb_emit(vb_line_ptr(), vb_line_len())
        vb_emit("\n" as u64, 1u64)
        return 0i32
    }
    /* copy captured stdout (bounded) into the transcript */
    let mut olen : u64 = proc_out_len()
    if olen > 262144u64 { olen = 262144u64 }
    proc_out_copy((&SH_STG) as u64, 0u64, olen)
    vb_emit((&SH_STG) as u64, olen)
    if rc == 1i32 { vb_emit("\n[stoma] timed out\n" as u64, 19u64) }
    vb_emit("[exit " as u64, 6u64)
    vb_emit_num(proc_code() as u64)
    vb_emit("]\n" as u64, 2u64)
    return 0i32
}

/* Parse + dispatch one committed line.  Journals the input (kind 1) and the transcript
 * (kind 2), then returns a control signal (0 continue, 2 exit). */
fn shell_feed_line(line: u64, llen: u64) -> u32 @export {
    /* journal the raw input line first (verbatim, before any dispatch) */
    journal_append(1u32, line, llen)

    let k : u32 = vb_parse(line, llen)      /* resets the transcript */
    let mut sig : u32 = 0u32

    if k == vb_k_empty() { sig = 0u32 }
    else { if k == vb_k_err() { sig = 0u32 }         /* transcript already holds the caret error */
    else { if k == vb_k_cd() { sh_cd() }
    else { if k == vb_k_pwd() { sh_pwd() }
    else { if k == vb_k_ls() { sh_ls() }
    else { if k == vb_k_env() { sh_env() }
    else { if k == vb_k_help() { vb_do_help() }
    else { if k == vb_k_plain() { SH_PLAIN = 1u32   vb_emit("[plain mode]\n" as u64, 13u64) }
    else { if k == vb_k_exit() { sig = 2u32 }
    else { if k == vb_k_gate() { sh_gate() }
    else { if k == vb_k_seal() { sh_seal() }
    else { if k == vb_k_tree() { sh_tree() }
    else { sh_extern() }                              /* EXTERN + (M4) build fallthrough */
    } } } } } } } } } } }

    /* journal the transcript output (verbatim) */
    journal_append(2u32, vb_out_ptr(), vb_out_len())
    return sig
}
