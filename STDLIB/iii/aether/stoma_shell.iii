/* STDLIB/iii/aether/stoma_shell.iii -- STOMA organ: the shell integration (M4 of the plan).
 *
 * Ties the walking skeleton together with NO main (so KATs drive it headlessly and stoma.iii
 * stays a thin entry): parse a line (stoma_verb), dispatch built-ins against real OS state
 * (cwd/env/dir via kernel32), route external commands to the captured-spawn broker
 * (stoma_proc), and journal every step (stoma_journal).  All human-visible bytes accumulate in
 * the verb transcript (stoma_verb VB_OUT); the driver forwards that ONE buffer to console +
 * journal -- so the interactive face and the plain log are byte-identical (Collapse Law).
 *
 * shell_feed_line returns a control signal: 0 continue, 2 exit requested.
 *
 * Hexad: kind_witness.  Ring: R-1.  K: 0.95.
 */
module stoma_shell

extern @abi(c-msvc-x64) fn vb_parse(line: u64, llen: u64) -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_ntok() -> u64 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_tok_ptr(i: u64) -> u64 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_tok_len(i: u64) -> u64 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_line_ptr() -> u64 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_line_len() -> u64 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_emit(p: u64, n: u64) -> i32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_emit_num(v: u64) -> i32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_out_ptr() -> u64 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_out_len() -> u64 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_out_byte(i: u64) -> u8 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_do_help() -> i32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_empty() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_cd() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_pwd() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_ls() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_env() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_help() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_plain() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_exit() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_extern() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_err() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_gate() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_seal() -> u32 from "stoma_verb.iii"
extern @abi(c-msvc-x64) fn vb_k_tree() -> u32 from "stoma_verb.iii"

extern @abi(c-msvc-x64) fn tree_reset() -> i32 from "stoma_tree.iii"
extern @abi(c-msvc-x64) fn tree_add(parent: i64, name: u64, nlen: u64) -> i64 from "stoma_tree.iii"
extern @abi(c-msvc-x64) fn tree_rebuild_visible() -> u64 from "stoma_tree.iii"
extern @abi(c-msvc-x64) fn tree_render_plain(dst: u64) -> u64 from "stoma_tree.iii"

extern @abi(c-msvc-x64) fn gate_ledger_load(path: u64) -> i32 from "stoma_gate.iii"
extern @abi(c-msvc-x64) fn gate_status(kat: u64, klen: u64) -> u32 from "stoma_gate.iii"
extern @abi(c-msvc-x64) fn gate_count_pass() -> u64 from "stoma_gate.iii"
extern @abi(c-msvc-x64) fn gate_count_wrong() -> u64 from "stoma_gate.iii"
extern @abi(c-msvc-x64) fn gate_run(cmd: u64, want: u32, cap_ms: u32) -> u32 from "stoma_gate.iii"
extern @abi(c-msvc-x64) fn gate_last_code() -> u32 from "stoma_gate.iii"
extern @abi(c-msvc-x64) fn gate_bash_would_see() -> u32 from "stoma_gate.iii"
extern @abi(c-msvc-x64) fn gate_full_vs_bash_diverges() -> u32 from "stoma_gate.iii"

extern @abi(c-msvc-x64) fn proc_run(cmd: u64, cwd: u64, cap_ms: u32) -> i32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_code() -> u32 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_out_len() -> u64 from "stoma_proc.iii"
extern @abi(c-msvc-x64) fn proc_out_copy(dst: u64, off: u64, n: u64) -> u64 from "stoma_proc.iii"

