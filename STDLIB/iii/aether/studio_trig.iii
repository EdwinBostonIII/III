    ST_SN[152u64]=(0i64-569i64)     ST_SN[153u64]=(0i64-590i64)     ST_SN[154u64]=(0i64-610i64)     ST_SN[155u64]=(0i64-630i64)     ST_SN[156u64]=(0i64-650i64)     ST_SN[157u64]=(0i64-669i64)     ST_SN[158u64]=(0i64-688i64)     ST_SN[159u64]=(0i64-706i64) 
