/* STDLIB/iii/aether/studio_trig.iii -- III STUDIO's shared fixed-point trig: the 256-entry integer sine table
 * (x1024, one full turn = 256 steps), hand-computed -- an III-owned asset, no libm anywhere.  st_init() fills it
 * once (idempotent); st_sn/st_cs give sin/cos for any angle in table steps. */
module studio_trig

var ST_SN : [i64; 256]
var ST_RDY : u8 = 0u8

fn st_init() -> i32 @export {
    if ST_RDY == 1u8 { return 0i32 }
    ST_SN[0u64]=0i64     ST_SN[1u64]=25i64     ST_SN[2u64]=50i64     ST_SN[3u64]=75i64     ST_SN[4u64]=100i64     ST_SN[5u64]=125i64     ST_SN[6u64]=150i64     ST_SN[7u64]=175i64 
