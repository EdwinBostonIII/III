    ST_RDY = 1u8
    return 0i32
}
fn st_sn(a: i64) -> i64 @export { return ST_SN[(a & 255i64) as u64] }
fn st_cs(a: i64) -> i64 @export { return ST_SN[((a + 64i64) & 255i64) as u64] }
