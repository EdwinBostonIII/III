    ST_SN[192u64]=(0i64-1024i64)     ST_SN[193u64]=(0i64-1024i64)     ST_SN[194u64]=(0i64-1023i64)     ST_SN[195u64]=(0i64-1021i64)     ST_SN[196u64]=(0i64-1019i64)     ST_SN[197u64]=(0i64-1016i64)     ST_SN[198u64]=(0i64-1013i64)     ST_SN[199u64]=(0i64-1009i64) 
    ST_SN[200u64]=(0i64-1004i64)     ST_SN[201u64]=(0i64-999i64)     ST_SN[202u64]=(0i64-993i64)     ST_SN[203u64]=(0i64-987i64)     ST_SN[204u64]=(0i64-980i64)     ST_SN[205u64]=(0i64-972i64)     ST_SN[206u64]=(0i64-964i64)     ST_SN[207u64]=(0i64-955i64) 
    ST_SN[208u64]=(0i64-946i64)     ST_SN[209u64]=(0i64-936i64)     ST_SN[210u64]=(0i64-926i64)     ST_SN[211u64]=(0i64-915i64)     ST_SN[212u64]=(0i64-903i64)     ST_SN[213u64]=(0i64-891i64)     ST_SN[214u64]=(0i64-878i64)     ST_SN[215u64]=(0i64-865i64) 
    ST_SN[216u64]=(0i64-851i64)     ST_SN[217u64]=(0i64-837i64)     ST_SN[218u64]=(0i64-822i64)     ST_SN[219u64]=(0i64-807i64)     ST_SN[220u64]=(0i64-792i64)     ST_SN[221u64]=(0i64-775i64)     ST_SN[222u64]=(0i64-759i64)     ST_SN[223u64]=(0i64-742i64) 
