extern @abi(c-msvc-x64) fn tc_inr(v: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_case(c: u32, f: u32, g: u32, s: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_w(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_sup(a: u32, f: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_wrec(p: u32, s: u32, w: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_infer(t: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_check(t: u32, ty: u32) -> u8 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_serialize(t: u32, out: *u8, cap: u64) -> u64 from "typecheck.iii"
/* QTT: multiplicity-carrying binders + the usage judgment (a layer over infer). */
extern @abi(c-msvc-x64) fn tc_pi_q(a: u32, b: u32, code: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_lam_q(a: u32, b: u32, code: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_qtt_ok(t: u32) -> u8 from "typecheck.iii"
/* BV64: the native 64-bit machine-int model (iota-reduces mod 2^64 on literals). */
extern @abi(c-msvc-x64) fn tc_bv() -> u32 from "typecheck.iii"
