/* STDLIB/iii/aether/typecheck_cli.iii -- iii-typecheck: THE CIC KERNEL AS A STANDING TOOL.
 *
 *   iii-typecheck <term-file>                    INFER the term's type; print it, or refuse
 *   iii-typecheck --check <term-file> <type-file>  CHECK term : type (bidirectional)
 *   iii-typecheck --qtt <term-file>              judge QTT USAGE: every binder within its declared
 *                                                multiplicity (erased ^0 / linear ^1 / unrestricted ^w).
 *                                                A layer over typing: ill-typed terms are refused first.
 *   iii-typecheck --lek "<c1..c6>" "<b1..b6>"    SOVEREIGNTY AS TYPES: register the cost and budget
 *                                                6-vectors in-process and let the kernel decide
 *                                                cost <= budget (product order) BY IOTA -- over-budget
 *                                                is a TYPE error (the LeK proof does not check).
 *   iii-typecheck --reach <hexad>                the kernel PROVES (or refuses) hexad reachability by
 *                                                reduction through its own oracle -- never baked.
 *
 * The kernel (numera/typecheck: lambda-Pi + predicative universes U0:U1:..., Sigma, Bool, Id/J,
 * Nat/iter/natrec, Unit, Empty, Sum, W-types, BV64, QTT; conversion by the directed CCL oracle) is
 * TRUSTED and UNCHANGED: this CLI is only an S-expression front end that BUILDS terms through the
 * kernel's own constructors and prints results by decoding the kernel's own serializer.  The de
 * Bruijn criterion survives: a parse error is THIS tool's verdict; only the kernel says WELL-TYPED.
 *
 * GRAMMAR (S-expressions; binders are de Bruijn -- (var 0) is the innermost):
 *   (sort N) (var N) (pi A B) (lam A b) (app f a) (sig A B) (pair a b) (fst p) (snd p) (ann t T)
 *   bool true false (if s t e) (id T a b) (refl a) (j M base proof) (transp P proof base)
 *   nat zero (succ n) (iter z s n) (natrec P z s n) unit tt empty (absurd C e)
 *   (sum A B) (inl v) (inr v) (case C f g s) (w A B) (sup a f) (wrec P s w)
 *   QTT binders: (lam0 A b) erased | (lam1 A b) linear | (lamw A b) unrestricted; same pi0/pi1/piw.
 *   BV64 (the native 64-bit machine-int type; ops iota-reduce mod 2^64 on literals):
 *   bv (bvlit N) (bvadd a b) (bvsub a b) (bvmul a b) (bvand a b) (bvor a b) (bvxor a b)
 *   (bvshl a b) (bvlshr a b) (bvudiv a b) (bvaddovf a b):Bool (bvmulovf a b):Bool
 * inl/inr/sup are CHECKABLE, not inferable (bidirectional): infer refuses them bare; annotate
 * ((ann (inl true) (sum bool nat))) or use --check.  bvudiv by literal 0 is STUCK by design: the
 * kernel will not equate it with anything.  Printed types omit QTT quantities (the kernel carries
 * them internally; they are part of the type's identity for conversion).  LEK/REACH bind registry
 * slots built IN-PROCESS from the --lek vectors / the --reach hexad id (not S-expression grammar).
 *
 * exit: 0 = WELL-TYPED / CHECKED / QTT-RESPECTED | 4 = the kernel REFUSED (ill-typed / does not
 *       check / usage violates a declared multiplicity) | 3 = parse error (position printed)
 *       | 2 = file error | 1 = usage | 5 = internal (serializer overflow -- never a silent claim).
 *
 * Hexad: kind_cognition.  Ring: R0.  NIH: composes numera/typecheck (+ its ccl/combinator oracles
 * from the archive); the trusted base is unmoved.
 */
module typecheck_cli

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn CreateFileA(name: u64, access: u32, share: u32, sec: u64, disp: u32, flags: u32, tmpl: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn ReadFile(h: u64, buf: u64, n: u32, rd: u64, ov: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> i32 from "kernel32"

extern @abi(c-msvc-x64) fn tc_reset() -> u64 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_var(k: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_sort(l: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_pi(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_lam(a: u32, b: u32) -> u32 from "typecheck.iii"
