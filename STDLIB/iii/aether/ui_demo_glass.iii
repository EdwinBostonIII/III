/* STDLIB/iii/aether/ui_demo_glass.iii -- III-GLASS first light.  A standalone III program that renders a scene
 * REPRESENTING III with the proven NIH rasterizer and saves it as a BMP you can open: the III mark (three bars),
 * the verification membrane (concentric proof-gates around a white core), a KAT grid (green cells with one red
 * tooth = the conscience line), the event field (a ripple row), and weave accents.  No imported libraries; the
 * pixels are III's own.  This is the still-frame milestone the real-time window layer turns into 60fps. */
module ui_demo_glass

extern @abi(c-msvc-x64) fn ui_clear(buf: u64, w: u32, h: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_fill_rect(buf: u64, w: u32, h: u32, x: u32, y: u32, rw: u32, rh: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_rect(buf: u64, w: u32, h: u32, x: u32, y: u32, rw: u32, rh: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_line(buf: u64, w: u32, h: u32, x0: i32, y0: i32, x1: i32, y1: i32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_save_bmp(fb: u64, w: u32, h: u32, path: u64) -> i32 from "ui_present.iii"

var FB   : [u32; 153600]   /* 480 x 320 */
var PATH : [u8; 10] = [103u8,108u8,97u8,115u8,115u8,46u8,98u8,109u8,112u8,0u8]   /* "glass.bmp\0" */

fn rgb(r: u32, g: u32, b: u32) -> u32 { return (255u32 << 24u32) | (r << 16u32) | (g << 8u32) | b }

fn main() -> u64 {
    let b : u64 = &FB as u64
    let w : u32 = 480u32
    let h : u32 = 320u32
    ui_clear(b, w, h, rgb(10u32, 10u32, 18u32))                     /* deep substrate */
    ui_fill_rect(b, w, h, 0u32, 0u32, w, 40u32, rgb(20u32, 20u32, 42u32))  /* title band */

    let cy : u32 = rgb(0u32, 229u32, 255u32)                        /* III cyan */
    ui_fill_rect(b, w, h, 20u32, 8u32, 9u32, 24u32, cy)             /* the three I's */
    ui_fill_rect(b, w, h, 40u32, 8u32, 9u32, 24u32, cy)
    ui_fill_rect(b, w, h, 60u32, 8u32, 9u32, 24u32, cy)

    ui_rect(b, w, h, 240u32, 110u32, 120u32, 120u32, cy)            /* verification membrane: */
    ui_rect(b, w, h, 255u32, 125u32, 90u32, 90u32, rgb(0u32, 136u32, 170u32))   /* nested proof-gates */
    ui_rect(b, w, h, 270u32, 140u32, 60u32, 60u32, rgb(0u32, 80u32, 102u32))
    ui_rect(b, w, h, 285u32, 155u32, 30u32, 30u32, rgb(255u32, 255u32, 255u32)) /* proven core */

    let grn : u32 = rgb(34u32, 204u32, 85u32)                       /* KAT grid: green pass... */
    let red : u32 = rgb(204u32, 51u32, 68u32)                       /* ...one red tooth (conscience) */
    let mut gy : u32 = 0u32
    while gy < 4u32 {
        let mut gx : u32 = 0u32
        while gx < 8u32 {
            let mut c : u32 = grn
            if gx == 5u32 { if gy == 1u32 { c = red } }
            ui_fill_rect(b, w, h, 20u32 + (gx * 22u32), 250u32 + (gy * 16u32), 18u32, 12u32, c)
            gx = gx + 1u32
        }
        gy = gy + 1u32
    }

    let dim : u32 = rgb(0u32, 136u32, 170u32)                       /* event field: ripple row */
    let mut dx : u32 = 0u32
    while dx < 24u32 {
        ui_fill_rect(b, w, h, 240u32 + (dx * 9u32), 250u32, 3u32, 3u32, dim)
        dx = dx + 1u32
    }

    let wv : u32 = rgb(0u32, 80u32, 102u32)                         /* weave accents */
    ui_line(b, w, h, 90i32, 20i32, 240i32, 110i32, wv)
    ui_line(b, w, h, 75i32, 250i32, 240i32, 170i32, wv)

    ui_save_bmp(b, w, h, &PATH as u64)
    return 0u64
}
