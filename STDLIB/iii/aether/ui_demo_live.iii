/* STDLIB/iii/aether/ui_demo_live.iii -- III-GLASS, LIVE.  A real-time window driven entirely by III: the proven
 * rasterizer paints into a framebuffer, ui_win blits it at ~60fps, and the loop folds mouse/keyboard input back
 * into the scene.  The proven-core pulses, the event-field scrolls, and the cursor paints on click -- the first
 * interactive III organ.  Close the window or press ESC to quit.  Zero imported libraries. */
module ui_demo_live

extern @abi(c-msvc-x64) fn ui_clear(buf: u64, w: u32, h: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_fill_rect(buf: u64, w: u32, h: u32, x: u32, y: u32, rw: u32, rh: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_rect(buf: u64, w: u32, h: u32, x: u32, y: u32, rw: u32, rh: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_win_open(title: u64, w: u32, h: u32) -> u64 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_win_present(buf: u64, w: u32, h: u32) -> i32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_win_pump() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_mx() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_my() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_mdown() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_sleep(ms: u32) -> i32 from "ui_win.iii"

var FB    : [u32; 153600]   /* 480 x 320 */
var TITLE : [u8; 15] = [73u8,73u8,73u8,45u8,71u8,76u8,65u8,83u8,83u8,32u8,76u8,73u8,86u8,69u8,0u8]   /* "III-GLASS LIVE\0" */

fn rgb(r: u32, g: u32, b: u32) -> u32 { return (255u32 << 24u32) | (r << 16u32) | (g << 8u32) | b }

fn render(b: u64, w: u32, h: u32, frame: u32) -> i32 {
    ui_clear(b, w, h, rgb(10u32, 10u32, 18u32))
    ui_fill_rect(b, w, h, 0u32, 0u32, w, 40u32, rgb(20u32, 20u32, 42u32))
    let cy : u32 = rgb(0u32, 229u32, 255u32)
    ui_fill_rect(b, w, h, 20u32, 8u32, 9u32, 24u32, cy)
    ui_fill_rect(b, w, h, 40u32, 8u32, 9u32, 24u32, cy)
    ui_fill_rect(b, w, h, 60u32, 8u32, 9u32, 24u32, cy)
    ui_rect(b, w, h, 240u32, 110u32, 120u32, 120u32, cy)
    ui_rect(b, w, h, 255u32, 125u32, 90u32, 90u32, rgb(0u32, 136u32, 170u32))
    ui_rect(b, w, h, 270u32, 140u32, 60u32, 60u32, rgb(0u32, 80u32, 102u32))
    /* the proven core pulses (triangle wave on the frame counter) -- proof the loop is live. */
    let ph : u32 = (frame / 4u32) & 31u32
    let mut pp : u32 = ph
    if ph > 15u32 { pp = 31u32 - ph }
    ui_fill_rect(b, w, h, 290u32 - pp, 160u32 - pp, 20u32 + (pp + pp), 20u32 + (pp + pp), rgb(255u32, 255u32, 255u32))
    /* KAT grid (green pass, one red tooth). */
    let grn : u32 = rgb(34u32, 204u32, 85u32)
    let red : u32 = rgb(204u32, 51u32, 68u32)
    let mut gy : u32 = 0u32
    while gy < 4u32 {
        let mut gx : u32 = 0u32
        while gx < 8u32 {
            let mut c : u32 = grn
            if gx == 5u32 { if gy == 1u32 { c = red } }
            ui_fill_rect(b, w, h, 20u32 + (gx * 22u32), 250u32 + (gy * 16u32), 18u32, 12u32, c)
            gx = gx + 1u32
        }
        gy = gy + 1u32
    }
    /* event field scrolls. */
    let dim : u32 = rgb(0u32, 136u32, 170u32)
    let off : u32 = (frame / 2u32) & 8u32
    let mut dx : u32 = 0u32
    while dx < 22u32 {
        ui_fill_rect(b, w, h, (240u32 + off) + (dx * 9u32), 250u32, 3u32, 3u32, dim)
        dx = dx + 1u32
    }
    /* the cursor -- a crosshair that paints orange while the button is held (interaction!). */
    let mx : u32 = ui_mx()
    let my : u32 = ui_my()
    if mx < w { if my < h {
        if ui_mdown() == 1u32 { ui_fill_rect(b, w, h, mx, my, 8u32, 8u32, rgb(255u32, 90u32, 0u32)) }
        let cc : u32 = rgb(255u32, 255u32, 255u32)
        ui_fill_rect(b, w, h, mx, my, 7u32, 2u32, cc)
        ui_fill_rect(b, w, h, mx, my, 2u32, 7u32, cc)
    } }
    return 0i32
}

fn main() -> u64 {
    ui_win_open(&TITLE as u64, 480u32, 320u32)
    let mut frame : u32 = 0u32
    while ui_win_pump() == 0u32 {
        render(&FB as u64, 480u32, 320u32, frame)
        ui_win_present(&FB as u64, 480u32, 320u32)
        ui_sleep(16u32)
        frame = frame + 1u32
    }
    return 0u64
}
