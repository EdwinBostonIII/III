/* STDLIB/iii/aether/ui_demo_vfont.iii -- proves exact-vector text: the SAME outlines filled by the exact-integer
 * even-odd engine at 14px, 22px, 36px, 64px, and a 180px "ZOOM" -- crisp at every scale, no bitmap blocking. */
module ui_demo_vfont

extern @abi(c-msvc-x64) fn ui_clear(buf: u64, w: u32, h: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_vtext(buf: u64, w: u32, h: u32, x: i64, y: i64, str: u64, len: u32, size: i64, color: u32, n: i64) -> i64 from "ui_vfont.iii"
extern @abi(c-msvc-x64) fn ui_save_bmp(fb: u64, w: u32, h: u32, path: u64) -> i32 from "ui_present.iii"

var FB   : [u32; 384000]   /* 800 x 480 */
var PATH : [u8; 10] = [118u8,102u8,111u8,110u8,116u8,46u8,98u8,109u8,112u8,0u8]   /* "vfont.bmp\0" */

fn rgb(r: u32, g: u32, b: u32) -> u32 { return (255u32 << 24u32) | (r << 16u32) | (g << 8u32) | b }

fn main() -> u64 {
    let b : u64 = &FB as u64
    ui_clear(b, 800u32, 480u32, rgb(12u32, 14u32, 20u32))
    let cy : u32 = rgb(0u32, 229u32, 255u32)
    ui_vtext(b, 800u32, 480u32, 20i64, 16i64,  "III-GLASS exact-vector 0123" as u64, 27u32, 14i64, cy, 4i64)
    ui_vtext(b, 800u32, 480u32, 20i64, 42i64,  "III-GLASS exact-vector 0123" as u64, 27u32, 22i64, cy, 4i64)
    ui_vtext(b, 800u32, 480u32, 20i64, 82i64,  "III-GLASS exact-vector 0123" as u64, 27u32, 36i64, cy, 4i64)
    ui_vtext(b, 800u32, 480u32, 20i64, 150i64, "III-GLASS exact-vector 0123" as u64, 27u32, 64i64, rgb(255u32,200u32,80u32), 4i64)
    ui_vtext(b, 800u32, 480u32, 20i64, 270i64, "ZOOM" as u64, 4u32, 180i64, rgb(255u32, 150u32, 40u32), 4i64)
    ui_save_bmp(b, 800u32, 480u32, &PATH as u64)
    return 0u64
}
