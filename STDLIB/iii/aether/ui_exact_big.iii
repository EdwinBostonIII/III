/* STDLIB/iii/aether/ui_exact_big.iii -- BIGINT-backed bi-quadratic COVERAGE for the FULL-RESOLUTION symmetric 2D
 * path.  ui_exact's ui_arc_cover2d is exact within i64; at screen coords the nested squaring in the degree-4
 * sign (an^2 ~ 1e28, pp^2 ~ 1e62) exceeds i64.  Here the same proven REDUCTION (degree-4 -> two single-D signs)
 * runs with arbitrary-precision products, so the coverage is exact at ANY glyph coordinate.
 *
 * THE FOLD (III-EXACT-SUBSTRATE-INTEGRATION T3): the signers ui_bsign1 / ui_sign_bi_big moved INTO the one
 * exact-sign kernel (sqrt_sum_sign.iii, Tier 0 -- the low-surd iterated-squaring fast path of the ladder).  The
 * two-live-kernels redundancy is over: this file keeps the bigint COVERAGE engine (bez_area_raw +
 * ui_arc_cover2d_big) and consumes the kernel's signer like every other face. */
module ui_exact_big

extern @abi(c-msvc-x64) fn ui_sign_bi_big(an: i64, bn: i64, dD1: i64, cn: i64, dD2: i64) -> i32 from "sqrt_sum_sign.iii"

/* RAW area-at-crossing numerators (pp + qq*sqrt dD)/(6 c^4) -- NO gcd reduction, so both crossings of one curve share
 * the denominator 6 c^4 (c=2 ax2, a=-ax1 are the same; only dD differs).  i64 holds pp ~ 1e15 at screen scale. */
var PPR : i64   var QQR : i64
fn bez_area_raw(ax0: i64, ax1: i64, ax2: i64, ay0: i64, ay1: i64, ay2: i64, a: i64, c: i64, dD: i64) -> i32 {
    let g1 : i64 = 6i64 * (ay0 * ax1)
    let g2 : i64 = 3i64 * ((2i64 * ay0 * ax2) + (ay1 * ax1))
    let g3 : i64 = 2i64 * ((2i64 * ay1 * ax2) + (ay2 * ax1))
    let g4 : i64 = 3i64 * (ay2 * ax2)
    let a2 : i64 = a * a
    let aD : i64 = a * dD
    let c2 : i64 = c * c
    let c3 : i64 = c2 * c
    let p2 : i64 = a2 + dD             let q2 : i64 = 2i64 * a
    let p3 : i64 = (a * a2) + (3i64 * aD)   let q3 : i64 = (3i64 * a2) + dD
    let p4 : i64 = ((a2 * a2) + (6i64 * a2 * dD)) + (dD * dD)   let q4 : i64 = (4i64 * a2 * a) + (4i64 * aD)
    PPR = ((((g1 * c3) * a) + ((g2 * c2) * p2)) + ((g3 * c) * p3)) + (g4 * p4)
    QQR = (((g1 * c3) + ((g2 * c2) * q2)) + ((g3 * c) * q3)) + (g4 * q4)
    return 0i32
}

/* FULL-RESOLUTION symmetric 2D coverage (region below an x-monotone arc), exact at ANY coord via the kernel's
 * bigint signer.  coverage = G(t2) - G(t1) - py = (an + bn sqrt D1 + cn sqrt D2)/(6 c^4), an=pp2-pp1-py*den,
 * bn=-qq1, cn=qq2; the exact alpha = round(sa*coverage) by a PROVEN-SIGN binary search.  The binary search also
 * CLAMPS naturally: coverage<0 (arc below) -> 0, coverage>1 (arc above the row) -> sa, fractional -> exact 8-bit. */
fn ui_arc_cover2d_big(ax0: i64, ax1: i64, ax2: i64, ay0: i64, ay1: i64, ay2: i64, px: i64, py: i64, sa: i64) -> i64 @export {
    if ax2 == 0i64 { return 0i64 - 1i64 }
    let a : i64 = 0i64 - ax1
    let c : i64 = 2i64 * ax2
    let d1 : i64 = (ax1 * ax1) - (4i64 * ax2 * (ax0 - px))
    let d2 : i64 = (ax1 * ax1) - (4i64 * ax2 * (ax0 - (px + 1i64)))
    if d1 < 0i64 { return 0i64 - 1i64 }
    if d2 < 0i64 { return 0i64 - 1i64 }
    bez_area_raw(ax0, ax1, ax2, ay0, ay1, ay2, a, c, d1)
    let pp1 : i64 = PPR   let qq1 : i64 = QQR
    bez_area_raw(ax0, ax1, ax2, ay0, ay1, ay2, a, c, d2)
    let pp2 : i64 = PPR   let qq2 : i64 = QQR
    let c2 : i64 = c * c
    let den : i64 = 6i64 * (c2 * c2)
    let an : i64 = (pp2 - pp1) - (py * den)
    let bn : i64 = 0i64 - qq1
    let cn : i64 = qq2
    /* alpha = largest k in [0,sa] with 2*sa*coverage >= 2k-1, i.e. sign(2 sa an - (2k-1) den + 2 sa bn sqrt D1 + 2 sa cn sqrt D2) >= 0 */
    let san : i64 = (2i64 * sa) * an
    let sbn : i64 = (2i64 * sa) * bn
    let scn : i64 = (2i64 * sa) * cn
    let mut lo : i64 = 0i64
    let mut hi : i64 = sa
    while lo < hi {
        let mid : i64 = (lo + hi + 1i64) / 2i64
        let s : i32 = ui_sign_bi_big(san - (((2i64 * mid) - 1i64) * den), sbn, d1, scn, d2)
        if s >= 0i32 { lo = mid } else { hi = mid - 1i64 }
    }
    return lo
}

/* (ui_arc_cover2d_sym_big lives in ui_exact_sym.iii -- keeps this file independent of the i64 geometry +
 * framebuffer; the signers live in sqrt_sum_sign.iii -- ONE kernel for every exact-sign consumer.) */
