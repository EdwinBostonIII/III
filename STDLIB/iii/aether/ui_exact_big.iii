/* STDLIB/iii/aether/ui_exact_big.iii -- BIGINT-backed bi-quadratic sign for the FULL-RESOLUTION symmetric 2D
 * coverage.  ui_exact's ui_arc_cover2d is exact within i64; at screen coords the nested squaring in the degree-4
 * sign (an^2 ~ 1e28, pp^2 ~ 1e62) exceeds i64.  Here the same proven REDUCTION (degree-4 -> two single-D signs)
 * runs with arbitrary-precision bigint products, so the coverage is exact at ANY glyph coordinate -- the word size
 * is no longer the limit.  Attaches to III's bigint (numera/bigint.iii) + arena (memoria/arena.iii). */
module ui_exact_big

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(arena_id: u64) -> i32 from "arena.iii"   /* release the region after bigint_drop_arena (the contract's missing half) */
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mul(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_add(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_sub(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_cmp(a: u64, b: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop_arena(arena_id: u64) -> i32 from "bigint.iii"

fn iabs64(x: i64) -> u64 {
    if x < 0i64 { return (0i64 - x) as u64 }
    return x as u64
}
fn isign64(x: i64) -> i32 {
    if x > 0i64 { return 1i32 }
    if x < 0i64 { return 0i32 - 1i32 }
    return 0i32
}

/* sign(u + v*sqrt D), u,v signed i64, D>=0 -- EXACT via bigint (handles u^2, v^2*D far beyond i64). */
fn ui_bsign1(u: i64, v: i64, dD: i64) -> i32 @export {
    let su : i32 = isign64(u)
    let sv : i32 = isign64(v)
    if v == 0i64 { return su }
    if dD == 0i64 { return su }
    if su == 0i32 { return sv }
    if su == sv { return su }
    /* opposite signs: the larger magnitude wins -- |u|^2  vs  v^2 * D  (both as bigints) */
    let ar : u64 = arena_new(65536u64)
    let bu : u64 = bigint_from_u64(ar, iabs64(u))
    let bu2 : u64 = bigint_mul(ar, bu, bu)
    let bv : u64 = bigint_from_u64(ar, iabs64(v))
    let bv2 : u64 = bigint_mul(ar, bv, bv)
    let bD : u64 = bigint_from_u64(ar, dD as u64)
    let bv2D : u64 = bigint_mul(ar, bv2, bD)
    let c : i32 = bigint_cmp(bu2, bv2D)
    bigint_drop_arena(ar)
    arena_drop(ar)                                            /* free the region slot -> no 64-slot pool leak (render-scale) */
    if c > 0i32 { return su }
    if c < 0i32 { return sv }
    return 0i32
}

/* sign(an + bn*sqrt D1 + cn*sqrt D2) -- the DEGREE-4 (bi-quadratic) sign, in arbitrary-precision bigint.  Same
 * proven reduction as ui_sign_bi (i64): level 1 = sign(an + bn sqrt D1) [ui_bsign1]; if it opposes cn*sqrt D2, the
 * winner is decided by the level-2 single-D sign of u + v sqrt D1, u = an^2+bn^2 D1 - cn^2 D2, v = 2 an bn -- but now
 * u,v are BIGINTS, so the nested squaring (pp^2 ~ 1e62 at screen scale) never overflows. */
fn ui_sign_bi_big(an: i64, bn: i64, dD1: i64, cn: i64, dD2: i64) -> i32 @export {
    let sP : i32 = ui_bsign1(an, bn, dD1)
    if cn == 0i64 { return sP }
    if dD2 == 0i64 { return sP }
    let sC : i32 = isign64(cn)
    if sP == 0i32 { return sC }
    if sP == sC { return sP }
    /* opposite: s2 = sign(u + v sqrt D1), u = an^2+bn^2 D1 - cn^2 D2, v = 2 an bn (bigint) */
    let ar : u64 = arena_new(262144u64)
    let bD1 : u64 = bigint_from_u64(ar, dD1 as u64)
    let ban : u64 = bigint_from_u64(ar, iabs64(an))
    let bbn : u64 = bigint_from_u64(ar, iabs64(bn))
    let bcn : u64 = bigint_from_u64(ar, iabs64(cn))
    let an2 : u64 = bigint_mul(ar, ban, ban)
    let bn2D1 : u64 = bigint_mul(ar, bigint_mul(ar, bbn, bbn), bD1)
    let cn2D2 : u64 = bigint_mul(ar, bigint_mul(ar, bcn, bcn), bigint_from_u64(ar, dD2 as u64))
    let pos : u64 = bigint_add(ar, an2, bn2D1)                 /* an^2 + bn^2 D1 (>= 0) */
    let cu : i32 = bigint_cmp(pos, cn2D2)
    let mut su : i32 = 0i32
    let mut absu : u64 = 0u64
    if cu > 0i32 { su = 1i32         absu = bigint_sub(ar, pos, cn2D2) }
    if cu < 0i32 { su = 0i32 - 1i32  absu = bigint_sub(ar, cn2D2, pos) }
    let sv : i32 = isign64(an) * isign64(bn)
    let mut s2 : i32 = 0i32
    if sv == 0i32 { s2 = su }
    if sv != 0i32 {
        if su == 0i32 { s2 = sv }
        if su == sv { s2 = su }
        if su != sv {
            if su != 0i32 {
                /* |u|^2 vs v^2 D1 = (2|an||bn|)^2 D1 */
                let absv : u64 = bigint_mul(ar, bigint_mul(ar, ban, bbn), bigint_from_u64(ar, 2u64))
                let u2 : u64 = bigint_mul(ar, absu, absu)
                let v2D1 : u64 = bigint_mul(ar, bigint_mul(ar, absv, absv), bD1)
                let c2 : i32 = bigint_cmp(u2, v2D1)
                if c2 > 0i32 { s2 = su }
                if c2 < 0i32 { s2 = sv }
            }
        }
    }
    bigint_drop_arena(ar)
    arena_drop(ar)                                            /* free the region slot -> no 64-slot pool leak (render-scale) */
    if s2 > 0i32 { return sP }
    if s2 < 0i32 { return sC }
    return 0i32
}

/* RAW area-at-crossing numerators (pp + qq*sqrt dD)/(6 c^4) -- NO gcd reduction, so both crossings of one curve share
 * the denominator 6 c^4 (c=2 ax2, a=-ax1 are the same; only dD differs).  i64 holds pp ~ 1e15 at screen scale. */
var PPR : i64   var QQR : i64
fn bez_area_raw(ax0: i64, ax1: i64, ax2: i64, ay0: i64, ay1: i64, ay2: i64, a: i64, c: i64, dD: i64) -> i32 {
    let g1 : i64 = 6i64 * (ay0 * ax1)
    let g2 : i64 = 3i64 * ((2i64 * ay0 * ax2) + (ay1 * ax1))
    let g3 : i64 = 2i64 * ((2i64 * ay1 * ax2) + (ay2 * ax1))
    let g4 : i64 = 3i64 * (ay2 * ax2)
    let a2 : i64 = a * a
    let aD : i64 = a * dD
    let c2 : i64 = c * c
    let c3 : i64 = c2 * c
    let p2 : i64 = a2 + dD             let q2 : i64 = 2i64 * a
    let p3 : i64 = (a * a2) + (3i64 * aD)   let q3 : i64 = (3i64 * a2) + dD
    let p4 : i64 = ((a2 * a2) + (6i64 * a2 * dD)) + (dD * dD)   let q4 : i64 = (4i64 * a2 * a) + (4i64 * aD)
    PPR = ((((g1 * c3) * a) + ((g2 * c2) * p2)) + ((g3 * c) * p3)) + (g4 * p4)
    QQR = (((g1 * c3) + ((g2 * c2) * q2)) + ((g3 * c) * q3)) + (g4 * q4)
    return 0i32
}

/* FULL-RESOLUTION symmetric 2D coverage (region below an x-monotone arc), exact at ANY coord via bigint.
 * coverage = G(t2) - G(t1) - py = (an + bn sqrt D1 + cn sqrt D2)/(6 c^4), an=pp2-pp1-py*den, bn=-qq1, cn=qq2; the
 * exact alpha = round(sa*coverage) by a PROVEN-SIGN bigint binary search.  The binary search also CLAMPS naturally:
 * coverage<0 (arc below) -> 0, coverage>1 (arc above the row) -> sa, fractional -> the exact 8-bit value. */
fn ui_arc_cover2d_big(ax0: i64, ax1: i64, ax2: i64, ay0: i64, ay1: i64, ay2: i64, px: i64, py: i64, sa: i64) -> i64 @export {
    if ax2 == 0i64 { return 0i64 - 1i64 }
    let a : i64 = 0i64 - ax1
    let c : i64 = 2i64 * ax2
    let d1 : i64 = (ax1 * ax1) - (4i64 * ax2 * (ax0 - px))
    let d2 : i64 = (ax1 * ax1) - (4i64 * ax2 * (ax0 - (px + 1i64)))
    if d1 < 0i64 { return 0i64 - 1i64 }
    if d2 < 0i64 { return 0i64 - 1i64 }
    bez_area_raw(ax0, ax1, ax2, ay0, ay1, ay2, a, c, d1)
    let pp1 : i64 = PPR   let qq1 : i64 = QQR
    bez_area_raw(ax0, ax1, ax2, ay0, ay1, ay2, a, c, d2)
    let pp2 : i64 = PPR   let qq2 : i64 = QQR
    let c2 : i64 = c * c
    let den : i64 = 6i64 * (c2 * c2)
    let an : i64 = (pp2 - pp1) - (py * den)
    let bn : i64 = 0i64 - qq1
    let cn : i64 = qq2
    /* alpha = largest k in [0,sa] with 2*sa*coverage >= 2k-1, i.e. sign(2 sa an - (2k-1) den + 2 sa bn sqrt D1 + 2 sa cn sqrt D2) >= 0 */
    let san : i64 = (2i64 * sa) * an
    let sbn : i64 = (2i64 * sa) * bn
    let scn : i64 = (2i64 * sa) * cn
    let mut lo : i64 = 0i64
    let mut hi : i64 = sa
    while lo < hi {
        let mid : i64 = (lo + hi + 1i64) / 2i64
        let s : i32 = ui_sign_bi_big(san - (((2i64 * mid) - 1i64) * den), sbn, d1, scn, d2)
        if s >= 0i32 { lo = mid } else { hi = mid - 1i64 }
    }
    return lo
}

/* (ui_arc_cover2d_sym_big moved to ui_exact_sym.iii -- keeps ui_exact_big independent of ui_exact, so the exact-real
 * consumers (sqrt_sum_sign) that use only ui_bsign1/cover2d_big do NOT drag in the i64 geometry + framebuffer.) */
