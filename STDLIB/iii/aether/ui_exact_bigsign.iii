/* ui_exact_bigsign.iii -- EXACT sign of a 2-surd (degree-4) algebraic number with ARBITRARY-PRECISION coefficients:
 * sgn(an + bn*sqrt(dhi) + cn*sqrt(dlo)), with an/bn/cn signed bigints and dhi/dlo >= 0 small integers.  This is the
 * BIGINT PORT of ui_exact.iii:ui_sign_bi (the proven i64 squaring-reduction, gated by KAT 2162): it decides the sign
 * by ITERATED SQUARING -- an exact, finite reduction to single-surd signs -- with NO separation bound, NO isqrt, and
 * NO precision knob.
 *
 * WHY this and not ui_sqrt_sum_sign_big: the coverage rounder probes sgn(2*sa*coverage - (2k-1)), which at the rounding
 * boundary is a near-cancellation of large terms.  ui_sqrt_sum_sign_big's N-surd SEPARATION BOUND false-zeros such
 * near-ties at render-scale magnitudes (it is the correct tool for n>=3 INDEPENDENT surds, where iterated squaring
 * blows up to 2^n cross-terms -- but per-pixel coverage is intrinsically a 2-surd, where squaring is exact and finite).
 * For 2 surds the squaring reduction is strictly more correct and unconditionally robust.
 *
 * PRECONDITION: dhi >= 0, dlo >= 0 (a real crossing's discriminant from ui_xc, which returns 0 when dD<0; a degenerate
 * sub-range bound carries D = 0, handled by the dD==0 branch).  Coefficient magnitudes are unbounded (bigint). */
module ui_exact_bigsign

extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mul(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_add(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_sub(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_cmp(a: u64, b: u64) -> i32 from "bigint.iii"

fn ui_bsgnv(s: i64) -> i32 { if s > 0i64 { return 1i32 }   if s < 0i64 { return 0i32 - 1i32 }   return 0i32 }

/* sign(asg*am + bsg*bm*sqrt(dD)), dD >= 0, am/bm magnitudes (bigint handles), asg/bsg in {-1,0,1}.
 * Same sign -> that sign; opposite -> the winner of |asg term| vs |bsg term|, i.e. am^2 vs bm^2*dD (exact bigint). */
fn ui_bigsign_surd(ar: u64, asg: i64, am: u64, bsg: i64, bm: u64, dD: i64) -> i32 {
    if dD == 0i64 { return ui_bsgnv(asg) }                                  /* sqrt(0)=0 -> sign of the rational term */
    if asg == 0i64 { return ui_bsgnv(bsg) }
    if bsg == 0i64 { return ui_bsgnv(asg) }
    if asg == bsg { return ui_bsgnv(asg) }
    let am2 : u64 = bigint_mul(ar, am, am)                                  /* am^2 */
    let bm2d : u64 = bigint_mul(ar, bigint_mul(ar, bm, bm), bigint_from_u64(ar, dD as u64))   /* bm^2 * dD */
    let c : i32 = bigint_cmp(am2, bm2d)
    if c > 0i32 { return ui_bsgnv(asg) }                                    /* rational term dominates */
    if c < 0i32 { return ui_bsgnv(bsg) }                                    /* surd term dominates */
    return 0i32                                                             /* exactly equal -> value 0 */
}

/* sign(an + bn*sqrt(dhi) + cn*sqrt(dlo)), dhi/dlo >= 0.  Faithful bigint port of ui_exact.iii:ui_sign_bi. */
fn ui_bigsign2(ar: u64, ansg: i64, anm: u64, bnsg: i64, bnm: u64, dhi: i64, cnsg: i64, cnm: u64, dlo: i64) -> i32 @export {
    let sP : i32 = ui_bigsign_surd(ar, ansg, anm, bnsg, bnm, dhi)           /* sign(P), P = an + bn*sqrt(dhi) */
    if cnsg == 0i64 { return sP }
    if dlo == 0i64 { return sP }
    let sC : i32 = ui_bsgnv(cnsg)                                           /* sign(cn*sqrt(dlo)), dlo>0 */
    if sP == 0i32 { return sC }
    if sP == sC { return sP }
    /* opposite signs: sign(P + cn*sqrt(dlo)) = sign(P) iff |P| > |cn|*sqrt(dlo) iff P^2 > cn^2*dlo.
     * P^2 = (an^2 + bn^2*dhi) + (2*an*bn)*sqrt(dhi); compare to cn^2*dlo (rational) -> a single-surd sign. */
    let an2 : u64 = bigint_mul(ar, anm, anm)
    let bn2dhi : u64 = bigint_mul(ar, bigint_mul(ar, bnm, bnm), bigint_from_u64(ar, dhi as u64))
    let ppA : u64 = bigint_add(ar, an2, bn2dhi)                             /* an^2 + bn^2*dhi (>=0) */
    let cn2dlo : u64 = bigint_mul(ar, bigint_mul(ar, cnm, cnm), bigint_from_u64(ar, dlo as u64))   /* cn^2*dlo (>=0) */
    let cc : i32 = bigint_cmp(ppA, cn2dlo)
    let mut rsg : i64 = 0i64
    let mut rmag : u64 = ppA
    if cc > 0i32 { rsg = 1i64        rmag = bigint_sub(ar, ppA, cn2dlo) }   /* P^2 - cn^2 dlo, rational part of the surd */
    if cc < 0i32 { rsg = 0i64 - 1i64 rmag = bigint_sub(ar, cn2dlo, ppA) }
    let ppBsg : i64 = ansg * bnsg                                          /* sign of 2*an*bn */
    let ppBm : u64 = bigint_mul(ar, bigint_mul(ar, anm, bnm), bigint_from_u64(ar, 2u64))   /* 2*|an|*|bn| */
    let s2 : i32 = ui_bigsign_surd(ar, rsg, rmag, ppBsg, ppBm, dhi)         /* sign(P^2 - cn^2 dlo) */
    if s2 > 0i32 { return sP }                                              /* |P| wins -> sign(P) */
    if s2 < 0i32 { return sC }                                              /* |cn|sqrt(dlo) wins -> sign(cn) */
    return 0i32
}
