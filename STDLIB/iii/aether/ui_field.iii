/* STDLIB/iii/aether/ui_field.iii -- THE UNIFIED FIELD: the topological-windowing engine's higher faculties, each
 * built on the exact-algebraic + bigint core (ui_exact / ui_exact_big).  Data is geometry; geometry has a measured
 * dimension; the dimension drives semantic zoom; time and N-D space are just more variables in the same polynomials.
 * Every faculty is exact where exactness is possible and an HONEST computable proxy where the exact quantity is
 * provably uncomputable (Kolmogorov complexity, the ill-posed inverse) -- and it says which it is. */
module ui_field

/* ============================================================================================================
 * (1) KOLMOGOROV-HAUSDORFF -- the boundary's dimension DERIVED from the data's complexity.
 * Kolmogorov complexity K is UNCOMPUTABLE (Halting Problem); the Renyi-2 collision entropy H2 = -log2(sum p_i^2) is
 * EXACTLY computable (sum p_i^2 = (sum c_i^2)/N^2, rational) and a rigorous lower bound on Shannon entropy -- the
 * honest complexity proxy.  d = 1 + H2/8 in [1,2]: predictable data -> 1.0 (smooth line); uniform-random -> 2.0
 * (space-filling).  Returned as milli-dimension (d*1000).  The collision count is EXACT; only the final log2 is a
 * fixed-point real (a dimension IS a real number). */
var FREQ : [u64; 256]

fn fld_gcd(a0: i64, b0: i64) -> i64 {
    let mut a : i64 = a0   if a < 0i64 { a = 0i64 - a }
    let mut b : i64 = b0   if b < 0i64 { b = 0i64 - b }
    while b != 0i64 { let t : i64 = b   b = a - ((a / b) * b)   a = t }
    return a
}
fn fld_gcd3(a: i64, b: i64, c: i64) -> i64 { return fld_gcd(fld_gcd(a, b), c) }

/* log2(m) * 1024, fixed-point, for m >= 1.  Integer part = highest set bit; 10 fractional bits by repeated squaring. */
fn log2_q10(m: u64) -> u64 @export {
    if m <= 1u64 { return 0u64 }
    let mut e : u64 = 0u64
    let mut v : u64 = m
    while v > 1u64 { v = v >> 1u64   e = e + 1u64 }          /* e = floor(log2 m) */
    let mut xf : u64 = 0u64                                  /* xf ~ (m / 2^e) * 2^20, in [2^20, 2^21) */
    if e <= 20u64 { xf = m << (20u64 - e) }
    if e > 20u64 { xf = m >> (e - 20u64) }
    let mut frac : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 10u64 {
        xf = (xf * xf) >> 20u64                              /* square the mantissa (stays < 2^64) */
        frac = frac << 1u64
        if xf >= 2097152u64 { frac = frac + 1u64   xf = xf >> 1u64 }   /* >= 2^21 -> next bit 1, renormalise */
        i = i + 1u64
    }
    return (e << 10u64) + frac
}

/* log2(m) * 2^20 -- 20 fractional bits, for ratio dimensions (d = (log nf - log nc)/log r) where the 2^20 scale
 * cancels, so the extra precision lands the exact closed-form dimension.  Mantissa carried at 2^30 for the squaring. */
fn log2_q20(m: u64) -> u64 @export {
    if m <= 1u64 { return 0u64 }
    let mut e : u64 = 0u64
    let mut v : u64 = m
    while v > 1u64 { v = v >> 1u64   e = e + 1u64 }
    let mut xf : u64 = 0u64                                  /* xf ~ (m / 2^e) * 2^30, in [2^30, 2^31) */
    if e <= 30u64 { xf = m << (30u64 - e) }
    if e > 30u64 { xf = m >> (e - 30u64) }
    let mut frac : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 20u64 {
        xf = (xf * xf) >> 30u64                              /* mantissa^2 (xf^2 < 2^62, fits) */
        frac = frac << 1u64
        if xf >= 2147483648u64 { frac = frac + 1u64   xf = xf >> 1u64 }   /* >= 2^31 -> next bit 1, renormalise */
        i = i + 1u64
    }
    return (e << 20u64) + frac
}

/* the Kolmogorov-Hausdorff dimension of a byte array, as d*1000 in [1000,2000]. */
fn ui_data_dim(buf: u64, n: u64) -> u64 @export {
    let p : *u8 = buf as *u8
    let mut i : u64 = 0u64
    while i < 256u64 { FREQ[i] = 0u64   i = i + 1u64 }
    i = 0u64
    while i < n { let b : u64 = p[i] as u64   FREQ[b] = FREQ[b] + 1u64   i = i + 1u64 }
    /* S = sum c_i^2 (the collision count) */
    let mut s : u64 = 0u64
    i = 0u64
    while i < 256u64 { let c : u64 = FREQ[i]   s = s + (c * c)   i = i + 1u64 }
    if s == 0u64 { return 1000u64 }
    /* H2*1024 = log2(N^2/S) = 2*log2(N) - log2(S) ; d*1000 = 1000 + 125*H2 */
    let h2q : u64 = (2u64 * log2_q10(n)) - log2_q10(s)
    return 1000u64 + ((125u64 * h2q) / 1024u64)
}

/* ============================================================================================================
 * (7) STRUCTURAL COLOR -- color GENERATED by topology, not an 8-bit RGB lie.  A boundary's complexity-dimension d
 * (faculty 1) maps to a physical wavelength (d=1 predictable -> 700nm red ; d=2 complex -> 380nm violet), and the
 * wavelength becomes a spectral RGB (the piecewise visible spectrum).  As the Hausdorff dimension shifts under zoom,
 * the element physically Doppler-shifts through the spectrum -- like a Morpho butterfly, the color IS the structure. */
fn ui_wavelength_rgb(lam: i64) -> u32 @export {
    let mut r : i64 = 0i64   let mut g : i64 = 0i64   let mut bl : i64 = 0i64
    if lam >= 380i64 { if lam < 440i64 { r = (255i64 * (440i64 - lam)) / 60i64   bl = 255i64 } }
    if lam >= 440i64 { if lam < 490i64 { g = (255i64 * (lam - 440i64)) / 50i64   bl = 255i64 } }
    if lam >= 490i64 { if lam < 510i64 { g = 255i64   bl = (255i64 * (510i64 - lam)) / 20i64 } }
    if lam >= 510i64 { if lam < 580i64 { r = (255i64 * (lam - 510i64)) / 70i64   g = 255i64 } }
    if lam >= 580i64 { if lam < 645i64 { r = 255i64   g = (255i64 * (645i64 - lam)) / 65i64 } }
    if lam >= 645i64 { if lam <= 700i64 { r = 255i64 } }
    return (255u32 << 24u32) | ((r as u32) << 16u32) | ((g as u32) << 8u32) | (bl as u32)
}
/* the structural color of a boundary with complexity-dimension d (d*1000): lambda = 700 - (d-1)*320 nm. */
fn ui_dim_to_rgb(d_milli: i64) -> u32 @export {
    let lam : i64 = 700i64 - (((d_milli - 1000i64) * 320i64) / 1000i64)
    return ui_wavelength_rgb(lam)
}

/* THE EXACT STRUCTURAL-COLOR IDENTITY (proven, not approximated) -- the 100% version: a periodic boundary of EXACT
 * period p (nm, read from the geometry) at rational sin(theta)=s/q reflects, in diffraction order m, the EXACT
 * wavelength lambda = p*s/(q*m) (the grating identity).  The PHYSICAL color is a proven algebraic identity of the
 * geometry -- no empirical color table, no float touches it.  (Only the final eye-RGB is empirical biology.) */
fn ui_grating_wavelength(p_nm: i64, sin_num: i64, sin_den: i64, order: i64) -> i64 @export {
    return (p_nm * sin_num) / (sin_den * order)
}
fn ui_struct_color(p_nm: i64, sin_num: i64, sin_den: i64, order: i64) -> u32 @export {
    return ui_wavelength_rgb(ui_grating_wavelength(p_nm, sin_num, sin_den, order))
}

/* ============================================================================================================
 * (4) CONTINUOUS TIME AS AN ALGEBRAIC VARIABLE -- infinite-framerate, zero-error kinematics.  An object's position
 * is a polynomial p(t) = p0 + v0*t + (acc/2)*t^2; time t is NOT a discrete tick but a continuous variable, and at
 * ANY instant -- including an IRRATIONAL one t = (ta + sqrt tD)/tc -- the position is a PROVEN algebraic value
 * (KIN_P + KIN_Q sqrt tD)/KIN_DEN, not an interpolated frame.  No animation loop, no float; the geometry at any
 * microsecond is a solved mathematical proof.  (The exact theorem; the display still samples it at the eye's frame
 * rate -- the one honest limit, named.) */
var KIN_P : i64   var KIN_Q : i64   var KIN_DEN : i64   var KIN_D : i64
fn ui_kinematic_at_t(p0: i64, v0: i64, acc: i64, ta: i64, tD: i64, tc: i64) -> i32 @export {
    /* t = (ta + sqrt tD)/tc ; t^2 = (ta^2+tD + 2 ta sqrt tD)/tc^2.  Common denominator 2 tc^2. */
    let tc2 : i64 = tc * tc
    let pp : i64 = ((2i64 * p0 * tc2) + (2i64 * v0 * ta * tc)) + (acc * ((ta * ta) + tD))
    let qq : i64 = (2i64 * v0 * tc) + (2i64 * acc * ta)
    let den : i64 = 2i64 * tc2
    /* reduce by gcd */
    let mut p : i64 = pp   let mut q : i64 = qq   let mut d : i64 = den
    if d < 0i64 { p = 0i64 - p   q = 0i64 - q   d = 0i64 - d }
    let g : i64 = fld_gcd3(p, q, d)
    if g > 1i64 { p = p / g   q = q / g   d = d / g }
    KIN_P = p   KIN_Q = q   KIN_DEN = d   KIN_D = tD
    return 0i32
}
fn ui_kin_p() -> i64 @export { return KIN_P }
fn ui_kin_q() -> i64 @export { return KIN_Q }
fn ui_kin_den() -> i64 @export { return KIN_DEN }
fn ui_kin_d() -> i64 @export { return KIN_D }

/* ============================================================================================================
 * (5) REVERSE RASTERIZATION / OPTICAL PROOFING -- the exact coverage is INVERTIBLE.  Forward: a 45-degree edge
 * x+y=c through the unit pixel covers area cov = c^2/2 (c in [0,1]) -- the exact algebraic identity.  Inverse: from
 * the EXACT coverage alone, recover the boundary's offset -- c^2 = 2*cov, a PROVEN value (the exact geometry that
 * cast the shadow), not a probabilistic guess.  Round-trip forward∘inverse = identity.  NAMED limit: exact only for
 * a CONSTRAINED family (here, edge orientation known); the UNconstrained inverse is ill-posed (many shapes, one
 * shadow) -- so III proves the geometry under a constraint, it does not hallucinate it. */
var COV_N : i64   var COV_D : i64   var INV_N : i64   var INV_D : i64
fn ui_forward_diag(off_n: i64, off_d: i64) -> i32 @export {        /* cov = off^2 / (2 off_d^2) */
    let mut n : i64 = off_n * off_n
    let mut d : i64 = (2i64 * off_d) * off_d
    let g : i64 = fld_gcd(n, d)
    if g > 1i64 { n = n / g   d = d / g }
    COV_N = n   COV_D = d
    return 0i32
}
fn ui_inverse_diag(cov_n: i64, cov_d: i64) -> i32 @export {        /* off^2 = 2*cov = 2 cov_n / cov_d */
    let mut n : i64 = 2i64 * cov_n
    let mut d : i64 = cov_d
    let g : i64 = fld_gcd(n, d)
    if g > 1i64 { n = n / g   d = d / g }
    INV_N = n   INV_D = d
    return 0i32
}
fn ui_cov_n() -> i64 @export { return COV_N }
fn ui_cov_d() -> i64 @export { return COV_D }
fn ui_inv_n() -> i64 @export { return INV_N }
fn ui_inv_d() -> i64 @export { return INV_D }

/* ============================================================================================================
 * (3) N-DIMENSIONAL ALGEBRAIC SLICING -- the holographic screen.  The 2D screen is a rigid constraint plane (x1=x,
 * x2=y, x3..xn fixed at c3..cn) cutting an N-dim quadric  sum a_i x_i^2 = b.  The cross-section is EXACTLY the conic
 * a1 x^2 + a2 y^2 = bp, bp = b - sum_{i>=3} a_i c_i^2 -- a pure integer subtraction.  Rotating the viewport through
 * 10000 dims is just changing the fixed sum; the section's birth/growth/collapse-to-a-point/vanish are exact integer
 * events, aliasing-free.  NAMED limit: a circle's AREA is pi*r^2 (transcendental) -- the slice EQUATION is exact, its
 * coverage is not algebraic. */
fn ui_slice_quadric(b: i64, fixed_sum: i64) -> i64 @export { return b - fixed_sum }
/* nature of the 2D conic a1 x^2 + a2 y^2 = bp (a1,a2 > 0): 0=empty, 1=point, 2=circle, 3=ellipse. */
fn ui_slice_nature(a1: i64, a2: i64, bp: i64) -> i32 @export {
    if bp < 0i64 { return 0i32 }       /* the plane misses the manifold -- empty */
    if bp == 0i64 { return 1i32 }      /* tangent -- a single point */
    if a1 == a2 { return 2i32 }        /* circle */
    return 3i32                        /* ellipse */
}
/* the exact squared semi-axis of the slice conic along x (= bp/a1) and y (= bp/a2), as reduced rationals.
 * for a hypersphere (a1=a2=1) both equal bp -- the circle's radius^2, an exact integer. */
var AX2_N : i64   var AX2_D : i64   var AY2_N : i64   var AY2_D : i64
fn ui_slice_axes(a1: i64, a2: i64, bp: i64) -> i32 @export {
    let mut xn : i64 = bp   let mut xd : i64 = a1
    let gx : i64 = fld_gcd(xn, xd)   if gx > 1i64 { xn = xn / gx   xd = xd / gx }
    let mut yn : i64 = bp   let mut yd : i64 = a2
    let gy : i64 = fld_gcd(yn, yd)   if gy > 1i64 { yn = yn / gy   yd = yd / gy }
    AX2_N = xn   AX2_D = xd   AY2_N = yn   AY2_D = yd
    return 0i32
}
fn ui_ax2_n() -> i64 @export { return AX2_N }
fn ui_ax2_d() -> i64 @export { return AX2_D }
fn ui_ay2_n() -> i64 @export { return AY2_N }
fn ui_ay2_d() -> i64 @export { return AY2_D }

/* ============================================================================================================
 * (Q) THE QUANTUM USER INTERFACE -- a monitor for quantum mechanics that does NOT destroy the math.  Pipe a quantum
 * state's amplitudes (as squared-magnitude integer weights c_i summing to `total`) over `n` basis states; III renders
 * its Renyi-2 entropy (faculty 1, exact-rational) as a fractal dimension d = 1 + H2/log2(n) in [1,2].  A UNIFORM
 * superposition is maximally space-filling (d=2); a PURE (collapsed) state has zero entropy, so d SNAPS to exactly
 * 1.000 -- the integer Euclidean baseline.  The user literally watches the boundary's continuous Hausdorff dimension
 * snap flat as the wave-function collapses.  NAMED limit: III renders the classical amplitude-DESCRIPTION exactly;
 * the quantum state itself lives on the QC -- III is its honest, math-preserving monitor, not the qubits. */
fn ui_quantum_dim(counts: u64, n_states: u64, total: u64) -> u64 @export {
    let p : *u64 = counts as *u64
    let mut s : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n_states { let c : u64 = p[i]   s = s + (c * c)   i = i + 1u64 }
    if s == 0u64 { return 1000u64 }
    let ln : u64 = log2_q10(n_states)
    if ln == 0u64 { return 1000u64 }                       /* a single basis state is always classical, d=1 */
    let h2q : u64 = (2u64 * log2_q10(total)) - log2_q10(s)
    return 1000u64 + ((1000u64 * h2q) / ln)
}
/* 1 iff the rendered state is collapsed (pure) -- the dimension has snapped to the integer baseline. */
fn ui_quantum_collapsed(counts: u64, n_states: u64, total: u64) -> u32 @export {
    if ui_quantum_dim(counts, n_states, total) == 1000u64 { return 1u32 }
    return 0u32
}

/* ============================================================================================================
 * (10) ACOUSTIC TOPOLOGY -- every UI element generates its own sound from its shape.  A 1-D resonator of length L
 * resonates at the harmonic series f_n = n*v/(2L) -- exact rational overtones.  A heavy/large element (big L) rings
 * low; a tight/wrinkled one rings high.  "In tune" is the EXACT predicate f_n = n*f_1; a constraint violation that
 * distorts L shifts a frequency off its harmonic and the user HEARS the math go out of tune before seeing it.
 * NAMED limit: a general 2-D membrane's eigenfrequencies are Bessel zeros (transcendental) -- the 1-D series is
 * exact, the drum-head is not. */
fn ui_acoustic_freq(length: i64, n_harm: i64, speed: i64) -> i64 @export {
    return (n_harm * speed) / (2i64 * length)
}
fn ui_is_harmonic(f1: i64, fq: i64, n: i64) -> u32 @export {
    if fq == (n * f1) { return 1u32 }              /* integer-multiple overtone -- in tune */
    return 0u32                                    /* inharmonic -- out of tune (a violation is audible) */
}

/* ============================================================================================================
 * (8) REVERSIBLE TIME-TRAVEL -- zero-entropy undo.  Every transform is a BIJECTION, so no information is destroyed
 * and the past is RECOMPUTED, never stored.  A time-parameterised shear S_t(x,y) = (x + k*t*y, y) has the exact
 * inverse S_{-t}; setting the time variable negative runs the algebra backward and the geometry un-folds to its
 * proven past state.  evolve(evolve(s,t),-t) = s exactly -- no undo stack.  NAMED limit: only BIJECTIVE transforms
 * are reversible (a lossy op like clamp/min discards information and has no inverse). */
var REV_X : i64   var REV_Y : i64
fn ui_evolve(x: i64, y: i64, k: i64, t: i64) -> i32 @export {
    REV_X = x + ((k * t) * y)
    REV_Y = y
    return 0i32
}
fn ui_rev_x() -> i64 @export { return REV_X }
fn ui_rev_y() -> i64 @export { return REV_Y }

/* ============================================================================================================
 * (L) THE LOCAL WEB -- relational ontology made operational.  HYPOTHESIS: only localized events, the relations
 * between them, and walls of hard logic exist -- there is no global background.  This is testable: a custom local
 * relay where each node is a "dot in the geometry" that reads ONLY its adjacent neighbors (a local event) and applies
 * a hard-logic wall (min(self, neighbor+1)).  Run it synchronously and the global distance-from-source field emerges
 * one hop per step -- the EVIDENCE: a global property reconstructed with NOTHING but local events + adjacency
 * relations + logic.  This realizes III's event-substrate (EVENT primary, STATE = fold of events) as a web.
 * NAMED limit: this satisfies the ontology for RELAY-RECONSTRUCTIBLE properties (distance/connectivity/conserved
 * flow); a genuinely non-decomposable global constraint would fall outside the local-relay class. */
var RLY : [i64; 64]   var RLY2 : [i64; 64]
fn ui_relay_init(n: i64, src: i64) -> i32 @export {
    let mut i : i64 = 0i64
    while i < n { RLY[i] = 1000000i64   i = i + 1i64 }      /* every node starts "unreached" (infinity) */
    RLY[src] = 0i64                                          /* the single source event: distance 0 */
    return 0i32
}
/* ONE synchronous relay step: each node updates from its PREVIOUS-step neighbors only -- a purely local event.
 * One call propagates the wavefront exactly one hop, so the caller can observe the relay working. */
fn ui_relay_step(n: i64) -> i32 @export {
    let mut i : i64 = 0i64
    while i < n {
        let mut v : i64 = RLY[i]
        if i > 0i64 { let l : i64 = RLY[i - 1i64] + 1i64   if l < v { v = l } }
        if i < (n - 1i64) { let r : i64 = RLY[i + 1i64] + 1i64   if r < v { v = r } }
        RLY2[i] = v
        i = i + 1i64
    }
    i = 0i64
    while i < n { RLY[i] = RLY2[i]   i = i + 1i64 }
    return 0i32
}
fn ui_relay_get(idx: i64) -> i64 @export { return RLY[idx] }
/* run the relay to its fixpoint (n-1 hops cover a line) and return the global diameter -- reconstructed locally. */
fn ui_relay_converge(n: i64) -> i64 @export {
    let mut h : i64 = 0i64
    while h < n { ui_relay_step(n)   h = h + 1i64 }
    let mut mx : i64 = 0i64
    let mut i : i64 = 0i64
    while i < n { if RLY[i] > mx { mx = RLY[i] }   i = i + 1i64 }
    return mx                                               /* the global max distance, from purely local relays */
}

/* ============================================================================================================
 * (S) SELF-POPULATION -- emergent complexity from a single local rule.  Humans cannot author infinite complexity;
 * they author the BASE RULE and press start.  A single seed event under the purely-local rule 90 (new[i] =
 * left XOR right) self-populates into the EXACT Sierpinski fractal -- a macro-structure no one drew.  Because the
 * step is integer-exact (never rounds), the local interactions grow a PERFECT fractal, and its emergent complexity
 * is then measurable by faculty 1 (the Hausdorff dimension log3/log2 of the Sierpinski gasket).  This is the
 * coordinate-free, self-growing universe in miniature.  NAMED limit: determinism -- the same rule+seed always yields
 * the same structure (no true randomness; novelty comes from the rule, not chance). */
var CA : [u8; 128]   var CA2 : [u8; 128]
fn ui_ca_seed(n: i64, pos: i64) -> i32 @export {
    let mut i : i64 = 0i64
    while i < n { CA[i] = 0u8   i = i + 1i64 }
    CA[pos] = 1u8                                           /* the single seed event */
    return 0i32
}
/* ONE self-population tick under rule 90; the macro-structure grows itself from purely local left^right reads. */
fn ui_ca_step(n: i64) -> i32 @export {
    let mut i : i64 = 0i64
    while i < n {
        let mut l : u8 = 0u8
        if i > 0i64 { l = CA[i - 1i64] }
        let mut r : u8 = 0u8
        if i < (n - 1i64) { r = CA[i + 1i64] }
        CA2[i] = (l + r) & 1u8                              /* left XOR right (values are 0/1) -- rule 90 */
        i = i + 1i64
    }
    i = 0i64
    while i < n { CA[i] = CA2[i]   i = i + 1i64 }
    return 0i32
}
fn ui_ca_get(idx: i64) -> u8 @export { return CA[idx] }
/* live-cell count -- the Sierpinski row-k population is exactly 2^popcount(k), an exact self-similar signature. */
fn ui_ca_count(n: i64) -> i64 @export {
    let mut c : i64 = 0i64
    let mut i : i64 = 0i64
    while i < n { c = c + (CA[i] as i64)   i = i + 1i64 }
    return c
}

/* ============================================================================================================
 * (N) SELF-POPULATING NUMBERS -- the answer to "numbers are too dumb".  A stored value (1.41421...) implies a false
 * absolute background and is lossy.  Instead store the RULE that GENERATES the number: a PERIODIC continued fraction
 * is a finite seed [a0; period...] that self-populates the EXACT convergents p_k/q_k of a quadratic irrational via
 * p_k = a_k p_{k-1} + p_{k-2}, to ANY precision, from a handful of symbols.  The Pell residue p^2 - D q^2 stays
 * exactly +-1 forever -- the PROOF the seed IS sqrt(D), not an approximation of it.  A number that self-populates,
 * just as faculty S self-populates a fractal.  NAMED limit: this is exact for quadratic irrationals (periodic CFs);
 * a transcendental like pi has a non-periodic CF (no finite seed). */
var CF_P : i64   var CF_Q : i64
fn ui_cf_run(a0: i64, period: u64, period_len: i64, n_terms: i64) -> i32 @export {
    let per : *i64 = period as *i64
    let mut pm1 : i64 = 1i64   let mut qm1 : i64 = 0i64    /* p_{-1}=1, q_{-1}=0 */
    let mut p : i64 = a0       let mut q : i64 = 1i64      /* p_0=a0,  q_0=1 */
    let mut k : i64 = 1i64
    while k < n_terms {
        let idx : i64 = (k - 1i64) % period_len
        let ak : i64 = per[idx]
        let np : i64 = (ak * p) + pm1                       /* the self-population recurrence */
        let nq : i64 = (ak * q) + qm1
        pm1 = p   qm1 = q
        p = np    q = nq
        k = k + 1i64
    }
    CF_P = p   CF_Q = q
    return 0i32
}
fn ui_cf_p() -> i64 @export { return CF_P }
fn ui_cf_q() -> i64 @export { return CF_Q }
/* Pell residue: p^2 - D q^2 -- for a convergent of sqrt(D) this is ALWAYS +-1, the exact proof the seed is sqrt(D). */
fn ui_cf_pell(d: i64) -> i64 @export { return (CF_P * CF_P) - ((d * CF_Q) * CF_Q) }

/* ============================================================================================================
 * (W) ALGEBRAIC WAVE OPTICS -- analytical wave tracing with no grid.  Two source wavefronts interfere; the path
 * difference Delta = |P-S1| - |P-S2| = sqrt(A) - sqrt(B) is a sum of radicals, yet "P lies on the m-th constructive
 * fringe (Delta = m*lambda)" is decided EXACTLY: squaring twice gives the pure-integer identity
 * (A - B - (m*lambda)^2)^2 = 4*(m*lambda)^2*B with the sign condition sign(A-B-(m lam)^2)=sign(m).  No grid, no
 * aliasing -- III outputs the exact nodes of constructive/destructive interference.  A destructive (half) fringe is
 * just the constructive test at lambda/2 with odd order.  NAMED limit: the fringe LOCUS is an irrational hyperbola
 * (membership is exact; the photon wavelength is the empirical physical input). */
fn ui_interfere(s1x: i64, s1y: i64, s2x: i64, s2y: i64, px: i64, py: i64, lam: i64, m: i64) -> i32 @export {
    let a : i64 = (((px - s1x) * (px - s1x)) + ((py - s1y) * (py - s1y)))    /* |P-S1|^2 */
    let b : i64 = (((px - s2x) * (px - s2x)) + ((py - s2y) * (py - s2y)))    /* |P-S2|^2 */
    let ml : i64 = m * lam
    let k : i64 = (a - b) - (ml * ml)                                        /* A - B - (m lam)^2 */
    if (k * k) != ((4i64 * (ml * ml)) * b) { return 0i32 }                   /* not on the fringe locus */
    if m > 0i64 { if k < 0i64 { return 0i32 } }                              /* sign condition: K ~ m */
    if m < 0i64 { if k > 0i64 { return 0i32 } }
    return 1i32                                                              /* exact constructive interference */
}
/* 1 iff P is on a DESTRUCTIVE (dark) fringe: 2*Delta = (2m+1)*lambda, i.e. the constructive test at lambda/2, order 2m+1. */
fn ui_interfere_dark(s1x: i64, s1y: i64, s2x: i64, s2y: i64, px: i64, py: i64, lam: i64, m: i64) -> i32 @export {
    return ui_interfere(s1x, s1y, s2x, s2y, px, py, lam, (2i64 * m) + 1i64)  /* lam here is already the half-wavelength */
}

/* ============================================================================================================
 * (H) FRACTAL HASH -- the geometry IS the tamper-evident seal.  The data is walked as a turtle path: every bit of
 * each byte steers a move (dx = low nibble - 8, dy = high nibble - 8), so the document becomes a polyline.  The seal
 * is the path's EXACT signed area (integer shoelace, 2*A) plus its endpoint.  A single bit-flip changes one move,
 * which TRANSLATES the entire downstream path -- so the endpoint provably shifts and the area shears: tamper is
 * detected exactly, never a false "valid".  NAMED limit: area+endpoint is two integers, so this is tamper-EVIDENCE,
 * NOT collision-resistance -- an adversary can craft a compensating forgery; compose with SHA for cryptographic use. */
var HASH_A2 : i64   var HASH_EX : i64   var HASH_EY : i64
fn ui_fractal_hash(buf: u64, n: u64) -> i32 @export {
    let p : *u8 = buf as *u8
    let mut x : i64 = 0i64   let mut y : i64 = 0i64
    let mut a2 : i64 = 0i64                                  /* 2 * signed area (shoelace) */
    let mut i : u64 = 0u64
    while i < n {
        let b : i64 = p[i] as i64
        let dx : i64 = (b & 15i64) - 8i64                    /* low nibble -> dx in [-8,7] */
        let dy : i64 = ((b >> 4i64) & 15i64) - 8i64          /* high nibble -> dy in [-8,7] */
        let nx : i64 = x + dx
        let ny : i64 = y + dy
        a2 = a2 + ((x * ny) - (nx * y))                      /* shoelace term: x_i y_{i+1} - x_{i+1} y_i */
        x = nx   y = ny
        i = i + 1u64
    }
    HASH_A2 = a2   HASH_EX = x   HASH_EY = y
    return 0i32
}
fn ui_hash_a2() -> i64 @export { return HASH_A2 }
fn ui_hash_ex() -> i64 @export { return HASH_EX }
fn ui_hash_ey() -> i64 @export { return HASH_EY }

/* ============================================================================================================
 * (B) THE BINDING -- topo (logic) + egraph (conservation) + exact-algebraic (render) as ONE field equation.  The
 * exact-algebraic invariant of a shape (its signed area, integer shoelace 2A = sum x_i y_{i+1} - x_{i+1} y_i over the
 * closed polygon) is CONSERVED under re-representation: a square as one polygon and as two triangles carry the
 * bit-identical area.  So the e-graph's equivalent forms must all carry the SAME exact invariant, and that equality
 * IS the logic constraint -- the three engines agree on one quantity.  This helper is the render/conservation leg;
 * the binding KAT (2118) threads it through the e-graph and the equality law.  NAMED limit: the binding holds on a
 * SHARED exact invariant; engines with no common invariant cannot be bound this way (real binding, not glue). */
fn ui_poly_area2(xs: u64, ys: u64, n: u64) -> i64 @export {
    let px : *i64 = xs as *i64
    let py : *i64 = ys as *i64
    let mut a2 : i64 = 0i64
    let mut i : u64 = 0u64
    while i < n {
        let j : u64 = (i + 1u64) % n                        /* wrap to close the polygon */
        a2 = a2 + ((px[i] * py[j]) - (px[j] * py[i]))        /* shoelace term */
        i = i + 1u64
    }
    if a2 < 0i64 { a2 = 0i64 - a2 }                          /* unsigned area (orientation-independent) */
    return a2
}
