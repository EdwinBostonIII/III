/* STDLIB/iii/aether/ui_glass.iii -- III-GLASS: a live window that shows III's REAL state, not a decoration.
 * Every frame it RUNS the exact-coverage engine (ui_edge / ui_tri_cov) on known geometry and prints the actual
 * integers it computes, checked against the expected values -- a self-verifying panel (green=match).  The mouse
 * reads the EXACT coverage of the pixel under the cursor (a real computation tied to your hand); any key toggles
 * the subsample count n=1<->8 so you watch hard edges become smooth and the numbers change.  Text, real data,
 * real interaction.  ESC or close to quit. */
module ui_glass

extern @abi(c-msvc-x64) fn ui_clear(buf: u64, w: u32, h: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_fill_rect(buf: u64, w: u32, h: u32, x: u32, y: u32, rw: u32, rh: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_fill_circle_aa(buf: u64, w: u32, h: u32, cx: i64, cy: i64, r: i64, color: u32, n: i64) -> i32 from "ui_exact.iii"
extern @abi(c-msvc-x64) fn ui_fill_tri_aa(buf: u64, w: u32, h: u32, x0: i64, y0: i64, x1: i64, y1: i64, x2: i64, y2: i64, color: u32, n: i64) -> i32 from "ui_exact.iii"
extern @abi(c-msvc-x64) fn ui_circle_cov(cx: i64, cy: i64, r: i64, px: i64, py: i64, n: i64) -> i64 from "ui_exact.iii"
extern @abi(c-msvc-x64) fn ui_tri_cov(x0: i64, y0: i64, x1: i64, y1: i64, x2: i64, y2: i64, px: i64, py: i64, n: i64) -> i64 from "ui_exact.iii"
extern @abi(c-msvc-x64) fn ui_edge(ax: i64, ay: i64, bx: i64, by: i64, px: i64, py: i64) -> i64 from "ui_exact.iii"
extern @abi(c-msvc-x64) fn ui_text_n(buf: u64, w: u32, h: u32, x: u32, y: u32, str: u64, len: u32, color: u32) -> u32 from "ui_font.iii"
extern @abi(c-msvc-x64) fn ui_text_u32(buf: u64, w: u32, h: u32, x: u32, y: u32, v: u32, color: u32) -> u32 from "ui_font.iii"
extern @abi(c-msvc-x64) fn ui_win_open(title: u64, w: u32, h: u32) -> u64 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_win_present(buf: u64, w: u32, h: u32) -> i32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_win_pump() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_mx() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_my() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_key() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_sleep(ms: u32) -> i32 from "ui_win.iii"

var FB    : [u32; 316800]   /* 720 x 440 */
var TITLE : [u8; 10] = [73u8,73u8,73u8,45u8,71u8,76u8,65u8,83u8,83u8,0u8]   /* window title "IIIGLASS\0" */

fn rgb(r: u32, g: u32, b: u32) -> u32 { return (255u32 << 24u32) | (r << 16u32) | (g << 8u32) | b }

/* "label = VALUE  OK/FAIL" line.  ok: 0 none, 1 green OK, 2 red FAIL. */
fn line_kv(b: u64, w: u32, h: u32, x: u32, y: u32, lbl: u64, lln: u32, val: u32, ok: u32) -> i32 {
    let mut cx : u32 = ui_text_n(b, w, h, x, y, lbl, lln, rgb(150u32, 165u32, 190u32))
    cx = ui_text_u32(b, w, h, cx, y, val, rgb(238u32, 242u32, 250u32))
    if ok == 1u32 { ui_text_n(b, w, h, cx + 10u32, y, "OK" as u64, 2u32, rgb(40u32, 220u32, 95u32)) }
    if ok == 2u32 { ui_text_n(b, w, h, cx + 10u32, y, "FAIL" as u64, 4u32, rgb(235u32, 60u32, 70u32)) }
    return 0i32
}

fn okflag(v: i64, expect: i64) -> u32 { if v == expect { return 1u32 }  return 2u32 }

fn render(b: u64, w: u32, h: u32, n: i64, mx: u32, my: u32) -> i32 {
    ui_clear(b, w, h, rgb(10u32, 11u32, 16u32))
    ui_fill_rect(b, w, h, 0u32, 0u32, w, 28u32, rgb(22u32, 24u32, 38u32))
    ui_text_n(b, w, h, 10u32, 6u32, "III-GLASS  exact-coverage engine -- live, verified" as u64, 50u32, rgb(0u32, 229u32, 255u32))

    /* the shapes being measured, drawn by the exact-AA engine at the current n. */
    let cx : i64 = 180i64
    let cyc : i64 = 250i64
    let rr : i64 = 95i64
    ui_fill_circle_aa(b, w, h, cx, cyc, rr, rgb(0u32, 200u32, 255u32), n)
    ui_fill_tri_aa(b, w, h, 70i64, 410i64, 300i64, 410i64, 185i64, 300i64, rgb(255u32, 150u32, 40u32), n)

    /* the panel: III computes these every frame and checks them. */
    ui_fill_rect(b, w, h, 380u32, 40u32, 330u32, 380u32, rgb(15u32, 17u32, 26u32))
    ui_text_n(b, w, h, 392u32, 50u32, "self-check (recomputed each frame)" as u64, 34u32, rgb(120u32, 135u32, 165u32))
    let e  : i64 = ui_edge(0i64, 0i64, 10i64, 0i64, 5i64, 3i64)
    let tf : i64 = ui_tri_cov(0i64, 0i64, 100i64, 0i64, 0i64, 100i64, 10i64, 10i64, 4i64)
    let tr : i64 = ui_tri_cov(0i64, 0i64, 100i64, 0i64, 0i64, 100i64, 50i64, 49i64, 4i64)
    line_kv(b, w, h, 392u32, 78u32,  "edge det   = " as u64, 13u32, e as u32,  okflag(e, 30i64))
    line_kv(b, w, h, 392u32, 100u32, "tri full   = " as u64, 13u32, tf as u32, okflag(tf, 16i64))
    line_kv(b, w, h, 392u32, 122u32, "tri rim    = " as u64, 13u32, tr as u32, okflag(tr, 10i64))

    ui_text_n(b, w, h, 392u32, 160u32, "interactive" as u64, 11u32, rgb(120u32, 135u32, 165u32))
    line_kv(b, w, h, 392u32, 188u32, "render n   = " as u64, 13u32, n as u32, 0u32)
    /* exact coverage of the pixel under the cursor -- a real computation driven by your hand. */
    let cc : i64 = ui_circle_cov(cx, cyc, rr, mx as i64, my as i64, n)
    let mut cxp : u32 = ui_text_n(b, w, h, 392u32, 210u32, "cursor cov = " as u64, 13u32, rgb(150u32, 165u32, 190u32))
    cxp = ui_text_u32(b, w, h, cxp, 210u32, cc as u32, rgb(238u32, 242u32, 250u32))
    cxp = ui_text_n(b, w, h, cxp, 210u32, " / " as u64, 3u32, rgb(120u32, 135u32, 165u32))
    ui_text_u32(b, w, h, cxp, 210u32, (n * n) as u32, rgb(120u32, 135u32, 165u32))
    ui_text_n(b, w, h, 392u32, 240u32, "(over the disk: exact subsamples inside)" as u64, 40u32, rgb(90u32, 100u32, 125u32))

    ui_text_n(b, w, h, 392u32, 290u32, "[any key] n=1 (hard) <-> n=8 (smooth)" as u64, 37u32, rgb(150u32, 165u32, 190u32))
    ui_text_n(b, w, h, 392u32, 312u32, "[ESC] quit -- no float anywhere" as u64, 31u32, rgb(150u32, 165u32, 190u32))

    /* cursor crosshair */
    if mx < w { if my < h {
        ui_fill_rect(b, w, h, mx, my, 9u32, 2u32, rgb(255u32, 255u32, 255u32))
        ui_fill_rect(b, w, h, mx, my, 2u32, 9u32, rgb(255u32, 255u32, 255u32))
    } }
    return 0i32
}

fn main() -> u64 {
    ui_win_open(&TITLE as u64, 720u32, 440u32)
    let mut n : i64 = 8i64
    while ui_win_pump() == 0u32 {
        let k : u32 = ui_key()
        if k != 0u32 { if n == 8i64 { n = 1i64 } else { n = 8i64 } }
        render(&FB as u64, 720u32, 440u32, n, ui_mx(), ui_my())
        ui_win_present(&FB as u64, 720u32, 440u32)
        ui_sleep(16u32)
    }
    return 0u64
}
