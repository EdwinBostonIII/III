/* STDLIB/iii/aether/ui_home.iii -- III-GLASS Sovereign Workspace HOME: the one entry point that ties the whole
 * workspace together.  Each row is a real view; Enter SPAWNS its actual binary (CreateProcessA, the faculty the
 * KAT runner established) as its own live window.  Not a mockup of a launcher -- it launches the real exes that
 * stand in the III root.  up/down select, Enter launch, ESC quit. */
module ui_home

extern @abi(c-msvc-x64) fn ui_clear(buf: u64, w: u32, h: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_fill_rect(buf: u64, w: u32, h: u32, x: u32, y: u32, rw: u32, rh: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_text_n(buf: u64, w: u32, h: u32, x: u32, y: u32, str: u64, len: u32, color: u32) -> u32 from "ui_font.iii"
extern @abi(c-msvc-x64) fn ui_win_open(title: u64, w: u32, h: u32) -> u64 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_win_present(buf: u64, w: u32, h: u32) -> i32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_win_pump() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_key() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_sleep(ms: u32) -> i32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn CreateProcessA(appName: u64, cmdLine: u64, procAttr: u64, threadAttr: u64, inherit: u32, flags: u32, env: u64, curDir: u64, si: u64, pi: u64) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(handle: u64) -> u32 from "kernel32"

var FB    : [u32; 364800]   /* 760 x 480 */
var TITLE : [u8; 10] = [73u8,73u8,73u8,72u8,79u8,77u8,69u8,0u8,0u8,0u8]   /* "IIIHOME\0" */
var SI    : [u8; 104]
var PI    : [u8; 24]
var CMD0  : [u8; 13] = [122u8,111u8,111u8,109u8,46u8,101u8,120u8,101u8,0u8,0u8,0u8,0u8,0u8]                    /* zoom.exe */
var CMD1  : [u8; 17] = [115u8,99u8,117u8,108u8,112u8,116u8,111u8,114u8,46u8,101u8,120u8,101u8,0u8,0u8,0u8,0u8,0u8]   /* sculptor.exe */
var CMD2  : [u8; 16] = [100u8,101u8,115u8,116u8,105u8,110u8,121u8,46u8,101u8,120u8,101u8,0u8,0u8,0u8,0u8,0u8]   /* destiny.exe */
var CMD3  : [u8; 16] = [109u8,111u8,114u8,112u8,104u8,105u8,99u8,46u8,101u8,120u8,101u8,0u8,0u8,0u8,0u8,0u8]    /* morphic.exe */
var CMD4  : [u8; 15] = [101u8,103u8,114u8,97u8,112u8,104u8,46u8,101u8,120u8,101u8,0u8,0u8,0u8,0u8,0u8]          /* egraph.exe */
var CMD5  : [u8; 13] = [107u8,97u8,116u8,115u8,46u8,101u8,120u8,101u8,0u8,0u8,0u8,0u8,0u8]                      /* kats.exe */
var CMD6  : [u8; 13] = [116u8,111u8,112u8,111u8,46u8,101u8,120u8,101u8,0u8,0u8,0u8,0u8,0u8]                     /* topo.exe */
var LFAIL : u32 = 0u32   /* set when CreateProcessA returns 0 (e.g. launched from the wrong CWD) */

fn rgb(r: u32, g: u32, b: u32) -> u32 { return (255u32 << 24u32) | (r << 16u32) | (g << 8u32) | b }
fn w32(b: u64, o: u64, v: u32) -> i32 { let p : *u8 = (b + o) as *u8  p[0u64] = (v & 255u32) as u8  p[1u64] = ((v >> 8u32) & 255u32) as u8  p[2u64] = ((v >> 16u32) & 255u32) as u8  p[3u64] = ((v >> 24u32) & 255u32) as u8  return 0i32 }
fn rptr(b: u64, o: u64) -> u64 { let p : *u64 = (b + o) as *u64  return p[0u64] }
fn zero(b: u64, n: u64) -> i32 { let mut i : u64 = 0u64  while i < n { let p : *u8 = (b + i) as *u8  p[0u64] = 0u8  i = i + 1u64 }  return 0i32 }

fn spawn(cmd: u64) -> i32 {
    zero(&SI as u64, 104u64)  w32(&SI as u64, 0u64, 104u32)
    zero(&PI as u64, 24u64)
    let ok : u32 = CreateProcessA(0u64, cmd, 0u64, 0u64, 0u32, 0u32, 0u64, 0u64, &SI as u64, &PI as u64)
    if ok == 0u32 { LFAIL = 1u32  return 0i32 }   /* surface the failure (e.g. wrong CWD) instead of swallowing it */
    LFAIL = 0u32
    CloseHandle(rptr(&PI as u64, 0u64))  CloseHandle(rptr(&PI as u64, 8u64))
    return 0i32
}
fn launch(idx: u32) -> i32 {
    if idx == 0u32 { spawn(&CMD0 as u64) }
    if idx == 1u32 { spawn(&CMD1 as u64) }
    if idx == 2u32 { spawn(&CMD2 as u64) }
    if idx == 3u32 { spawn(&CMD3 as u64) }
    if idx == 4u32 { spawn(&CMD4 as u64) }
    if idx == 5u32 { spawn(&CMD5 as u64) }
    if idx == 6u32 { spawn(&CMD6 as u64) }
    return 0i32
}
fn row_label(b: u64, x: u32, y: u32, idx: u32, color: u32, dim: u32) -> i32 {
    if idx == 0u32 { ui_text_n(b, 760u32, 480u32, x, y, "Infinite Semantic Zoom" as u64, 22u32, color)  ui_text_n(b, 760u32, 480u32, x + 250u32, y, "exact camera, vector text, LOD" as u64, 30u32, dim) }
    if idx == 1u32 { ui_text_n(b, 760u32, 480u32, x, y, "Constraint Sculptor" as u64, 19u32, color)  ui_text_n(b, 760u32, 480u32, x + 250u32, y, "cov/tri/edge/mod/disj -- real provers" as u64, 37u32, dim) }
    if idx == 2u32 { ui_text_n(b, 760u32, 480u32, x, y, "Holographic Destiny" as u64, 19u32, color)  ui_text_n(b, 760u32, 480u32, x + 250u32, y, "sd_denote closed-form image" as u64, 27u32, dim) }
    if idx == 3u32 { ui_text_n(b, 760u32, 480u32, x, y, "Morphic Editing" as u64, 15u32, color)  ui_text_n(b, 760u32, 480u32, x + 250u32, y, "drag rewrites SVIR, re-proves live" as u64, 34u32, dim) }
    if idx == 4u32 { ui_text_n(b, 760u32, 480u32, x, y, "E-graph (live)" as u64, 14u32, color)  ui_text_n(b, 760u32, 480u32, x + 250u32, y, "type N, x*N re-saturates" as u64, 24u32, dim) }
    if idx == 5u32 { ui_text_n(b, 760u32, 480u32, x, y, "Live KAT Runner" as u64, 15u32, color)  ui_text_n(b, 760u32, 480u32, x + 250u32, y, "spawn real binaries, real exit codes" as u64, 36u32, dim) }
    if idx == 6u32 { ui_text_n(b, 760u32, 480u32, x, y, "Topological Window" as u64, 18u32, color)  ui_text_n(b, 760u32, 480u32, x + 250u32, y, "Pixel=f(x,y,t) closed form, no leak" as u64, 35u32, dim) }
    return 0i32
}

fn render(b: u64, sel: u32) -> i32 {
    ui_clear(b, 760u32, 480u32, rgb(9u32, 10u32, 15u32))
    ui_fill_rect(b, 760u32, 480u32, 0u32, 0u32, 760u32, 30u32, rgb(22u32, 24u32, 38u32))
    ui_text_n(b, 760u32, 480u32, 12u32, 7u32, "III-GLASS  Sovereign Workspace -- one substrate: math, compiler, rasteriser" as u64, 74u32, rgb(0u32, 229u32, 255u32))
    let mut i : u32 = 0u32
    while i < 7u32 {
        let yy : u32 = 60u32 + i * 50u32
        let mut nc : u32 = rgb(220u32,228u32,240u32)
        if i == sel { ui_fill_rect(b, 760u32, 480u32, 24u32, yy - 10u32, 712u32, 44u32, rgb(26u32,34u32,52u32))
                      ui_fill_rect(b, 760u32, 480u32, 24u32, yy - 10u32, 4u32, 44u32, rgb(0u32,229u32,255u32))
                      nc = rgb(0u32,229u32,255u32) }
        row_label(b, 44u32, yy, i, nc, rgb(110u32,122u32,148u32))
        i = i + 1u32
    }
    ui_text_n(b, 760u32, 480u32, 24u32, 432u32, "[up/down] select   [Enter] launch the real view   [ESC] quit" as u64, 60u32, rgb(95u32,105u32,130u32))
    if LFAIL == 1u32 { ui_text_n(b, 760u32, 480u32, 24u32, 408u32, "launch failed -- run home.exe from the III root (relative exe paths)" as u64, 67u32, rgb(235u32,120u32,90u32)) }
    return 0i32
}

fn main() -> u64 {
    ui_win_open(&TITLE as u64, 760u32, 480u32)
    let mut sel : u32 = 0u32
    while ui_win_pump() == 0u32 {
        let k : u32 = ui_key()
        if k == 38u32 { if sel > 0u32 { sel = sel - 1u32 } }
        if k == 40u32 { if sel < 6u32 { sel = sel + 1u32 } }
        if k == 13u32 { launch(sel) }
        render(&FB as u64, sel)
        ui_win_present(&FB as u64, 760u32, 480u32)
        ui_sleep(16u32)
    }
    return 0u64
}
