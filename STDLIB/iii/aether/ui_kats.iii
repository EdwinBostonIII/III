/* STDLIB/iii/aether/ui_kats.iii -- III-GLASS live KAT runner: the most literal "tell me about the system".  It
 * does NOT hardcode pass/fail -- it SPAWNS the real prebuilt corpus binaries (CreateProcessA), waits, and reads
 * each one's ACTUAL exit code (GetExitCodeProcess).  Green PASS means the real process really returned 99 just
 * now; red FAIL would mean it didn't.  up/down select, Enter runs the selected KAT, 'a' runs all.  This also
 * gives III a real process-spawn faculty.  No fakery: the codes are read from the OS. */
module ui_kats

extern @abi(c-msvc-x64) fn ui_clear(buf: u64, w: u32, h: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_fill_rect(buf: u64, w: u32, h: u32, x: u32, y: u32, rw: u32, rh: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_text_n(buf: u64, w: u32, h: u32, x: u32, y: u32, str: u64, len: u32, color: u32) -> u32 from "ui_font.iii"
extern @abi(c-msvc-x64) fn ui_text_u32(buf: u64, w: u32, h: u32, x: u32, y: u32, v: u32, color: u32) -> u32 from "ui_font.iii"
extern @abi(c-msvc-x64) fn ui_win_open(title: u64, w: u32, h: u32) -> u64 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_win_present(buf: u64, w: u32, h: u32) -> i32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_win_pump() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_key() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_sleep(ms: u32) -> i32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn CreateProcessA(appName: u64, cmdLine: u64, procAttr: u64, threadAttr: u64, inherit: u32, flags: u32, env: u64, curDir: u64, si: u64, pi: u64) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn WaitForSingleObject(handle: u64, ms: u32) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn GetExitCodeProcess(handle: u64, codePtr: u64) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(handle: u64) -> u32 from "kernel32"

var FB     : [u32; 364800]   /* 760 x 480 */
var TITLE  : [u8; 10] = [73u8,73u8,73u8,75u8,65u8,84u8,83u8,0u8,0u8,0u8]   /* "IIIKATS\0" */
var SI     : [u8; 104]   /* STARTUPINFOA */
var PI     : [u8; 24]    /* PROCESS_INFORMATION: hProcess@0 hThread@8 */
var CODE   : [u8; 8]
var CMDBUF : [u8; 64]
var PREFIX : [u8; 18] = [83u8,84u8,68u8,76u8,73u8,66u8,92u8,98u8,117u8,105u8,108u8,100u8,92u8,107u8,97u8,116u8,115u8,92u8]   /* "STDLIB\build\kats\" */
var KNUM   : [u64; 4] = [2081u64, 2082u64, 2083u64, 2084u64]
var KACT   : [u32; 4]    /* actual exit code from the last run */
var KRUN   : [u32; 4]    /* 0 = not run, 1 = run */

fn rgb(r: u32, g: u32, b: u32) -> u32 { return (255u32 << 24u32) | (r << 16u32) | (g << 8u32) | b }
fn w32(b: u64, o: u64, v: u32) -> i32 { let p : *u8 = (b + o) as *u8  p[0u64] = (v & 255u32) as u8  p[1u64] = ((v >> 8u32) & 255u32) as u8  p[2u64] = ((v >> 16u32) & 255u32) as u8  p[3u64] = ((v >> 24u32) & 255u32) as u8  return 0i32 }
fn r32(b: u64, o: u64) -> u32 { let p : *u8 = (b + o) as *u8  return (p[0u64] as u32) | ((p[1u64] as u32) << 8u32) | ((p[2u64] as u32) << 16u32) | ((p[3u64] as u32) << 24u32) }
fn rptr(b: u64, o: u64) -> u64 { let p : *u64 = (b + o) as *u64  return p[0u64] }
fn zero(b: u64, n: u64) -> i32 { let mut i : u64 = 0u64  while i < n { let p : *u8 = (b + i) as *u8  p[0u64] = 0u8  i = i + 1u64 }  return 0i32 }

/* "STDLIB\build\kats\NNNN.exe\0" into CMDBUF for the 4-digit KAT number. */
fn build_path(num: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < 18u64 { CMDBUF[i] = PREFIX[i]  i = i + 1u64 }
    CMDBUF[18u64] = ((((num / 1000u64) % 10u64) as u8)) + 48u8
    CMDBUF[19u64] = ((((num / 100u64) % 10u64) as u8)) + 48u8
    CMDBUF[20u64] = ((((num / 10u64) % 10u64) as u8)) + 48u8
    CMDBUF[21u64] = (((num % 10u64) as u8)) + 48u8
    CMDBUF[22u64] = 46u8  CMDBUF[23u64] = 101u8  CMDBUF[24u64] = 120u8  CMDBUF[25u64] = 101u8  CMDBUF[26u64] = 0u8
    return 0i32
}

/* SPAWN the real binary; return its true exit code (or 0xFFFFFFFF if launch failed). */
fn run_kat(num: u64) -> u32 {
    build_path(num)
    zero(&SI as u64, 104u64)
    w32(&SI as u64, 0u64, 104u32)          /* STARTUPINFOA.cb */
    zero(&PI as u64, 24u64)
    let ok : u32 = CreateProcessA(0u64, &CMDBUF as u64, 0u64, 0u64, 0u32, 134217728u32, 0u64, 0u64, &SI as u64, &PI as u64)  /* CREATE_NO_WINDOW */
    if ok == 0u32 { return 4294967295u32 }
    let hproc : u64 = rptr(&PI as u64, 0u64)
    WaitForSingleObject(hproc, 30000u32)
    GetExitCodeProcess(hproc, &CODE as u64)
    let code : u32 = r32(&CODE as u64, 0u64)
    CloseHandle(hproc)
    CloseHandle(rptr(&PI as u64, 8u64))
    return code
}

fn kat_name(b: u64, x: u32, y: u32, idx: u32, color: u32) -> i32 {
    if idx == 0u32 { ui_text_n(b, 760u32, 480u32, x, y, "ui_exact   (exact-integer AA coverage)" as u64, 38u32, color) }
    if idx == 1u32 { ui_text_n(b, 760u32, 480u32, x, y, "ui_font    (vector/bitmap glyph blit)" as u64, 37u32, color) }
    if idx == 2u32 { ui_text_n(b, 760u32, 480u32, x, y, "egraph     (saturation found shift-sub)" as u64, 39u32, color) }
    if idx == 3u32 { ui_text_n(b, 760u32, 480u32, x, y, "disjoint   (alias prover, sound)" as u64, 32u32, color) }
    return 0i32
}

fn render(b: u64, sel: u32, busy: u32) -> i32 {
    ui_clear(b, 760u32, 480u32, rgb(10u32, 11u32, 16u32))
    ui_fill_rect(b, 760u32, 480u32, 0u32, 0u32, 760u32, 28u32, rgb(22u32, 24u32, 38u32))
    ui_text_n(b, 760u32, 480u32, 10u32, 6u32, "III-GLASS  live KAT runner -- real corpus binaries, real exit codes" as u64, 66u32, rgb(0u32, 229u32, 255u32))
    ui_text_n(b, 760u32, 480u32, 30u32, 52u32, "KAT" as u64, 3u32, rgb(110u32,125u32,150u32))
    ui_text_n(b, 760u32, 480u32, 430u32, 52u32, "expect" as u64, 6u32, rgb(110u32,125u32,150u32))
    ui_text_n(b, 760u32, 480u32, 540u32, 52u32, "actual" as u64, 6u32, rgb(110u32,125u32,150u32))
    ui_text_n(b, 760u32, 480u32, 650u32, 52u32, "verdict" as u64, 7u32, rgb(110u32,125u32,150u32))

    let mut i : u32 = 0u32
    while i < 4u32 {
        let yy : u32 = 80u32 + i * 40u32
        if i == sel { ui_fill_rect(b, 760u32, 480u32, 20u32, yy - 6u32, 720u32, 34u32, rgb(24u32,30u32,46u32)) }
        let mut nx : u32 = ui_text_u32(b, 760u32, 480u32, 30u32, yy, KNUM[i as u64] as u32, rgb(235u32,240u32,250u32))
        kat_name(b, nx + 16u32, yy, i, rgb(150u32,165u32,190u32))
        ui_text_u32(b, 760u32, 480u32, 440u32, yy, 99u32, rgb(150u32,165u32,190u32))
        if KRUN[i as u64] == 0u32 { ui_text_n(b, 760u32, 480u32, 550u32, yy, "--" as u64, 2u32, rgb(110u32,120u32,140u32)) }
        if KRUN[i as u64] == 1u32 {
            let act : u32 = KACT[i as u64]
            let mut vc : u32 = rgb(235u32,60u32,70u32)
            if act == 99u32 { vc = rgb(40u32,220u32,95u32) }
            ui_text_u32(b, 760u32, 480u32, 550u32, yy, act, vc)
            if act == 99u32 { ui_text_n(b, 760u32, 480u32, 650u32, yy, "PASS" as u64, 4u32, vc) }
            if act != 99u32 { ui_text_n(b, 760u32, 480u32, 650u32, yy, "FAIL" as u64, 4u32, vc) }
        }
        i = i + 1u32
    }

    ui_fill_rect(b, 760u32, 480u32, 0u32, 300u32, 760u32, 2u32, rgb(40u32,44u32,60u32))
    if busy == 1u32 { ui_text_n(b, 760u32, 480u32, 30u32, 320u32, "spawning real process ... (CreateProcessA -> WaitForSingleObject -> GetExitCodeProcess)" as u64, 86u32, rgb(255u32,210u32,80u32)) }
    ui_text_n(b, 760u32, 480u32, 30u32, 430u32, "[up/down] select   [Enter] run selected   [A] run all   [ESC] quit" as u64, 66u32, rgb(95u32,105u32,130u32))
    return 0i32
}

fn main() -> u64 {
    ui_win_open(&TITLE as u64, 760u32, 480u32)
    let mut sel : u32 = 0u32
    while ui_win_pump() == 0u32 {
        let k : u32 = ui_key()
        if k == 38u32 { if sel > 0u32 { sel = sel - 1u32 } }       /* up */
        if k == 40u32 { if sel < 3u32 { sel = sel + 1u32 } }       /* down */
        if k == 13u32 {                                            /* Enter: run selected */
            render(&FB as u64, sel, 1u32)  ui_win_present(&FB as u64, 760u32, 480u32)
            KACT[sel as u64] = run_kat(KNUM[sel as u64])  KRUN[sel as u64] = 1u32
        }
        if k == 65u32 {                                            /* A: run all */
            let mut j : u32 = 0u32
            while j < 4u32 {
                render(&FB as u64, j, 1u32)  ui_win_present(&FB as u64, 760u32, 480u32)
                KACT[j as u64] = run_kat(KNUM[j as u64])  KRUN[j as u64] = 1u32
                j = j + 1u32
            }
        }
        render(&FB as u64, sel, 0u32)
        ui_win_present(&FB as u64, 760u32, 480u32)
        ui_sleep(16u32)
    }
    return 0u64
}
