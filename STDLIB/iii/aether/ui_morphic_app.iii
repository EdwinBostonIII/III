/* STDLIB/iii/aether/ui_morphic_app.iii -- the WINDOW SHELL for ui_morphic (reunification W4b-i.11
 * split: the autopoietic core + render live in ui_morphic.iii, gated headless by corpus 2473; this
 * shim owns only the window loop, so the core links into KATs with no user32 dependency). */
module ui_morphic_app

extern @abi(c-msvc-x64) fn um_edit_c(c: u64) -> u32 from "ui_morphic.iii"
extern @abi(c-msvc-x64) fn um_relift() -> u32 from "ui_morphic.iii"
extern @abi(c-msvc-x64) fn um_render(b: u64, w: u32, h: u32, c: u64, proven: u32, node: u32) -> i32 from "ui_morphic.iii"
extern @abi(c-msvc-x64) fn um_fb() -> u64 from "ui_morphic.iii"
extern @abi(c-msvc-x64) fn um_title() -> u64 from "ui_morphic.iii"
extern @abi(c-msvc-x64) fn ui_win_open(title: u64, w: u32, h: u32) -> u64 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_win_present(buf: u64, w: u32, h: u32) -> i32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_win_pump() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_mx() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_my() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_mdown() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn ui_sleep(ms: u32) -> i32 from "ui_win.iii"

fn main() -> u64 {
    ui_win_open(um_title(), 760u32, 480u32)
    let mut c : u64 = 12u64
    let mut proven : u32 = 0u32
    let mut node : u32 = 0u32
    let mut dirty : u32 = 1u32
    while ui_win_pump() == 0u32 {
        /* drag -> set C from cursor -> mark dirty (edit the source). */
        if ui_mdown() == 1u32 {
            let my : u32 = ui_my()
            if my >= 400u32 { if my <= 436u32 {
                let mx : u32 = ui_mx()
                let mut nc : i64 = (((mx as i64) - 60i64) * 64i64) / 500i64
                if nc < 0i64 { nc = 0i64 }
                if nc > 64i64 { nc = 64i64 }
                if (nc as u64) != c { c = nc as u64  dirty = 1u32 }
            } }
        }
        if dirty == 1u32 {
            /* AUTOPOIETIC EDIT: the same headless core the gate (2473) drives. */
            proven = um_edit_c(c)
            node = um_relift()
            dirty = 0u32
        }
        um_render(um_fb(), 760u32, 480u32, c, proven, node)
        ui_win_present(um_fb(), 760u32, 480u32)
        ui_sleep(16u32)
    }
    return 0u64
}
