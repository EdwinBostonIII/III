/* STDLIB/iii/aether/witness_cli.iii -- iii-witness: THE STRANGER'S TESTAMENT VERIFIER (AUTARKEIA Alpha-1).
 *
 *   iii-witness verify <testament.dat> [pkpin|none] [parent|none] [root|none] [manifest|none]
 *
 * TWO HONEST TIERS:
 *   TIER-1 (minutes, NO toolchain): format + SLH-DSA signature + (optional) key pin + (optional)
 *          generation link to a parent + monotone law.  A stranger runs this on a bare host.
 *          `iii-witness verify testament.dat pk.bin`                    -- signature + key pin
 *          `iii-witness verify testament.dat pk.bin parent.dat`         -- + generation chain
 *   TIER-1+ (still no build, re-derives the record chains from committed bytes) and the FULL
 *          re-derivation against the tree when <root> + <manifest> are supplied:
 *          `iii-witness verify testament.dat pk.bin parent.dat . STDLIB/testament/MANIFEST.txt`
 *          recomputes the TREE Merkle root, every SEED/TOOL/SPORE/EXEC digest, the MATHESIS
 *          record digests + pinned heads, the FORGE chain re-walk, and the RADICAL certificate.
 *
 * EXIT (distinct per tamper class): 0 GREEN | 2 file | 10 format | 11 signature/key-pin |
 *   12 generation link | 13 semantic re-derivation | 14 tree root | 15 monotone law.
 * The verifier trusts NOTHING it is handed: every claim re-derives from the testament's own bytes
 * (Tier-1) or from the committed tree (full).  Its own trust root is the SVIR waist (a 374-line
 * verify+interp a stranger can audit or reimplement), the DDC lineage, the three meaning-bearers,
 * and previous-generation pinning -- see DOCS/III-AUTARKEIA-MAP.md Alpha-1.
 *
 * Hexad: kind_essence.  Ring: R0.  NIH: composes aether/testament.
 */
module witness_cli

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn tw_verify(datp: u64, pkpin: u64, parentp: u64, root: u64, manp: u64) -> u64 from "testament.iii"

fn ps(s: u64) -> u32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { putchar(p[i] as i32)  i = i + 1u64 }
    return 1u32
}
fn streq(a: u64, b: u64) -> u32 {
    let pa : *u8 = a as *u8
    let pb : *u8 = b as *u8
    let mut i : u64 = 0u64
    while pa[i] != 0u8 {
        if pa[i] != pb[i] { return 0u32 }
        i = i + 1u64
    }
    if pb[i] != 0u8 { return 0u32 }
    return 1u32
}
fn argopt(av: *u64, argc: i32, idx: i32) -> u64 {
    if argc <= idx { return 0u64 }
    let a : u64 = av[idx as u64]
    if streq(a, "none" as u64) == 1u32 { return 0u64 }
    return a
}

fn witness_enter(argc: i32, argv: u64) -> u64 @export {
    if argc < 3i32 {
        ps("iii-witness verify <testament.dat> [pkpin|none] [parent|none] [root|none] [manifest|none]\n" as u64)
        return 1u64
    }
    let av : *u64 = argv as *u64
    if streq(av[1u64], "verify" as u64) == 0u32 {
        ps("iii-witness: unknown command (only `verify`)\n" as u64)
        return 1u64
    }
    let datp   : u64 = av[2u64]
    let pkpin  : u64 = argopt(av, argc, 3i32)
    let parentp: u64 = argopt(av, argc, 4i32)
    let root   : u64 = argopt(av, argc, 5i32)
    let manp   : u64 = argopt(av, argc, 6i32)
    if root != 0u64 { if manp == 0u64 {
        ps("iii-witness: <root> given without <manifest> -- both required for full re-derivation\n" as u64)
        return 1u64
    } }
    /* bind the verdict, name it, return it: exit 0 = VALID, nonzero = a tamper class.
     * The two outcomes (== 0 valid / != 0 refused) make the verifier's discrimination
     * visible in-source, not only in the process exit code. */
    let tv : u64 = tw_verify(datp, pkpin, parentp, root, manp)
    if tv == 0u64 { ps("iii-witness: VALID -- the testament verified against its pins\n" as u64) }
    if tv != 0u64 { ps("iii-witness: REFUSED -- the exit code names the tamper class\n" as u64) }
    return tv
}
