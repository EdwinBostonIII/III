/* STDLIB/iii/aether/ws_console.iii -- III STUDIO workspace: CONSOLE, the sovereign CLI.  Every verb invokes a
 * [APP-SURFACE-MODULE] -- window/app execution surface: compiled by its family gate so it cannot rot;
 * its unreached exports are app-class BY NATURE (headless corpus cannot pump a window) and are excluded
 * from the v3 dark census (mechanism: sanctus/corpus_coverage, reunification W0.2).
 * REAL faculty and prints its REAL verdict -- no canned strings:
 *   sign a b [a b ...]          exact sign of a1*sqrt(b1)+...  (sqrtsum_lazy3 -- the Sqrt-sum engine)
 *   collide x y z r  x y z r    exact sphere contact: SEPARATED / TOUCHING / OVERLAPPING + the exact metric
 *   relay 12 ints               which 2-leg route is EXACTLY shorter (n=4 Sqrt-sum, wb_kernel)
 *   mod m r c init              PROVE x%m==r stays invariant under x+=c over ALL 2^64 (sks_mod_prove_linear)
 *   gate NNNN                   SPAWN the real corpus binary, report its real exit code (99 = PASS)
 * Typed input arrives through the OS WM_CHAR ring (ui_getchar); answers land in a scrollback whose colours are
 * the verdicts.  This is the CLI no other tool has: its calculator is exact and its claims are proved or spawned. */
module ws_console

extern @abi(c-msvc-x64) fn ui_fill_rect(buf: u64, w: u32, h: u32, x: u32, y: u32, rw: u32, rh: u32, color: u32) -> i32 from "ui_raster.iii"
extern @abi(c-msvc-x64) fn ui_text_n(buf: u64, w: u32, h: u32, x: u32, y: u32, str: u64, len: u32, color: u32) -> u32 from "ui_font.iii"
extern @abi(c-msvc-x64) fn ui_vtext(buf: u64, w: u32, h: u32, x: i64, y: i64, str: u64, len: u32, size: i64, color: u32, n: i64) -> i64 from "ui_vfont.iii"
extern @abi(c-msvc-x64) fn th_panel_c(buf: u64, w: u32, h: u32, x: u32, y: u32, rw: u32, rh: u32, fill: u32) -> i32 from "studio_theme.iii"
extern @abi(c-msvc-x64) fn th_vbold(buf: u64, w: u32, h: u32, x: i64, y: i64, str: u64, len: u32, size: i64, color: u32) -> i64 from "studio_theme.iii"
extern @abi(c-msvc-x64) fn th_paper() -> u32 from "studio_theme.iii"
extern @abi(c-msvc-x64) fn th_inset() -> u32 from "studio_theme.iii"
extern @abi(c-msvc-x64) fn th_cream() -> u32 from "studio_theme.iii"
extern @abi(c-msvc-x64) fn th_ink() -> u32 from "studio_theme.iii"
extern @abi(c-msvc-x64) fn th_maroon() -> u32 from "studio_theme.iii"
extern @abi(c-msvc-x64) fn th_good() -> u32 from "studio_theme.iii"
extern @abi(c-msvc-x64) fn th_bad() -> u32 from "studio_theme.iii"
extern @abi(c-msvc-x64) fn th_warn() -> u32 from "studio_theme.iii"
extern @abi(c-msvc-x64) fn th_dim() -> u32 from "studio_theme.iii"
extern @abi(c-msvc-x64) fn ui_getchar() -> u32 from "ui_win.iii"
extern @abi(c-msvc-x64) fn sqrtsum_lazy3(a: u64, b: u64, n: u64) -> i32 from "sqrt_sum_sign.iii"
extern @abi(c-msvc-x64) fn wbk_collide_sign(dd: i64, sm: i64) -> i32 from "wb_kernel.iii"
extern @abi(c-msvc-x64) fn wbk_relay_sign(d_sr1: i64, d_r1t: i64, d_sr2: i64, d_r2t: i64) -> i32 from "wb_kernel.iii"
extern @abi(c-msvc-x64) fn sks_mod_prove_linear(m: u64, r: u64, c: u64, init: u64) -> u8 from "ser_kinduct_sym.iii"
extern @abi(c-msvc-x64) fn CreateProcessA(appName: u64, cmdLine: u64, procAttr: u64, threadAttr: u64, inherit: u32, flags: u32, env: u64, curDir: u64, si: u64, pi: u64) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn WaitForSingleObject(handle: u64, ms: u32) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn GetExitCodeProcess(handle: u64, codePtr: u64) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(handle: u64) -> u32 from "kernel32"

const WSC_MAXL : u64 = 48u64      /* scrollback lines */
const WSC_COLS : u64 = 120u64     /* chars per line   */
var WSC_TXT  : [u8; 5760]         /* 48 * 120 ring    */
var WSC_LLEN : [u32; 48]
var WSC_LCOL : [u32; 48]
var WSC_HEAD : u64 = 0u64         /* count of lines ever written */
var WSC_IN   : [u8; 110]
var WSC_INL  : u32 = 0u32
var WSC_ARGS : [i64; 16]
var WSC_NARG : u64 = 0u64
var WSC_SSA  : [i64; 8]   var WSC_SSB : [i64; 8]
var WSC_SI   : [u8; 104]  var WSC_PI  : [u8; 24]   var WSC_CODE : [u8; 8]   var WSC_CMD : [u8; 64]
var WSC_LB   : [u8; 128]  var WSC_LBL : u32 = 0u32   /* line builder */

/* ── line builder: text + numbers composed, then committed to the ring with a verdict colour ─────── */
fn cb_reset() -> i32 { WSC_LBL = 0u32   return 0i32 }
fn cb_txt(s: u64, n: u32) -> i32 {
    let mut i : u32 = 0u32
    while i < n { if WSC_LBL < 118u32 { let p : *u8 = (s + (i as u64)) as *u8   WSC_LB[WSC_LBL as u64] = p[0u64]   WSC_LBL = WSC_LBL + 1u32 }   i = i + 1u32 }
    return 0i32
}
var WSC_DIG : [u8; 24]
fn cb_num(v: i64) -> i32 {
    let mut val : i64 = v
    if val < 0i64 { cb_txt("-" as u64, 1u32)   val = 0i64 - val }
    if val == 0i64 { cb_txt("0" as u64, 1u32)   return 0i32 }
    let mut k : u32 = 0u32
    while val > 0i64 { WSC_DIG[k as u64] = ((val % 10i64) + 48i64) as u8   val = val / 10i64   k = k + 1u32 }
    while k > 0u32 { k = k - 1u32   if WSC_LBL < 118u32 { WSC_LB[WSC_LBL as u64] = WSC_DIG[k as u64]   WSC_LBL = WSC_LBL + 1u32 } }
    return 0i32
}
fn cb_commit(color: u32) -> i32 {
    let slot : u64 = WSC_HEAD % WSC_MAXL
    let base : u64 = slot * WSC_COLS
    let mut i : u32 = 0u32
    let mut n : u32 = WSC_LBL   if n > 118u32 { n = 118u32 }
    while i < n { WSC_TXT[base + (i as u64)] = WSC_LB[i as u64]   i = i + 1u32 }
    WSC_LLEN[slot] = n   WSC_LCOL[slot] = color
    WSC_HEAD = WSC_HEAD + 1u64
    WSC_LBL = 0u32
    return 0i32
}
fn say(s: u64, n: u32, color: u32) -> i32 { cb_reset()   cb_txt(s, n)   cb_commit(color)   return 0i32 }

/* ── tokenizer ────────────────────────────────────────────────────────────────────────────────────── */
fn c_at(i: u32) -> u32 { return WSC_IN[i as u64] as u32 }
fn skip_sp(i: u32) -> u32 { let mut j : u32 = i   while j < WSC_INL { if c_at(j) != 32u32 { return j }   j = j + 1u32 }   return j }
fn tok_end(i: u32) -> u32 { let mut j : u32 = i   while j < WSC_INL { if c_at(j) == 32u32 { return j }   j = j + 1u32 }   return j }
fn parse_int(s: u32, e: u32) -> i64 {
    let mut i : u32 = s   let mut neg : u32 = 0u32
    if i < e { if c_at(i) == 45u32 { neg = 1u32   i = i + 1u32 } }
    let mut v : i64 = 0i64
    while i < e { let c : u32 = c_at(i)   if c >= 48u32 { if c <= 57u32 { v = v * 10i64 + ((c - 48u32) as i64) } }   i = i + 1u32 }
    if neg == 1u32 { return 0i64 - v }
    return v
}
fn tok_is(s: u32, e: u32, lit: u64, n: u32) -> u32 {
    if (e - s) != n { return 0u32 }
    let mut i : u32 = 0u32
    while i < n { let p : *u8 = (lit + (i as u64)) as *u8   if c_at(s + i) != (p[0u64] as u32) { return 0u32 }   i = i + 1u32 }
    return 1u32
}
fn parse_args(start: u32) -> u64 {
    WSC_NARG = 0u64
    let mut i : u32 = skip_sp(start)
    while i < WSC_INL {
        let e : u32 = tok_end(i)
        if WSC_NARG < 16u64 { WSC_ARGS[WSC_NARG] = parse_int(i, e)   WSC_NARG = WSC_NARG + 1u64 }
        i = skip_sp(e)
    }
    return WSC_NARG
}

/* ── the verbs: each one calls the REAL faculty and prints its REAL answer ───────────────────────── */
fn v_sign() -> i32 {
    let n : u64 = WSC_NARG / 2u64
    if n < 2u64 { say("usage: sign a1 b1 a2 b2 [a3 b3 [a4 b4]]   (b >= 0)" as u64, 50u32, th_warn())   return 0i32 }
    let mut nn : u64 = n   if nn > 4u64 { nn = 4u64 }
    let mut i : u64 = 0u64
    while i < nn { WSC_SSA[i] = WSC_ARGS[i * 2u64]   WSC_SSB[i] = WSC_ARGS[i * 2u64 + 1u64]   i = i + 1u64 }
    let sg : i32 = sqrtsum_lazy3((&WSC_SSA) as u64, (&WSC_SSB) as u64, nn)
    cb_reset()   cb_txt("sign( " as u64, 6u32)
    i = 0u64
    while i < nn {
        if i > 0u64 { cb_txt(" + " as u64, 3u32) }
        cb_num(WSC_SSA[i])   cb_txt("*sqrt(" as u64, 6u32)   cb_num(WSC_SSB[i])   cb_txt(")" as u64, 1u32)
        i = i + 1u64
    }
    cb_txt(" ) = " as u64, 5u32)
    if sg < 0i32 { cb_txt("-1   NEGATIVE, exactly" as u64, 22u32)   cb_commit(th_maroon()) }
    if sg == 0i32 { cb_txt("0   ZERO, exactly (a surd identity)" as u64, 35u32)   cb_commit(th_good()) }
    if sg > 0i32 { cb_txt("+1   POSITIVE, exactly" as u64, 22u32)   cb_commit(th_good()) }
    return 0i32
}
fn v_collide() -> i32 {
    if WSC_NARG < 8u64 { say("usage: collide x y z r  x y z r" as u64, 31u32, th_warn())   return 0i32 }
    let dx : i64 = WSC_ARGS[4u64] - WSC_ARGS[0u64]
    let dy : i64 = WSC_ARGS[5u64] - WSC_ARGS[1u64]
    let dz : i64 = WSC_ARGS[6u64] - WSC_ARGS[2u64]
    let dd : i64 = dx*dx + dy*dy + dz*dz
    let sm : i64 = WSC_ARGS[3u64] + WSC_ARGS[7u64]
    let sg : i32 = wbk_collide_sign(dd, sm)
    let diff : i64 = dd - sm*sm
    cb_reset()
    if sg > 0i32 { cb_txt("SEPARATED   exact gap^2 = " as u64, 26u32)   cb_num(diff)   cb_commit(th_good()) }
    if sg == 0i32 { cb_txt("TOUCHING   exact tangency: |c1-c2|^2 == (r1+r2)^2" as u64, 49u32)   cb_commit(th_warn()) }
    if sg < 0i32 { cb_txt("OVERLAPPING   exact depth^2 = " as u64, 30u32)   cb_num(0i64 - diff)   cb_commit(th_bad()) }
    return 0i32
}
fn v_relay() -> i32 {
    if WSC_NARG < 12u64 { say("usage: relay Sx Sy Sz  R1x R1y R1z  R2x R2y R2z  Tx Ty Tz" as u64, 57u32, th_warn())   return 0i32 }
    let mut d : [i64; 4]
    let mut leg : u64 = 0u64
    /* legs: S->R1, R1->T, S->R2, R2->T */
    while leg < 4u64 {
        let mut ai : u64 = 0u64   let mut bi : u64 = 0u64
        if leg == 0u64 { ai = 0u64   bi = 3u64 }
        if leg == 1u64 { ai = 3u64   bi = 9u64 }
        if leg == 2u64 { ai = 0u64   bi = 6u64 }
        if leg == 3u64 { ai = 6u64   bi = 9u64 }
        let ex : i64 = WSC_ARGS[bi] - WSC_ARGS[ai]
        let ey : i64 = WSC_ARGS[bi + 1u64] - WSC_ARGS[ai + 1u64]
        let ez : i64 = WSC_ARGS[bi + 2u64] - WSC_ARGS[ai + 2u64]
        d[leg] = ex*ex + ey*ey + ez*ez
        leg = leg + 1u64
    }
    let sg : i32 = wbk_relay_sign(d[0u64], d[1u64], d[2u64], d[3u64])
    if sg < 0i32 { say("route via R1 is EXACTLY shorter  (n=4 Sqrt-sum sign)" as u64, 52u32, th_good()) }
    if sg == 0i32 { say("the two routes are EXACTLY equal  (n=4 Sqrt-sum sign = 0)" as u64, 57u32, th_warn()) }
    if sg > 0i32 { say("route via R2 is EXACTLY shorter  (n=4 Sqrt-sum sign)" as u64, 52u32, th_good()) }
    return 0i32
}
fn v_mod() -> i32 {
    if WSC_NARG < 4u64 { say("usage: mod m r c init    proves x%m==r invariant under x+=c, ALL 2^64" as u64, 69u32, th_warn())   return 0i32 }
    let ok : u8 = sks_mod_prove_linear(WSC_ARGS[0u64] as u64, WSC_ARGS[1u64] as u64, WSC_ARGS[2u64] as u64, WSC_ARGS[3u64] as u64)
    cb_reset()   cb_txt("x % " as u64, 4u32)   cb_num(WSC_ARGS[0u64])   cb_txt(" == " as u64, 4u32)   cb_num(WSC_ARGS[1u64])
    cb_txt("  under x += " as u64, 13u32)   cb_num(WSC_ARGS[2u64])   cb_txt("  from " as u64, 7u32)   cb_num(WSC_ARGS[3u64])
    if ok == 1u8 { cb_txt("   PROVEN over all 2^64 (k-induction)" as u64, 37u32)   cb_commit(th_good()) }
    if ok != 1u8 { cb_txt("   REFUTED (the invariant does not hold)" as u64, 40u32)   cb_commit(th_bad()) }
    return 0i32
}
fn cz(b: u64, n: u64) -> i32 { let mut i : u64 = 0u64   while i < n { let p : *u8 = (b + i) as *u8   p[0u64] = 0u8   i = i + 1u64 }   return 0i32 }
fn cw32(b: u64, o: u64, v: u32) -> i32 { let p : *u8 = (b + o) as *u8   p[0u64] = (v & 255u32) as u8   p[1u64] = ((v >> 8u32) & 255u32) as u8   p[2u64] = ((v >> 16u32) & 255u32) as u8   p[3u64] = ((v >> 24u32) & 255u32) as u8   return 0i32 }
fn cr32(b: u64, o: u64) -> u32 { let p : *u8 = (b + o) as *u8   return (p[0u64] as u32) | ((p[1u64] as u32) << 8u32) | ((p[2u64] as u32) << 16u32) | ((p[3u64] as u32) << 24u32) }
fn crptr(b: u64, o: u64) -> u64 { let p : *u64 = (b + o) as *u64   return p[0u64] }
fn v_gate() -> i32 {
    if WSC_NARG < 1u64 { say("usage: gate NNNN    spawns STDLIB\\build\\kats\\NNNN.exe, reports its real exit code" as u64, 81u32, th_warn())   return 0i32 }
    let num : i64 = WSC_ARGS[0u64]
    cz((&WSC_CMD) as u64, 64u64)
    /* "STDLIB\build\kats\NNNN.exe" */
    let pre : u64 = "STDLIB\\build\\kats\\" as u64
    let mut i : u64 = 0u64
    while i < 18u64 { let p : *u8 = (pre + i) as *u8   WSC_CMD[i] = p[0u64]   i = i + 1u64 }
    WSC_CMD[18u64] = (((num / 1000i64) % 10i64) + 48i64) as u8
    WSC_CMD[19u64] = (((num / 100i64) % 10i64) + 48i64) as u8
    WSC_CMD[20u64] = (((num / 10i64) % 10i64) + 48i64) as u8
    WSC_CMD[21u64] = ((num % 10i64) + 48i64) as u8
    WSC_CMD[22u64] = 46u8   WSC_CMD[23u64] = 101u8   WSC_CMD[24u64] = 120u8   WSC_CMD[25u64] = 101u8   WSC_CMD[26u64] = 0u8
    cz((&WSC_SI) as u64, 104u64)   cw32((&WSC_SI) as u64, 0u64, 104u32)
    cz((&WSC_PI) as u64, 24u64)
    let ok : u32 = CreateProcessA(0u64, (&WSC_CMD) as u64, 0u64, 0u64, 0u32, 134217728u32, 0u64, 0u64, (&WSC_SI) as u64, (&WSC_PI) as u64)
    if ok == 0u32 { cb_reset()   cb_txt("gate " as u64, 5u32)   cb_num(num)   cb_txt(" : could not spawn (no such KAT binary?)" as u64, 40u32)   cb_commit(th_bad())   return 0i32 }
    let hp : u64 = crptr((&WSC_PI) as u64, 0u64)
    WaitForSingleObject(hp, 30000u32)
    GetExitCodeProcess(hp, (&WSC_CODE) as u64)
    let code : u32 = cr32((&WSC_CODE) as u64, 0u64)
    CloseHandle(hp)   CloseHandle(crptr((&WSC_PI) as u64, 8u64))
    cb_reset()   cb_txt("gate " as u64, 5u32)   cb_num(num)   cb_txt(" : real exit code " as u64, 18u32)   cb_num(code as i64)
    if code == 99u32 { cb_txt("   PASS" as u64, 7u32)   cb_commit(th_good()) }
    if code != 99u32 { cb_txt("   FAIL (want 99)" as u64, 17u32)   cb_commit(th_bad()) }
    return 0i32
}
fn v_help() -> i32 {
    say("sign a b [a b ...]        exact sign of sum(a*sqrt(b)) -- the Sqrt-sum engine" as u64, 78u32, th_ink())
    say("collide x y z r  x y z r  exact sphere contact + exact gap/depth metric" as u64, 72u32, th_ink())
    say("relay S R1 R2 T (xyz*4)   which relay route is EXACTLY shorter (n=4 surd sign)" as u64, 79u32, th_ink())
    say("mod m r c init            PROVE x%m==r invariant under x+=c over all 2^64" as u64, 74u32, th_ink())
    say("gate NNNN                 spawn the real corpus KAT, report its real exit code" as u64, 79u32, th_ink())
    return 0i32
}

fn exec_line() -> i32 {
    /* echo the command in maroon */
    cb_reset()   cb_txt("> " as u64, 2u32)   cb_txt((&WSC_IN) as u64, WSC_INL)   cb_commit(th_maroon())
    let s : u32 = skip_sp(0u32)
    if s >= WSC_INL { WSC_INL = 0u32   return 0i32 }
    let e : u32 = tok_end(s)
    parse_args(e)
    let mut hit : u32 = 0u32
    if tok_is(s, e, "sign" as u64, 4u32) == 1u32 { v_sign()   hit = 1u32 }
    if tok_is(s, e, "collide" as u64, 7u32) == 1u32 { v_collide()   hit = 1u32 }
    if tok_is(s, e, "relay" as u64, 5u32) == 1u32 { v_relay()   hit = 1u32 }
    if tok_is(s, e, "mod" as u64, 3u32) == 1u32 { v_mod()   hit = 1u32 }
    if tok_is(s, e, "gate" as u64, 4u32) == 1u32 { v_gate()   hit = 1u32 }
    if tok_is(s, e, "help" as u64, 4u32) == 1u32 { v_help()   hit = 1u32 }
    if hit == 0u32 { say("unknown verb -- try: help" as u64, 25u32, th_warn()) }
    WSC_INL = 0u32
    return 0i32
}

fn ws_console_init() -> i32 @export {
    if WSC_HEAD > 0u64 { return 0i32 }
    say("III CONSOLE -- exact calculator, inductive prover, live gate runner.  Type help." as u64, 81u32, th_dim())
    return 0i32
}

fn ws_console_input(k: u32, mx: u32, my: u32, md: u32) -> i32 @export {
    /* typed characters arrive through the OS WM_CHAR ring */
    let mut c : u32 = ui_getchar()
    while c != 0u32 {
        if c == 13u32 { exec_line() }
        if c == 8u32 { if WSC_INL > 0u32 { WSC_INL = WSC_INL - 1u32 } }
        if c >= 32u32 { if c <= 126u32 { if WSC_INL < 108u32 { WSC_IN[WSC_INL as u64] = c as u8   WSC_INL = WSC_INL + 1u32 } } }
        c = ui_getchar()
    }
    return 0i32
}

fn ws_console_render(buf: u64, w: u32, h: u32, cx: u32, cy: u32, cw: u32, chh: u32) -> i32 @export {
    th_vbold(buf, w, h, (cx + 8u32) as i64, cy as i64, "CONSOLE" as u64, 7u32, 24i64, th_maroon())
    ui_text_n(buf, w, h, cx + 150u32, cy + 8u32, "every answer below is a real faculty's verdict" as u64, 46u32, th_dim())
    /* scrollback panel */
    let py : u32 = cy + 40u32
    let ph : u32 = chh - 96u32
    th_panel_c(buf, w, h, cx + 4u32, py, cw - 12u32, ph, th_inset())
    let rows : u64 = ((ph - 20u32) / 18u32) as u64
    let mut show : u64 = WSC_HEAD
    if show > rows { show = rows }
    if show > WSC_MAXL { show = WSC_MAXL }
    let mut r : u64 = 0u64
    while r < show {
        let idx : u64 = (WSC_HEAD - show + r) % WSC_MAXL
        let base : u64 = idx * WSC_COLS
        ui_text_n(buf, w, h, cx + 18u32, py + 12u32 + (r as u32) * 18u32, ((&WSC_TXT) as u64) + base, WSC_LLEN[idx], WSC_LCOL[idx])
        r = r + 1u64
    }
    /* input line: bold, cream, with a block cursor */
    let iy : u32 = py + ph + 10u32
    th_panel_c(buf, w, h, cx + 4u32, iy, cw - 12u32, 36u32, th_cream())
    ui_text_n(buf, w, h, cx + 16u32, iy + 10u32, ">" as u64, 1u32, th_maroon())
    ui_text_n(buf, w, h, cx + 32u32, iy + 10u32, (&WSC_IN) as u64, WSC_INL, th_ink())
    ui_fill_rect(buf, w, h, cx + 32u32 + WSC_INL * 8u32, iy + 8u32, 8u32, 18u32, th_maroon())
    return 0i32
}
