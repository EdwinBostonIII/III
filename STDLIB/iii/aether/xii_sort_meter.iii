/* STDLIB/iii/aether/xii_sort_meter.iii -- THE R042 SORT-PENALTY TIER tied to resource metering.
 *
 * The blocked-frontier caveat: the R042 "sort modulo associativity" rewrite (omnia/xii_rewrite) lacked a
 * cost tier for OWNER-DOMAIN convergence -- an adversarial owner could submit deeply out-of-order
 * associative FORM spines that force expensive R042 transposition cascades, paying nothing.  This closes it
 * by tying the theoretical cost of the rewrite directly to the PHYSICAL resource meter.
 *
 * r042_penalty(t) computes the geometric sort-penalty of an R042 site: the canonical weight (xii_canon_weight,
 * the geometric depth of the spine) of a term that MATCHES R042 -- 0 for a non-site (already-sorted or
 * unrelated).  r042_charge debits that penalty from a compute box's CPU quota (aether/compute_box
 * cb_charge_cpu), so a deep adversarial sort EXHAUSTS the owner's budget and is bounded, while a shallow or
 * non-R042 term is barely charged.  The operational cost of the rewrite is now the physical cost.
 *
 * Hexad: kind_essence.  Ring: R-1.  K: 1.00.  Composes omnia/xii_rewrite (match_R042) + omnia/xii_canonicalise
 * (the weight) + aether/compute_box (the meter) -- no new organ, no float.
 */
module aether_xii_sort_meter

extern @abi(c-msvc-x64) fn match_R042(t: u32) -> u8 from "xii_rewrite.iii"
extern @abi(c-msvc-x64) fn xii_canon_weight(t: u32) -> u32 from "xii_canonicalise.iii"
extern @abi(c-msvc-x64) fn cb_charge_cpu(guest_cap: u64, sb_id: u64, micros: u64) -> u8 from "compute_box.iii"

/* the geometric sort-penalty of t: the canonical weight (geometric depth) of an R042 match site, else 0. */
fn r042_penalty(t: u32) -> u32 @export {
    if match_R042(t) == 0u8 { return 0u32 }
    return xii_canon_weight(t)
}

/* charge the R042 sort-penalty to a compute box's CPU meter.  1 = charged within budget (or nothing to
 * charge); 0 = the (deep) sort exhausted the owner's quota -- the owner-domain sorting attack is bounded. */
fn r042_charge(guest_cap: u64, sb_id: u64, t: u32) -> u8 @export {
    let p : u32 = r042_penalty(t)
    if p == 0u32 { return 1u8 }
    return cb_charge_cpu(guest_cap, sb_id, p as u64)
}
