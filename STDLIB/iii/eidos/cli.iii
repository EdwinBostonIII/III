/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\eidos\cli.iii
 *
 * III STDLIB - eidos::cli  --  THE IN-HOUSE DISPLAY COMMAND (display arch FR-5): one command, every view.
 *
 * Edwin's directive: "an in-house CLI that takes advantage of every primitive built for the system."
 * eidos_cli_run(verb, cap, path) is the single entry point, dispatching to the whole display stack:
 *   MAP   (0): the batcave MODULE graph -- self_cartographer -> self_atlas -> eidos/layout (barycentric +
 *              radial) -> eidos/render -> the truecolor mandala.
 *   WEB   (1): the live isub CONTENT-ADDRESSED web -- drive a REAL reduction trace (xii_isub_normalize),
 *              then eidos/web projects the <verb,a,b> quanta it shatters onto the bus.
 *   PLAN  (2): the WEB + the Composer's geodesic overlaid (eidos/web's desc_plan highlight) -- the
 *              read-only display as the planner's live consumer.
 *   FIELD (3): the batcave revealed over EVENT-TIME, stratum-by-stratum, as a field-witnessed flipbook
 *              (eidos/temporal).
 * Each view writes a truecolor .ans artifact and self-labels via its own caption (the legend).  An
 * unknown verb is REJECTED (returns 0) -- never a silent wrong render.
 *
 * ENCAPSULATE, NOT REIMPLEMENT (no island): the CLI orchestrates; it owns no graph, plane, colour, web,
 * or clock.  It composes self_cartographer + eidos/{render,layout,canvas,web,temporal} + xii (the real
 * trace driver) + aether/fs.  Ring R0.  K 0.98 (filesystem-bound).  NIH: libc-free.  W2 (<=4 params).
 */
module eidos_cli

extern @abi(c-msvc-x64) fn scarto_map(cap: u64, root_ptr: u64, root_len: u64) -> u32 from "self_cartographer.iii"
extern @abi(c-msvc-x64) fn render_atlas() -> u32 from "render.iii"
extern @abi(c-msvc-x64) fn render_caption(b: u64) -> i32 from "render.iii"
extern @abi(c-msvc-x64) fn render_legend(b: u64) -> u32 from "render.iii"
extern @abi(c-msvc-x64) fn canvas_serialize(b: u64) -> i32 from "canvas.iii"

/* MAP+FIELD share the artifact write; FIELD has its own flipbook writer. */
extern @abi(c-msvc-x64) fn temporal_build() -> i32 from "temporal.iii"
extern @abi(c-msvc-x64) fn eidos_temporal_write(cap: u64, path_ptr: u64) -> u32 from "temporal.iii"

/* WEB+PLAN: the live isub web projection (the concurrent eidos/web sibling) + its plan overlay. */
extern @abi(c-msvc-x64) fn web_render() -> u32 from "web.iii"
extern @abi(c-msvc-x64) fn web_overlay_plan(start_pt: u32, target_pt: u32) -> u32 from "web.iii"
extern @abi(c-msvc-x64) fn eidos_web_write(cap: u64, path_ptr: u64) -> u32 from "web.iii"

/* the REAL trace driver: build a term + normalise it so the reduction shatters onto the isub bus. */
extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_fusion2(kind: u8, a: u32, b: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_isub_normalize(t: u32) -> u32 from "xii_isub.iii"
extern @abi(c-msvc-x64) fn isub_reset() -> i32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_count() -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_a(i: u32) -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_b(i: u32) -> u32 from "isub.iii"

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn builder_new(arena_id: u64, hint: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_seal(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_len(id: u64) -> u64 from "builder.iii"
extern @abi(c-msvc-x64) fn builder_drop(id: u64) -> i32 from "builder.iii"
extern @abi(c-msvc-x64) fn fs_open(cap: u64, path: u64, mode: u32) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_write(h: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_close(h: u64) -> i32 from "fs.iii"

const CLI_ARENA : u64 = 4194304u64       /* 4 MiB scratch for the serialized frame */
const CLI_HINT  : u64 = 1048576u64
const CLI_WRITE : u32 = 2u32

const CLI_MAP   : u32 = 0u32
const CLI_WEB   : u32 = 1u32
const CLI_PLAN  : u32 = 2u32
const CLI_FIELD : u32 = 3u32

var CLI_ROOT : [u8; 16]                   /* the III self-tree root ("STDLIB/iii" or "iii"), NUL-terminated */

fn cli_bcopy(dst: u64, src: u64, n: u64) -> u64 {
    let d : *u8 = dst as *u8
    let s : *u8 = src as *u8
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]  i = i + 1u64 }
    d[n] = 0u8
    return n
}

/* serialize the CURRENT plane (image + the batcave caption) to path; returns bytes written (0 = fail). */
fn eidos_cli_write(cap: u64, path_ptr: u64) -> u32 @export {
    let a   : u64 = arena_new(CLI_ARENA)
    let b   : u64 = builder_new(a, CLI_HINT)
    canvas_serialize(b)
    render_caption(b)
    render_legend(b)
    let base : u64 = builder_seal(b)
    let len  : u64 = builder_len(b)
    let h    : u64 = fs_open(cap, path_ptr, CLI_WRITE)
    if h == 0u64 { builder_drop(b)  return 0u32 }
    let w : u64 = fs_write(h, base, len)
    fs_close(h)
    builder_drop(b)
    return w as u32
}

/* drive a REAL reduction trace onto the isub bus (the 1943/1987 pattern); returns the quanta count. */
fn cli_drive_trace() -> u32 {
    xii_term_arena_reset()
    let v   : u32 = xii_term_make_basis(1u8, 0x100u32)
    let nul : u32 = xii_term_make_basis(5u8, 0xFFFFFFFFu32)
    let i1  : u32 = xii_term_make_fusion2(18u8, nul, v)
    let i2  : u32 = xii_term_make_fusion2(18u8, nul, i1)
    let s   : u32 = xii_term_make_fusion2(18u8, nul, i2)
    isub_reset()
    xii_isub_normalize(s)
    return isub_count()
}

/* the full command: walk the real tree, render the mandala, write the artifact.  Returns the node count. */
fn eidos_cli_render_map(cap: u64, root_ptr: u64, root_len: u64, path_ptr: u64) -> u32 {
    let nc : u32 = scarto_map(cap, root_ptr, root_len)
    if nc == 0u32 { return 0u32 }
    render_atlas()
    let w : u32 = eidos_cli_write(cap, path_ptr)
    if w == 0u32 { return 0u32 }
    return nc
}

/* THE DISPATCHER: render the requested VIEW of III to path.  Returns bytes written (0 = failure or an
 * unknown verb -- rejected, never a silent wrong render).  The self-tree root is CWD-independent
 * (sweep 2026-07-02): repo-root invocations see STDLIB/iii, STDLIB/ invocations see iii -- probe the
 * first, fall back; the probe IS the walk, so the atlas is populated once and every verb reuses it. */
fn eidos_cli_run(verb: u32, cap: u64, path_ptr: u64) -> u32 @export {
    cli_bcopy((&CLI_ROOT as u64), ("STDLIB/iii" as u64), 10u64)
    let mut nw : u32 = scarto_map(cap, (&CLI_ROOT as u64), 10u64)
    if nw == 0u32 {
        cli_bcopy((&CLI_ROOT as u64), ("iii" as u64), 3u64)
        nw = scarto_map(cap, (&CLI_ROOT as u64), 3u64)
    }
    if verb == CLI_MAP {
        if nw == 0u32 { return 0u32 }
        render_atlas()
        return eidos_cli_write(cap, path_ptr)
    }
    if verb == CLI_FIELD {
        if nw == 0u32 { return 0u32 }
        temporal_build()
        return eidos_temporal_write(cap, path_ptr)
    }
    if verb == CLI_WEB {
        let nq : u32 = cli_drive_trace()
        if nq == 0u32 { return 0u32 }
        web_render()
        return eidos_web_write(cap, path_ptr)
    }
    if verb == CLI_PLAN {
        let nq : u32 = cli_drive_trace()
        if nq == 0u32 { return 0u32 }
        web_render()
        web_overlay_plan(isub_a(0u32), isub_b(nq - 1u32))
        return eidos_web_write(cap, path_ptr)
    }
    return 0u32                            /* unknown verb: reject */
}
