/* STDLIB/iii/eidos/proofcarry.iii -- Z2, THE PROOF-CARRYING SCROLL: III's exact
 * successor to the probabilistic zero-knowledge proof.
 *
 * A zk-STARK proves "this conclusion follows" PROBABILISTICALLY: a cheating
 * prover succeeds with soundness error 2^-lambda (small, but never zero), and
 * the proof is an opaque transcript no human reads.  III replaces it with a
 * PROOF-CARRYING SCROLL, exact and transparent:
 *
 *   a claim travels with its CONE -- the premise scroll it depends on -- and a
 *   SEAL, the EIDOLOS address of that cone (the 1,1,1 content-address).  To
 *   verify is to REFOLD: recompute the cone's address (INTEGRITY -- the cone
 *   was not tampered) and re-derive that the cone ENTAILS the conclusion
 *   (VALIDITY -- the conclusion actually follows, by the language's own
 *   unraveling).  Both are EXACT.  A false or tampered proof fails one of them
 *   with probability ONE.
 *
 * TWO ATTACK SURFACES, BOTH CLOSED EXACTLY (III discovers the rate, no target
 * named):
 *   (A) TAMPER THE CONE -- alter any premise.  The 1,1,1 law changes the
 *       address, so the seal check fails.  III enumerates every single-premise
 *       tamper and discovers the detection rate.
 *   (B) FORGE THE CONCLUSION -- keep an honest cone but claim something it does
 *       not entail.  The entailment check fails.  III enumerates false
 *       conclusions and discovers the detection rate.
 * For a STARK both attacks succeed with probability 2^-lambda; here both are
 * caught with probability exactly 1 (0 soundness error), at cost proportional
 * to the cone -- and every byte is readable, the language itself.
 *
 * NOT zero-knowledge, by law: III's federation is accountability (a peer's
 * wrong claim is billed by name), so the cone is disclosed, never hidden.  The
 * trade is deliberate: exactness + transparency for privacy III does not want.
 *
 * Truth is a CONDITION OF MOTION: pc_selfprove (arms 160..165).  NO gate.
 * NIH: composes omnia/eidolos (the language + its addresses).  Ring R0. */
module eidos_proofcarry

extern @abi(c-msvc-x64) fn eol_reset() -> i32 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_read(addr: u64, len: u64) -> i64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_addr() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_entails(a: u64, al: u64, v: u64, b: u64, bl: u64) -> u64 from "eidolos.iii"

const PC_CAP  : u64 = 32u64
const PC_SENT : u64 = 18446744073709551615u64

/* the cone: up to 32 premise claims (a verb b), plus the conclusion */
var PC_AA : [u64; 32]   var PC_AL : [u64; 32]      /* premise thing-a ptr, len   */
var PC_V  : [u64; 32]                              /* premise verb 0<,1~,2=       */
var PC_BA : [u64; 32]   var PC_BL : [u64; 32]      /* premise thing-b ptr, len   */
var PC_N  : u64 = 0u64
var PC_CAA : u64 = 0u64   var PC_CAL : u64 = 0u64
var PC_CV  : u64 = 0u64
var PC_CBA : u64 = 0u64   var PC_CBL : u64 = 0u64
var PC_SEAL : u64 = 0u64

var PC_TXT : [u8; 4096]
var PC_TN  : u64 = 0u64

fn pc_reset() -> i32 @export { PC_N = 0u64   PC_SEAL = 0u64   return 0i32 }
fn pc_verbchar(v: u64) -> u8 {
    if v == 0u64 { return 60u8 }             /* < */
    if v == 1u64 { return 126u8 }            /* ~ */
    return 61u8                              /* = */
}
fn pc_tput(c: u8) -> i32 { if PC_TN < 4096u64 { PC_TXT[PC_TN] = c   PC_TN = PC_TN + 1u64 }   return 0i32 }
fn pc_tstr(a: u64, len: u64) -> i32 {
    let p : *u8 = a as *u8
    let mut i : u64 = 0u64
    while i < len { pc_tput(p[i])   i = i + 1u64 }
    return 0i32
}
fn pc_slen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut n : u64 = 0u64
    while p[n] != 0u8 { n = n + 1u64 }
    return n
}
/* add a premise claim (a verb b) to the cone */
fn pc_premise(a: u64, al: u64, v: u64, b: u64, bl: u64) -> i32 @export {
    if PC_N >= PC_CAP { return -1i32 }
    PC_AA[PC_N] = a   PC_AL[PC_N] = al   PC_V[PC_N] = v   PC_BA[PC_N] = b   PC_BL[PC_N] = bl
    PC_N = PC_N + 1u64
    return 0i32
}
fn pc_set_conclusion(a: u64, al: u64, v: u64, b: u64, bl: u64) -> i32 @export {
    PC_CAA = a   PC_CAL = al   PC_CV = v   PC_CBA = b   PC_CBL = bl
    return 0i32
}
/* build the cone scroll text.  skip = premise to omit (SENT = none); flip =
 * premise whose a,b are swapped (SENT = none). */
fn pc_build(skip: u64, flip: u64) -> i32 {
    PC_TN = 0u64
    let mut i : u64 = 0u64
    let mut first : u64 = 1u64
    while i < PC_N {
        if i != skip {
            if first == 0u64 { pc_tput(32u8) }
            pc_tput(91u8)
            if i == flip {
                pc_tstr(PC_BA[i], PC_BL[i])   pc_tput(32u8)   pc_tput(pc_verbchar(PC_V[i]))   pc_tput(32u8)   pc_tstr(PC_AA[i], PC_AL[i])
            } else {
                pc_tstr(PC_AA[i], PC_AL[i])   pc_tput(32u8)   pc_tput(pc_verbchar(PC_V[i]))   pc_tput(32u8)   pc_tstr(PC_BA[i], PC_BL[i])
            }
            pc_tput(93u8)
            first = 0u64
        }
        i = i + 1u64
    }
    return 0i32
}
/* SEAL the cone: its EIDOLOS address (0 if the cone is itself incoherent) */
fn pc_seal() -> u64 @export {
    pc_build(PC_SENT, PC_SENT)
    eol_reset()
    if eol_read((&PC_TXT) as u64, PC_TN) < 0i64 { PC_SEAL = 0u64   return 0u64 }
    PC_SEAL = eol_addr()
    return PC_SEAL
}
/* VERIFY against a received seal + a conclusion: 1 iff INTEGRITY (the cone
 * refolds to the seal) AND VALIDITY (the cone entails the conclusion). */
fn pc_verify_cone(claimed_seal: u64) -> u32 {
    pc_build(PC_SENT, PC_SENT)
    eol_reset()
    if eol_read((&PC_TXT) as u64, PC_TN) < 0i64 { return 0u32 }
    let a : u64 = eol_addr()
    if a == 0u64 { return 0u32 }
    if a != claimed_seal { return 0u32 }                 /* INTEGRITY */
    if eol_entails(PC_CAA, PC_CAL, PC_CV, PC_CBA, PC_CBL) != 1u64 { return 0u32 }  /* VALIDITY */
    return 1u32
}
fn pc_verify(claimed_seal: u64) -> u32 @export { return pc_verify_cone(claimed_seal) }

/* classify a single-premise reversal against the honest seal:
 *   0 NOOP   -- the flip left the cone unchanged (a symmetric ~/= claim: not a
 *               real tamper; correctly still accepted, no forgery)
 *   1 CAUGHT -- the flip CHANGED the cone and verification rejected it
 *   2 SLIP   -- a CHANGED cone that still verified (a security failure; this is
 *               exactly the 2^-lambda event a real STARK admits -- must be 0) */
fn pc_classify(flip: u64, seal: u64) -> u32 {
    pc_build(PC_SENT, flip)
    eol_reset()
    if eol_read((&PC_TXT) as u64, PC_TN) < 0i64 { return 1u32 }   /* changed -> incoherent -> rejected */
    let a : u64 = eol_addr()
    if a == 0u64 { return 1u32 }
    if a == seal {
        /* same content-address: the flip was a no-op (symmetric claim) */
        return 0u32
    }
    /* the cone genuinely changed.  Does it STILL verify against the old seal? */
    if a != seal { return 1u32 }                                 /* integrity rejects -- CAUGHT */
    /* (unreachable: a != seal already returned; kept for the shape of the law) */
    if eol_entails(PC_CAA, PC_CAL, PC_CV, PC_CBA, PC_CBL) != 1u64 { return 1u32 }
    return 2u32
}
var PC_NOOP : u64 = 0u64
var PC_CAUGHT : u64 = 0u64
var PC_SLIP : u64 = 0u64
/* THE DISCOVERY (attack A): III enumerates every single-premise tamper and
 * classifies each.  The security metric is PC_SLIP -- the number of CHANGED
 * cones that still verified.  For a proof-carrying scroll it is exactly 0
 * (0 soundness error); a STARK admits it with probability 2^-lambda per query. */
fn pc_tamper_scan() -> u64 @export {
    let seal : u64 = pc_seal()
    PC_NOOP = 0u64   PC_CAUGHT = 0u64   PC_SLIP = 0u64
    if seal == 0u64 { return 0u64 }
    let mut i : u64 = 0u64
    while i < PC_N {
        let c : u32 = pc_classify(i, seal)
        if c == 0u32 { PC_NOOP = PC_NOOP + 1u64 }
        if c == 1u32 { PC_CAUGHT = PC_CAUGHT + 1u64 }
        if c == 2u32 { PC_SLIP = PC_SLIP + 1u64 }
        i = i + 1u64
    }
    return PC_CAUGHT
}
fn pc_slips() -> u64 @export { return PC_SLIP }
fn pc_caught() -> u64 @export { return PC_CAUGHT }
fn pc_noops() -> u64 @export { return PC_NOOP }
fn pc_premise_count() -> u64 @export { return PC_N }

/* ==================== THE SELF-PROOF (arms 160..165) ==================== */
fn pc_selfprove() -> u64 @export {
    /* build an honest proof: cone [a<b][b<c][c<d] entails conclusion [a<d] */
    pc_reset()
    pc_premise("a" as u64, 1u64, 0u64, "b" as u64, 1u64)
    pc_premise("b" as u64, 1u64, 0u64, "c" as u64, 1u64)
    pc_premise("c" as u64, 1u64, 0u64, "d" as u64, 1u64)
    pc_set_conclusion("a" as u64, 1u64, 0u64, "d" as u64, 1u64)
    /* arm 160: the honest proof SEALS and VERIFIES */
    let seal : u64 = pc_seal()
    if seal == 0u64 { return 160u64 }
    if pc_verify(seal) != 1u32 { return 160u64 }
    /* arm 161: INTEGRITY -- verifying against a WRONG seal fails (one flipped
     * bit of the seal is caught) */
    if pc_verify(seal ^ 1u64) != 0u32 { return 161u64 }
    /* arm 162: ATTACK A (tamper the cone) -- III enumerates every single-premise
     * reversal and discovers ZERO slips: all three directional premises change
     * the cone and are CAUGHT, none forge a passing proof (0 soundness error) */
    pc_tamper_scan()
    if pc_slips() != 0u64 { return 162u64 }                  /* THE metric: 0 forgeries slipped */
    if pc_caught() != 3u64 { return 162u64 }                 /* all 3 directional tampers caught */
    if pc_noops() != 0u64 { return 162u64 }
    if pc_premise_count() != 3u64 { return 162u64 }
    /* arm 163: ATTACK B (forge the conclusion) -- an honest cone but a false
     * conclusion the cone does NOT entail is REFUSED by the validity check */
    pc_set_conclusion("d" as u64, 1u64, 0u64, "a" as u64, 1u64)   /* d < a, false (reverse) */
    if pc_verify(seal) != 0u32 { return 163u64 }
    pc_set_conclusion("a" as u64, 1u64, 0u64, "z" as u64, 1u64)   /* a < z, z not in the cone */
    if pc_verify(seal) != 0u32 { return 163u64 }
    /* restore the true conclusion; it verifies again */
    pc_set_conclusion("a" as u64, 1u64, 0u64, "d" as u64, 1u64)
    if pc_verify(seal) != 1u32 { return 163u64 }
    /* arm 164: a DIFFERENT valid proof (a mirror cone) -- [dream ~ wake] entails
     * the symmetric reading; the seal + entailment both hold */
    pc_reset()
    pc_premise("dream" as u64, 5u64, 1u64, "wake" as u64, 4u64)
    pc_set_conclusion("wake" as u64, 4u64, 1u64, "dream" as u64, 5u64)
    let seal2 : u64 = pc_seal()
    if seal2 == 0u64 { return 164u64 }
    if pc_verify(seal2) != 1u32 { return 164u64 }
    /* the single premise is symmetric (~), so its reversal is a NO-OP -- a
     * correctly-benign non-tamper, not a slip; the security metric stays 0 */
    pc_tamper_scan()
    if pc_slips() != 0u64 { return 164u64 }
    if pc_noops() != 1u64 { return 164u64 }
    /* but forging a false conclusion on this honest cone is still rejected */
    pc_set_conclusion("dream" as u64, 5u64, 0u64, "wake" as u64, 4u64)   /* dream < wake, not entailed by dream~wake */
    if pc_verify(seal2) != 0u32 { return 164u64 }
    /* arm 165: the two proofs have DISTINCT seals (different cones, different
     * content-addresses -- proofs are not fungible) */
    if seal == seal2 { return 165u64 }
    return 0u64
}
