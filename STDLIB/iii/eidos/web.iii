 *
 * III STDLIB - eidos::web  --  THE EIDOS-WEB PROJECTION (display arch Phase 2): render the REAL isub
 * content-addressed web onto the plane.
 *
 * eidos::render projects the self_atlas (III's MODULE graph).  eidos::web is its sibling over the OTHER
 * real geometry -- the live isub bus: the content-addressed <verb,a,b> quanta a real reduction trace
 * (xii_isub_normalize) shatters onto the metal bus.  NO hand-built web: web authors no quanta; a real
 * execution drives the bus and this projects what is there (display arch FR-1 caveat, eidos/descriptor).
 *
 * THE PROJECTION (block = node, the content-address IS the colour, FR-2):
 *   - identity : each quantum's 32-byte content-address sha256(verb||a||b) (isub_cav).
 *   - colour   : eidos/palette over that identity -- two content-identical quanta are the SAME colour BY
 *                CONSTRUCTION, so coincidence (what the coincidence engine PROVES) is literally VISIBLE.
 *   - x (col)  : a SECOND readout of the same identity (palette_pos_seed) -- hue and column are two faces
 *                of one content-address (ADR-2), independent of the operand addresses.
 *   - y (row)  : the geometric VERB band (BELOW vs REFLECT -- the real ripple direction, ripple.iii),
 *                jittered WITHIN the band by a third identity readout, so each direction is a filled band.
 *   - edges    : the web's COMPOSITION adjacency (quantum i's sink == quantum j's source, b_i==a_j) drawn
 *                UNDER the nodes in the source colour, dimmed -- the real <verb,a,b> chain structure.
 * Off-plane and pixel-coincident quanta are COUNTED, never silently dropped (NFR-completeness).  The
 * projection is total by construction (col<W, row<H always), so a sound gate asserts off-plane == 0.
 *
 * ENCAPSULATE, NOT REIMPLEMENT (no island): web reads the REAL isub bus and composes the REAL
 * eidos/canvas (the plane) + eidos/palette (the colour law).  It re-authors no bus, no plane, no colour.
 *
 * Ring R0.  K 1.00 (pure projection over two sealed organs + the live bus).  NIH: libc-free.  W2 (<=4 params).
 */
module eidos_web

/* the live content-addressed web -- the isub bus (driven by a real trace, never hand-built). */
extern @abi(c-msvc-x64) fn isub_count() -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_verb(i: u32) -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_a(i: u32) -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_b(i: u32) -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_cav_into(verb: u32, a: u32, b: u32, out32: *u8) -> i32 from "isub.iii"

/* the colour law (eidos/palette) -- colour IS the content-address. */
extern @abi(c-msvc-x64) fn palette_rgb(p32: u64) -> u32 from "palette.iii"
extern @abi(c-msvc-x64) fn palette_pos_seed(p32: u64) -> u32 from "palette.iii"
extern @abi(c-msvc-x64) fn palette_dim(rgb: u32) -> u32 from "palette.iii"

/* the plane (eidos/canvas). */
extern @abi(c-msvc-x64) fn canvas_w() -> u32 from "canvas.iii"
extern @abi(c-msvc-x64) fn canvas_h() -> u32 from "canvas.iii"
