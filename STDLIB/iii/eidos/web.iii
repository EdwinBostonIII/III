extern @abi(c-msvc-x64) fn canvas_serialize(b: u64) -> i32 from "canvas.iii"

/* the COMPOSER (eidos/descriptor -> eidos/compose Bellman-Ford): routes the web's order in REAL point
 * addresses.  web is its FIRST live consumer through the display (Phase 3 plan-overlay). */
extern @abi(c-msvc-x64) fn desc_build_order() -> i32 from "descriptor.iii"
extern @abi(c-msvc-x64) fn desc_plan(start: u32, target: u32) -> u32 from "descriptor.iii"
extern @abi(c-msvc-x64) fn desc_plan_len() -> u32 from "descriptor.iii"
extern @abi(c-msvc-x64) fn desc_plan_node(i: u32) -> u32 from "descriptor.iii"

/* the Composer's RIPPLE half (eidos/weave): plans over real ripple quanta + EXECUTES the plan as witnessed
 * ripples onto the isub bus -- so web renders weave's executed plan (weave's first live consumer). */
