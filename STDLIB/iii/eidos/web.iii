 * adjacency -- so web renders the topology graph + highlights route_path's geodesic (route's first live consumer). */
extern @abi(c-msvc-x64) fn topoa_neighbors(a: u32, edge_kind: u8, out: *u32, out_n: *u32, out_cap: u32) -> i32 from "topology_atlas.iii"
