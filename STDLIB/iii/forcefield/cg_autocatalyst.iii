/* STDLIB/iii/forcefield/cg_autocatalyst.iii -- THE SIEVE of the Autocatalytic Synthesis Loop.
 *
 * The absolute, deterministic wall.  A hallucinated candidate identity (from egraph_stochastic) is
 * turned into a candidate proof term by the synthesizer (numera/sov_isa) and fed to the system's
 * ultimate truth-teller: the CIC kernel tc_check (numera/typecheck).  The kernel is the SOLE arbiter.
 *
 *   REJECTION ARM:  tc_check == 0  -> the mutation is mathematically FALSE (or exceeds the arena cap, a
 *                   sound capacity fail-safe).  ZERO state change -- the next sov_ac_setup's tc_reset
 *                   wipes the volatile candidate; nothing is sealed, nothing recorded.  ~99.x% of dreams.
 *   ADMISSION ARM:  tc_check == 1  -> a mathematically TRUE, kernel-CERTIFIED optimization.  The identity
 *                   is content-address SEALED (cad_oneshot, Keccak-256 -- the hash IS its identity, M6)
 *                   into the RUNTIME certified-rewrite registry.
 *
 * THE HARD-INVARIANT FIX (honored): the proposal says "permanently written into hdl_gate_db.iii".  That
 * is self-editing SEALED SOURCE -- forbidden (Generative-Sovereignty single-source + the content-address
 * seal; and .iii->.exe cannot rewrite source at runtime).  So the registry is a VOLATILE, in-memory,
 * cad-sealed table: it evaporates on exit BY DESIGN.  Permanent assimilation of a discovery into the
 * compiler source is the OPERATOR-GATED CRASH-PROTOCOL step (a reseal), NEVER an autonomous self-edit
 * (M20 / ADR-FORGE-4: the Forge is reflexive but BOUNDED -- it may seal its own contents but no proof
 * herein asserts the substrate's own soundness; that remains the iiis-2 == iiis-3 bootstrap fixed point).
 *
 * Hexad: kind_seal.  Ring: R0.  K: 1.00.  NIH: composes sov_isa + typecheck + cad, all in-tree.
 */
module cg_autocatalyst

extern @abi(c-msvc-x64) fn sov_ac_setup() -> u64 from "sov_isa.iii"
extern @abi(c-msvc-x64) fn sov_synth_strength_at(k: u32) -> u32 from "sov_isa.iii"
extern @abi(c-msvc-x64) fn sov_hall_goal(a: u32, b: u32) -> u32 from "sov_isa.iii"
extern @abi(c-msvc-x64) fn tc_check(t: u32, ty: u32) -> u8 from "typecheck.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"

const CGA_REG_CAP : u32 = 64u32

var CGA_REG_SEAL : [u8;  2048]   /* 64 slots x 32-byte Keccak content address */
var CGA_REG_A    : [u32; 64]     /* the certified identity's lhs exponent */
var CGA_REG_B    : [u32; 64]     /* ... rhs exponent (== a for every sealed entry) */
var CGA_REG_N    : [u32; 1]      /* number of certified discoveries this run */
var CGA_MSG      : [u8;  8]      /* scratch: the (a,b) bytes hashed into the seal */

fn cga_reset() -> u64 @export { CGA_REG_N[0u64] = 0u32  return 0u64 }
fn cga_count() -> u32 @export { return CGA_REG_N[0u64] }
fn cga_entry_a(i: u32) -> u32 @export { if i >= CGA_REG_N[0u64] { return 0xFFFFFFFFu32 }  return CGA_REG_A[i as u64] }
fn cga_entry_b(i: u32) -> u32 @export { if i >= CGA_REG_N[0u64] { return 0xFFFFFFFFu32 }  return CGA_REG_B[i as u64] }

/* 1 iff EVERY sealed entry is a TRUE identity (a == b) -- the soundness property: the kernel never
 * admitted a false hallucination.  A single false seal (a != b) returns 0. */
fn cga_all_true() -> u8 @export {
    let n : u32 = CGA_REG_N[0u64]
    let mut i : u32 = 0u32
    while i < n {
        if CGA_REG_A[i as u64] != CGA_REG_B[i as u64] { return 0u8 }
        i = i + 1u32
    }
    return 1u8
}

/* THE SIEVE: dispose a hallucinated strength candidate (a,b) through the kernel.
 * budget==0 -> the synthesizer never attempts (timeout), return 0.  Reject (false, or arena-cap) ->
 * ZERO state change, return 0.  Admit (kernel tc_check==1) -> cad-seal into the volatile registry,
 * return 1.  The registry only ever records what the kernel ALREADY certified. */
fn cga_dispose(a: u32, b: u32, budget: u32) -> u8 @export {
    if budget == 0u32 { return 0u8 }
    sov_ac_setup()                                   /* tc_reset + proven tower (also wipes the prior dream) */
    let cert : u32 = sov_synth_strength_at(a)        /* the synthesizer's best proof attempt for this candidate */
    let goal : u32 = sov_hall_goal(a, b)             /* the candidate equation mul(x,2^a) == double^b(x) */
    if tc_check(cert, goal) != 1u8 { return 0u8 }    /* THE WALL: false / arena-cap -> discard, zero state */

    let n : u32 = CGA_REG_N[0u64]
    if n >= CGA_REG_CAP { return 1u8 }               /* certified but registry full: still a true discovery */
    CGA_MSG[0u64] = (a & 0xFFu32) as u8
    CGA_MSG[1u64] = ((a >> 8u32) & 0xFFu32) as u8
    CGA_MSG[2u64] = ((a >> 16u32) & 0xFFu32) as u8
    CGA_MSG[3u64] = ((a >> 24u32) & 0xFFu32) as u8
    CGA_MSG[4u64] = (b & 0xFFu32) as u8
    CGA_MSG[5u64] = ((b >> 8u32) & 0xFFu32) as u8
    CGA_MSG[6u64] = ((b >> 16u32) & 0xFFu32) as u8
    CGA_MSG[7u64] = ((b >> 24u32) & 0xFFu32) as u8
    let outp : *u8 = ((&CGA_REG_SEAL as u64) + (n as u64) * 32u64) as *u8
    cad_oneshot(1u32, (&CGA_MSG as u64) as *u8, 8u64, outp)   /* suite 1 = Keccak-256; seal = identity (M6) */
    CGA_REG_A[n as u64] = a
    CGA_REG_B[n as u64] = b
    CGA_REG_N[0u64] = n + 1u32
    return 1u8
}

/* SELFTEST (kernel-backed): the sieve admits ONLY kernel-true identities.  99 =
 *  (1) a TRUE candidate (a==b==3) is ADMITTED + sealed (count 0->1);
 *  (2) a FALSE candidate (a=3,b=4) is REJECTED -- count UNCHANGED (zero state change);
 *  (3) a budget=0 candidate is REJECTED (synthesizer timeout) -- count unchanged;
 *  (4) every sealed entry is a true identity (cga_all_true); and the seal is non-zero (cad ran). */
fn cga_selftest() -> u64 @export {
    cga_reset()
    if cga_dispose(3u32, 3u32, 64u32) != 1u8 { return 1u64 }      /* TRUE -> admit */
    if cga_count() != 1u32 { return 2u64 }
    if cga_dispose(3u32, 4u32, 64u32) != 0u8 { return 3u64 }      /* FALSE -> reject */
    if cga_count() != 1u32 { return 4u64 }                        /* zero state change on reject */
    if cga_dispose(2u32, 2u32, 0u32) != 0u8 { return 5u64 }       /* budget 0 -> timeout */
    if cga_count() != 1u32 { return 6u64 }
    if cga_all_true() != 1u8 { return 7u64 }                      /* only true identities sealed */
    /* the seal of the admitted (3,3) identity is non-zero (cad actually ran) */
    let mut nz : u8 = 0u8
    let mut i : u32 = 0u32
    while i < 32u32 { if CGA_REG_SEAL[i as u64] != 0u8 { nz = 1u8 }  i = i + 1u32 }
    if nz == 0u8 { return 8u64 }
    return 99u64
}

/* ===== harmony item 17: THE WIDTH-FAITHFUL DREAM SIEVE ===========================================
 * cga_dispose certifies IDEAL-integer strength identities (the sov_isa Peano tower).  The compiler's
 * registers are NOT ideal integers: they are Z/2^64 with x86 count-mask shifts -- and an ideal truth
 * can be a machine LIE: x*2^64 == x<<64 holds ideally, but on the metal the left wraps to 0 while
 * the right count-masks to x.  cga_dispose_bv routes the SAME candidate class through the width-
 * faithful two-tier disposer (bv_dispose: bv_ring soundly refutes, the kernel's BV64 iota -- count-
 * mask exact -- is the sole arbiter), sealing admissions into a SEPARATE width-faithful registry.
 * The autonomous discovery loop can therefore certify rewrites the code generator may actually apply
 * to 64-bit registers; the (64,64) ideal-truth is REFUSED (the differential the selftest pins --
 * bv_ring even AGREES at (64,64) because *2^64 wraps to *0 in the ring, and the KERNEL still vetoes:
 * sovereignty demonstrated inside the sieve itself).  The registry only ever records what the
 * width-faithful gate ALREADY certified; same volatile/by-design-evaporating contract as the Peano
 * registry (assimilation into source stays operator-gated). */
extern @abi(c-msvc-x64) fn bvd_admit(lhs_tc: u32, rhs_tc: u32, lhs_bv: u32, rhs_bv: u32) -> u8 from "bv_dispose.iii"
extern @abi(c-msvc-x64) fn bv_reset() -> i32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_const(c: u64) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_var(v: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_mul(x: u32, y: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_shl(x: u32, k: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn tc_reset() -> u64 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_var(k: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bvlit_u64(v: u64) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bvmul(x: u32, y: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bvshl(x: u32, y: u32) -> u32 from "typecheck.iii"

var CGA_BV_SEAL : [u8;  2048]   /* 64 slots x 32-byte Keccak content address (width-faithful) */
var CGA_BV_A    : [u32; 64]
var CGA_BV_B    : [u32; 64]
var CGA_BV_N    : [u32; 1]
var CGA_BV_MSG  : [u8;  9]      /* domain byte 0xB5 || a(4 LE) || b(4 LE): never collides with the Peano seal */

fn cga_bv_reset() -> u64 @export { CGA_BV_N[0u64] = 0u32  return 0u64 }
fn cga_bv_count() -> u32 @export { return CGA_BV_N[0u64] }
fn cga_bv_entry_a(i: u32) -> u32 @export { if i >= CGA_BV_N[0u64] { return 0xFFFFFFFFu32 }  return CGA_BV_A[i as u64] }
fn cga_bv_entry_b(i: u32) -> u32 @export { if i >= CGA_BV_N[0u64] { return 0xFFFFFFFFu32 }  return CGA_BV_B[i as u64] }

/* the width-faithful soundness property: every sealed entry is MACHINE-true.  The machine law for
 * mul(x, 2^a) == shl(x, b) over Z/2^64 with the x86 COUNT-MASK shift is  a < 64 AND a == (b & 63):
 * the multiply's 2^a wraps (a >= 64 -> the zero multiplier, never equal to a shift), while the
 * shift's count masks (b = 64 behaves as b = 0 -- so (0, 64) is a TRUE machine identity the
 * ideal-integer model would not even phrase, and the discovery loop, KAT 1353, finds it). */
fn cga_bv_all_true() -> u8 @export {
    let n : u32 = CGA_BV_N[0u64]
    let mut i : u32 = 0u32
    while i < n {
        if CGA_BV_A[i as u64] >= 64u32 { return 0u8 }
        if CGA_BV_A[i as u64] != (CGA_BV_B[i as u64] & 63u32) { return 0u8 }
        i = i + 1u32
    }
    return 1u8
}

/* THE WIDTH-FAITHFUL SIEVE: dispose the strength candidate  mul(x, 2^a) == shl(x, b)  over Z/2^64.
 * The 2^a literal WRAPS (the machine meaning of the ideal constant); the shift amount is the raw b
 * (the kernel's iota count-masks it, exactly as the silicon does).  budget==0 -> never attempted.
 * Reject -> ZERO state change.  Admit -> cad-sealed into the width-faithful registry. */
fn cga_dispose_bv(a: u32, b: u32, budget: u32) -> u8 @export {
    if budget == 0u32 { return 0u8 }
    bv_reset()
    tc_reset()
    let mut pow : u64 = 0u64
    if a < 64u32 { pow = 1u64 << (a as u64) }        /* a >= 64: 2^a mod 2^64 = 0 (the wrap IS the meaning) */
    let b_l : u32 = bv_mul(bv_var(0u32), bv_const(pow))
    let b_r : u32 = bv_shl(bv_var(0u32), b)
    let t_l : u32 = tc_bvmul(tc_var(0u32), tc_bvlit_u64(pow))
    let t_r : u32 = tc_bvshl(tc_var(0u32), tc_bvlit_u64(b as u64))
    if bvd_admit(t_l, t_r, b_l, b_r) != 1u8 { return 0u8 }   /* THE WALL: width-unfaithful -> discard */
    let n : u32 = CGA_BV_N[0u64]
    if n >= CGA_REG_CAP { return 1u8 }               /* certified but registry full: still machine-true */
    CGA_BV_MSG[0u64] = 0xB5u8
    CGA_BV_MSG[1u64] = (a & 0xFFu32) as u8
    CGA_BV_MSG[2u64] = ((a >> 8u32) & 0xFFu32) as u8
    CGA_BV_MSG[3u64] = ((a >> 16u32) & 0xFFu32) as u8
    CGA_BV_MSG[4u64] = ((a >> 24u32) & 0xFFu32) as u8
    CGA_BV_MSG[5u64] = (b & 0xFFu32) as u8
    CGA_BV_MSG[6u64] = ((b >> 8u32) & 0xFFu32) as u8
    CGA_BV_MSG[7u64] = ((b >> 16u32) & 0xFFu32) as u8
    CGA_BV_MSG[8u64] = ((b >> 24u32) & 0xFFu32) as u8
    let outp : *u8 = ((&CGA_BV_SEAL as u64) + (n as u64) * 32u64) as *u8
    cad_oneshot(1u32, (&CGA_BV_MSG as u64) as *u8, 9u64, outp)
    CGA_BV_A[n as u64] = a
    CGA_BV_B[n as u64] = b
    CGA_BV_N[0u64] = n + 1u32
    return 1u8
}

/* ===== harmony item 24: THE AUTONOMOUS WIDTH-FAITHFUL DISCOVERY LOOP =============================
 * Item 17 built the per-candidate sieve; this is the DRIVER that makes discovery autonomous:
 * exhaustively enumerate the (a, b) strength-candidate grid and dispose EVERY pair through the
 * width-faithful two-tier gate.  Deterministic and observation-free -- exhaustive enumeration is
 * the anti-ML discovery discipline (no counting-and-promoting, no thresholds: every candidate
 * meets the kernel, the kernel decides, the registry records).  Returns the number ADMITTED.
 * The width edge is part of the sweep's own truth: a max_exp of 64 offers the ideal-integer
 * truth (64,64) to the gate and the kernel's count-mask iota REFUSES it -- the loop discovers
 * exactly the machine-true diagonal and nothing else. */
fn cga_bv_discover(max_exp: u32, budget: u32) -> u32 @export {
    let mut admitted : u32 = 0u32
    let mut a : u32 = 0u32
    while a <= max_exp {
        let mut b : u32 = 0u32
        while b <= max_exp {
            if cga_dispose_bv(a, b, budget) == 1u8 { admitted = admitted + 1u32 }
            b = b + 1u32
        }
        a = a + 1u32
    }
    return admitted
}

/* ===== harmony wave-4 M1: THE MIXED-FRAGMENT TIER (domain byte 0xB6) ============================
 * The third registry tier, for identities NEITHER prior authority can phrase: bv_ring is
 * polynomial-only (no &,|,^,~) and the kernel's BV iota carries no mixed laws.  The deciding
 * authority here is UNSAT -- numera/bv_bits Tseitin-blasts both sides into III's own CDCL solver
 * and refutes "some bit differs" (bb_equal == 1 is a resolution proof of pointwise equality over
 * ALL 2^(2w) valuations).  A candidate is admitted ONLY when the miter is UNSAT at EVERY probe
 * width (8, 16, 32, 64): a single countermodel at any width discards it -- fail-closed, and the
 * w=64 tier alone is already the full machine width.  Deterministic (the solver's schedules are
 * integer-driven), observation-free (exhaustive refutation, not sampling -- Mandate 7).
 *
 * The shape catalog (x = var 0, y = var 1) -- the textbook mixed strength laws a code generator
 * lives on, every one UNPHRASABLE in the other two tiers:
 *   1: (x&y)+(x|y)          == x+y          (the add/and/or exchange)
 *   2: x-(x&y)              == x&~y         (masked subtract = and-not)
 *   3: (x|y)-(x&y)          == x^y          (xor as or-minus-and)
 *   4: (x&y)|(x^y)          == x|y          (or recomposition)
 *   5: x+(~x&y)             == x|y          (carry-free or)
 *   6: (x+y)-((x&y)<<1)     == x^y          (xor as add-minus-double-carry)
 * Seals are cad(0xB6 || shape_le4) into the SAME volatile registry style as 0xB5 (re-derive,
 * never trust a stale seal).  cga_dispose_mixed admits one shape; cga_mixed_discover sweeps the
 * catalog.  A deliberately FALSE shape id (>= 7 -> builder refuses; a wrong pairing is caught by
 * the solver's countermodel) keeps the negative arm honest. */

var CGA_MX_A    : [u32; 64]     /* admitted shape ids */
var CGA_MX_N    : [u32; 1]
var CGA_MX_SEAL : [u8; 2048]    /* 64 x 32-byte cad seals */
var CGA_MX_MSG  : [u8; 5]       /* 0xB6 || shape(4 LE) */

extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_and(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_or(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_xor(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_not(a: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_add(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_sub(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shl(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shr(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_equal(a: u32, b: u32) -> u8 from "bv_bits.iii"

fn _cga_mx_lhs(shape: u32) -> u32 {
    let x : u32 = bb_var(0u32)
    let y : u32 = bb_var(1u32)
    if shape == 1u32 { return bb_add(bb_and(x, y), bb_or(x, y)) }
    if shape == 2u32 { return bb_sub(x, bb_and(x, y)) }
    if shape == 3u32 { return bb_sub(bb_or(x, y), bb_and(x, y)) }
    if shape == 4u32 { return bb_or(bb_and(x, y), bb_xor(x, y)) }
    if shape == 5u32 { return bb_add(x, bb_and(bb_not(x), y)) }
    if shape == 6u32 { return bb_sub(bb_add(x, y), bb_shl(bb_and(x, y), 1u64)) }
    return 0xFFFFFFFFu32
}

fn _cga_mx_rhs(shape: u32) -> u32 {
    let x : u32 = bb_var(0u32)
    let y : u32 = bb_var(1u32)
    if shape == 1u32 { return bb_add(x, y) }
    if shape == 2u32 { return bb_and(x, bb_not(y)) }
    if shape == 3u32 { return bb_xor(x, y) }
    if shape == 4u32 { return bb_or(x, y) }
    if shape == 5u32 { return bb_or(x, y) }
    if shape == 6u32 { return bb_xor(x, y) }
    return 0xFFFFFFFFu32
}

/* admit shape iff the lhs==rhs miter is UNSAT at w = 8, 16, 32 AND 64 (fail-closed at each) */
fn cga_dispose_mixed(shape: u32, budget: u32) -> u8 @export {
    if budget == 0u32 { return 0u8 }
    if shape == 0u32 { return 0u8 }
    if shape > 6u32 { return 0u8 }                   /* outside the catalog: refuse (fail-closed) */
    let mut wi : u64 = 8u64
    while wi <= 64u64 {
        bb_reset(wi)
        let l : u32 = _cga_mx_lhs(shape)
        let r : u32 = _cga_mx_rhs(shape)
        if l == 0xFFFFFFFFu32 { return 0u8 }
        if r == 0xFFFFFFFFu32 { return 0u8 }
        if bb_equal(l, r) != 1u8 { return 0u8 }      /* SAT countermodel or capacity: discard */
        wi = wi * 2u64
    }
    let n : u32 = CGA_MX_N[0u64]
    if n >= 64u32 { return 1u8 }                     /* certified but registry full: still true */
    CGA_MX_MSG[0u64] = 0xB6u8
    CGA_MX_MSG[1u64] = (shape & 0xFFu32) as u8
    CGA_MX_MSG[2u64] = ((shape >> 8u32) & 0xFFu32) as u8
    CGA_MX_MSG[3u64] = ((shape >> 16u32) & 0xFFu32) as u8
    CGA_MX_MSG[4u64] = ((shape >> 24u32) & 0xFFu32) as u8
    let outp : *u8 = ((&CGA_MX_SEAL as u64) + (n as u64) * 32u64) as *u8
    cad_oneshot(1u32, (&CGA_MX_MSG as u64) as *u8, 5u64, outp)
    CGA_MX_A[n as u64] = shape
    CGA_MX_N[0u64] = n + 1u32
    return 1u8
}

/* sweep the whole catalog; returns the number admitted */
fn cga_mixed_discover(budget: u32) -> u32 @export {
    if budget == 0u32 { return 0u32 }
    let mut adm : u32 = 0u32
    let mut s : u32 = 1u32
    while s <= 6u32 {
        if cga_dispose_mixed(s, budget) == 1u8 { adm = adm + 1u32 }
        s = s + 1u32
    }
    return adm
}

fn cga_mixed_count() -> u32 @export { return CGA_MX_N[0u64] }
fn cga_mixed_get(i: u32) -> u32 @export {
    if i >= CGA_MX_N[0u64] { return 0xFFFFFFFFu32 }
    return CGA_MX_A[i as u64]
}
fn cga_mixed_seal_byte(i: u32, j: u32) -> u8 @export {
    if i >= CGA_MX_N[0u64] { return 0u8 }
    if j >= 32u32 { return 0u8 }
    return CGA_MX_SEAL[(i as u64) * 32u64 + (j as u64)]
}

/* ===== harmony wave-4 M2: THE SHIFT-COMBINING LAW FAMILY (domain byte 0xB7) =====================
 * The peephole class a code generator combines shifts with -- certified parametrically, with the
 * COUNT-MASK BOUNDARY enforced as the admission wall.  Authority: UNSAT via bv_bits (zero-clause
 * literal shifts; the miter is pure bit-remap equality).  THE TRANSFER CONDITION, stated exactly:
 * bv_bits models the MATHEMATICAL shift (k >= w yields 0) while silicon count-masks (k & 63), so
 * a law proven here transfers to the machine ONLY where the two models agree -- every shift count
 * involved (a, b, AND a+b) strictly below the width.  The disposer refuses anything else: the
 * silicon 'law' (x>>40)>>40 == x>>((40+40)&63) is FALSE and must never be admitted; the honest
 * law family is bounded, and the bound is part of the seal.
 *   shape 1: (x>>a)>>b == x>>(a+b)                      (right-shift combining)
 *   shape 2: (x<<a)<<b == x<<(a+b)                      (left-shift combining)
 *   shape 3: (x<<k)>>k == x & (~0 >> k)                 (mask recovery; k = a, b ignored/0)
 * Seals: cad(0xB7 || shape || a_le4 || b_le4).  Probe widths 8/16/32/64 with the PER-WIDTH bound
 * (counts below EACH probe width are required for that width's miter to be meaningful, so probes
 * narrower than the counts are SKIPPED -- w=64 is always probed and always sufficient-or-refusing). */

var CGA_SH_SHAPE : [u32; 128]
var CGA_SH_A     : [u32; 128]
var CGA_SH_B     : [u32; 128]
var CGA_SH_N     : [u32; 1]
var CGA_SH_SEAL  : [u8; 4096]   /* 128 x 32-byte cad seals */
var CGA_SH_MSG   : [u8; 13]     /* 0xB7 || shape(4) || a(4) || b(4) */

fn _cga_sh_lhs(shape: u32, a: u32, b: u32) -> u32 {
    let x : u32 = bb_var(0u32)
    if shape == 1u32 { return bb_shr(bb_shr(x, a as u64), b as u64) }
    if shape == 2u32 { return bb_shl(bb_shl(x, a as u64), b as u64) }
    if shape == 3u32 { return bb_shr(bb_shl(x, a as u64), a as u64) }
    return 0xFFFFFFFFu32
}

fn _cga_sh_rhs(shape: u32, a: u32, b: u32, w: u64) -> u32 {
    let x : u32 = bb_var(0u32)
    if shape == 1u32 { return bb_shr(x, (a as u64) + (b as u64)) }
    if shape == 2u32 { return bb_shl(x, (a as u64) + (b as u64)) }
    if shape == 3u32 {
        /* the mask is PER-WIDTH: ~0_w >> a == (1 << (w-a)) - 1.  A 64-bit-fixed mask is WRONG at
         * narrower probes -- the disposer itself caught that during bring-up (a w=16 countermodel
         * refused the width-naive term): the falsifier widths are not decoration. */
        let mask : u64 = (1u64 << (w - (a as u64))) - 1u64
        return bb_and(x, bb_const(mask))
    }
    return 0xFFFFFFFFu32
}

fn cga_dispose_shift(shape: u32, a: u32, b: u32, budget: u32) -> u8 @export {
    if budget == 0u32 { return 0u8 }
    if shape == 0u32 { return 0u8 }
    if shape > 3u32 { return 0u8 }
    /* THE COUNT-MASK WALL: every count strictly below the machine width, or refuse */
    if a >= 64u32 { return 0u8 }
    if b >= 64u32 { return 0u8 }
    if a + b >= 64u32 { return 0u8 }
    if shape == 3u32 { if b != 0u32 { return 0u8 } }     /* shape 3 is unary in a; b must be 0 */
    let mut wi : u64 = 8u64
    while wi <= 64u64 {
        /* probe only widths where the counts are in-model (w=64 always qualifies) */
        let mut skip : u32 = 0u32
        if (a as u64) >= wi { skip = 1u32 }
        if (b as u64) >= wi { skip = 1u32 }
        if ((a as u64) + (b as u64)) >= wi { skip = 1u32 }
        if skip == 0u32 {
            bb_reset(wi)
            let l : u32 = _cga_sh_lhs(shape, a, b)
            let r : u32 = _cga_sh_rhs(shape, a, b, wi)
            if l == 0xFFFFFFFFu32 { return 0u8 }
            if r == 0xFFFFFFFFu32 { return 0u8 }
            if bb_equal(l, r) != 1u8 { return 0u8 }
        }
        wi = wi * 2u64
    }
    let n : u32 = CGA_SH_N[0u64]
    if n >= 128u32 { return 1u8 }
    CGA_SH_MSG[0u64] = 0xB7u8
    CGA_SH_MSG[1u64] = (shape & 0xFFu32) as u8
    CGA_SH_MSG[2u64] = ((shape >> 8u32) & 0xFFu32) as u8
    CGA_SH_MSG[3u64] = ((shape >> 16u32) & 0xFFu32) as u8
    CGA_SH_MSG[4u64] = ((shape >> 24u32) & 0xFFu32) as u8
    CGA_SH_MSG[5u64] = (a & 0xFFu32) as u8
    CGA_SH_MSG[6u64] = ((a >> 8u32) & 0xFFu32) as u8
    CGA_SH_MSG[7u64] = ((a >> 16u32) & 0xFFu32) as u8
    CGA_SH_MSG[8u64] = ((a >> 24u32) & 0xFFu32) as u8
    CGA_SH_MSG[9u64] = (b & 0xFFu32) as u8
    CGA_SH_MSG[10u64] = ((b >> 8u32) & 0xFFu32) as u8
    CGA_SH_MSG[11u64] = ((b >> 16u32) & 0xFFu32) as u8
    CGA_SH_MSG[12u64] = ((b >> 24u32) & 0xFFu32) as u8
    let outp : *u8 = ((&CGA_SH_SEAL as u64) + (n as u64) * 32u64) as *u8
    cad_oneshot(1u32, (&CGA_SH_MSG as u64) as *u8, 13u64, outp)
    CGA_SH_SHAPE[n as u64] = shape
    CGA_SH_A[n as u64] = a
    CGA_SH_B[n as u64] = b
    CGA_SH_N[0u64] = n + 1u32
    return 1u8
}

/* the discovery sweep: shapes 1-2 over the (a,b) grid 1..G with a+b < 64; shape 3 over a in 1..G.
 * Every admission is individually UNSAT-proven; the count-mask wall bounds the family honestly. */
fn cga_shift_discover(g: u32, budget: u32) -> u32 @export {
    if budget == 0u32 { return 0u32 }
    let mut adm : u32 = 0u32
    let mut sa : u32 = 1u32
    while sa <= g {
        let mut sb : u32 = 1u32
        while sb <= g {
            if cga_dispose_shift(1u32, sa, sb, budget) == 1u8 { adm = adm + 1u32 }
            if cga_dispose_shift(2u32, sa, sb, budget) == 1u8 { adm = adm + 1u32 }
            sb = sb + 1u32
        }
        if cga_dispose_shift(3u32, sa, 0u32, budget) == 1u8 { adm = adm + 1u32 }
        sa = sa + 1u32
    }
    return adm
}

fn cga_shift_count() -> u32 @export { return CGA_SH_N[0u64] }
fn cga_shift_get_shape(i: u32) -> u32 @export {
    if i >= CGA_SH_N[0u64] { return 0xFFFFFFFFu32 }
    return CGA_SH_SHAPE[i as u64]
}

/* ===== harmony wave-4 M5: the LEASH, completed across the lattice ================================
 * cga_all_true / cga_bv_all_true re-verify the Peano and count-mask registries; these are the
 * 0xB6/0xB7 analogs -- every registered mixed/shift law is RE-PROVEN through its own disposer
 * (the volatile re-derive contract: a seal is never trusted, always re-earned).  1 iff every
 * entry re-admits; an empty registry holds vacuously (the dream may not have run yet). */
fn cga_mixed_verify_all() -> u8 @export {
    let n : u32 = CGA_MX_N[0u64]
    let mut i : u32 = 0u32
    while i < n {
        let saved : u32 = CGA_MX_N[0u64]
        if cga_dispose_mixed(CGA_MX_A[i as u64], 1u32) != 1u8 { return 0u8 }
        CGA_MX_N[0u64] = saved            /* re-proof only: do not grow the registry */
        i = i + 1u32
    }
    return 1u8
}

fn cga_shift_verify_all() -> u8 @export {
    let n : u32 = CGA_SH_N[0u64]
    let mut i : u32 = 0u32
    while i < n {
        let saved : u32 = CGA_SH_N[0u64]
        if cga_dispose_shift(CGA_SH_SHAPE[i as u64], CGA_SH_A[i as u64], CGA_SH_B[i as u64], 1u32) != 1u8 { return 0u8 }
        CGA_SH_N[0u64] = saved
        i = i + 1u32
    }
    return 1u8
}

/* wave-4 M19: the count-mask registry's pair getters -- the pipeline bridge reads them. */
fn cga_bv_get_a(i: u32) -> u32 @export {
    if i >= CGA_BV_N[0u64] { return 0xFFFFFFFFu32 }
    return CGA_BV_A[i as u64]
}
fn cga_bv_get_b(i: u32) -> u32 @export {
    if i >= CGA_BV_N[0u64] { return 0xFFFFFFFFu32 }
    return CGA_BV_B[i as u64]
}
