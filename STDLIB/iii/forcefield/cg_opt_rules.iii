/* STDLIB/iii/forcefield/cg_opt_rules.iii -- Path C: the SINGLE SOURCE OF TRUTH for cg_r3's strength-
 * reduction peephole rules, and the kernel CERTIFIER that proves each one width-faithfully.
 *
 * The F6 audit (DOCS/III-F6-LEDGER-AUDIT.md, "sovereign-optimizer") found the sov_isa BV64 shift-fold
 * proof (sov_shift_fold_witness) is genuine + width-faithful but lives in a SANDBOX (corpus/1207) that
 * never inspects the emitter -- "proof-carrying" with NO mechanical proof->emit binding (the binding was
 * a prose citation comment).  This module closes that gap: ONE table (COR_FACTOR/COR_SHIFT) drives BOTH
 *   (1) the KERNEL PROOF       -- cor_kernel_certify(i): tc_check( lam x:BV. refl(x<<k) ,
 *                                  Pi x:BV. Id(BV, x<<k, x*2^k) ) over the CIC BV64 kernel, AND
 *   (2) the WIDTH-INVARIANCE guard -- cor_width_invariant(i): factor == 1<<shift exactly.  Only an exact
 *       power of two is a width-faithful strength reduction; a non-pow2 / overflowing const-fold is
 *       REJECTED.  THE soundness contribution (the unary-model boundary, III-OPTIMIZER-PATH-C.md).
 * The binding gate (scripts/cg_optrules_bind_gate.sh) then reads THIS SAME table and asserts cg_r3's
 * ACTUAL emission for `x*factor` is `shl $shift` -- divergence (imul for a tabled pow2, or the wrong
 * shift) reddens.  So the kernel proof, the soundness guard, and the real emitter are bound to one source.
 *
 * Hexad: kind_sensitivity.  Ring: R0.  K: 1.00.  NIH: typecheck.iii CIC kernel only.
 * Determinism: integer-only; ==/!= and UNSIGNED < ; no u64 div/mod; single-source table.
 */
module forcefield_cg_opt_rules

extern @abi(c-msvc-x64) fn tc_reset() -> u64 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_var(k: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_pi(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_lam(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_id(ty: u32, lhs: u32, rhs: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_refl(a: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bv() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bvlit_u64(v: u64) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bvmul(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bvshl(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_check(t: u32, ty: u32) -> u8 from "typecheck.iii"
/* The ACTUAL strength-reduction emission law cg_r3 now delegates to (COMPILER/BOOT/cg_opt_rules.iii) --
 * proven sound here, so the certifier binds the kernel proof to the very functions that DRIVE codegen. */
extern @abi(c-msvc-x64) fn cgopt_mul_admit(v: u64) -> u32 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cgopt_mul_shift_k(v: u64) -> u32 from "cg_opt_rules.iii"
/* The NEW shl+add emission law cg_r3 gained (x*(2^k+1) -> (x<<k)+x), certified below to the SAME standard. */
extern @abi(c-msvc-x64) fn cgopt_mul_shladd_admit(v: u64) -> u32 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cgopt_mul_shladd_k(v: u64) -> u32 from "cg_opt_rules.iii"
/* The NEW shl-sub emission law cg_r3 gained THIS SESSION (x*(2^k-1) -> (x<<k)-x), certified below identically. */
extern @abi(c-msvc-x64) fn cgopt_mul_subk_admit(v: u64) -> u32 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cgopt_mul_subk_k(v: u64) -> u32 from "cg_opt_rules.iii"
/* The NEW signed-div emission law cg_r3 gained (i64 x/2^k -> bias+sar), certified below by COMPLETE
 * small-width sweeps against the hardware divider -- the two-engine law at the silicon altitude. */
extern @abi(c-msvc-x64) fn cgopt_sdiv_admit(v: u64) -> u32 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cgopt_sdiv_k(v: u64) -> u32 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cgopt_sdiv_mask(v: u64) -> u64 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cgopt_mul_2sh_admit(v: u64) -> u32 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cgopt_mul_2sh_j(v: u64) -> u32 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cgopt_mul_2sh_m(v: u64) -> u32 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cgopt_mul_2ss_admit(v: u64) -> u32 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cgopt_mul_2ss_j(v: u64) -> u32 from "cg_opt_rules.iii"
extern @abi(c-msvc-x64) fn cgopt_mul_2ss_m(v: u64) -> u32 from "cg_opt_rules.iii"
/* TWO INDEPENDENT proof engines for the shladd law (the kernel's refl CANNOT distribute mul over add, so
 * the pow2 certifier's engine does not transfer -- empirically confirmed).  (1) bv_ring: ALGEBRAIC, proves
 * the full range k=1..63 by polynomial normalization over Z/2^64 (distributivity, circuit-independent,
 * cheap).  (2) bv_bits SAT: BIT-LEVEL, an exhaustive-valuation cross-witness on a small sample. */
extern @abi(c-msvc-x64) fn bv_reset() -> i32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_const(c: u64) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_var(v: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_add(a: u32, b: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_sub(a: u32, b: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_mul(a: u32, b: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_shl(a: u32, k: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_equal(a: u32, b: u32) -> u8 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shl(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_add(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_sub(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_mul(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_equal(a: u32, b: u32) -> u8 from "bv_bits.iii"

/* The SR rule table: row i = (factor 2^shift  ->  emit `shl $shift`).  Covers the FULL emittable range
 * shift 1..63 -- exactly what cg_r3's r3_mul_pow2_k can emit (an F6 re-audit flagged that the old 7-row
 * sample, like the sov_isa proof set, UNDER-COVERED the emitter).  SINGLE SOURCE OF TRUTH. */
const COR_N : u64 = 63u64
var COR_SHIFT  : [u64; 63]
var COR_FACTOR : [u64; 63]
var COR_INIT : u64 = 0u64

fn cor_init() -> u64 {
    if COR_INIT == 1u64 { return 0u64 }
    let mut i : u64 = 0u64
    while i < COR_N {
        COR_SHIFT[i] = i + 1u64                 /* shifts 1..63 */
        COR_FACTOR[i] = 1u64 << (i + 1u64)      /* the exact power of two 2^1..2^63 */
        i = i + 1u64
    }
    COR_INIT = 1u64
    return 0u64
}

fn cor_rule_count() -> u64 @export { cor_init() return COR_N }
fn cor_shift_at(i: u64) -> u64 @export { cor_init() if i >= COR_N { return 0u64 } return COR_SHIFT[i] }
fn cor_factor_at(i: u64) -> u64 { cor_init() if i >= COR_N { return 0u64 } return COR_FACTOR[i] }

/* (2) WIDTH-INVARIANCE guard: width-faithful iff factor is EXACTLY 2^shift (and shift in range). */
fn cor_width_invariant_kf(shift: u64, factor: u64) -> u8 {
    if shift >= 64u64 { return 0u8 }
    let p : u64 = 1u64 << shift
    if p == factor { return 1u8 }
    return 0u8
}
fn cor_width_invariant(i: u64) -> u8 {
    cor_init()
    if i >= COR_N { return 0u8 }
    return cor_width_invariant_kf(COR_SHIFT[i], COR_FACTOR[i])
}

/* (1) KERNEL PROOF: tc_check( lam x:BV. refl(x<<shift) ,  Pi x:BV. Id(BV, x<<shift, x*factor) ).
 * 1 iff the CIC BV64 kernel certifies x<<shift == x*factor mod 2^64 (the same proof sov_isa runs). */
fn cor_kernel_certify_kf(shift: u64, factor: u64) -> u8 {
    tc_reset()
    let lhs : u32 = tc_bvshl(tc_var(0u32), tc_bvlit_u64(shift))
    let rhs : u32 = tc_bvmul(tc_var(0u32), tc_bvlit_u64(factor))
    let goal : u32 = tc_pi(tc_bv(), tc_id(tc_bv(), lhs, rhs))
    let cert : u32 = tc_lam(tc_bv(), tc_refl(lhs))
    return tc_check(cert, goal)
}
fn cor_kernel_certify(i: u64) -> u8 {
    cor_init()
    if i >= COR_N { return 0u8 }
    return cor_kernel_certify_kf(COR_SHIFT[i], COR_FACTOR[i])
}

/* The CERTIFIER: every tabled rule must pass BOTH the width-invariance guard AND the kernel proof.
 * 99 = all certified; (100+i) = rule i fails width-invariance; (200+i) = rule i fails the kernel proof. */
fn cor_certify_all() -> u64 @export {
    cor_init()
    let mut i : u64 = 0u64
    while i < COR_N {
        if cor_width_invariant_kf(COR_SHIFT[i], COR_FACTOR[i]) != 1u8 { return 100u64 + i }
        if cor_kernel_certify_kf(COR_SHIFT[i], COR_FACTOR[i]) != 1u8 { return 200u64 + i }
        i = i + 1u64
    }
    return 99u64
}

/* PROVE-THE-NEGATIVE: the certifier has TEETH -- it REJECTS unsound rules, so 99 is not vacuous.
 *   (a) a NON-pow2 factor (3) fails the width-invariance guard;
 *   (b) a mismatched (shift=1, factor=4) fails BOTH the guard (1<<1=2 != 4) AND the kernel proof
 *       (the x<<1 certificate does NOT prove x*4 -- sov_isa line 2614). 1 iff every unsound rule rejected. */
fn cor_rejects_unsound() -> u8 @export {
    if cor_width_invariant_kf(1u64, 3u64) != 0u8 { return 0u8 }       /* 3 not pow2 -> width REJECTS */
    if cor_width_invariant_kf(1u64, 4u64) != 0u8 { return 0u8 }       /* 1<<1=2 != 4 -> width REJECTS */
    tc_reset()
    let lhs : u32 = tc_bvshl(tc_var(0u32), tc_bvlit_u64(1u64))
    let bad : u32 = tc_pi(tc_bv(), tc_id(tc_bv(), lhs, tc_bvmul(tc_var(0u32), tc_bvlit_u64(4u64))))
    let cert : u32 = tc_lam(tc_bv(), tc_refl(lhs))
    if tc_check(cert, bad) != 0u8 { return 0u8 }                      /* kernel REJECTS the off-by-one fold */
    return 1u8
}

/* THE PROOF->EMIT BINDING (Path C, now mechanical at the SOURCE level): the ACTUAL functions cg_r3
 * delegates to (cgopt_mul_admit / cgopt_mul_shift_k in COMPILER/BOOT/cg_opt_rules.iii) agree with this
 * kernel-certified table on EVERY rule -- so proving the table proves the live emitter.  1 iff agreement:
 *   for each certified rule (factor 2^k): cgopt_mul_admit(factor)==1 AND cgopt_mul_shift_k(factor)==k;
 *   AND the emitter REJECTS what the certifier rejects (non-pow2 3/6, and 0/1 below the floor). */
fn cor_boot_agrees() -> u8 @export {
    cor_init()
    let mut i : u64 = 0u64
    while i < COR_N {
        if cgopt_mul_admit(COR_FACTOR[i]) != 1u32 { return 0u8 }
        if (cgopt_mul_shift_k(COR_FACTOR[i]) as u64) != COR_SHIFT[i] { return 0u8 }
        i = i + 1u64
    }
    if cgopt_mul_admit(0u64) != 0u32 { return 0u8 }     /* below the floor */
    if cgopt_mul_admit(1u64) != 0u32 { return 0u8 }     /* x*1 is the identity fold, not a shift */
    if cgopt_mul_admit(3u64) != 0u32 { return 0u8 }     /* non-pow2 */
    if cgopt_mul_admit(6u64) != 0u32 { return 0u8 }     /* non-pow2 */
    return 1u8
}

/* ============================================================================================
 * SHL-ADD STRENGTH REDUCTION -- the rule cg_r3 GAINED (x*(2^k+1) -> (x<<k)+x: one shl + one add in
 * place of a full imul).  Certified to the SAME gospel standard as the pow2 rule above, but with TWO
 * INDEPENDENT proof engines (single-engine trust is the weakness the cross-prover discipline removes):
 *   (1) bv_ring (ALGEBRAIC, FULL range k=1..63): (x<<k)+x and x*(2^k+1) normalize to the SAME canonical
 *       polynomial (2^k+1)*x over Z/2^64 -- pure distributivity, independent of any bit circuit, cheap.
 *   (2) bv_bits SAT (BIT-LEVEL, SAMPLE): bb_equal proves the miter UNSAT over all 2^64 valuations on
 *       representative rules -- the exhaustive-valuation engine corroborates the algebraic one.  Sampled
 *       (not full range): bb_mul builds a general O(w^2) multiplier whose miter is intractable across all
 *       63 (measured: >5 min), so the ALGEBRAIC engine carries coverage and SAT independently confirms it.
 * Plus a SHAPE guard (factor == 2^k+1 exactly), BOOT-emitter agreement, and a negative arm with teeth.
 * Soundness: x*(2^k+1) == x*2^k + x == (x<<k)+x mod 2^64 for k in 1..63 (bv_shl models the x86 k&63 mask).
 * The kernel's refl was empirically confirmed UNABLE to prove this (it does not distribute mul over add),
 * so the pow2 engine genuinely does not transfer -- this is a real second proof faculty, not a copy. */
var COR_SL_K      : [u64; 63]
var COR_SL_FACTOR : [u64; 63]
var COR_SL_INIT   : u64 = 0u64

fn cor_sl_init() -> u64 {
    if COR_SL_INIT == 1u64 { return 0u64 }
    let mut i : u64 = 0u64
    while i < COR_N {
        COR_SL_K[i] = i + 1u64                          /* k = 1..63 */
        COR_SL_FACTOR[i] = (1u64 << (i + 1u64)) + 1u64  /* factor = 2^k + 1 */
        i = i + 1u64
    }
    COR_SL_INIT = 1u64
    return 0u64
}

fn cor_sl_rule_count() -> u64 @export { cor_sl_init() return COR_N }
fn cor_sl_shift_at(i: u64) -> u64 @export { cor_sl_init() if i >= COR_N { return 0u64 } return COR_SL_K[i] }
fn cor_sl_factor_at(i: u64) -> u64 { cor_sl_init() if i >= COR_N { return 0u64 } return COR_SL_FACTOR[i] }

/* SHAPE guard: width-faithful shladd iff factor == 2^k+1 exactly and k in 1..63. */
fn cor_sl_shape_kf(k: u64, factor: u64) -> u8 {
    if k < 1u64 { return 0u8 }
    if k >= 64u64 { return 0u8 }
    let p : u64 = (1u64 << k) + 1u64
    if p == factor { return 1u8 }
    return 0u8
}

/* (1) ALGEBRAIC proof (bv_ring): (x<<k)+x and x*factor are the SAME polynomial over Z/2^64. */
fn cor_sl_ring_certify_kf(k: u64, factor: u64) -> u8 {
    bv_reset()
    let x : u32 = bv_var(0u32)
    let lhs : u32 = bv_add(bv_shl(x, k as u32), x)
    let rhs : u32 = bv_mul(x, bv_const(factor))
    return bv_equal(lhs, rhs)
}
fn cor_sl_kernel_certify(i: u64) -> u8 {
    cor_sl_init()
    if i >= COR_N { return 0u8 }
    return cor_sl_ring_certify_kf(COR_SL_K[i], COR_SL_FACTOR[i])
}

/* (2) BIT-LEVEL proof (bv_bits SAT): the miter (x<<k)+x vs x*factor is UNSAT over all 2^64 valuations. */
fn cor_sl_sat_certify_kf(k: u64, factor: u64) -> u8 {
    bb_reset(64u64)
    let x : u32 = bb_var(0u32)
    let lhs : u32 = bb_add(bb_shl(x, k), x)
    let rhs : u32 = bb_mul(x, bb_const(factor))
    return bb_equal(lhs, rhs)
}

/* The shladd CERTIFIER: every tabled rule passes the SHAPE guard AND the algebraic (full-range) proof; a
 * representative SAMPLE additionally passes the independent bit-level SAT proof.  99 = all certified;
 * (300+i) shape fail; (400+i) algebraic fail; (50N) SAT-sample fail. */
fn cor_sl_certify_all() -> u64 @export {
    cor_sl_init()
    let mut i : u64 = 0u64
    while i < COR_N {
        if cor_sl_shape_kf(COR_SL_K[i], COR_SL_FACTOR[i]) != 1u8 { return 300u64 + i }
        if cor_sl_ring_certify_kf(COR_SL_K[i], COR_SL_FACTOR[i]) != 1u8 { return 400u64 + i }
        i = i + 1u64
    }
    if cor_sl_sat_certify_kf(1u64, 3u64) != 1u8 { return 501u64 }
    if cor_sl_sat_certify_kf(2u64, 5u64) != 1u8 { return 502u64 }
    if cor_sl_sat_certify_kf(3u64, 9u64) != 1u8 { return 503u64 }
    return 99u64
}

/* PROVE-THE-NEGATIVE for shladd: BOTH engines reject a false rule, and the shape guard rejects non-(2^k+1)
 * factors -- so 99 is not vacuous.  1 iff every unsound case is rejected. */
fn cor_sl_rejects_unsound() -> u8 @export {
    if cor_sl_shape_kf(1u64, 5u64) != 0u8 { return 0u8 }   /* 2^1+1=3 != 5 -> shape REJECTS */
    if cor_sl_shape_kf(2u64, 4u64) != 0u8 { return 0u8 }   /* 4 is pow2, not 2^k+1 -> shape REJECTS */
    if cor_sl_shape_kf(0u64, 2u64) != 0u8 { return 0u8 }   /* k<1 -> shape REJECTS */
    bv_reset()
    let x : u32 = bv_var(0u32)
    let nr : u8 = bv_equal(bv_add(bv_shl(x, 1u32), x), bv_mul(x, bv_const(5u64)))
    if nr != 0u8 { return 0u8 }                            /* algebraic: 3x != 5x */
    bb_reset(64u64)
    let y : u32 = bb_var(0u32)
    let ns : u8 = bb_equal(bb_add(bb_shl(y, 1u64), y), bb_mul(y, bb_const(5u64)))
    if ns != 0u8 { return 0u8 }                            /* bit-level: 3x != 5x (countermodel) */
    return 1u8
}

/* BOOT-emitter agreement for shladd: the ACTUAL functions cg_r3 delegates to (cgopt_mul_shladd_admit /
 * cgopt_mul_shladd_k) agree with this certified table on every rule, and REJECT what the certifier
 * rejects.  1 iff agreement. */
fn cor_sl_boot_agrees() -> u8 @export {
    cor_sl_init()
    let mut i : u64 = 0u64
    while i < COR_N {
        if cgopt_mul_shladd_admit(COR_SL_FACTOR[i]) != 1u32 { return 0u8 }
        if (cgopt_mul_shladd_k(COR_SL_FACTOR[i]) as u64) != COR_SL_K[i] { return 0u8 }
        i = i + 1u64
    }
    if cgopt_mul_shladd_admit(0u64) != 0u32 { return 0u8 }   /* below floor */
    if cgopt_mul_shladd_admit(1u64) != 0u32 { return 0u8 }   /* below floor */
    if cgopt_mul_shladd_admit(2u64) != 0u32 { return 0u8 }   /* v < 3 */
    if cgopt_mul_shladd_admit(4u64) != 0u32 { return 0u8 }   /* pow2, not 2^k+1 */
    if cgopt_mul_shladd_admit(7u64) != 0u32 { return 0u8 }   /* non-(2^k+1) */
    if cgopt_mul_shladd_admit(8u64) != 0u32 { return 0u8 }   /* pow2 */
    return 1u8
}

/* ============================================================================================
 * SHL-SUB STRENGTH REDUCTION -- the rule cg_r3 GAINED THIS SESSION (x*(2^k-1) -> (x<<k)-x: one shl + one
 * sub in place of a full imul, for the Mersenne factors 7,15,31,...,2^63-1).  Certified to the SAME gospel
 * standard as shladd, with TWO INDEPENDENT engines proving the EXACT emitted form (x<<k)-x:
 *   (1) bv_ring (ALGEBRAIC, FULL range k=3..63): bv_sub(x<<k, x) and x*(2^k-1) normalize to the SAME
 *       canonical polynomial (2^k-1)*x over Z/2^64 -- pure distributivity, circuit-independent, cheap.
 *   (2) bv_bits SAT (BIT-LEVEL, SAMPLE): bb_equal proves the miter bb_sub(x<<k,x) vs x*(2^k-1) UNSAT over
 *       all 2^64 valuations -- the exhaustive-valuation engine corroborates the algebraic one (sampled, as
 *       bb_mul's general multiplier makes the full-range miter intractable; the ring carries coverage).
 * Plus a SHAPE guard (factor == 2^k-1, k>=3), BOOT-emitter agreement, and a negative arm with teeth.
 * Soundness: x*(2^k-1) == x*2^k - x == (x<<k)-x mod 2^64.  k=1,2 EXCLUDED: 2^1-1=1 is the identity fold;
 * 2^2-1=3 is also 2^1+1, owned by shladd (cg_r3 tries shl+add first) -- 3 being the unique 2^k-1 that is
 * also 2^j+1, the k>=3 domain {7,15,...} is shladd-disjoint. */
var COR_SS_K      : [u64; 61]
var COR_SS_FACTOR : [u64; 61]
var COR_SS_INIT   : u64 = 0u64
const COR_SS_N : u64 = 61u64                     /* k = 3..63 -> 61 rules */

fn cor_ss_init() -> u64 {
    if COR_SS_INIT == 1u64 { return 0u64 }
    let mut i : u64 = 0u64
    while i < COR_SS_N {
        COR_SS_K[i] = i + 3u64                          /* k = 3..63 */
        COR_SS_FACTOR[i] = (1u64 << (i + 3u64)) - 1u64  /* factor = 2^k - 1 */
        i = i + 1u64
    }
    COR_SS_INIT = 1u64
    return 0u64
}

fn cor_ss_rule_count() -> u64 @export { cor_ss_init() return COR_SS_N }
fn cor_ss_shift_at(i: u64) -> u64 @export { cor_ss_init() if i >= COR_SS_N { return 0u64 } return COR_SS_K[i] }
fn cor_ss_factor_at(i: u64) -> u64 { cor_ss_init() if i >= COR_SS_N { return 0u64 } return COR_SS_FACTOR[i] }

/* SHAPE guard: width-faithful shl-sub iff factor == 2^k-1 exactly and k in 3..63. */
fn cor_ss_shape_kf(k: u64, factor: u64) -> u8 {
    if k < 3u64 { return 0u8 }
    if k >= 64u64 { return 0u8 }
    let p : u64 = (1u64 << k) - 1u64
    if p == factor { return 1u8 }
    return 0u8
}

/* (1) ALGEBRAIC proof (bv_ring): bv_sub(x<<k, x) and x*factor are the SAME polynomial over Z/2^64. */
fn cor_ss_ring_certify_kf(k: u64, factor: u64) -> u8 {
    bv_reset()
    let x : u32 = bv_var(0u32)
    let lhs : u32 = bv_sub(bv_shl(x, k as u32), x)
    let rhs : u32 = bv_mul(x, bv_const(factor))
    return bv_equal(lhs, rhs)
}
fn cor_ss_kernel_certify(i: u64) -> u8 {
    cor_ss_init()
    if i >= COR_SS_N { return 0u8 }
    return cor_ss_ring_certify_kf(COR_SS_K[i], COR_SS_FACTOR[i])
}

/* (2) BIT-LEVEL proof (bv_bits SAT): the miter bb_sub(x<<k,x) vs x*factor is UNSAT over all 2^64 valuations. */
fn cor_ss_sat_certify_kf(k: u64, factor: u64) -> u8 {
    bb_reset(64u64)
    let x : u32 = bb_var(0u32)
    let lhs : u32 = bb_sub(bb_shl(x, k), x)
    let rhs : u32 = bb_mul(x, bb_const(factor))
    return bb_equal(lhs, rhs)
}

/* The shl-sub CERTIFIER: every tabled rule passes the SHAPE guard AND the algebraic (full-range) proof; a
 * representative SAMPLE additionally passes the independent bit-level SAT proof.  99 = all certified;
 * (600+i) shape fail; (700+i) algebraic fail; (80N) SAT-sample fail. */
fn cor_ss_certify_all() -> u64 @export {
    cor_ss_init()
    let mut i : u64 = 0u64
    while i < COR_SS_N {
        if cor_ss_shape_kf(COR_SS_K[i], COR_SS_FACTOR[i]) != 1u8 { return 600u64 + i }
        if cor_ss_ring_certify_kf(COR_SS_K[i], COR_SS_FACTOR[i]) != 1u8 { return 700u64 + i }
        i = i + 1u64
    }
    if cor_ss_sat_certify_kf(3u64, 7u64) != 1u8 { return 801u64 }
    if cor_ss_sat_certify_kf(4u64, 15u64) != 1u8 { return 802u64 }
    if cor_ss_sat_certify_kf(5u64, 31u64) != 1u8 { return 803u64 }
    return 99u64
}

/* PROVE-THE-NEGATIVE for shl-sub: BOTH engines reject a false rule, and the shape guard rejects non-(2^k-1)
 * factors -- so 99 is not vacuous.  1 iff every unsound case is rejected. */
fn cor_ss_rejects_unsound() -> u8 @export {
    if cor_ss_shape_kf(3u64, 9u64) != 0u8 { return 0u8 }   /* 2^3-1=7 != 9 -> shape REJECTS */
    if cor_ss_shape_kf(3u64, 8u64) != 0u8 { return 0u8 }   /* 8 is pow2, not 2^k-1 -> shape REJECTS */
    if cor_ss_shape_kf(2u64, 3u64) != 0u8 { return 0u8 }   /* k<3 (shladd's domain) -> shape REJECTS */
    bv_reset()
    let x : u32 = bv_var(0u32)
    let nr : u8 = bv_equal(bv_sub(bv_shl(x, 3u32), x), bv_mul(x, bv_const(9u64)))
    if nr != 0u8 { return 0u8 }                            /* algebraic: 7x != 9x */
    bb_reset(64u64)
    let y : u32 = bb_var(0u32)
    let ns : u8 = bb_equal(bb_sub(bb_shl(y, 3u64), y), bb_mul(y, bb_const(9u64)))
    if ns != 0u8 { return 0u8 }                            /* bit-level: 7x != 9x (countermodel) */
    return 1u8
}

/* BOOT-emitter agreement for shl-sub: cgopt_mul_subk_admit / cgopt_mul_subk_k agree with this certified
 * table on every rule, and REJECT what the certifier rejects.  1 iff agreement. */
fn cor_ss_boot_agrees() -> u8 @export {
    cor_ss_init()
    let mut i : u64 = 0u64
    while i < COR_SS_N {
        if cgopt_mul_subk_admit(COR_SS_FACTOR[i]) != 1u32 { return 0u8 }
        if (cgopt_mul_subk_k(COR_SS_FACTOR[i]) as u64) != COR_SS_K[i] { return 0u8 }
        i = i + 1u64
    }
    if cgopt_mul_subk_admit(0u64) != 0u32 { return 0u8 }   /* below floor */
    if cgopt_mul_subk_admit(1u64) != 0u32 { return 0u8 }   /* identity (x*1) */
    if cgopt_mul_subk_admit(3u64) != 0u32 { return 0u8 }   /* 2^2-1 but shladd's by dispatch (v<7) */
    if cgopt_mul_subk_admit(5u64) != 0u32 { return 0u8 }   /* not 2^k-1 */
    if cgopt_mul_subk_admit(8u64) != 0u32 { return 0u8 }   /* pow2 */
    if cgopt_mul_subk_admit(9u64) != 0u32 { return 0u8 }   /* not 2^k-1 */
    return 1u8
}

/* The full self-test: ALL THREE strength-reduction rules cg_r3 delegates here are certified.  POW2 (x*2^k ->
 * shl): kernel-certified width-faithfully, negative arm bites, boot emitter agrees.  SHL-ADD (x*(2^k+1) ->
 * shl+add) and SHL-SUB (x*(2^k-1) -> shl+sub): each certified by TWO independent engines (bv_ring full range
 * + bv_bits SAT sample), shape guard + negative arm + boot emitter agreement. 99 = every arm of ALL THREE. */
/* ============================================================================================
 * TWO-SHIFT STRENGTH REDUCTION -- the rule cg_r3 GAINED via seraphyte_add_2shift.sh (x*(2^j+2^m) ->
 * (x<<j)+(x<<m): two shifts + one add in place of a full imul, for popcount-2 EVEN factors 6,10,12,20,...).
 * Certified to the SAME standard as subk/shladd: the bv_ring ALGEBRAIC engine proves the EXACT emitted form
 * (x<<j)+(x<<m) normalizes to the polynomial (2^j+2^m)*x over Z/2^64 across a representative table; a shape
 * guard + negative arm + BOOT-emitter agreement make 99 non-vacuous. */
var COR_2S_J      : [u64; 14]
var COR_2S_M      : [u64; 14]
var COR_2S_FACTOR : [u64; 14]
var COR_2S_INIT   : u64 = 0u64
const COR_2S_N    : u64 = 14u64
fn cor_2s_set(i: u64, j: u64, m: u64) -> u64 {
    COR_2S_J[i] = j
    COR_2S_M[i] = m
    COR_2S_FACTOR[i] = (1u64 << j) + (1u64 << m)
    return 0u64
}
fn cor_2s_init() -> u64 {
    if COR_2S_INIT == 1u64 { return 0u64 }
    cor_2s_set(0u64, 2u64, 1u64)      /* 6    */
    cor_2s_set(1u64, 3u64, 1u64)      /* 10   */
    cor_2s_set(2u64, 3u64, 2u64)      /* 12   */
    cor_2s_set(3u64, 4u64, 2u64)      /* 20   */
    cor_2s_set(4u64, 5u64, 1u64)      /* 34   */
    cor_2s_set(5u64, 5u64, 3u64)      /* 40   */
    cor_2s_set(6u64, 5u64, 4u64)      /* 48   */
    cor_2s_set(7u64, 10u64, 1u64)     /* 1026 */
    cor_2s_set(8u64, 20u64, 4u64)
    cor_2s_set(9u64, 31u64, 1u64)
    cor_2s_set(10u64, 40u64, 20u64)
    cor_2s_set(11u64, 62u64, 1u64)
    cor_2s_set(12u64, 63u64, 1u64)    /* large edge: 2^63 + 2^1 */
    cor_2s_set(13u64, 63u64, 62u64)   /* 2^63 + 2^62 */
    COR_2S_INIT = 1u64
    return 0u64
}
fn cor_2s_rule_count() -> u64 @export { cor_2s_init() return COR_2S_N }
/* SHAPE: factor == 2^j + 2^m exactly, j > m >= 1. */
fn cor_2s_shape_jmf(j: u64, m: u64, factor: u64) -> u8 {
    if m < 1u64 { return 0u8 }
    if j <= m { return 0u8 }
    if j > 63u64 { return 0u8 }
    if ((1u64 << j) + (1u64 << m)) != factor { return 0u8 }
    return 1u8
}
/* ALGEBRAIC (bv_ring): (x<<j)+(x<<m) and x*factor are the SAME polynomial over Z/2^64. */
fn cor_2s_ring_certify_jmf(j: u64, m: u64, factor: u64) -> u8 {
    bv_reset()
    let x : u32 = bv_var(0u32)
    return bv_equal(bv_add(bv_shl(x, j as u32), bv_shl(x, m as u32)), bv_mul(x, bv_const(factor)))
}
/* 99 = every table rule passes shape + algebraic; (800+i) shape fail; (850+i) algebraic fail. */
fn cor_2s_certify_all() -> u64 @export {
    cor_2s_init()
    let mut i : u64 = 0u64
    while i < COR_2S_N {
        if cor_2s_shape_jmf(COR_2S_J[i], COR_2S_M[i], COR_2S_FACTOR[i]) != 1u8 { return 800u64 + i }
        if cor_2s_ring_certify_jmf(COR_2S_J[i], COR_2S_M[i], COR_2S_FACTOR[i]) != 1u8 { return 850u64 + i }
        i = i + 1u64
    }
    return 99u64
}
/* PROVE-THE-NEGATIVE: a wrong decomposition is rejected by shape AND by the algebraic engine. */
fn cor_2s_rejects_unsound() -> u8 @export {
    if cor_2s_shape_jmf(3u64, 1u64, 12u64) != 0u8 { return 0u8 }    /* 2^3+2^1=10 != 12 -> shape REJECTS */
    if cor_2s_shape_jmf(0u64, 0u64, 1u64) != 0u8 { return 0u8 }     /* m<1 -> REJECTS */
    bv_reset()
    let x : u32 = bv_var(0u32)
    if bv_equal(bv_add(bv_shl(x, 3u32), bv_shl(x, 1u32)), bv_mul(x, bv_const(12u64))) != 0u8 { return 0u8 }  /* 10x != 12x */
    return 1u8
}
/* BOOT-emitter agreement: the ACTUAL cgopt_mul_2sh_* cg_r3 delegates to agree with the certified table and
 * REJECT what the certifier rejects (odd, pow2, popcount != 2). */
fn cor_2s_boot_agrees() -> u8 @export {
    cor_2s_init()
    let mut i : u64 = 0u64
    while i < COR_2S_N {
        if cgopt_mul_2sh_admit(COR_2S_FACTOR[i]) != 1u32 { return 0u8 }
        if (cgopt_mul_2sh_j(COR_2S_FACTOR[i]) as u64) != COR_2S_J[i] { return 0u8 }
        if (cgopt_mul_2sh_m(COR_2S_FACTOR[i]) as u64) != COR_2S_M[i] { return 0u8 }
        i = i + 1u64
    }
    if cgopt_mul_2sh_admit(7u64) != 0u32 { return 0u8 }    /* odd popcount-3 */
    if cgopt_mul_2sh_admit(9u64) != 0u32 { return 0u8 }    /* 2^3+1 odd (shladd's) */
    if cgopt_mul_2sh_admit(8u64) != 0u32 { return 0u8 }    /* pow2 */
    if cgopt_mul_2sh_admit(11u64) != 0u32 { return 0u8 }   /* popcount-3 */
    return 1u8
}

/* ============================================================================================
 * 2-SHIFT-SUBTRACT STRENGTH REDUCTION -- the SECOND emitter-produced family (seraphyte_add_2sub.sh):
 * x*(2^j-2^m) -> (x<<j)-(x<<m) for CONTIGUOUS-RUN factors (14,28,30,56,60,...; even, popcount>=3, run not
 * from bit 0).  Disjoint from 2-shift-add (popcount 2) and subk (run from bit 0).  Certified like cor_2s:
 * bv_ring proves (x<<j)-(x<<m) == (2^j-2^m)*x across a representative table; shape + negative + boot agreement. */
var COR_2SS_J      : [u64; 12]
var COR_2SS_M      : [u64; 12]
var COR_2SS_FACTOR : [u64; 12]
var COR_2SS_INIT   : u64 = 0u64
const COR_2SS_N    : u64 = 12u64
fn cor_2ss_set(i: u64, j: u64, m: u64) -> u64 {
    COR_2SS_J[i] = j
    COR_2SS_M[i] = m
    COR_2SS_FACTOR[i] = (1u64 << j) - (1u64 << m)
    return 0u64
}
fn cor_2ss_init() -> u64 {
    if COR_2SS_INIT == 1u64 { return 0u64 }
    cor_2ss_set(0u64, 4u64, 1u64)      /* 14    */
    cor_2ss_set(1u64, 5u64, 2u64)      /* 28    */
    cor_2ss_set(2u64, 5u64, 1u64)      /* 30    */
    cor_2ss_set(3u64, 6u64, 3u64)      /* 56    */
    cor_2ss_set(4u64, 6u64, 2u64)      /* 60    */
    cor_2ss_set(5u64, 10u64, 1u64)     /* 1022  */
    cor_2ss_set(6u64, 8u64, 4u64)      /* 240   */
    cor_2ss_set(7u64, 20u64, 3u64)
    cor_2ss_set(8u64, 31u64, 1u64)
    cor_2ss_set(9u64, 40u64, 20u64)
    cor_2ss_set(10u64, 63u64, 1u64)    /* 2^63 - 2^1 */
    cor_2ss_set(11u64, 63u64, 60u64)   /* 2^63 - 2^60 */
    COR_2SS_INIT = 1u64
    return 0u64
}
fn cor_2ss_rule_count() -> u64 @export { cor_2ss_init() return COR_2SS_N }
/* SHAPE: factor == 2^j - 2^m, j > m >= 1, run length j-m >= 3. */
fn cor_2ss_shape_jmf(j: u64, m: u64, factor: u64) -> u8 {
    if m < 1u64 { return 0u8 }
    if j <= m { return 0u8 }
    if (j - m) < 3u64 { return 0u8 }
    if j > 63u64 { return 0u8 }
    if ((1u64 << j) - (1u64 << m)) != factor { return 0u8 }
    return 1u8
}
/* ALGEBRAIC (bv_ring): (x<<j)-(x<<m) and x*factor are the SAME polynomial over Z/2^64. */
fn cor_2ss_ring_certify_jmf(j: u64, m: u64, factor: u64) -> u8 {
    bv_reset()
    let x : u32 = bv_var(0u32)
    return bv_equal(bv_sub(bv_shl(x, j as u32), bv_shl(x, m as u32)), bv_mul(x, bv_const(factor)))
}
/* 99 = every table rule passes; (900+i) shape fail; (950+i) algebraic fail. */
fn cor_2ss_certify_all() -> u64 @export {
    cor_2ss_init()
    let mut i : u64 = 0u64
    while i < COR_2SS_N {
        if cor_2ss_shape_jmf(COR_2SS_J[i], COR_2SS_M[i], COR_2SS_FACTOR[i]) != 1u8 { return 900u64 + i }
        if cor_2ss_ring_certify_jmf(COR_2SS_J[i], COR_2SS_M[i], COR_2SS_FACTOR[i]) != 1u8 { return 950u64 + i }
        i = i + 1u64
    }
    return 99u64
}
fn cor_2ss_rejects_unsound() -> u8 @export {
    if cor_2ss_shape_jmf(4u64, 1u64, 28u64) != 0u8 { return 0u8 }   /* 2^4-2^1=14 != 28 -> shape REJECTS */
    if cor_2ss_shape_jmf(3u64, 1u64, 6u64) != 0u8 { return 0u8 }    /* j-m=2 < 3 (popcount-2, 2-add's) -> REJECTS */
    bv_reset()
    let x : u32 = bv_var(0u32)
    if bv_equal(bv_sub(bv_shl(x, 4u32), bv_shl(x, 1u32)), bv_mul(x, bv_const(28u64))) != 0u8 { return 0u8 }  /* 14x != 28x */
    return 1u8
}
fn cor_2ss_boot_agrees() -> u8 @export {
    cor_2ss_init()
    let mut i : u64 = 0u64
    while i < COR_2SS_N {
        if cgopt_mul_2ss_admit(COR_2SS_FACTOR[i]) != 1u32 { return 0u8 }
        if (cgopt_mul_2ss_j(COR_2SS_FACTOR[i]) as u64) != COR_2SS_J[i] { return 0u8 }
        if (cgopt_mul_2ss_m(COR_2SS_FACTOR[i]) as u64) != COR_2SS_M[i] { return 0u8 }
        i = i + 1u64
    }
    if cgopt_mul_2ss_admit(24u64) != 0u32 { return 0u8 }   /* popcount-2 (2-add's) */
    if cgopt_mul_2ss_admit(7u64) != 0u32 { return 0u8 }    /* odd (subk's) */
    if cgopt_mul_2ss_admit(8u64) != 0u32 { return 0u8 }    /* pow2 */
    if cgopt_mul_2ss_admit(22u64) != 0u32 { return 0u8 }   /* not a contiguous run */
    return 1u8
}

/* ============================================================================================
 * SIGNED-DIV-BY-POW2 BIAS+SAR -- the rule cg_r3 gained (i64 x/2^k -> movq/sarq63/movabsq/andq/
 * addq/sarq k: six cheap ops for a cqto+idivq).  Soundness: for ALL i64 x and k in 1..62,
 *     trunc(x / 2^k) == (x + ((x >>a 63) & (2^k - 1))) >>a k
 * (x >= 0: bias 0, sar = floor = trunc; x < 0: trunc = ceil = floor((x + 2^k - 1)/2^k); the bias
 * add cannot overflow; v = 2^63 is EXCLUDED -- as a u64 literal it reads i64-negative).
 * CERTIFIED BY TWO ENGINES AT THE SILICON ALTITUDE: the exact emitted bias sequence (rebuilt here
 * from u64 primitives, arithmetic shift emulated explicitly) against the HARDWARE DIVIDER (i64 /
 * with a VARIABLE divisor -- compiles to cqto+idivq, so the reference cannot route through the very
 * fold being certified).  COMPLETE at width 8 (all 256 x, every k) and width 16 (all 65536 x, every
 * k) -- the identity is width-generic (its proof never uses 64) -- plus the 64-bit edge battery
 * (INT_MIN, INT_MIN+1, -1, 0, 1, INT_MAX, +-(2^k +- 1)) and random words at k in {1,2,31,32,33,62}.
 * Shape guard + prove-the-negative (a WRONG bias 2^k BITES at x=-2,k=1) + BOOT-emitter agreement. */
var COR_SD_K      : [u64; 62]
var COR_SD_FACTOR : [u64; 62]
var COR_SD_INIT   : u64 = 0u64
const COR_SD_N : u64 = 62u64
fn cor_sd_init() -> u64 {
    if COR_SD_INIT == 1u64 { return 0u64 }
    let mut i : u64 = 0u64
    while i < COR_SD_N {
        COR_SD_K[i] = i + 1u64                          /* k = 1..62 */
        COR_SD_FACTOR[i] = 1u64 << (i + 1u64)
        i = i + 1u64
    }
    COR_SD_INIT = 1u64
    return 0u64
}
fn cor_sd_rule_count() -> u64 @export { cor_sd_init() return COR_SD_N }
fn cor_sd_shift_at(i: u64) -> u64 @export { cor_sd_init() if i >= COR_SD_N { return 0u64 } return COR_SD_K[i] }
/* SHAPE: v == 2^k exactly, k in 1..62 (high bit clear). */
fn cor_sd_shape_kf(k: u64, factor: u64) -> u8 {
    if k < 1u64 { return 0u8 }
    if k > 62u64 { return 0u8 }
    if (1u64 << k) != factor { return 0u8 }
    return 1u8
}
/* the EXACT emitted sequence, rebuilt from u64 primitives (arithmetic shift emulated explicitly --
 * .iii's own >> is logical, so nothing here silently relies on the fold under test).  The bias is
 * built BY SHIFTS ALONE, exactly as emitted: sar63 spreads the sign (0 or all-ones), the logical
 * shr by (64-k) keeps its low k bits (0 or 2^k - 1). */
fn cor_sd_bias(xi: i64, k: u64) -> i64 {
    let xu : u64 = xi as u64
    let sext : u64 = 0u64 - (xu >> 63u64)              /* sarq $63: 0 or all-ones */
    let bias : u64 = sext >> (64u64 - k)               /* shrq $(64-k): 0 or 2^k-1 */
    let sum : u64 = xu + bias                          /* addq */
    let hs : u64 = sum >> 63u64
    let res : u64 = (sum >> k) | ((0u64 - hs) << (64u64 - k))   /* sarq $k, emulated */
    return res as i64
}
var COR_SD_SEED : u64 = 88172645463325252u64
fn cor_sd_rnd() -> u64 {
    let mut x : u64 = COR_SD_SEED
    x = x ^ (x << 13u64)
    x = x ^ (x >> 7u64)
    x = x ^ (x << 17u64)
    COR_SD_SEED = x
    return x
}
/* one (x, k) check: bias sequence vs the hardware divider (variable divisor -> cqto+idivq). */
fn cor_sd_one(xi: i64, k: u64) -> u8 {
    let dv : i64 = (1u64 << k) as i64
    let want : i64 = xi / dv
    if cor_sd_bias(xi, k) != want { return 0u8 }
    return 1u8
}
/* 99 = certified; (1200+i) shape fail; 1300 width-8 sweep fail; 1301 width-16 sweep fail;
 * 1302 edge/random battery fail. */
fn cor_sd_certify_all() -> u64 @export {
    cor_sd_init()
    /* the walk goes THROUGH the exported accessors -- the certifier certifies exactly the
     * view the bind gate reads (one table, one lens), and the accessor surface is thereby
     * covered by the certifier itself (ratchet-delta-zero). */
    let n : u64 = cor_sd_rule_count()
    if n != COR_SD_N { return 1203u64 }
    let mut i : u64 = 0u64
    while i < n {
        let k : u64 = cor_sd_shift_at(i)
        if k != COR_SD_K[i] { return 1204u64 }
        if cor_sd_shape_kf(k, COR_SD_FACTOR[i]) != 1u8 { return 1200u64 + i }
        i = i + 1u64
    }
    /* COMPLETE width-8: all 256 sign-extended bytes, every k 1..7 */
    let mut xv : u64 = 0u64
    while xv < 256u64 {
        let mut xi : i64 = xv as i64
        if xv >= 128u64 { xi = xi - 256i64 }
        let mut k : u64 = 1u64
        while k <= 7u64 {
            if cor_sd_one(xi, k) != 1u8 { return 1300u64 }
            k = k + 1u64
        }
        xv = xv + 1u64
    }
    /* COMPLETE width-16: all 65536 sign-extended words, every k 1..14 */
    xv = 0u64
    while xv < 65536u64 {
        let mut xi : i64 = xv as i64
        if xv >= 32768u64 { xi = xi - 65536i64 }
        let mut k : u64 = 1u64
        while k <= 14u64 {
            if cor_sd_one(xi, k) != 1u8 { return 1301u64 }
            k = k + 1u64
        }
        xv = xv + 1u64
    }
    /* 64-bit edges + randoms at k in {1, 2, 31, 32, 33, 62} */
    let nmin : i64 = (0i64 - 9223372036854775807i64) - 1i64
    let nmax : i64 = 9223372036854775807i64
    var eks : [u64; 6]
    eks[0u64] = 1u64
    eks[1u64] = 2u64
    eks[2u64] = 31u64
    eks[3u64] = 32u64
    eks[4u64] = 33u64
    eks[5u64] = 62u64
    let mut e : u64 = 0u64
    while e < 6u64 {
        let k : u64 = eks[e]
        let dv : i64 = (1u64 << k) as i64
        if cor_sd_one(nmin, k) != 1u8 { return 1302u64 }
        if cor_sd_one(nmin + 1i64, k) != 1u8 { return 1302u64 }
        if cor_sd_one(0i64 - 1i64, k) != 1u8 { return 1302u64 }
        if cor_sd_one(0i64, k) != 1u8 { return 1302u64 }
        if cor_sd_one(1i64, k) != 1u8 { return 1302u64 }
        if cor_sd_one(nmax, k) != 1u8 { return 1302u64 }
        if cor_sd_one(dv - 1i64, k) != 1u8 { return 1302u64 }
        if cor_sd_one(dv, k) != 1u8 { return 1302u64 }
        if cor_sd_one(dv + 1i64, k) != 1u8 { return 1302u64 }
        if cor_sd_one(0i64 - (dv - 1i64), k) != 1u8 { return 1302u64 }
        if cor_sd_one(0i64 - dv, k) != 1u8 { return 1302u64 }
        if cor_sd_one(0i64 - (dv + 1i64), k) != 1u8 { return 1302u64 }
        let mut t : u64 = 0u64
        while t < 16u64 {
            if cor_sd_one(cor_sd_rnd() as i64, k) != 1u8 { return 1302u64 }
            t = t + 1u64
        }
        e = e + 1u64
    }
    return 99u64
}
/* PROVE-THE-NEGATIVE: the shape guard rejects non-pow2 / k=0 / the sign-bit divisor, and a WRONG
 * bias mask (2^k instead of 2^k-1) BITES at the concrete witness x=-2, k=1 (trunc(-2/2) = -1, but
 * the wrong bias lands 0).  1 iff every unsound case is rejected. */
fn cor_sd_rejects_unsound() -> u8 @export {
    if cor_sd_shape_kf(1u64, 3u64) != 0u8 { return 0u8 }            /* non-pow2 */
    if cor_sd_shape_kf(0u64, 1u64) != 0u8 { return 0u8 }            /* k = 0 (x/1 is identity's) */
    if cor_sd_shape_kf(63u64, 9223372036854775808u64) != 0u8 { return 0u8 }  /* 2^63: i64-negative divisor */
    if cor_sd_shape_kf(2u64, 8u64) != 0u8 { return 0u8 }            /* mismatched k/factor */
    /* wrong-bias teeth: an off-by-one bias shift (63-k, giving bias 2^(k+1)-1) at x = -2, k = 1
     * must DISAGREE with the divider: bias 3, sum 1, sar 0 != trunc(-2/2) = -1 */
    let xu : u64 = (0i64 - 2i64) as u64
    let sext : u64 = 0u64 - (xu >> 63u64)
    let wbias : u64 = sext >> 62u64                    /* WRONG: 63-k with k=1 */
    let wsum : u64 = xu + wbias
    let whs : u64 = wsum >> 63u64
    let wres : u64 = (wsum >> 1u64) | ((0u64 - whs) << 63u64)
    let want : i64 = (0i64 - 2i64) / 2i64
    if (wres as i64) == want { return 0u8 }
    return 1u8
}
/* BOOT-emitter agreement: cgopt_sdiv_admit/k/mask agree with this certified table on every rule and
 * REJECT what the certifier rejects.  1 iff agreement. */
fn cor_sd_boot_agrees() -> u8 @export {
    cor_sd_init()
    let mut i : u64 = 0u64
    while i < COR_SD_N {
        if cgopt_sdiv_admit(COR_SD_FACTOR[i]) != 1u32 { return 0u8 }
        if (cgopt_sdiv_k(COR_SD_FACTOR[i]) as u64) != COR_SD_K[i] { return 0u8 }
        if cgopt_sdiv_mask(COR_SD_FACTOR[i]) != (COR_SD_FACTOR[i] - 1u64) { return 0u8 }
        i = i + 1u64
    }
    if cgopt_sdiv_admit(0u64) != 0u32 { return 0u8 }
    if cgopt_sdiv_admit(1u64) != 0u32 { return 0u8 }                /* x/1: identity, not this fold */
    if cgopt_sdiv_admit(3u64) != 0u32 { return 0u8 }                /* non-pow2 stays idivq */
    if cgopt_sdiv_admit(6u64) != 0u32 { return 0u8 }
    if cgopt_sdiv_admit(9223372036854775808u64) != 0u32 { return 0u8 }  /* 2^63 excluded */
    return 1u8
}

fn cor_selftest() -> u64 @export {
    if cor_certify_all() != 99u64 { return cor_certify_all() }
    if cor_rejects_unsound() != 1u8 { return 5u64 }
    if cor_boot_agrees() != 1u8 { return 6u64 }
    let sl : u64 = cor_sl_certify_all()
    if sl != 99u64 { return sl }
    if cor_sl_rejects_unsound() != 1u8 { return 7u64 }
    if cor_sl_boot_agrees() != 1u8 { return 8u64 }
    let ss : u64 = cor_ss_certify_all()
    if ss != 99u64 { return ss }
    if cor_ss_rejects_unsound() != 1u8 { return 9u64 }
    if cor_ss_boot_agrees() != 1u8 { return 10u64 }
    let c2s : u64 = cor_2s_certify_all()
    if c2s != 99u64 { return c2s }
    if cor_2s_rejects_unsound() != 1u8 { return 11u64 }
    if cor_2s_boot_agrees() != 1u8 { return 12u64 }
    let c2ss : u64 = cor_2ss_certify_all()
    if c2ss != 99u64 { return c2ss }
    if cor_2ss_rejects_unsound() != 1u8 { return 13u64 }
    if cor_2ss_boot_agrees() != 1u8 { return 14u64 }
    let sd : u64 = cor_sd_certify_all()
    if sd != 99u64 { return sd }
    if cor_sd_rejects_unsound() != 1u8 { return 15u64 }
    if cor_sd_boot_agrees() != 1u8 { return 16u64 }
    return 99u64
}
