/* STDLIB/iii/forcefield/cg_surgical_strike.iii -- THE AST REWRITER of the Isomorphic Scythe.
 *
 * Safely amputates obsolete logic and rewires references to the optimal function -- but ONLY after the
 * kernel has PROVEN the two are universally equivalent (proof_bisimulation).  Every rewrite is backed by
 * a CIC proof; no rewire is performed on a merely-heuristic match.
 *
 * THE HARD-INVARIANT FIX (honored): the proposal says "traverse the entire global AST and rewrite every
 * call_context in memory".  III has NO persistent runtime global AST -- it compiles each module to a .exe;
 * the AST exists only transiently during a compile.  So the III-faithful "redirect callers" is to RECORD
 * the kernel-certified obsolescence mapping (legacy -> optimal) into an in-memory registry; the COMPILER
 * applies the recorded mapping at next build-time canonicalization (the proof-carrying optimizer already
 * does exactly this for the strength-reduction class).  No source is touched here -- in-memory only.
 *
 * Hexad: kind_seal.  Ring: R0.  K: 1.00.  NIH: composes proof_bisimulation (the kernel).
 */
module forcefield_cg_surgical_strike

extern @abi(c-msvc-x64) fn bisim_is_obsolete(a: u32, b: u32) -> u8 from "proof_bisimulation.iii"

const CSS_CAP : u32 = 64u32

var CSS_LEGACY  : [u32; 64]   /* the obsolete legacy function (exponent a) */
var CSS_OPTIMAL : [u32; 64]   /* the optimal replacement (exponent b == a for every certified mapping) */
var CSS_N       : [u32; 1]

fn css_reset() -> u64 @export { CSS_N[0u64] = 0u32  return 0u64 }
fn css_count() -> u32 @export { return CSS_N[0u64] }

/* cg_verify_graph_integrity: the rewrite legacy(a) -> optimal(b) is provably SAFE iff the pair is
 * kernel-proven OBSOLETE (universally equivalent + strictly cheaper).  A self-mapping (a==b on the
 * SAME function id) would be a no-op, but here legacy and optimal are DISTINCT implementations of the
 * same value (multiply vs shift), so equivalence is exactly the safety condition.  Returns 1 iff safe. */
fn cg_verify_graph_integrity(a: u32, b: u32) -> u8 @export {
    if bisim_is_obsolete(a, b) != 1u8 { return 0u8 }   /* not PROVEN obsolete -> unsafe to rewire */
    return 1u8
}

/* cg_redirect_record: record the kernel-certified obsolescence mapping legacy(a) -> optimal(b) into the
 * in-memory rewrite registry, IFF graph integrity holds.  Returns 1 if recorded, 0 if rejected (zero
 * state change on reject).  The compiler applies the recorded mapping at next build -- NO runtime
 * live-AST mutation, NO source edit. */
fn cg_redirect_record(a: u32, b: u32) -> u8 @export {
    if cg_verify_graph_integrity(a, b) != 1u8 { return 0u8 }   /* unproven -> reject, zero state */
    let n : u32 = CSS_N[0u64]
    if n >= CSS_CAP { return 1u8 }                             /* proven safe but registry full */
    CSS_LEGACY[n as u64] = a
    CSS_OPTIMAL[n as u64] = b
    CSS_N[0u64] = n + 1u32
    return 1u8
}

/* 1 iff every recorded rewrite is a kernel-certified equivalence (a == b) -- no unproven rewire slipped in. */
fn css_all_proven() -> u8 @export {
    let n : u32 = CSS_N[0u64]
    let mut i : u32 = 0u32
    while i < n {
        if CSS_LEGACY[i as u64] != CSS_OPTIMAL[i as u64] { return 0u8 }
        i = i + 1u32
    }
    return 1u8
}

/* SELFTEST: 99 = (1) a proven-obsolete pair (3,3) is recorded; (2) an unproven pair (3,4) is REJECTED
 * with zero state change; (3) every recorded rewrite is kernel-certified. */
fn css_selftest() -> u64 @export {
    css_reset()
    if cg_redirect_record(3u32, 3u32) != 1u8 { return 1u64 }   /* obsolete -> recorded */
    if css_count() != 1u32 { return 2u64 }
    if cg_redirect_record(3u32, 4u32) != 0u8 { return 3u64 }   /* not obsolete (a!=b) -> rejected */
    if css_count() != 1u32 { return 4u64 }                     /* zero state change on reject */
    if css_all_proven() != 1u8 { return 5u64 }                 /* only certified rewrites recorded */
    return 99u64
}
