/* STDLIB/iii/forcefield/daemon_dream.iii -- THE ENGINE of the Autocatalytic Synthesis Loop.
 *
 * Orchestrates the full propose -> synthesize -> dispose -> seal pipeline without disturbing the
 * system's primary deterministic obligations.  Each cycle: the mutagen HALLUCINATES a candidate
 * identity (egraph_stochastic), the synthesizer attempts a proof, and the kernel sieve DISPOSES
 * (cg_autocatalyst).  Kernel-certified discoveries accumulate in the volatile registry.
 *
 * THE HARD-INVARIANT FIX (honored): the proposal's "asynchronous background daemon that triggers
 * build_iiis2 so the Golden Fixpoint autonomously shifts" is REFUTED -- two reasons, both fatal:
 *   (1) III has NO exposed scheduler/threading and a compiled .iii -> .exe CANNOT invoke the build
 *       system to reseal itself; an "infinite background loop triggering build_iiis2" is not expressible.
 *   (2) An AUTONOMOUS golden shift violates M20 / ADR-FORGE-4 (the substrate may not assert its own
 *       soundness / re-root its own trust) AND the determinism contract (a self-mutating golden is not a
 *       fixed point -- it breaks federation R1 identity + reproducibility) AND the seal-critical CRASH-
 *       PROTOCOL (a compiler reseal demands a surfaced operator checkpoint).
 * So this is a BOUNDED, SYNCHRONOUS driver: it DISCOVERS + kernel-CERTIFIES + SEALS optimizations and
 * SURFACES the certified-rewrite set (the return value + the registry).  Promoting a discovery into the
 * compiler source + reseal is the OPERATOR-GATED step under CRASH PROTOCOL -- the human pulls the trigger.
 * "Background / idle" is the operator's invocation cadence, not a runtime thread.
 *
 * Hexad: kind_decision.  Ring: R0.  K: 1.00.  NIH: composes egraph_stochastic + cg_autocatalyst.
 */
module daemon_dream

extern @abi(c-msvc-x64) fn egs_hallucinate(state: u64, out_a: *u32, out_b: *u32) -> u64 from "egraph_stochastic.iii"
extern @abi(c-msvc-x64) fn cga_dispose(a: u32, b: u32, budget: u32) -> u8 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_reset() -> u64 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_count() -> u32 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_all_true() -> u8 from "cg_autocatalyst.iii"

var DD_A : [u32; 1]
var DD_B : [u32; 1]

/* THE DREAM: run n_cycles seeded dream cycles; return the count of kernel-CERTIFIED discoveries (the
 * surfaced certified-rewrite set lives in the cg_autocatalyst registry).  Deterministic in the seed. */
fn daemon_dream_run(seed: u64, n_cycles: u32, budget: u32) -> u32 @export {
    cga_reset()
    let mut s : u64 = seed
    let mut i : u32 = 0u32
    while i < n_cycles {
        s = egs_hallucinate(s, (&DD_A as u64) as *u32, (&DD_B as u64) as *u32)
        cga_dispose(DD_A[0u64], DD_B[0u64], budget)
        i = i + 1u32
    }
    return cga_count()
}

/* Independent oracle: replay the same seed and count how many cycles propose a TRUE identity (a==b),
 * WITHOUT the kernel -- so the KAT can assert the kernel sealed EXACTLY the true ones (no more, no less). */
fn dd_count_true(seed: u64, n_cycles: u32) -> u32 {
    let mut s : u64 = seed
    let mut i : u32 = 0u32
    let mut c : u32 = 0u32
    while i < n_cycles {
        s = egs_hallucinate(s, (&DD_A as u64) as *u32, (&DD_B as u64) as *u32)
        if DD_A[0u64] == DD_B[0u64] { c = c + 1u32 }
        i = i + 1u32
    }
    return c
}

/* THE HEADLINE KAT -- the whole loop, end to end, kernel-governed.  99 =
 *  (1) the dream's certified count == the independent true-candidate count (the kernel sealed EXACTLY
 *      the mathematically-true identities -- no false hallucination admitted, no true one missed);
 *  (2) NON-VACUOUS: the dream discovered >= 1 real optimization;
 *  (3) every sealed entry is a true identity (cga_all_true -- the leash holds even though the mutagen lies);
 *  (4) DETERMINISM (M2): the same seed yields the same discovery count -- the dream is replayable;
 *  (5) budget=0: the synthesizer times out every cycle -> ZERO discoveries (the sieve seals nothing). */
fn daemon_dream_kat() -> u64 @export {
    let seed : u64 = 0x0C0FFEE123456789u64
    let n : u32 = 16u32
    let certified : u32 = daemon_dream_run(seed, n, 64u32)
    let expected : u32 = dd_count_true(seed, n)
    if certified != expected { return 1u64 }       /* kernel sealed EXACTLY the true identities */
    if certified < 1u32 { return 2u64 }            /* non-vacuous: at least one real discovery */
    if cga_all_true() != 1u8 { return 3u64 }       /* no false hallucination sealed */
    let again : u32 = daemon_dream_run(seed, n, 64u32)
    if again != certified { return 4u64 }          /* determinism: replayable dream */
    if daemon_dream_run(seed, n, 0u32) != 0u32 { return 5u64 }   /* budget 0 -> zero discoveries */
    return 99u64
}

/* ===== harmony wave-4 M5: THE FULL DREAM -- one driver across the whole authority lattice =======
 * The original dream covers the Peano tier alone.  The wave built three more authorities; the
 * full dream exercises ALL of them in one bounded, synchronous, operator-invoked pass:
 *   - hallucinated (a,b) candidates dispose through BOTH the ideal-integer tier (cga_dispose)
 *     and the width-faithful count-mask tier (cga_dispose_bv) -- the same dream, two truths;
 *   - the mixed catalog (0xB6, UNSAT) and the shift-combining grid (0xB7, UNSAT with the
 *     count-mask wall) discover deterministically;
 * and THE LEASH closes over every registry: each tier's verify-all re-proves every sealed entry
 * through its own disposer.  Same contract as ever: bounded, deterministic in the seed,
 * observation-free; promotion into the compiler stays OPERATOR-GATED (M20/ADR-FORGE-4). */
extern @abi(c-msvc-x64) fn cga_dispose_bv(a: u32, b: u32, budget: u32) -> u8 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_bv_reset() -> u64 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_bv_count() -> u32 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_bv_all_true() -> u8 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_mixed_discover(budget: u32) -> u32 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_mixed_count() -> u32 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_mixed_verify_all() -> u8 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_shift_discover(g: u32, budget: u32) -> u32 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_shift_count() -> u32 from "cg_autocatalyst.iii"
extern @abi(c-msvc-x64) fn cga_shift_verify_all() -> u8 from "cg_autocatalyst.iii"

/* run the full dream; returns the TOTAL certified across all four tiers */
fn daemon_dream_run_full(seed: u64, n_cycles: u32, budget: u32) -> u32 @export {
    if budget == 0u32 { return 0u32 }
    cga_reset()
    cga_bv_reset()
    let mut s : u64 = seed
    let mut i : u32 = 0u32
    while i < n_cycles {
        s = egs_hallucinate(s, (&DD_A as u64) as *u32, (&DD_B as u64) as *u32)
        cga_dispose(DD_A[0u64], DD_B[0u64], budget)
        cga_dispose_bv(DD_A[0u64], DD_B[0u64], budget)
        i = i + 1u32
    }
    let mut total : u32 = cga_count() + cga_bv_count()
    total = total + cga_mixed_discover(budget)
    total = total + cga_shift_discover(6u32, budget)
    return total
}

/* THE LEASH over the whole lattice: every sealed law in every tier re-proves, or 0 */
fn daemon_dream_leash_all() -> u8 @export {
    if cga_all_true() != 1u8 { return 0u8 }
    if cga_bv_all_true() != 1u8 { return 0u8 }
    if cga_mixed_verify_all() != 1u8 { return 0u8 }
    if cga_shift_verify_all() != 1u8 { return 0u8 }
    return 1u8
}

/* ===== wave-4 M15: THE WITNESSED DREAM -- the discovery session as a provenance-bound fact =====
 * daemon_dream's contract SURFACES the certified set; the witnessed variant makes each session
 * a content-addressed fact on the spine: producer cad('dream'), op cad('dream.certified'),
 * payload = (seed, total, and the four per-tier counts -- Peano, count-mask, mixed, shift) as
 * LE u64s, out_commit = cad(payload).  The leash is taken FIRST: an unleashed registry (any
 * sealed law failing re-proof) witnesses NOTHING and returns 0xFFFFFFFF -- provenance is only
 * for verified state.  An unpublishable fragment returns 0xFFFFFFFE with the dream's results
 * STANDING (the item-6 honest-unwitnessed convention).  Otherwise returns the certified total. */
extern @abi(c-msvc-x64) fn wh_init(initial_time: u64) -> i32 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn wh_publish(producer: *u8, opid: *u8, in_commit: *u8, out_commit: *u8, revtag: u8, phase: u8, pillar: u16, antecedents: *u8, n_ante: u32, payload: *u8, payload_len: u32, out_frag_id: *u8) -> u64 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(domain: u32, msg: *u8, len: u64, out32: *u8) -> i32 from "cad.iii"

var DW_PROD_TXT : [u8; 5]  = [100u8,114u8,101u8,97u8,109u8]                                          /* "dream" */
var DW_OP_TXT   : [u8; 15] = [100u8,114u8,101u8,97u8,109u8,46u8,99u8,101u8,114u8,116u8,105u8,102u8,105u8,101u8,100u8] /* "dream.certified" */
var DW_PROD : [u8; 32]
var DW_OP   : [u8; 32]
var DW_IN   : [u8; 32]
var DW_OUT  : [u8; 32]
var DW_PAY  : [u8; 48]
var DW_FID  : [u8; 32]
var DW_INITED : u8 = 0u8     /* the spine inits ONCE -- re-init would reset the index and orphan prior facts */

fn _dw_pay_u64(off: u64, v: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < 8u64 {
        DW_PAY[off + i] = ((v >> (i * 8u64)) & 0xFFu64) as u8
        i = i + 1u64
    }
    return 0u64
}

fn daemon_dream_run_full_witnessed(seed: u64, n_cycles: u32, budget: u32) -> u32 @export {
    let total : u32 = daemon_dream_run_full(seed, n_cycles, budget)
    /* THE LEASH FIRST: provenance only for verified state */
    if daemon_dream_leash_all() != 1u8 { return 0xFFFFFFFFu32 }
    if DW_INITED == 0u8 {
        wh_init(1u64)
        DW_INITED = 1u8
    }
    cad_oneshot(1u32, (&DW_PROD_TXT as u64) as *u8, 5u64, (&DW_PROD as u64) as *u8)
    cad_oneshot(1u32, (&DW_OP_TXT as u64) as *u8, 15u64, (&DW_OP as u64) as *u8)
    _dw_pay_u64(0u64, seed)
    _dw_pay_u64(8u64, total as u64)
    _dw_pay_u64(16u64, cga_count() as u64)
    _dw_pay_u64(24u64, cga_bv_count() as u64)
    _dw_pay_u64(32u64, cga_mixed_count() as u64)
    _dw_pay_u64(40u64, cga_shift_count() as u64)
    cad_oneshot(1u32, (&DW_OP as u64) as *u8, 32u64, (&DW_IN as u64) as *u8)
    cad_oneshot(1u32, (&DW_PAY as u64) as *u8, 48u64, (&DW_OUT as u64) as *u8)
    let widx : u64 = wh_publish((&DW_PROD as u64) as *u8, (&DW_OP as u64) as *u8,
               (&DW_IN as u64) as *u8, (&DW_OUT as u64) as *u8,
               0u8, 0u8, 0u16,
               (&DW_PROD as u64) as *u8, 0u32,
               (&DW_PAY as u64) as *u8, 48u32,
               (&DW_FID as u64) as *u8)
    if widx == 0xFFFFFFFFFFFFFFFFu64 { return 0xFFFFFFFEu32 }   /* proven but unwitnessed: honest */
    return total
}
