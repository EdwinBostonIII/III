/* C:\Users\Edwin Boston\OneDrive\Desktop\III\FORCEFIELD\optinvoke.iii
 *
 * The optimal-invocation selector (STANDALONE artifact) — the decision core of
 * "the one superior system picks the optimal realization every time."
 *
 * The full engine is: candidate-generation (egraph equality saturation) + cost
 * assignment (cost_lattice) + SELECTION. This module is the SELECTION — the
 * actual decision, and the part with the load-bearing guarantees:
 *
 *   - min-cost over the proven-equivalent class (the candidate set),
 *   - VALIDITY as the pruning side-condition (an invalid candidate is never
 *     chosen, however cheap),
 *   - DETERMINISTIC tie-break: equal cost is broken by the candidate's
 *     content-address (lexicographic min) → argmin is single-valued → the
 *     choice is reproducible, no profiling, no learning,
 *   - the IMPLEMENTATION-vs-SUITE distinction: candidates that produce the SAME
 *     output address are freely interchangeable (implementation-selection, a
 *     pure win); candidates that produce DIFFERENT outputs (suite-selection) are
 *     a semantically significant choice that must be address-tagged/agreed.
 *
 * The egraph (which produces the candidates) and the cost_lattice (which costs
 * them) feed this; wiring them is the next brick. This is the decision, in full.
 *
 * Candidate record stride = 80 bytes:
 *   [0..31] cand_id (content-address of the realization)
 *   [32..63] out_addr (content-address of the OUTPUT it produces)
 *   [64..71] cost (u64 LE)   [72] valid (u8)
 *
 * NIH: III's own mhash for the decision seal. No floats, no statistics.
 */

module forcefield_optinvoke

extern @abi(c-msvc-x64) fn mhash_begin() -> i32 from "mhash.iii"
extern @abi(c-msvc-x64) fn mhash_payload(p: u64, plen: u64) -> i32 from "mhash.iii"
extern @abi(c-msvc-x64) fn mhash_domain(d: u64, dl: u64) -> i32 from "mhash.iii"
extern @abi(c-msvc-x64) fn mhash_final(out: u64) -> i32 from "mhash.iii"
/* BATCH 2 (Evolution): the cost_lattice is the SINGLE cost authority -- the selector consumes the
 * rich 6-dim microarch model (latency,throughput,regpressure,icache,dcache,energy) scalarized
 * through one registered order, never pre-scalarized magic numbers. */
extern @abi(c-msvc-x64) fn cl_dot(weights: *u64, c: *u64) -> u64 from "cost_lattice.iii"

const OI_NONE  : u64 = 0xFFFFFFFFFFFFFFFFu64
const OI_IMPL  : u64 = 0u64
const OI_SUITE : u64 = 1u64

fn oi_ld_u64(p: *u8, off: u64) -> u64 {
    let b0 : u64 = p[off] as u64
    let b1 : u64 = p[off + 1u64] as u64
    let b2 : u64 = p[off + 2u64] as u64
    let b3 : u64 = p[off + 3u64] as u64
    let b4 : u64 = p[off + 4u64] as u64
    let b5 : u64 = p[off + 5u64] as u64
    let b6 : u64 = p[off + 6u64] as u64
    let b7 : u64 = p[off + 7u64] as u64
    return b0 | (b1 << 8u64) | (b2 << 16u64) | (b3 << 24u64) | (b4 << 32u64) | (b5 << 40u64) | (b6 << 48u64) | (b7 << 56u64)
}

fn oi_eq32(a: *u8, ao: u64, b: *u8, bo: u64) -> u8 {
    let mut k : u64 = 0u64
    let mut eq : u8 = 1u8
    while k < 32u64 {
        if a[ao + k] != b[bo + k] { eq = 0u8 }
        k = k + 1u64
    }
    return eq
}

/* 1 iff a[ao..ao+32] < b[bo..bo+32] lexicographically (byte 0 most significant) */
fn oi_addr_lt(a: *u8, ao: u64, b: *u8, bo: u64) -> u8 {
    let mut k : u64 = 0u64
    while k < 32u64 {
        let av : u8 = a[ao + k]
        let bv : u8 = b[bo + k]
        if av != bv {
            if av < bv { return 1u8 }
            return 0u8
        }
        k = k + 1u64
    }
    return 0u8
}

fn oi_copy(dst: *u8, doff: u64, src: *u8, soff: u64, n: u64) -> u64 {
    let mut k : u64 = 0u64
    while k < n {
        dst[doff + k] = src[soff + k]
        k = k + 1u64
    }
    return 0u64
}

fn oi_hash(src: *u8, soff: u64, len: u64, out: *u8, oo: u64) -> u64 {
    mhash_begin()
    mhash_payload((src as u64) + soff, len)
    mhash_final((out as u64) + oo)
    return 0u64
}

/* the decision: index of the min-cost VALID candidate (ties broken by smaller
 * cand_id), with its cand_id written to out_choice; OI_NONE if none valid. */
fn oi_select(cands: *u8, n: u64, out_choice: *u8) -> u64 @export {
    let mut best : u64 = OI_NONE
    let mut bcost : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n {
        if cands[i * 80u64 + 72u64] == 1u8 {
            let ci : u64 = oi_ld_u64(cands, i * 80u64 + 64u64)
            let mut take : u8 = 0u8
            if best == OI_NONE {
                take = 1u8
            } else {
                if ci < bcost {
                    take = 1u8
                } else {
                    if ci == bcost {
                        if oi_addr_lt(cands, i * 80u64, cands, best * 80u64) == 1u8 { take = 1u8 }
                    }
                }
            }
            if take == 1u8 {
                best = i
                bcost = ci
            }
        }
        i = i + 1u64
    }
    if best == OI_NONE { return OI_NONE }
    oi_copy(out_choice, 0u64, cands, best * 80u64, 32u64)
    return best
}

/* IMPL (0): all valid candidates produce the same output -> free interchange.
 * SUITE (1): valid candidates produce different outputs -> significant choice.
 * OI_NONE: no valid candidate. */
fn oi_selection_kind(cands: *u8, n: u64) -> u64 @export {
    let mut firstv : u64 = OI_NONE
    let mut i : u64 = 0u64
    while i < n {
        if cands[i * 80u64 + 72u64] == 1u8 {
            if firstv == OI_NONE { firstv = i }
        }
        i = i + 1u64
    }
    if firstv == OI_NONE { return OI_NONE }
    let mut differ : u64 = 0u64
    let mut j : u64 = 0u64
    while j < n {
        if cands[j * 80u64 + 72u64] == 1u8 {
            if oi_eq32(cands, j * 80u64 + 32u64, cands, firstv * 80u64 + 32u64) == 0u8 { differ = 1u64 }
        }
        j = j + 1u64
    }
    if differ == 1u64 { return OI_SUITE }
    return OI_IMPL
}

/* the decision seal: a content-address of the whole candidate table, so the
 * choice is reproducible and witnessable. */
var OI_DOM : [u8; 14]      /* A-OI-2: "optinvoke.seal" domain tag */
var OI_DOM_INIT : u8 = 0u8
fn oi_dom_init() -> i32 {
    if OI_DOM_INIT == 1u8 { return 0i32 }
    OI_DOM[0u64] = 111u8   OI_DOM[1u64] = 112u8   OI_DOM[2u64] = 116u8
    OI_DOM[3u64] = 105u8   OI_DOM[4u64] = 110u8   OI_DOM[5u64] = 118u8
    OI_DOM[6u64] = 111u8   OI_DOM[7u64] = 107u8   OI_DOM[8u64] = 101u8
    OI_DOM[9u64] = 46u8    OI_DOM[10u64] = 115u8  OI_DOM[11u64] = 101u8
    OI_DOM[12u64] = 97u8   OI_DOM[13u64] = 108u8
    OI_DOM_INIT = 1u8
    return 0i32
}

/* A-OI-2: domain-separate the optinvoke seal so it cannot alias a bare mhash of the same
 * bytes in another context (cross-context second-preimage); prefix a fixed domain tag. */
fn oi_seal(cands: *u8, n: u64, out: *u8) -> u64 @export {
    oi_dom_init()
    mhash_begin()
    mhash_domain((&OI_DOM as u64), 14u64)
    /* DETERMINISM (A-OI-2): stream only the 73 MEANINGFUL bytes of each 80-byte record
     * (output [32..63], field [64..71], validity [72]); the 7 padding bytes [73..79] are not
     * content, and hashing leftover/uninitialized padding made the seal non-reproducible. */
    let mut i : u64 = 0u64
    while i < n {
        mhash_payload((cands as u64) + i * 80u64, 73u64)
        i = i + 1u64
    }
    mhash_final((out as u64))
    return 0u64
}

/* store u64 v little-endian into p[off..off+7] -- the candidate cost-field writer for oi_cost_candidates. */
fn oi_st_u64(p: *u8, off: u64, v: u64) -> u64 {
    let mut i : u64 = 0u64
    let mut x : u64 = v
    while i < 8u64 {
        p[off + i] = (x & 0xFFu64) as u8
        x = x >> 8u64
        i = i + 1u64
    }
    return 0u64
}

/* ===== BATCH 2 (Evolution): generate->cost->SELECT with the cost_lattice as the single cost authority.
 * Until now optinvoke's candidate `cost` field was a pre-scalarized magic number (hand-set in the
 * 840 KAT). The rich cost model lives in cost_lattice (6-dim microarch vectors, scalarized by a
 * registered order). oi_cost_candidates wires it in: it scalarizes each candidate's 6-u64 vector
 * through cl_dot(weights, vec) and writes the result into the candidate's cost field, so the selector
 * runs on the ONE cost model -- never magic numbers, never a second costing path that could disagree
 * with the lattice. Determinism: cl_dot is a saturating INTEGER dot (no FP); identical inputs ->
 * identical scalar. `vecs` is a packed array of n 6-u64 cost vectors (48 bytes each), parallel to
 * cands; `weights` is one 6-u64 order vector. ===== */
fn oi_cost_candidates(cands: *u8, n: u64, vecs: *u8, weights: *u8) -> u64 @export {
    let wptr : *u64 = (weights as u64) as *u64
    let mut i : u64 = 0u64
    while i < n {
        let vptr : *u64 = ((vecs as u64) + i * 48u64) as *u64
        let scalar : u64 = cl_dot(wptr, vptr)
        oi_st_u64(cands, i * 80u64 + 64u64, scalar)
        i = i + 1u64
    }
    return 0u64
}

/* The composed decision: cost every candidate through the cost_lattice, then select the min-cost
 * VALID realization (oi_select -- validity prunes FIRST so an invalid candidate is never chosen
 * however cheap; equal cost is broken by the candidate's content-address -> argmin single-valued ->
 * reproducible, no profiling, no learning). Returns the chosen index (OI_NONE if none valid) and
 * writes the chosen cand_id to out_choice. "III picks the optimal realization every time", now with
 * the real microarch cost model wired end-to-end -- not a KAT-level hand-composition. */
fn oi_select_costed(cands: *u8, n: u64, vecs: *u8, weights: *u8, out_choice: *u8) -> u64 @export {
    oi_cost_candidates(cands, n, vecs, weights)
    return oi_select(cands, n, out_choice)
}

/* ===== BATCH 2 (Evolution): source egraph's TERM-extraction cost from the SAME cost_lattice -- one
 * cost authority across the WHOLE generate->cost->select pipeline. egraph's eg_extract reads a flat
 * u32 cost at req[slot+2] (the per-operation cost it sums up the term); this writes it as
 * cl_dot(weights, vec6) of that operation's 6-dim microarch vector, CAPPED below EGRAPH_INF_COST
 * (0xFFFFFFFF) so a node is never spuriously marked unreachable and a sum of a few costs stays finite.
 * Now egraph picks the optimal TERM and optinvoke the optimal REALIZATION through ONE model: the
 * lattice GENUINELY drives the term choice (swap the microarch vectors and the other term wins -- KAT
 * 956), it is not a hardcoded preference. Determinism: cl_dot is a saturating integer dot. ===== */
const OI_EG_COST_CAP : u64 = 0x3FFFFFFFu64   /* << EGRAPH_INF_COST; sums of several stay below INF */
fn oi_egraph_cost(req: *u32, slot: u32, vec6: *u8, weights: *u8) -> u64 @export {
    let wptr : *u64 = (weights as u64) as *u64
    let vptr : *u64 = (vec6 as u64) as *u64
    let mut scalar : u64 = cl_dot(wptr, vptr)
    if scalar > OI_EG_COST_CAP { scalar = OI_EG_COST_CAP }
    req[(slot as u64) + 2u64] = scalar as u32
    return scalar
}
