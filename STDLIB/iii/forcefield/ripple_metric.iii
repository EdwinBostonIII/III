/* STDLIB/iii/forcefield/ripple_metric.iii -- the Sovereign Ripple Calculus,
 * INCREMENT 1: the objective made computable.  MEASURE-ONLY (no self-editing).
 *
 * Models III's functional connections as a graph: nodes = modules (each with a
 * capability-hash and an intent-class), edges = ripples (each load-bearing or dead,
 * each plain or witnessed).  Computes the four targets of the design, PROVABLY at the
 * graph level (the decidable fragment -- this is a sound graph-level PROXY for the MDL
 * objective "minimal structure preserving the whole proven capability set", NOT a
 * capability-level semantic analysis, which is undecidable; see
 * DOCS/III-RIPPLE-OPTIMIZER-ARCHITECTURE.md):
 *
 *   NOISE          = edges carrying no capability (unused) and not witnessed-keep.
 *                    Provably removable -> minimize.
 *   GOOD COMPLEXITY= load-bearing edges (the symbol is actually used); removing one
 *                    LOSES a capability -> it is irreducible -> preserve/grow.
 *   SEPARATION     = capability-equal node pairs kept in DISTINCT modules (duplication);
 *                    unification would collapse them -> minimize.
 *   UNIFICATION    = the dual: collapsing capability-equal duplicates (raises J).
 *
 * Two lessons from III's own tree are encoded as HARD predicates (the decider relies on
 * them; the KAT proves the negative): (1) a load-bearing edge is NEVER noise and cutting
 * it is NEVER capability-preserving -- good complexity is protected; (2) capability-equal
 * but intent-class-DIFFERENT nodes (e.g. cpufeat userspace vs Ring-0) are NOT unifiable --
 * an intended variation point is never merged.  Intent is not kernel-provable, so it is
 * carried as a witnessed marker and the metric ABSTAINS from merging across it.
 *
 * Pure, deterministic, no allocator (module-global BSS arrays; integer ==/!= and counts).
 * Compiler-UNREFERENCED -> LIBNATIVE.  Hexad: kind_sensitivity (self-measurement).
 * Ring: R0.  K: 1.00.  NIH: omnia/caindex.iii (COMBINE-3 shared content-address
 * index -- used only by rm_sep's O(N) grouping; murmur3 transitively). */
module forcefield_ripple_metric

/* W3.1 / COMBINE-3: rm_sep groups capability-equal nodes through the shared
 * caindex (omnia/caindex.iii) -- the X3 "deterministic superposition collapse" --
 * turning the old O(N^2) all-pairs scan into ~O(N).  The count is identical:
 * a group of m capability/intent-equal nodes contributes C(m,2) pairs, summed
 * incrementally (the k-th member of a group adds k-1 pairs). */
extern @abi(c-msvc-x64) fn cai_clear(vals: u64, slots: u64) -> i32 from "caindex.iii"
extern @abi(c-msvc-x64) fn cai_get(keys: u64, vals: u64, mask: u64, id: *u8) -> u32 from "caindex.iii"
extern @abi(c-msvc-x64) fn cai_put(keys: u64, vals: u64, mask: u64, id: *u8, payload: u32) -> i32 from "caindex.iii"

const RM_MAXN : u32 = 4096u32     /* module-graph headroom (III ~420 modules) */
const RM_MAXE : u32 = 16384u32    /* edge headroom (III ~835 ripples) */
const RM_BAD  : u32 = 0xFFFFFFFFu32

var RM_N : [u32; 1]               /* node count */
var RM_E : [u32; 1]               /* edge count */
var RM_CAP : [u64; 4096]          /* per-node capability content-address */
var RM_ICLASS : [u32; 4096]       /* per-node intent-class (variation-point id) */
var RM_ESRC : [u32; 16384]
var RM_EDST : [u32; 16384]
var RM_EUSED : [u32; 16384]       /* 1 = load-bearing (symbol referenced); 0 = dead */
var RM_EINTENT : [u32; 16384]     /* 1 = witnessed-keep even if unused; 0 = plain */

/* rm_sep grouping index (W3.1): maps a node's 32-byte (cap||iclass) key to the
 * running size of its capability/intent group.  Sized to RM_MAXN so an all-
 * distinct graph never overflows; VALS cleared to CAI_EMPTY at each rm_sep call. */
const RM_SEP_SLOTS : u64 = 4096u64
const RM_SEP_MASK  : u64 = 4095u64
var RM_SEP_KEYS : [u8;  131072]   /* RM_MAXN(4096) * 32 */
var RM_SEP_VALS : [u32; 4096]
var RM_SEP_KEY  : [u8;  32]       /* per-node 32-byte key scratch (cap||iclass||0) */

/* ---- graph construction ---- */
fn rm_reset() -> u64 @export {
    RM_N[0u32] = 0u32
    RM_E[0u32] = 0u32
    return 0u64
}

fn rm_add_node(cap: u64, iclass: u32) -> u32 @export {
    let i : u32 = RM_N[0u32]
    if i >= RM_MAXN { return RM_BAD }
    RM_CAP[i] = cap
    RM_ICLASS[i] = iclass
    RM_N[0u32] = i + 1u32
    return i
}

fn rm_add_edge(src: u32, dst: u32, used: u32, intent: u32) -> u32 @export {
    let e : u32 = RM_E[0u32]
    if e >= RM_MAXE { return RM_BAD }
    RM_ESRC[e] = src
    RM_EDST[e] = dst
    RM_EUSED[e] = used
    RM_EINTENT[e] = intent
    RM_E[0u32] = e + 1u32
    return e
}

/* ---- per-edge predicates ---- */
/* NOISE: unused (carries no capability) AND not witnessed-keep. */
fn rm_is_noise(e: u32) -> u32 @export {
    if e >= RM_E[0u32] { return 0u32 }
    if RM_EUSED[e] == 0u32 { if RM_EINTENT[e] == 0u32 { return 1u32 } }
    return 0u32
}
/* CUT VALID (capability-preserving): only an unused edge may be cut.  Cutting a
 * load-bearing edge LOSES a capability -> invalid (the hard constraint the decider checks). */
fn rm_cut_valid(e: u32) -> u32 @export {
    if e >= RM_E[0u32] { return 0u32 }
    if RM_EUSED[e] == 0u32 { return 1u32 }
    return 0u32
}
/* CUT IMPROVES J: valid AND removes genuine noise (not a witnessed edge). */
fn rm_cut_improves(e: u32) -> u32 @export {
    return rm_is_noise(e)
}

/* ---- per-pair predicates (unification) ---- */
/* UNIFIABLE: distinct nodes, capability-equal, AND same intent-class.  Capability-equal
 * but intent-class-different = intended parallel (cpufeat userspace vs Ring-0) -> NOT
 * unifiable: an intended variation point is preserved. */
fn rm_unifiable(i: u32, j: u32) -> u32 @export {
    if i == j { return 0u32 }
    if i >= RM_N[0u32] { return 0u32 }
    if j >= RM_N[0u32] { return 0u32 }
    if RM_CAP[i] == RM_CAP[j] { if RM_ICLASS[i] == RM_ICLASS[j] { return 1u32 } }
    return 0u32
}
fn rm_merge_valid(i: u32, j: u32) -> u32 @export {
    return rm_unifiable(i, j)
}
/* merging capability-equal duplicates reduces separation + description length -> J up. */
fn rm_merge_improves(i: u32, j: u32) -> u32 @export {
    return rm_unifiable(i, j)
}

/* ---- group key (single source for rm_sep + ripple_loop's rl_run) ---- */
/* Write node i's 32-byte group key = cap(8 LE) || iclass(4 LE) || zero(20) into
 * bufp.  Two nodes share this key IFF capability-equal AND intent-equal -- i.e.
 * exactly when rm_unifiable(i,j)==1.  caindex hashes/compares all 32 bytes, so
 * the 20 trailing zeros are inert padding (deterministic). */
fn rm_write_key(i: u32, bufp: *u8) -> i32 {
    let cap : u64 = RM_CAP[i]
    let icl64 : u64 = RM_ICLASS[i] as u64
    let mut z : u64 = 0u64
    while z < 32u64 { bufp[z] = 0u8  z = z + 1u64 }
    bufp[0u64] = (cap & 0xFFu64) as u8
    bufp[1u64] = ((cap >> 8u64)  & 0xFFu64) as u8
    bufp[2u64] = ((cap >> 16u64) & 0xFFu64) as u8
    bufp[3u64] = ((cap >> 24u64) & 0xFFu64) as u8
    bufp[4u64] = ((cap >> 32u64) & 0xFFu64) as u8
    bufp[5u64] = ((cap >> 40u64) & 0xFFu64) as u8
    bufp[6u64] = ((cap >> 48u64) & 0xFFu64) as u8
    bufp[7u64] = ((cap >> 56u64) & 0xFFu64) as u8
    bufp[8u64]  = (icl64 & 0xFFu64) as u8
    bufp[9u64]  = ((icl64 >> 8u64)  & 0xFFu64) as u8
    bufp[10u64] = ((icl64 >> 16u64) & 0xFFu64) as u8
    bufp[11u64] = ((icl64 >> 24u64) & 0xFFu64) as u8
    return 0i32
}

/* Exported accessor: write node i's 32-byte group key into out (rl_run buckets on
 * it).  Out-of-range i -> zeroed key + -1 (memory-safe; RM_CAP is [u64; RM_MAXN]). */
fn rm_node_key(i: u32, out: *u8) -> i32 @export {
    if i >= RM_MAXN {
        let mut z : u64 = 0u64
        while z < 32u64 { out[z] = 0u8  z = z + 1u64 }
        return -1i32
    }
    return rm_write_key(i, out)
}

/* ---- aggregate metrics ---- */
fn rm_noise() -> u32 @export {
    let mut c : u32 = 0u32
    let mut e : u32 = 0u32
    let n : u32 = RM_E[0u32]
    while e < n {
        if rm_is_noise(e) == 1u32 { c = c + 1u32 }
        e = e + 1u32
    }
    return c
}
fn rm_good() -> u32 @export {
    let mut c : u32 = 0u32
    let mut e : u32 = 0u32
    let n : u32 = RM_E[0u32]
    while e < n {
        if RM_EUSED[e] == 1u32 { c = c + 1u32 }
        e = e + 1u32
    }
    return c
}
/* SEPARATION: count of unifiable node pairs (capability-equal, intent-equal) currently
 * in distinct nodes -- the duplication unification would collapse. */
fn rm_sep() -> u32 @export {
    let n : u32 = RM_N[0u32]
    let kp : u64 = &RM_SEP_KEYS as u64
    let vp : u64 = &RM_SEP_VALS as u64
    let bufp : *u8 = (&RM_SEP_KEY as u64) as *u8
    cai_clear(vp, RM_SEP_SLOTS)
    let mut c : u32 = 0u32
    let mut i : u32 = 0u32
    while i < n {
        rm_write_key(i, bufp)
        /* Running group size m: this node forms m new pairs with the m prior
         * members, then the group grows to m+1 (Sum over groups of C(m,2)). */
        let prev : u32 = cai_get(kp, vp, RM_SEP_MASK, bufp)
        let mut m : u32 = 0u32
        if prev != 0xFFFFFFFFu32 { m = prev }
        c = c + m
        cai_put(kp, vp, RM_SEP_MASK, bufp, m + 1u32)
        i = i + 1u32
    }
    return c
}

/* The objective J, offset to stay non-negative (counts are small vs the offset):
 * J = OFFSET + good - noise - separation.  Higher J = more load-bearing structure,
 * less dead noise, less duplication.  The per-candidate ΔJ the decider uses is given
 * by rm_cut_improves / rm_merge_improves (each strictly raises J when 1). */
const RM_J_OFFSET : u64 = 1000000u64
fn rm_j() -> u64 @export {
    let g  : u64 = rm_good() as u64
    let nz : u64 = rm_noise() as u64
    let sp : u64 = rm_sep() as u64
    /* [soundness] floor at 0.  For a large graph nz+sp can exceed OFFSET+g; the old
     * `OFFSET+g-nz-sp` then UNDERFLOWED to a near-u64-max value -> a degenerate (all-noise)
     * state read as MAXIMAL 𝒱, a false-accept by rm_cut_improves/rm_merge_improves.  g and the
     * counts are u32-derived so pos/sub themselves never overflow u64. */
    let pos : u64 = RM_J_OFFSET + g
    let sub : u64 = nz + sp
    if sub > pos { return 0u64 }
    return pos - sub
}

/* G2 (III-SOVEREIGN-ENHANCEMENT-COORDINATION): the named value 𝒱 the Enhancement Theorem maximizes.
 * 𝒱 = rm_value is a TOTAL u64 order and a pure function of the three structural counts
 * (good, noise, sep) -- so it CANNOT be raised by a cosmetic/relabelling move (non-gameable):
 * ΔV>0 ⟺ Δgood>0 ∨ Δnoise<0 ∨ Δsep<0, each a real structural gain. Certified by KAT 930. */
fn rm_value() -> u64 @export { return rm_j() }

/* ===== BATCH 1 (Evolution): the MDL BOUNDARY face of 𝒱 -- ripple_metric is now the SINGLE
 * value-function authority. Until now the extraction decider (ripple_extract C2) carried its OWN
 * inline cost compare (saved > new_file + import); a second, independent value model that could
 * silently DIVERGE from 𝒱 (someone re-philosophises J but not C2 -> the optimizer admits boundaries
 * 𝒱 would reject). The two are the SAME judgement seen at two granularities: a unification (merge)
 * collapses a separation and raises 𝒱; a separation-CREATING move (extract a shared routine into a
 * new file) is value-positive ONLY when the deduplication dividend it earns strictly outweighs the
 * new boundary's structural overhead (its header + imports + the pointer indirection at the callers).
 *
 * rm_extract_cost is that overhead in lines; rm_extract_improves is the strict ΔV>0 verdict that
 * ripple_extract's C2 now DEFERS to (one model, one authority). The strict `>` keeps a break-even
 * boundary (dividend == cost) NON-improving: III never spawns a file that merely pays for itself --
 * only one whose shared logic genuinely earns its own boundary. Non-gameability EXTENDS to this face:
 * the verdict is a pure function of the three line counts, so no relabelling can flip it.
 * Certified by KAT 954 (prove-the-negative: break-even and below are REJECTED; above is ADMITTED). */
fn rm_extract_cost(new_file_lines: u64, import_overhead: u64) -> u64 @export {
    return new_file_lines + import_overhead
}
fn rm_extract_improves(saved_lines: u64, new_file_lines: u64, import_overhead: u64) -> u32 @export {
    let cost : u64 = rm_extract_cost(new_file_lines, import_overhead)
    if saved_lines > cost { return 1u32 }   /* strict ΔV > 0: the dividend earns the boundary */
    return 0u32
}
