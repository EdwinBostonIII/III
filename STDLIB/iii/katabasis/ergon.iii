/* ==================== THE FAULT MAP ==================== */
const ERG_META_ANOMALY : u32 = 1001u32     /* vitality 0 but roster examines green */
const ERG_META_XFOLD   : u32 = 1002u32     /* ergon's own fold != intro_vitality  */
const ERG_META_GARBAGE : u32 = 1003u32     /* kardia accepted a malformed line    */

var ERG_VIT : u64 = 0u64                   /* last census vitality root           */
fn erg_vitality() -> u64 @export { return ERG_VIT }

/* map (seat, raw arm) -> the census code space; mode 1 SABOTAGES seat 1 into
 * seat 0's range so the injectivity checker can prove its own teeth */
fn erg_mapcode(seat: u64, arm: u64, mode: u64) -> u64 {
    if seat == 0u64 { return arm }                     /* intro codes pass through */
    if seat == 1u64 { if mode == 1u64 { return 90u64 + arm }   return 600u64 + arm }
    if seat == 2u64 { return 700u64 + arm }
    if seat == 3u64 { return 800u64 + arm }
    if seat == 4u64 { return 900u64 + arm }
    if seat == 5u64 { return 950u64 + arm }
    if seat == 6u64 { return 1100u64 + arm }
    if seat == 7u64 { return 1200u64 + arm }
    if seat == 8u64 { return 1300u64 + arm }
    if seat == 10u64 { return 1400u64 + arm }          /* the DEEP verb's codes  */
    if seat == 11u64 { return 1500u64 + arm }          /* the AUTARKEIA verb     */
    if seat == 12u64 { return 1600u64 + arm }          /* the ZK-AUDIT verb      */
    return 1000u64 + arm
}
/* the whole fault space is INJECTIVE: enumerate every code either seat can emit
 * and require no collision (1 injective | 0 collision found) */
var ERG_SEEN : [u8; 1700]
fn erg_map_injective(mode: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < 1700u64 { ERG_SEEN[i] = 0u8   i = i + 1u64 }
    /* seat 0: 100..599  seat 1: 11..19  seat 2: 41..45  seat 3: 21..36
     * seat 4: 1..6  meta: 1..3 (mapped 1001..1003) */
    let mut c : u64 = 100u64
    while c <= 599u64 {
        let m : u64 = erg_mapcode(0u64, c, mode)
        if ERG_SEEN[m] == 1u8 { return 0u64 }
        ERG_SEEN[m] = 1u8
        c = c + 1u64
    }
    let mut k : u64 = 11u64
    while k <= 19u64 {
        let m1 : u64 = erg_mapcode(1u64, k, mode)
        if ERG_SEEN[m1] == 1u8 { return 0u64 }
        ERG_SEEN[m1] = 1u8
        k = k + 1u64
    }
    let mut s : u64 = 41u64
    while s <= 46u64 {
        let m2 : u64 = erg_mapcode(2u64, s, mode)
        if ERG_SEEN[m2] == 1u8 { return 0u64 }
        ERG_SEEN[m2] = 1u8
        s = s + 1u64
    }
    let mut d : u64 = 21u64
    while d <= 36u64 {
        let m3 : u64 = erg_mapcode(3u64, d, mode)
        if ERG_SEEN[m3] == 1u8 { return 0u64 }
        ERG_SEEN[m3] = 1u8
        d = d + 1u64
    }
    let mut q : u64 = 1u64
    while q <= 6u64 {
        let m4 : u64 = erg_mapcode(4u64, q, mode)
        if ERG_SEEN[m4] == 1u8 { return 0u64 }
        ERG_SEEN[m4] = 1u8
        q = q + 1u64
    }
    let mut w : u64 = 1u64
    while w <= 7u64 {
        let m5 : u64 = erg_mapcode(5u64, w, mode)
        if ERG_SEEN[m5] == 1u8 { return 0u64 }
        ERG_SEEN[m5] = 1u8
        w = w + 1u64
    }
    let mut hx : u64 = 1u64
    while hx <= 5u64 {
        let m6 : u64 = erg_mapcode(6u64, hx, mode)
        if ERG_SEEN[m6] == 1u8 { return 0u64 }
        ERG_SEEN[m6] = 1u8
        hx = hx + 1u64
    }
    let mut it : u64 = 1u64
    while it <= 4u64 {
        let m7 : u64 = erg_mapcode(7u64, it, mode)
        if ERG_SEEN[m7] == 1u8 { return 0u64 }
        ERG_SEEN[m7] = 1u8
        it = it + 1u64
    }
    let mut xc : u64 = 1u64
    while xc <= 12u64 {
        let m8 : u64 = erg_mapcode(8u64, xc, mode)
        if ERG_SEEN[m8] == 1u8 { return 0u64 }
        ERG_SEEN[m8] = 1u8
        xc = xc + 1u64
    }
    let mut dp : u64 = 1u64
    while dp <= 13u64 {
        let m10 : u64 = erg_mapcode(10u64, dp, mode)
        if ERG_SEEN[m10] == 1u8 { return 0u64 }
        ERG_SEEN[m10] = 1u8
        dp = dp + 1u64
    }
    let mut ak : u64 = 1u64
    while ak <= 10u64 {
        let m11 : u64 = erg_mapcode(11u64, ak, mode)
        if ERG_SEEN[m11] == 1u8 { return 0u64 }
        ERG_SEEN[m11] = 1u8
        ak = ak + 1u64
    }
    let mut zk : u64 = 1u64
    while zk <= 5u64 {
        let m12 : u64 = erg_mapcode(12u64, zk, mode)
        if ERG_SEEN[m12] == 1u8 { return 0u64 }
        ERG_SEEN[m12] = 1u8
        zk = zk + 1u64
    }
    let mut z : u64 = 1u64
    while z <= 3u64 {
        let m9 : u64 = erg_mapcode(9u64, z, mode)
        if ERG_SEEN[m9] == 1u8 { return 0u64 }
        ERG_SEEN[m9] = 1u8
        z = z + 1u64
    }
    return 1u64
}

/* ==================== THE SELF-PROOF (condition of motion) ====================
 * Cheap, synthetic, with teeth -- no verb runs over a broken instrument.
 * 0 = proven | the arm number (71..72). */
fn erg_selfprove() -> u64 @export {
    /* arm 71: the fault map is injective -- and the CHECKER has teeth (a
     * sabotaged map that collides seat 1 into seat 0's range MUST be caught) */
    if erg_map_injective(0u64) != 1u64 { return 71u64 }
    if erg_map_injective(1u64) != 0u64 { return 71u64 }
    /* arm 72: the fold instrument the cross-check leans on -- deterministic,
     * input-sensitive (one flipped bit anywhere moves the seal) */
    let mut h1 : u64 = idfold_basis()
    h1 = idfold_u64(h1, 12345u64)
    h1 = idfold_u64(h1, 67890u64)
    let s1 : u64 = idfold_seal(h1)
    let mut h2 : u64 = idfold_basis()
    h2 = idfold_u64(h2, 12345u64)
    h2 = idfold_u64(h2, 67890u64)
    if idfold_seal(h2) != s1 { return 72u64 }
    let mut h3 : u64 = idfold_basis()
    h3 = idfold_u64(h3, 12345u64 ^ 1u64)
    h3 = idfold_u64(h3, 67890u64)
    if idfold_seal(h3) == s1 { return 72u64 }
    return 0u64
}

/* ==================== SEAT 0: INTROSPECTION + the examiner-of-the-examiner ==== */
fn erg_seat_intro() -> u32 @export {
    ERG_VIT = 0u64
    let v : u64 = intro_vitality()
    if v == 0u64 {
        let c : u32 = intro_examine_all()
        if c != 0u32 { return c }
        return ERG_META_ANOMALY
    }
    /* re-fold the vitality root with ergon's OWN loop; refuse a fold the
     * examiner cannot reproduce -- and prove the refusal is load-bearing */
    let mut h : u64 = idfold_basis()
    let mut i : u32 = 0u32
    while i < intro_organ_count() { h = idfold_u64(h, intro_organ_ident(i))   i = i + 1u32 }
    if idfold_seal(h) != v { return ERG_META_XFOLD }
    let mut hp : u64 = idfold_basis()
    hp = idfold_u64(hp, intro_organ_ident(0u32) ^ 1u64)
    let mut j : u32 = 1u32
    while j < intro_organ_count() { hp = idfold_u64(hp, intro_organ_ident(j))   j = j + 1u32 }
    if idfold_seal(hp) == v { return ERG_META_XFOLD }
    ERG_VIT = v
    return 0u32
}

/* ==================== SEAT 1..3: the standing organs' own arms ==================== */
var ERG_G : [u8; 8]
fn erg_seat_kardia() -> u32 @export {
    /* garbage teeth first: a malformed ledger line MUST fold to nothing */
    ERG_G[0u64] = 88u8   ERG_G[1u64] = 88u8   ERG_G[2u64] = 88u8   ERG_G[3u64] = 88u8
    if kd_fold_line((&ERG_G) as u64, 4u64) != 0u64 { return ERG_META_GARBAGE }
    let a : u64 = kd_selfprove()
    if a != 0u64 { return (600u64 + a) as u32 }
    return 0u32
}
fn erg_seat_soma() -> u32 @export {
    let a : u64 = soma_selfprove()
    if a != 0u64 { return (700u64 + a) as u32 }
    return 0u32
}
fn erg_seat_doxa() -> u32 @export {
    let a : u64 = dx_selfprove()
    if a != 0u64 { return (800u64 + a) as u32 }
    return 0u32
}

/* ==================== SEAT 4: THE ABSORBED FAMILY (iscene) ====================
 * The laws of gate 2200_iscene, re-derived live -- stored pin REMOVED.
 * Returns 0 | 1 DET | 2 RES | 3 SIZE | 4 RT | 5 BIND | 6 PX/SETTERS. */
var ERG_FBRD : [u32; 12288]
fn erg_scene_build() -> i32 {
    iscene_reset()
    iscene_add(0i64 - 30i64, 20i64,        340i64, 7225i64, 235i64, 150i64, 70i64)
    iscene_add(55i64,        0i64 - 4i64,  250i64, 3600i64, 80i64,  175i64, 225i64)
    iscene_add(0i64 - 82i64, 0i64 - 60i64, 205i64, 2025i64, 120i64, 220i64, 110i64)
    return 0i32
}
fn erg_arm_iscene() -> u64 {
    /* DET: the render is a function -- twice at 128x96, identical and nonzero.
     * NO stored pin: the law is determinism, not one renderer's frozen bytes. */
    erg_scene_build()
    iscene_render(128u64, 96u64)
    let d1 : u64 = iscene_sig(128u64, 96u64)
    iscene_render(128u64, 96u64)
    let d2 : u64 = iscene_sig(128u64, 96u64)
    if d1 != d2 { return 1u64 }
    if d1 == 0u64 { return 1u64 }
    /* RES: the SAME master renders deterministic, pairwise-DISTINCT frames at
     * three resolutions -- one tiny file, arbitrarily many exact rasters */
    iscene_render(96u64, 72u64)
    let ra1 : u64 = iscene_sig(96u64, 72u64)
    iscene_render(96u64, 72u64)
    let ra2 : u64 = iscene_sig(96u64, 72u64)
    iscene_render(192u64, 144u64)
    let rc1 : u64 = iscene_sig(192u64, 144u64)
    iscene_render(192u64, 144u64)
    let rc2 : u64 = iscene_sig(192u64, 144u64)
    if ra1 != ra2 { return 2u64 }
    if rc1 != rc2 { return 2u64 }
    if ra1 == 0u64 { return 2u64 }
    if rc1 == 0u64 { return 2u64 }
    if ra1 == d1 { return 2u64 }
    if rc1 == d1 { return 2u64 }
    if ra1 == rc1 { return 2u64 }
    /* SIZE: the master is O(objects) by the format's own equation, resolution-
     * free -- the LIVE object count enters the law, no literal enthroned */
    let n : i64 = iscene_count()
    if n != 3i64 { return 3u64 }
    let fb : u64 = iscene_file_bytes()
    if fb != (56u64 + (n as u64) * 56u64) { return 3u64 }
    if fb >= 1024u64 { return 3u64 }
    /* RT: write the master, WIPE the scene, read it back -- the scene signature
     * and the 128x96 render both survive the trip exactly */
    let ss0 : u64 = iscene_scene_sig()
    if iscene_write("STDLIB/build/ergon_census.isc" as u64) != 0i32 { return 4u64 }
    iscene_reset()
    if iscene_count() != 0i64 { return 4u64 }
    let rc : i64 = iscene_read("STDLIB/build/ergon_census.isc" as u64)
    if rc != 3i64 { return 4u64 }
    if iscene_scene_sig() != ss0 { return 4u64 }
    iscene_render(128u64, 96u64)
    if iscene_sig(128u64, 96u64) != d1 { return 4u64 }
    /* BIND: project to .ixr bound to the scene signature; the pixel file
     * recovers the binding AND the pixels bit-for-bit */
    let ss : u64 = iscene_scene_sig()
    iscene_render(128u64, 96u64)
    if iform_write_bound(iscene_fb_addr(), 128u32, 96u32, ss, "STDLIB/build/ergon_census.ixr" as u64) != 0i32 { return 5u64 }
    let rr : i64 = iform_read("STDLIB/build/ergon_census.ixr" as u64, (&ERG_FBRD) as u64, 12288u64)
    if rr < 0i64 { return 5u64 }
    if iform_last_bind() != ss { return 5u64 }
    let fba : u64 = iscene_fb_addr()
    let mut diff : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 12288u64 {
        let p : *u32 = (fba + i * 4u64) as *u32
        if p[0u64] != ERG_FBRD[i] { diff = diff + 1u64 }
        i = i + 1u64
    }
    if diff != 0u64 { return 5u64 }
    /* PX + SETTERS (the teeth): the pixel read-head agrees with the live
     * framebuffer, and focal/light are LOAD-BEARING -- changing either MUST
     * change the image; restoring MUST reproduce it.  A renderer that stops
     * feeling its inputs cannot pass, so the arm can never go vacuous. */
    erg_scene_build()
    iscene_render(128u64, 96u64)
    let base : u64 = iscene_sig(128u64, 96u64)
    if base != d1 { return 6u64 }
    let fbp : u64 = iscene_fb_addr()
    let pc : *u32 = (fbp + (48u64 * 128u64 + 64u64) * 4u64) as *u32
    if iscene_px(64u64, 48u64, 128u64) != pc[0u64] { return 6u64 }
    let po : *u32 = fbp as *u32
    if iscene_px(0u64, 0u64, 128u64) != po[0u64] { return 6u64 }
    iscene_set_focal(140i64)
    iscene_render(128u64, 96u64)
    if iscene_sig(128u64, 96u64) == base { return 6u64 }
    erg_scene_build()
    iscene_render(128u64, 96u64)
    if iscene_sig(128u64, 96u64) != base { return 6u64 }
    iscene_set_light(200i64, 0i64 - 200i64, 60i64)
    iscene_render(128u64, 96u64)
    if iscene_sig(128u64, 96u64) == base { return 6u64 }
    iscene_reset()
    return 0u64
}
fn erg_seat_iscene() -> u32 @export {
    let a : u64 = erg_arm_iscene()
    if a != 0u64 { return (900u64 + a) as u32 }
    return 0u32
}

/* ==================== SEAT 5: THE ABSORBED FAMILY (iform) ====================
 * The laws of gate 2199_iform (the first C1-table retirement), re-derived live.
 * Returns 0 | 1 RT | 2 SV | 3 TAMPER | 4 HDR | 5 BIND | 6 DET | 7 SUP. */
var ERG_IFB  : [u32; 3072]                 /* 64x48 varying-alpha battery         */
var ERG_IFB2 : [u32; 3072]
var ERG_TB   : [u8; 20000]
var ERG_TC   : [u32; 1]
fn erg_iform_fill() -> i32 {
    /* deterministic battery whose ALPHA byte varies across 0..255 (many mid
     * values) -- the probe, not an expectation: the LAW is that every word
     * survives the container bit-for-bit, alpha included */
    let mut i : u64 = 0u64
    while i < 3072u64 {
        let a : u32 = ((i * 7u64) & 255u64) as u32
        let r : u32 = ((i * 5u64) & 255u64) as u32
        let g : u32 = ((i * 3u64) & 255u64) as u32
        let b : u32 = (i & 255u64) as u32
        ERG_IFB[i] = (a << 24u32) | (r << 16u32) | (g << 8u32) | b
        i = i + 1u64
    }
    return 0i32
}
fn erg_arm_iform() -> u64 {
    erg_iform_fill()
    /* DET: the payload signature is a PURE function of the pixels -- twice the
     * same, nonzero -- with input-sensitivity TEETH replacing the old stored
     * pin: flipping ONE pixel word MUST move the signature. */
    let d1 : u64 = iform_sig_words((&ERG_IFB) as u64, 3072u64)
    let d2 : u64 = iform_sig_words((&ERG_IFB) as u64, 3072u64)
    if d1 != d2 { return 6u64 }
    if d1 == 0u64 { return 6u64 }
    let keep : u32 = ERG_IFB[100u64]
    ERG_IFB[100u64] = keep ^ 1u32
    if iform_sig_words((&ERG_IFB) as u64, 3072u64) == d1 { return 6u64 }
    ERG_IFB[100u64] = keep
    if iform_sig_words((&ERG_IFB) as u64, 3072u64) != d1 { return 6u64 }
    /* RT + BIND: write bound, read back -- bit-for-bit, alpha included; the
     * read-side signature cache must equal the computed signature (coherence,
     * not decoration); the generator binding survives. */
    if iform_write_bound((&ERG_IFB) as u64, 64u32, 48u32, 12345678901234u64, "STDLIB/build/ergon_iform.ixr" as u64) != 0i32 { return 1u64 }
    let rr : i64 = iform_read("STDLIB/build/ergon_iform.ixr" as u64, (&ERG_IFB2) as u64, 3072u64)
    if rr < 0i64 { return 1u64 }
    if iform_last_sig() != d1 { return 1u64 }
    let mut diff : u64 = 0u64
    let mut mid : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 3072u64 {
        if ERG_IFB[i] != ERG_IFB2[i] { diff = diff + 1u64 }
        let a : u32 = ERG_IFB2[i] >> 24u32
        if a != 0u32 { if a != 255u32 { mid = mid + 1u64 } }
        i = i + 1u64
    }
    if diff != 0u64 { return 1u64 }
    /* HDR: the container is self-describing -- exact dimensions recovered,
     * and the read result packs them (w<<32)|h. */
    if iform_last_w() != 64u32 { return 4u64 }
    if iform_last_h() != 48u32 { return 4u64 }
    if rr != ((64i64 << 32i64) | 48i64) { return 4u64 }
    /* BIND: the generator signature reads back intact. */
    if iform_last_bind() != 12345678901234u64 { return 5u64 }
    /* SV: a freshly-written file self-verifies. */
    if iform_verify("STDLIB/build/ergon_iform.ixr" as u64) != 0i32 { return 2u64 }
    /* TAMPER: flip ONE payload byte ON DISK (through the OS), re-verify -- the
     * container MUST detect it (verdict 2).  This is the integrity field the
     * legacy raster never had. */
    let hf : u64 = CreateFileA("STDLIB/build/ergon_iform.ixr" as u64, 2147483648u32, 1u32, 0u64, 3u32, 128u32, 0u64)
    if hf == 18446744073709551615u64 { return 3u64 }
    ReadFile(hf, (&ERG_TB) as u64, 20000u32, (&ERG_TC) as u64, 0u64)
    CloseHandle(hf)
    let bp : *u8 = ((&ERG_TB) as u64 + 100u64) as *u8
    bp[0u64] = bp[0u64] ^ 255u8
    let hf2 : u64 = CreateFileA("STDLIB/build/ergon_iform.ixr" as u64, 1073741824u32, 0u32, 0u64, 2u32, 128u32, 0u64)
    if hf2 == 18446744073709551615u64 { return 3u64 }
    WriteFile(hf2, (&ERG_TB) as u64, ERG_TC[0u64], (&ERG_TC) as u64, 0u64)
    CloseHandle(hf2)
    if iform_verify("STDLIB/build/ergon_iform.ixr" as u64) != 2i32 { return 3u64 }
    /* SUP: the round-tripped image carried mid-range alphas (neither 0 nor 255)
     * -- unrepresentable in the 24-bit legacy path, preserved exactly here --
     * and the organ's own recorded verdict on the legacy format stands. */
    if mid == 0u64 { return 7u64 }
    if iform_note_bmp_is_legacy() != 1i32 { return 7u64 }
    return 0u64
}
fn erg_seat_iform() -> u32 @export {
    let a : u64 = erg_arm_iform()
    if a != 0u64 { return (950u64 + a) as u32 }
    return 0u32
}

/* ==================== SEAT 6: HEXAD (ex run_hexad_cli) ====================
 * The 144-manifold's laws, derived over the WHOLE 729-point code space every
 * census (the retired runner sampled ~15 points).  The examiner decodes base-3
 * WITH ITS OWN LOOP (never unpack6) and applies ITS OWN admission rule -- true
 * two-path against the organ's bitmap.  Codes 1100+arm:
 *   1 census (my full count == 144 == the organ's), 2 whole-space verdict
 *   agreement, 3 SABOTAGE teeth (a wrong rule must break both laws),
 *   4 compose dominance + whole-space idempotence, 5 pack/unpack bijection. */
var ERG_HT : [i32; 6]
var ERG_HT2 : [i32; 6]
fn erg_hex_myrule(h: u64) -> u64 {
    /* MY decode + MY rule: base-3 LE digits; digit 0 = trit -1 = NEG; admitted
     * iff no NEG among pillars 0..3.  mode-free, no calls into the organ. */
    let mut v : u64 = h
    let mut k : u64 = 0u64
    while k < 4u64 {
        let q : u64 = v / 3u64
        if (v - q * 3u64) == 0u64 { return 0u64 }
        v = q
        k = k + 1u64
    }
    return 1u64
}
fn erg_hex_sabotage(h: u64) -> u64 {
    /* the deliberately-wrong rule (NEG in P5 also bricks) for the teeth */
    let mut v : u64 = h
    let mut k : u64 = 0u64
    while k < 5u64 {
        let q : u64 = v / 3u64
        if (v - q * 3u64) == 0u64 { return 0u64 }
        v = q
        k = k + 1u64
    }
    return 1u64
}
fn erg_arm_hexad() -> u64 {
    iii_hexad_init()
    /* arm 1: the census -- my whole-space count, the manifold equation, and the
     * organ's own count all agree (144 = 2^4 * 3^2) */
    let mut mine : u64 = 0u64
    let mut h : u64 = 0u64
    while h < 729u64 { mine = mine + erg_hex_myrule(h)   h = h + 1u64 }
    if mine != 144u64 { return 1u64 }
    if iii_hexad_reachable_count() != 144u64 { return 1u64 }
    /* arm 2: whole-space verdict agreement -- every one of the 729 codes */
    h = 0u64
    while h < 729u64 {
        let want : u64 = erg_hex_myrule(h)
        if (iii_hexad_reachable(h as u16) as u64) != want { return 2u64 }
        h = h + 1u64
    }
    /* arm 3: SABOTAGE teeth -- the wrong rule must yield a different census
     * (96) AND disagree with the organ somewhere; a cross-check that cannot
     * fail proves nothing */
    let mut sab : u64 = 0u64
    let mut dis : u64 = 0u64
    h = 0u64
    while h < 729u64 {
        let s : u64 = erg_hex_sabotage(h)
        sab = sab + s
        if (iii_hexad_reachable(h as u16) as u64) != s { dis = dis + 1u64 }
        h = h + 1u64
    }
    if sab != 96u64 { return 3u64 }
    if dis == 0u64 { return 3u64 }
    /* arm 4: compose -- NEG dominates AND on the structural pillars (all-POS
     * composed with NEG@P1 bricks; admitted with admitted stays admitted), and
     * compose is IDEMPOTENT over the whole space (trit AND/OR both are) */
    let mut i : u64 = 0u64
    while i < 6u64 { ERG_HT[i] = 1i32   i = i + 1u64 }
    let all_pos : u16 = iii_hexad_pack6((&ERG_HT) as u64)
    ERG_HT[0u64] = 0i32 - 1i32
    let neg_p1 : u16 = iii_hexad_pack6((&ERG_HT) as u64)
    if iii_hexad_reachable(iii_hexad_compose6(all_pos, neg_p1)) != 0u8 { return 4u64 }
    i = 0u64
    while i < 4u64 { ERG_HT[i] = 1i32   i = i + 1u64 }
    ERG_HT[4u64] = 0i32
    ERG_HT[5u64] = 0i32
    let adm : u16 = iii_hexad_pack6((&ERG_HT) as u64)
    if iii_hexad_reachable(iii_hexad_compose6(adm, adm)) != 1u8 { return 4u64 }
    h = 0u64
    while h < 729u64 {
        if iii_hexad_compose6(h as u16, h as u16) != (h as u16) { return 4u64 }
        h = h + 1u64
    }
    /* arm 5: pack6(unpack6(h)) == h over the whole code space (bijection) */
    h = 0u64
    while h < 729u64 {
        if iii_hexad_unpack6(h as u16, (&ERG_HT2) as u64) != 1u8 { return 5u64 }
        if (iii_hexad_pack6((&ERG_HT2) as u64) as u64) != h { return 5u64 }
        h = h + 1u64
    }
    return 0u64
}
fn erg_seat_hexad() -> u32 @export {
    let a : u64 = erg_arm_hexad()
    if a != 0u64 { return (1100u64 + a) as u32 }
    return 0u32
}

/* ==================== SEAT 7: INTENT (ex run_intent_cli) ====================
 * The Oracle of Rejection's laws with expected verdicts DERIVED live from the
 * ontology's own masks -- the retired runner hardcoded them in comments; here
 * the examiner tokenizes each sentence WITH ITS OWN space-splitter, reads each
 * word's mask from the ontology, intersects the operator masks itself, and
 * derives the class by ITS OWN popcount.  dis_resolve must agree everywhere.
 * Codes 1200+arm: 1 derivation agreement + four-class coverage, 2 determinism
 * (verdict AND resolved mask), 3 SABOTAGE teeth (an examiner that skips a
 * token must be caught by disagreement), 4 the resolved-mask law. */
fn erg_int_pop(v: u64) -> u64 {
    let mut c : u64 = 0u64
    let mut s : u64 = 0u64
    while s < 64u64 { c = c + ((v >> s) & 1u64)   s = s + 1u64 }
    return c
}
fn erg_int_len(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut n : u64 = 0u64
    while p[n] != 0u8 { n = n + 1u64 }
    return n
}
/* MY derivation: split on spaces with my own scanner, mask each word via the
 * ontology, AND the nonzero (operator) masks.  skip_index skips the i-th WORD
 * (the sabotage teeth); pass 0xFFFF to skip nothing.  Returns the class. */
fn erg_int_derive2(s: u64, n: u64, skip_index: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut acc : u64 = 0xFFFFFFFFFFFFFFFFu64
    let mut ops : u64 = 0u64
    let mut i : u64 = 0u64
    let mut widx : u64 = 0u64
    while i < n {
        if p[i] == 32u8 { i = i + 1u64 } else {
            let ws : u64 = i
            let mut we : u64 = i
            let mut go : u64 = 1u64
            while go == 1u64 {
                if we >= n { go = 0u64 } else { if p[we] == 32u8 { go = 0u64 } else { we = we + 1u64 } }
            }
            if widx != skip_index {
                let m : u64 = lo_mask_of(s + ws, we - ws)
                if m != 0u64 { acc = acc & m   ops = ops + 1u64 }
            }
            widx = widx + 1u64
            i = we
        }
    }
    if ops == 0u64 { return 3u64 }                    /* EMPTY */
    let pc : u64 = erg_int_pop(acc)
    if pc == 1u64 { return 0u64 }                     /* RESOLVED */
    if pc == 0u64 { return 1u64 }                     /* CONTRADICTION */
    return 2u64                                       /* AMBIGUOUS */
}
/* my derived intersection (for the resolved-mask law); mirrors erg_int_derive2 */
fn erg_int_mask(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let n : u64 = erg_int_len(s)
    let mut acc : u64 = 0xFFFFFFFFFFFFFFFFu64
    let mut ops : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n {
        if p[i] == 32u8 { i = i + 1u64 } else {
            let ws : u64 = i
            let mut we : u64 = i
            let mut go : u64 = 1u64
            while go == 1u64 {
                if we >= n { go = 0u64 } else { if p[we] == 32u8 { go = 0u64 } else { we = we + 1u64 } }
            }
            let m : u64 = lo_mask_of(s + ws, we - ws)
            if m != 0u64 { acc = acc & m   ops = ops + 1u64 }
            i = we
        }
    }
    if ops == 0u64 { return 0u64 }
    return acc
}
fn erg_int_probe(s: u64) -> u64 {
    /* one sentence: my derived class vs the oracle; >=100 on disagreement,
     * else the derived class (0..3) */
    let want : u64 = erg_int_derive2(s, erg_int_len(s), 0xFFFFu64)
    let got : u64 = dis_resolve(s, erg_int_len(s)) as u64
    if got != want { return 100u64 + want }
    return want
}
var ERG_INT_COVER : [u64; 4]
fn erg_arm_intent() -> u64 {
    lo_init()
    let mut c : u64 = 0u64
    while c < 4u64 { ERG_INT_COVER[c] = 0u64   c = c + 1u64 }
    /* arm 1: derivation agreement across the probe battery -- every class must
     * be REACHED by derivation (coverage), never assumed */
    let mut r : u64 = 0u64
    r = erg_int_probe("lock the database" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("freeze the disk" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("expire the ttl" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("encrypt the key" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("deny the port" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("lock the network" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("encrypt the network port" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("generate a key" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("freeze the port" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("lock" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("generate" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("lock lock" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("the cat sat on the mat" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    r = erg_int_probe("hello world" as u64)
    if r >= 100u64 { return 1u64 }
    ERG_INT_COVER[r] = ERG_INT_COVER[r] + 1u64
    c = 0u64
    while c < 4u64 { if ERG_INT_COVER[c] == 0u64 { return 1u64 }   c = c + 1u64 }
    /* arm 2: determinism -- verdict and resolved mask byte-stable */
    let v1 : u64 = dis_resolve("lock the database" as u64, 17u64) as u64
    let m1 : u64 = dis_resolved_mask()
    let v2 : u64 = dis_resolve("lock the database" as u64, 17u64) as u64
    let m2 : u64 = dis_resolved_mask()
    if v1 != v2 { return 2u64 }
    if m1 != m2 { return 2u64 }
    /* arm 3: SABOTAGE teeth -- an examiner that skips the disambiguating word
     * ("network" in "lock the network") must DISAGREE with the oracle; a
     * cross-check that cannot fail proves nothing */
    let full : u64 = erg_int_derive2("lock the network" as u64, 16u64, 0xFFFFu64)
    let sab : u64 = erg_int_derive2("lock the network" as u64, 16u64, 2u64)
    if full != 0u64 { return 3u64 }
    if sab == full { return 3u64 }
    if (dis_resolve("lock the network" as u64, 16u64) as u64) == sab { return 3u64 }
    /* arm 4: the resolved-mask law -- on RESOLVED the surviving bit is exactly
     * my derived intersection with popcount 1; on a non-RESOLVED verdict the
     * mask is 0 */
    if (dis_resolve("deny the port" as u64, 13u64) as u64) != 0u64 { return 4u64 }
    if dis_resolved_mask() != erg_int_mask("deny the port" as u64) { return 4u64 }
    if erg_int_pop(dis_resolved_mask()) != 1u64 { return 4u64 }
    if (dis_resolve("generate" as u64, 8u64) as u64) != 2u64 { return 4u64 }
    if dis_resolved_mask() != 0u64 { return 4u64 }
    return 0u64
}
fn erg_seat_intent() -> u32 @export {
    let a : u64 = erg_arm_intent()
    if a != 0u64 { return (1200u64 + a) as u32 }
    return 0u32
}

/* ==================== SEAT 8: EXEC -- the tool faces, through the process
 * organ (ex run_standing_tools' smoke half) ====================
 * The committed tool binaries are made to DO THEIR WORK: spawned through
 * stoma_proc (the house's own process organ -- pipes, wall-cap, kill-on-close),
 * their TRUE OS exit codes and output bytes judged in-process.  Known answers
 * are external truth (FIPS-180 digests, closed-form signs, the OS's own exit
 * codes, the constitution's sealed ids) -- never a tool's own stdout taken on
 * faith.  The retired runner's gate-REBUILD arms are NOT here: those gates are
 * C1 heart cells (the heart beats them when their reach drifts) -- rebuilding
 * them per sweep was the batch form.  Its in-process synapse/autophasis law
 * arms live in introspection's examines (seat 0).  Its heavy die-faculty verbs
 * live in the DEEP verb (erg_deep, 1400+) -- organ-owned, on demand.
 * Codes 1300+arm. */
var ERG_XB : [u8; 512]
fn erg_x_sput(at: u64, s: u64) -> u64 {
    let p : *u8 = (&ERG_XB) as u64 as *u8
    let q : *u8 = s as *u8
    let mut i : u64 = 0u64
    let mut a : u64 = at
    while q[i] != 0u8 { p[a] = q[i]   a = a + 1u64   i = i + 1u64 }
    p[a] = 0u8
    return a
}
/* spawn a command line (CWD = the III root, inherited); returns the child's
 * exit code, or 9901 on plumbing failure / 9902 on wall-timeout */
fn erg_x_run(cmd: u64, cap_ms: u32) -> u64 {
    let r : i32 = proc_run(cmd, 0u64, cap_ms)
    if r == 1i32 { return 9902u64 }
    if r != 0i32 { return 9901u64 }
    return proc_code() as u64
}
fn erg_x_find(pat: u64) -> u64 {
    let mut n : u64 = 0u64
    let p : *u8 = pat as *u8
    while p[n] != 0u8 { n = n + 1u64 }
    if proc_out_find(pat, n) == 1u32 { return 1u64 }
    return 0u64
}
/* parse the first unsigned decimal right after `marker` in the captured stdout */
fn erg_x_parse_after(marker: u64) -> u64 {
    let mut mlen : u64 = 0u64
    let mp : *u8 = marker as *u8
    while mp[mlen] != 0u8 { mlen = mlen + 1u64 }
    let n : u64 = proc_out_len()
    let mut i : u64 = 0u64
    while i + mlen <= n {
        let mut k : u64 = 0u64
        let mut hit : u64 = 1u64
        while k < mlen { if proc_out_at(i + k) != mp[k] { hit = 0u64   k = mlen } else { k = k + 1u64 } }
        if hit == 1u64 {
            let mut j : u64 = i + mlen
            let mut v : u64 = 0u64
            let mut got : u64 = 0u64
            let mut go : u64 = 1u64
            while go == 1u64 {
                if j >= n { go = 0u64 } else {
                    let c : u8 = proc_out_at(j)
                    if c >= 48u8 { if c <= 57u8 { v = v * 10u64 + ((c - 48u8) as u64)   got = 1u64   j = j + 1u64 } else { go = 0u64 } } else { go = 0u64 }
                }
            }
            if got == 1u64 { return v }
            return 0u64
        }
        i = i + 1u64
    }
    return 0u64
}
/* write a small file (CREATE_ALWAYS) through the OS; length = strlen(bytes),
 * so literals never carry hand-counted lengths (foreseen numbers rot) */
var ERG_NOMOS_LIVE : u64 = 0u64
var ERG_NOMOS_SEALED : u64 = 0u64
var ERG_SEED : [u8; 96]
fn erg_x_put(path: u64, bytes: u64) -> u64 {
    let p : *u8 = bytes as *u8
    let mut len : u64 = 0u64
    while p[len] != 0u8 { len = len + 1u64 }
    return erg_x_putn(path, bytes, len)
}
fn erg_x_putn(path: u64, bytes: u64, len: u64) -> u64 {
    let h : u64 = CreateFileA(path, 1073741824u32, 0u32, 0u64, 2u32, 128u32, 0u64)
    if h == 18446744073709551615u64 { return 0u64 }
    WriteFile(h, bytes, len as u32, (&ERG_TC) as u64, 0u64)
    CloseHandle(h)
    return 1u64
}
