    if erg_x_run("COMPILED\\iii-substrate.exe glossa STDLIB/build/ergap1" as u64, 300000u32) != 0u64 { return 1409u32 }
    let g1 : u64 = erg_x_parse_after("GLOSSA-SET id=" as u64)
