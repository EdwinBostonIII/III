    if erg_x_run("COMPILED\\iii_eval.exe STDLIB/build/ergon_p42.iii" as u64, 120000u32) != 36u64 { return 6u64 }
    if erg_x_run("COMPILED\\iii-events.exe --quiet STDLIB/build/ergon_p42.iii" as u64, 120000u32) != 36u64 { return 6u64 }
    if erg_x_run("COMPILED\\iii-events.exe --diff STDLIB/build/ergon_p42.iii STDLIB/build/ergon_p42.iii" as u64, 120000u32) != 0u64 { return 6u64 }
