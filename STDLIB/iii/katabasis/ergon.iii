/* STDLIB/iii/katabasis/ergon.iii -- THE ERGON: the machine proven by its WORK.
 *
 * THE CONSTITUTION THIS ORGAN ENFORCES: verification is not a separate act
 * performed on foreseen cases -- it is a property of the work itself.  A stored
 * expected answer tests only what its author foresaw, and an author (human,
 * Claude, or a future III developing III) can always edit toward it.  A LAW
 * derived at the moment of motion cannot be edited toward: to pass it you must
 * HAVE the property.  So the ERGON answers "is III whole?" the only unriggable
 * way -- by making the whole standing fleet DO ITS WORK, live, in one process:
 *
 *   seat 0  INTROSPECTION   the 5-organ roster examined with independent logic
 *                           (autognosis, autophasis, synapse, admix, entangle),
 *                           composed UNCHANGED -- plus the examiner-of-the-
 *                           examiner: ergon re-folds the vitality root with its
 *                           own loop and refuses a fold it cannot reproduce
 *   seat 1  KARDIA          the heart's condition-of-motion arms + garbage teeth
 *                           (a malformed ledger line MUST be refused)
 *   seat 2  SOMA            the body's arms (addressing, partition, ownership,
 *                           ledger-matcher laws)
 *   seat 3  DOXA            the belief organ's 16 arms (type law, mint, chamber,
 *                           federation -- each with its negative control)
 *   seat 4  ISCENE          the FIRST ABSORBED FAMILY: the laws of the .isc
 *                           resolution-independent scene master, formerly gate
 *                           2200_iscene + runner run_iform_kats.sh, now derived
 *                           live -- WITH THE STORED PIN REMOVED.  The old gate
 *                           froze one renderer output (2171929741710745466); the
 *                           law-form keeps determinism, resolution-independence,
 *                           the size equation, the lossless round-trip, the
 *                           generator binding, and the load-bearing-setter teeth
 *                           -- and lets the renderer EVOLVE, because no foreseen
 *                           byte is enthroned
 *
 * THE FAULT SPACE (a nonzero census verdict LOCATES seat and arm; proven
 * injective by erg_selfprove arm 71 before any verb moves):
 *   100..599   introspection roster (its own organ*100+arm codes)
 *   600+arm    kardia arms (611..619)
 *   700+arm    soma arms (741..745)
 *   800+arm    doxa arms (821..836)
 *   900+arm    iscene absorbed laws (901..906)
 *   1001..1003 ergon meta (vitality anomaly, cross-fold mismatch, garbage accepted)
 *
 * THE LEDGER: the census also REPORTS the ancestral batch layer still on the
 * die (runner scripts, registry claims, gate files -- counted organ-natively by
 * soma).  Debt is not sickness; it is measured molt-pressure, burned down as
 * families are absorbed into seats here.  What the census cannot yet derive
 * stays honestly in the ledger -- nothing is deleted on assumption.
 *
 * NIH: pure composition -- introspection, kardia, soma, doxa, iscene/iform,
 * numera/idfold.  Two-path everywhere it can be: the examiner re-derives with
 * its own arithmetic.  Hexad: kind_essence.  Ring R0. */
module katabasis_ergon

extern @abi(c-msvc-x64) fn intro_examine_all() -> u32 from "introspection.iii"
extern @abi(c-msvc-x64) fn intro_organ_count() -> u32 from "introspection.iii"
extern @abi(c-msvc-x64) fn intro_organ_ident(i: u32) -> u64 from "introspection.iii"
extern @abi(c-msvc-x64) fn intro_vitality() -> u64 from "introspection.iii"

extern @abi(c-msvc-x64) fn kd_selfprove() -> u64 from "kardia.iii"
extern @abi(c-msvc-x64) fn kd_fold_line(addr: u64, len: u64) -> u64 from "kardia.iii"

extern @abi(c-msvc-x64) fn soma_selfprove() -> u64 from "soma.iii"
extern @abi(c-msvc-x64) fn soma_survey_runners(dirpath: u64) -> u64 from "soma.iii"

extern @abi(c-msvc-x64) fn dx_selfprove() -> u64 from "doxa.iii"

extern @abi(c-msvc-x64) fn idfold_basis() -> u64 from "idfold.iii"
extern @abi(c-msvc-x64) fn idfold_u64(h: u64, v: u64) -> u64 from "idfold.iii"
extern @abi(c-msvc-x64) fn idfold_seal(h: u64) -> u64 from "idfold.iii"

extern @abi(c-msvc-x64) fn iscene_reset() -> i32 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_add(cx: i64, cy: i64, cz: i64, r2: i64, r: i64, g: i64, b: i64) -> i32 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_render(w: u64, h: u64) -> i32 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_sig(w: u64, h: u64) -> u64 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_scene_sig() -> u64 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_count() -> i64 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_fb_addr() -> u64 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_write(path: u64) -> i32 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_read(path: u64) -> i64 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_file_bytes() -> u64 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_px(x: u64, y: u64, w: u64) -> u32 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_set_focal(f: i64) -> i32 from "iscene.iii"
extern @abi(c-msvc-x64) fn iscene_set_light(lx: i64, ly: i64, lz: i64) -> i32 from "iscene.iii"

extern @abi(c-msvc-x64) fn iform_write_bound(fb: u64, w: u32, h: u32, bind: u64, path: u64) -> i32 from "iform.iii"
extern @abi(c-msvc-x64) fn iform_read(path: u64, fb_out: u64, maxwords: u64) -> i64 from "iform.iii"
extern @abi(c-msvc-x64) fn iform_last_bind() -> u64 from "iform.iii"

/* ==================== THE FAULT MAP ==================== */
const ERG_META_ANOMALY : u32 = 1001u32     /* vitality 0 but roster examines green */
const ERG_META_XFOLD   : u32 = 1002u32     /* ergon's own fold != intro_vitality  */
const ERG_META_GARBAGE : u32 = 1003u32     /* kardia accepted a malformed line    */

var ERG_VIT : u64 = 0u64                   /* last census vitality root           */
fn erg_vitality() -> u64 @export { return ERG_VIT }

/* map (seat, raw arm) -> the census code space; mode 1 SABOTAGES seat 1 into
 * seat 0's range so the injectivity checker can prove its own teeth */
fn erg_mapcode(seat: u64, arm: u64, mode: u64) -> u64 {
    if seat == 0u64 { return arm }                     /* intro codes pass through */
    if seat == 1u64 { if mode == 1u64 { return 90u64 + arm }   return 600u64 + arm }
    if seat == 2u64 { return 700u64 + arm }
    if seat == 3u64 { return 800u64 + arm }
    if seat == 4u64 { return 900u64 + arm }
    return 1000u64 + arm
}
/* the whole fault space is INJECTIVE: enumerate every code either seat can emit
 * and require no collision (1 injective | 0 collision found) */
var ERG_SEEN : [u8; 1104]
fn erg_map_injective(mode: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < 1104u64 { ERG_SEEN[i] = 0u8   i = i + 1u64 }
    /* seat 0: 100..599  seat 1: 11..19  seat 2: 41..45  seat 3: 21..36
     * seat 4: 1..6  meta: 1..3 (mapped 1001..1003) */
    let mut c : u64 = 100u64
    while c <= 599u64 {
        let m : u64 = erg_mapcode(0u64, c, mode)
        if ERG_SEEN[m] == 1u8 { return 0u64 }
        ERG_SEEN[m] = 1u8
        c = c + 1u64
    }
    let mut k : u64 = 11u64
    while k <= 19u64 {
        let m1 : u64 = erg_mapcode(1u64, k, mode)
        if ERG_SEEN[m1] == 1u8 { return 0u64 }
        ERG_SEEN[m1] = 1u8
        k = k + 1u64
    }
    let mut s : u64 = 41u64
    while s <= 45u64 {
        let m2 : u64 = erg_mapcode(2u64, s, mode)
        if ERG_SEEN[m2] == 1u8 { return 0u64 }
        ERG_SEEN[m2] = 1u8
        s = s + 1u64
    }
    let mut d : u64 = 21u64
    while d <= 36u64 {
        let m3 : u64 = erg_mapcode(3u64, d, mode)
        if ERG_SEEN[m3] == 1u8 { return 0u64 }
        ERG_SEEN[m3] = 1u8
        d = d + 1u64
    }
    let mut q : u64 = 1u64
    while q <= 6u64 {
        let m4 : u64 = erg_mapcode(4u64, q, mode)
        if ERG_SEEN[m4] == 1u8 { return 0u64 }
        ERG_SEEN[m4] = 1u8
        q = q + 1u64
    }
    let mut z : u64 = 1u64
    while z <= 3u64 {
        let m5 : u64 = erg_mapcode(5u64, z, mode)
        if ERG_SEEN[m5] == 1u8 { return 0u64 }
        ERG_SEEN[m5] = 1u8
        z = z + 1u64
    }
    return 1u64
}

/* ==================== THE SELF-PROOF (condition of motion) ====================
 * Cheap, synthetic, with teeth -- no verb runs over a broken instrument.
 * 0 = proven | the arm number (71..72). */
fn erg_selfprove() -> u64 @export {
    /* arm 71: the fault map is injective -- and the CHECKER has teeth (a
     * sabotaged map that collides seat 1 into seat 0's range MUST be caught) */
    if erg_map_injective(0u64) != 1u64 { return 71u64 }
    if erg_map_injective(1u64) != 0u64 { return 71u64 }
    /* arm 72: the fold instrument the cross-check leans on -- deterministic,
     * input-sensitive (one flipped bit anywhere moves the seal) */
    let mut h1 : u64 = idfold_basis()
    h1 = idfold_u64(h1, 12345u64)
    h1 = idfold_u64(h1, 67890u64)
    let s1 : u64 = idfold_seal(h1)
    let mut h2 : u64 = idfold_basis()
    h2 = idfold_u64(h2, 12345u64)
    h2 = idfold_u64(h2, 67890u64)
    if idfold_seal(h2) != s1 { return 72u64 }
    let mut h3 : u64 = idfold_basis()
    h3 = idfold_u64(h3, 12345u64 ^ 1u64)
    h3 = idfold_u64(h3, 67890u64)
    if idfold_seal(h3) == s1 { return 72u64 }
    return 0u64
}

/* ==================== SEAT 0: INTROSPECTION + the examiner-of-the-examiner ==== */
fn erg_seat_intro() -> u32 @export {
    ERG_VIT = 0u64
    let v : u64 = intro_vitality()
    if v == 0u64 {
        let c : u32 = intro_examine_all()
        if c != 0u32 { return c }
        return ERG_META_ANOMALY
    }
    /* re-fold the vitality root with ergon's OWN loop; refuse a fold the
     * examiner cannot reproduce -- and prove the refusal is load-bearing */
    let mut h : u64 = idfold_basis()
    let mut i : u32 = 0u32
    while i < intro_organ_count() { h = idfold_u64(h, intro_organ_ident(i))   i = i + 1u32 }
    if idfold_seal(h) != v { return ERG_META_XFOLD }
    let mut hp : u64 = idfold_basis()
    hp = idfold_u64(hp, intro_organ_ident(0u32) ^ 1u64)
    let mut j : u32 = 1u32
    while j < intro_organ_count() { hp = idfold_u64(hp, intro_organ_ident(j))   j = j + 1u32 }
    if idfold_seal(hp) == v { return ERG_META_XFOLD }
    ERG_VIT = v
    return 0u32
}

/* ==================== SEAT 1..3: the standing organs' own arms ==================== */
var ERG_G : [u8; 8]
fn erg_seat_kardia() -> u32 @export {
    /* garbage teeth first: a malformed ledger line MUST fold to nothing */
    ERG_G[0u64] = 88u8   ERG_G[1u64] = 88u8   ERG_G[2u64] = 88u8   ERG_G[3u64] = 88u8
    if kd_fold_line((&ERG_G) as u64, 4u64) != 0u64 { return ERG_META_GARBAGE }
    let a : u64 = kd_selfprove()
    if a != 0u64 { return (600u64 + a) as u32 }
    return 0u32
}
fn erg_seat_soma() -> u32 @export {
    let a : u64 = soma_selfprove()
    if a != 0u64 { return (700u64 + a) as u32 }
    return 0u32
}
fn erg_seat_doxa() -> u32 @export {
    let a : u64 = dx_selfprove()
    if a != 0u64 { return (800u64 + a) as u32 }
    return 0u32
}

/* ==================== SEAT 4: THE ABSORBED FAMILY (iscene) ====================
 * The laws of gate 2200_iscene, re-derived live -- stored pin REMOVED.
 * Returns 0 | 1 DET | 2 RES | 3 SIZE | 4 RT | 5 BIND | 6 PX/SETTERS. */
var ERG_FBRD : [u32; 12288]
fn erg_scene_build() -> i32 {
    iscene_reset()
    iscene_add(0i64 - 30i64, 20i64,        340i64, 7225i64, 235i64, 150i64, 70i64)
    iscene_add(55i64,        0i64 - 4i64,  250i64, 3600i64, 80i64,  175i64, 225i64)
    iscene_add(0i64 - 82i64, 0i64 - 60i64, 205i64, 2025i64, 120i64, 220i64, 110i64)
    return 0i32
}
fn erg_arm_iscene() -> u64 {
    /* DET: the render is a function -- twice at 128x96, identical and nonzero.
     * NO stored pin: the law is determinism, not one renderer's frozen bytes. */
    erg_scene_build()
    iscene_render(128u64, 96u64)
    let d1 : u64 = iscene_sig(128u64, 96u64)
    iscene_render(128u64, 96u64)
    let d2 : u64 = iscene_sig(128u64, 96u64)
    if d1 != d2 { return 1u64 }
    if d1 == 0u64 { return 1u64 }
    /* RES: the SAME master renders deterministic, pairwise-DISTINCT frames at
     * three resolutions -- one tiny file, arbitrarily many exact rasters */
    iscene_render(96u64, 72u64)
    let ra1 : u64 = iscene_sig(96u64, 72u64)
    iscene_render(96u64, 72u64)
    let ra2 : u64 = iscene_sig(96u64, 72u64)
    iscene_render(192u64, 144u64)
    let rc1 : u64 = iscene_sig(192u64, 144u64)
    iscene_render(192u64, 144u64)
    let rc2 : u64 = iscene_sig(192u64, 144u64)
    if ra1 != ra2 { return 2u64 }
    if rc1 != rc2 { return 2u64 }
    if ra1 == 0u64 { return 2u64 }
    if rc1 == 0u64 { return 2u64 }
    if ra1 == d1 { return 2u64 }
    if rc1 == d1 { return 2u64 }
    if ra1 == rc1 { return 2u64 }
    /* SIZE: the master is O(objects) by the format's own equation, resolution-
     * free -- the LIVE object count enters the law, no literal enthroned */
    let n : i64 = iscene_count()
    if n != 3i64 { return 3u64 }
    let fb : u64 = iscene_file_bytes()
    if fb != (56u64 + (n as u64) * 56u64) { return 3u64 }
    if fb >= 1024u64 { return 3u64 }
    /* RT: write the master, WIPE the scene, read it back -- the scene signature
     * and the 128x96 render both survive the trip exactly */
    let ss0 : u64 = iscene_scene_sig()
    if iscene_write("STDLIB/build/ergon_census.isc" as u64) != 0i32 { return 4u64 }
    iscene_reset()
    if iscene_count() != 0i64 { return 4u64 }
    let rc : i64 = iscene_read("STDLIB/build/ergon_census.isc" as u64)
    if rc != 3i64 { return 4u64 }
    if iscene_scene_sig() != ss0 { return 4u64 }
    iscene_render(128u64, 96u64)
    if iscene_sig(128u64, 96u64) != d1 { return 4u64 }
    /* BIND: project to .ixr bound to the scene signature; the pixel file
     * recovers the binding AND the pixels bit-for-bit */
    let ss : u64 = iscene_scene_sig()
    iscene_render(128u64, 96u64)
    if iform_write_bound(iscene_fb_addr(), 128u32, 96u32, ss, "STDLIB/build/ergon_census.ixr" as u64) != 0i32 { return 5u64 }
    let rr : i64 = iform_read("STDLIB/build/ergon_census.ixr" as u64, (&ERG_FBRD) as u64, 12288u64)
    if rr < 0i64 { return 5u64 }
    if iform_last_bind() != ss { return 5u64 }
    let fba : u64 = iscene_fb_addr()
    let mut diff : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 12288u64 {
        let p : *u32 = (fba + i * 4u64) as *u32
        if p[0u64] != ERG_FBRD[i] { diff = diff + 1u64 }
        i = i + 1u64
    }
    if diff != 0u64 { return 5u64 }
    /* PX + SETTERS (the teeth): the pixel read-head agrees with the live
     * framebuffer, and focal/light are LOAD-BEARING -- changing either MUST
     * change the image; restoring MUST reproduce it.  A renderer that stops
     * feeling its inputs cannot pass, so the arm can never go vacuous. */
    erg_scene_build()
    iscene_render(128u64, 96u64)
    let base : u64 = iscene_sig(128u64, 96u64)
    if base != d1 { return 6u64 }
    let fbp : u64 = iscene_fb_addr()
    let pc : *u32 = (fbp + (48u64 * 128u64 + 64u64) * 4u64) as *u32
    if iscene_px(64u64, 48u64, 128u64) != pc[0u64] { return 6u64 }
    let po : *u32 = fbp as *u32
    if iscene_px(0u64, 0u64, 128u64) != po[0u64] { return 6u64 }
    iscene_set_focal(140i64)
    iscene_render(128u64, 96u64)
    if iscene_sig(128u64, 96u64) == base { return 6u64 }
    erg_scene_build()
    iscene_render(128u64, 96u64)
    if iscene_sig(128u64, 96u64) != base { return 6u64 }
    iscene_set_light(200i64, 0i64 - 200i64, 60i64)
    iscene_render(128u64, 96u64)
    if iscene_sig(128u64, 96u64) == base { return 6u64 }
    iscene_reset()
    return 0u64
}
fn erg_seat_iscene() -> u32 @export {
    let a : u64 = erg_arm_iscene()
    if a != 0u64 { return (900u64 + a) as u32 }
    return 0u32
}

/* ==================== THE CENSUS: the fleet works, therefore it is ==================== */
fn erg_census() -> u32 @export {
    let sp : u64 = erg_selfprove()
    if sp != 0u64 { return (1000u64 + sp) as u32 }     /* 1071/1072: own instrument broken */
    let s0 : u32 = erg_seat_intro()
    if s0 != 0u32 { return s0 }
    let s1 : u32 = erg_seat_kardia()
    if s1 != 0u32 { return s1 }
    let s2 : u32 = erg_seat_soma()
    if s2 != 0u32 { return s2 }
    let s3 : u32 = erg_seat_doxa()
    if s3 != 0u32 { return s3 }
    let s4 : u32 = erg_seat_iscene()
    if s4 != 0u32 { return s4 }
    return 0u32
}

/* the ledger's runner count (the ancestral fleet still on the die) */
fn erg_ledger_runners() -> u64 @export {
    return soma_survey_runners("STDLIB/scripts" as u64)
}
