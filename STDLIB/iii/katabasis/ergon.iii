/* ==================== THE AUTARKEIA VERB: the sealed spine + the covenant ====
 * (ex run_testament + run_covenant) -- the machinery that makes III's testament
 * a self-verifying fact.  The tool FACES (keygen determinism, malformed refusal)
 * live in the exec seat; here is the heavy MACHINERY: emit a generation-0
 * testament over the LIVE committed tree (SLH-DSA-signed), re-derive it against
 * the tree, the full TAMPER BATTERY (each class its DISTINCT refusal), the
 * generation CHAIN, and THE COVENANT EQUATION -- the host- and generation-
 * invariant core is a pure function of committed truth, co-signed by a live
 * ML-DSA 3-of-3 quorum.  No stored answer anywhere: the frozen RADICAL/FORGE
 * hex pins of the retired runner are SUBSUMED by the full re-derivation (witness
 * verify against the tree re-walks every record from committed bytes).  Minutes
 * of wall (three SLH-DSA signings) -- on demand, never census-weight.
 * Codes 1500+arm. */
var ERG_CORE : [u8; 65536]                 /* the host-invariant core lines       */
var ERG_RA : [u8; 96]                      /* fold root of core(gen0)             */
var ERG_RB : [u8; 96]                      /* fold root of core(gen0b)            */
var ERG_R1 : [u8; 96]                      /* fold root of core(gen1)             */
var ERG_CBUF : [u8; 512]
/* does the captured stdout line starting at `s` (length to first \n) begin with
 * one of the host-invariant tags?  TREE/SEED/BEARER/RECORD/CERT, each + space */
fn erg_a_at(i: u64) -> u8 { return proc_out_at(i) }
fn erg_line_is_core(s: u64, n: u64) -> u64 {
    if s + 5u64 > n { return 0u64 }
    /* "TREE " */
    if erg_a_at(s) == 84u8 { if erg_a_at(s+1u64) == 82u8 { if erg_a_at(s+2u64) == 69u8 { if erg_a_at(s+3u64) == 69u8 { if erg_a_at(s+4u64) == 32u8 { return 1u64 } } } } }
    /* "SEED " */
    if erg_a_at(s) == 83u8 { if erg_a_at(s+1u64) == 69u8 { if erg_a_at(s+2u64) == 69u8 { if erg_a_at(s+3u64) == 68u8 { if erg_a_at(s+4u64) == 32u8 { return 1u64 } } } } }
    /* "CERT " */
    if erg_a_at(s) == 67u8 { if erg_a_at(s+1u64) == 69u8 { if erg_a_at(s+2u64) == 82u8 { if erg_a_at(s+3u64) == 84u8 { if erg_a_at(s+4u64) == 32u8 { return 1u64 } } } } }
    /* "BEARER " */
    if s + 7u64 <= n { if erg_a_at(s) == 66u8 { if erg_a_at(s+1u64) == 69u8 { if erg_a_at(s+2u64) == 65u8 { if erg_a_at(s+3u64) == 82u8 { if erg_a_at(s+4u64) == 69u8 { if erg_a_at(s+5u64) == 82u8 { if erg_a_at(s+6u64) == 32u8 { return 1u64 } } } } } } } }
    /* "RECORD " */
    if s + 7u64 <= n { if erg_a_at(s) == 82u8 { if erg_a_at(s+1u64) == 69u8 { if erg_a_at(s+2u64) == 67u8 { if erg_a_at(s+3u64) == 79u8 { if erg_a_at(s+4u64) == 82u8 { if erg_a_at(s+5u64) == 68u8 { if erg_a_at(s+6u64) == 32u8 { return 1u64 } } } } } } } }
    return 0u64
}
/* run `iii-testament show DAT`, write the host-invariant lines to CORE_PATH,
 * return the count (0 on failure) */
fn erg_show_core(dat: u64, core_path: u64) -> u64 {
    let cp : *u8 = (&ERG_XB) as u64 as *u8
    let mut a : u64 = erg_x_sput(0u64, "COMPILED\\iii-testament.exe show " as u64)
    a = erg_x_sput(a, dat)
    if erg_x_run((&ERG_XB) as u64, 120000u32) != 0u64 { return 0u64 }
    let n : u64 = proc_out_len()
    let dst : *u8 = (&ERG_CORE) as u64 as *u8
    let mut w : u64 = 0u64
    let mut cnt : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n {
        let ls : u64 = i
        let mut le : u64 = i
        let mut go : u64 = 1u64
        while go == 1u64 { if le >= n { go = 0u64 } else { if proc_out_at(le) == 10u8 { go = 0u64 } else { le = le + 1u64 } } }
        if erg_line_is_core(ls, n) == 1u64 {
            let mut j : u64 = ls
            while j < le { if w < 65535u64 { dst[w] = proc_out_at(j)   w = w + 1u64 }   j = j + 1u64 }
            if w < 65535u64 { dst[w] = 10u8   w = w + 1u64 }
            cnt = cnt + 1u64
        }
        i = le + 1u64
    }
    if erg_x_putn(core_path, (&ERG_CORE) as u64, w) != 1u64 { return 0u64 }
    return cnt
}
/* run `iii-judge fold CORE`, copy the hex after "root=" into dst, return len */
fn erg_fold_root(core_path: u64, dst: u64) -> u64 {
    let mut a : u64 = erg_x_sput(0u64, "COMPILED\\iii-judge.exe fold " as u64)
    a = erg_x_sput(a, core_path)
    if erg_x_run((&ERG_XB) as u64, 60000u32) != 0u64 { return 0u64 }
    /* find "root=" in captured stdout, copy trailing [0-9a-f] into dst */
    let n : u64 = proc_out_len()
    let dp : *u8 = dst as *u8
    let mut i : u64 = 0u64
    while i + 5u64 <= n {
        if proc_out_at(i) == 114u8 { if proc_out_at(i+1u64) == 111u8 { if proc_out_at(i+2u64) == 111u8 { if proc_out_at(i+3u64) == 116u8 { if proc_out_at(i+4u64) == 61u8 {
            let mut j : u64 = i + 5u64
            let mut w : u64 = 0u64
            let mut go : u64 = 1u64
            while go == 1u64 {
                if j >= n { go = 0u64 } else {
                    let c : u8 = proc_out_at(j)
                    let ishex : u64 = erg_ishex(c)
                    if ishex == 1u64 { if w < 95u64 { dp[w] = c   w = w + 1u64 }   j = j + 1u64 } else { go = 0u64 }
                }
            }
            return w
        } } } } }
        i = i + 1u64
    }
    return 0u64
}
fn erg_ishex(c: u8) -> u64 {
    if c >= 48u8 { if c <= 57u8 { return 1u64 } }
    if c >= 97u8 { if c <= 102u8 { return 1u64 } }
    return 0u64
}
fn erg_buf_eq(a: u64, alen: u64, b: u64, blen: u64) -> u64 {
    if alen != blen { return 0u64 }
    if alen == 0u64 { return 0u64 }
    let pa : *u8 = a as *u8
    let pb : *u8 = b as *u8
    let mut i : u64 = 0u64
    while i < alen { if pa[i] != pb[i] { return 0u64 }   i = i + 1u64 }
    return 1u64
}
fn erg_autarkeia() -> u32 @export {
    /* arm 1: the manifest over the committed tree.  git ls-files output is
     * byte-identical to `LC_ALL=C sort -u` (git's index is byte-sorted), so no
     * shell/sort is needed -- git.exe is spawned directly, its stdout redirected
     * by cmd.  The whole manifest is read into ERG_MAN once (the tamper arms
     * derive their variants from it in-organ, no sed/grep dependency). */
    erg_x_run("cmd /c if not exist STDLIB\\build\\ergon_autk mkdir STDLIB\\build\\ergon_autk" as u64, 30000u32)
    if erg_x_run("cmd /c git ls-files -- COMPILER/BOOT/*.iii COMPILER/BOOT/*.c COMPILER/BOOT/*.h COMPILER/BOOT/*.sh STDLIB/iii/**/*.iii STDLIB/sovir/*.iii STDLIB/sovir/*.sh STDLIB/corpus/*.iii STDLIB/scripts/*.sh DOCS/*.md DOCS/*.log DOCS/*.txt > STDLIB\\build\\ergon_autk\\MANIFEST.txt" as u64, 120000u32) != 0u64 { return 1501u32 }
    if erg_read_manifest("STDLIB/build/ergon_autk/MANIFEST.txt" as u64) == 0u64 { return 1501u32 }
    if erg_man_lines() < 100u64 { return 1501u32 }
    /* arm 2: an SLH-DSA keypair -- deterministic seed, generated to 96 bytes */
    let mut sdi : u64 = 0u64
    while sdi < 96u64 { ERG_SEED[sdi] = (65u64 + (sdi * 11u64 + 5u64) % 26u64) as u8   sdi = sdi + 1u64 }
    if erg_x_putn("STDLIB/build/ergon_autk/seed.bin" as u64, (&ERG_SEED) as u64, 96u64) != 1u64 { return 1502u32 }
    if erg_x_run("COMPILED\\iii-testament.exe keygen STDLIB/build/ergon_autk/seed.bin STDLIB/build/ergon_autk/pk.bin STDLIB/build/ergon_autk/sk.bin" as u64, 180000u32) != 0u64 { return 1502u32 }
    /* arm 3: emit gen0, gen0b (same args -> determinism), gen1 (chained) */
    if erg_x_run("COMPILED\\iii-testament.exe emit . STDLIB/build/ergon_autk/MANIFEST.txt STDLIB/build/ergon_autk/sk.bin STDLIB/build/ergon_autk/pk.bin STDLIB/build/ergon_autk/gen0.dat none none" as u64, 300000u32) != 0u64 { return 1503u32 }
    if erg_x_run("COMPILED\\iii-testament.exe emit . STDLIB/build/ergon_autk/MANIFEST.txt STDLIB/build/ergon_autk/sk.bin STDLIB/build/ergon_autk/pk.bin STDLIB/build/ergon_autk/gen0b.dat none none" as u64, 300000u32) != 0u64 { return 1503u32 }
    if erg_x_run("COMPILED\\iii-testament.exe emit . STDLIB/build/ergon_autk/MANIFEST.txt STDLIB/build/ergon_autk/sk.bin STDLIB/build/ergon_autk/pk.bin STDLIB/build/ergon_autk/gen1.dat STDLIB/build/ergon_autk/gen0.dat none" as u64, 300000u32) != 0u64 { return 1503u32 }
    /* arm 4: tier-1 (no tree) + full re-derivation (re-walks every record from
     * committed bytes -- this SUBSUMES the retired runner's frozen RADICAL/FORGE
     * hex pins; a drifted record reddens here without any stored hex) */
    if erg_x_run("COMPILED\\iii-witness.exe verify STDLIB/build/ergon_autk/gen0.dat STDLIB/build/ergon_autk/pk.bin" as u64, 120000u32) != 0u64 { return 1504u32 }
    if erg_x_run("COMPILED\\iii-witness.exe verify STDLIB/build/ergon_autk/gen0.dat STDLIB/build/ergon_autk/pk.bin none . STDLIB/build/ergon_autk/MANIFEST.txt" as u64, 180000u32) != 0u64 { return 1504u32 }
    /* arm 5: THE TAMPER BATTERY -- each class its DISTINCT refusal.
     * body-byte(11): flip a byte inside gen0 on disk */
    erg_x_run("cmd /c copy /y STDLIB\\build\\ergon_autk\\gen0.dat STDLIB\\build\\ergon_autk\\tA.dat >nul" as u64, 30000u32)
    if erg_flip_byte("STDLIB/build/ergon_autk/tA.dat" as u64, 200u64) != 1u64 { return 1505u32 }
    if erg_x_run("COMPILED\\iii-witness.exe verify STDLIB/build/ergon_autk/tA.dat STDLIB/build/ergon_autk/pk.bin" as u64, 120000u32) != 11u64 { return 1505u32 }
    /* wrong-key(11): a fresh public key */
    let mut wk : u64 = 0u64
    while wk < 96u64 { ERG_SEED[wk] = (90u64 - (wk * 13u64 + 1u64) % 26u64) as u8   wk = wk + 1u64 }
    erg_x_putn("STDLIB/build/ergon_autk/seed3.bin" as u64, (&ERG_SEED) as u64, 96u64)
    erg_x_run("COMPILED\\iii-testament.exe keygen STDLIB/build/ergon_autk/seed3.bin STDLIB/build/ergon_autk/wpk.bin STDLIB/build/ergon_autk/wsk.bin" as u64, 180000u32)
    if erg_x_run("COMPILED\\iii-witness.exe verify STDLIB/build/ergon_autk/gen0.dat STDLIB/build/ergon_autk/wpk.bin" as u64, 120000u32) != 11u64 { return 1505u32 }
    /* manifest(14): drop the first line -- derived in-organ from ERG_MAN */
    if erg_man_write_skip_first("STDLIB/build/ergon_autk/man_tam.txt" as u64) != 1u64 { return 1505u32 }
    if erg_x_run("COMPILED\\iii-witness.exe verify STDLIB/build/ergon_autk/gen0.dat STDLIB/build/ergon_autk/pk.bin none . STDLIB/build/ergon_autk/man_tam.txt" as u64, 180000u32) != 14u64 { return 1505u32 }
    /* file-content(14): back up a real committed source, append a byte, verify
     * MUST catch it against the tree, restore, and re-verify green (the restore
     * self-checks -- a corrupted restore reddens the re-verify) */
    erg_x_run("cmd /c copy /y STDLIB\\corpus\\2600_mathesis_admit.iii STDLIB\\build\\ergon_autk\\cf.bak >nul" as u64, 30000u32)
    erg_x_run("cmd /c echo.>> STDLIB\\corpus\\2600_mathesis_admit.iii" as u64, 30000u32)
    let ft : u64 = erg_x_run("COMPILED\\iii-witness.exe verify STDLIB/build/ergon_autk/gen0.dat STDLIB/build/ergon_autk/pk.bin none . STDLIB/build/ergon_autk/MANIFEST.txt" as u64, 180000u32)
    erg_x_run("cmd /c copy /y STDLIB\\build\\ergon_autk\\cf.bak STDLIB\\corpus\\2600_mathesis_admit.iii >nul" as u64, 30000u32)
    if ft != 14u64 { return 1505u32 }
    if erg_x_run("COMPILED\\iii-witness.exe verify STDLIB/build/ergon_autk/gen0.dat STDLIB/build/ergon_autk/pk.bin none . STDLIB/build/ergon_autk/MANIFEST.txt" as u64, 180000u32) != 0u64 { return 1505u32 }
    /* arm 6: determinism -- gen0 and gen0b (identical args, unchanged tree) are
     * BYTE-IDENTICAL, signature included (FIPS-205 deterministic signing) */
    if erg_x_run("cmd /c fc /b STDLIB\\build\\ergon_autk\\gen0.dat STDLIB\\build\\ergon_autk\\gen0b.dat >nul" as u64, 30000u32) != 0u64 { return 1506u32 }
    /* arm 7: the generation CHAIN -- gen1 verifies with its parent (0); a
     * testament may not be its own parent (12); a swapped keypair breaks
     * continuity at emit (15); dropping one KAT breaks the monotone law (15) */
    if erg_x_run("COMPILED\\iii-witness.exe verify STDLIB/build/ergon_autk/gen1.dat STDLIB/build/ergon_autk/pk.bin STDLIB/build/ergon_autk/gen0.dat" as u64, 120000u32) != 0u64 { return 1507u32 }
    if erg_x_run("COMPILED\\iii-witness.exe verify STDLIB/build/ergon_autk/gen1.dat STDLIB/build/ergon_autk/pk.bin STDLIB/build/ergon_autk/gen1.dat" as u64, 120000u32) != 12u64 { return 1507u32 }
    if erg_x_run("COMPILED\\iii-testament.exe emit . STDLIB/build/ergon_autk/MANIFEST.txt STDLIB/build/ergon_autk/wsk.bin STDLIB/build/ergon_autk/wpk.bin STDLIB/build/ergon_autk/gen1bad.dat STDLIB/build/ergon_autk/gen0.dat none" as u64, 300000u32) != 15u64 { return 1507u32 }
    if erg_man_write_skip_line("STDLIB/build/ergon_autk/man_small.txt" as u64, "STDLIB/corpus/2600_mathesis_admit.iii" as u64) != 1u64 { return 1507u32 }
    if erg_x_run("COMPILED\\iii-testament.exe emit . STDLIB/build/ergon_autk/man_small.txt STDLIB/build/ergon_autk/sk.bin STDLIB/build/ergon_autk/pk.bin STDLIB/build/ergon_autk/gen1small.dat STDLIB/build/ergon_autk/gen0.dat none" as u64, 300000u32) != 15u64 { return 1507u32 }
    /* arm 8: THE COVENANT EQUATION -- core(T) = the judge-fold of the host- and
     * generation-invariant show lines.  core(gen0)==core(gen0b) [determinism]
     * AND core(gen1)==core(gen0) [GENERATION-INVARIANT, the non-trivial law:
     * gen1 differs in generation/parent yet folds to the same core] AND the
     * generation actually ADVANCED (else the invariance is vacuous) */
    if erg_show_core("STDLIB/build/ergon_autk/gen0.dat" as u64, "STDLIB/build/ergon_autk/coreA.txt" as u64) < 5u64 { return 1508u32 }
    let la : u64 = erg_fold_root("STDLIB/build/ergon_autk/coreA.txt" as u64, (&ERG_RA) as u64)
    if la == 0u64 { return 1508u32 }
    if erg_show_core("STDLIB/build/ergon_autk/gen0b.dat" as u64, "STDLIB/build/ergon_autk/coreB.txt" as u64) < 5u64 { return 1508u32 }
    let lb : u64 = erg_fold_root("STDLIB/build/ergon_autk/coreB.txt" as u64, (&ERG_RB) as u64)
    if erg_show_core("STDLIB/build/ergon_autk/gen1.dat" as u64, "STDLIB/build/ergon_autk/core1.txt" as u64) < 5u64 { return 1508u32 }
    let l1 : u64 = erg_fold_root("STDLIB/build/ergon_autk/core1.txt" as u64, (&ERG_R1) as u64)
    if erg_buf_eq((&ERG_RA) as u64, la, (&ERG_RB) as u64, lb) != 1u64 { return 1508u32 }
    if erg_buf_eq((&ERG_RA) as u64, la, (&ERG_R1) as u64, l1) != 1u64 { return 1508u32 }
    /* generation advanced: gen0 and gen1 show DIFFERENT generation lines */
    erg_x_run("COMPILED\\iii-testament.exe show STDLIB/build/ergon_autk/gen0.dat" as u64, 120000u32)
    let g0 : u64 = erg_x_parse_after("generation " as u64)
    erg_x_run("COMPILED\\iii-testament.exe show STDLIB/build/ergon_autk/gen1.dat" as u64, 120000u32)
    let g1 : u64 = erg_x_parse_after("generation " as u64)
    if g0 == g1 { return 1508u32 }
    /* arm 9: FED -- a live ML-DSA (FIPS 204) 3-of-3 quorum co-signs the core;
     * a tampered core is co-signed by NONE (adversarial) */
    if erg_x_putn("STDLIB/build/ergon_autk/core.bin" as u64, (&ERG_RA) as u64, la) != 1u64 { return 1509u32 }
    let dp : *u8 = (&ERG_RA) as u64 as *u8
    dp[la] = 48u8   dp[la + 1u64] = 48u8
    erg_x_putn("STDLIB/build/ergon_autk/core_bad.bin" as u64, (&ERG_RA) as u64, la + 2u64)
    let mut q : u64 = 0u64
    let mut qb : u64 = 0u64
    let mut k : u64 = 1u64
    while k <= 3u64 {
        let mut sd : u64 = 0u64
        while sd < 32u64 { ERG_SEED[sd] = (70u64 + (sd * 7u64 + k * 3u64) % 26u64) as u8   sd = sd + 1u64 }
        let mut sp : u64 = erg_x_sput(0u64, "STDLIB/build/ergon_autk/fed_seed_" as u64)
        sp = erg_x_sput(sp, erg_k_str(k))
        let spath : u64 = erg_dup_xb()
        erg_x_putn(spath, (&ERG_SEED) as u64, 32u64)
        /* keygen / sign / verify the good core */
        if erg_fed_cycle(k, "STDLIB/build/ergon_autk/core.bin" as u64) == 0u64 { q = q + 1u64 }
        if erg_fed_verify(k, "STDLIB/build/ergon_autk/core_bad.bin" as u64) == 0u64 { qb = qb + 1u64 }
        k = k + 1u64
    }
    if q != 3u64 { return 1509u32 }
    if qb != 0u64 { return 1509u32 }
    /* arm 10: the MONOTONE ratchet via iii-judge pin -- gen 0->1 up accepted, a
     * regression to 0 REFUSED (a generation may never go backward) */
    erg_x_run("cmd /c del /q STDLIB\\build\\ergon_autk\\gen_led.txt" as u64, 30000u32)
    if erg_x_run("COMPILED\\iii-judge.exe pin STDLIB/build/ergon_autk/gen_led.txt generation 0 up" as u64, 60000u32) != 0u64 { return 1510u32 }
    if erg_x_run("COMPILED\\iii-judge.exe pin STDLIB/build/ergon_autk/gen_led.txt generation 1 up" as u64, 60000u32) != 0u64 { return 1510u32 }
    if erg_x_run("COMPILED\\iii-judge.exe pin STDLIB/build/ergon_autk/gen_led.txt generation 0 up" as u64, 60000u32) != 1u64 { return 1510u32 }
    return 0u32
}
/* ==================== THE ZK-AUDIT VERB (ex run_zk_audit) ====================
 * Every zk gadget's CLAIMED soundness bit-count must match its query/field
 * KNOBS.  A ~2^-86 production claim demands a 128-FS-query basis (NQPB*NBATCH
 * >= 128, or an explicit "128 queries"/"128 FS" line) AND the declared field
 * marker; an xref module's every claim must NAME another zk_ module; an
 * unlisted module may carry NO claim.  The manifest (the classification) is the
 * audit's ground truth, embedded here -- NOT a stored test answer: it says which
 * knobs a claim is allowed to rest on, and the file's own knobs must satisfy it.
 * TEETH (both directions, on perturbed COPIES -- the live tree is never touched):
 * downscaling a production gadget's NBATCH must REDDEN (knob < claim); adding a
 * claim to an unlisted module must REDDEN (unclassified claim).  Organ-native:
 * cmd lists the files, the files are read + matched in-organ (findstr/grep never
 * resolve via CreateProcessA anyway).  Codes 1600+arm. */
var ERG_ZKF : [u8; 262144]                 /* one zk file's bytes                 */
var ERG_ZKF_LEN : u64 = 0u64
var ERG_ZK_SCANNED : u64 = 0u64
var ERG_ZK_CLAIMERS : u64 = 0u64
var ERG_ZK_VIOL : u64 = 0u64
fn erg_zk_scanned() -> u64 @export { return ERG_ZK_SCANNED }
fn erg_zk_claimers() -> u64 @export { return ERG_ZK_CLAIMERS }
fn erg_zk_violations() -> u64 @export { return ERG_ZK_VIOL }
/* substring search in ERG_ZKF[0..len): count occurrences of (pat,plen) */
fn erg_zk_count(pat: u64, plen: u64) -> u64 {
    let f : *u8 = (&ERG_ZKF) as u64 as *u8
    let p : *u8 = pat as *u8
    let mut c : u64 = 0u64
    let mut i : u64 = 0u64
    while i + plen <= ERG_ZKF_LEN {
        let mut j : u64 = 0u64
        let mut hit : u64 = 1u64
        while j < plen { if f[i + j] != p[j] { hit = 0u64   j = plen } else { j = j + 1u64 } }
        if hit == 1u64 { c = c + 1u64   i = i + plen } else { i = i + 1u64 }
    }
    return c
}
fn erg_zk_has(pat: u64) -> u64 {
    let p : *u8 = pat as *u8
    let mut n : u64 = 0u64
    while p[n] != 0u8 { n = n + 1u64 }
    if erg_zk_count(pat, n) > 0u64 { return 1u64 }
    return 0u64
}
/* find "const NAME" then the first decimal after '=' on that construct */
fn erg_zk_const(name: u64) -> u64 {
    let f : *u8 = (&ERG_ZKF) as u64 as *u8
    let p : *u8 = name as *u8
    let mut nlen : u64 = 0u64
    while p[nlen] != 0u8 { nlen = nlen + 1u64 }
    let mut i : u64 = 0u64
    while i + nlen <= ERG_ZKF_LEN {
        let mut j : u64 = 0u64
        let mut hit : u64 = 1u64
        while j < nlen { if f[i + j] != p[j] { hit = 0u64   j = nlen } else { j = j + 1u64 } }
        if hit == 1u64 {
            /* scan to '=' */
            let mut k : u64 = i + nlen
            let mut go : u64 = 1u64
            while go == 1u64 { if k >= ERG_ZKF_LEN { go = 0u64 } else { if f[k] == 61u8 { go = 0u64 } else { k = k + 1u64 } } }
            if k >= ERG_ZKF_LEN { return 0u64 }
            k = k + 1u64
            /* skip spaces to the first digit */
            let mut sp2 : u64 = 1u64
            while sp2 == 1u64 { if k >= ERG_ZKF_LEN { sp2 = 0u64 } else { if f[k] == 32u8 { k = k + 1u64 } else { sp2 = 0u64 } } }
            let mut v : u64 = 0u64
            let mut got : u64 = 0u64
            let mut dg : u64 = 1u64
            while dg == 1u64 {
                if k >= ERG_ZKF_LEN { dg = 0u64 } else {
                    if f[k] >= 48u8 { if f[k] <= 57u8 { v = v * 10u64 + ((f[k] - 48u8) as u64)   got = 1u64   k = k + 1u64 } else { dg = 0u64 } } else { dg = 0u64 }
                }
            }
            if got == 1u64 { return v }
            return 0u64
        }
        i = i + 1u64
    }
    return 0u64
}
/* every "2^-86" line names a zk_ token?  1 clean | 0 a bare self-claim exists */
fn erg_zk_xref_ok() -> u64 {
    let f : *u8 = (&ERG_ZKF) as u64 as *u8
    let mut i : u64 = 0u64
    while i < ERG_ZKF_LEN {
        let ls : u64 = i
        let mut le : u64 = i
        let mut go : u64 = 1u64
        while go == 1u64 { if le >= ERG_ZKF_LEN { go = 0u64 } else { if f[le] == 10u8 { go = 0u64 } else { le = le + 1u64 } } }
        /* does this line contain "2^-86"? */
        let mut hasclaim : u64 = 0u64
        let mut a : u64 = ls
        while a + 5u64 <= le { if f[a]==50u8 { if f[a+1u64]==94u8 { if f[a+2u64]==45u8 { if f[a+3u64]==56u8 { if f[a+4u64]==54u8 { hasclaim = 1u64   a = le } } } } }   a = a + 1u64 }
        if hasclaim == 1u64 {
            /* must contain "zk_" somewhere on the line */
            let mut haszk : u64 = 0u64
            let mut b : u64 = ls
            while b + 3u64 <= le { if f[b]==122u8 { if f[b+1u64]==107u8 { if f[b+2u64]==95u8 { haszk = 1u64   b = le } } }   b = b + 1u64 }
            if haszk == 0u64 { return 0u64 }
        }
        i = le + 1u64
    }
    return 1u64
}
/* classify a basename: 0 unlisted | 1 prod128/GF(p^4) | 2 prod128/(5/8)^128 |
 * 3 prod128/zk_ext2_fri256 | 4 xref */
fn erg_zk_streq(nm: u64, nlen: u64, lit: u64) -> u64 {
    let p : *u8 = nm as *u8
    let q : *u8 = lit as *u8
    let mut i : u64 = 0u64
    while q[i] != 0u8 { if i >= nlen { return 0u64 }   if p[i] != q[i] { return 0u64 }   i = i + 1u64 }
    if i != nlen { return 0u64 }
    return 1u64
}
fn erg_zk_class(nm: u64, nlen: u64) -> u64 {
    if erg_zk_streq(nm, nlen, "zk_fused_committed" as u64) == 1u64 { return 1u64 }
    if erg_zk_streq(nm, nlen, "zk_fused_forge63" as u64) == 1u64 { return 1u64 }
    if erg_zk_streq(nm, nlen, "zk_here_to_there" as u64) == 1u64 { return 1u64 }
    if erg_zk_streq(nm, nlen, "zk_fused_prod" as u64) == 1u64 { return 1u64 }
    if erg_zk_streq(nm, nlen, "zk_ext4_prod" as u64) == 1u64 { return 1u64 }
    if erg_zk_streq(nm, nlen, "zk_perm_k3prod" as u64) == 1u64 { return 1u64 }
    if erg_zk_streq(nm, nlen, "zk_ext2_fri256" as u64) == 1u64 { return 2u64 }
    if erg_zk_streq(nm, nlen, "zk_ext2_prod" as u64) == 1u64 { return 3u64 }
    if erg_zk_streq(nm, nlen, "zk_ext4_stark_committed" as u64) == 1u64 { return 4u64 }
    return 0u64
}
/* read a zk file (basename, no ext) into ERG_ZKF; returns len or 0 */
fn erg_zk_read(nm: u64, nlen: u64) -> u64 {
    let pp : *u8 = (&ERG_XB) as u64 as *u8
    let mut a : u64 = erg_x_sput(0u64, "STDLIB/sovir/" as u64)
    let dp : *u8 = (&ERG_XB) as u64 as *u8
    let sp : *u8 = nm as *u8
    let mut i : u64 = 0u64
    while i < nlen { dp[a] = sp[i]   a = a + 1u64   i = i + 1u64 }
    dp[a] = 0u8
    a = erg_x_sput(a, ".iii" as u64)
    let h : u64 = CreateFileA((&ERG_XB) as u64, 2147483648u32, 1u32, 0u64, 3u32, 128u32, 0u64)
    if h == 18446744073709551615u64 { return 0u64 }
    if ReadFile(h, (&ERG_ZKF) as u64, 262144u32, (&ERG_TC) as u64, 0u64) == 0i32 { CloseHandle(h)   return 0u64 }
    CloseHandle(h)
    ERG_ZKF_LEN = ERG_TC[0u64] as u64
    return ERG_ZKF_LEN
}
/* audit the file currently in ERG_ZKF for basename (nm,nlen); returns 1 if it
 * VIOLATES (and the reason is implicit in the class), 0 if clean */
fn erg_zk_audit_loaded(nm: u64, nlen: u64) -> u64 {
    let nclaim : u64 = erg_zk_count("2^-86" as u64, 5u64)
    let cls : u64 = erg_zk_class(nm, nlen)
    if nclaim == 0u64 {
        /* a prod-classified module with no claim is a stale manifest row */
        if cls >= 1u64 { if cls <= 3u64 { return 1u64 } }
        return 0u64
    }
    if cls == 0u64 { return 1u64 }                      /* claim in an unlisted module */
    if cls == 4u64 {                                    /* xref: every claim names a zk_ */
        if erg_zk_xref_ok() == 1u64 { return 0u64 }
        return 1u64
    }
    /* prod128: a 128-query basis + the field marker.  SEMANTICS (mirroring the
     * retired runner exactly): when the NQPB/NBATCH consts EXIST, their product
     * MUST be >= 128 -- a smaller product is a definitive violation, and the
     * "128 queries" text is NOT a fallback (else a downscaled knob would hide
     * behind its own explanatory comment, and the teeth would not bite).  The
     * text basis applies ONLY when the consts are absent. */
    let nqpb : u64 = erg_zk_const("const NQPB" as u64)
    let nbatch : u64 = erg_zk_const("const NBATCH" as u64)
    let mut basis : u64 = 0u64
    if nqpb > 0u64 { if nbatch > 0u64 {
        if nqpb * nbatch >= 128u64 { basis = 1u64 } else { return 1u64 }
    } }
    if basis == 0u64 { if erg_zk_has("128 queries" as u64) == 1u64 { basis = 1u64 } }
    if basis == 0u64 { if erg_zk_has("128 FS" as u64) == 1u64 { basis = 1u64 } }
    if basis == 0u64 { return 1u64 }
    /* field marker */
    if cls == 1u64 { if erg_zk_has("GF(p^4)" as u64) == 1u64 { return 0u64 }   return 1u64 }
    if cls == 2u64 { if erg_zk_has("(5/8)^128" as u64) == 1u64 { return 0u64 }   return 1u64 }
    if cls == 3u64 { if erg_zk_has("zk_ext2_fri256" as u64) == 1u64 { return 0u64 }   return 1u64 }
    return 1u64
}
var ERG_ZKLIST : [u8; 65536]
fn erg_zkaudit() -> u32 @export {
    ERG_ZK_SCANNED = 0u64
    ERG_ZK_CLAIMERS = 0u64
    ERG_ZK_VIOL = 0u64
    /* enumerate zk_*.iii via cmd (native); dir /b = bare names */
    erg_x_run("cmd /c if not exist STDLIB\\build\\ergon_zk mkdir STDLIB\\build\\ergon_zk" as u64, 30000u32)
    if erg_x_run("cmd /c dir /b /on STDLIB\\sovir\\zk_*.iii > STDLIB\\build\\ergon_zk\\list.txt" as u64, 60000u32) != 0u64 { return 1601u32 }
    let h : u64 = CreateFileA("STDLIB/build/ergon_zk/list.txt" as u64, 2147483648u32, 1u32, 0u64, 3u32, 128u32, 0u64)
    if h == 18446744073709551615u64 { return 1601u32 }
    ReadFile(h, (&ERG_ZKLIST) as u64, 65536u32, (&ERG_TC) as u64, 0u64)
    CloseHandle(h)
    let ln : u64 = ERG_TC[0u64] as u64
    let lp : *u8 = (&ERG_ZKLIST) as u64 as *u8
    let mut i : u64 = 0u64
    while i < ln {
        let ls : u64 = i
        let mut le : u64 = i
        let mut go : u64 = 1u64
        while go == 1u64 { if le >= ln { go = 0u64 } else { if lp[le] == 10u8 { go = 0u64 } else { if lp[le] == 13u8 { go = 0u64 } else { le = le + 1u64 } } } }
        /* strip trailing ".iii" -> basename */
        if le > ls + 4u64 {
            let blen : u64 = (le - ls) - 4u64
            ERG_ZK_SCANNED = ERG_ZK_SCANNED + 1u64
            if erg_zk_read(((&ERG_ZKLIST) as u64) + ls, blen) > 0u64 {
                if erg_zk_count("2^-86" as u64, 5u64) > 0u64 { ERG_ZK_CLAIMERS = ERG_ZK_CLAIMERS + 1u64 }
                if erg_zk_audit_loaded(((&ERG_ZKLIST) as u64) + ls, blen) == 1u64 { ERG_ZK_VIOL = ERG_ZK_VIOL + 1u64 }
            } else { ERG_ZK_VIOL = ERG_ZK_VIOL + 1u64 }
        }
        /* advance past the CR/LF run to the next name */
        i = le
        let mut eol : u64 = 1u64
        while eol == 1u64 { if i >= ln { eol = 0u64 } else { if lp[i] == 10u8 { i = i + 1u64 } else { if lp[i] == 13u8 { i = i + 1u64 } else { eol = 0u64 } } } }
    }
    if ERG_ZK_SCANNED < 40u64 { return 1602u32 }        /* the census must be non-trivial */
    if ERG_ZK_VIOL > 0u64 { return 1603u32 }            /* a real violation on the live tree */
    /* TEETH 1: downscale a production NBATCH on a COPY -> its basis must fail */
    erg_x_run("cmd /c copy /y STDLIB\\sovir\\zk_fused_committed.iii STDLIB\\build\\ergon_zk\\t1.iii >nul" as u64, 30000u32)
    if erg_zk_read_path("STDLIB/build/ergon_zk/t1.iii" as u64) == 0u64 { return 1604u32 }
    /* rewrite "NBATCH: u64 = 4u64" -> "= 1u64" in the buffer, write back, re-read, audit MUST violate */
    if erg_zk_downscale_nbatch() == 0u64 { return 1604u32 }
    erg_x_putn("STDLIB/build/ergon_zk/t1.iii" as u64, (&ERG_ZKF) as u64, ERG_ZKF_LEN)
    erg_zk_read_path("STDLIB/build/ergon_zk/t1.iii" as u64)
    if erg_zk_audit_loaded("zk_fused_committed" as u64, 18u64) != 1u64 { return 1604u32 }
    /* TEETH 2: add a bare 2^-86 claim to an UNLISTED module copy -> must violate */
    erg_x_run("cmd /c copy /y STDLIB\\sovir\\zk_ext2_fri256.iii STDLIB\\build\\ergon_zk\\t2.iii >nul" as u64, 30000u32)
    /* t2 as an UNLISTED name (audit under a fake basename with a claim present):
     * zk_ext2_fri256 DOES claim; audited as an unlisted name it must violate */
    if erg_zk_read_path("STDLIB/build/ergon_zk/t2.iii" as u64) == 0u64 { return 1605u32 }
    if erg_zk_audit_loaded("zk_not_in_manifest" as u64, 18u64) != 1u64 { return 1605u32 }
    return 0u32
}
fn erg_zk_read_path(path: u64) -> u64 {
    let h : u64 = CreateFileA(path, 2147483648u32, 1u32, 0u64, 3u32, 128u32, 0u64)
    if h == 18446744073709551615u64 { return 0u64 }
    if ReadFile(h, (&ERG_ZKF) as u64, 262144u32, (&ERG_TC) as u64, 0u64) == 0i32 { CloseHandle(h)   return 0u64 }
    CloseHandle(h)
    ERG_ZKF_LEN = ERG_TC[0u64] as u64
    return ERG_ZKF_LEN
}
/* find "const NBATCH" in ERG_ZKF, scan to '=', set the first digit of its value
 * to '1' (a definitive downscale); 1 ok | 0 not found.  Targets the CONST, not
 * a comment mention, so the teeth strike the real knob. */
fn erg_zk_downscale_nbatch() -> u64 {
    let f : *u8 = (&ERG_ZKF) as u64 as *u8
    let p : *u8 = "const NBATCH" as u64 as *u8
    let mut plen : u64 = 0u64
    while p[plen] != 0u8 { plen = plen + 1u64 }
    let mut i : u64 = 0u64
    while i + plen <= ERG_ZKF_LEN {
        let mut j : u64 = 0u64
        let mut hit : u64 = 1u64
        while j < plen { if f[i + j] != p[j] { hit = 0u64   j = plen } else { j = j + 1u64 } }
        if hit == 1u64 {
            let mut k : u64 = i + plen
            let mut go : u64 = 1u64
            while go == 1u64 { if k >= ERG_ZKF_LEN { go = 0u64 } else { if f[k] == 61u8 { go = 0u64 } else { k = k + 1u64 } } }
            if k >= ERG_ZKF_LEN { return 0u64 }
            k = k + 1u64
            let mut dg : u64 = 1u64
            while dg == 1u64 {
                if k >= ERG_ZKF_LEN { dg = 0u64 } else {
                    if f[k] >= 48u8 { if f[k] <= 57u8 { f[k] = 49u8   return 1u64 } else { k = k + 1u64 } } else { k = k + 1u64 }
                }
            }
            return 0u64
        }
        i = i + 1u64
    }
    return 0u64
}
/* the k-th FED seed path suffix (1/2/3) */
fn erg_k_str(k: u64) -> u64 {
    if k == 1u64 { return "1.bin" as u64 }
    if k == 2u64 { return "2.bin" as u64 }
    return "3.bin" as u64
}
var ERG_XB2 : [u8; 512]
fn erg_dup_xb() -> u64 {
    let s : *u8 = (&ERG_XB) as u64 as *u8
    let d : *u8 = (&ERG_XB2) as u64 as *u8
    let mut i : u64 = 0u64
    while s[i] != 0u8 { d[i] = s[i]   i = i + 1u64 }
    d[i] = 0u8
    return (&ERG_XB2) as u64
}
/* ML-DSA keygen+sign+verify of MSG under the k-th quorum key; 0 = verified */
fn erg_fed_cycle(k: u64, msg: u64) -> u64 {
    let mut a : u64 = erg_x_sput(0u64, "COMPILED\\iii-crypto.exe keygen 2 STDLIB/build/ergon_autk/fed_seed_" as u64)
    a = erg_x_sput(a, erg_k_str(k))
    a = erg_x_sput(a, " STDLIB/build/ergon_autk/fed_pk_" as u64)
    a = erg_x_sput(a, erg_k_str(k))
    a = erg_x_sput(a, " STDLIB/build/ergon_autk/fed_sk_" as u64)
    a = erg_x_sput(a, erg_k_str(k))
    if erg_x_run((&ERG_XB) as u64, 120000u32) != 0u64 { return 9u64 }
    a = erg_x_sput(0u64, "COMPILED\\iii-crypto.exe sign 2 STDLIB/build/ergon_autk/fed_sk_" as u64)
    a = erg_x_sput(a, erg_k_str(k))
    a = erg_x_sput(a, " " as u64)
    a = erg_x_sput(a, msg)
    a = erg_x_sput(a, " STDLIB/build/ergon_autk/fed_sig_" as u64)
    a = erg_x_sput(a, erg_k_str(k))
    if erg_x_run((&ERG_XB) as u64, 120000u32) != 0u64 { return 9u64 }
    return erg_fed_verify(k, msg)
}
fn erg_fed_verify(k: u64, msg: u64) -> u64 {
    let mut a : u64 = erg_x_sput(0u64, "COMPILED\\iii-crypto.exe verify 2 STDLIB/build/ergon_autk/fed_pk_" as u64)
    a = erg_x_sput(a, erg_k_str(k))
    a = erg_x_sput(a, " " as u64)
    a = erg_x_sput(a, msg)
    a = erg_x_sput(a, " STDLIB/build/ergon_autk/fed_sig_" as u64)
    a = erg_x_sput(a, erg_k_str(k))
    return erg_x_run((&ERG_XB) as u64, 120000u32)
}
/* the committed-file manifest, read whole once; the tamper arms derive their
 * variants from it in-organ (no sed/grep dependency) */
var ERG_MAN : [u8; 262144]
var ERG_MAN2 : [u8; 262144]
var ERG_MAN_LEN : u64 = 0u64
fn erg_read_manifest(path: u64) -> u64 {
    ERG_MAN_LEN = 0u64
    let h : u64 = CreateFileA(path, 2147483648u32, 1u32, 0u64, 3u32, 128u32, 0u64)
    if h == 18446744073709551615u64 { return 0u64 }
    if ReadFile(h, (&ERG_MAN) as u64, 262144u32, (&ERG_TC) as u64, 0u64) == 0i32 { CloseHandle(h)   return 0u64 }
    CloseHandle(h)
    ERG_MAN_LEN = ERG_TC[0u64] as u64
    if ERG_MAN_LEN == 0u64 { return 0u64 }
    return ERG_MAN_LEN
}
fn erg_man_lines() -> u64 {
    let p : *u8 = (&ERG_MAN) as u64 as *u8
    let mut c : u64 = 0u64
    let mut i : u64 = 0u64
    while i < ERG_MAN_LEN { if p[i] == 10u8 { c = c + 1u64 }   i = i + 1u64 }
    return c
}
/* write the manifest minus its first line (from just past the first newline) */
fn erg_man_write_skip_first(dst: u64) -> u64 {
    let p : *u8 = (&ERG_MAN) as u64 as *u8
    let mut nl : u64 = ERG_MAN_LEN
    let mut i : u64 = 0u64
    while i < ERG_MAN_LEN { if p[i] == 10u8 { nl = i   i = ERG_MAN_LEN } else { i = i + 1u64 } }
    if nl >= ERG_MAN_LEN { return 0u64 }                 /* no newline -> malformed */
    let s2 : u64 = nl + 1u64
    return erg_x_putn(dst, ((&ERG_MAN) as u64) + s2, ERG_MAN_LEN - s2)
}
/* write the manifest minus the exact line equal to `needle` (NUL-terminated) */
fn erg_man_write_skip_line(dst: u64, needle: u64) -> u64 {
    let np : *u8 = needle as *u8
    let mut nlen : u64 = 0u64
    while np[nlen] != 0u8 { nlen = nlen + 1u64 }
    let p : *u8 = (&ERG_MAN) as u64 as *u8
    let op : *u8 = (&ERG_MAN2) as u64 as *u8
    let mut w : u64 = 0u64
    let mut i : u64 = 0u64
    let mut dropped : u64 = 0u64
    while i < ERG_MAN_LEN {
        let ls : u64 = i
        let mut le : u64 = i
        let mut go : u64 = 1u64
        while go == 1u64 { if le >= ERG_MAN_LEN { go = 0u64 } else { if p[le] == 10u8 { go = 0u64 } else { le = le + 1u64 } } }
        let llen : u64 = le - ls
        let mut match_line : u64 = 0u64
        if llen == nlen {
            match_line = 1u64
            let mut j : u64 = 0u64
            while j < nlen { if p[ls + j] != np[j] { match_line = 0u64   j = nlen } else { j = j + 1u64 } }
        }
        if match_line == 1u64 { dropped = dropped + 1u64 } else {
            let mut k : u64 = ls
            while k <= le { if k < ERG_MAN_LEN { op[w] = p[k]   w = w + 1u64 } else { op[w] = 10u8   w = w + 1u64 }   k = k + 1u64 }
        }
        i = le + 1u64
    }
    if dropped == 0u64 { return 0u64 }                  /* the line must exist to drop it */
    return erg_x_putn(dst, (&ERG_MAN2) as u64, w)
}
/* flip one byte at `off` in a file on disk IN PLACE (seek-read-1, seek-write-1)
 * -- never truncates, so a large signed testament stays whole but corrupted */
var ERG_FB1 : [u8; 4]
fn erg_flip_byte(path: u64, off: u64) -> u64 {
    let h : u64 = CreateFileA(path, 3221225472u32, 0u32, 0u64, 3u32, 128u32, 0u64)   /* GENERIC_READ|WRITE, OPEN_EXISTING */
    if h == 18446744073709551615u64 { return 0u64 }
    SetFilePointer(h, off as i32, 0u64, 0u32)                                        /* FILE_BEGIN */
    if ReadFile(h, (&ERG_FB1) as u64, 1u32, (&ERG_TC) as u64, 0u64) == 0i32 { CloseHandle(h)   return 0u64 }
    if ERG_TC[0u64] == 0u32 { CloseHandle(h)   return 0u64 }
    let p : *u8 = (&ERG_FB1) as u64 as *u8
    p[0u64] = p[0u64] ^ 255u8
    SetFilePointer(h, off as i32, 0u64, 0u32)
    WriteFile(h, (&ERG_FB1) as u64, 1u32, (&ERG_TC) as u64, 0u64)
    CloseHandle(h)
    return 1u64
}

/* ==================== THE CENSUS: the fleet works, therefore it is ==================== */
fn erg_census() -> u32 @export {
    let sp : u64 = erg_selfprove()
    if sp != 0u64 { return (1000u64 + sp) as u32 }     /* 1071/1072: own instrument broken */
    let s0 : u32 = erg_seat_intro()
    if s0 != 0u32 { return s0 }
    let s1 : u32 = erg_seat_kardia()
    if s1 != 0u32 { return s1 }
    let s2 : u32 = erg_seat_soma()
    if s2 != 0u32 { return s2 }
    let s3 : u32 = erg_seat_doxa()
    if s3 != 0u32 { return s3 }
    let s4 : u32 = erg_seat_iscene()
    if s4 != 0u32 { return s4 }
    let s5 : u32 = erg_seat_iform()
    if s5 != 0u32 { return s5 }
    let s6 : u32 = erg_seat_hexad()
    if s6 != 0u32 { return s6 }
    let s7 : u32 = erg_seat_intent()
    if s7 != 0u32 { return s7 }
    let s8 : u32 = erg_seat_exec()
    if s8 != 0u32 { return s8 }
    return 0u32
}

/* the ledger's runner count (the ancestral fleet still on the die) */
fn erg_ledger_runners() -> u64 @export {
    return soma_survey_runners("STDLIB/scripts" as u64)
}
