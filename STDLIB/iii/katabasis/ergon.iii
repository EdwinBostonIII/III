    /* arm 5: redeem -- 929 fallen ops lifted at exact measured deficit */
    if erg_x_run("COMPILED\\iii-substrate.exe redeem 3" as u64, 300000u32) != 0u64 { return 1405u32 }
    if erg_x_find("FALLEN (irreversible)     : 929" as u64) != 1u64 { return 1405u32 }
    if erg_x_find("d=4 F=14  BLSR(x)" as u64) != 1u64 { return 1405u32 }
