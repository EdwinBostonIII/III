    erg_x_put("STDLIB/build/ergon_ju.txt" as u64, "abd" as u64)
    if erg_x_run("COMPILED\\iii-judge.exe hash STDLIB/build/ergon_ju.txt ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad" as u64, 60000u32) != 1u64 { return 8u64 }
