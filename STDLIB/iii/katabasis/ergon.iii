    if erg_x_run("COMPILED\\iii-substrate.exe nomos 25000 STDLIB/build/ergnm" as u64, 600000u32) != 0u64 { return 1410u32 }
    let nl : u64 = erg_x_parse_after("NOMOS-SET id=" as u64)
    if nl == 0u64 { return 1410u32 }
    ERG_NOMOS_LIVE = nl
    ERG_NOMOS_SEALED = autognosis_nomos_id()
    /* arm 11: oneiros -- the dream admitted (sentinel 0, cert present) */
    if erg_x_run("COMPILED\\iii-substrate.exe oneiros 500 STDLIB/build/ergnm" as u64, 600000u32) != 0u64 { return 1411u32 }
    if erg_x_find("SENTINEL=0" as u64) != 1u64 { return 1411u32 }
    if erg_x_find("ONEIROS-CERT=" as u64) != 1u64 { return 1411u32 }
    /* arm 12: project (TOPOS x CASSANDRA) -- data as GF(2) geometry, predicted
     * in bounded superposition, reified bit-for-bit with no parser; the verb
     * runs cass_selfproof + tp_selfprove as its condition of motion */
    if erg_x_run("COMPILED\\iii-substrate.exe project" as u64, 300000u32) != 0u64 { return 1412u32 }
    /* arm 13: evolve (THE CRUCIBLE) -- morphogenetic evolution, beam-search
     * cheaper than blind, adopts only a survivor proven flawless; cr_selfprove
