    if g1 != autognosis_glossa_id() { return 1409u32 }
    if erg_x_run("COMPILED\\iii-prove.exe STDLIB/build/ergap1/gw5_s0.iii f STDLIB/build/ergap1/gw5_s1.iii f" as u64, 300000u32) != 0u64 { return 1409u32 }
    /* arm 10: nomos -- live legislation runs; the sealed id is compared in-
