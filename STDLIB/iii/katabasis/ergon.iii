    if erg_x_run("COMPILED\\iii-judge.exe pin STDLIB/build/ergon_led.txt floor 20 up" as u64, 60000u32) != 0u64 { return 8u64 }
    if erg_x_run("COMPILED\\iii-judge.exe pin STDLIB/build/ergon_led.txt floor 5 up" as u64, 60000u32) != 1u64 { return 8u64 }
    erg_x_put("STDLIB/build/ergon_r1.txt" as u64, "row-a\nrow-b\nrow-c\n" as u64)
    if erg_x_run("COMPILED\\iii-judge.exe fold STDLIB/build/ergon_r1.txt" as u64, 60000u32) != 0u64 { return 8u64 }
    if erg_x_find("root=" as u64) != 1u64 { return 8u64 }
    let ra : u64 = erg_x_parse_after("root=" as u64)
    erg_x_put("STDLIB/build/ergon_r1.txt" as u64, "row-a\nrow-X\nrow-c\n" as u64)
    if erg_x_run("COMPILED\\iii-judge.exe fold STDLIB/build/ergon_r1.txt" as u64, 60000u32) != 0u64 { return 8u64 }
    let rb : u64 = erg_x_parse_after("root=" as u64)
    if ra == rb { return 8u64 }
    /* arm 9: iii-testament keygen -- FIPS-205 deterministic: same 96-byte seed
     * file -> byte-identical pk(64)+sk(128), twice */
    /* the seed is GENERATED to exactly 96 bytes by construction (deterministic
     * fill) -- no hand-counted literal length anywhere */
    let mut sdi : u64 = 0u64
    while sdi < 96u64 { ERG_SEED[sdi] = (65u64 + (sdi * 7u64 + 3u64) % 26u64) as u8   sdi = sdi + 1u64 }
    if erg_x_putn("STDLIB/build/ergon_seed.bin" as u64, (&ERG_SEED) as u64, 96u64) != 1u64 { return 9u64 }
    if erg_x_run("COMPILED\\iii-testament.exe keygen STDLIB/build/ergon_seed.bin STDLIB/build/ergon_pk1.bin STDLIB/build/ergon_sk1.bin" as u64, 180000u32) != 0u64 { return 9u64 }
    if erg_x_run("COMPILED\\iii-testament.exe keygen STDLIB/build/ergon_seed.bin STDLIB/build/ergon_pk2.bin STDLIB/build/ergon_sk2.bin" as u64, 180000u32) != 0u64 { return 9u64 }
    if erg_x_cmp("STDLIB/build/ergon_pk1.bin" as u64, "STDLIB/build/ergon_pk2.bin" as u64, 64u64) != 1u64 { return 9u64 }
    if erg_x_cmp("STDLIB/build/ergon_sk1.bin" as u64, "STDLIB/build/ergon_sk2.bin" as u64, 128u64) != 1u64 { return 9u64 }
    /* arm 10: iii-witness -- trusts nothing: malformed input REFUSED as format
     * (10); the committed canonical testament verifies Tier-1 VALID */
    erg_x_put("STDLIB/build/ergon_garbage.bin" as u64, "not a testament at all -- too short and no IIITSTMT magic" as u64)
    if erg_x_run("COMPILED\\iii-witness.exe verify STDLIB/build/ergon_garbage.bin" as u64, 60000u32) != 10u64 { return 10u64 }
    /* the canonical testament is a RITE product, not a committed artifact --
     * tier-1 verify runs only when one exists (the retired runner's own guard) */
    let th : u64 = CreateFileA("STDLIB/testament/testament.dat" as u64, 2147483648u32, 1u32, 0u64, 3u32, 128u32, 0u64)
    if th != 18446744073709551615u64 {
        CloseHandle(th)
        if erg_x_run("COMPILED\\iii-witness.exe verify STDLIB/testament/testament.dat STDLIB/testament/testament.pk" as u64, 120000u32) != 0u64 { return 10u64 }
    }
    /* arm 11: iii-friction -- the falsifier battery greens; bare usage is 1 */
    if erg_x_run("COMPILED\\iii-friction.exe check" as u64, 240000u32) != 0u64 { return 11u64 }
    if erg_x_run("COMPILED\\iii-friction.exe" as u64, 30000u32) != 1u64 { return 11u64 }
    /* arm 12: iii-xeno -- fairness bijection exact; two-route census (canonical
     * == Burnside) at n=2; vacuous sweep REFUSED; bare usage 1 */
    if erg_x_run("COMPILED\\iii-xeno.exe fair 300" as u64, 120000u32) != 0u64 { return 12u64 }
    if erg_x_run("COMPILED\\iii-xeno.exe census 2" as u64, 240000u32) != 0u64 { return 12u64 }
    if erg_x_run("COMPILED\\iii-xeno.exe sweep 0 0" as u64, 60000u32) != 5u64 { return 12u64 }
    if erg_x_run("COMPILED\\iii-xeno.exe" as u64, 30000u32) != 1u64 { return 12u64 }
    return 0u64
}
/* byte-compare two files of exact expected length through the OS */
var ERG_FA : [u8; 256]
var ERG_FB : [u8; 256]
fn erg_x_cmp(pa: u64, pb: u64, want_len: u64) -> u64 {
    if want_len > 256u64 { return 0u64 }
    let ha : u64 = CreateFileA(pa, 2147483648u32, 1u32, 0u64, 3u32, 128u32, 0u64)
    if ha == 18446744073709551615u64 { return 0u64 }
    ReadFile(ha, (&ERG_FA) as u64, 256u32, (&ERG_TC) as u64, 0u64)
    CloseHandle(ha)
    if (ERG_TC[0u64] as u64) != want_len { return 0u64 }
    let hb : u64 = CreateFileA(pb, 2147483648u32, 1u32, 0u64, 3u32, 128u32, 0u64)
    if hb == 18446744073709551615u64 { return 0u64 }
    ReadFile(hb, (&ERG_FB) as u64, 256u32, (&ERG_TC) as u64, 0u64)
    CloseHandle(hb)
    if (ERG_TC[0u64] as u64) != want_len { return 0u64 }
    let mut i : u64 = 0u64
    while i < want_len { if ERG_FA[i] != ERG_FB[i] { return 0u64 }   i = i + 1u64 }
    return 1u64
}
fn erg_seat_exec() -> u32 @export {
    let a : u64 = erg_arm_exec()
    if a != 0u64 { return (1300u64 + a) as u32 }
    return 0u32
}

/* ==================== THE DEEP VERB: the die's heavy faculties ====================
 * The substrate's live-die verbs (ex run_standing_tools' deep half), organ-owned
 * and on-demand: minutes of wall, not census-weight.  Sealed-id agreements are
 * judged IN-PROCESS against the constitution (autognosis) -- stronger than the
 * retired runner's source-grepping.  NOMOS id-drift is band physics (THE
 * METER-CONTEXT LAW): named, never silent; the sealed rows' TRUTH on today's
 * die is the heart's cell 2748 (beaten on drift), not re-adjudicated here.
 * Codes 1400+arm. */
fn erg_deep() -> u32 @export {
    /* arm 1: atoms/bridge/isa -- the ISA-born algebra on the live die */
    if erg_x_run("COMPILED\\iii-substrate.exe atoms" as u64, 240000u32) != 0u64 { return 1401u32 }
    if erg_x_run("COMPILED\\iii-substrate.exe bridge" as u64, 240000u32) != 0u64 { return 1401u32 }
    if erg_x_run("COMPILED\\iii-substrate.exe isa 3" as u64, 300000u32) != 0u64 { return 1401u32 }
    /* arm 2: author->prover -- III lowers a discovered identity to pure .iii
     * and the sovereign prover disposes it over ALL 2^64 */
    erg_x_run("cmd /c del /q STDLIB\\build\\ergon_isa_l.iii STDLIB\\build\\ergon_isa_r.iii" as u64, 30000u32)
    if erg_x_run("COMPILED\\iii-substrate.exe emit 3 0 STDLIB/build/ergon_isa_l.iii STDLIB/build/ergon_isa_r.iii" as u64, 300000u32) != 0u64 { return 1402u32 }
    if erg_x_run("COMPILED\\iii-prove.exe STDLIB/build/ergon_isa_l.iii f STDLIB/build/ergon_isa_r.iii f" as u64, 300000u32) != 0u64 { return 1402u32 }
    /* arm 3: physis + moment + taxis -- cost geometry, the contingency
     * register (rc 2 = honestly-quiet die), the 153-class preorder */
    if erg_x_run("COMPILED\\iii-substrate.exe physis" as u64, 300000u32) != 0u64 { return 1403u32 }
    if erg_x_find("VALUE-INVARIANT" as u64) != 1u64 { return 1403u32 }
    let mm : u64 = erg_x_run("COMPILED\\iii-substrate.exe moment" as u64, 300000u32)
    if mm != 0u64 { if mm != 2u64 { return 1403u32 } }
    if mm == 0u64 { if erg_x_find("MODAL SPLIT IS REAL" as u64) != 1u64 { return 1403u32 } }
    if erg_x_run("COMPILED\\iii-substrate.exe taxis 3" as u64, 300000u32) != 0u64 { return 1403u32 }
    if erg_x_find("objects: 153 semantic classes" as u64) != 1u64 { return 1403u32 }
    if erg_x_find("0 cycles" as u64) != 1u64 { return 1403u32 }
    /* arm 4: reversible -- the diode + the six-altar convergence */
    if erg_x_run("COMPILED\\iii-substrate.exe reversible" as u64, 300000u32) != 0u64 { return 1404u32 }
    if erg_x_find("SHARPEST DIODE" as u64) != 1u64 { return 1404u32 }
    if erg_x_find("THREE independent routes, one gate" as u64) != 1u64 { return 1404u32 }
