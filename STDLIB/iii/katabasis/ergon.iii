    let a2 : u64 = erg_x_parse_after("AUTOPHASIS-SET id=" as u64)
    if a1 != a2 { return 1408u32 }
    if a1 != autognosis_autophasis_id() { return 1408u32 }
    /* arm 9: glossa press -- deterministic twice, live == SEALED lexicon id,
