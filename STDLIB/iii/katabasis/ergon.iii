    if erg_x_run("cmd /c if not exist STDLIB\\build\\ergap1 mkdir STDLIB\\build\\ergap1" as u64, 30000u32) >= 9000u64 { return 1408u32 }
    if erg_x_run("COMPILED\\iii-substrate.exe autophasis STDLIB/build/ergap1" as u64, 300000u32) != 0u64 { return 1408u32 }
    let a1 : u64 = erg_x_parse_after("AUTOPHASIS-SET id=" as u64)
