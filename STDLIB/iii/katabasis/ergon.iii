/* raw file access for the on-disk TAMPER law (the container must catch a
 * corrupted payload BYTE, so the examiner corrupts one -- through the OS, the
 * same way real corruption arrives) */
extern @abi(c-msvc-x64) fn CreateFileA(name: u64, access: u32, share: u32, sec: u64, disp: u32, flags: u32, tmpl: u64) -> u64 from "kernel32"
