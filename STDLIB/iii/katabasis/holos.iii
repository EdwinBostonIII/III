/* STDLIB/iii/katabasis/holos.iii -- THE WHOLE: the engine fleet dissolved into
 * one organism.
 *
 * Before this organ, III's capabilities lived as ~30 standalone binaries --
 * each an ENGINE in the old sense: on or off, running or not running, launched
 * by hand or by a script, each dragging its own copy of the whole archive.
 * The kardia already dissolved BATCH VERIFICATION into cells with standing;
 * this organ lifts the same law one level: THE ENGINES THEMSELVES become
 * cells.  Each skill is
 *
 *     (name, class, probe, face, dep-closure, reach-pin, standing, liveness)
 *
 * where the reach-pin is the mhash fold of everything the skill's behavior
 * depends on (the pinned compiler + the committed archive = the BODY pin,
 * the skill's face TU, and its fresh-organ closure -- the same lists its
 * retired build script used to compile).  A skill is DUE exactly when its
 * live pin no longer matches the pin of its last PROOF; everything else
 * keeps its standing.  Nothing here is "running" or "not running": skills
 * have STANDING between invocations, held in an append-only ledger, and
 * activation is exactly drift or need.
 *
 * THE LEDGER (event-primary): append-only lines at STDLIB/build/holos/holos.log
 *     H1|name|pin16hex|exit|mode|seq        mode: W work | P proof
 * State = last-wins fold by sequence WITHIN each mode class.  A WORK record is
 * the autobiography (any real invocation: its argv-observed exit + the pin it
 * ran under) and carries LIVENESS only; a PROOF record is an earned derivation
 * (the skill's own self-proof/probe run to exit 0) and carries STANDING.  THE
 * MODE LAW (the monotone law's sibling): a WORK record never displaces PROOF
 * standing -- verbs like `prove` answer 1 for REFUTED and that is a correct
 * answer, not a wound.  Malformed lines are COUNTED and refused, never
 * silently skipped.
 *
 * CLASSES:  1 = P, the skill names a cheap self-derivation (its own `prove`
 *               verb or a law-fixed probe) -- `earn` can convert its dues;
 *           2 = U, no safe cheap self-derivation exists (author/testament/
 *               witness/eval) -- counted honestly; their laws are enforced by
 *               their own selfprove-refusal arms at every real invocation and
 *               their deep verification is owned by named seats (ergon
 *               autarkeia / exec, the kardia cells, the event corpus).
 *
 * STANDING (per skill, from the P-fold vs the live pin):
 *     0 PROVEN    proof at exit 0 on exactly this body
 *     1 STALE     proof exists but the body/face/closure drifted since
 *     2 UNPROVEN  nothing earned yet on any body (or the wound predates drift)
 *     3 RED       the last proof on THIS body failed -- a live wound
 * VITALITY: fold over every PROVEN skill; REFUSED (0) while any RED stands --
 * the organism will not call itself healthy over a known wound.
 *
 * THE TWO-SOURCE LAW: the build manifest (COMPILER/BOOT/build_iii.sh) is the
 * organism's other registry; every dep path recorded here MUST be cited there.
 * ho_ingest_build folds the citation check live and COUNTS uncited paths --
 * table/build drift is caught at every face, never discovered at link time.
 *
 * NIH: composes sanctus/mhash via kardia's exported digest + fold seats and
 * msvcrt.  Self-proof arms run at EVERY invocation before any verb moves
 * (the autognosis refusal pattern, exit 9 at the face).  Hexad: kind_essence.
 * Ring R0. */
module katabasis_holos

extern @abi(c-msvc-x64) fn kd_digest_file(path: u64) -> u64 from "kardia.iii"
extern @abi(c-msvc-x64) fn kd_fold2(a: u64, b: u64) -> u64 from "kardia.iii"
extern @abi(c-msvc-x64) fn mhash_begin() -> i32 from "mhash.iii"
extern @abi(c-msvc-x64) fn mhash_payload(payload: u64, payload_len: u64) -> i32 from "mhash.iii"
extern @abi(c-msvc-x64) fn mhash_final(out_32: u64) -> i32 from "mhash.iii"
extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fread(buf: u64, sz: u64, n: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fputs(s: u64, stream: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(stream: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn _mkdir(path: u64) -> i32 from "msvcrt"

const HO_MAX  : u64 = 64u64
const HO_NLEN : u64 = 16u64
const HO_SENT : u64 = 18446744073709551615u64

/* ---- the skill table ---- */
var HO_NAMES : [u8; 1024]                /* HO_MAX x HO_NLEN */
var HO_NL    : [u64; 64]
var HO_CLS   : [u8; 64]                  /* 1 P | 2 U */
var HO_PROBE : [u64; 64]                 /* pointer into the manifest literal (0 for U) */
var HO_FACE  : [u64; 64]                 /* pointer to the face path literal */
var HO_DEPS  : [u64; 192]                /* up to 3 dep-chunk pointers per skill (i*3+k) */
var HO_PIN   : [u64; 64]                 /* live reach-pin */
var HO_PPIN  : [u64; 64]                 /* last PROOF pin (ledger fold) */
var HO_PEXIT : [u64; 64]
var HO_PSEQ  : [u64; 64]
var HO_PMODE : [u8; 64]                  /* 0 none | 1 proof present */
var HO_WPIN  : [u64; 64]                 /* last WORK pin (liveness) */
var HO_WEXIT : [u64; 64]
var HO_WSEQ  : [u64; 64]
var HO_WMODE : [u8; 64]
var HO_N     : u64 = 0u64
var HO_MALF  : u64 = 0u64
var HO_SEQ   : u64 = 0u64
var HO_MISSING : u64 = 0u64              /* dep/face paths that did not digest */
var HO_UNCITED : u64 = 0u64              /* dep paths not cited by build_iii.sh */
var HO_BODY  : u64 = 0u64                /* the body pin: iiis-2 + archive */

fn ho_reset() -> i32 @export {
    HO_N = 0u64
    HO_MALF = 0u64
    HO_SEQ = 0u64
    HO_MISSING = 0u64
    HO_UNCITED = 0u64
    HO_BODY = 0u64
    return 0i32
}
fn ho_name_at(i: u64) -> u64 @export { return ((&HO_NAMES) as u64) + (i * HO_NLEN) }
fn ho_find(name: u64, len: u64) -> u64 @export {
    let np : *u8 = name as *u8
    let mut i : u64 = 0u64
    while i < HO_N {
        if HO_NL[i] == len {
            let cp : *u8 = ho_name_at(i) as *u8
            let mut j : u64 = 0u64
            let mut same : u64 = 1u64
            while j < len { if cp[j] != np[j] { same = 0u64   j = len } else { j = j + 1u64 } }
            if same == 1u64 { return i }
        }
        i = i + 1u64
    }
    return HO_SENT
}
fn ho_reg(name: u64, len: u64, cls: u8, probe: u64, face: u64) -> i64 @export {
    if len == 0u64 { return -1i64 }
    if len >= HO_NLEN { return -1i64 }
    let ex : u64 = ho_find(name, len)
    if ex != HO_SENT { return ex as i64 }
    if HO_N >= HO_MAX { return -2i64 }
    let dst : *u8 = ho_name_at(HO_N) as *u8
    let sp : *u8 = name as *u8
    let mut j : u64 = 0u64
    while j < len { dst[j] = sp[j]   j = j + 1u64 }
    while j < HO_NLEN { dst[j] = 0u8   j = j + 1u64 }
    HO_NL[HO_N] = len
    HO_CLS[HO_N] = cls
    HO_PROBE[HO_N] = probe
    HO_FACE[HO_N] = face
    HO_DEPS[HO_N * 3u64] = 0u64
    HO_DEPS[HO_N * 3u64 + 1u64] = 0u64
    HO_DEPS[HO_N * 3u64 + 2u64] = 0u64
    HO_PIN[HO_N] = 0u64
    HO_PPIN[HO_N] = 0u64
    HO_PEXIT[HO_N] = 0u64
    HO_PSEQ[HO_N] = 0u64
    HO_PMODE[HO_N] = 0u8
    HO_WPIN[HO_N] = 0u64
    HO_WEXIT[HO_N] = 0u64
    HO_WSEQ[HO_N] = 0u64
    HO_WMODE[HO_N] = 0u8
    HO_N = HO_N + 1u64
    return HO_N as i64 - 1i64
}
fn ho_set_deps(i: u64, d0: u64, d1: u64, d2: u64) -> i32 {
    if i >= HO_N { return -1i32 }
    HO_DEPS[i * 3u64] = d0
    HO_DEPS[i * 3u64 + 1u64] = d1
    HO_DEPS[i * 3u64 + 2u64] = d2
    return 0i32
}
fn ho_count() -> u64 @export { return HO_N }
fn ho_class(i: u64) -> u8 @export { if i < HO_N { return HO_CLS[i] }  return 0u8 }
fn ho_probe(i: u64) -> u64 @export { if i < HO_N { return HO_PROBE[i] }  return 0u64 }
fn ho_face(i: u64) -> u64 @export { if i < HO_N { return HO_FACE[i] }  return 0u64 }
fn ho_name_len(i: u64) -> u64 @export { if i < HO_N { return HO_NL[i] }  return 0u64 }
fn ho_name_byte(i: u64, j: u64) -> u8 @export { if i < HO_N { if j < HO_NL[i] { let cp : *u8 = ho_name_at(i) as *u8   return cp[j] } }  return 0u8 }
fn ho_malformed() -> u64 @export { return HO_MALF }
fn ho_missing() -> u64 @export { return HO_MISSING }
fn ho_uncited() -> u64 @export { return HO_UNCITED }
fn ho_body_pin() -> u64 @export { return HO_BODY }
fn ho_live_pin(i: u64) -> u64 @export { if i < HO_N { return HO_PIN[i] }  return 0u64 }
fn ho_set_live_pin(i: u64, pin: u64) -> i32 @export { if i < HO_N { HO_PIN[i] = pin }  return 0i32 }
fn ho_w_seq(i: u64) -> u64 @export { if i < HO_N { return HO_WSEQ[i] }  return 0u64 }
fn ho_w_exit(i: u64) -> u64 @export { if i < HO_N { return HO_WEXIT[i] }  return 0u64 }
fn ho_w_present(i: u64) -> u8 @export { if i < HO_N { return HO_WMODE[i] }  return 0u8 }
fn ho_seqmax() -> u64 @export { return HO_SEQ }

/* ---- the ledger fold: last-wins by sequence WITHIN each mode class ---- */
fn ho_fold_rec(name: u64, len: u64, pin: u64, exitc: u64, mode: u8, seq: u64) -> u64 @export {
    if mode != 1u8 { if mode != 2u8 { HO_MALF = HO_MALF + 1u64   return 0u64 } }
    let i : u64 = ho_find(name, len)
    if i == HO_SENT { HO_MALF = HO_MALF + 1u64   return 0u64 }
    if seq > HO_SEQ { HO_SEQ = seq }
    /* mode 1 = W (work / liveness), mode 2 = P (proof / standing) */
    if mode == 2u8 {
        if HO_PMODE[i] == 1u8 { if seq < HO_PSEQ[i] { return 1u64 } }
        HO_PPIN[i] = pin
        HO_PEXIT[i] = exitc
        HO_PSEQ[i] = seq
        HO_PMODE[i] = 1u8
        return 1u64
    }
    if HO_WMODE[i] == 1u8 { if seq < HO_WSEQ[i] { return 1u64 } }
    HO_WPIN[i] = pin
    HO_WEXIT[i] = exitc
    HO_WSEQ[i] = seq
    HO_WMODE[i] = 1u8
    return 1u64
}
/* STANDING: 0 PROVEN | 1 STALE | 2 UNPROVEN | 3 RED (live wound) */
fn ho_standing(i: u64) -> u64 @export {
    if i >= HO_N { return 2u64 }
    if HO_PMODE[i] == 0u8 { return 2u64 }
    if HO_PEXIT[i] == 0u64 {
        if HO_PPIN[i] == HO_PIN[i] { return 0u64 }
        return 1u64
    }
    if HO_PPIN[i] == HO_PIN[i] { return 3u64 }
    return 2u64
}
fn ho_due(i: u64) -> u64 @export {
    if i >= HO_N { return 0u64 }
    if HO_CLS[i] != 1u8 { return 0u64 }
    let s : u64 = ho_standing(i)
    if s == 0u64 { return 0u64 }
    return 1u64
}
fn ho_due_n() -> u64 @export {
    let mut n : u64 = 0u64
    let mut i : u64 = 0u64
    while i < HO_N { if ho_due(i) == 1u64 { n = n + 1u64 }   i = i + 1u64 }
    return n
}
fn ho_standing_n(which: u64) -> u64 @export {
    let mut n : u64 = 0u64
    let mut i : u64 = 0u64
    while i < HO_N { if ho_standing(i) == which { n = n + 1u64 }   i = i + 1u64 }
    return n
}
fn ho_class_n(cls: u8) -> u64 @export {
    let mut n : u64 = 0u64
    let mut i : u64 = 0u64
    while i < HO_N { if HO_CLS[i] == cls { n = n + 1u64 }   i = i + 1u64 }
    return n
}
/* VITALITY: fold over every PROVEN skill; REFUSED (0) while any RED stands */
var HO_H32 : [u8; 32]
var HO_VACC : [u64; 4]
fn ho_vitality() -> u64 @export {
    if ho_standing_n(3u64) != 0u64 { return 0u64 }
    mhash_begin()
    let mut folded : u64 = 0u64
    let mut i : u64 = 0u64
    while i < HO_N {
        if ho_standing(i) == 0u64 {
            folded = folded + 1u64
            mhash_payload(ho_name_at(i), HO_NL[i])
            HO_VACC[0u64] = HO_PPIN[i]
            HO_VACC[1u64] = HO_PEXIT[i]
            HO_VACC[2u64] = HO_PSEQ[i]
            HO_VACC[3u64] = i
            mhash_payload((&HO_VACC) as u64, 32u64)
        }
        i = i + 1u64
    }
    if folded == 0u64 { return 1u64 }               /* intact but nothing earned on this body yet */
    mhash_final((&HO_H32) as u64)
    let hp : *u64 = (&HO_H32) as *u64
    let v : u64 = hp[0u64]
    if v == 0u64 { return 1u64 }
    return v
}

/* ---- the digest memo (one SHA stream per distinct path per pin pass) ---- */
var HO_DCK  : [u64; 2048]
var HO_DCV  : [u64; 2048]
var HO_DCG  : [u64; 2048]
var HO_DGEN : u64 = 0u64
fn ho_path_hash(path: u64, plen: u64) -> u64 {
    let p : *u8 = path as *u8
    let mut h : u64 = 14695981039346656037u64
    let mut i : u64 = 0u64
    while i < plen { h = (h ^ (p[i] as u64)) * 1099511628211u64   i = i + 1u64 }
    return h
}
var HO_PATH : [u8; 256]
fn ho_digest_memo_n(path: u64, plen: u64) -> u64 {
    if plen == 0u64 { return HO_SENT }
    if plen >= 256u64 { return HO_SENT }
    /* NUL-terminate a copy for fopen */
    let dp : *u8 = (&HO_PATH) as *u8
    let sp : *u8 = path as *u8
    let mut c : u64 = 0u64
    while c < plen { dp[c] = sp[c]   c = c + 1u64 }
    dp[plen] = 0u8
    let key : u64 = ho_path_hash(path, plen)
    let mut probe : u64 = 0u64
    let h0 : u64 = (key ^ (key >> 33u64)) % 2048u64
    while probe < 2048u64 {
        let s : u64 = (h0 + probe) % 2048u64
        if HO_DCG[s] != HO_DGEN { HO_DCG[s] = HO_DGEN   HO_DCK[s] = key   HO_DCV[s] = kd_digest_file((&HO_PATH) as u64)   return HO_DCV[s] }
        if HO_DCK[s] == key { return HO_DCV[s] }
        probe = probe + 1u64
    }
    return kd_digest_file((&HO_PATH) as u64)
}

/* ---- the live reach-pins ----
 * body = fold(iiis-2, archive); skill = fold(body, face, dep...deps).
 * A missing path folds as SENT (drift stays visible) and is COUNTED. */
fn ho_slen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut n : u64 = 0u64
    while p[n] != 0u8 { n = n + 1u64 }
    return n
}
fn ho_pin_chunk(pin0: u64, chunk: u64) -> u64 {
    /* chunk = "path;path;...\0"; folds each path's digest in order */
    if chunk == 0u64 { return pin0 }
    let p : *u8 = chunk as *u8
    let mut pin : u64 = pin0
    let mut s : u64 = 0u64
    let mut i : u64 = 0u64
    let mut go : u64 = 1u64
    while go == 1u64 {
        let c : u8 = p[i]
        if c == 59u8 {
            if i > s {
                let g : u64 = ho_digest_memo_n(chunk + s, i - s)
                if g == HO_SENT { HO_MISSING = HO_MISSING + 1u64 }
                pin = kd_fold2(pin, g)
            }
            s = i + 1u64
        }
        if c == 0u8 {
            if i > s {
                let g2 : u64 = ho_digest_memo_n(chunk + s, i - s)
                if g2 == HO_SENT { HO_MISSING = HO_MISSING + 1u64 }
                pin = kd_fold2(pin, g2)
            }
            go = 0u64
        }
        i = i + 1u64
    }
    return pin
}
fn ho_pin_body() -> u64 @export {
    let a : u64 = ho_digest_memo_n("COMPILED/iiis-2.exe" as u64, 19u64)
    let b : u64 = ho_digest_memo_n("STDLIB/build/iii/libiii_native.a" as u64, 32u64)
    if a == HO_SENT { HO_MISSING = HO_MISSING + 1u64 }
    if b == HO_SENT { HO_MISSING = HO_MISSING + 1u64 }
    HO_BODY = kd_fold2(a, b)
    return HO_BODY
}
fn ho_pin_skill(i: u64) -> u64 @export {
    if i >= HO_N { return 0u64 }
    if HO_BODY == 0u64 { ho_pin_body() }
    let f : u64 = HO_FACE[i]
    let g : u64 = ho_digest_memo_n(f, ho_slen(f))
    if g == HO_SENT { HO_MISSING = HO_MISSING + 1u64 }
    let mut pin : u64 = kd_fold2(HO_BODY, g)
    pin = ho_pin_chunk(pin, HO_DEPS[i * 3u64])
    pin = ho_pin_chunk(pin, HO_DEPS[i * 3u64 + 1u64])
    pin = ho_pin_chunk(pin, HO_DEPS[i * 3u64 + 2u64])
    HO_PIN[i] = pin
    return pin
}
fn ho_pin_all() -> i32 @export {
    HO_DGEN = HO_DGEN + 1u64
    HO_MISSING = 0u64
    HO_BODY = 0u64
    ho_pin_body()
    let mut i : u64 = 0u64
    while i < HO_N { ho_pin_skill(i)   i = i + 1u64 }
    return 0i32
}

/* ---- the two-source law: every dep path must be cited by build_iii.sh ---- */
var HO_BBUF : [u8; 131072]
var HO_BLEN : u64 = 0u64
fn ho_load_build() -> u64 {
    HO_BLEN = 0u64
    let h : u64 = fopen("COMPILER/BOOT/build_iii.sh" as u64, "rb" as u64)
    if h == 0u64 { return 0u64 }
    let mut n : u64 = fread(((&HO_BBUF) as u64) + HO_BLEN, 1u64, 32768u64, h)
    while n > 0u64 {
        HO_BLEN = HO_BLEN + n
        if HO_BLEN + 32768u64 >= 131072u64 { n = 0u64 } else {
            n = fread(((&HO_BBUF) as u64) + HO_BLEN, 1u64, 32768u64, h)
        }
    }
    fclose(h)
    return HO_BLEN
}
fn ho_build_cites(path: u64, plen: u64) -> u64 {
    if plen == 0u64 { return 1u64 }
    if HO_BLEN < plen { return 0u64 }
    let bp : *u8 = (&HO_BBUF) as *u8
    let pp : *u8 = path as *u8
    let mut i : u64 = 0u64
    let lim : u64 = HO_BLEN - plen
    while i <= lim {
        let mut k : u64 = 0u64
        let mut hit : u64 = 1u64
        while k < plen { if bp[i + k] != pp[k] { hit = 0u64   k = plen } else { k = k + 1u64 } }
        if hit == 1u64 { return 1u64 }
        i = i + 1u64
    }
    return 0u64
}
fn ho_cite_chunk(chunk: u64) -> i32 {
    if chunk == 0u64 { return 0i32 }
    let p : *u8 = chunk as *u8
    let mut s : u64 = 0u64
    let mut i : u64 = 0u64
    let mut go : u64 = 1u64
    while go == 1u64 {
        let c : u8 = p[i]
        if c == 59u8 {
            if i > s { if ho_build_cites(chunk + s, i - s) == 0u64 { HO_UNCITED = HO_UNCITED + 1u64 } }
            s = i + 1u64
        }
        if c == 0u8 {
            if i > s { if ho_build_cites(chunk + s, i - s) == 0u64 { HO_UNCITED = HO_UNCITED + 1u64 } }
            go = 0u64
        }
        i = i + 1u64
    }
    return 0i32
}
fn ho_ingest_build() -> i64 @export {
    HO_UNCITED = 0u64
    if ho_load_build() == 0u64 { return -1i64 }
    let mut i : u64 = 0u64
    while i < HO_N {
        let f : u64 = HO_FACE[i]
        if ho_build_cites(f, ho_slen(f)) == 0u64 { HO_UNCITED = HO_UNCITED + 1u64 }
        ho_cite_chunk(HO_DEPS[i * 3u64])
        ho_cite_chunk(HO_DEPS[i * 3u64 + 1u64])
        ho_cite_chunk(HO_DEPS[i * 3u64 + 2u64])
        i = i + 1u64
    }
    return HO_UNCITED as i64
}

/* ---- the append-only ledger ---- */
var HO_LBUF : [u8; 192]
var HO_LPATH : [u8; 256]
fn ho_sput(dst: *u8, at: u64, s: u64) -> u64 {
    let sp : *u8 = s as *u8
    let mut i : u64 = 0u64
    let mut a : u64 = at
    while sp[i] != 0u8 { dst[a] = sp[i]   a = a + 1u64   i = i + 1u64 }
    dst[a] = 0u8
    return a
}
fn ho_sputn(dst: *u8, at: u64, s: u64, n: u64) -> u64 {
    let sp : *u8 = s as *u8
    let mut i : u64 = 0u64
    let mut a : u64 = at
    while i < n { dst[a] = sp[i]   a = a + 1u64   i = i + 1u64 }
    dst[a] = 0u8
    return a
}
fn ho_sputu(dst: *u8, at: u64, v: u64) -> u64 {
    if v >= 10u64 {
        let a : u64 = ho_sputu(dst, at, v / 10u64)
        dst[a] = (48u64 + (v % 10u64)) as u8
        dst[a + 1u64] = 0u8
        return a + 1u64
    }
    dst[at] = (48u64 + v) as u8
    dst[at + 1u64] = 0u8
    return at + 1u64
}
fn ho_sputhex(dst: *u8, at: u64, v: u64) -> u64 {
    let mut a : u64 = at
    let mut k : u64 = 64u64
    while k > 0u64 {
        k = k - 4u64
        let nib : u64 = (v >> k) & 15u64
        if nib < 10u64 { dst[a] = (48u64 + nib) as u8 } else { dst[a] = (87u64 + nib) as u8 }
        a = a + 1u64
    }
    dst[a] = 0u8
    return a
}
fn ho_make_dir() -> i32 @export { _mkdir("STDLIB/build" as u64)   return _mkdir("STDLIB/build/holos" as u64) }
fn ho_ledger_append(i: u64, exitc: u64, mode: u8) -> i32 @export {
    if i >= HO_N { return -1i32 }
    let dp : *u8 = (&HO_LPATH) as *u8
    ho_sput(dp, 0u64, "STDLIB/build/holos/holos.log" as u64)
    let h : u64 = fopen((&HO_LPATH) as u64, "ab" as u64)
    if h == 0u64 { return -1i32 }
    let lp : *u8 = (&HO_LBUF) as *u8
    let mut a : u64 = ho_sput(lp, 0u64, "H1|" as u64)
    a = ho_sputn(lp, a, ho_name_at(i), HO_NL[i])
    a = ho_sput(lp, a, "|" as u64)
    a = ho_sputhex(lp, a, HO_PIN[i])
    a = ho_sput(lp, a, "|" as u64)
    a = ho_sputu(lp, a, exitc)
    a = ho_sput(lp, a, "|" as u64)
    if mode == 2u8 { a = ho_sput(lp, a, "P" as u64) } else { a = ho_sput(lp, a, "W" as u64) }
    a = ho_sput(lp, a, "|" as u64)
    HO_SEQ = HO_SEQ + 1u64
    a = ho_sputu(lp, a, HO_SEQ)
    a = ho_sput(lp, a, "\n" as u64)
    fputs((&HO_LBUF) as u64, h)
    fclose(h)
    ho_fold_rec(ho_name_at(i), HO_NL[i], HO_PIN[i], exitc, mode, HO_SEQ)
    return 0i32
}
fn ho_fold_line(addr: u64, len: u64) -> u64 @export {
    let lp : *u8 = addr as *u8
    if len < 8u64 { HO_MALF = HO_MALF + 1u64   return 0u64 }
    if lp[0u64] != 72u8 { HO_MALF = HO_MALF + 1u64   return 0u64 }
    if lp[1u64] != 49u8 { HO_MALF = HO_MALF + 1u64   return 0u64 }
    if lp[2u64] != 124u8 { HO_MALF = HO_MALF + 1u64   return 0u64 }
    let ns : u64 = 3u64
    let mut ne : u64 = ns
    let mut nk : u64 = 0u64
    while ne < len { if lp[ne] == 124u8 { nk = ne   ne = len } else { ne = ne + 1u64 } }
    ne = nk
    if ne <= ns { HO_MALF = HO_MALF + 1u64   return 0u64 }
    if ne >= len { HO_MALF = HO_MALF + 1u64   return 0u64 }
    let ps : u64 = ne + 1u64
    if ps + 16u64 >= len { HO_MALF = HO_MALF + 1u64   return 0u64 }
    let mut pin : u64 = 0u64
    let mut k : u64 = 0u64
    let mut bad : u64 = 0u64
    while k < 16u64 {
        let c : u8 = lp[ps + k]
        let mut nib : u64 = 255u64
        if c >= 48u8 { if c <= 57u8 { nib = (c - 48u8) as u64 } }
        if c >= 97u8 { if c <= 102u8 { nib = ((c - 97u8) as u64) + 10u64 } }
        if nib == 255u64 { bad = 1u64   k = 16u64 } else { pin = (pin << 4u64) | nib   k = k + 1u64 }
    }
    if bad == 1u64 { HO_MALF = HO_MALF + 1u64   return 0u64 }
    if lp[ps + 16u64] != 124u8 { HO_MALF = HO_MALF + 1u64   return 0u64 }
    let mut vp : u64 = ps + 17u64
    let mut v : u64 = 0u64
    let mut nfound : u64 = 0u64
    let mut vk : u64 = 0u64
    while vp < len { let c2 : u8 = lp[vp]   if c2 >= 48u8 { if c2 <= 57u8 { v = (v * 10u64) + ((c2 - 48u8) as u64)   nfound = 1u64   vp = vp + 1u64 } else { vk = vp   vp = len } } else { vk = vp   vp = len } }
    vp = vk
    if nfound == 0u64 { HO_MALF = HO_MALF + 1u64   return 0u64 }
    if vp >= len { HO_MALF = HO_MALF + 1u64   return 0u64 }
    if lp[vp] != 124u8 { HO_MALF = HO_MALF + 1u64   return 0u64 }
    let mp : u64 = vp + 1u64
    if mp + 1u64 >= len { HO_MALF = HO_MALF + 1u64   return 0u64 }
    let mut mode : u8 = 0u8
    if lp[mp] == 87u8 { mode = 1u8 }
    if lp[mp] == 80u8 { mode = 2u8 }
    if mode == 0u8 { HO_MALF = HO_MALF + 1u64   return 0u64 }
    if lp[mp + 1u64] != 124u8 { HO_MALF = HO_MALF + 1u64   return 0u64 }
    let mut sp2 : u64 = mp + 2u64
    let mut seq : u64 = 0u64
    nfound = 0u64
    while sp2 < len { let c3 : u8 = lp[sp2]   if c3 >= 48u8 { if c3 <= 57u8 { seq = (seq * 10u64) + ((c3 - 48u8) as u64)   nfound = 1u64   sp2 = sp2 + 1u64 } else { sp2 = len } } else { sp2 = len } }
    if nfound == 0u64 { HO_MALF = HO_MALF + 1u64   return 0u64 }
    return ho_fold_rec(addr + ns, ne - ns, pin, v, mode, seq)
}
var HO_FBUF : [u8; 1048576]
var HO_FLEN : u64 = 0u64
fn ho_ledger_load() -> i64 @export {
    HO_FLEN = 0u64
    let h : u64 = fopen("STDLIB/build/holos/holos.log" as u64, "rb" as u64)
    if h == 0u64 { return 0i64 }
    let mut n : u64 = fread(((&HO_FBUF) as u64) + HO_FLEN, 1u64, 65536u64, h)
    while n > 0u64 {
        HO_FLEN = HO_FLEN + n
        if HO_FLEN + 65536u64 >= 1048576u64 { n = 0u64 } else {
            n = fread(((&HO_FBUF) as u64) + HO_FLEN, 1u64, 65536u64, h)
        }
    }
    fclose(h)
    let bp : *u8 = (&HO_FBUF) as *u8
    let mut cnt : i64 = 0i64
    let mut i : u64 = 0u64
    while i < HO_FLEN {
        let ls : u64 = i
        let mut le : u64 = i
        while le < HO_FLEN { if bp[le] == 10u8 { i = le   le = HO_FLEN } else { le = le + 1u64   if le >= HO_FLEN { i = le } } }
        let mut ll : u64 = i - ls
        if ll > 0u64 { if bp[ls + ll - 1u64] == 13u8 { ll = ll - 1u64 } }
        if ll > 0u64 {
            ho_fold_line(((&HO_FBUF) as u64) + ls, ll)
            cnt = cnt + 1i64
        }
        i = i + 1u64
    }
    return cnt
}

/* ==================== THE MANIFEST (the skill registry) ====================
 * One row per skill: name|class(P/U)|probe or -|face path.  Dep closures in
 * chunk literals (they mirror the retired per-engine build scripts).  These
 * rows ARE the dissolution record: each engine's identity, kept. */
fn ho_mrow(i: u64) -> u64 {
    if i == 0u64  { return "agon|P|root STDLIB/iii/katabasis/agon.iii COMPILED/iii.exe|STDLIB/iii/aether/agon_cli.iii" as u64 }
    if i == 1u64  { return "author|U|-|STDLIB/iii/aether/author_cli.iii" as u64 }
    if i == 2u64  { return "closure|P|derive STDLIB/iii/katabasis/pulse.iii|STDLIB/iii/aether/closure_cli.iii" as u64 }
    if i == 3u64  { return "crypto|P|hash COMPILER/BOOT/mhash_lib.sh|STDLIB/iii/aether/crypto_cli.iii" as u64 }
    if i == 4u64  { return "doxa|P|prove|COMPILER/BOOT/doxa_main.iii" as u64 }
    if i == 5u64  { return "eidolos|P|prove|COMPILER/BOOT/eidolos_main.iii" as u64 }
    if i == 6u64  { return "ergon|P|prove|COMPILER/BOOT/ergon_main.iii" as u64 }
    if i == 7u64  { return "eval|U|-|COMPILER/BOOT/eval_main.iii" as u64 }
    if i == 8u64  { return "events|P|--diff COMPILER/BOOT/stage1_corpus/13_for_loop.iii COMPILER/BOOT/stage1_corpus/13_for_loop.iii|COMPILER/BOOT/events_main.iii" as u64 }
    if i == 9u64  { return "exact|P|\"2 2 3 2 -5 2\"|STDLIB/iii/aether/exact_cli.iii" as u64 }
    if i == 10u64 { return "friction|P|check|STDLIB/iii/aether/friction_cli.iii" as u64 }
    if i == 11u64 { return "hexad|P|--count|STDLIB/iii/omnia/hexad_cli.iii" as u64 }
    if i == 12u64 { return "intent|P|\"lock the database\"|STDLIB/iii/intent/intent_cli.iii" as u64 }
    if i == 13u64 { return "judge|P|run 2 \"cmd /c exit 2\"|STDLIB/iii/aether/judge_cli.iii" as u64 }
    if i == 14u64 { return "kardia|P|prove|COMPILER/BOOT/kardia_main.iii" as u64 }
    if i == 15u64 { return "line|P|prove|COMPILER/BOOT/line_main.iii" as u64 }
    if i == 16u64 { return "manifold|P|prove|COMPILER/BOOT/manifold_main.iii" as u64 }
    if i == 17u64 { return "motion|P|prove|COMPILER/BOOT/motion_main.iii" as u64 }
    if i == 18u64 { return "plane|P|prove|COMPILER/BOOT/plane_main.iii" as u64 }
    if i == 19u64 { return "proofcarry|P|prove|COMPILER/BOOT/proofcarry_main.iii" as u64 }
    if i == 20u64 { return "prove|P|--list COMPILER/BOOT/stage1_corpus/13_for_loop.iii|COMPILER/BOOT/prove_main.iii" as u64 }
    if i == 21u64 { return "pulse|P|hash COMPILED/iii.exe|STDLIB/iii/aether/pulse_cli.iii" as u64 }
    if i == 22u64 { return "soma|P|prove|COMPILER/BOOT/soma_main.iii" as u64 }
    if i == 23u64 { return "space|P|prove|COMPILER/BOOT/space_main.iii" as u64 }
    if i == 24u64 { return "substrate|P|atoms|STDLIB/iii/aether/substrate_cli.iii" as u64 }
    if i == 25u64 { return "testament|U|-|STDLIB/iii/aether/testament_cli.iii" as u64 }
    if i == 26u64 { return "typecheck|P|--reach 40|STDLIB/iii/aether/typecheck_cli.iii" as u64 }
    if i == 27u64 { return "witness|U|-|STDLIB/iii/aether/witness_cli.iii" as u64 }
    if i == 28u64 { return "worldline|P|prove|COMPILER/BOOT/worldline_main.iii" as u64 }
    if i == 29u64 { return "xeno|P|fair 300|STDLIB/iii/aether/xeno_cli.iii" as u64 }
    if i == 30u64 { return "xenos|P|prove|STDLIB/iii/aether/xenos_cli.iii" as u64 }
    if i == 31u64 { return "anglos|P|prove|STDLIB/iii/aether/anglos_cli.iii" as u64 }
    return 0u64
}
