                    if k == 1u64 { return "STDLIB/iii/aether/oneiros.iii;STDLIB/iii/aether/xeno_ontogenesis.iii;STDLIB/iii/aether/autophasis.iii;STDLIB/iii/katabasis/autognosis.iii;STDLIB/iii/aether/synapse.iii;STDLIB/iii/aether/admix.iii;STDLIB/iii/aether/entangle.iii;STDLIB/iii/katabasis/introspection.iii" as u64 }
                    if k == 2u64 { return "STDLIB/iii/aether/reversibility.iii;STDLIB/iii/aether/lagrangian.iii;STDLIB/iii/oneiros/cassandra.iii;STDLIB/iii/glossa/topos.iii;STDLIB/iii/katabasis/kardia.iii;STDLIB/iii/katabasis/crucible.iii;STDLIB/iii/aether/symmetria.iii" as u64 } }
    if i == 25u64 { if k == 0u64 { return "STDLIB/iii/aether/testament.iii" as u64 } }
    if i == 27u64 { if k == 0u64 { return "STDLIB/iii/aether/testament.iii" as u64 } }
    if i == 28u64 { if k == 0u64 { return "STDLIB/iii/eidos/exact_worldline.iii;STDLIB/iii/aether/kfield.iii;STDLIB/iii/memoria/arena.iii;STDLIB/iii/numera/bigint.iii;STDLIB/iii/numera/cpufeat.iii;STDLIB/iii/numera/typecheck.iii;STDLIB/iii/numera/ccl.iii;STDLIB/iii/numera/cost_lattice.iii" as u64 }
                    if k == 1u64 { return "STDLIB/iii/numera/combinator.iii;STDLIB/iii/numera/weave_blocks.iii;STDLIB/iii/omnia/hexad_reach.iii;STDLIB/iii/omnia/hexad_pfs.iii;STDLIB/iii/omnia/hexad_algebra.iii;STDLIB/iii/numera/trit.iii;STDLIB/iii/omnia/eidolos.iii" as u64 }
                    if k == 2u64 { return "STDLIB/iii/numera/idfold.iii;STDLIB/iii/omnia/isub.iii;STDLIB/iii/omnia/exec_cert.iii;STDLIB/iii/numera/sha256.iii" as u64 } }
    if i == 29u64 { if k == 0u64 { return "STDLIB/iii/aether/xeno_ontogenesis.iii;STDLIB/iii/aether/xeno_isa.iii;STDLIB/iii/aether/substrate_ontogenesis.iii;STDLIB/iii/aether/mathesis_ontogenesis.iii;STDLIB/iii/aether/mathesis_forge.iii" as u64 } }
    if i == 30u64 { if k == 0u64 { return "STDLIB/iii/aether/xenos.iii;STDLIB/iii/aether/xring.iii;STDLIB/iii/verba/json.iii;STDLIB/iii/verba/builder.iii;STDLIB/iii/verba/lexicon.iii;STDLIB/iii/omnia/eidolos.iii;STDLIB/iii/memoria/arena.iii" as u64 } }
    if i == 31u64 { if k == 0u64 { return "STDLIB/iii/aether/anglos.iii;STDLIB/iii/aether/proxenos.iii;STDLIB/iii/verba/nl_lex.iii;STDLIB/iii/verba/nl_parse.iii;STDLIB/iii/aether/xenos.iii;STDLIB/iii/aether/xring.iii;STDLIB/iii/verba/json.iii" as u64 }
                    if k == 1u64 { return "STDLIB/iii/verba/builder.iii;STDLIB/iii/verba/lexicon.iii;STDLIB/iii/omnia/eidolos.iii;STDLIB/iii/memoria/arena.iii" as u64 } }
    return 0u64
}
/* parse one manifest row into a registration */
fn ho_ingest_row(i: u64) -> i64 {
    let row : u64 = ho_mrow(i)
    if row == 0u64 { return -1i64 }
    let p : *u8 = row as *u8
    /* name up to '|' */
    let mut ne : u64 = 0u64
    while p[ne] != 124u8 { ne = ne + 1u64 }
    /* class char */
    let cch : u8 = p[ne + 1u64]
    let mut cls : u8 = 2u8
    if cch == 80u8 { cls = 1u8 }
    /* probe: after second '|' up to third '|' */
    let ps : u64 = ne + 3u64
    let mut pe : u64 = ps
    while p[pe] != 124u8 { pe = pe + 1u64 }
    let mut probe : u64 = row + ps
    if cls == 2u8 { probe = 0u64 }
    if pe == ps + 1u64 { if p[ps] == 45u8 { probe = 0u64 } }
    /* face: after third '|' to NUL -- the literal's own tail is the face string */
    let face : u64 = row + pe + 1u64
    let idx : i64 = ho_reg(row, ne, cls, probe, face)
    if idx < 0i64 { return idx }
    ho_set_deps(idx as u64, ho_mdep(i, 0u64), ho_mdep(i, 1u64), ho_mdep(i, 2u64))
    return idx
}
/* NOTE: probe pointers returned by ho_probe point INTO the row literal and are
 * '|'-terminated, not NUL-terminated.  ho_probe_len gives the span. */
fn ho_probe_len(i: u64) -> u64 @export {
    let pr : u64 = ho_probe(i)
    if pr == 0u64 { return 0u64 }
    let p : *u8 = pr as *u8
    let mut n : u64 = 0u64
    while p[n] != 124u8 { n = n + 1u64 }
    return n
}
fn ho_ingest() -> i64 @export {
    let mut i : u64 = 0u64
    let mut cnt : i64 = 0i64
    while i < 64u64 {
        if ho_mrow(i) == 0u64 { i = 64u64 } else {
            if ho_ingest_row(i) >= 0i64 { cnt = cnt + 1i64 }
            i = i + 1u64
        }
    }
    return cnt
}

/* ==================== THE SELF-PROOF ====================
 * Runs at EVERY invocation of the organism, on the reset table, before any
 * verb or skill moves; a failed arm refuses the whole face (exit 9).  Resets
 * and re-ingests the live manifest after. */
fn ho_selfprove() -> u64 @export {
    ho_reset()
    /* arm 21: registration -- dedupe, find, unknown -> SENT */
    let a : i64 = ho_reg("cell_a" as u64, 6u64, 1u8, 0u64, "x" as u64)
    let b : i64 = ho_reg("cell_b" as u64, 6u64, 2u8, 0u64, "y" as u64)
    let a2 : i64 = ho_reg("cell_a" as u64, 6u64, 1u8, 0u64, "x" as u64)
    if a != 0i64 { ho_reset()   ho_ingest()   return 21u64 }
    if b != 1i64 { ho_reset()   ho_ingest()   return 21u64 }
    if a2 != 0i64 { ho_reset()   ho_ingest()   return 21u64 }
    if ho_count() != 2u64 { ho_reset()   ho_ingest()   return 21u64 }
    if ho_find("cell_z" as u64, 6u64) != HO_SENT { ho_reset()   ho_ingest()   return 21u64 }
    /* arm 22: the fold is last-wins by sequence within a mode class */
    if ho_fold_rec("cell_a" as u64, 6u64, 111u64, 0u64, 2u8, 5u64) != 1u64 { ho_reset()   ho_ingest()   return 22u64 }
    ho_fold_rec("cell_a" as u64, 6u64, 222u64, 7u64, 2u8, 3u64)
    if HO_PPIN[0u64] != 111u64 { ho_reset()   ho_ingest()   return 22u64 }
    if HO_PEXIT[0u64] != 0u64 { ho_reset()   ho_ingest()   return 22u64 }
    /* arm 23: THE MODE LAW -- a WORK record never displaces PROOF standing */
    ho_fold_rec("cell_a" as u64, 6u64, 333u64, 55u64, 1u8, 9u64)
    if HO_PPIN[0u64] != 111u64 { ho_reset()   ho_ingest()   return 23u64 }
    if HO_WEXIT[0u64] != 55u64 { ho_reset()   ho_ingest()   return 23u64 }
    ho_set_live_pin(0u64, 111u64)
    if ho_standing(0u64) != 0u64 { ho_reset()   ho_ingest()   return 23u64 }
    /* arm 24: due-on-drift -- pin drift wakes the skill; a match lets it rest */
    if ho_due(0u64) != 0u64 { ho_reset()   ho_ingest()   return 24u64 }
    ho_set_live_pin(0u64, 999u64)
    if ho_standing(0u64) != 1u64 { ho_reset()   ho_ingest()   return 24u64 }
    if ho_due(0u64) != 1u64 { ho_reset()   ho_ingest()   return 24u64 }
    if ho_due(1u64) != 0u64 { ho_reset()   ho_ingest()   return 24u64 }   /* U-class: never "due", counted apart */
    /* arm 25: teeth -- garbage refused + counted; an unknown mode refused */
    let mbefore : u64 = ho_malformed()
    if ho_fold_line("garbage line" as u64, 12u64) != 0u64 { ho_reset()   ho_ingest()   return 25u64 }
    if ho_malformed() != mbefore + 1u64 { ho_reset()   ho_ingest()   return 25u64 }
    if ho_fold_rec("cell_a" as u64, 6u64, 1u64, 1u64, 7u8, 99u64) != 0u64 { ho_reset()   ho_ingest()   return 25u64 }
    if ho_malformed() != mbefore + 2u64 { ho_reset()   ho_ingest()   return 25u64 }
    /* arm 26: a WELL-formed line for a known skill folds */
    let lp : *u8 = (&HO_LBUF) as *u8
    let mut at : u64 = ho_sput(lp, 0u64, "H1|cell_b|" as u64)
    at = ho_sputhex(lp, at, 4660u64)
    at = ho_sput(lp, at, "|0|P|8" as u64)
    if ho_fold_line((&HO_LBUF) as u64, at) != 1u64 { ho_reset()   ho_ingest()   return 26u64 }
    if HO_PMODE[1u64] != 1u8 { ho_reset()   ho_ingest()   return 26u64 }
    /* arm 27: VITALITY refuses over a live wound */
    ho_set_live_pin(1u64, 4660u64)
    ho_fold_rec("cell_a" as u64, 6u64, 999u64, 0u64, 2u8, 12u64)
    if ho_vitality() == 0u64 { ho_reset()   ho_ingest()   return 27u64 }
    ho_fold_rec("cell_b" as u64, 6u64, 4660u64, 7u64, 2u8, 13u64)
    if ho_standing(1u64) != 3u64 { ho_reset()   ho_ingest()   return 27u64 }
    if ho_vitality() != 0u64 { ho_reset()   ho_ingest()   return 27u64 }
    ho_reset()
    ho_ingest()
    return 0u64
}
