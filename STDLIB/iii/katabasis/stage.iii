/* STDLIB/iii/katabasis/stage.iii -- OUSIA / HYPOSTASIS / ENERGEIA: the staged-type compilation lifecycle.
 *
 * POC for the LOGOS 3-tier as III's IR staging discipline (multi-stage typing): the weave's pure logic cannot become
 * executable until it is mathematically BOUND to a hardware crystal.
 *   OUSIA      = unbound weave: pure logic, no machine, no address, no privilege.
 *   HYPOSTASIS = crystal-bound instance: the abstract term folded with the live crystal -> a machine-specific,
 *                content-addressed instantiation.  ONLY a Hypostasis may execute.
 *   ENERGEIA   = the constrained execution -- and it is gated to the proven-safe depth.
 * The strict boundary: stage_execute REJECTS an Ousia (unbound) term; binding requires a real crystal.  This makes
 * "derive-don't-hardcode" + "execute only at the proven-safe supremum" a TYPING LAW, not a convention.  Ring R0.
 * KAT: corpus 1818. */
module katabasis_stage

const STAGE_OUSIA      : u32 = 0u32
const STAGE_HYPOSTASIS : u32 = 1u32
const ST_REJECT : u32 = 0xFFFFFFFFu32

/* BIND (Ousia -> Hypostasis): fold the unbound term with the crystal address into a content-addressed instance.
 * Requires a real crystal (nonzero) -- you cannot instantiate logic without a machine to bind it to. */
fn stage_bind(ousia_term: u32, crystal_addr: u32) -> u32 @export {
    if crystal_addr == 0u32 { return ST_REJECT }   /* no crystal -> no Hypostasis */
    return (ousia_term ^ crystal_addr) & 0xFFFFFFu32
}

/* EXECUTE (Hypostasis -> Energeia): ONLY a bound term may run; an Ousia term is rejected (unbound logic is not
 * executable -- the staging law).  depth_ok gates Energeia to the proven-safe supremum. */
fn stage_execute(term: u32, stage_tag: u32, depth_ok: u8) -> u32 @export {
    if stage_tag != STAGE_HYPOSTASIS { return ST_REJECT }   /* Ousia / anything-unbound: cannot execute */
    if depth_ok != 1u8 { return ST_REJECT }                 /* beyond the proven-safe depth: refused */
    return term
}
