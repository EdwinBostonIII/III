/* STDLIB/iii/nous/bayes_search.iii -- BAYESIAN-OPTIMAL BUDGET ALLOCATION
 * (III-PHASE4-PROBABILITY, Layer 7 -- full-system integration).
 *
 * Upgrades Campaign I's search market into BAYESIAN-OPTIMAL allocation: a search budget is routed to the
 * subgoals with the highest POSTERIOR expected yield, computed exactly by numera/bayes_exact (prior x
 * likelihood).  The posterior update genuinely shifts the optimum -- when evidence favours one subgoal, the
 * Bayesian choice differs from the prior choice -- and the REGRET of any allocation (the gap to the optimal
 * posterior yield) is an exact integer, zero for the optimal choice.  Campaign I's explosion is now fought
 * with optimal, proved allocation rather than a uniform split.
 *
 * Hexad: kind_decision.  Ring: R0.  K: 1.00.  Composes numera/bayes_exact (the exact posterior) -- the
 * Pareto/cost discipline of search_market lifted to a Bayesian objective.  Determinism: integer-only.
 */
module nous_bayes_search

extern @abi(c-msvc-x64) fn bx_set(a: u64, b: u64, l0: u64, l1: u64) -> i32 from "bayes_exact.iii"
extern @abi(c-msvc-x64) fn bx_posterior_num(i: u32) -> u64 from "bayes_exact.iii"

/* set prior yields (a,b) and observed likelihoods (l0,l1); the posterior yield of subgoal i is prior_i*lik_i. */
fn bs2_set(prior0: u64, prior1: u64, lik0: u64, lik1: u64) -> i32 @export {
    return bx_set(prior0, prior1, lik0, lik1)
}

/* the posterior expected yield of subgoal i. */
fn bs2_posterior_yield(i: u32) -> u64 @export { return bx_posterior_num(i) }

/* the Bayesian-optimal subgoal = argmax posterior yield (ties -> lower index). */
fn bs2_best() -> u32 @export {
    if bx_posterior_num(0u32) >= bx_posterior_num(1u32) { return 0u32 }
    return 1u32
}

/* the regret of funding subgoal i = best posterior yield - yield_i (0 for the optimal choice). */
fn bs2_regret(i: u32) -> u64 @export {
    let y0 : u64 = bx_posterior_num(0u32)
    let y1 : u64 = bx_posterior_num(1u32)
    let mut best : u64 = y0
    if y1 > y0 { best = y1 }
    return best - bx_posterior_num(i)
}

/* ---- the PROPOSER-BUDGET allocator: the autogenesis proposers (harmony_synth, refactor_propose) drive
 * their OWN per-cycle enumeration budget through this.  It keeps its own deterministic yield state (so it
 * never disturbs the bx_* registers shared with bayes_exact/percept_infer) and applies the SAME exact
 * posterior law -- posterior_i = prior_i * observed_yield_i -- with a NON-TRIVIAL prior, so a proposer's
 * past productivity, not just its current count, shapes how much of the fixed budget it gets.  No float. */
const BS2_PRIOR0 : u64 = 2u64   /* harmony's historical-productivity prior */
const BS2_PRIOR1 : u64 = 1u64   /* refactor's prior */

var BS2_Y0 : u64 = 1u64         /* last observed harmony yield */
var BS2_Y1 : u64 = 1u64         /* last observed refactor yield */

/* a proposer reports its observed yield (its candidate count this scan) for next cycle's allocation. */
fn bs2_observe(i: u32, y: u64) -> i32 @export {
    if i == 0u32 { BS2_Y0 = y } else { BS2_Y1 = y }
    return 0i32
}

/* posterior expected yield of proposer i = prior_i * observed_yield_i (the exact bayes_exact law). */
fn bs2_post(i: u32) -> u64 {
    if i == 0u32 { return BS2_PRIOR0 * BS2_Y0 }
    return BS2_PRIOR1 * BS2_Y1
}

/* proposer i's share of a fixed total enumeration budget: total * post_i / (post_0 + post_1).  The
 * higher-posterior proposer enumerates more candidates; a starved one collapses to its baseline.  Equal
 * observed yields still favour harmony (the 2:1 prior) -- a raw-yield divider cannot reproduce this. */
fn bs2_budget(total: u64, i: u32) -> u64 @export {
    let p0 : u64 = bs2_post(0u32)
    let p1 : u64 = bs2_post(1u32)
    let tot : u64 = p0 + p1
    if tot == 0u64 { return total }
    let pi : u64 = bs2_post(i)
    return (total * pi) / tot
}

/* the Bayesian-optimal lead proposer (0 = harmony, 1 = refactor) by posterior yield. */
fn bs2_lead() -> u32 @export {
    if bs2_post(0u32) >= bs2_post(1u32) { return 0u32 }
    return 1u32
}
