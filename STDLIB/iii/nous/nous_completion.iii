/* STDLIB/iii/nous/nous_completion.iii -- confluence-completion acceleration (nous P4).
 *
 * The load-bearing first job of the proposer: Knuth-Bendix-style completion.  For each
 * divergent critical pair, nous proposes joining rewrites; the engine CHECKS each (every
 * proposal must canonicalise the two sides to the same normal form -- the join is never
 * trusted, always re-checked).  The completion resolves into the trichotomy:
 *   SATURATED -- ALL critical pairs join => the rule family is confluent; ship a
 *                cad-sealed convergence certificate.
 *   GAP       -- budget spent before all pairs were checked => REFUSE the promotion; the
 *                engine stays in its last proven-confluent state (the bones do not break).
 *   REFUTED   -- a pair does NOT join (non-orientable) => reject the family with proof.
 *
 * THE SAFETY PROPERTY (the negative arm): SATURATED requires EVERY pair checked AND
 * joined.  A budget that checks only some pairs yields GAP, never SATURATED -- a partial
 * completion can never masquerade as a proven-confluent one.  This is the completion
 * analogue of nous_search's keystone.
 *
 * At M13 there are no new rule families, so the critical pairs here are SYNTHETIC
 * (constructed trit-op overlaps): a commutative AND pair joins (min is symmetric); an
 * AND-vs-OR pair does not (min != max).  The live dynamic critical-pair enumeration, sealed by the
 * Confluence-Core Certificate (xii_conf_cert; route-S retired the static xii_critpairs), is the M14
 * wiring (B-8); this module proves the completion DISCIPLINE now.
 *
 * Hexad: kind_decision.  Ring: R0.  K: 1.00.  NIH: xii_term + xii_canonicalise + cad.
 * Determinism: integer-only; ==/!= compares; single-line fns.  (Tags NOUS_CMP_* are
 * distinct from nous_search's NOUS_* to avoid the trap-2 link-global collision.)
 */
module nous_completion

extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_fusion2(kind: u8, a: u32, b: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_alloc() -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_set_kind(idx: u32, kind: u8) -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_set_child_a(idx: u32, ref: u32) -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_canonicalise(t: u32) -> u32 from "xii_canonicalise.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_struct_eq(a: u32, b: u32) -> u8 from "xii_rewrite.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_is_zero(a: *u8) -> u8 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_eq(a: *u8, b: *u8) -> u8 from "cad.iii"

const NOUS_CMP_SATURATED : u8  = 0u8
const NOUS_CMP_GAP       : u8  = 1u8
const NOUS_CMP_REFUTED   : u8  = 2u8
const NOUS_CMP_TRIT_VAL  : u8  = 24u8
const NOUS_CMP_TRIT_AND  : u8  = 26u8
const NOUS_CMP_TRIT_OR   : u8  = 27u8
const NOUS_CMP_TRIT_NOT  : u8  = 25u8
const NOUS_CMP_TRIT_SUM  : u8  = 28u8
const NOUS_CMP_TRIT_MUL  : u8  = 29u8
const NOUS_CMP_CAD_KECCAK : u32 = 1u32

var NOUS_CMP_CERT : [u8; 32]   /* cad-sealed SATURATED convergence certificate */
var NOUS_CMP_CERT2 : [u8; 32]  /* [CUT-11] second cert buffer for the non-vacuity (binding) checks */
var NOUS_CMP_TAG  : [u8; 9]    /* [CUT-11] cert preimage: n_pairs LE4 || budget LE4 || verdict (was [u8;4] binding only the verdict -> every cert identical) */

fn cmp_mkval(v: i32) -> u32 { return xii_term_make_basis(NOUS_CMP_TRIT_VAL, (v + 1i32) as u32) }

/* Does the critical pair (opa(a0,a1), opb(b0,b1)) JOIN?  Build both in one arena,
 * canonicalise each, and compare normal forms.  1 = joins (confluent at this overlap). */
fn cmp_pair_joins(opa: u8, a0: i32, a1: i32, opb: u8, b0: i32, b1: i32) -> u8 {
    xii_term_arena_reset()
    let ta : u32 = xii_term_make_fusion2(opa, cmp_mkval(a0), cmp_mkval(a1))
    let tb : u32 = xii_term_make_fusion2(opb, cmp_mkval(b0), cmp_mkval(b1))
    let ra : u32 = xii_canonicalise(ta)
    let rb : u32 = xii_canonicalise(tb)
    return xii_rewrite_struct_eq(ra, rb)
}

/* Run completion over n_pairs synthetic critical pairs under a pair-budget.  If
 * force_nonjoin=1, pair 0 is the non-joinable AND-vs-OR overlap (the REFUTED witness). */
fn nous_complete(n_pairs: u32, budget: u32, force_nonjoin: u8) -> u8 @export {
    let mut checked : u32 = 0u32
    let mut i : u32 = 0u32
    while i < n_pairs {
        if checked >= budget { return NOUS_CMP_GAP }   /* budget spent: pairs unchecked -> cannot certify */
        let mut joins : u8 = 0u8
        if force_nonjoin == 1u8 {
            if i == 0u32 {
                joins = cmp_pair_joins(NOUS_CMP_TRIT_AND, -1i32, 1i32, NOUS_CMP_TRIT_OR, -1i32, 1i32)
            } else {
                joins = cmp_pair_joins(NOUS_CMP_TRIT_AND, -1i32, 1i32, NOUS_CMP_TRIT_AND, 1i32, -1i32)
            }
        } else {
            joins = cmp_pair_joins(NOUS_CMP_TRIT_AND, -1i32, 1i32, NOUS_CMP_TRIT_AND, 1i32, -1i32)
        }
        if joins != 1u8 { return NOUS_CMP_REFUTED }    /* non-joinable overlap -> reject the family */
        checked = checked + 1u32
        i = i + 1u32
    }
    return NOUS_CMP_SATURATED                          /* every pair checked AND joined -> confluent */
}

/* On SATURATED, seal the convergence certificate (cad of the verdict).  Returns 0 if
 * sealed (and the family may be promoted), -1 if the completion did not saturate (no
 * cert -- promotion refused). */
fn nous_complete_cert(n_pairs: u32, budget: u32, out32: *u8) -> i32 @export {
    if (out32 as u64) == 0u64 { return -1i32 }
    let outcome : u8 = nous_complete(n_pairs, budget, 0u8)
    if outcome != NOUS_CMP_SATURATED { return -1i32 }
    NOUS_CMP_TAG[0u64] = (n_pairs & 0xFFu32) as u8         /* [CUT-11] bind the family it certifies */
    NOUS_CMP_TAG[1u64] = ((n_pairs >> 8u32)  & 0xFFu32) as u8
    NOUS_CMP_TAG[2u64] = ((n_pairs >> 16u32) & 0xFFu32) as u8
    NOUS_CMP_TAG[3u64] = ((n_pairs >> 24u32) & 0xFFu32) as u8
    NOUS_CMP_TAG[4u64] = (budget & 0xFFu32) as u8
    NOUS_CMP_TAG[5u64] = ((budget >> 8u32)  & 0xFFu32) as u8
    NOUS_CMP_TAG[6u64] = ((budget >> 16u32) & 0xFFu32) as u8
    NOUS_CMP_TAG[7u64] = ((budget >> 24u32) & 0xFFu32) as u8
    NOUS_CMP_TAG[8u64] = NOUS_CMP_SATURATED
    cad_oneshot(NOUS_CMP_CAD_KECCAK, (&NOUS_CMP_TAG as u64) as *u8, 9u64, out32)
    return 0i32
}

/* idempotence overlap: op(a,a) canonicalises to the basis a (a confluent canonicaliser with the idempotence
 * rule joins op(a,a) with a). fusion-vs-basis normal-form comparison. */
fn cmp_idem_joins(op: u8, a: i32) -> u8 {
    xii_term_arena_reset()
    let t1 : u32 = xii_term_make_fusion2(op, cmp_mkval(a), cmp_mkval(a))
    let t2 : u32 = cmp_mkval(a)
    let r1 : u32 = xii_canonicalise(t1)
    let r2 : u32 = xii_canonicalise(t2)
    return xii_rewrite_struct_eq(r1, r2)
}

/* a general algebraic-law overlap: op(a,b) canonicalises to the basis reduct r (the canonicaliser's rule for
 * this op/operand reduces op(a,b) to r). fusion-vs-basis normal-form comparison. */
fn cmp_law_joins(op: u8, a: i32, b: i32, r: i32) -> u8 {
    xii_term_arena_reset()
    let t1 : u32 = xii_term_make_fusion2(op, cmp_mkval(a), cmp_mkval(b))
    let t2 : u32 = cmp_mkval(r)
    let r1 : u32 = xii_canonicalise(t1)
    let r2 : u32 = xii_canonicalise(t2)
    return xii_rewrite_struct_eq(r1, r2)
}

/* NOT (unary) construction via the low-level term API (no xii_term change needed): alloc + kind=TRIT_NOT +
 * child_a = the operand. */
fn cmp_mknot(a: i32) -> u32 {
    let n : u32 = xii_term_alloc()
    xii_term_set_kind(n, NOUS_CMP_TRIT_NOT)
    xii_term_set_child_a(n, cmp_mkval(a))
    return n
}

/* negation-evaluation overlap: NOT(a) canonicalises to the trit negation -a. */
fn cmp_negeval_joins(a: i32) -> u8 {
    xii_term_arena_reset()
    let t1 : u32 = cmp_mknot(a)
    let t2 : u32 = cmp_mkval(0i32 - a)
    let r1 : u32 = xii_canonicalise(t1)
    let r2 : u32 = xii_canonicalise(t2)
    return xii_rewrite_struct_eq(r1, r2)
}

/* double-negation overlap: NOT(NOT(a)) canonicalises to a (the involution law). */
fn cmp_dneg_joins(a: i32) -> u8 {
    xii_term_arena_reset()
    let outer : u32 = xii_term_alloc()
    xii_term_set_kind(outer, NOUS_CMP_TRIT_NOT)
    xii_term_set_child_a(outer, cmp_mknot(a))
    let r1 : u32 = xii_canonicalise(outer)
    let r2 : u32 = xii_canonicalise(cmp_mkval(a))
    return xii_rewrite_struct_eq(r1, r2)
}

/* De Morgan overlap: NOT(op(a,b)) canonicalises to dual(NOT a, NOT b) (dual(AND)=OR, dual(OR)=AND). */
fn cmp_demorgan_joins(op: u8, dual: u8, a: i32, b: i32) -> u8 {
    xii_term_arena_reset()
    let inner : u32 = xii_term_make_fusion2(op, cmp_mkval(a), cmp_mkval(b))
    let not_inner : u32 = xii_term_alloc()
    xii_term_set_kind(not_inner, NOUS_CMP_TRIT_NOT)
    xii_term_set_child_a(not_inner, inner)
    let dual_side : u32 = xii_term_make_fusion2(dual, cmp_mknot(a), cmp_mknot(b))
    let r1 : u32 = xii_canonicalise(not_inner)
    let r2 : u32 = xii_canonicalise(dual_side)
    return xii_rewrite_struct_eq(r1, r2)
}

/* associativity overlap: op(op(a,b),c) canonicalises to op(a,op(b,c)). nested fusion terms. */
fn cmp_assoc_joins(op: u8, a: i32, b: i32, c: i32) -> u8 {
    xii_term_arena_reset()
    let ab : u32 = xii_term_make_fusion2(op, cmp_mkval(a), cmp_mkval(b))
    let left : u32 = xii_term_make_fusion2(op, ab, cmp_mkval(c))
    let bc : u32 = xii_term_make_fusion2(op, cmp_mkval(b), cmp_mkval(c))
    let right : u32 = xii_term_make_fusion2(op, cmp_mkval(a), bc)
    let r1 : u32 = xii_canonicalise(left)
    let r2 : u32 = xii_canonicalise(right)
    return xii_rewrite_struct_eq(r1, r2)
}

/* distributivity overlap: op(a, dual(b,c)) canonicalises to dual(op(a,b), op(a,c)). */
fn cmp_distrib_joins(op: u8, dual: u8, a: i32, b: i32, c: i32) -> u8 {
    xii_term_arena_reset()
    let bc : u32 = xii_term_make_fusion2(dual, cmp_mkval(b), cmp_mkval(c))
    let left : u32 = xii_term_make_fusion2(op, cmp_mkval(a), bc)
    let ab : u32 = xii_term_make_fusion2(op, cmp_mkval(a), cmp_mkval(b))
    let ac : u32 = xii_term_make_fusion2(op, cmp_mkval(a), cmp_mkval(c))
    let right : u32 = xii_term_make_fusion2(dual, ab, ac)
    let r1 : u32 = xii_canonicalise(left)
    let r2 : u32 = xii_canonicalise(right)
    return xii_rewrite_struct_eq(r1, r2)
}

/* absorption overlap: op(a, dual(a,b)) canonicalises to a (the lattice absorption law). */
fn cmp_absorb_joins(op: u8, dual: u8, a: i32, b: i32) -> u8 {
    xii_term_arena_reset()
    let ab : u32 = xii_term_make_fusion2(dual, cmp_mkval(a), cmp_mkval(b))
    let left : u32 = xii_term_make_fusion2(op, cmp_mkval(a), ab)
    let r1 : u32 = xii_canonicalise(left)
    let r2 : u32 = xii_canonicalise(cmp_mkval(a))
    return xii_rewrite_struct_eq(r1, r2)
}

/* additive-inverse overlap: SUM(a, NOT(a)) canonicalises to 0 (NOT(a) = -a is the SUM-inverse of a -- the only
 * SUM law beyond commutativity/identity that holds, since SUM is SATURATING and hence NOT associative). */
fn cmp_addinv_joins(a: i32) -> u8 {
    xii_term_arena_reset()
    let sm : u32 = xii_term_make_fusion2(NOUS_CMP_TRIT_SUM, cmp_mkval(a), cmp_mknot(a))
    let r1 : u32 = xii_canonicalise(sm)
    let r2 : u32 = xii_canonicalise(cmp_mkval(0i32))
    return xii_rewrite_struct_eq(r1, r2)
}

/* the number of LIVE-enumerated critical-pair overlaps spanning the COMPLETE trit algebra (all 6 ops --
 * VAL/NOT/AND/OR/SUM/MUL).  De Morgan sub-algebra (186): 18 commutativity + 6 idempotence + 6 identity + 6
 * annihilator + 3 neg-eval + 3 double-neg + 18 De Morgan + 54 assoc + 54 distrib + 18 absorption.  SUM/MUL
 * arithmetic (84, ONLY the universally-holding laws -- SUM-associativity is EXCLUDED, it fails under saturation):
 * 18 SUM/MUL commutativity + 9 (SUM-identity-0, MUL-identity-1, MUL-annihilator-0) + 27 MUL-associativity +
 * 27 MUL-distributivity-over-SUM + 3 additive-inverse.  Total = 270. */
fn nous_live_pair_count() -> u32 @export { return 270u32 }

/* [M14 B-8] LIVE DYNAMIC critical-pair enumeration -- the increment that lifts nous_complete from
 * hand-constructed SYNTHETIC pairs to the trit-op algebra's critical pairs DERIVED on the fly: for every
 * commutative op (AND=min, OR=max) it walks the WHOLE operand domain and checks the commutativity overlap
 * op(a,b) vs op(b,a) and the idempotence overlap op(a,a) vs a -- every one a critical pair a confluent
 * canonicaliser MUST join.  Same trichotomy + safety property as nous_complete: a budget that checks only some
 * overlaps yields GAP, never SATURATED (a partial enumeration can never masquerade as a proven-confluent one). */
fn nous_complete_live(budget: u32) -> u8 @export {
    let mut checked : u32 = 0u32
    let mut oi : u32 = 0u32
    while oi < 2u32 {
        let mut op : u8 = NOUS_CMP_TRIT_AND
        if oi == 1u32 { op = NOUS_CMP_TRIT_OR }
        let mut a : i32 = -1i32
        while a <= 1i32 {
            let mut b : i32 = -1i32
            while b <= 1i32 {
                if checked >= budget { return NOUS_CMP_GAP }
                if cmp_pair_joins(op, a, b, op, b, a) != 1u8 { return NOUS_CMP_REFUTED }
                checked = checked + 1u32
                b = b + 1i32
            }
            a = a + 1i32
        }
        oi = oi + 1u32
    }
    let mut oj : u32 = 0u32
    while oj < 2u32 {
        let mut op2 : u8 = NOUS_CMP_TRIT_AND
        if oj == 1u32 { op2 = NOUS_CMP_TRIT_OR }
        let mut c : i32 = -1i32
        while c <= 1i32 {
            if checked >= budget { return NOUS_CMP_GAP }
            if cmp_idem_joins(op2, c) != 1u8 { return NOUS_CMP_REFUTED }
            checked = checked + 1u32
            c = c + 1i32
        }
        oj = oj + 1u32
    }
    /* identity overlaps: AND(a,1)=a (1 is the AND-identity = lattice top), OR(a,-1)=a (-1 is the OR-identity
     * = lattice bottom), for all a */
    let mut d : i32 = -1i32
    while d <= 1i32 {
        if checked >= budget { return NOUS_CMP_GAP }
        if cmp_law_joins(NOUS_CMP_TRIT_AND, d, 1i32, d) != 1u8 { return NOUS_CMP_REFUTED }
        checked = checked + 1u32
        if checked >= budget { return NOUS_CMP_GAP }
        if cmp_law_joins(NOUS_CMP_TRIT_OR, d, -1i32, d) != 1u8 { return NOUS_CMP_REFUTED }
        checked = checked + 1u32
        d = d + 1i32
    }
    /* annihilator overlaps: AND(a,-1)=-1 (bottom absorbs under min), OR(a,1)=1 (top absorbs under max), all a */
    let mut e : i32 = -1i32
    while e <= 1i32 {
        if checked >= budget { return NOUS_CMP_GAP }
        if cmp_law_joins(NOUS_CMP_TRIT_AND, e, -1i32, -1i32) != 1u8 { return NOUS_CMP_REFUTED }
        checked = checked + 1u32
        if checked >= budget { return NOUS_CMP_GAP }
        if cmp_law_joins(NOUS_CMP_TRIT_OR, e, 1i32, 1i32) != 1u8 { return NOUS_CMP_REFUTED }
        checked = checked + 1u32
        e = e + 1i32
    }
    /* negation-evaluation overlaps: NOT(a) vs -a for all a */
    let mut f : i32 = -1i32
    while f <= 1i32 {
        if checked >= budget { return NOUS_CMP_GAP }
        if cmp_negeval_joins(f) != 1u8 { return NOUS_CMP_REFUTED }
        checked = checked + 1u32
        f = f + 1i32
    }
    /* double-negation overlaps: NOT(NOT(a)) vs a for all a */
    let mut g : i32 = -1i32
    while g <= 1i32 {
        if checked >= budget { return NOUS_CMP_GAP }
        if cmp_dneg_joins(g) != 1u8 { return NOUS_CMP_REFUTED }
        checked = checked + 1u32
        g = g + 1i32
    }
    /* De Morgan overlaps: NOT(AND(a,b)) vs OR(NOT a,NOT b) and NOT(OR(a,b)) vs AND(NOT a,NOT b), all (a,b) */
    let mut h : i32 = -1i32
    while h <= 1i32 {
        let mut k : i32 = -1i32
        while k <= 1i32 {
            if checked >= budget { return NOUS_CMP_GAP }
            if cmp_demorgan_joins(NOUS_CMP_TRIT_AND, NOUS_CMP_TRIT_OR, h, k) != 1u8 { return NOUS_CMP_REFUTED }
            checked = checked + 1u32
            if checked >= budget { return NOUS_CMP_GAP }
            if cmp_demorgan_joins(NOUS_CMP_TRIT_OR, NOUS_CMP_TRIT_AND, h, k) != 1u8 { return NOUS_CMP_REFUTED }
            checked = checked + 1u32
            k = k + 1i32
        }
        h = h + 1i32
    }
    /* associativity overlaps: op(op(a,b),c) vs op(a,op(b,c)) for op in {AND,OR}, all (a,b,c) -- 2x27=54 */
    let mut p : u32 = 0u32
    while p < 2u32 {
        let mut aop : u8 = NOUS_CMP_TRIT_AND
        if p == 1u32 { aop = NOUS_CMP_TRIT_OR }
        let mut a3 : i32 = -1i32
        while a3 <= 1i32 {
            let mut b3 : i32 = -1i32
            while b3 <= 1i32 {
                let mut c3 : i32 = -1i32
                while c3 <= 1i32 {
                    if checked >= budget { return NOUS_CMP_GAP }
                    if cmp_assoc_joins(aop, a3, b3, c3) != 1u8 { return NOUS_CMP_REFUTED }
                    checked = checked + 1u32
                    c3 = c3 + 1i32
                }
                b3 = b3 + 1i32
            }
            a3 = a3 + 1i32
        }
        p = p + 1u32
    }
    /* distributivity overlaps: AND over OR and OR over AND, all (a,b,c) -- 2x27=54 */
    let mut q : u32 = 0u32
    while q < 2u32 {
        let mut dop : u8 = NOUS_CMP_TRIT_AND
        let mut ddual : u8 = NOUS_CMP_TRIT_OR
        if q == 1u32 { dop = NOUS_CMP_TRIT_OR  ddual = NOUS_CMP_TRIT_AND }
        let mut a4 : i32 = -1i32
        while a4 <= 1i32 {
            let mut b4 : i32 = -1i32
            while b4 <= 1i32 {
                let mut c4 : i32 = -1i32
                while c4 <= 1i32 {
                    if checked >= budget { return NOUS_CMP_GAP }
                    if cmp_distrib_joins(dop, ddual, a4, b4, c4) != 1u8 { return NOUS_CMP_REFUTED }
                    checked = checked + 1u32
                    c4 = c4 + 1i32
                }
                b4 = b4 + 1i32
            }
            a4 = a4 + 1i32
        }
        q = q + 1u32
    }
    /* absorption overlaps: AND(a,OR(a,b))=a and OR(a,AND(a,b))=a, all (a,b) -- 2x9=18 */
    let mut s : u32 = 0u32
    while s < 2u32 {
        let mut sop : u8 = NOUS_CMP_TRIT_AND
        let mut sdual : u8 = NOUS_CMP_TRIT_OR
        if s == 1u32 { sop = NOUS_CMP_TRIT_OR  sdual = NOUS_CMP_TRIT_AND }
        let mut a5 : i32 = -1i32
        while a5 <= 1i32 {
            let mut b5 : i32 = -1i32
            while b5 <= 1i32 {
                if checked >= budget { return NOUS_CMP_GAP }
                if cmp_absorb_joins(sop, sdual, a5, b5) != 1u8 { return NOUS_CMP_REFUTED }
                checked = checked + 1u32
                b5 = b5 + 1i32
            }
            a5 = a5 + 1i32
        }
        s = s + 1u32
    }
    /* ===== SUM/MUL ARITHMETIC algebra -- ONLY the universally-holding laws (SUM is saturating => no assoc) ===== */
    /* SUM & MUL commutativity: 2 ops x 9 = 18 */
    let mut t : u32 = 0u32
    while t < 2u32 {
        let mut mop : u8 = NOUS_CMP_TRIT_SUM
        if t == 1u32 { mop = NOUS_CMP_TRIT_MUL }
        let mut a6 : i32 = -1i32
        while a6 <= 1i32 {
            let mut b6 : i32 = -1i32
            while b6 <= 1i32 {
                if checked >= budget { return NOUS_CMP_GAP }
                if cmp_pair_joins(mop, a6, b6, mop, b6, a6) != 1u8 { return NOUS_CMP_REFUTED }
                checked = checked + 1u32
                b6 = b6 + 1i32
            }
            a6 = a6 + 1i32
        }
        t = t + 1u32
    }
    /* SUM identity 0 + MUL identity 1 + MUL annihilator 0: 3 x 3 = 9 */
    let mut a7 : i32 = -1i32
    while a7 <= 1i32 {
        if checked >= budget { return NOUS_CMP_GAP }
        if cmp_law_joins(NOUS_CMP_TRIT_SUM, a7, 0i32, a7) != 1u8 { return NOUS_CMP_REFUTED }
        checked = checked + 1u32
        if checked >= budget { return NOUS_CMP_GAP }
        if cmp_law_joins(NOUS_CMP_TRIT_MUL, a7, 1i32, a7) != 1u8 { return NOUS_CMP_REFUTED }
        checked = checked + 1u32
        if checked >= budget { return NOUS_CMP_GAP }
        if cmp_law_joins(NOUS_CMP_TRIT_MUL, a7, 0i32, 0i32) != 1u8 { return NOUS_CMP_REFUTED }
        checked = checked + 1u32
        a7 = a7 + 1i32
    }
    /* MUL associativity: 27 */
    let mut a8 : i32 = -1i32
    while a8 <= 1i32 {
        let mut b8 : i32 = -1i32
        while b8 <= 1i32 {
            let mut c8 : i32 = -1i32
            while c8 <= 1i32 {
                if checked >= budget { return NOUS_CMP_GAP }
                if cmp_assoc_joins(NOUS_CMP_TRIT_MUL, a8, b8, c8) != 1u8 { return NOUS_CMP_REFUTED }
                checked = checked + 1u32
                c8 = c8 + 1i32
            }
            b8 = b8 + 1i32
        }
        a8 = a8 + 1i32
    }
    /* MUL distributivity over SUM: MUL(a,SUM(b,c)) = SUM(MUL(a,b),MUL(a,c)) -- 27 (holds despite SUM saturation) */
    let mut a9 : i32 = -1i32
    while a9 <= 1i32 {
        let mut b9 : i32 = -1i32
        while b9 <= 1i32 {
            let mut c9 : i32 = -1i32
            while c9 <= 1i32 {
                if checked >= budget { return NOUS_CMP_GAP }
                if cmp_distrib_joins(NOUS_CMP_TRIT_MUL, NOUS_CMP_TRIT_SUM, a9, b9, c9) != 1u8 { return NOUS_CMP_REFUTED }
                checked = checked + 1u32
                c9 = c9 + 1i32
            }
            b9 = b9 + 1i32
        }
        a9 = a9 + 1i32
    }
    /* additive inverse: SUM(a, NOT a) = 0 -- 3 */
    let mut aa : i32 = -1i32
    while aa <= 1i32 {
        if checked >= budget { return NOUS_CMP_GAP }
        if cmp_addinv_joins(aa) != 1u8 { return NOUS_CMP_REFUTED }
        checked = checked + 1u32
        aa = aa + 1i32
    }
    return NOUS_CMP_SATURATED
}

fn nous_completion_selftest() -> u64 @export {
    /* all 3 joinable pairs, generous budget -> SATURATED */
    if nous_complete(3u32, 5u32, 0u8) != NOUS_CMP_SATURATED { return 1u64 }
    /* same family, budget < pairs -> GAP (promotion refused; NOT certified) */
    if nous_complete(3u32, 2u32, 0u8) != NOUS_CMP_GAP { return 2u64 }
    if nous_complete(3u32, 0u32, 0u8) != NOUS_CMP_GAP { return 3u64 }
    /* a non-joinable pair present -> REFUTED */
    if nous_complete(3u32, 5u32, 1u8) != NOUS_CMP_REFUTED { return 4u64 }
    /* the negative arm: a partial check (budget<pairs) must NOT be SATURATED */
    if nous_complete(3u32, 1u32, 0u8) == NOUS_CMP_SATURATED { return 5u64 }
    /* direct join witnesses */
    if cmp_pair_joins(NOUS_CMP_TRIT_AND, -1i32, 1i32, NOUS_CMP_TRIT_AND, 1i32, -1i32) != 1u8 { return 6u64 }  /* commutative -> joins */
    if cmp_pair_joins(NOUS_CMP_TRIT_AND, -1i32, 1i32, NOUS_CMP_TRIT_OR, -1i32, 1i32) != 0u8 { return 7u64 }   /* AND != OR -> not joinable */
    /* SATURATED ships a non-zero cad cert; a non-saturating completion ships none */
    let c : *u8 = (&NOUS_CMP_CERT as u64) as *u8
    if nous_complete_cert(3u32, 5u32, c) != 0i32 { return 8u64 }
    if cad_is_zero(c) != 0u8 { return 9u64 }
    if nous_complete_cert(3u32, 2u32, c) != -1i32 { return 10u64 }   /* GAP -> no cert (promotion refused) */
    /* [CUT-11] NON-VACUITY: the cert must BIND the (n_pairs, budget) it certifies, not a constant.
     * On the unfixed code (which hashed only the constant verdict byte) checks 15 and 17 FAIL
     * because every cert is identical regardless of the family proven. */
    let c2 : *u8 = (&NOUS_CMP_CERT2 as u64) as *u8
    if nous_complete_cert(3u32, 5u32, c)  != 0i32 { return 11u64 }
    if nous_complete_cert(3u32, 5u32, c2) != 0i32 { return 12u64 }
    if cad_eq(c, c2) != 1u8 { return 13u64 }                          /* determinism: same family -> same cert */
    if nous_complete_cert(4u32, 5u32, c2) != 0i32 { return 14u64 }
    if cad_eq(c, c2) != 0u8 { return 15u64 }                          /* different n_pairs -> DIFFERENT cert */
    if nous_complete_cert(3u32, 4u32, c2) != 0i32 { return 16u64 }
    if cad_eq(c, c2) != 0u8 { return 17u64 }                          /* different budget -> DIFFERENT cert */
    /* [M14 B-8] LIVE dynamic critical-pair enumeration: the trit-op commutativity + idempotence overlaps over
     * the WHOLE operand domain (24 overlaps), enumerated dynamically and ALL joining -> SATURATED (vs the
     * single synthetic witness above); the safety property holds (a partial enumeration never certifies). */
    if nous_live_pair_count() != 270u32 { return 20u64 }
    if nous_complete_live(270u32) != NOUS_CMP_SATURATED { return 21u64 }   /* all 6 ops' critical pairs join */
    if nous_complete_live(300u32) != NOUS_CMP_SATURATED { return 22u64 }   /* generous budget -> still SATURATED */
    if nous_complete_live(269u32) != NOUS_CMP_GAP { return 23u64 }         /* one overlap unchecked -> GAP */
    if nous_complete_live(0u32) != NOUS_CMP_GAP { return 24u64 }
    return 99u64
}
