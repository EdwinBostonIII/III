/* STDLIB/iii/nous/nous_conjecture_term.iii -- Conjecture increment 3: critical-pair completion over
 * STRUCTURED TERMS, with a SOUND (reduction-order) termination guard.
 *
 * SCOPE (read first): a STANDALONE demonstration of the completion ALGORITHM over a toy term algebra
 * (depth-1 f over leaf symbols). It does NOT complete III's live XII rule set and does NOT use the
 * mig4 unifier/critpair pipeline. It proves the propose->dispose->admit loop is SOUND over structured
 * terms with both ROOT and SUBTERM critical pairs.
 *
 * TERMINATION GUARD (the soundness core; reduction order, NOT reachability):
 * A prior version checked "r does not reach l" as the termination test. That is UNSOUND under subterm
 * rewriting: a leaf-rule l->r is not one edge but the family f(l,q)->f(r,q), f(p,l)->f(p,r), which a
 * leaf-only reach never sees -- so e.g. with f(0,9)->f(1,9) present, conjecturing 1->0 was wrongly
 * admitted, giving the loop f(0,9)->f(1,9)->f(0,9)->...  The sound guard is a WEIGHT REDUCTION ORDER:
 *   mu(leaf s)     = s + 1                       (in 1..256)
 *   mu(f(p,q))     = (p+1) + (q+1) + 256         (in 258..768; every f-term outweighs every leaf)
 * mu is closed under our contexts: if mu(s)>mu(t) then mu(f(s,q))>mu(f(t,q)) and mu(f(p,s))>mu(f(p,t))
 * (the +q+256 cancels), so a subterm rewrite strictly decreases mu exactly when the leaf-rule does.
 * Hence if EVERY rule satisfies mu(lhs)>mu(rhs), every rewrite strictly decreases mu (a positive
 * integer) and the system TERMINATES -- soundly, under root AND subterm rewriting. The disposer admits
 * a conjectured rule only if the WHOLE rule set (incl. the candidate) is mu-decreasing.
 *
 * Term encoding (packed u32): leaf s in 0..255 is s (< 0x10000); f(p,q) over leaf children is
 * 0x10000 | (p<<8) | q. Equality is u32 equality. Orientation bigger-mu -> smaller-mu keeps every
 * leaf-rule leaf->leaf (a leaf never outweighs an f-term), preserving the depth-1 invariant.
 *
 * Hexad: kind_decision.  Ring: R0.  K: 1.00.  NIH: self-contained.  Determinism: integer-only;
 * u32 ==/< (signed-i64 trap only); module-scope arrays; bounded BFS reach (no recursion); single writer.
 * The NTM_MAX_REACH cap bounds joinability's reach; a truncated reach yields a CONSERVATIVE not-joined
 * (so completion may over-conjecture or under-admit, never unsoundly admit -- termination is mu's job).
 */
module nous_conjecture_term

const NTM_MAX_RULES : u32 = 64u32
const NTM_MAX_REACH : u32 = 256u32
const NTM_MAX_SUCC  : u32 = 64u32
const NTM_FBIT      : u32 = 0x10000u32   /* terms >= this are f-terms */
const NTM_FW        : u32 = 256u32       /* f-term base weight: every f-term outweighs every leaf */

const NTM_CONFLUENT : i32 = 0i32
const NTM_ADMITTED  : i32 = 1i32
const NTM_REJECTED  : i32 = -1i32
const NTM_FULL      : i32 = -2i32

var NR_LHS    : [u32; 64]
var NR_RHS    : [u32; 64]
var NR_N      : u32 = 0u32
var NTM_RA    : [u32; 256]   /* reach buffer (BFS frontier+visited) */
var NTM_RA_N  : u32 = 0u32
var NTM_RB    : [u32; 256]   /* reach snapshot (for joinability intersect) */
var NTM_SUCC  : [u32; 64]    /* one-step successors scratch */
var NTM_SUCC_N: u32 = 0u32
var NTM_PAIR  : [u32; 2]     /* critical-pair sink */

/* --- term constructors / accessors --- */
fn ntm_leaf(s: u32) -> u32 @export { return s & 0xFFu32 }
fn ntm_f(p: u32, q: u32) -> u32 @export { return NTM_FBIT | ((p & 0xFFu32) << 8u32) | (q & 0xFFu32) }
fn ntm_is_f(t: u32) -> u8 @export { if t >= NTM_FBIT { return 1u8 }  return 0u8 }

fn nr_reset() -> i32 @export { NR_N = 0u32  return 0i32 }
fn nr_add(lhs: u32, rhs: u32) -> i32 @export {
    if NR_N >= NTM_MAX_RULES { return NTM_FULL }
    NR_LHS[NR_N as u64] = lhs
    NR_RHS[NR_N as u64] = rhs
    NR_N = NR_N + 1u32
    return 0i32
}
fn nr_count() -> u32 @export { return NR_N }

fn _ntm_succ_push(v: u32) {
    if NTM_SUCC_N < NTM_MAX_SUCC { NTM_SUCC[NTM_SUCC_N as u64] = v  NTM_SUCC_N = NTM_SUCC_N + 1u32 }
}

/* One-step successors of term t under the rule set, into NTM_SUCC. */
fn ntm_succ(t: u32) -> i32 {
    NTM_SUCC_N = 0u32
    let mut i : u32 = 0u32
    if t < NTM_FBIT {
        while i < NR_N {
            if NR_LHS[i as u64] == t { _ntm_succ_push(NR_RHS[i as u64]) }
            i = i + 1u32
        }
        return 0i32
    }
    let p : u32 = (t >> 8u32) & 0xFFu32
    let q : u32 = t & 0xFFu32
    while i < NR_N {
        if NR_LHS[i as u64] == t { _ntm_succ_push(NR_RHS[i as u64]) }
        i = i + 1u32
    }
    i = 0u32
    while i < NR_N {
        if NR_LHS[i as u64] < NTM_FBIT {
            if NR_LHS[i as u64] == p { _ntm_succ_push(ntm_f(NR_RHS[i as u64], q)) }
            if NR_LHS[i as u64] == q { _ntm_succ_push(ntm_f(p, NR_RHS[i as u64])) }
        }
        i = i + 1u32
    }
    return 0i32
}

/* Reach-set of `start` (BFS to fixpoint), into NTM_RA (count NTM_RA_N). Bounded by NTM_MAX_REACH;
 * on overflow the reach is truncated (joinability then conservatively reports not-joined). */
fn ntm_reach(start: u32) -> i32 {
    NTM_RA[0u64] = start
    NTM_RA_N = 1u32
    let mut head : u32 = 0u32
    while head < NTM_RA_N {
        let cur : u32 = NTM_RA[head as u64]
        head = head + 1u32
        ntm_succ(cur)
        let mut s : u32 = 0u32
        while s < NTM_SUCC_N {
            let v : u32 = NTM_SUCC[s as u64]
            let mut seen : u8 = 0u8
            let mut k : u32 = 0u32
            while k < NTM_RA_N { if NTM_RA[k as u64] == v { seen = 1u8 }  k = k + 1u32 }
            if seen == 0u8 { if NTM_RA_N < NTM_MAX_REACH { NTM_RA[NTM_RA_N as u64] = v  NTM_RA_N = NTM_RA_N + 1u32 } }
            s = s + 1u32
        }
    }
    return 0i32
}

/* 1 iff u and v reach a common term (joinable). */
fn ntm_joins(u: u32, v: u32) -> u8 @export {
    ntm_reach(u)
    let bn : u32 = NTM_RA_N
    let mut i : u32 = 0u32
    while i < bn { NTM_RB[i as u64] = NTM_RA[i as u64]  i = i + 1u32 }
    ntm_reach(v)
    let mut a : u32 = 0u32
    while a < bn {
        let mut b : u32 = 0u32
        while b < NTM_RA_N {
            if NTM_RB[a as u64] == NTM_RA[b as u64] { return 1u8 }
            b = b + 1u32
        }
        a = a + 1u32
    }
    return 0u8
}

/* The reduction-order weight: leaf s -> s+1; f(p,q) -> (p+1)+(q+1)+FW (every f-term outweighs every
 * leaf). Context-closed: a child rewrite changes mu(f) by exactly the child's mu change. */
fn ntm_measure(t: u32) -> u32 @export {
    if t < NTM_FBIT { return t + 1u32 }
    let p : u32 = (t >> 8u32) & 0xFFu32
    let q : u32 = t & 0xFFu32
    return (p + 1u32) + (q + 1u32) + NTM_FW
}

/* 1 iff EVERY rule strictly decreases mu (mu(lhs) > mu(rhs)). Then -- because mu is context-closed --
 * every rewrite (root or subterm) strictly decreases mu, so the system TERMINATES (mu is a positive
 * integer, well-founded). This is the sound termination certificate. */
fn ntm_system_terminating() -> u8 @export {
    let mut i : u32 = 0u32
    while i < NR_N {
        if ntm_measure(NR_LHS[i as u64]) <= ntm_measure(NR_RHS[i as u64]) { return 0u8 }
        i = i + 1u32
    }
    return 1u8
}

/* Find a non-joining critical pair: ROOT (two rules, same LHS, divergent RHS) or SUBTERM (a leaf-rule
 * rewrites a child of an f-rule's LHS). Writes (u,v) to out; returns 1, or 0 if confluent. */
fn ntm_find_cp(out: *u32) -> u8 @export {
    let mut i : u32 = 0u32
    while i < NR_N {
        let mut j : u32 = 0u32
        while j < NR_N {
            if i != j {
                if NR_LHS[i as u64] == NR_LHS[j as u64] {
                    if NR_RHS[i as u64] != NR_RHS[j as u64] {
                        if ntm_joins(NR_RHS[i as u64], NR_RHS[j as u64]) == 0u8 {
                            out[0u64] = NR_RHS[i as u64]
                            out[1u64] = NR_RHS[j as u64]
                            return 1u8
                        }
                    }
                }
            }
            j = j + 1u32
        }
        i = i + 1u32
    }
    i = 0u32
    while i < NR_N {
        if NR_LHS[i as u64] >= NTM_FBIT {
            let p : u32 = (NR_LHS[i as u64] >> 8u32) & 0xFFu32
            let q : u32 = NR_LHS[i as u64] & 0xFFu32
            let mut j : u32 = 0u32
            while j < NR_N {
                if NR_LHS[j as u64] < NTM_FBIT {
                    if NR_LHS[j as u64] == p {
                        let alt : u32 = ntm_f(NR_RHS[j as u64], q)
                        if ntm_joins(NR_RHS[i as u64], alt) == 0u8 {
                            out[0u64] = NR_RHS[i as u64]  out[1u64] = alt  return 1u8
                        }
                    }
                    if NR_LHS[j as u64] == q {
                        let alt2 : u32 = ntm_f(p, NR_RHS[j as u64])
                        if ntm_joins(NR_RHS[i as u64], alt2) == 0u8 {
                            out[0u64] = NR_RHS[i as u64]  out[1u64] = alt2  return 1u8
                        }
                    }
                }
                j = j + 1u32
            }
        }
        i = i + 1u32
    }
    return 0u8
}

/* The disposer (pure): is l->r an admissible completion for (u,v)?  Admit iff non-trivial (l != r),
 * the WHOLE rule set incl. l->r is mu-decreasing (sound termination, context-closed -- so it catches
 * the subterm-edge family a reachability check missed), and joinability of (u,v) is restored. Adds
 * the rule temporarily to test, then removes it. */
fn ntm_dispose_candidate(l: u32, r: u32, u: u32, v: u32) -> u8 @export {
    if l == r { return 0u8 }
    let saved : u32 = NR_N
    nr_add(l, r)
    let term : u8 = ntm_system_terminating()
    let j : u8 = ntm_joins(u, v)
    NR_N = saved
    if term == 1u8 { if j == 1u8 { return 1u8 } }
    return 0u8
}

/* PROPOSE -> DISPOSE -> ADMIT over structured terms. Orient bigger-mu -> smaller-mu so the candidate
 * strictly decreases the reduction order (equal mu -> the system-terminating check rejects it). */
fn ntm_conjecture_complete() -> i32 @export {
    if ntm_find_cp(&NTM_PAIR as *u32) == 0u8 { return NTM_CONFLUENT }
    let u : u32 = NTM_PAIR[0u64]
    let v : u32 = NTM_PAIR[1u64]
    let mut l : u32 = u
    let mut r : u32 = v
    if ntm_measure(v) > ntm_measure(u) { l = v  r = u }
    if ntm_dispose_candidate(l, r, u, v) == 1u8 {
        nr_add(l, r)
        return NTM_ADMITTED
    }
    return NTM_REJECTED
}
