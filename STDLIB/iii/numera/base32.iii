/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\base32.iii
 *
 * III STDLIB - numera::base32
 *
 * Verified Base32 (RFC 4648 alphabet) binary<->text codec, no padding: bytes are regrouped 8->5
 * bits into the alphabet "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567", and decoded 5->8 bits back. The
 * canonical case-sensitive transport encoding for identifiers, TOTP secrets, and DNS/URL-safe blobs.
 *
 * The verified property is ROUND-TRIP IDENTITY decode(encode(x)) == x for ALL byte strings x, plus
 * the RFC 4648 known-answer vector and rejection of out-of-alphabet input. NIH / self-contained
 * (pure byte/bit arithmetic via a small accumulator; no externs).
 *
 * Public API:
 *   base32_init() -> i32                                 fill the alphabet + reverse tables (call once)
 *   base32_encode(in_ptr, in_len, out_ptr) -> u32        writes ceil(in_len*8/5) chars; returns count
 *   base32_decode(in_ptr, in_len, out_ptr) -> i32        writes floor(in_len*5/8) bytes; -1 on bad char
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99 (pure; no allocation).
 */
module numera_base32

var B32_ALPHA : [u8; 32]
var B32_DEC   : [u8; 256]

fn base32_init() -> i32 @export {
    let mut i : u32 = 0u32
    while i < 26u32 { B32_ALPHA[i] = (65u32 + i) as u8 ; i = i + 1u32 }   /* 'A'..'Z' */
    let mut j : u32 = 0u32
    while j < 6u32 { B32_ALPHA[26u32 + j] = (50u32 + j) as u8 ; j = j + 1u32 }  /* '2'..'7' */
    let mut c : u32 = 0u32
    while c < 256u32 { B32_DEC[c] = 0xFFu8 ; c = c + 1u32 }
    let mut k : u32 = 0u32
    while k < 32u32 { B32_DEC[B32_ALPHA[k] as u32] = k as u8 ; k = k + 1u32 }
    return 0i32
}

fn base32_encode(in_ptr: u64, in_len: u32, out_ptr: u64) -> u32 @export {
    let ip : *u8 = in_ptr as *u8
    let op : *u8 = out_ptr as *u8
    let mut acc : u32 = 0u32
    let mut nbits : u32 = 0u32
    let mut outc : u32 = 0u32
    let mut i : u32 = 0u32
    while i < in_len {
        acc = (acc << 8u32) | (ip[i as u64] as u32)
        nbits = nbits + 8u32
        while nbits >= 5u32 {
            nbits = nbits - 5u32
            let sym : u32 = (acc >> nbits) & 0x1Fu32
            op[outc as u64] = B32_ALPHA[sym]
            outc = outc + 1u32
        }
        i = i + 1u32
    }
    if nbits > 0u32 {
        let sym : u32 = (acc << (5u32 - nbits)) & 0x1Fu32   /* pad the low bits with zeros */
        op[outc as u64] = B32_ALPHA[sym]
        outc = outc + 1u32
    }
    return outc
}

fn base32_decode(in_ptr: u64, in_len: u32, out_ptr: u64) -> i32 @export {
    let ip : *u8 = in_ptr as *u8
    let op : *u8 = out_ptr as *u8
    let mut acc : u32 = 0u32
    let mut nbits : u32 = 0u32
    let mut outc : u32 = 0u32
    let mut i : u32 = 0u32
    while i < in_len {
        let val : u32 = B32_DEC[ip[i as u64] as u32] as u32
        if val == 0xFFu32 { return -1i32 }      /* out-of-alphabet character */
        acc = (acc << 5u32) | val
        nbits = nbits + 5u32
        while nbits >= 8u32 {
            nbits = nbits - 8u32
            op[outc as u64] = ((acc >> nbits) & 0xFFu32) as u8
            outc = outc + 1u32
        }
        i = i + 1u32
    }
    return outc as i32
}

/* ===== KAT ===== */
var B32_IN  : [u8; 512]
var B32_ENC : [u8; 1024]
var B32_OUT : [u8; 512]
var B32_EXP : [u8; 10]
var B32_RNG : [u64; 1]

fn b32_rng() -> u64 {
    let mut z : u64 = B32_RNG[0u64]
    z = z ^ (z << 13u64)
    z = z ^ (z >> 7u64)
    z = z ^ (z << 17u64)
    B32_RNG[0u64] = z
    return z
}

fn b32_is_neg(x: i32) -> u32 { return (x as u32) >> 31u32 }

/* =====================================================================================
 * base32_kat -- 99 = decode(encode(x))==x for all x, self-checked:
 *   (1) RFC 4648 vector: "foobar" -> "MZXW6YTBOI";
 *   (2) ROUND-TRIP over 200 seeded random byte strings of random length 0..400;
 *   (3) NEGATIVE: an out-of-alphabet character ('0', '1', '8', '9', lowercase) is rejected (-1).
 * ===================================================================================== */
fn base32_kat() -> u64 @export {
    base32_init()

    /* (1) RFC vector */
    B32_IN[0u32]=0x66u8 ; B32_IN[1u32]=0x6Fu8 ; B32_IN[2u32]=0x6Fu8
    B32_IN[3u32]=0x62u8 ; B32_IN[4u32]=0x61u8 ; B32_IN[5u32]=0x72u8     /* "foobar" */
    let ec : u32 = base32_encode(&B32_IN as u64, 6u32, &B32_ENC as u64)
    if ec != 10u32 { return 1u64 }
    B32_EXP[0u32]=0x4Du8 ; B32_EXP[1u32]=0x5Au8 ; B32_EXP[2u32]=0x58u8 ; B32_EXP[3u32]=0x57u8 ; B32_EXP[4u32]=0x36u8
    B32_EXP[5u32]=0x59u8 ; B32_EXP[6u32]=0x54u8 ; B32_EXP[7u32]=0x42u8 ; B32_EXP[8u32]=0x4Fu8 ; B32_EXP[9u32]=0x49u8  /* "MZXW6YTBOI" */
    let mut e : u32 = 0u32
    while e < 10u32 {
        if B32_ENC[e] != B32_EXP[e] { return 2u64 }
        e = e + 1u32
    }

    /* (2) round-trip over random strings */
    B32_RNG[0u64] = 0x510E527FADE682D1u64
    let mut tr : u32 = 0u32
    while tr < 200u32 {
        let r0 : u64 = b32_rng()
        let n : u32 = (r0 % 401u64) as u32      /* 0..400 */
        let mut i : u32 = 0u32
        while i < n {
            let r1 : u64 = b32_rng()
            B32_IN[i] = (r1 & 0xFFu64) as u8
            i = i + 1u32
        }
        let cc : u32 = base32_encode(&B32_IN as u64, n, &B32_ENC as u64)
        let dc : i32 = base32_decode(&B32_ENC as u64, cc, &B32_OUT as u64)
        if b32_is_neg(dc) == 1u32 { return 3000u64 + (tr as u64) }
        if (dc as u32) != n { return 4000u64 + (tr as u64) }
        let mut v : u32 = 0u32
        while v < n {
            if B32_OUT[v] != B32_IN[v] { return 5000u64 + (tr as u64) }
            v = v + 1u32
        }
        tr = tr + 1u32
    }

    /* (3) NEGATIVE: out-of-alphabet input rejected */
    B32_ENC[0u32]=0x4Du8 ; B32_ENC[1u32]=0x30u8     /* 'M','0' -- '0' not in alphabet */
    if base32_decode(&B32_ENC as u64, 2u32, &B32_OUT as u64) != -1i32 { return 6u64 }
    B32_ENC[1u32]=0x6Du8                            /* 'm' lowercase -- not in alphabet */
    if base32_decode(&B32_ENC as u64, 2u32, &B32_OUT as u64) != -1i32 { return 7u64 }

    return 99u64
}
