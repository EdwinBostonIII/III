/* STDLIB/iii/numera/bayes_exact.iii -- EXACT BAYESIAN INFERENCE
 * (III-PHASE4-PROBABILITY, Layer 4).
 *
 * Prior times likelihood to an EXACT posterior, with an exact marginal likelihood -- all integer
 * arithmetic, no float.  For hypotheses H0,H1 with prior weights (a,b) and likelihood weights
 * (l0,l1) = (P(E|H0), P(E|H1)):
 *   joint P(E,Hi) = li * hi ,   marginal P(E) = l0*a + l1*b ,   posterior P(Hi|E) = (li*hi) / P(E).
 * The posterior is normalized BY CONSTRUCTION over the exact marginal (the posteriors sum to one exactly),
 * which is the normalization a float Bayesian update silently violates.
 *
 * Hexad: kind_cognition.  Ring: R0.  K: 1.00.  Pairs with numera/infer_exact / distribution (exact
 * rationals) and theorem_commons (the posterior-normalization is a kernel theorem at the measure layer).
 * Determinism: integer-only; no float.
 */
module numera_bayes_exact

var BX_A  : u64 = 1u64   /* prior weight P(H0) */
var BX_B  : u64 = 1u64   /* prior weight P(H1) */
var BX_L0 : u64 = 1u64   /* likelihood weight P(E|H0) */
var BX_L1 : u64 = 1u64   /* likelihood weight P(E|H1) */

fn bx_set(a: u64, b: u64, l0: u64, l1: u64) -> i32 @export {
    BX_A = a  BX_B = b  BX_L0 = l0  BX_L1 = l1
    return 0i32
}

/* posterior NUMERATOR for Hi = likelihood_i * prior_i (the joint P(E,Hi)). */
fn bx_posterior_num(i: u32) -> u64 @export {
    if i == 0u32 { return BX_L0 * BX_A }
    return BX_L1 * BX_B
}

/* the exact marginal likelihood P(E) = sum_i likelihood_i * prior_i (the posterior denominator). */
fn bx_marginal() -> u64 @export {
    return BX_L0 * BX_A + BX_L1 * BX_B
}

/* 1 iff the posterior is normalized: sum of posterior numerators == the marginal (the posteriors sum to 1). */
fn bx_normalized() -> u8 @export {
    if (bx_posterior_num(0u32) + bx_posterior_num(1u32)) == bx_marginal() { return 1u8 }
    return 0u8
}
