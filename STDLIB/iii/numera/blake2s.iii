/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\blake2s.iii
 *
 * III STDLIB - numera::blake2s
 *
 * RFC 7693 BLAKE2s -- modern fast hash, 32-byte output, 64-byte block,
 * operates on u32 words.  10 rounds of compression.
 *
 * Public API (singleton state):
 *   blake2s_init(out_len:u64) -> u32           -- out_len 1..32
 *   blake2s_update(input:*u8, len:u64) -> u32
 *   blake2s_final(out:*u8) -> u32              -- writes out_len bytes
 *   blake2s_oneshot(input:*u8, len:u64, out:*u8, out_len:u64) -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00.
 */

module numera_blake2s

const B2S_BLOCK_BYTES : u32 = 64u32

/* Initialization vector (IV) -- same as SHA-256's, RFC 7693 §2.6 */
var B2S_IV : [u32; 8]
var B2S_IV_INIT : u8 = 0u8
var B2S_SESSION : u8 = 0u8   /* [soundness] session-init guard (mirrors sha256 SHA_INIT): update/final before init = uninitialised state */

/* SIGMA: 10 permutations of {0..15} for round message scheduling */
var B2S_SIGMA : [u32; 160]   /* 10 rounds * 16 entries */

/* State */
var B2S_H        : [u32; 8]
var B2S_T        : [u32; 2]      /* low/high 64-bit message-length counter */
var B2S_BUF      : [u8;  64]
var B2S_BUFLEN   : u32 = 0u32
var B2S_OUT_LEN  : u32 = 32u32
var B2S_M        : [u32; 16]     /* message words for compression */
var B2S_V        : [u32; 16]     /* working vector */
var B2S_MROWS    : [u32; 160]    /* §3.5 SIMD pre-gathered message schedule:
                                  * 10 rounds × {col_x,col_y,diag_x,diag_y} × 4 lanes */
var B2S_FORCE    : u32           /* §3.5 dispatch override: 0=auto, 1=scalar, 2=avx512, 3=avx2 */

extern @abi(c-msvc-x64) fn cpufeat_has_avx512f() -> u8 from "cpufeat.iii"
extern @abi(c-msvc-x64) fn cpufeat_has_avx2() -> u8 from "cpufeat.iii"
/* THE UNIFIED WEAVE: Blake2's G IS the shared ARX mix (numera/weave_blocks) with message words; its right-
 * rotations {16,12,8,7} are left-rotations {16,20,24,25} by the proven rotl(x,k)==rotr(x,32-k). */
extern @abi(c-msvc-x64) fn wvb_arx_mix(va: u32, vb: u32, vc: u32, vd: u32, x: u32, y: u32, r0: u32, r1: u32, r2: u32, r3: u32) -> i32 from "weave_blocks.iii"
extern @abi(c-msvc-x64) fn wvb_a(i: u64) -> u32 from "weave_blocks.iii"

fn b2s_init_iv() -> i32 {
    if B2S_IV_INIT == 1u8 { return 0i32 }
    B2S_IV[0] = 0x6A09E667u32
    B2S_IV[1] = 0xBB67AE85u32
    B2S_IV[2] = 0x3C6EF372u32
    B2S_IV[3] = 0xA54FF53Au32
    B2S_IV[4] = 0x510E527Fu32
    B2S_IV[5] = 0x9B05688Cu32
    B2S_IV[6] = 0x1F83D9ABu32
    B2S_IV[7] = 0x5BE0CD19u32
    /* SIGMA: standard 10 rounds.  Layout: round r, position p -> SIGMA[r*16 + p] */
    let mut sig : u32 = 0u32
    /* round 0 */
    B2S_SIGMA[sig +  0u32] =  0u32; B2S_SIGMA[sig +  1u32] =  1u32
    B2S_SIGMA[sig +  2u32] =  2u32; B2S_SIGMA[sig +  3u32] =  3u32
    B2S_SIGMA[sig +  4u32] =  4u32; B2S_SIGMA[sig +  5u32] =  5u32
    B2S_SIGMA[sig +  6u32] =  6u32; B2S_SIGMA[sig +  7u32] =  7u32
    B2S_SIGMA[sig +  8u32] =  8u32; B2S_SIGMA[sig +  9u32] =  9u32
    B2S_SIGMA[sig + 10u32] = 10u32; B2S_SIGMA[sig + 11u32] = 11u32
    B2S_SIGMA[sig + 12u32] = 12u32; B2S_SIGMA[sig + 13u32] = 13u32
    B2S_SIGMA[sig + 14u32] = 14u32; B2S_SIGMA[sig + 15u32] = 15u32
    sig = sig + 16u32
    /* round 1 */
    B2S_SIGMA[sig +  0u32] = 14u32; B2S_SIGMA[sig +  1u32] = 10u32
    B2S_SIGMA[sig +  2u32] =  4u32; B2S_SIGMA[sig +  3u32] =  8u32
    B2S_SIGMA[sig +  4u32] =  9u32; B2S_SIGMA[sig +  5u32] = 15u32
    B2S_SIGMA[sig +  6u32] = 13u32; B2S_SIGMA[sig +  7u32] =  6u32
    B2S_SIGMA[sig +  8u32] =  1u32; B2S_SIGMA[sig +  9u32] = 12u32
    B2S_SIGMA[sig + 10u32] =  0u32; B2S_SIGMA[sig + 11u32] =  2u32
    B2S_SIGMA[sig + 12u32] = 11u32; B2S_SIGMA[sig + 13u32] =  7u32
    B2S_SIGMA[sig + 14u32] =  5u32; B2S_SIGMA[sig + 15u32] =  3u32
    sig = sig + 16u32
    /* round 2 */
    B2S_SIGMA[sig +  0u32] = 11u32; B2S_SIGMA[sig +  1u32] =  8u32
    B2S_SIGMA[sig +  2u32] = 12u32; B2S_SIGMA[sig +  3u32] =  0u32
    B2S_SIGMA[sig +  4u32] =  5u32; B2S_SIGMA[sig +  5u32] =  2u32
    B2S_SIGMA[sig +  6u32] = 15u32; B2S_SIGMA[sig +  7u32] = 13u32
    B2S_SIGMA[sig +  8u32] = 10u32; B2S_SIGMA[sig +  9u32] = 14u32
    B2S_SIGMA[sig + 10u32] =  3u32; B2S_SIGMA[sig + 11u32] =  6u32
    B2S_SIGMA[sig + 12u32] =  7u32; B2S_SIGMA[sig + 13u32] =  1u32
    B2S_SIGMA[sig + 14u32] =  9u32; B2S_SIGMA[sig + 15u32] =  4u32
    sig = sig + 16u32
    /* round 3 */
    B2S_SIGMA[sig +  0u32] =  7u32; B2S_SIGMA[sig +  1u32] =  9u32
    B2S_SIGMA[sig +  2u32] =  3u32; B2S_SIGMA[sig +  3u32] =  1u32
    B2S_SIGMA[sig +  4u32] = 13u32; B2S_SIGMA[sig +  5u32] = 12u32
    B2S_SIGMA[sig +  6u32] = 11u32; B2S_SIGMA[sig +  7u32] = 14u32
    B2S_SIGMA[sig +  8u32] =  2u32; B2S_SIGMA[sig +  9u32] =  6u32
    B2S_SIGMA[sig + 10u32] =  5u32; B2S_SIGMA[sig + 11u32] = 10u32
    B2S_SIGMA[sig + 12u32] =  4u32; B2S_SIGMA[sig + 13u32] =  0u32
    B2S_SIGMA[sig + 14u32] = 15u32; B2S_SIGMA[sig + 15u32] =  8u32
    sig = sig + 16u32
    /* round 4 */
    B2S_SIGMA[sig +  0u32] =  9u32; B2S_SIGMA[sig +  1u32] =  0u32
    B2S_SIGMA[sig +  2u32] =  5u32; B2S_SIGMA[sig +  3u32] =  7u32
    B2S_SIGMA[sig +  4u32] =  2u32; B2S_SIGMA[sig +  5u32] =  4u32
    B2S_SIGMA[sig +  6u32] = 10u32; B2S_SIGMA[sig +  7u32] = 15u32
    B2S_SIGMA[sig +  8u32] = 14u32; B2S_SIGMA[sig +  9u32] =  1u32
    B2S_SIGMA[sig + 10u32] = 11u32; B2S_SIGMA[sig + 11u32] = 12u32
    B2S_SIGMA[sig + 12u32] =  6u32; B2S_SIGMA[sig + 13u32] =  8u32
    B2S_SIGMA[sig + 14u32] =  3u32; B2S_SIGMA[sig + 15u32] = 13u32
    sig = sig + 16u32
    /* round 5 */
    B2S_SIGMA[sig +  0u32] =  2u32; B2S_SIGMA[sig +  1u32] = 12u32
    B2S_SIGMA[sig +  2u32] =  6u32; B2S_SIGMA[sig +  3u32] = 10u32
    B2S_SIGMA[sig +  4u32] =  0u32; B2S_SIGMA[sig +  5u32] = 11u32
    B2S_SIGMA[sig +  6u32] =  8u32; B2S_SIGMA[sig +  7u32] =  3u32
    B2S_SIGMA[sig +  8u32] =  4u32; B2S_SIGMA[sig +  9u32] = 13u32
    B2S_SIGMA[sig + 10u32] =  7u32; B2S_SIGMA[sig + 11u32] =  5u32
    B2S_SIGMA[sig + 12u32] = 15u32; B2S_SIGMA[sig + 13u32] = 14u32
    B2S_SIGMA[sig + 14u32] =  1u32; B2S_SIGMA[sig + 15u32] =  9u32
    sig = sig + 16u32
    /* round 6 */
    B2S_SIGMA[sig +  0u32] = 12u32; B2S_SIGMA[sig +  1u32] =  5u32
    B2S_SIGMA[sig +  2u32] =  1u32; B2S_SIGMA[sig +  3u32] = 15u32
    B2S_SIGMA[sig +  4u32] = 14u32; B2S_SIGMA[sig +  5u32] = 13u32
    B2S_SIGMA[sig +  6u32] =  4u32; B2S_SIGMA[sig +  7u32] = 10u32
    B2S_SIGMA[sig +  8u32] =  0u32; B2S_SIGMA[sig +  9u32] =  7u32
    B2S_SIGMA[sig + 10u32] =  6u32; B2S_SIGMA[sig + 11u32] =  3u32
    B2S_SIGMA[sig + 12u32] =  9u32; B2S_SIGMA[sig + 13u32] =  2u32
    B2S_SIGMA[sig + 14u32] =  8u32; B2S_SIGMA[sig + 15u32] = 11u32
    sig = sig + 16u32
    /* round 7 */
    B2S_SIGMA[sig +  0u32] = 13u32; B2S_SIGMA[sig +  1u32] = 11u32
    B2S_SIGMA[sig +  2u32] =  7u32; B2S_SIGMA[sig +  3u32] = 14u32
    B2S_SIGMA[sig +  4u32] = 12u32; B2S_SIGMA[sig +  5u32] =  1u32
    B2S_SIGMA[sig +  6u32] =  3u32; B2S_SIGMA[sig +  7u32] =  9u32
    B2S_SIGMA[sig +  8u32] =  5u32; B2S_SIGMA[sig +  9u32] =  0u32
    B2S_SIGMA[sig + 10u32] = 15u32; B2S_SIGMA[sig + 11u32] =  4u32
    B2S_SIGMA[sig + 12u32] =  8u32; B2S_SIGMA[sig + 13u32] =  6u32
    B2S_SIGMA[sig + 14u32] =  2u32; B2S_SIGMA[sig + 15u32] = 10u32
    sig = sig + 16u32
    /* round 8 */
    B2S_SIGMA[sig +  0u32] =  6u32; B2S_SIGMA[sig +  1u32] = 15u32
    B2S_SIGMA[sig +  2u32] = 14u32; B2S_SIGMA[sig +  3u32] =  9u32
    B2S_SIGMA[sig +  4u32] = 11u32; B2S_SIGMA[sig +  5u32] =  3u32
    B2S_SIGMA[sig +  6u32] =  0u32; B2S_SIGMA[sig +  7u32] =  8u32
    B2S_SIGMA[sig +  8u32] = 12u32; B2S_SIGMA[sig +  9u32] =  2u32
    B2S_SIGMA[sig + 10u32] = 13u32; B2S_SIGMA[sig + 11u32] =  7u32
    B2S_SIGMA[sig + 12u32] =  1u32; B2S_SIGMA[sig + 13u32] =  4u32
    B2S_SIGMA[sig + 14u32] = 10u32; B2S_SIGMA[sig + 15u32] =  5u32
    sig = sig + 16u32
    /* round 9 */
    B2S_SIGMA[sig +  0u32] = 10u32; B2S_SIGMA[sig +  1u32] =  2u32
    B2S_SIGMA[sig +  2u32] =  8u32; B2S_SIGMA[sig +  3u32] =  4u32
    B2S_SIGMA[sig +  4u32] =  7u32; B2S_SIGMA[sig +  5u32] =  6u32
    B2S_SIGMA[sig +  6u32] =  1u32; B2S_SIGMA[sig +  7u32] =  5u32
    B2S_SIGMA[sig +  8u32] = 15u32; B2S_SIGMA[sig +  9u32] = 11u32
    B2S_SIGMA[sig + 10u32] =  9u32; B2S_SIGMA[sig + 11u32] = 14u32
    B2S_SIGMA[sig + 12u32] =  3u32; B2S_SIGMA[sig + 13u32] = 12u32
    B2S_SIGMA[sig + 14u32] = 13u32; B2S_SIGMA[sig + 15u32] =  0u32
    B2S_IV_INIT = 1u8
    return 0i32
}

/* [W59 coverage] SIGMA self-consistency: each of the 10 rounds must be a PERMUTATION of {0..15}.
 * Returns 0 if all 10 rounds are valid permutations, else (round+1) of the first malformed round.
 * Catches an out-of-range / duplicate / missing SIGMA literal -- a class the "abc"/"" digest KATs
 * MISS, because their message words M[2..15]=0, so a swap among zero-word indices is invisible to
 * the digest yet is a real message-schedule bug.  Exercises ALL 160 entries (10 rounds * 16). */
fn b2s_sigma_selfcheck() -> u32 @export {
    b2s_init_iv()
    let mut r : u32 = 0u32
    while r < 10u32 {
        let s : u32 = r * 16u32
        let mut seen : u32 = 0u32
        let mut p : u32 = 0u32
        while p < 16u32 {
            let v : u32 = B2S_SIGMA[s + p]
            if v > 15u32 { return r + 1u32 }              /* out of range */
            let bit : u32 = 1u32 << v
            if (seen & bit) != 0u32 { return r + 1u32 }   /* duplicate */
            seen = seen | bit
            p = p + 1u32
        }
        if seen != 0xFFFFu32 { return r + 1u32 }          /* a value of {0..15} is missing */
        r = r + 1u32
    }
    return 0u32
}

fn b2s_rotr32(x: u32, n: u32) -> u32 {
    return ((x >> n) | (x << (32u32 - n)))
}

/* G mixing function (RFC 7693 §3.1) operates on B2S_V */
fn b2s_mix(a: u32, b: u32, c: u32, d: u32) -> i32 {
    /* THE UNIFIED WEAVE: G is the shared ARX mix with message words (B2S_MIX_X/Y).  Blake2's right-rotations
     * {16,12,8,7} become the core's left-rotations {16,20,24,25} via the proven rotl(x,k)==rotr(x,32-k) --
     * byte-identical to the inline b2s_rotr32 form. */
    wvb_arx_mix(B2S_V[a], B2S_V[b], B2S_V[c], B2S_V[d], B2S_MIX_X, B2S_MIX_Y, 16u32, 20u32, 24u32, 25u32)
    B2S_V[a] = wvb_a(0u64)
    B2S_V[b] = wvb_a(1u64)
    B2S_V[c] = wvb_a(2u64)
    B2S_V[d] = wvb_a(3u64)
    return 0i32
}

var B2S_MIX_X : u32 = 0u32
var B2S_MIX_Y : u32 = 0u32

/* ---- §3.5 SIMD round engine ---- */

/* Scalar 10-round loop (RFC 7693), operating on B2S_V via b2s_mix. */
fn b2s_rounds_scalar() -> i32 {
    let mut r : u32 = 0u32
    while r < 10u32 {
        let s : u32 = r * 16u32
        B2S_MIX_X = B2S_M[B2S_SIGMA[s + 0u32]]; B2S_MIX_Y = B2S_M[B2S_SIGMA[s + 1u32]]
        b2s_mix(0u32, 4u32, 8u32, 12u32)
        B2S_MIX_X = B2S_M[B2S_SIGMA[s + 2u32]]; B2S_MIX_Y = B2S_M[B2S_SIGMA[s + 3u32]]
        b2s_mix(1u32, 5u32, 9u32, 13u32)
        B2S_MIX_X = B2S_M[B2S_SIGMA[s + 4u32]]; B2S_MIX_Y = B2S_M[B2S_SIGMA[s + 5u32]]
        b2s_mix(2u32, 6u32, 10u32, 14u32)
        B2S_MIX_X = B2S_M[B2S_SIGMA[s + 6u32]]; B2S_MIX_Y = B2S_M[B2S_SIGMA[s + 7u32]]
        b2s_mix(3u32, 7u32, 11u32, 15u32)
        B2S_MIX_X = B2S_M[B2S_SIGMA[s + 8u32]]; B2S_MIX_Y = B2S_M[B2S_SIGMA[s + 9u32]]
        b2s_mix(0u32, 5u32, 10u32, 15u32)
        B2S_MIX_X = B2S_M[B2S_SIGMA[s + 10u32]]; B2S_MIX_Y = B2S_M[B2S_SIGMA[s + 11u32]]
        b2s_mix(1u32, 6u32, 11u32, 12u32)
        B2S_MIX_X = B2S_M[B2S_SIGMA[s + 12u32]]; B2S_MIX_Y = B2S_M[B2S_SIGMA[s + 13u32]]
        b2s_mix(2u32, 7u32, 8u32, 13u32)
        B2S_MIX_X = B2S_M[B2S_SIGMA[s + 14u32]]; B2S_MIX_Y = B2S_M[B2S_SIGMA[s + 15u32]]
        b2s_mix(3u32, 4u32, 9u32, 14u32)
        r = r + 1u32
    }
    return 0i32
}

/* Pre-gather the per-round message rows into B2S_MROWS so the SIMD
 * kernels avoid a runtime gather.  Per round r (s=r*16, o=r*16):
 *   col_x = M[sig s+0,+2,+4,+6]   col_y = M[sig s+1,+3,+5,+7]
 *   diag_x= M[sig s+8,+10,+12,+14] diag_y= M[sig s+9,+11,+13,+15]
 * matching the column/diagonal mix message-word usage exactly. */
fn b2s_gather_msched() -> i32 {
    let mut r : u32 = 0u32
    while r < 10u32 {
        let s : u32 = r * 16u32
        let o : u32 = r * 16u32
        B2S_MROWS[o +  0u32] = B2S_M[B2S_SIGMA[s +  0u32]]
        B2S_MROWS[o +  1u32] = B2S_M[B2S_SIGMA[s +  2u32]]
        B2S_MROWS[o +  2u32] = B2S_M[B2S_SIGMA[s +  4u32]]
        B2S_MROWS[o +  3u32] = B2S_M[B2S_SIGMA[s +  6u32]]
        B2S_MROWS[o +  4u32] = B2S_M[B2S_SIGMA[s +  1u32]]
        B2S_MROWS[o +  5u32] = B2S_M[B2S_SIGMA[s +  3u32]]
        B2S_MROWS[o +  6u32] = B2S_M[B2S_SIGMA[s +  5u32]]
        B2S_MROWS[o +  7u32] = B2S_M[B2S_SIGMA[s +  7u32]]
        B2S_MROWS[o +  8u32] = B2S_M[B2S_SIGMA[s +  8u32]]
        B2S_MROWS[o +  9u32] = B2S_M[B2S_SIGMA[s + 10u32]]
        B2S_MROWS[o + 10u32] = B2S_M[B2S_SIGMA[s + 12u32]]
        B2S_MROWS[o + 11u32] = B2S_M[B2S_SIGMA[s + 14u32]]
        B2S_MROWS[o + 12u32] = B2S_M[B2S_SIGMA[s +  9u32]]
        B2S_MROWS[o + 13u32] = B2S_M[B2S_SIGMA[s + 11u32]]
        B2S_MROWS[o + 14u32] = B2S_M[B2S_SIGMA[s + 13u32]]
        B2S_MROWS[o + 15u32] = B2S_M[B2S_SIGMA[s + 15u32]]
        r = r + 1u32
    }
    return 0i32
}

/* AVX-512 (EVEX.128) 4-row SIMD: ChaCha20 structure with vprord (ROTR)
 * and two message-row vpaddd per G.  rax=V, rdx=MROWS, rcx=round ctr,
 * xmm0..3 = rows — all Win64 caller-saved. */
fn b2s_rounds_avx512() -> i32 {
    b2s_gather_msched()
    metal {
    leaq L_B2S_V(%rip), %rax
    vmovdqu (%rax), %xmm0
    vmovdqu 16(%rax), %xmm1
    vmovdqu 32(%rax), %xmm2
    vmovdqu 48(%rax), %xmm3
    leaq L_B2S_MROWS(%rip), %rdx
    movl $10, %ecx
.Lb2s_avx_rnd:
    vpaddd %xmm1, %xmm0, %xmm0
    vpaddd (%rdx), %xmm0, %xmm0
    vpxord %xmm0, %xmm3, %xmm3
    vprord $16, %xmm3, %xmm3
    vpaddd %xmm3, %xmm2, %xmm2
    vpxord %xmm2, %xmm1, %xmm1
    vprord $12, %xmm1, %xmm1
    vpaddd %xmm1, %xmm0, %xmm0
    vpaddd 16(%rdx), %xmm0, %xmm0
    vpxord %xmm0, %xmm3, %xmm3
    vprord $8, %xmm3, %xmm3
    vpaddd %xmm3, %xmm2, %xmm2
    vpxord %xmm2, %xmm1, %xmm1
    vprord $7, %xmm1, %xmm1
    vpshufd $0x39, %xmm1, %xmm1
    vpshufd $0x4E, %xmm2, %xmm2
    vpshufd $0x93, %xmm3, %xmm3
    vpaddd %xmm1, %xmm0, %xmm0
    vpaddd 32(%rdx), %xmm0, %xmm0
    vpxord %xmm0, %xmm3, %xmm3
    vprord $16, %xmm3, %xmm3
    vpaddd %xmm3, %xmm2, %xmm2
    vpxord %xmm2, %xmm1, %xmm1
    vprord $12, %xmm1, %xmm1
    vpaddd %xmm1, %xmm0, %xmm0
    vpaddd 48(%rdx), %xmm0, %xmm0
    vpxord %xmm0, %xmm3, %xmm3
    vprord $8, %xmm3, %xmm3
    vpaddd %xmm3, %xmm2, %xmm2
    vpxord %xmm2, %xmm1, %xmm1
    vprord $7, %xmm1, %xmm1
    vpshufd $0x93, %xmm1, %xmm1
    vpshufd $0x4E, %xmm2, %xmm2
    vpshufd $0x39, %xmm3, %xmm3
    addq $64, %rdx
    decl %ecx
    jnz .Lb2s_avx_rnd
    vmovdqu %xmm0, (%rax)
    vmovdqu %xmm1, 16(%rax)
    vmovdqu %xmm2, 32(%rax)
    vmovdqu %xmm3, 48(%rax)
    vzeroupper
    }
    return 0i32
}

/* AVX2 (VEX.128): same, but ROTR via vpsrld+vpslld+vpor (xmm4 temp),
 * vpxor not vpxord. */
fn b2s_rounds_avx2() -> i32 {
    b2s_gather_msched()
    metal {
    leaq L_B2S_V(%rip), %rax
    vmovdqu (%rax), %xmm0
    vmovdqu 16(%rax), %xmm1
    vmovdqu 32(%rax), %xmm2
    vmovdqu 48(%rax), %xmm3
    leaq L_B2S_MROWS(%rip), %rdx
    movl $10, %ecx
.Lb2s_avx2_rnd:
    vpaddd %xmm1, %xmm0, %xmm0
    vpaddd (%rdx), %xmm0, %xmm0
    vpxor %xmm0, %xmm3, %xmm3
    vpsrld $16, %xmm3, %xmm4
    vpslld $16, %xmm3, %xmm3
    vpor %xmm4, %xmm3, %xmm3
    vpaddd %xmm3, %xmm2, %xmm2
    vpxor %xmm2, %xmm1, %xmm1
    vpsrld $12, %xmm1, %xmm4
    vpslld $20, %xmm1, %xmm1
    vpor %xmm4, %xmm1, %xmm1
    vpaddd %xmm1, %xmm0, %xmm0
    vpaddd 16(%rdx), %xmm0, %xmm0
    vpxor %xmm0, %xmm3, %xmm3
    vpsrld $8, %xmm3, %xmm4
    vpslld $24, %xmm3, %xmm3
    vpor %xmm4, %xmm3, %xmm3
    vpaddd %xmm3, %xmm2, %xmm2
    vpxor %xmm2, %xmm1, %xmm1
    vpsrld $7, %xmm1, %xmm4
    vpslld $25, %xmm1, %xmm1
    vpor %xmm4, %xmm1, %xmm1
    vpshufd $0x39, %xmm1, %xmm1
    vpshufd $0x4E, %xmm2, %xmm2
    vpshufd $0x93, %xmm3, %xmm3
