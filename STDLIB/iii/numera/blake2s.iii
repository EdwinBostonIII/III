    vpaddd 32(%rdx), %xmm0, %xmm0
    vpxor %xmm0, %xmm3, %xmm3
    vpsrld $16, %xmm3, %xmm4
    vpslld $16, %xmm3, %xmm3
    vpor %xmm4, %xmm3, %xmm3
    vpaddd %xmm3, %xmm2, %xmm2
    vpxor %xmm2, %xmm1, %xmm1
    vpsrld $12, %xmm1, %xmm4
    vpslld $20, %xmm1, %xmm1
    vpor %xmm4, %xmm1, %xmm1
    vpaddd %xmm1, %xmm0, %xmm0
    vpaddd 48(%rdx), %xmm0, %xmm0
    vpxor %xmm0, %xmm3, %xmm3
    vpsrld $8, %xmm3, %xmm4
    vpslld $24, %xmm3, %xmm3
    vpor %xmm4, %xmm3, %xmm3
    vpaddd %xmm3, %xmm2, %xmm2
    vpxor %xmm2, %xmm1, %xmm1
    vpsrld $7, %xmm1, %xmm4
    vpslld $25, %xmm1, %xmm1
    vpor %xmm4, %xmm1, %xmm1
    vpshufd $0x93, %xmm1, %xmm1
