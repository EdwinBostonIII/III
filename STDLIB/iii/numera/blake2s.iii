    return 0i32
}

/* iiis-2 cpufeat dispatch: AVX-512 > AVX2 > scalar; B2S_FORCE overrides
 * for KAT bit-identity testing.  Mandate 7: structural CPUID dispatch. */
fn b2s_rounds() -> i32 {
    if B2S_FORCE == 1u32 { return b2s_rounds_scalar() }
    if B2S_FORCE == 2u32 { return b2s_rounds_avx512() }
    if B2S_FORCE == 3u32 { return b2s_rounds_avx2() }
    if cpufeat_has_avx512f() == 1u8 { return b2s_rounds_avx512() }
    if cpufeat_has_avx2() == 1u8 { return b2s_rounds_avx2() }
    return b2s_rounds_scalar()
}

fn b2s_force_path(p: u32) -> i32 @export { B2S_FORCE = p ; return 0i32 }

fn b2s_compress(last: u8) -> i32 {
    /* Load message words from BUF (LE u32). */
    let mut i : u32 = 0u32
    while i < 16u32 {
        let off : u32 = i * 4u32
        let b0 : u32 = B2S_BUF[off + 0u32] as u32
        let b1 : u32 = B2S_BUF[off + 1u32] as u32
        let b2 : u32 = B2S_BUF[off + 2u32] as u32
        let b3 : u32 = B2S_BUF[off + 3u32] as u32
        B2S_M[i] = b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32)
        i = i + 1u32
    }
    /* Initialize V. */
    let mut k : u32 = 0u32
    while k < 8u32 {
        B2S_V[k] = B2S_H[k]
        k = k + 1u32
    }
    B2S_V[8]  = B2S_IV[0]
    B2S_V[9]  = B2S_IV[1]
    B2S_V[10] = B2S_IV[2]
    B2S_V[11] = B2S_IV[3]
    B2S_V[12] = B2S_IV[4] ^ B2S_T[0]
    B2S_V[13] = B2S_IV[5] ^ B2S_T[1]
    B2S_V[14] = B2S_IV[6]
    if last == 1u8 { B2S_V[14] = B2S_V[14] ^ 0xFFFFFFFFu32 }
    B2S_V[15] = B2S_IV[7]
    /* 10 rounds — §3.5 dispatched (scalar / AVX-512 / AVX2), bit-identical. */
    b2s_rounds()
    /* Mix V into H. */
    let mut q : u32 = 0u32
    while q < 8u32 {
        B2S_H[q] = (B2S_H[q] ^ B2S_V[q] ^ B2S_V[q + 8u32])
        q = q + 1u32
    }
    return 0i32
}

fn blake2s_init(out_len: u64) -> u32 @dynamic(ripple=auto) @constant_time @export {
    /* BLAKE2s digest length is 1..32 (RFC 7693 sec 2.5). Clamp out-of-range so an invalid out_len cannot
     * drive blake2s_final past B2S_H[8] (OOB read) or the caller's out buffer (OOB write). out_len is a
     * PUBLIC length parameter, so clamping it does not weaken the @constant_time secret-data property. */
    let mut ol : u32 = out_len as u32
    if ol == 0u32 { ol = 32u32 }
    if ol > 32u32 { ol = 32u32 }
    b2s_init_iv()
    let mut i : u32 = 0u32
    while i < 8u32 {
        B2S_H[i] = B2S_IV[i]
        i = i + 1u32
    }
    /* Mix in parameter block: depth=1, fanout=1, key_length=0, digest_length */
    let param0 : u32 = 0x01010000u32 | ol
    B2S_H[0] = B2S_H[0] ^ param0
    B2S_T[0]    = 0u32
    B2S_T[1]    = 0u32
    B2S_BUFLEN  = 0u32
    B2S_OUT_LEN = ol
    B2S_SESSION = 1u8
    return 0u32
}

fn blake2s_update(input: *u8, len: u64) -> u32 @dynamic(ripple=auto) @constant_time @export {
    if B2S_SESSION == 0u8 { return 1u32 }   /* [soundness] no update before init (mirrors sha256_update) */
    let mut rem : u64 = len
    let mut off : u64 = 0u64
    while rem > 0u64 {
        if B2S_BUFLEN == 64u32 {
            /* Counter += 64 */
            let new_t0 : u32 = (B2S_T[0] + 64u32)
            if new_t0 < B2S_T[0] { B2S_T[1] = (B2S_T[1] + 1u32) }
            B2S_T[0] = new_t0
            b2s_compress(0u8)
            B2S_BUFLEN = 0u32
        }
        let mut take : u64 = (64u32 - B2S_BUFLEN) as u64
        if take > rem { take = rem }
        let mut k : u64 = 0u64
        while k < take {
            B2S_BUF[(B2S_BUFLEN as u64) + k] = input[off + k]
            k = k + 1u64
        }
        B2S_BUFLEN = B2S_BUFLEN + (take as u32)
        off = off + take
        rem = rem - take
    }
    return 0u32
}

fn blake2s_final(out: *u8) -> u32 @dynamic(ripple=auto) @constant_time @export {
    if B2S_SESSION == 0u8 { return 1u32 }   /* [soundness] no final before init (mirrors sha256_final) */
    /* Counter += BUFLEN */
    let new_t0 : u32 = (B2S_T[0] + B2S_BUFLEN)
    if new_t0 < B2S_T[0] { B2S_T[1] = (B2S_T[1] + 1u32) }
    B2S_T[0] = new_t0
    /* Pad remaining buffer with zeros */
    while B2S_BUFLEN < 64u32 {
        B2S_BUF[B2S_BUFLEN] = 0u8
        B2S_BUFLEN = B2S_BUFLEN + 1u32
    }
    b2s_compress(1u8)
    /* Emit OUT_LEN bytes from H, LE */
    let mut i : u32 = 0u32
    while i < B2S_OUT_LEN {
        let word_idx : u32 = i >> 2u32
        let byte_in_word : u32 = i & 3u32
        let h_val : u32 = B2S_H[word_idx]
        let shift : u32 = byte_in_word * 8u32
        out[i] = ((h_val >> shift) & 0xFFu32) as u8
        i = i + 1u32
    }
    return 0u32
}

fn blake2s_oneshot(input: *u8, len: u64, out: *u8, out_len: u64) -> u32 @dynamic(ripple=auto) @constant_time @export {
    blake2s_init(out_len)
    blake2s_update(input, len)
    return blake2s_final(out)
}
