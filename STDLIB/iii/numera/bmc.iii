/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\bmc.iii
 *
 * III STDLIB - numera::bmc  --  BOUNDED + INDUCTIVE MODEL CHECKING (one method, both halves).
 *
 * MODEL-TIER (III-PERFECTION-LEDGER label): this is the didactic verified model of the method;
 * III's LIVE verification membrane is the ser_* family (ser_tgraph BMC / ser_kinduct / ser_kinduct_sym).
 * Merged per the ledger: numera/kinduction was the other half of this same method in its own file.
 *
 * BOUNDED half: given a transition system and a BAD state, explore the reachable states out to a
 * bound k and decide whether the bad state can be reached.  If it can, the depth at which it first
 * appears is the length of a counterexample trace; if it cannot within k, the safety property holds
 * up to that bound.  Boundedness is the point -- model checking trades completeness for a decidable,
 * exhaustive search of all behaviours within the horizon, the same discipline numera::tso applies
 * to memory interleavings.
 *   Transition system (6 states): 0->{1,2}, 1->3, 2->3, 3->4, 4->5.  The bad state 5 is first
 *   reachable at depth 4 (e.g. 0->1->3->4->5), so the system is safe to depth 3 and violated at 4.
 *
 * INDUCTIVE half: bmc proves safety up to a BOUND; induction proves it for ALL time.  A property P
 * is an inductive invariant when (base) it holds in the initial state and (step) every transition
 * from a P-state lands in another P-state -- then P holds along every reachable path, with no bound.
 * When the step FAILS, the failing transition is the reason a larger k or a strengthened invariant
 * is needed.  This is the bridge from bounded checking to unbounded proof.
 *   Two counters with invariant P(s) = "s <= 3": a CAPPED counter (succ saturates at 3) is inductive
 *   so P holds forever; an UNCAPPED counter (succ = s+1) breaks the step at s=3 (witnessed).
 *
 * Verified (bmc_kat + kinduction_kat): shortest distance to bad is 4; reachable within 4 not 3;
 * safe to depth 3, violated at 4; the capped counter certified, the uncapped refused with witness 3.
 *
 * Public API:
 *   bmc_setup() ; bmc_succ_of(set) -> u32 ; bmc_shortest(target) -> u32 ; bmc_reachable(target,k) -> u32 ;
 *   bmc_safe(bad,k) -> u32
 *   ki_succ(s,mode) -> u32 ; ki_p(s) -> u32 ; ki_step(mode) -> u32 ; ki_invariant(mode) -> u32 ;
 *   ki_step_witness() -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_bmc

/* ===================== BOUNDED half ===================== */

const BMC_N    : u32 = 6u32
const BMC_NONE : u32 = 7u32        /* unreachable sentinel (> any real depth) */

var BMC_TRANS : [u32; 6]           /* BMC_TRANS[s] = bitset of successor states */

fn bmc_setup() -> i32 @export {
    BMC_TRANS[0u64]=(1u32<<1u32)|(1u32<<2u32)    /* 0 -> 1,2 */
    BMC_TRANS[1u64]=1u32<<3u32                    /* 1 -> 3 */
    BMC_TRANS[2u64]=1u32<<3u32                    /* 2 -> 3 */
    BMC_TRANS[3u64]=1u32<<4u32                    /* 3 -> 4 */
    BMC_TRANS[4u64]=1u32<<5u32                    /* 4 -> 5 (bad) */
    BMC_TRANS[5u64]=0u32                          /* 5 -> {} */
    return 0i32
}

/* the union of successors of every state in the given set. */
fn bmc_succ_of(set: u32) -> u32 @export {
    let mut out : u32 = 0u32
    let mut s : u32 = 0u32
    while s < BMC_N {
        if ((set >> s) & 1u32) == 1u32 { out = out | BMC_TRANS[s as u64] }
        s = s + 1u32
    }
    return out
}

/* shortest distance from the initial state 0 to target (BMC_NONE if unreachable within N steps). */
fn bmc_shortest(target: u32) -> u32 @export {
    /* [sev2] `reach >> target` is UB for target>=32; and any target >= BMC_N is an out-of-range state that is
     * trivially unreachable.  One guard here also covers bmc_reachable/bmc_safe (both route through this). */
    if target >= BMC_N { return BMC_NONE }
    let mut reach : u32 = 1u32 << 0u32           /* {0} */
    let mut depth : u32 = 0u32
    while depth <= BMC_N {
        if ((reach >> target) & 1u32) == 1u32 { return depth }
        reach = reach | bmc_succ_of(reach)
        depth = depth + 1u32
    }
    return BMC_NONE
}

/* is the target reachable within k steps? */
fn bmc_reachable(target: u32, k: u32) -> u32 @export {
    let d : u32 = bmc_shortest(target)
    if d == BMC_NONE { return 0u32 }
    if d <= k { return 1u32 }
    return 0u32
}

/* is the system safe (bad state NOT reachable) within bound k? */
fn bmc_safe(bad: u32, k: u32) -> u32 @export {
    if bmc_reachable(bad, k) == 1u32 { return 0u32 }
    return 1u32
}

/* =====================================================================================
 * bmc_kat -- 99 = bounded model checking is correct, self-checked:
 *   (1) the shortest distance to the bad state 5 is 4;
 *   (2) state 5 is reachable within bound 4 but NOT within bound 3;
 *   (3) the system is SAFE up to depth 3 and VIOLATED at depth 4 (a depth-4 counterexample);
 *   (4) intermediate distances are correct: state 0 at 0, state 3 at depth 2.
 * ===================================================================================== */
fn bmc_kat() -> u64 @export {
    bmc_setup()

    /* (1) shortest distance to the bad state */
    if bmc_shortest(5u32) != 4u32 { return 1u64 }

    /* (2) bounded reachability */
    if bmc_reachable(5u32, 4u32) != 1u32 { return 2u64 }
    if bmc_reachable(5u32, 3u32) != 0u32 { return 3u64 }

    /* (3) safety verdict at each bound */
    if bmc_safe(5u32, 3u32) != 1u32 { return 4u64 }
    if bmc_safe(5u32, 4u32) != 0u32 { return 5u64 }

    /* (4) intermediate distances */
    if bmc_shortest(0u32) != 0u32 { return 6u64 }
    if bmc_shortest(3u32) != 2u32 { return 7u64 }
    if bmc_shortest(4u32) != 3u32 { return 8u64 }

    return 99u64
}

/* ===================== INDUCTIVE half (formerly numera/kinduction.iii) ===================== */

const KI_BOUND : u32 = 3u32        /* the invariant P(s) = s <= 3 */
const KI_MAXS  : u32 = 8u32        /* state space to quantify the inductive step over */

var KI_WIT : [u32; 1]              /* state at which the inductive step fails */

/* the transition: mode 0 saturates at the bound (capped); mode 1 increments unboundedly. */
fn ki_succ(s: u32, mode: u32) -> u32 @export {
    if mode == 0u32 {
        if s < KI_BOUND { return s + 1u32 }
        return KI_BOUND
    }
    return s + 1u32
}

/* the invariant predicate P(s) = s <= bound. */
fn ki_p(s: u32) -> u32 @export {
    if s <= KI_BOUND { return 1u32 }
    return 0u32
}

/* the inductive STEP: every P-state transitions to a P-state.  0 with a witness if some transition breaks it. */
fn ki_step(mode: u32) -> u32 @export {
    let mut s : u32 = 0u32
    while s < KI_MAXS {
        if ki_p(s) == 1u32 {
            let ns : u32 = ki_succ(s, mode)
            if ki_p(ns) == 0u32 { KI_WIT[0u64] = s ; return 0u32 }
        }
        s = s + 1u32
    }
    return 1u32
}

/* P is an inductive invariant iff it holds initially (base) and the step holds. */
fn ki_invariant(mode: u32) -> u32 @export {
    if ki_p(0u32) == 0u32 { return 0u32 }      /* base case: P(initial) */
    return ki_step(mode)
}

fn ki_step_witness() -> u32 @export { return KI_WIT[0u64] }

/* =====================================================================================
 * kinduction_kat -- 99 = unbounded safety by induction is correct, self-checked:
 *   (1) the capped counter's inductive step holds, so P is proven an invariant (unbounded safe);
 *   (2) the uncapped counter's step FAILS at s=3 (it steps to 4) and is NOT certified;
 *   (3) the transition values are correct: capped succ(3)=3, uncapped succ(3)=4;
 *   (4) the predicate boundary is correct: P(3) holds, P(4) does not.
 * ===================================================================================== */
fn kinduction_kat() -> u64 @export {
    /* (1) capped counter: inductive invariant */
    if ki_step(0u32) != 1u32 { return 1u64 }
    if ki_invariant(0u32) != 1u32 { return 2u64 }

    /* (2) uncapped counter: step fails, not certified */
    if ki_step(1u32) != 0u32 { return 3u64 }
    if ki_step_witness() != 3u32 { return 4u64 }           /* P(3) holds but succ(3)=4 violates it */
    if ki_invariant(1u32) != 0u32 { return 5u64 }

    /* (3) transition values */
    if ki_succ(3u32, 0u32) != 3u32 { return 6u64 }         /* capped: stays at the bound */
    if ki_succ(3u32, 1u32) != 4u32 { return 7u64 }         /* uncapped: overshoots */

    /* (4) predicate boundary */
    if ki_p(3u32) != 1u32 { return 8u64 }
    if ki_p(4u32) != 0u32 { return 9u64 }

    return 99u64
}
