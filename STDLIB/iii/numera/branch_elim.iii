/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\branch_elim.iii
 *
 * III STDLIB - numera::branch_elim  --  DEAD-BRANCH ELIMINATION FROM VALUE RANGES (composition).
 *
 * The emergent payoff of combining analyses: a branch condition alone tells you nothing, and a value range
 * alone tells you nothing about control flow, but TOGETHER they can prove a branch is DEAD.  This consumes
 * numera::interval_lattice to bound the value a condition tests, and decides whether the test is always
 * true (the else-arm is dead), always false (the then-arm is dead), or genuinely data-dependent (both arms
 * live).  Folding the dead arm away is the "conditional" in conditional constant propagation -- a real
 * optimization no single analysis enables.
 *
 * Condition: (2*x) < c for x in [lo,hi].  The interval transfer gives 2*x in [2*lo, 2*hi]; if that whole
 * range is below c the branch is THEN-only, if entirely at-or-above c it is ELSE-only, else BOTH live.
 *
 * Verified (branch_elim_kat): a THEN-only branch (range below c), an ELSE-only branch (range at/above c),
 * and a BOTH-live branch (range straddling c) are each classified correctly and each verdict is cross-checked
 * against the EXHAUSTIVE concrete condition over the range (a THEN-only claim really has no false instance, a
 * BOTH claim really is mixed); a branch is eliminable iff the verdict is not BOTH.  NIH; composes interval_lattice.
 *
 * Public API:
 *   be_verdict(lo,hi,c) -> u32 (0 both / 1 then-only / 2 else-only) ; be_eliminable(lo,hi,c) -> u32 ;
 *   be_sound(lo,hi,c) -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_branch_elim

extern @abi(c-msvc-x64) fn il_mul(l1: u32, h1: u32, l2: u32, h2: u32) -> i32 from "interval_lattice.iii"
extern @abi(c-msvc-x64) fn il_lo() -> u32 from "interval_lattice.iii"
extern @abi(c-msvc-x64) fn il_hi() -> u32 from "interval_lattice.iii"

const BE_BOTH      : u32 = 0u32
const BE_THEN_ONLY : u32 = 1u32     /* condition always true -> the else arm is dead */
const BE_ELSE_ONLY : u32 = 2u32     /* condition always false -> the then arm is dead */

/* classify the branch (2*x) < c over x in [lo,hi] using the interval range of 2*x. */
fn be_verdict(lo: u32, hi: u32, c: u32) -> u32 @export {
    il_mul(lo, hi, 2u32, 2u32)              /* range of 2*x = [2*lo, 2*hi] */
    let rlo : u32 = il_lo()
    let rhi : u32 = il_hi()
    if rhi < c { return BE_THEN_ONLY }      /* the whole range is below c -> always true */
    if rlo >= c { return BE_ELSE_ONLY }     /* the whole range is at/above c -> always false */
    return BE_BOTH
}

/* a branch is eliminable iff one arm is provably dead. */
fn be_eliminable(lo: u32, hi: u32, c: u32) -> u32 @export {
    if be_verdict(lo, hi, c) == BE_BOTH { return 0u32 }
    return 1u32
}

/* cross-check the verdict against the exhaustive concrete condition over the range. */
fn be_sound(lo: u32, hi: u32, c: u32) -> u32 @export {
    let v : u32 = be_verdict(lo, hi, c)
    let mut saw_true : u32 = 0u32
    let mut saw_false : u32 = 0u32
    let mut x : u32 = lo
    while x <= hi {
        if (x * 2u32) < c { saw_true = 1u32 }
        if (x * 2u32) >= c { saw_false = 1u32 }
        x = x + 1u32
    }
    /* THEN-only must have NO false instance; ELSE-only must have NO true instance; BOTH must have both */
    if v == BE_THEN_ONLY { if saw_false == 1u32 { return 0u32 } }
    if v == BE_ELSE_ONLY { if saw_true == 1u32 { return 0u32 } }
    if v == BE_BOTH {
        if saw_true == 0u32 { return 0u32 }
        if saw_false == 0u32 { return 0u32 }
    }
    return 1u32
}

/* =====================================================================================
 * branch_elim_kat -- 99 = dead-branch elimination from ranges is correct, self-checked:
 *   (1) a range entirely below c is THEN-only (else arm dead) and eliminable;
 *   (2) a range entirely at/above c is ELSE-only (then arm dead) and eliminable;
 *   (3) a straddling range is BOTH-live and NOT eliminable;
 *   (4) every verdict is sound vs the exhaustive concrete condition, across several parameterizations.
 * ===================================================================================== */
fn branch_elim_kat() -> u64 @export {
    /* (1) then-only: 2*x in [0,10] < 20 always */
    if be_verdict(0u32, 5u32, 20u32) != BE_THEN_ONLY { return 1u64 }
    if be_eliminable(0u32, 5u32, 20u32) != 1u32 { return 2u64 }

    /* (2) else-only: 2*x in [20,40] >= 15 always */
    if be_verdict(10u32, 20u32, 15u32) != BE_ELSE_ONLY { return 3u64 }
    if be_eliminable(10u32, 20u32, 15u32) != 1u32 { return 4u64 }

    /* (3) both-live: 2*x in [0,20] straddles 10 */
    if be_verdict(0u32, 10u32, 10u32) != BE_BOTH { return 5u64 }
    if be_eliminable(0u32, 10u32, 10u32) != 0u32 { return 6u64 }

    /* (4) soundness over several parameterizations */
    if be_sound(0u32, 5u32, 20u32) != 1u32 { return 7u64 }
    if be_sound(10u32, 20u32, 15u32) != 1u32 { return 8u64 }
    if be_sound(0u32, 10u32, 10u32) != 1u32 { return 9u64 }
    if be_sound(3u32, 7u32, 8u32) != 1u32 { return 10u64 }      /* 2*x in [6,14] straddles 8 */
    if be_sound(0u32, 0u32, 1u32) != 1u32 { return 11u64 }      /* 2*0=0 < 1 -> then-only */

    return 99u64
}
