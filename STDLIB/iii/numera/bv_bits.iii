/* STDLIB/iii/numera/bv_bits.iii -- THE MIXED ARITHMETIC+BITWISE EQUIVALENCE DECIDER (harmony item 18).
 *
 * III owned two partial word-deciders: bv_ring (sound polynomial arithmetic over Z/2^64 -- NO bitwise)
 * and bv_ring's BW fragment (exhaustive pure-bitwise over <=6 vars -- NO arithmetic).  The identities
 * that MATTER to a code generator live exactly on the boundary neither could cross:
 *     (x & y) + (x | y) == x + y          x - (x & y) == x & ~y          x ^ y == (x | y) - (x & y)
 * bv_bits decides the MIXED language { var, const, and, or, xor, not, add, sub, shl k, shr k, mul }
 * over Z/2^w (w <= 64, caller-set) by Tseitin BIT-BLASTING into III's own CDCL solver (numera/sat):
 * equivalence is decided as UNSAT of "some output bit differs" -- exact, sound, complete over the
 * chosen width.  NIH end to end: the encoder is this file; the solver is sat.iii; no oracle.
 *
 * ARCHITECTURE -- the bit-indirection table: every node's w bits map to SAT variable ids through
 * BB_BITVAR, so CONSTANTS cost zero clauses (bits alias the two globally-pinned ZERO/ONE vars),
 * SHIFTS cost zero clauses (pure remapping with vacated bits aliasing ZERO), and INPUT VARS are
 * shared by id (bb_var(0) on both sides of an equivalence is the SAME variable -- the decider
 * quantifies over it).  Gates allocate fresh vars + clauses: AND/OR 3, XOR 4, NOT 2 per bit;
 * ADD = ripple carry (two XORs + a 6-clause majority per bit); SUB = x + ~y + 1 (carry-in pinned 1);
 * MUL = shift-add accumulation (row j gated by x_j, truncated adders) ~ 17*w^2/2 clauses at full
 * width -- well inside SAT_MAX_CLAUSES; width-8 instances solve interactively for the multiplier
 * identities that are classically SAT-hard at 64.
 *
 * CONTRACT: per-decision scope (bb_reset -> build -> bb_equal), like bv_ring's arena.  Clauses are
 * BUFFERED at construction and replayed into a fresh sat_init at bb_equal, so bb_equal is callable
 * repeatedly on one DAG (it snapshots and restores the var/stream cursors around its difference
 * encoding).  An equivalence proven at width w is a theorem of Z/2^w (the low-w-bit semantics);
 * width 64 IS the machine word.  Errors (capacity, bad input) poison the decision: bb_equal -> 0xFF,
 * never a fabricated verdict.
 *
 * Hexad: kind_decision.  Ring: R0.  K: 1.00.  NIH: numera/sat only.  Deterministic: the encoder is
 * a pure function of the construction sequence; sat.iii is deterministic CDCL. */
module numera_bv_bits

extern @abi(c-msvc-x64) fn sat_init(n_vars: u32) -> i32 from "sat.iii"
extern @abi(c-msvc-x64) fn sat_add_clause(lits: *u32, n_lits: u32) -> i32 from "sat.iii"
extern @abi(c-msvc-x64) fn sat_solve() -> i32 from "sat.iii"

const BB_SAT_SAT   : i32 = 1i32
const BB_SAT_UNSAT : i32 = 2i32

const BB_MAX_NODES  : u32 = 128u32
const BB_MAX_INPUTS : u32 = 8u32
const BB_MAX_VARS   : u32 = 60000u32
const BB_STREAM_CAP : u64 = 524288u64

const BB_K_VAR   : u8 = 0u8
const BB_K_CONST : u8 = 1u8
const BB_K_GATE  : u8 = 2u8    /* any node whose bits are already fully encoded */

const BB_SENT : u32 = 0xFFFFFFFFu32

var BB_W      : u64 = 64u64            /* decision width (1..64) */
var BB_NV     : u32 = 0u32             /* sat vars allocated (1-based ids) */
var BB_NN     : u32 = 0u32             /* nodes allocated */
var BB_ERR    : u8  = 0u8              /* sticky capacity/input error -> bb_equal refuses */
var BB_ZVAR   : u32 = 0u32             /* the globally pinned-0 var */
var BB_OVAR   : u32 = 0u32             /* the globally pinned-1 var */
var BB_INBASE : [u32; 8]               /* first sat var of input v's bits (0 = unallocated) */
var BB_BITVAR : [u32; 8192]            /* node-bit -> sat var id (BB_MAX_NODES * 64) */
var BB_STREAM : [u32; 524288]          /* buffered clauses: [n, lits...]* */
var BB_SP     : u64 = 0u64             /* stream cursor */
var BB_NCL    : u64 = 0u64             /* buffered clause count */
var BB_CL     : [u32; 80]              /* replay/emit scratch (max clause = w + small) */
var BB_ACC    : [u32; 64]              /* mul accumulator bit map (per-stage scratch) */
var BB_ROW    : [u32; 64]              /* mul row bit map */
var BB_DIAG_ADD   : i32 = 0i32         /* diagnostics: first bad sat_add_clause rc */
var BB_DIAG_SOLVE : i32 = 0x7Fi32      /* diagnostics: sat_solve rc */
var BB_DIAG_INIT  : i32 = 0x7Fi32      /* diagnostics: sat_init rc */

/* ============================================================================================================
 * THE STRUCTURAL SPINE -- what makes the circuit ONE substrate, not two.
 *
 * The bit-indirection above (BB_BITVAR) is the SAT encoding: it lets the judge REASON over a circuit.  But a
 * circuit the judge can reason over is the SAME object that should EXECUTE -- otherwise every primitive is
 * authored twice (a proof form AND a runtime form, the two-layer split).  The structural spine records, per
 * node, the OPERATION that built it (kind + operand node-ids + shift amount / const), so the very DAG the SAT
 * miter decides can also be EVALUATED on concrete inputs (bb_eval).  One definition; the judge proves it, the
 * evaluator runs it, the invention engine mutates it.  Nodes are built bottom-up, so a node's operands always
 * have SMALLER ids -- evaluation is a single forward sweep, no recursion, no stack. */
const EK_VAR   : u32 = 0u32
const EK_CONST : u32 = 1u32
const EK_AND   : u32 = 2u32
const EK_OR    : u32 = 3u32
const EK_XOR   : u32 = 4u32
const EK_NOT   : u32 = 5u32
const EK_SHL   : u32 = 6u32
const EK_SHR   : u32 = 7u32
const EK_ADD   : u32 = 8u32
const EK_SUB   : u32 = 9u32
const EK_MUL   : u32 = 10u32

var BB_NKIND  : [u32; 128]             /* per-node operation kind (EK_*) */
var BB_NA     : [u32; 128]             /* operand a node-id  (or VAR index for EK_VAR) */
var BB_NB     : [u32; 128]             /* operand b node-id  (binary ops) */
var BB_NK     : [u64; 128]             /* shift amount k     (EK_SHL/EK_SHR) */
var BB_NCONST : [u64; 128]            /* literal value      (EK_CONST) */
var BB_INVAL  : [u64; 8]               /* concrete input word per VAR index (bb_set_input) */
var BB_NVAL   : [u64; 128]             /* evaluation scratch: the concrete value of each node */

/* record node n's structure (called by every builder right after bb_node_alloc). */
fn bb_struct(n: u32, kind: u32, a: u32, b: u32, k: u64) -> u64 {
    if n >= BB_MAX_NODES { return 0u64 }
    BB_NKIND[n as u64] = kind
    BB_NA[n as u64]    = a
    BB_NB[n as u64]    = b
    BB_NK[n as u64]    = k
    return 0u64
}

fn bb_diag_add() -> i32 @export { return BB_DIAG_ADD }
fn bb_diag_solve() -> i32 @export { return BB_DIAG_SOLVE }
fn bb_diag_init() -> i32 @export { return BB_DIAG_INIT }

fn bb_pos(v: u32) -> u32 { return v << 1u32 }
fn bb_neg(v: u32) -> u32 { return (v << 1u32) | 1u32 }

fn bb_newvar() -> u32 {
    if BB_NV >= BB_MAX_VARS { BB_ERR = 1u8 ; return 1u32 }
    BB_NV = BB_NV + 1u32
    return BB_NV
}

/* append a clause of n lits (already in BB_CL[0..n)) to the stream */
fn bb_emit(n: u32) -> u64 {
    if BB_SP + (n as u64) + 1u64 > BB_STREAM_CAP { BB_ERR = 1u8 ; return 0u64 }
    BB_STREAM[BB_SP] = n
    let mut i : u64 = 0u64
    while i < (n as u64) {
        BB_STREAM[BB_SP + 1u64 + i] = BB_CL[i]
        i = i + 1u64
    }
    BB_SP = BB_SP + (n as u64) + 1u64
    BB_NCL = BB_NCL + 1u64
    return 0u64
}
fn bb_cl1(a: u32) -> u64 { BB_CL[0u64] = a ; return bb_emit(1u32) }
fn bb_cl2(a: u32, b: u32) -> u64 { BB_CL[0u64] = a ; BB_CL[1u64] = b ; return bb_emit(2u32) }
fn bb_cl3(a: u32, b: u32, c: u32) -> u64 { BB_CL[0u64] = a ; BB_CL[1u64] = b ; BB_CL[2u64] = c ; return bb_emit(3u32) }

/* z <-> x AND y */
fn bb_gate_and(z: u32, x: u32, y: u32) -> u64 {
    bb_cl2(bb_neg(z), bb_pos(x))
    bb_cl2(bb_neg(z), bb_pos(y))
    bb_cl3(bb_pos(z), bb_neg(x), bb_neg(y))
    return 0u64
}
/* z <-> x OR y */
fn bb_gate_or(z: u32, x: u32, y: u32) -> u64 {
    bb_cl2(bb_pos(z), bb_neg(x))
    bb_cl2(bb_pos(z), bb_neg(y))
    bb_cl3(bb_neg(z), bb_pos(x), bb_pos(y))
    return 0u64
}
/* z <-> x XOR y */
fn bb_gate_xor(z: u32, x: u32, y: u32) -> u64 {
    bb_cl3(bb_neg(z), bb_pos(x), bb_pos(y))
    bb_cl3(bb_neg(z), bb_neg(x), bb_neg(y))
    bb_cl3(bb_pos(z), bb_neg(x), bb_pos(y))
    bb_cl3(bb_pos(z), bb_pos(x), bb_neg(y))
    return 0u64
}
/* z <-> NOT x */
fn bb_gate_not(z: u32, x: u32) -> u64 {
    bb_cl2(bb_pos(z), bb_pos(x))
    bb_cl2(bb_neg(z), bb_neg(x))
    return 0u64
}
/* m <-> MAJ(x, y, c) */
fn bb_gate_maj(m: u32, x: u32, y: u32, c: u32) -> u64 {
    bb_cl3(bb_neg(m), bb_pos(x), bb_pos(y))
    bb_cl3(bb_neg(m), bb_pos(x), bb_pos(c))
    bb_cl3(bb_neg(m), bb_pos(y), bb_pos(c))
    bb_cl3(bb_pos(m), bb_neg(x), bb_neg(y))
    bb_cl3(bb_pos(m), bb_neg(x), bb_neg(c))
    bb_cl3(bb_pos(m), bb_neg(y), bb_neg(c))
    return 0u64
}

/* fresh full-adder bit: returns the sum var; *the carry-out var is returned through BB_FA_COUT. */
var BB_FA_COUT : u32 = 0u32
fn bb_fulladder(x: u32, y: u32, cin: u32) -> u32 {
    let t : u32 = bb_newvar()
    bb_gate_xor(t, x, y)
    let s : u32 = bb_newvar()
    bb_gate_xor(s, t, cin)
    let co : u32 = bb_newvar()
    bb_gate_maj(co, x, y, cin)
    BB_FA_COUT = co
    return s
}

/* set the decision width and reset everything (per-decision scope). */
fn bb_reset(w: u64) -> i32 @export {
    let mut ww : u64 = w
    if ww == 0u64 { ww = 64u64 }
    if ww > 64u64 { ww = 64u64 }
    BB_W = ww
    BB_NV = 0u32
    BB_NN = 0u32
    BB_ERR = 0u8
    BB_SP = 0u64
    BB_NCL = 0u64
    let mut i : u64 = 0u64
    while i < 8u64 { BB_INBASE[i] = 0u32 ; i = i + 1u64 }
    BB_ZVAR = bb_newvar()
    bb_cl1(bb_neg(BB_ZVAR))           /* pinned 0 */
    BB_OVAR = bb_newvar()
    bb_cl1(bb_pos(BB_OVAR))           /* pinned 1 */
    return 0i32
}

fn bb_node_alloc() -> u32 {
    if BB_NN >= BB_MAX_NODES { BB_ERR = 1u8 ; return 0u32 }
    let n : u32 = BB_NN
    BB_NN = BB_NN + 1u32
    return n
}
fn bb_bit(n: u32, i: u64) -> u32 { return BB_BITVAR[(n as u64) * 64u64 + i] }
fn bb_setbit(n: u32, i: u64, v: u32) -> u64 { BB_BITVAR[(n as u64) * 64u64 + i] = v ; return 0u64 }

/* an input word (v < 8): the SAME v aliases the SAME sat vars on every use. */
fn bb_var(v: u32) -> u32 @export {
    if v >= BB_MAX_INPUTS { BB_ERR = 1u8 ; return BB_SENT }
    if BB_INBASE[v as u64] == 0u32 {
        let base : u32 = BB_NV + 1u32
        let mut i : u64 = 0u64
        while i < BB_W { bb_newvar() ; i = i + 1u64 }
        BB_INBASE[v as u64] = base
    }
    let n : u32 = bb_node_alloc()
    let b : u32 = BB_INBASE[v as u64]
    let mut i : u64 = 0u64
    while i < BB_W { bb_setbit(n, i, b + (i as u32)) ; i = i + 1u64 }
    bb_struct(n, EK_VAR, v, 0u32, 0u64)            /* the spine: this node IS input v */
    return n
}

/* a constant word: bits alias the global pinned ZERO/ONE vars -- zero clauses, zero fresh vars. */
fn bb_const(c: u64) -> u32 @export {
    let n : u32 = bb_node_alloc()
    let mut i : u64 = 0u64
    while i < BB_W {
        if ((c >> i) & 1u64) == 1u64 { bb_setbit(n, i, BB_OVAR) } else { bb_setbit(n, i, BB_ZVAR) }
        i = i + 1u64
    }
    bb_struct(n, EK_CONST, 0u32, 0u32, 0u64)       /* the spine: this node IS the literal c */
    BB_NCONST[n as u64] = c
    return n
}

fn bb_and(a: u32, b: u32) -> u32 @export {
    if a >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }   /* [W19] node ids are untrusted: bb_bit(a/b,i) reads BB_BITVAR[id*64+i] OOB otherwise */
    if b >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }
    let n : u32 = bb_node_alloc()
    let mut i : u64 = 0u64
    while i < BB_W {
        let z : u32 = bb_newvar()
        bb_gate_and(z, bb_bit(a, i), bb_bit(b, i))
        bb_setbit(n, i, z)
        i = i + 1u64
    }
    bb_struct(n, EK_AND, a, b, 0u64)
    return n
}
fn bb_or(a: u32, b: u32) -> u32 @export {
    if a >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }   /* [W19] untrusted node ids */
    if b >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }
    let n : u32 = bb_node_alloc()
    let mut i : u64 = 0u64
    while i < BB_W {
        let z : u32 = bb_newvar()
        bb_gate_or(z, bb_bit(a, i), bb_bit(b, i))
        bb_setbit(n, i, z)
        i = i + 1u64
    }
    bb_struct(n, EK_OR, a, b, 0u64)
    return n
}
fn bb_xor(a: u32, b: u32) -> u32 @export {
    if a >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }   /* [W19] untrusted node ids */
    if b >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }
    let n : u32 = bb_node_alloc()
    let mut i : u64 = 0u64
    while i < BB_W {
        let z : u32 = bb_newvar()
        bb_gate_xor(z, bb_bit(a, i), bb_bit(b, i))
        bb_setbit(n, i, z)
        i = i + 1u64
    }
    bb_struct(n, EK_XOR, a, b, 0u64)
    return n
}
fn bb_not(a: u32) -> u32 @export {
    if a >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }   /* [W19] untrusted node id */
    let n : u32 = bb_node_alloc()
    let mut i : u64 = 0u64
    while i < BB_W {
        let z : u32 = bb_newvar()
        bb_gate_not(z, bb_bit(a, i))
        bb_setbit(n, i, z)
        i = i + 1u64
    }
    bb_struct(n, EK_NOT, a, 0u32, 0u64)
    return n
}

/* logical shifts by a CONSTANT: pure bit remapping, vacated bits alias pinned ZERO. */
fn bb_shl(a: u32, k: u64) -> u32 @export {
    if a >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }   /* [W19] untrusted node id */
    let n : u32 = bb_node_alloc()
    let mut i : u64 = 0u64
    while i < BB_W {
        if i < k { bb_setbit(n, i, BB_ZVAR) } else { bb_setbit(n, i, bb_bit(a, i - k)) }
        i = i + 1u64
    }
    bb_struct(n, EK_SHL, a, 0u32, k)
    return n
}
fn bb_shr(a: u32, k: u64) -> u32 @export {
    if a >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }   /* [W19] untrusted node id */
    let n : u32 = bb_node_alloc()
    let mut i : u64 = 0u64
    while i < BB_W {
        if i + k < BB_W { bb_setbit(n, i, bb_bit(a, i + k)) } else { bb_setbit(n, i, BB_ZVAR) }
        i = i + 1u64
    }
    bb_struct(n, EK_SHR, a, 0u32, k)
    return n
}

/* ripple-carry adder core: out node = a + b + cin (cin = ZVAR or OVAR), mod 2^w. */
fn bb_add_core(a: u32, b: u32, cin: u32) -> u32 {
    let n : u32 = bb_node_alloc()
    let mut c : u32 = cin
    let mut i : u64 = 0u64
    while i < BB_W {
        let s : u32 = bb_fulladder(bb_bit(a, i), bb_bit(b, i), c)
        c = BB_FA_COUT
        bb_setbit(n, i, s)
        i = i + 1u64
    }
    return n
}
fn bb_add(a: u32, b: u32) -> u32 @export {
    if a >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }   /* [W19] untrusted node ids */
    if b >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }
    let n : u32 = bb_add_core(a, b, BB_ZVAR)
    bb_struct(n, EK_ADD, a, b, 0u64)
    return n
}
/* a - b = a + ~b + 1 */
fn bb_sub(a: u32, b: u32) -> u32 @export {
    if a >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }   /* [W19] guard b BEFORE bb_not(b) reads OOB */
    if b >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }
    let nb : u32 = bb_not(b)
    let n : u32 = bb_add_core(a, nb, BB_OVAR)
    bb_struct(n, EK_SUB, a, b, 0u64)               /* eval: (a + ~b + 1) = a - b mod 2^w */
    return n
}

/* mul: shift-add accumulation.  Row j (a's bit j gating b), truncated adders from bit j upward. */
fn bb_mul(a: u32, b: u32) -> u32 @export {
    if a >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }   /* [W19] untrusted node ids */
    if b >= BB_MAX_NODES { BB_ERR = 1u8 ; return BB_SENT }
    /* row 0: acc_i = a_0 AND b_i */
    let a0 : u32 = bb_bit(a, 0u64)
    let mut i : u64 = 0u64
    while i < BB_W {
        let z : u32 = bb_newvar()
        bb_gate_and(z, a0, bb_bit(b, i))
        BB_ACC[i] = z
        i = i + 1u64
    }
    /* stages j = 1..w-1: acc[j..w) += (a_j AND b[0..w-j)) at offset j */
    let mut j : u64 = 1u64
    while j < BB_W {
        let aj : u32 = bb_bit(a, j)
        let mut t : u64 = 0u64
        while t + j < BB_W {
            let r : u32 = bb_newvar()
            bb_gate_and(r, aj, bb_bit(b, t))
            BB_ROW[t] = r
            t = t + 1u64
        }
        let mut c : u32 = BB_ZVAR
        let mut k : u64 = j
        while k < BB_W {
            let s : u32 = bb_fulladder(BB_ACC[k], BB_ROW[k - j], c)
            c = BB_FA_COUT
            BB_ACC[k] = s
            k = k + 1u64
        }
        j = j + 1u64
    }
    let n : u32 = bb_node_alloc()
    i = 0u64
    while i < BB_W { bb_setbit(n, i, BB_ACC[i]) ; i = i + 1u64 }
    bb_struct(n, EK_MUL, a, b, 0u64)
    return n
}

/* THE DECIDER: 1 iff a == b over Z/2^w (UNSAT of "some bit differs"), 0 with a countermodel if not,
 * 0xFF on any capacity/input error (the decision is POISONED, never fabricated).  Snapshots and
 * restores the var/stream cursors, so the DAG remains reusable for further bb_equal calls. */
fn bb_equal(a: u32, b: u32) -> u8 @export {
    if BB_ERR == 1u8 { return 0xFFu8 }
    if a == BB_SENT { return 0xFFu8 }
    if b == BB_SENT { return 0xFFu8 }
    if a >= BB_NN { return 0xFFu8 }
    if b >= BB_NN { return 0xFFu8 }
    let save_nv : u32 = BB_NV
    let save_sp : u64 = BB_SP
    let save_ncl : u64 = BB_NCL
    /* difference bits + the big OR */
    let mut i : u64 = 0u64
    while i < BB_W {
        let d : u32 = bb_newvar()
        bb_gate_xor(d, bb_bit(a, i), bb_bit(b, i))
        BB_CL[i] = bb_pos(d)                    /* collect for the OR clause (xor gates emit via scratch first) */
        i = i + 1u64
    }
    /* NOTE: bb_gate_xor uses BB_CL internally -- rebuild the OR lits now from the d vars just made:
     * the d vars were allocated consecutively save_nv+1 .. save_nv+w. */
    i = 0u64
    while i < BB_W {
        BB_CL[i] = bb_pos(save_nv + 1u32 + (i as u32))
        i = i + 1u64
    }
    bb_emit(BB_W as u32)
    let mut verdict : u8 = 0xFFu8
    BB_DIAG_ADD = 0i32
    BB_DIAG_SOLVE = 0x7Fi32
    BB_DIAG_INIT = 0x7Fi32
    if BB_ERR == 0u8 {
        let irc : i32 = sat_init(BB_NV)
        BB_DIAG_INIT = irc
        if irc == 0i32 {
            /* replay the buffered stream */
            let mut sp : u64 = 0u64
            let mut bad : u8 = 0u8
            while sp < BB_SP {
                let nl : u32 = BB_STREAM[sp]
                let mut q : u64 = 0u64
                while q < (nl as u64) {
                    BB_CL[q] = BB_STREAM[sp + 1u64 + q]
                    q = q + 1u64
                }
                let rc : i32 = sat_add_clause((&BB_CL as u64) as *u32, nl)
                if rc != 0i32 { if bad == 0u8 { BB_DIAG_ADD = rc } bad = 1u8 }
                sp = sp + (nl as u64) + 1u64
            }
            if bad == 0u8 {
                let sv : i32 = sat_solve()
                BB_DIAG_SOLVE = sv
                if sv == BB_SAT_UNSAT { verdict = 1u8 }
                if sv == BB_SAT_SAT { verdict = 0u8 }
            }
        }
    }
    /* restore: the DAG survives; the difference encoding evaporates */
    BB_NV = save_nv
    BB_SP = save_sp
    BB_NCL = save_ncl
    return verdict
}

/* ============================================================================================================
 * THE EVALUATOR -- the circuit EXECUTES (the half that makes the substrate ONE, not two).
 *
 * Set the concrete input words with bb_set_input(v, value), then bb_eval(node) sweeps the DAG FORWARD -- every
 * operand id is smaller than the node that uses it (bottom-up construction), so one pass over 0..node computes
 * each node's concrete w-bit value with no recursion.  The very DAG the SAT judge (bb_equal) PROVES is the DAG
 * this evaluator RUNS: a primitive is now a single object that is both proven and executed, never a proof form
 * plus a divorced runtime copy.  bb_eval(circuit) reproduces the native primitive byte-for-byte, so the native
 * (wvb_*) form is the proven-equal fast PROJECTION of this one definition, not a second authored layer. */
fn bb_set_input(v: u32, val: u64) -> i32 @export {
    if v >= BB_MAX_INPUTS { return 0xFi32 }
    BB_INVAL[v as u64] = val
    return 0i32
}

/* the w-bit width mask, built without a shift-by-width (w in 1..64, so 1u64<<64 UB never happens). */
fn bb_wmask() -> u64 {
    let mut m : u64 = 0u64
    let mut i : u64 = 0u64
    while i < BB_W { m = (m << 1u64) | 1u64 ; i = i + 1u64 }
    return m
}

/* evaluate node `t` on the current inputs (bb_set_input); returns its concrete value over Z/2^w (0 if t is out
 * of range).  Pure function of the construction sequence + inputs -- deterministic, like the encoder. */
fn bb_eval(t: u32) -> u64 @export {
    if t >= BB_NN { return 0u64 }
    let mask : u64 = bb_wmask()
    let mut n : u32 = 0u32
    while n <= t {
        let kind : u32 = BB_NKIND[n as u64]
        let ia   : u32 = BB_NA[n as u64]
        let ib   : u32 = BB_NB[n as u64]
        let va   : u64 = BB_NVAL[ia as u64]                 /* operands precede n -> already evaluated */
        let vb   : u64 = BB_NVAL[ib as u64]
        let mut v : u64 = 0u64
        if kind == EK_VAR   { if (ia as u64) < 8u64 { v = BB_INVAL[ia as u64] & mask } }
        if kind == EK_CONST { v = BB_NCONST[n as u64] & mask }
        if kind == EK_AND   { v = (va & vb) & mask }
        if kind == EK_OR    { v = (va | vb) & mask }
        if kind == EK_XOR   { v = (va ^ vb) & mask }
        if kind == EK_NOT   { v = (~va) & mask }
        if kind == EK_SHL   {
            let k : u64 = BB_NK[n as u64]
            if k < 64u64 { v = (va << k) & mask }
        }
        if kind == EK_SHR   {
            let k : u64 = BB_NK[n as u64]
            if k < 64u64 { v = (va >> k) & mask }
        }
        if kind == EK_ADD   { v = (va + vb) & mask }
        if kind == EK_SUB   { v = (va - vb) & mask }
        if kind == EK_MUL   { v = (va * vb) & mask }
        BB_NVAL[n as u64] = v
        n = n + 1u32
    }
    return BB_NVAL[t as u64]
}
