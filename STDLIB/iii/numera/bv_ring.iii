module bv_ring

/* ===== bv_ring: the RIGHT kernel for ring-0 codegen ========================
 * A u64-SOUND decision layer.  It decides equality of expressions over the
 * machine-word ring Z/2^64 for the {variable, u64 constant, +, -, *, <<}
 * fragment by reducing each side to a canonical multivariate-polynomial normal
 * form (monomials whose coefficients are taken mod 2^64 -- i.e. native u64
 * wraparound).
 *
 * Soundness: poly-equal => functionally-equal for ALL u64 valuations (a
 * polynomial identity over Z/2^64 holds pointwise).  It is intentionally
 * CONSERVATIVE: functionally-equal-but-not-poly-equal pairs (which exist over a
 * finite ring -- e.g. x^2 == x mod 2 functionally) are NOT certified, so a
 * proof-carrying optimizer that gates a rewrite on bv_equal NEVER blesses an
 * unsound rewrite; it may only decline a sound one.  That is exactly the
 * guarantee a ring-0 optimizer needs.
 *
 * Unlike the Peano-Nat type-theory kernel, bv_ring's THEORY is machine-word
 * arithmetic: multiple variables, large u64 constants, and shifts are modelled
 * natively -- so it can actually reason about the code cg_r3 emits.  No
 * external dependencies; fully deterministic; bounded arena (W3/Trap-7 safe:
 * all scratch is module-scope). */

const BV_MAX_VARS : u32 = 4u32
const BV_MAX_MONO : u32 = 32u32
const BV_MAX_POLY : u32 = 96u32
const BV_FIELD    : u32 = 255u32     /* max per-variable exponent (8-bit field) */

var BV_KEY  : [u32; 3072]   /* BV_MAX_POLY(96) * BV_MAX_MONO(32) packed exponent keys */
var BV_COEF : [u64; 3072]   /* coefficient mod 2^64 (native wrap) */
var BV_LEN  : [u32; 96]     /* live monomial count per poly slot */
var BV_USED : u32 = 0u32
var BV_ERR  : u8  = 0u8      /* sticky: arena / exponent overflow this session */
/* CANONICAL-SERIALIZATION sentinel + scratch (harmony item 2): the byte length 0xFFFF…FF can never be a
 * real serialization length (a poly is <=32 monomials * 12 bytes = 384), so it is an unambiguous REFUSE. */
const BV_CANON_REFUSE : u64 = 0xFFFFFFFFFFFFFFFFu64
var BV_CANON_K : [u32; 32]   /* gathered live monomial keys, then key-sorted */
var BV_CANON_C : [u64; 32]   /* their coefficients (kept paired through the sort) */

/* Reset the arena before each certification (per-decision scope). */
fn bv_reset() -> i32 @export {
    BV_USED = 0u32
    BV_ERR  = 0u8
    return 0i32
}

fn bv_alloc() -> u32 {
    if BV_USED >= BV_MAX_POLY { BV_ERR = 1u8 ; return 0u32 }
    let s : u32 = BV_USED
    BV_USED = BV_USED + 1u32
    BV_LEN[(s as u64)] = 0u32
    return s
}

/* Add (key, coeff) into poly slot s, combining equal keys.  Zero coeffs are
 * never inserted; a combine that lands on zero is left in place and skipped at
 * compare time. */
fn bv_push(s: u32, key: u32, coeff: u64) -> i32 {
    if coeff == 0u64 { return 0i32 }
    let sb : u64 = s as u64
    let base : u64 = sb * 32u64
    let n : u32 = BV_LEN[sb]
    let mut i : u32 = 0u32
    while i < n {
        let idx : u64 = base + (i as u64)
        if BV_KEY[idx] == key {
            BV_COEF[idx] = BV_COEF[idx] + coeff
            return 0i32
        }
        i = i + 1u32
    }
    if n >= BV_MAX_MONO { BV_ERR = 1u8 ; return 1i32 }
    let widx : u64 = base + (n as u64)
    BV_KEY[widx]  = key
    BV_COEF[widx] = coeff
    BV_LEN[sb] = n + 1u32
    return 0i32
}

fn bv_const(c: u64) -> u32 @export {
    let s : u32 = bv_alloc()
    bv_push(s, 0u32, c)
    return s
}

fn bv_var(v: u32) -> u32 @export {
    let s : u32 = bv_alloc()
    if v < BV_MAX_VARS {
        let one : u32 = 1u32
        let key : u32 = one << (v * 8u32)   /* exponent 1 in field v */
        bv_push(s, key, 1u64)
    } else {
        BV_ERR = 1u8
    }
    return s
}

fn bv_copy_into(dst: u32, src: u32) -> i32 {
    let sbase : u64 = (src as u64) * 32u64
    let n : u32 = BV_LEN[(src as u64)]
    let mut i : u32 = 0u32
    while i < n {
        let idx : u64 = sbase + (i as u64)
        bv_push(dst, BV_KEY[idx], BV_COEF[idx])
        i = i + 1u32
    }
    return 0i32
}

fn bv_add(a: u32, b: u32) -> u32 @export {
    let s : u32 = bv_alloc()
    bv_copy_into(s, a)
    bv_copy_into(s, b)
    return s
}

fn bv_neg(a: u32) -> u32 {
    let s : u32 = bv_alloc()
    let abase : u64 = (a as u64) * 32u64
    let n : u32 = BV_LEN[(a as u64)]
    let mut i : u32 = 0u32
    while i < n {
        let idx : u64 = abase + (i as u64)
        bv_push(s, BV_KEY[idx], 0u64 - BV_COEF[idx])
        i = i + 1u32
    }
    return s
}

fn bv_sub(a: u32, b: u32) -> u32 @export {
    let nb : u32 = bv_neg(b)
    return bv_add(a, nb)
}

/* Per-field exponent add; sets BV_ERR + returns 0 on field overflow. */
fn bv_key_add(ka: u32, kb: u32) -> u32 {
    let mut r : u32 = 0u32
    let mut i : u32 = 0u32
    while i < BV_MAX_VARS {
        let sh : u32 = i * 8u32
        let ea : u32 = (ka >> sh) & 0xFFu32
        let eb : u32 = (kb >> sh) & 0xFFu32
        let es : u32 = ea + eb
        if es > BV_FIELD { BV_ERR = 1u8 ; return 0u32 }
        r = r | (es << sh)
        i = i + 1u32
    }
    return r
}

fn bv_mul(a: u32, b: u32) -> u32 @export {
    let s : u32 = bv_alloc()
    let abase : u64 = (a as u64) * 32u64
    let bbase : u64 = (b as u64) * 32u64
    let na : u32 = BV_LEN[(a as u64)]
    let nb : u32 = BV_LEN[(b as u64)]
    let mut i : u32 = 0u32
    while i < na {
        let ai : u64 = abase + (i as u64)
        let mut j : u32 = 0u32
        while j < nb {
            let bj : u64 = bbase + (j as u64)
            let k : u32 = bv_key_add(BV_KEY[ai], BV_KEY[bj])
            bv_push(s, k, BV_COEF[ai] * BV_COEF[bj])
            j = j + 1u32
        }
        i = i + 1u32
    }
    return s
}

fn bv_shl(a: u32, k: u32) -> u32 @export {
    /* C-BV-1: x86-64 SHL masks the shift count to 6 bits (k & 63), so x<<64 == x<<0 == x,
     * NOT 0.  Model the TARGET's mask so a certified rewrite is honored by the hardware
     * (the prior `k>=64 -> 0` was C's UB-as-zero, which the target does not implement). */
    let km : u32 = k & 63u32
    let one : u64 = 1u64
    let factor : u64 = one << (km as u64)
    let s : u32 = bv_alloc()
    let abase : u64 = (a as u64) * 32u64
    let n : u32 = BV_LEN[(a as u64)]
    let mut i : u32 = 0u32
    while i < n {
        let idx : u64 = abase + (i as u64)
        bv_push(s, BV_KEY[idx], BV_COEF[idx] * factor)
        i = i + 1u32
    }
    return s
}

/* Every NONZERO monomial of a appears with an equal coeff in b. */
fn bv_subset(a: u32, b: u32) -> u8 {
    let abase : u64 = (a as u64) * 32u64
    let bbase : u64 = (b as u64) * 32u64
    let na : u32 = BV_LEN[(a as u64)]
    let nb : u32 = BV_LEN[(b as u64)]
    let mut i : u32 = 0u32
    while i < na {
        let ai : u64 = abase + (i as u64)
        let ca : u64 = BV_COEF[ai]
        if ca != 0u64 {
            let ka : u32 = BV_KEY[ai]
            let mut found : u8 = 0u8
            let mut j : u32 = 0u32
            while j < nb {
                let bj : u64 = bbase + (j as u64)
                if BV_KEY[bj] == ka { if BV_COEF[bj] == ca { found = 1u8 } }
                j = j + 1u32
            }
            if found == 0u8 { return 0u8 }
        }
        i = i + 1u32
    }
    return 1u8
}

/* 1 iff a and b are the SAME canonical polynomial over Z/2^64 (=> equal as u64
 * functions for all valuations).  Any arena/exponent overflow -> 0 (decline). */
fn bv_equal(a: u32, b: u32) -> u8 @export {
    if BV_ERR == 1u8 { return 0u8 }
    if bv_subset(a, b) == 0u8 { return 0u8 }
    if bv_subset(b, a) == 0u8 { return 0u8 }
    return 1u8
}

/* 1 iff poly a is a pure CONSTANT (no nonzero variable monomial) -- i.e. the
 * expression equals a fixed u64 for ALL valuations.  Any overflow -> 0.  This
 * is the predicate a ring-0 optimizer uses to soundly fold an expression (even
 * one containing variables, e.g. x-x) to a compile-time constant. */
fn bv_is_const(s: u32) -> u8 @export {
    if BV_ERR == 1u8 { return 0u8 }
    let base : u64 = (s as u64) * 32u64
    let n : u32 = BV_LEN[(s as u64)]
    let mut i : u32 = 0u32
    while i < n {
        let idx : u64 = base + (i as u64)
        if BV_KEY[idx] != 0u32 { if BV_COEF[idx] != 0u64 { return 0u8 } }
        i = i + 1u32
    }
    return 1u8
}

/* The constant value of poly a (its key-0 coefficient, mod 2^64); 0 if absent.
 * Only meaningful when bv_is_const(a) == 1. */
fn bv_const_val(s: u32) -> u64 @export {
    let base : u64 = (s as u64) * 32u64
    let n : u32 = BV_LEN[(s as u64)]
    let mut i : u32 = 0u32
    while i < n {
        let idx : u64 = base + (i as u64)
        if BV_KEY[idx] == 0u32 { return BV_COEF[idx] }
        i = i + 1u32
    }
    return 0u64
}

/* CANONICAL SERIALIZATION (harmony item 2) -- turn poly slot s into a UNIQUE byte string per polynomial
 * (ring) equivalence class, so the class gets a content-addressable NAME.  Gathers the LIVE (nonzero-coeff)
 * monomials -- bv_push leaves latent zeros after cancellation (x-x), which bv_subset/bv_equal already skip,
 * so we skip them here too -- selection-sorts them ASCENDING by the packed exponent key (keys are UNIQUE per
 * slot, since bv_push combines equal keys, so there are no ties and the order is deterministic), then streams
 * each monomial as key(4 LE) || coeff(8 LE).  Because this is a true NORMAL FORM, bv_equal(a,b)==1 IFF
 * bv_canon_serialize(a)==bv_canon_serialize(b) byte-for-byte: order-independent, zero-collapsing, exact.
 * Returns the byte length written, or BV_CANON_REFUSE (writing NOTHING) when BV_ERR is set (an overflowed
 * poly must NEVER mint an address) or the buffer `cap` is too small (no OOB write). */
fn bv_canon_serialize(s: u32, out: *u8, cap: u64) -> u64 @export {
    if BV_ERR == 1u8 { return BV_CANON_REFUSE }
    if s >= BV_MAX_POLY { return BV_CANON_REFUSE }
    let base : u64 = (s as u64) * 32u64
    let n : u32 = BV_LEN[(s as u64)]
    /* gather live (nonzero) monomials into the canon scratch */
    let mut m : u32 = 0u32
    let mut i : u32 = 0u32
    while i < n {
        let idx : u64 = base + (i as u64)
        let c : u64 = BV_COEF[idx]
        if c != 0u64 {
            BV_CANON_K[(m as u64)] = BV_KEY[idx]
            BV_CANON_C[(m as u64)] = c
            m = m + 1u32
        }
        i = i + 1u32
    }
    /* selection sort ascending by key (m <= 32; keys unique -> total order, deterministic) */
    let mut a : u32 = 0u32
    while a < m {
        let mut minj : u32 = a
        let mut b : u32 = a + 1u32
        while b < m {
            if BV_CANON_K[(b as u64)] < BV_CANON_K[(minj as u64)] { minj = b }
            b = b + 1u32
        }
        let tk : u32 = BV_CANON_K[(a as u64)]
        let tc : u64 = BV_CANON_C[(a as u64)]
        BV_CANON_K[(a as u64)] = BV_CANON_K[(minj as u64)]
        BV_CANON_C[(a as u64)] = BV_CANON_C[(minj as u64)]
        BV_CANON_K[(minj as u64)] = tk
        BV_CANON_C[(minj as u64)] = tc
        a = a + 1u32
    }
    /* cap guard: each monomial is 12 bytes (key 4 LE + coeff 8 LE); refuse rather than write OOB */
    let total : u64 = (m as u64) * 12u64
    if total > cap { return BV_CANON_REFUSE }
    /* stream key(4 LE) || coeff(8 LE) per sorted monomial */
    let mut o : u64 = 0u64
    let mut j : u32 = 0u32
    while j < m {
        let k : u32 = BV_CANON_K[(j as u64)]
        out[o]        = (k & 0xFFu32) as u8
        out[o + 1u64] = ((k >> 8u32) & 0xFFu32) as u8
        out[o + 2u64] = ((k >> 16u32) & 0xFFu32) as u8
        out[o + 3u64] = ((k >> 24u32) & 0xFFu32) as u8
        o = o + 4u64
        let c : u64 = BV_CANON_C[(j as u64)]
        let mut bi : u64 = 0u64
        while bi < 8u64 {
            out[o] = ((c >> (bi * 8u64)) & 0xFFu64) as u8
            o = o + 1u64
            bi = bi + 1u64
        }
        j = j + 1u32
    }
    return total
}

/* ===== bitwise fragment: bit-parallel exhaustive decider ===================
 * For a PURE bitwise expression (variables, constants, & | ^ ~) over <=6 vars,
 * evaluate it on the "truth-table column" magic constants BW_M0..BW_M5 (bit b
 * of BW_Mi = bit i of the position index b).  Because &|^~ are bit-parallel
 * (each output bit depends ONLY on the same-position input bits) and <=6 vars
 * means all 2^n <= 64 combinations appear across the 64 bit positions,
 * lhs(M) == rhs(M) over all 64 bits  IFF  lhs == rhs for EVERY u64 valuation.
 * A complete proof with a single u64 evaluation -- no loop.  >6 distinct vars
 * -> BW_ERR (64 positions cannot realize 2^n > 64 combinations) -> decline. */
const BW_M0 : u64 = 0xAAAAAAAAAAAAAAAAu64
const BW_M1 : u64 = 0xCCCCCCCCCCCCCCCCu64
const BW_M2 : u64 = 0xF0F0F0F0F0F0F0F0u64
const BW_M3 : u64 = 0xFF00FF00FF00FF00u64
const BW_M4 : u64 = 0xFFFF0000FFFF0000u64
const BW_M5 : u64 = 0xFFFFFFFF00000000u64
const BW_ONES : u64 = 0xFFFFFFFFFFFFFFFFu64
var BW_ERR : u8 = 0u8

fn bw_reset() -> i32 @export { BW_ERR = 0u8 ; return 0i32 }

/* Evaluate variable i to its truth-table column (i in [0,5]); i>=6 -> BW_ERR. */
fn bw_var(i: u32) -> u64 @export {
    if i == 0u32 { return BW_M0 }
    if i == 1u32 { return BW_M1 }
    if i == 2u32 { return BW_M2 }
    if i == 3u32 { return BW_M3 }
    if i == 4u32 { return BW_M4 }
    if i == 5u32 { return BW_M5 }
    BW_ERR = 1u8
    return 0u64
}
fn bw_const(c: u64) -> u64 @export { return c }
fn bw_and(a: u64, b: u64) -> u64 @export { return a & b }
fn bw_or(a: u64, b: u64)  -> u64 @export { return a | b }
fn bw_xor(a: u64, b: u64) -> u64 @export { return a ^ b }
fn bw_not(a: u64) -> u64 @export { return a ^ BW_ONES }

/* 1 iff the two pure-bitwise expressions are equal for ALL u64 valuations. */
fn bw_equal(a: u64, b: u64) -> u8 @export {
    if BW_ERR == 1u8 { return 0u8 }
    if a == b { return 1u8 }
    return 0u8
}

/* ===== column-stack bitwise decider: exact for >6 variables (W3.15/ENHANCE-12) ==
 * The single-register decider above caps at 6 vars (64 positions cannot realize
 * 2^k > 64 valuations).  Surpass: stack W = ceil(2^k / 64) u64 words per value so
 * EVERY one of the 2^k valuations occupies its own bit position across the stack.
 * Variable i's column over position b (b = word*64 + offset): bit b = bit i of b.
 *   - i < 6 : within-word periodic -> BW_Mi in every word.
 *   - i >= 6: constant within a word -> word w is all-ones iff bit (i-6) of w is set.
 * &|^~ apply word-wise; equality is all-words-equal; a satisfying assignment is the
 * lowest set bit across the stack (var i = bit i of that position).  No float, no
 * sampling: a complete decision within the deterministic gate (I1). */
const BWS_MAX_VARS   : u32 = 12u32          /* up to 2^12 = 4096 valuations */
const BWS_MAX_WORDS  : u64 = 64u64          /* 4096 / 64 = 64 u64 words per value */
const BWS_MAX_SLOTS  : u64 = 128u64         /* stacked-value arena depth */
const BWS_NO_WITNESS : u64 = 0xFFFFFFFFFFFFFFFFu64

var BWS_W      : [u64; 8192]   /* BWS_MAX_SLOTS(128) * BWS_MAX_WORDS(64) */
var BWS_NWORDS : u64 = 1u64    /* live words per value this session = ceil(2^k/64) */
var BWS_USED   : u64 = 0u64
var BWS_ERR    : u8  = 0u8

/* Begin a k-variable decision: fix the live word count and reset the arena.
 * k > BWS_MAX_VARS -> BWS_ERR (decline, never silently wrong). */
fn bws_init(k: u32) -> i32 @export {
    BWS_USED = 0u64
    BWS_ERR  = 0u8
    if k > BWS_MAX_VARS {
        BWS_ERR = 1u8
        BWS_NWORDS = 1u64
        return 1i32
    }
    if k <= 6u32 {
        BWS_NWORDS = 1u64
        return 0i32
    }
    let sh : u64 = (k - 6u32) as u64
    BWS_NWORDS = 1u64 << sh
    return 0i32
}

fn bws_alloc() -> u64 {
    if BWS_USED >= BWS_MAX_SLOTS { BWS_ERR = 1u8 ; return 0u64 }
    let s : u64 = BWS_USED
    BWS_USED = BWS_USED + 1u64
    return s
}

/* The within-word truth-table column for variable i in [0,5]. */
fn bws_mask6(i: u32) -> u64 {
    if i == 0u32 { return BW_M0 }
    if i == 1u32 { return BW_M1 }
    if i == 2u32 { return BW_M2 }
    if i == 3u32 { return BW_M3 }
    if i == 4u32 { return BW_M4 }
    return BW_M5
}

/* A fresh value = the truth-table column of variable i over BWS_NWORDS words. */
fn bws_var(i: u32) -> u64 @export {
    let s : u64 = bws_alloc()
    let base : u64 = s * BWS_MAX_WORDS
    let nw : u64 = BWS_NWORDS
    if (i as u64) < 6u64 {
        let col : u64 = bws_mask6(i)
        let mut w : u64 = 0u64
        while w < nw { BWS_W[base + w] = col ; w = w + 1u64 }
    } else {
        let hb : u64 = (i as u64) - 6u64
        let mut w : u64 = 0u64
        while w < nw {
            if ((w >> hb) & 1u64) == 1u64 { BWS_W[base + w] = BW_ONES } else { BWS_W[base + w] = 0u64 }
            w = w + 1u64
        }
    }
    return s
}

/* The boolean constants over all valuations (the only position-uniform constants). */
fn bws_false() -> u64 @export {
    let s : u64 = bws_alloc()
    let base : u64 = s * BWS_MAX_WORDS
    let mut w : u64 = 0u64
    while w < BWS_NWORDS { BWS_W[base + w] = 0u64 ; w = w + 1u64 }
    return s
}
fn bws_true() -> u64 @export {
    let s : u64 = bws_alloc()
    let base : u64 = s * BWS_MAX_WORDS
    let mut w : u64 = 0u64
    while w < BWS_NWORDS { BWS_W[base + w] = BW_ONES ; w = w + 1u64 }
    return s
}

fn bws_and(a: u64, b: u64) -> u64 @export {
    let s : u64 = bws_alloc()
    let ba : u64 = a * BWS_MAX_WORDS
    let bb : u64 = b * BWS_MAX_WORDS
    let bs : u64 = s * BWS_MAX_WORDS
    let mut w : u64 = 0u64
    while w < BWS_NWORDS { BWS_W[bs + w] = BWS_W[ba + w] & BWS_W[bb + w] ; w = w + 1u64 }
    return s
}
fn bws_or(a: u64, b: u64) -> u64 @export {
    let s : u64 = bws_alloc()
    let ba : u64 = a * BWS_MAX_WORDS
    let bb : u64 = b * BWS_MAX_WORDS
    let bs : u64 = s * BWS_MAX_WORDS
    let mut w : u64 = 0u64
    while w < BWS_NWORDS { BWS_W[bs + w] = BWS_W[ba + w] | BWS_W[bb + w] ; w = w + 1u64 }
    return s
}
fn bws_xor(a: u64, b: u64) -> u64 @export {
    let s : u64 = bws_alloc()
    let ba : u64 = a * BWS_MAX_WORDS
    let bb : u64 = b * BWS_MAX_WORDS
    let bs : u64 = s * BWS_MAX_WORDS
    let mut w : u64 = 0u64
    while w < BWS_NWORDS { BWS_W[bs + w] = BWS_W[ba + w] ^ BWS_W[bb + w] ; w = w + 1u64 }
    return s
}
fn bws_not(a: u64) -> u64 @export {
    let s : u64 = bws_alloc()
    let ba : u64 = a * BWS_MAX_WORDS
    let bs : u64 = s * BWS_MAX_WORDS
    let mut w : u64 = 0u64
    while w < BWS_NWORDS { BWS_W[bs + w] = BWS_W[ba + w] ^ BW_ONES ; w = w + 1u64 }
    return s
}

/* 1 iff a and b are equal for ALL 2^k valuations.  Any overflow/decline -> 0. */
fn bws_equal(a: u64, b: u64) -> u8 @export {
    if BWS_ERR == 1u8 { return 0u8 }
    let ba : u64 = a * BWS_MAX_WORDS
    let bb : u64 = b * BWS_MAX_WORDS
    let mut w : u64 = 0u64
    while w < BWS_NWORDS {
        if BWS_W[ba + w] != BWS_W[bb + w] { return 0u8 }
        w = w + 1u64
    }
    return 1u8
}

/* Lowest valuation index b (0..2^k-1) at which value a is TRUE, or BWS_NO_WITNESS
 * if a is false everywhere.  This recovers a satisfying assignment (var i = bit i). */
fn bws_witness(a: u64) -> u64 @export {
    let ba : u64 = a * BWS_MAX_WORDS
    let mut w : u64 = 0u64
    while w < BWS_NWORDS {
        let word : u64 = BWS_W[ba + w]
        if word != 0u64 {
            let mut o : u64 = 0u64
            while o < 64u64 {
                if ((word >> o) & 1u64) == 1u64 { return w * 64u64 + o }
                o = o + 1u64
            }
        }
        w = w + 1u64
    }
    return BWS_NO_WITNESS
}

/* Variable i's value (0/1) under the valuation indexed by b. */
fn bws_assign_bit(b: u64, i: u32) -> u8 @export {
    return ((b >> (i as u64)) & 1u64) as u8
}

/* KAT: the u64-sound decider.  POSITIVES are real Z/2^64 ring identities it
 * certifies; NEGATIVES are non-identities it must REJECT (soundness + non-
 * vacuity).  99 = pass; 1..13 ring, 14..18 const-fold, 19..30 bitwise. */
fn bv_ring_selftest() -> u64 @export {
    bv_reset()
    if bv_equal(bv_add(bv_var(0u32), bv_const(0u64)), bv_var(0u32)) != 1u8 { return 1u64 }   /* x+0 == x */
    bv_reset()
    if bv_equal(bv_mul(bv_var(0u32), bv_const(1u64)), bv_var(0u32)) != 1u8 { return 2u64 }   /* x*1 == x */
    bv_reset()
    if bv_equal(bv_mul(bv_var(0u32), bv_const(0u64)), bv_const(0u64)) != 1u8 { return 3u64 } /* x*0 == 0 */
    bv_reset()
    if bv_equal(bv_mul(bv_var(0u32), bv_const(2u64)), bv_shl(bv_var(0u32), 1u32)) != 1u8 { return 4u64 } /* x*2 == x<<1 */
    bv_reset()
    if bv_equal(bv_shl(bv_shl(bv_var(0u32), 2u32), 3u32), bv_shl(bv_var(0u32), 5u32)) != 1u8 { return 5u64 } /* (x<<2)<<3 == x<<5 */
    bv_reset()
    if bv_equal(bv_sub(bv_var(0u32), bv_var(0u32)), bv_const(0u64)) != 1u8 { return 6u64 }   /* x-x == 0 */
    bv_reset()
    let dl : u32 = bv_mul(bv_var(0u32), bv_add(bv_var(1u32), bv_var(2u32)))
    let dr : u32 = bv_add(bv_mul(bv_var(0u32), bv_var(1u32)), bv_mul(bv_var(0u32), bv_var(2u32)))
    if bv_equal(dl, dr) != 1u8 { return 7u64 }                                               /* x*(y+z) == xy+xz */
    bv_reset()
    if bv_equal(bv_add(bv_var(0u32), bv_var(1u32)), bv_add(bv_var(1u32), bv_var(0u32))) != 1u8 { return 8u64 } /* x+y == y+x */
    bv_reset()
    if bv_equal(bv_add(bv_var(0u32), bv_const(1u64)), bv_var(0u32)) != 0u8 { return 9u64 }   /* x+1 != x */
    bv_reset()
    if bv_equal(bv_mul(bv_var(0u32), bv_const(2u64)), bv_mul(bv_var(0u32), bv_const(3u64))) != 0u8 { return 10u64 } /* x*2 != x*3 */
    bv_reset()
    if bv_equal(bv_var(0u32), bv_var(1u32)) != 0u8 { return 11u64 }                          /* x != y */
    bv_reset()
    if bv_equal(bv_shl(bv_var(0u32), 1u32), bv_shl(bv_var(0u32), 2u32)) != 0u8 { return 12u64 } /* x<<1 != x<<2 */
    bv_reset()
    if bv_equal(bv_mul(bv_var(0u32), bv_var(1u32)), bv_mul(bv_var(0u32), bv_var(2u32))) != 0u8 { return 13u64 } /* xy != xz */
    /* generalized constant detection -- the ring-0 fold predicate */
    bv_reset()
    let cz : u32 = bv_sub(bv_var(0u32), bv_var(0u32))                      /* x - x */
    if bv_is_const(cz) != 1u8 { return 14u64 }
    if bv_const_val(cz) != 0u64 { return 15u64 }
    bv_reset()
    let c5 : u32 = bv_sub(bv_add(bv_const(5u64), bv_var(0u32)), bv_var(0u32))  /* 5 + x - x */
    if bv_is_const(c5) != 1u8 { return 16u64 }
    if bv_const_val(c5) != 5u64 { return 17u64 }
    bv_reset()
    if bv_is_const(bv_add(bv_var(0u32), bv_const(1u64))) != 0u8 { return 18u64 } /* x + 1 NOT const */
    /* ----- bitwise fragment (bit-parallel decider) ----- */
    bw_reset()
    if bw_equal(bw_and(bw_var(0u32), bw_var(0u32)), bw_var(0u32)) != 1u8 { return 19u64 }  /* x&x == x */
    bw_reset()
    if bw_equal(bw_or(bw_var(0u32), bw_var(0u32)), bw_var(0u32)) != 1u8 { return 20u64 }   /* x|x == x */
    bw_reset()
    if bw_equal(bw_xor(bw_var(0u32), bw_var(0u32)), bw_const(0u64)) != 1u8 { return 21u64 } /* x^x == 0 */
    bw_reset()
    if bw_equal(bw_or(bw_var(0u32), bw_const(0u64)), bw_var(0u32)) != 1u8 { return 22u64 }  /* x|0 == x */
    bw_reset()
    if bw_equal(bw_and(bw_var(0u32), bw_const(0u64)), bw_const(0u64)) != 1u8 { return 23u64 } /* x&0 == 0 */
    bw_reset()
    if bw_equal(bw_and(bw_var(0u32), bw_not(bw_var(0u32))), bw_const(0u64)) != 1u8 { return 24u64 } /* x & ~x == 0 */
    bw_reset()
    if bw_equal(bw_not(bw_not(bw_var(0u32))), bw_var(0u32)) != 1u8 { return 25u64 }         /* ~~x == x */
    bw_reset()
    let dm_l : u64 = bw_not(bw_and(bw_var(0u32), bw_var(1u32)))
    let dm_r : u64 = bw_or(bw_not(bw_var(0u32)), bw_not(bw_var(1u32)))
    if bw_equal(dm_l, dm_r) != 1u8 { return 26u64 }                                         /* ~(x&y)==~x|~y (De Morgan) */
    bw_reset()
    let xr_l : u64 = bw_xor(bw_var(0u32), bw_var(1u32))
    let xr_r : u64 = bw_and(bw_or(bw_var(0u32), bw_var(1u32)), bw_not(bw_and(bw_var(0u32), bw_var(1u32))))
    if bw_equal(xr_l, xr_r) != 1u8 { return 27u64 }                                         /* x^y == (x|y)&~(x&y) */
    bw_reset()
    if bw_equal(bw_and(bw_var(0u32), bw_var(1u32)), bw_var(0u32)) != 0u8 { return 28u64 }   /* x&y != x */
    bw_reset()
    if bw_equal(bw_or(bw_var(0u32), bw_const(1u64)), bw_var(0u32)) != 0u8 { return 29u64 }  /* x|1 != x */
    bw_reset()
    if bw_equal(bw_xor(bw_var(0u32), bw_var(1u32)), bw_const(0u64)) != 0u8 { return 30u64 } /* x^y != 0 */
    return 99u64
}

/* W3.15 / ENHANCE-12 falsifier: the column-stack decider is EXACT for >6 vars.
 * Positives are 7- and 8-variable boolean identities it must certify; negatives are
 * non-identities it must reject WITH a recoverable satisfying assignment; and >12
 * vars must DECLINE (BWS_ERR), never silently wrong.  99 = pass. */
fn bv_ring_colstack_kat() -> u64 @export {
    /* ----- 7 variables (W = 2 words): De Morgan over a 7-way AND ----- */
    bws_init(7u32)
    if BWS_NWORDS != 2u64 { return 1u64 }                 /* 2^7/64 = 2 words */
    let a01 : u64 = bws_and(bws_var(0u32), bws_var(1u32))
    let a2  : u64 = bws_and(a01, bws_var(2u32))
    let a3  : u64 = bws_and(a2, bws_var(3u32))
    let a4  : u64 = bws_and(a3, bws_var(4u32))
    let a5  : u64 = bws_and(a4, bws_var(5u32))
    let a6  : u64 = bws_and(a5, bws_var(6u32))
    let dl7 : u64 = bws_not(a6)
    let o01 : u64 = bws_or(bws_not(bws_var(0u32)), bws_not(bws_var(1u32)))
    let o2  : u64 = bws_or(o01, bws_not(bws_var(2u32)))
    let o3  : u64 = bws_or(o2, bws_not(bws_var(3u32)))
    let o4  : u64 = bws_or(o3, bws_not(bws_var(4u32)))
    let o5  : u64 = bws_or(o4, bws_not(bws_var(5u32)))
    let dr7 : u64 = bws_or(o5, bws_not(bws_var(6u32)))
    if bws_equal(dl7, dr7) != 1u8 { return 2u64 }         /* ~(AND7) == OR7(~xi): valid */
    if BWS_ERR != 0u8 { return 3u64 }

    /* ----- 7-var XOR associativity (left-assoc == right-assoc) ----- */
    bws_init(7u32)
    let lx5 : u64 = bws_xor(bws_xor(bws_xor(bws_xor(bws_var(0u32), bws_var(1u32)), bws_var(2u32)), bws_var(3u32)), bws_var(4u32))
    let lx7 : u64 = bws_xor(bws_xor(lx5, bws_var(5u32)), bws_var(6u32))
    let rx5 : u64 = bws_xor(bws_var(2u32), bws_xor(bws_var(3u32), bws_xor(bws_var(4u32), bws_xor(bws_var(5u32), bws_var(6u32)))))
    let rx7 : u64 = bws_xor(bws_var(0u32), bws_xor(bws_var(1u32), rx5))
    if bws_equal(lx7, rx7) != 1u8 { return 4u64 }

    /* ----- 7-var NEGATIVE: (AND of all 7) != x0, with recoverable witness ----- */
    bws_init(7u32)
    let b01 : u64 = bws_and(bws_var(0u32), bws_var(1u32))
    let b2  : u64 = bws_and(b01, bws_var(2u32))
    let b3  : u64 = bws_and(b2, bws_var(3u32))
    let b4  : u64 = bws_and(b3, bws_var(4u32))
    let b5  : u64 = bws_and(b4, bws_var(5u32))
    let b6  : u64 = bws_and(b5, bws_var(6u32))
    let v0  : u64 = bws_var(0u32)
    if bws_equal(b6, v0) != 0u8 { return 5u64 }           /* non-identity: must reject */
    let wb : u64 = bws_witness(bws_xor(b6, v0))
    if wb == BWS_NO_WITNESS { return 6u64 }               /* a counterexample MUST exist */
    let x0b : u8 = bws_assign_bit(wb, 0u32)
    let mut andall : u8 = 1u8
    let mut vi : u32 = 0u32
    while vi < 7u32 {
        if bws_assign_bit(wb, vi) == 0u8 { andall = 0u8 }
        vi = vi + 1u32
    }
    if andall == x0b { return 7u64 }                      /* witness truly distinguishes */

    /* ----- 8 variables (W = 4 words): De Morgan over an 8-way OR ----- */
    bws_init(8u32)
    if BWS_NWORDS != 4u64 { return 8u64 }                 /* 2^8/64 = 4 words */
    let p01 : u64 = bws_or(bws_var(0u32), bws_var(1u32))
    let p2  : u64 = bws_or(p01, bws_var(2u32))
    let p3  : u64 = bws_or(p2, bws_var(3u32))
    let p4  : u64 = bws_or(p3, bws_var(4u32))
    let p5  : u64 = bws_or(p4, bws_var(5u32))
    let p6  : u64 = bws_or(p5, bws_var(6u32))
    let p7  : u64 = bws_or(p6, bws_var(7u32))
    let lp8 : u64 = bws_not(p7)
    let q01 : u64 = bws_and(bws_not(bws_var(0u32)), bws_not(bws_var(1u32)))
    let q2  : u64 = bws_and(q01, bws_not(bws_var(2u32)))
    let q3  : u64 = bws_and(q2, bws_not(bws_var(3u32)))
    let q4  : u64 = bws_and(q3, bws_not(bws_var(4u32)))
    let q5  : u64 = bws_and(q4, bws_not(bws_var(5u32)))
    let q6  : u64 = bws_and(q5, bws_not(bws_var(6u32)))
    let rq8 : u64 = bws_and(q6, bws_not(bws_var(7u32)))
    if bws_equal(lp8, rq8) != 1u8 { return 9u64 }         /* ~(OR8) == AND8(~xi): valid */

    /* ----- 8-var NEGATIVE: x0 ^ x7 != false, witness distinguishes x0 from x7 ----- */
    bws_init(8u32)
    let nx : u64 = bws_xor(bws_var(0u32), bws_var(7u32))
    if bws_equal(nx, bws_false()) != 0u8 { return 10u64 }
    let wb2 : u64 = bws_witness(nx)
    if wb2 == BWS_NO_WITNESS { return 11u64 }
    if bws_assign_bit(wb2, 0u32) == bws_assign_bit(wb2, 7u32) { return 12u64 }

    /* ----- above the cap: DECLINE (BWS_ERR), never silently wrong ----- */
    bws_init(13u32)
    if BWS_ERR != 1u8 { return 13u64 }

    return 99u64
}

/* W3.21 / C-BV-1 falsifier: bv_shl models the x86-64 SHL count-mask (k & 63), so a
 * shift >= width wraps the count rather than zeroing the value -- otherwise the ring
 * decider would certify x<<64 -> 0, a rewrite the hardware does NOT honor. 99 = pass. */
fn bv_ring_shift_mask_kat() -> u64 @export {
    bv_reset()
    if bv_equal(bv_shl(bv_var(0u32), 64u32), bv_var(0u32)) != 1u8 { return 1u64 }                       /* x<<64 == x */
    bv_reset()
    if bv_equal(bv_shl(bv_var(0u32), 65u32), bv_shl(bv_var(0u32), 1u32)) != 1u8 { return 2u64 }         /* x<<65 == x<<1 */
    bv_reset()
    if bv_equal(bv_shl(bv_var(0u32), 128u32), bv_var(0u32)) != 1u8 { return 3u64 }                      /* x<<128 == x */
    bv_reset()
    if bv_equal(bv_shl(bv_var(0u32), 1u32), bv_var(0u32)) != 0u8 { return 4u64 }                        /* x<<1 != x (normal) */
    bv_reset()
    if bv_equal(bv_shl(bv_var(0u32), 66u32), bv_shl(bv_var(0u32), 2u32)) != 1u8 { return 5u64 }         /* x<<66 == x<<2 */
    return 99u64
}
