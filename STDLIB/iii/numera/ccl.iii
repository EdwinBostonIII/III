/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\ccl.iii
 *
 * III STDLIB - numera::ccl  (Path C brick 16: beta-eta via directed CCL reduction)
 *
 * Curien's Categorical Combinatory Logic as a DIRECTED, confluent, terminating
 * reduction (apply_one to normal form) -- the right tool for normalisation.
 * (Equality saturation in an e-graph is the WRONG tool: beta DUPLICATES and the
 * categorical rules EXPAND, so accumulating every equivalent form blows up.  The
 * B16a e-graph PoC proved CCL-eta is a STRUCTURAL rule -- and here that exact rule
 * is a directed contraction in an O(reduction-length) reducer.)
 *
 * Compilation (de Bruijn -> categorical; context = a product):
 *   #0     -> Snd ;  #(k+1) -> Comp(<#k>, Fst)
 *   lam. b -> Cur(<b>) ;  f a -> Comp(App, Pair(<f>, <a>))
 *   constant c -> c   (context-free; weakening c o y = c)
 *
 * The CCL rules, oriented as a terminating reduction (no surjective-pairing SP --
 * we need exponential eta, not product eta; SP is the Klop-nonconfluence culprit):
 *   idl   Id o x          -> x
 *   idr   x o Id          -> x
 *   ass   (x o y) o z     -> x o (y o z)
 *   dpair <x,y> o z       -> <x o z, y o z>
 *   dcur  Cur(x) o y      -> Cur(x o <y o Fst, Snd>)
 *   fst   Fst o <x,y>     -> x
 *   snd   Snd o <x,y>     -> y
 *   beta  App o <Cur(x) o y, z> -> x o <y, z>
 *   bare  App o <Cur(x), z>     -> x o <Id, z>
 *   eta   Cur(App o <x o Fst, Snd>) -> x       (the B16a structural eta)
 *   weak  c o y          -> c   (c a constant: categorical weakening c o ! = c)
 * Confluence is verified empirically (846 + 855 differential) and is slated for
 * MACHINE certification at B18d (xii_critpair_enum + xii_conf_cert).
 *
 * Hexad: kind_essence + kind_cognition.  Ring: R0.  K: 1.00.  NIH: own arena only.
 */

module numera_ccl

/* TC constructors (numera/typecheck) -- the read-back ccl_to_tc reifies a CCL
 * normal form back into a TC node.  Mutual module reference: typecheck externs
 * ccl_*, ccl externs tc_* -- resolved at archive link. */
extern @abi(c-msvc-x64) fn tc_var(k: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_lam(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_app(f: u32, a: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_pi(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_pi_q(a: u32, b: u32, code: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_sig(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_id(ty: u32, l: u32, r: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_sum(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_w(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_sup(a: u32, f: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_nat() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bool() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_unit() -> u32 from "typecheck.iii"
