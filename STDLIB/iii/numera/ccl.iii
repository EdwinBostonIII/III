extern @abi(c-msvc-x64) fn iii_hexad_reachable(h: u16) -> u8 from "hexad_reach.iii"
extern @abi(c-msvc-x64) fn cl_le_product(c: *u64, cp: *u64) -> u8 from "cost_lattice.iii"
const CCL_ID   : u8 = 1u8     /* Id            (nullary morphism)        */
const CCL_COMP : u8 = 2u8     /* Comp(f,g) = f o g   (binary)            */
const CCL_PAIR : u8 = 3u8     /* Pair(f,g) = <f,g>   (binary)            */
const CCL_FST  : u8 = 4u8     /* Fst           (nullary)                 */
const CCL_SND  : u8 = 5u8     /* Snd           (nullary)                 */
const CCL_CUR  : u8 = 6u8     /* Cur(f) = Lambda(f)  (unary)             */
const CCL_APP  : u8 = 7u8     /* App           (nullary morphism)        */
const CCL_ATOM : u8 = 8u8     /* free constant: A = atom id              */
/* data constructors + eliminators -- all CONSTANTS (applied via App o Pair).
 * Tag >= CCL_ATOM means "a constant" (weakening c o y = c applies). */
const CCL_TRUE   : u8 = 9u8
const CCL_FALSE  : u8 = 10u8
const CCL_ZERO   : u8 = 11u8
const CCL_SUCC   : u8 = 12u8   /* succ m  = App o <SUCC, m>   */
const CCL_INL    : u8 = 13u8   /* inl v   = App o <INL, v>    */
const CCL_INR    : u8 = 14u8   /* inr v   = App o <INR, v>    */
const CCL_REFL   : u8 = 15u8   /* refl a  = App o <REFL, a>   */
const CCL_IF     : u8 = 16u8   /* IF s t e   (TRUE->t, FALSE->e)             */
const CCL_ITER   : u8 = 17u8   /* ITER z s n (ZERO->z, SUCC m-> s (rec))     */
const CCL_NATREC : u8 = 18u8   /* NATREC z s n (ZERO->z, SUCC m-> s m (rec)) */
const CCL_CASE   : u8 = 19u8   /* CASE f g x (INL v->f v, INR v->g v)        */
const CCL_J      : u8 = 20u8   /* J d p (REFL a -> d)                        */
const CCL_SPAIR  : u8 = 21u8   /* Sigma pair  <a,b>_S = App o <App o <SPAIR,a>,b> */
const CCL_SFST   : u8 = 22u8   /* Sigma fst:  SFST (SPAIR a b) -> a          */
const CCL_SSND   : u8 = 23u8   /* Sigma snd:  SSND (SPAIR a b) -> b          */
const CCL_TRANSP : u8 = 24u8   /* transp pr proof base ; proof=REFL -> base  */
const CCL_SUP    : u8 = 25u8   /* sup(a,f) : W-type constructor (2 args)      */
const CCL_WREC   : u8 = 26u8
const CCL_REACH  : u8 = 27u8
const CCL_LEK    : u8 = 28u8   /* mig2: LEK(cost_slot,budget_slot) reduces TRUE/FALSE via cl_le_product over CLEK_REG (M13 budget, full 6-vector) */   /* mig2: REACH(h) A=hexad literal; reduces TRUE/FALSE via iii_hexad_reachable -- the kernel VERIFIES M3 reachability by iota, not a baked/trusted value */   /* wrec(P,s,w) : W eliminator (3 args, motive)  */

/* ===== BV64: the native 64-bit machine-int (bitvector) model ====================
 * The kernel VERIFIES 64-bit machine arithmetic BY IOTA -- the same move REACH(h)
 * made for hexad-reachability, at scale.  These are FLAT primitive morphisms (NOT
 * the App/Comp point-free spine): each carries its operand node-ids directly in A/B
 * (a BVLIT carries the u64 value as A=lo32,B=hi32), and ccl_step reduces them with
 * NATIVE u64 wraparound = arithmetic mod 2^64.  The trusted surface is exactly the
 * closed-literal evaluator + the Z/2^64 monoid/semiring identities (the absorbing /
 * identity elements) + the single definitional shl->mul rule -- each a one-line,
 * textbook-sound ring fact.  A NEUTRAL operand (a free variable x) simply does not
 * reduce, so x<<k and x*2^k both normalise to bvmul(x, lit 2^k) and tc_conv proves
 * them equal WITHOUT any polynomial canonicalisation in the trusted base.  The full
 * symbolic ring DECISION stays in the UNTRUSTED proposer (numera/bv_ring). */
const CCL_BVLIT    : u8 = 29u8   /* a 64-bit literal value: A=lo32, B=hi32 (a normal form)         */
const CCL_BVADD    : u8 = 30u8   /* A=left node, B=right node : BV  (mod 2^64)                     */
const CCL_BVSUB    : u8 = 31u8   /* A=left, B=right : BV                                            */
const CCL_BVMUL    : u8 = 32u8   /* A=left, B=right : BV                                            */
const CCL_BVAND    : u8 = 33u8   /* A=left, B=right : BV  (bitwise)                                 */
const CCL_BVOR     : u8 = 34u8   /* A=left, B=right : BV                                            */
const CCL_BVXOR    : u8 = 35u8   /* A=left, B=right : BV                                            */
const CCL_BVSHL    : u8 = 36u8   /* A=base, B=count : BV  (count masked &63; shl->mul definitional) */
const CCL_BVADDOVF : u8 = 37u8   /* A=left, B=right : Bool  (unsigned add carry-out)                */
const CCL_BVMULOVF : u8 = 38u8   /* A=left, B=right : Bool  (u64 full-product overflow)             */
const CCL_BVLSHR   : u8 = 39u8   /* A=base, B=count : BV  (LOGICAL right shift; count masked &63 -- harmony 22) */
const CCL_BVUDIV   : u8 = 40u8   /* A=dividend, B=divisor : BV  (UNSIGNED div; divisor 0 is STUCK -- wave-4 M11) */

const CCL_BV_ONES : u64 = 0xFFFFFFFFFFFFFFFFu64   /* the all-ones 64-bit word (~0) */

const CCL_SENT : u32 = 0xFFFFFFFFu32
const CCL_CAP  : u32 = 65536u32
const CCL_FUEL : u32 = 2000000u32

var CCL_TAG   : [u8;  65536]
var CCL_A     : [u32; 65536]
var CCL_B     : [u32; 65536]
var CCL_N     : [u32; 1]
var CCL_FIRED : [u32; 1]
var CCL_EARG  : [u32; 8]      /* eliminator-spine arg scratch (used non-recursively) */
var CCL_ENARG : [u32; 1]

fn ccl_reset() -> u64 @export {
    CCL_N[0u64] = 1u32
    return 0u64
}

fn ccl_mk(tag: u8, a: u32, b: u32) -> u32 {
    let n : u32 = CCL_N[0u64]
    if n >= CCL_CAP { return 0u32 }
    CCL_TAG[n] = tag
    CCL_A[n] = a
    CCL_B[n] = b
    CCL_N[0u64] = n + 1u32
    return n
}

fn ccl_id() -> u32 @export { return ccl_mk(CCL_ID, 0u32, 0u32) }
fn ccl_fst() -> u32 @export { return ccl_mk(CCL_FST, 0u32, 0u32) }
fn ccl_snd() -> u32 @export { return ccl_mk(CCL_SND, 0u32, 0u32) }
fn ccl_app() -> u32 @export { return ccl_mk(CCL_APP, 0u32, 0u32) }
fn ccl_comp(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_COMP, a, b) }
fn ccl_pair(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_PAIR, a, b) }
fn ccl_cur(x: u32) -> u32 @export { return ccl_mk(CCL_CUR, x, 0u32) }
/* typed Cur: the binder's DOMAIN is carried in the idle 2nd field (B18 read-back).
 * Reduction ignores it (reads CCL_A=body); dcur threads it; eta/beta drop it;
 * struct_eq ignores it (conversion is domain-erased).  0 = no domain (codomains). */
fn ccl_cur_d(domain: u32, body: u32) -> u32 @export { return ccl_mk(CCL_CUR, body, domain) }
fn ccl_atom(id: u32) -> u32 @export { return ccl_mk(CCL_ATOM, id, 0u32) }
fn ccl_true_c() -> u32 @export { return ccl_mk(CCL_TRUE, 0u32, 0u32) }
fn ccl_false_c() -> u32 @export { return ccl_mk(CCL_FALSE, 0u32, 0u32) }
fn ccl_zero_c() -> u32 @export { return ccl_mk(CCL_ZERO, 0u32, 0u32) }
fn ccl_succ_c() -> u32 @export { return ccl_mk(CCL_SUCC, 0u32, 0u32) }
fn ccl_inl_c() -> u32 @export { return ccl_mk(CCL_INL, 0u32, 0u32) }
fn ccl_inr_c() -> u32 @export { return ccl_mk(CCL_INR, 0u32, 0u32) }
fn ccl_refl_c() -> u32 @export { return ccl_mk(CCL_REFL, 0u32, 0u32) }
fn ccl_if_c() -> u32 @export { return ccl_mk(CCL_IF, 0u32, 0u32) }
fn ccl_reach_c(h: u32) -> u32 @export { return ccl_mk(CCL_REACH, h, 0u32) }
var CLEK_REG  : [u64; 384]
var CLEK_NEXT : [u32; 1]
fn clek_register(c: u64) -> u32 @export {
    let slot : u32 = CLEK_NEXT[0u64]
    if slot >= 64u32 { return 0u32 }
    let cp : *u64 = c as *u64
    let base : u64 = (slot as u64) * 6u64
    let mut k : u64 = 0u64
    while k < 6u64 {
        CLEK_REG[base + k] = cp[k]
        k = k + 1u64
    }
    CLEK_NEXT[0u64] = slot + 1u32
    return slot
}
fn ccl_lek_c(cs: u32, bs: u32) -> u32 @export { return ccl_mk(CCL_LEK, cs, bs) }

/* ===== BV64 constructors + u64<->(lo,hi) packing ===== */
/* the u64 value of a BVLIT node (A=lo32, B=hi32). */
fn ccl_bv_val(c: u32) -> u64 { return (CCL_A[c] as u64) | ((CCL_B[c] as u64) << 32u64) }
/* a fresh BVLIT node carrying the u64 value v. */
fn ccl_bvlit_v(v: u64) -> u32 { return ccl_mk(CCL_BVLIT, (v & 0xFFFFFFFFu64) as u32, (v >> 32u64) as u32) }
fn ccl_bvlit_c(lo: u32, hi: u32) -> u32 @export { return ccl_mk(CCL_BVLIT, lo, hi) }
fn ccl_bvadd_c(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_BVADD, a, b) }
fn ccl_bvsub_c(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_BVSUB, a, b) }
fn ccl_bvmul_c(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_BVMUL, a, b) }
fn ccl_bvand_c(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_BVAND, a, b) }
fn ccl_bvor_c(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_BVOR, a, b) }
fn ccl_bvxor_c(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_BVXOR, a, b) }
fn ccl_bvshl_c(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_BVSHL, a, b) }
fn ccl_bvaddovf_c(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_BVADDOVF, a, b) }
fn ccl_bvmulovf_c(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_BVMULOVF, a, b) }
fn ccl_bvlshr_c(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_BVLSHR, a, b) }
fn ccl_bvudiv_c(a: u32, b: u32) -> u32 @export { return ccl_mk(CCL_BVUDIV, a, b) }

fn ccl_iter_c() -> u32 @export { return ccl_mk(CCL_ITER, 0u32, 0u32) }
fn ccl_natrec_c() -> u32 @export { return ccl_mk(CCL_NATREC, 0u32, 0u32) }
fn ccl_case_c() -> u32 @export { return ccl_mk(CCL_CASE, 0u32, 0u32) }
fn ccl_j_c() -> u32 @export { return ccl_mk(CCL_J, 0u32, 0u32) }
fn ccl_spair_c() -> u32 @export { return ccl_mk(CCL_SPAIR, 0u32, 0u32) }
fn ccl_sfst_c() -> u32 @export { return ccl_mk(CCL_SFST, 0u32, 0u32) }
fn ccl_ssnd_c() -> u32 @export { return ccl_mk(CCL_SSND, 0u32, 0u32) }
fn ccl_transp_c() -> u32 @export { return ccl_mk(CCL_TRANSP, 0u32, 0u32) }
fn ccl_sup_c() -> u32 @export { return ccl_mk(CCL_SUP, 0u32, 0u32) }
fn ccl_wrec_c() -> u32 @export { return ccl_mk(CCL_WREC, 0u32, 0u32) }

/* curried application  f a  =  App o <f, a>. */
fn ccl_app2(f: u32, a: u32) -> u32 @export {
    return ccl_comp(ccl_app(), ccl_pair(f, a))
}

/* shift by k (cutoff 0): p o Fst^k -- weakening past k binders.  The CCL-native
 * replacement for tc_shift(p, k, 0): a free var #j becomes #(j+k) on reduction. */
fn ccl_shift_fstk(p: u32, k: u32) -> u32 @export {
    let mut cur : u32 = p
    let mut i : u32 = 0u32
    while i < k {
        cur = ccl_comp(cur, ccl_fst())
        i = i + 1u32
    }
    return cur
}

/* STRENGTHEN: invert one  o Fst  weakening on a NORMAL-FORM CCL morphism v.
 * Returns w with (w o Fst) reducing to v -- i.e. drop one binder level from
 * every variable in v -- or CCL_SENT if v depends on #0 (Snd) and so is NOT a
 * weakening.  This is the semantic core of COMPLETE eta: an old syntactic
 * matcher only saw a BARE trailing Fst, but `ass` right-associates  x o Fst
 * for a composite x (a higher de Bruijn variable Snd o Fst^k) into
 * Snd o (Fst o ...), whose right child is no longer a bare Fst -- so eta
 * silently failed on #1, #2, ... (verified: probe 862).  Strengthening closes
 * that gap structurally: variables of ANY index, neutral application spines,
 * pairs, and closed constants (atoms / type-formers / data ctors-as-functions).
 *   x o Fst        -> x                 (single un-weakening, any x)
 *   Snd o (Fst o R)-> Snd o R           (#m -> #(m-1), m>=2)
 *   App o <g,x>    -> App o <str g,str x> (neutral spine, both must strengthen)
 *   <p,q>          -> <str p, str q>
 *   closed const c -> c                 (c o Fst reduces to c) */
fn ccl_strengthen(v: u32) -> u32 {
    let tag : u8 = CCL_TAG[v]
    if tag == CCL_SND { return CCL_SENT }        /* #0 -- uses the bound variable */
    /* BV op nodes (tags 30..38) carry environment-dependent operands -> strengthen them (and FAIL if
     * any operand depends on #0); they are NOT weakening-invariant constants.  A BVLIT (tag 29) IS a
     * closed value and correctly hits the constant rule below.  Mirror of the COMP/PAIR strengthen. */
    if tag >= CCL_BVADD {
        if tag <= CCL_BVUDIV {
            let bsa : u32 = ccl_strengthen(CCL_A[v])
            if bsa == CCL_SENT { return CCL_SENT }
            let bsb : u32 = ccl_strengthen(CCL_B[v])
            if bsb == CCL_SENT { return CCL_SENT }
            return ccl_mk(tag, bsa, bsb)
        }
    }
    if tag >= CCL_ATOM { return v }              /* closed constant: weakening-invariant */
    if tag == CCL_COMP {
        let a : u32 = CCL_A[v]
        let b : u32 = CCL_B[v]
        if CCL_TAG[b] == CCL_FST { return a }    /* x o Fst is the weakening of x */
        if CCL_TAG[a] == CCL_SND {               /* variable Snd o Fst^m, m>=2 */
            if CCL_TAG[b] == CCL_COMP {
                if CCL_TAG[CCL_A[b]] == CCL_FST { return ccl_comp(ccl_snd(), CCL_B[b]) }
            }
            return CCL_SENT
        }
        if CCL_TAG[a] == CCL_APP {               /* neutral application spine App o <g,x> */
            if CCL_TAG[b] == CCL_PAIR {
                let sg : u32 = ccl_strengthen(CCL_A[b])
                if sg == CCL_SENT { return CCL_SENT }
                let sx : u32 = ccl_strengthen(CCL_B[b])
                if sx == CCL_SENT { return CCL_SENT }
                return ccl_comp(ccl_app(), ccl_pair(sg, sx))
            }
        }
        return CCL_SENT
    }
    if tag == CCL_PAIR {
        let sp : u32 = ccl_strengthen(CCL_A[v])
        if sp == CCL_SENT { return CCL_SENT }
        let sq : u32 = ccl_strengthen(CCL_B[v])
        if sq == CCL_SENT { return CCL_SENT }
        return ccl_pair(sp, sq)
    }
    return CCL_SENT                              /* Cur / bare Id,Fst,App head: conservative */
}

/* COMPLETE eta-contraction: body == App o <V, Snd> with V a weakening (not
 * using #0)  ->  strengthen(V).  Generalises the bare-Fst matcher to every
 * weakened V, so eta is complete for higher variables and neutral spines. */
fn ccl_eta_contract(body: u32) -> u32 {
    if CCL_TAG[body] != CCL_COMP { return CCL_SENT }
    if CCL_TAG[CCL_A[body]] != CCL_APP { return CCL_SENT }
    let bb : u32 = CCL_B[body]
    if CCL_TAG[bb] != CCL_PAIR { return CCL_SENT }
    if CCL_TAG[CCL_B[bb]] != CCL_SND { return CCL_SENT }
    let v : u32 = ccl_strengthen(CCL_A[bb])
    if v == CCL_SENT { return CCL_SENT }
    /* SOUNDNESS (the closed-lambda / tc_natrec IH-shift fix): do NOT eta-contract  lam x. (C x) -> C
     * when the head C is a data constructor or eliminator (tag >= CCL_TRUE).  Such a C is NEVER a
     * standalone function in this kernel -- succ/inl/inr/iter/... are valid only as App o <C, arg> --
     * so the contracted bare C fails to typecheck as a function.  Concretely (lam n:Nat. succ n) :
     * Nat->Nat would eta-collapse to bare succ, which tc_shift_k then mangles, so tc_natrec's IH-type
     * shift (tc_ctx_lookup -> tc_shift_k(ih_ty,k+1)) diverges from the reconstructed step type and the
     * induction STEP fails tc_check -- the pinned blocker of ALL nat-induction.  Keeping the lambda
     * form loses NO valid conversion: a bare constructor never legitimately appears standalone, and a
     * genuine function constant (CCL_ATOM, tag 8) is still eta-contracted (v < CCL_TRUE). */
    if CCL_TAG[v] >= CCL_TRUE { return CCL_SENT }
    return v
}

/* unwind an App o Pair spine: t = App o <App o <... <head, a0> ...>, a_{k-1}>.
 * Fills CCL_EARG[0..k-1] (EARG[0] = OUTERMOST/last arg) + CCL_ENARG[0]=k; returns
 * the head.  Used NON-RECURSIVELY: the caller reads EARG before ccl_step recurses,
 * so the shared scratch is never clobbered mid-use. */
fn ccl_unwind(t: u32) -> u32 {
    let mut cur : u32 = t
    let mut k : u32 = 0u32
    let mut go : u32 = 1u32
    while go == 1u32 {
        let mut is_app : u32 = 0u32
        if CCL_TAG[cur] == CCL_COMP {
            if CCL_TAG[CCL_A[cur]] == CCL_APP {
                if CCL_TAG[CCL_B[cur]] == CCL_PAIR {
                    is_app = 1u32
                }
            }
        }
        if is_app == 0u32 { go = 0u32 }
        if is_app == 1u32 {
            let bb : u32 = CCL_B[cur]
            CCL_EARG[k] = CCL_B[bb]
            k = k + 1u32
            cur = CCL_A[bb]
            if k >= 8u32 { go = 0u32 }
        }
    }
    CCL_ENARG[0u64] = k
    return cur
}

/* if x == App o <CTAG-const, arg> return arg, else SENT (single-arg constructor). */
fn ccl_cons1_arg(x: u32, ctag: u8) -> u32 {
    if CCL_TAG[x] != CCL_COMP { return CCL_SENT }
    if CCL_TAG[CCL_A[x]] != CCL_APP { return CCL_SENT }
    let bb : u32 = CCL_B[x]
    if CCL_TAG[bb] != CCL_PAIR { return CCL_SENT }
    if CCL_TAG[CCL_A[bb]] != ctag { return CCL_SENT }
    return CCL_B[bb]
}

/* if x == App o <App o <CTAG, a>, b> return a (which=0) or b (which=1), else SENT. */
fn ccl_cons2_arg(x: u32, ctag: u8, which: u32) -> u32 {
    if CCL_TAG[x] != CCL_COMP { return CCL_SENT }
    if CCL_TAG[CCL_A[x]] != CCL_APP { return CCL_SENT }
    let bb : u32 = CCL_B[x]
    if CCL_TAG[bb] != CCL_PAIR { return CCL_SENT }
    let barg : u32 = CCL_B[bb]
    let inner : u32 = CCL_A[bb]
    if CCL_TAG[inner] != CCL_COMP { return CCL_SENT }
    if CCL_TAG[CCL_A[inner]] != CCL_APP { return CCL_SENT }
    let ib : u32 = CCL_B[inner]
    if CCL_TAG[ib] != CCL_PAIR { return CCL_SENT }
    if CCL_TAG[CCL_A[ib]] != ctag { return CCL_SENT }
    if which == 0u32 { return CCL_B[ib] }
    return barg
}

/* data eliminator iota: if t is a fully-applied eliminator with a CONSTRUCTOR
 * scrutinee, return the contractum (NO substitution -- the methods are closed
 * combinators applied via App), else CCL_SENT. */
fn ccl_elim_redex(t: u32) -> u32 {
    let head : u32 = ccl_unwind(t)
    let k : u32 = CCL_ENARG[0u64]
    let htag : u8 = CCL_TAG[head]
    if htag == CCL_IF {
        if k == 3u32 {
            let s : u32 = CCL_EARG[2u32]
            if CCL_TAG[s] == CCL_TRUE { return CCL_EARG[1u32] }
            if CCL_TAG[s] == CCL_FALSE { return CCL_EARG[0u32] }
        }
    }
    if htag == CCL_J {
        /* J C d p : motive C=EARG[2], d=EARG[1], p=EARG[0] ; p=REFL -> d. */
        if k == 3u32 {
            if ccl_cons1_arg(CCL_EARG[0u32], CCL_REFL) != CCL_SENT { return CCL_EARG[1u32] }
        }
    }
    if htag == CCL_CASE {
        /* CASE C f g s : motive C=EARG[3], f=EARG[2], g=EARG[1], s=EARG[0]. */
        if k == 4u32 {
            let x : u32 = CCL_EARG[0u32]
            let lv : u32 = ccl_cons1_arg(x, CCL_INL)
            if lv != CCL_SENT { return ccl_app2(CCL_EARG[2u32], lv) }
            let rv : u32 = ccl_cons1_arg(x, CCL_INR)
            if rv != CCL_SENT { return ccl_app2(CCL_EARG[1u32], rv) }
        }
    }
    if htag == CCL_ITER {
        if k == 3u32 {
            let n : u32 = CCL_EARG[0u32]
            let zz : u32 = CCL_EARG[2u32]
            let ss : u32 = CCL_EARG[1u32]
            if CCL_TAG[n] == CCL_ZERO { return zz }
            let m : u32 = ccl_cons1_arg(n, CCL_SUCC)
            if m != CCL_SENT {
                let rec : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_iter_c(), zz), ss), m)
                return ccl_app2(ss, rec)
            }
        }
    }
    if htag == CCL_NATREC {
        /* NATREC C z s n : motive C=EARG[3], z=EARG[2], s=EARG[1], n=EARG[0]. */
        if k == 4u32 {
            let cc : u32 = CCL_EARG[3u32]
            let zz : u32 = CCL_EARG[2u32]
            let ss : u32 = CCL_EARG[1u32]
            let n : u32 = CCL_EARG[0u32]
            if CCL_TAG[n] == CCL_ZERO { return zz }
            let m : u32 = ccl_cons1_arg(n, CCL_SUCC)
            if m != CCL_SENT {
                let rec : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_app2(ccl_natrec_c(), cc), zz), ss), m)
                return ccl_app2(ccl_app2(ss, m), rec)
            }
        }
    }
    if htag == CCL_WREC {
        /* WREC P s w : motive P=EARG[2], step s=EARG[1], scrutinee w=EARG[0].
         * w = sup(a,f)  ->  s a f IH,  where the HIGHER-ORDER induction hypothesis
         * IH = Cur( WREC (P o Fst) (s o Fst) ((f o Fst) o Snd) ) recurses on each
         * child f(b) (the o Fst weakens P,s,f past the new binder b=Snd). */
        if k == 3u32 {
            let wpp : u32 = CCL_EARG[2u32]
            let wss : u32 = CCL_EARG[1u32]
            let wsc : u32 = CCL_EARG[0u32]
            let wav : u32 = ccl_cons2_arg(wsc, CCL_SUP, 0u32)
            if wav != CCL_SENT {
                let wfv : u32 = ccl_cons2_arg(wsc, CCL_SUP, 1u32)
                let wih_body : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_wrec_c(), ccl_comp(wpp, ccl_fst())), ccl_comp(wss, ccl_fst())), ccl_app2(ccl_comp(wfv, ccl_fst()), ccl_snd()))
                let wih : u32 = ccl_cur(wih_body)
                return ccl_app2(ccl_app2(ccl_app2(wss, wav), wfv), wih)
            }
        }
    }
    /* SFST (SPAIR a b) -> a ; SSND (SPAIR a b) -> b */
    if htag == CCL_SFST {
        if k == 1u32 {
            let av : u32 = ccl_cons2_arg(CCL_EARG[0u32], CCL_SPAIR, 0u32)
            if av != CCL_SENT { return av }
        }
    }
    if htag == CCL_SSND {
        if k == 1u32 {
            let bv : u32 = ccl_cons2_arg(CCL_EARG[0u32], CCL_SPAIR, 1u32)
            if bv != CCL_SENT { return bv }
        }
    }
    /* transp pr proof base : proof=REFL -> base.  (pr=EARG[2], proof=EARG[1], base=EARG[0]) */
    if htag == CCL_TRANSP {
        if k == 3u32 {
            if ccl_cons1_arg(CCL_EARG[1u32], CCL_REFL) != CCL_SENT { return CCL_EARG[0u32] }
        }
    }
    return CCL_SENT
}

/* ===== BV64 iota: the contractum of a BV op whose BOTH operands are ALREADY normal,
 * or CCL_SENT if no rule fires (the op is stuck on a neutral / non-literal operand).
 * Soundness: every rule is a textbook identity of the ring Z/2^64 (= u64 with native
 * wraparound).  Closed literals fold by NATIVE u64 arithmetic; the identity/absorbing
 * elements collapse against a neutral operand; bvshl on a literal count is the single
 * definitional rule x<<k == x*2^(k&63) (the x86-64 SHL count mask -- a shift >= width
 * wraps the COUNT, it does NOT zero the value).  The caller (ccl_step) sets CCL_FIRED.
 * A neutral operand never matches a literal guard, so x stays neutral and no polynomial
 * over x is ever canonicalised in this trusted base.
 *
 * harmony item 21 adds the four SELF-LAWS on structurally identical operands (ccl_bv_eq):
 * x-x=0, x^x=0, x&x=x, x|x=x -- each an unconditional identity of Z/2^64 for EVERY value of
 * the operand term, so firing them never depends on the operand's meaning, only its identity
 * with itself.  The two-tier disposer (bv_dispose) therefore now ADMITS the self-cancellation
 * family the polynomial ring already proposed and the kernel previously had to decline. ===== */
fn ccl_bv_eq(a: u32, b: u32, depth: u32) -> u8 {
    if depth == 0u32 { return 0u8 }                /* depth belt: refuse, never claim */
    if a == b { return 1u8 }
    let at : u8 = CCL_TAG[a]
    let bt : u8 = CCL_TAG[b]
    if at != bt { return 0u8 }
    if at == CCL_BVLIT {
        if ccl_bv_val(a) == ccl_bv_val(b) { return 1u8 }
        return 0u8
    }
    if at == CCL_ATOM {
        if CCL_A[a] == CCL_A[b] { return 1u8 }
        return 0u8
    }
    if at == CCL_FST { return 1u8 }
    if at == CCL_SND { return 1u8 }
    if at == CCL_ID  { return 1u8 }
    let mut binary : u8 = 0u8
    if at == CCL_COMP  { binary = 1u8 }
    if at == CCL_BVADD { binary = 1u8 }
    if at == CCL_BVSUB { binary = 1u8 }
    if at == CCL_BVMUL { binary = 1u8 }
    if at == CCL_BVAND { binary = 1u8 }
    if at == CCL_BVOR  { binary = 1u8 }
    if at == CCL_BVXOR { binary = 1u8 }
    if at == CCL_BVSHL { binary = 1u8 }
    if at == CCL_BVLSHR { binary = 1u8 }
    if at == CCL_BVUDIV { binary = 1u8 }
    if binary == 0u8 { return 0u8 }                /* outside the BV fragment: refuse (incomplete, never unsound) */
    if ccl_bv_eq(CCL_A[a], CCL_A[b], depth - 1u32) != 1u8 { return 0u8 }
    return ccl_bv_eq(CCL_B[a], CCL_B[b], depth - 1u32)
}

fn ccl_bv_fold(op: u8, a: u32, b: u32) -> u32 {
    let at : u8 = CCL_TAG[a]
    let bt : u8 = CCL_TAG[b]
    let mut alit : u8 = 0u8
    let mut blit : u8 = 0u8
    if at == CCL_BVLIT { alit = 1u8 }
    if bt == CCL_BVLIT { blit = 1u8 }
    let mut va : u64 = 0u64
    let mut vb : u64 = 0u64
    if alit == 1u8 { va = ccl_bv_val(a) }
    if blit == 1u8 { vb = ccl_bv_val(b) }

    if op == CCL_BVADD {
        if alit == 1u8 { if blit == 1u8 { return ccl_bvlit_v(va + vb) } }   /* fold (mod 2^64) */
        if alit == 1u8 { if va == 0u64 { return b } }                      /* 0 + x = x */
        if blit == 1u8 { if vb == 0u64 { return a } }                      /* x + 0 = x */
        return CCL_SENT
    }
    if op == CCL_BVSUB {
        if alit == 1u8 { if blit == 1u8 { return ccl_bvlit_v(va - vb) } }   /* fold (mod 2^64) */
        if blit == 1u8 { if vb == 0u64 { return a } }                      /* x - 0 = x */
        if ccl_bv_eq(a, b, 64u32) == 1u8 { return ccl_bvlit_v(0u64) }      /* x - x = 0 (harmony 21) */
        return CCL_SENT
    }
    if op == CCL_BVMUL {
        if alit == 1u8 { if blit == 1u8 { return ccl_bvlit_v(va * vb) } }   /* fold (mod 2^64) */
        if alit == 1u8 { if va == 0u64 { return a } }                      /* 0 * x = 0  (a is lit 0) */
        if blit == 1u8 { if vb == 0u64 { return b } }                      /* x * 0 = 0 */
        if alit == 1u8 { if va == 1u64 { return b } }                      /* 1 * x = x */
        if blit == 1u8 { if vb == 1u64 { return a } }                      /* x * 1 = x */
        return CCL_SENT
    }
    if op == CCL_BVAND {
        if alit == 1u8 { if blit == 1u8 { return ccl_bvlit_v(va & vb) } }
        if alit == 1u8 { if va == 0u64 { return a } }                      /* 0 & x = 0 */
        if blit == 1u8 { if vb == 0u64 { return b } }                      /* x & 0 = 0 */
        if alit == 1u8 { if va == CCL_BV_ONES { return b } }               /* ~0 & x = x */
        if blit == 1u8 { if vb == CCL_BV_ONES { return a } }               /* x & ~0 = x */
        if ccl_bv_eq(a, b, 64u32) == 1u8 { return a }                      /* x & x = x (harmony 21) */
        return CCL_SENT
    }
    if op == CCL_BVOR {
        if alit == 1u8 { if blit == 1u8 { return ccl_bvlit_v(va | vb) } }
        if alit == 1u8 { if va == 0u64 { return b } }                      /* 0 | x = x */
        if blit == 1u8 { if vb == 0u64 { return a } }                      /* x | 0 = x */
        if alit == 1u8 { if va == CCL_BV_ONES { return a } }               /* ~0 | x = ~0 */
        if blit == 1u8 { if vb == CCL_BV_ONES { return b } }               /* x | ~0 = ~0 */
        if ccl_bv_eq(a, b, 64u32) == 1u8 { return a }                      /* x | x = x (harmony 21) */
        return CCL_SENT
    }
    if op == CCL_BVXOR {
        if alit == 1u8 { if blit == 1u8 { return ccl_bvlit_v(va ^ vb) } }
        if alit == 1u8 { if va == 0u64 { return b } }                      /* 0 ^ x = x */
        if blit == 1u8 { if vb == 0u64 { return a } }                      /* x ^ 0 = x */
        if ccl_bv_eq(a, b, 64u32) == 1u8 { return ccl_bvlit_v(0u64) }      /* x ^ x = 0 (harmony 21) */
        return CCL_SENT
    }
    if op == CCL_BVSHL {
        if blit == 1u8 {
            let k : u64 = vb & 63u64                                       /* x86-64 SHL count mask */
            return ccl_bvmul_c(a, ccl_bvlit_v(1u64 << k))                  /* x<<k == x * 2^(k&63) */
        }
        return CCL_SENT
    }
    if op == CCL_BVLSHR {
        if alit == 1u8 { if blit == 1u8 { return ccl_bvlit_v(va >> (vb & 63u64)) } }   /* fold (x86 SHR count mask) */
        if blit == 1u8 { if (vb & 63u64) == 0u64 { return a } }            /* x >> 0 = x (incl. masked counts) */
        return CCL_SENT
    }
    if op == CCL_BVUDIV {
        /* UNSIGNED division.  Divisor 0 is STUCK (no rule -- the machine traps; the kernel
         * refuses to give 0/x a value).  THE DIV-STRENGTH IOTA (wave-4 M11): division by a
         * power of two IS the logical right shift, unconditionally for unsigned -- the
         * kernel-certified justification a cg division fold cites (the 1207/SHL precedent,
         * division edition). */
        if blit == 1u8 {
            if vb != 0u64 {
                if alit == 1u8 { return ccl_bvlit_v(va / vb) }             /* closed fold */
                if vb == 1u64 { return a }                                 /* x / 1 = x */
                if (vb & (vb - 1u64)) == 0u64 {
                    /* vb == 2^k: find k (vb != 0, vb != 1 here -> k in 1..63) */
                    let mut k : u64 = 0u64
                    let mut t : u64 = vb
                    while t > 1u64 { t = t >> 1u64 ; k = k + 1u64 }
                    return ccl_bvlshr_c(a, ccl_bvlit_v(k))                 /* x / 2^k = x >> k */
                }
            }
        }
        return CCL_SENT
    }
    if op == CCL_BVADDOVF {
        if alit == 1u8 { if blit == 1u8 {
            let sum : u64 = va + vb
            if sum < va { return ccl_true_c() }                           /* carry-out of bit 63 */
            return ccl_false_c()
        } }
        return CCL_SENT
    }
    if op == CCL_BVMULOVF {
        if alit == 1u8 { if blit == 1u8 {
            if va == 0u64 { return ccl_false_c() }                         /* 0 * b never overflows */
            let prod : u64 = va * vb
            if (prod / va) != vb { return ccl_true_c() }                   /* full product exceeds 64 bits */
            return ccl_false_c()
        } }
        return CCL_SENT
    }
    return CCL_SENT
}

/* one leftmost-outermost directed CCL reduction step; sets CCL_FIRED on success. */
fn ccl_step(t: u32) -> u32 {
    /* data eliminator iota first (constructor scrutinee) -- checked at every node. */
    let dr : u32 = ccl_elim_redex(t)
    if dr != CCL_SENT {
        CCL_FIRED[0u64] = 1u32
        return dr
    }
    let tag : u8 = CCL_TAG[t]
    if tag == CCL_REACH {
        CCL_FIRED[0u64] = 1u32
        if iii_hexad_reachable(CCL_A[t] as u16) == 1u8 { return ccl_true_c() }
        return ccl_false_c()
    }
    if tag == CCL_LEK {
        CCL_FIRED[0u64] = 1u32
        let cs : u64 = (CCL_A[t] as u64) * 6u64
        let bs : u64 = (CCL_B[t] as u64) * 6u64
        let cptr : *u64 = ((&CLEK_REG as u64) + cs * 8u64) as *u64
        let bptr : *u64 = ((&CLEK_REG as u64) + bs * 8u64) as *u64
        if cl_le_product(cptr, bptr) == 1u8 { return ccl_true_c() }
        return ccl_false_c()
    }
    /* BV64 iota: a literal is its own normal form; an op reduces its operands
     * leftmost-outermost, then fires a ring rule once both are normal. */
    if tag == CCL_BVLIT { return t }
    if tag >= CCL_BVADD {
        if tag <= CCL_BVUDIV {
            let bo_a : u32 = CCL_A[t]
            let bo_b : u32 = CCL_B[t]
            let bo_ra : u32 = ccl_step(bo_a)
            if CCL_FIRED[0u64] == 1u32 { return ccl_mk(tag, bo_ra, bo_b) }
            let bo_rb : u32 = ccl_step(bo_b)
            if CCL_FIRED[0u64] == 1u32 { return ccl_mk(tag, bo_a, bo_rb) }
            let bo_f : u32 = ccl_bv_fold(tag, bo_a, bo_b)
            if bo_f != CCL_SENT {
                CCL_FIRED[0u64] = 1u32
                return bo_f
            }
            return t
        }
    }
    if tag == CCL_CUR {
        let body : u32 = CCL_A[t]
        let dom : u32 = CCL_B[t]
        /* reduce the body FIRST, preserving the binder domain (dependent types),
         * so eta sees the ass-normalised body -- COMPLETE eta requires it (a
         * higher-variable x o Fst right-associates before eta would match). */
        let rb : u32 = ccl_step(body)
        if CCL_FIRED[0u64] == 1u32 { return ccl_cur_d(dom, rb) }
        /* body is normal: COMPLETE eta-contraction (strengthen-based). */
        let ex : u32 = ccl_eta_contract(body)
        if ex != CCL_SENT {
            CCL_FIRED[0u64] = 1u32
            return ex
        }
        /* the domain is itself a (dependent) type that may carry redexes. */
        if dom != 0u32 {
            let rd : u32 = ccl_step(dom)
            if CCL_FIRED[0u64] == 1u32 { return ccl_cur_d(rd, body) }
        }
        return t
    }
    if tag == CCL_COMP {
        let a : u32 = CCL_A[t]
        let b : u32 = CCL_B[t]
        let atag : u8 = CCL_TAG[a]
        let btag : u8 = CCL_TAG[b]
        if btag == CCL_ID {
            CCL_FIRED[0u64] = 1u32
            return a
        }
        if atag == CCL_ID {
            CCL_FIRED[0u64] = 1u32
            return b
        }
        if atag == CCL_COMP {
            CCL_FIRED[0u64] = 1u32
            return ccl_comp(CCL_A[a], ccl_comp(CCL_B[a], b))
        }
        if atag == CCL_PAIR {
            CCL_FIRED[0u64] = 1u32
            return ccl_pair(ccl_comp(CCL_A[a], b), ccl_comp(CCL_B[a], b))
        }
        if atag == CCL_CUR {
            /* dcur: the body gets the EXTENDED environment <y o Fst, Snd>; the
             * DOMAIN (a type in the OUTER context) gets the environment y itself
             * -- so a dependent domain referencing outer vars is substituted. */
            let adom : u32 = CCL_B[a]
            let mut ndom : u32 = adom
            if adom != 0u32 { ndom = ccl_comp(adom, b) }
            CCL_FIRED[0u64] = 1u32
            return ccl_cur_d(ndom, ccl_comp(CCL_A[a], ccl_pair(ccl_comp(b, ccl_fst()), ccl_snd())))
        }
        if atag == CCL_FST {
            if btag == CCL_PAIR {
                CCL_FIRED[0u64] = 1u32
                return CCL_A[b]
            }
        }
        if atag == CCL_SND {
            if btag == CCL_PAIR {
                CCL_FIRED[0u64] = 1u32
                return CCL_B[b]
            }
        }
        if atag == CCL_APP {
            if btag == CCL_PAIR {
                let p : u32 = CCL_A[b]
                let q : u32 = CCL_B[b]
                let ptag : u8 = CCL_TAG[p]
                if ptag == CCL_CUR {
                    CCL_FIRED[0u64] = 1u32
                    return ccl_comp(CCL_A[p], ccl_pair(ccl_id(), q))
                }
                let mut is_beta : u32 = 0u32
                if ptag == CCL_COMP {
                    if CCL_TAG[CCL_A[p]] == CCL_CUR { is_beta = 1u32 }
                }
                if is_beta == 1u32 {
                    let cx : u32 = CCL_A[CCL_A[p]]
                    CCL_FIRED[0u64] = 1u32
                    return ccl_comp(cx, ccl_pair(CCL_B[p], q))
                }
            }
        }
        /* BV op nodes (tags 30..38) carry ENVIRONMENT-DEPENDENT operands (e.g. bvadd(Snd, lit)
         * references #0) -- so  bvop(A,B) o b  must DISTRIBUTE the composition into the operands
         * (like the PAIR rule above), NOT weaken to a closed constant.  A BVLIT (tag 29) IS a closed
         * literal value (its A,B are the u64 halves, not morphisms) and correctly weakens below.
         * SOUNDNESS: without this, a BV op under a substituted binder would drop the substitution. */
        if atag >= CCL_BVADD {
            if atag <= CCL_BVUDIV {
                CCL_FIRED[0u64] = 1u32
                return ccl_mk(atag, ccl_comp(CCL_A[a], b), ccl_comp(CCL_B[a], b))
            }
        }
        if atag >= CCL_ATOM {
            CCL_FIRED[0u64] = 1u32
            return a
        }
        let ra : u32 = ccl_step(a)
        if CCL_FIRED[0u64] == 1u32 { return ccl_comp(ra, b) }
        let rb : u32 = ccl_step(b)
        if CCL_FIRED[0u64] == 1u32 { return ccl_comp(a, rb) }
        return t
    }
    if tag == CCL_PAIR {
        /* no rule fires at a Pair node, but redexes live INSIDE it -- recurse. */
        let pa : u32 = CCL_A[t]
        let pb : u32 = CCL_B[t]
        let rpa : u32 = ccl_step(pa)
        if CCL_FIRED[0u64] == 1u32 { return ccl_pair(rpa, pb) }
        let rpb : u32 = ccl_step(pb)
        if CCL_FIRED[0u64] == 1u32 { return ccl_pair(pa, rpb) }
        return t
    }
    return t
}

/* reduce to CCL normal form (fixpoint of ccl_step), fuel-bounded. */
fn ccl_reduce(t: u32) -> u32 @export {
    let mut cur : u32 = t
    let mut go : u32 = 1u32
    let mut fuel : u32 = CCL_FUEL
    while go == 1u32 {
        if fuel == 0u32 { return cur }
        fuel = fuel - 1u32
        CCL_FIRED[0u64] = 0u32
        let next : u32 = ccl_step(cur)
        if CCL_FIRED[0u64] == 0u32 { go = 0u32 }
        cur = next
    }
    return cur
}

/* structural equality (CCL has no binders -> pure structure). */
fn ccl_struct_eq(x: u32, y: u32) -> u8 @export {
    /* II-CCL-2: node 0 is the reserved INVALID / arena-exhausted sentinel (ccl_mk
     * returns 0 on overflow; ccl_reset starts the bump at 1). It must NEVER compare
     * equal -- otherwise two exhausted reductions both collapse to node 0 and
     * ccl_conv would wrongly report "convertible", admitting a FALSE definitional
     * equality into the kernel (the unsound direction). Fail closed: 0 != anything. */
    if x == 0u32 { return 0u8 }
    if y == 0u32 { return 0u8 }
    let tx : u8 = CCL_TAG[x]
    let ty : u8 = CCL_TAG[y]
    if tx != ty { return 0u8 }
    if tx == CCL_ATOM {
        if CCL_A[x] == CCL_A[y] { return 1u8 }
        return 0u8
    }
    if tx == CCL_COMP {
        if ccl_struct_eq(CCL_A[x], CCL_A[y]) == 0u8 { return 0u8 }
        return ccl_struct_eq(CCL_B[x], CCL_B[y])
    }
    if tx == CCL_PAIR {
        if ccl_struct_eq(CCL_A[x], CCL_A[y]) == 0u8 { return 0u8 }
        return ccl_struct_eq(CCL_B[x], CCL_B[y])
    }
    if tx == CCL_CUR {
        return ccl_struct_eq(CCL_A[x], CCL_A[y])
    }
    /* BV64 (SOUNDNESS-CRITICAL): a BVLIT is equal ONLY when its 64-bit value (A=lo,B=hi)
     * matches -- WITHOUT this, two distinct literals would hit the nullary fallthrough below
     * (equal-tag => equal) and the kernel would prove FALSE definitional equalities (bvlit 2
     * == bvlit 3).  A BV op node (tags 30..38) is structural: equal iff both operands are. */
    if tx == CCL_BVLIT {
        if CCL_A[x] != CCL_A[y] { return 0u8 }
        if CCL_B[x] != CCL_B[y] { return 0u8 }
        return 1u8
    }
    /* wave-4 M17 SOUNDNESS FIX: the upper bound was CCL_BVMULOVF(38) -- BVLSHR(39) and
     * BVUDIV(40), added in 8.28/8.29, FELL THROUGH to the nullary equal-tag rule below, so any
     * two stuck shr (or udiv) forms compared EQUAL regardless of operands (x/8 == x>>2 was
     * provable; x>>3 == x>>2 likewise).  This was the FOURTH tag-range site -- strengthen/step/
     * comp-distribute were extended, the COMPARATOR was not.  Found by the federation falsifier
     * (1369 arm 3); the pow2-negative teeth in 1363 now pin every future BV tag against it. */
    if tx >= CCL_BVADD {
        if tx <= CCL_BVUDIV {
            if ccl_struct_eq(CCL_A[x], CCL_A[y]) == 0u8 { return 0u8 }
            return ccl_struct_eq(CCL_B[x], CCL_B[y])
        }
    }
    /* nullary morphisms Id/Fst/Snd/App: equal tag => equal. */
    return 1u8
}

/* conversion: reduce both to CCL normal form, compare structurally. */
fn ccl_conv(x: u32, y: u32) -> u8 @export {
    let nx : u32 = ccl_reduce(x)
    let ny : u32 = ccl_reduce(y)
    return ccl_struct_eq(nx, ny)
}

/* II-CCL-2 falsifier (prove the negative): the INVALID/exhausted sentinel (node 0)
 * must be fail-closed in ccl_struct_eq -- never equal to anything, including itself --
 * so arena exhaustion can never manufacture a FALSE "convertible" verdict. Also proves
 * the fix introduces NO false-negative on a real term. 99 = correct; 1..4 = which broke.
 * (Before the fix, ccl_struct_eq(0,0) returned 1 via the nullary-tag fallthrough.) */
fn ccl_invalid_kat() -> u64 @export {
    ccl_reset()
    if ccl_struct_eq(0u32, 0u32) != 0u8 { return 1u64 }   /* 0 vs 0 -> NOT equal (fail-closed) */
    let s : u32 = ccl_snd()
    if ccl_struct_eq(0u32, s) != 0u8 { return 2u64 }       /* 0 vs real -> NOT equal */
    if ccl_struct_eq(s, 0u32) != 0u8 { return 3u64 }       /* real vs 0 -> NOT equal */
    if ccl_struct_eq(s, s)    != 1u8 { return 4u64 }       /* real vs itself -> still equal (no regression) */
    return 99u64
}

/* ============================================================
 *  ETA KAT (846 vectors via directed reduction).
 *  99 = reproduces 846; 1..5 = first failing vector.
 * ============================================================ */
fn ccl_eta_kat() -> u64 @export {
    ccl_reset()
    /* T1 = lam f. lam x. (f x) = Cur(Cur(App o <Snd o Fst, Snd>)) */
    let sndfst : u32 = ccl_comp(ccl_snd(), ccl_fst())
    let inner  : u32 = ccl_cur(ccl_comp(ccl_app(), ccl_pair(sndfst, ccl_snd())))
    let t1     : u32 = ccl_cur(inner)
    /* T2 = lam f. f = Cur(Snd) */
    let t2     : u32 = ccl_cur(ccl_snd())
    /* P2 = lam f. lam x. x = Cur(Cur(Snd)) */
    let p2     : u32 = ccl_cur(ccl_cur(ccl_snd()))
    /* P3 = lam x. (x x) = Cur(App o <Snd, Snd>) */
    let p3     : u32 = ccl_cur(ccl_comp(ccl_app(), ccl_pair(ccl_snd(), ccl_snd())))

    /* P1 (eta fires). */
    if ccl_conv(t1, t2) != 1u8 { return 1u64 }
    /* P2 (no conflation). */
    if ccl_conv(t1, p2) != 0u8 { return 2u64 }
    /* P3 (strengthen-fail: x used twice, no eta). */
    if ccl_conv(p3, t2) != 0u8 { return 3u64 }
    /* P4 (reflexive). */
    if ccl_conv(t1, t1) != 1u8 { return 4u64 }
    /* eta normal form is exactly Cur(Snd). */
    if ccl_struct_eq(ccl_reduce(t1), t2) != 1u8 { return 5u64 }

    return 99u64
}

/* ============================================================
 *  BETA KAT (closed beta-redexes via directed reduction).
 *  99 = all reduce correctly; 1..5 = first failing case.
 * ============================================================ */
fn ccl_beta_kat() -> u64 @export {
    ccl_reset()
    let c : u32 = ccl_atom(20u32)
    let d : u32 = ccl_atom(21u32)

    /* T1: (lam a. a) c -> c */
    let t1 : u32 = ccl_comp(ccl_app(), ccl_pair(ccl_cur(ccl_snd()), c))
    if ccl_struct_eq(ccl_reduce(t1), c) != 1u8 { return 1u64 }

    /* T2: (lam a. lam b. a) c d -> c   (kf = Cur(Cur(Snd o Fst))) */
    let kf  : u32 = ccl_cur(ccl_cur(ccl_comp(ccl_snd(), ccl_fst())))
    let t2i : u32 = ccl_comp(ccl_app(), ccl_pair(kf, c))
    let t2  : u32 = ccl_comp(ccl_app(), ccl_pair(t2i, d))
    if ccl_struct_eq(ccl_reduce(t2), c) != 1u8 { return 2u64 }

    /* T3: (lam a. lam b. b) c d -> d   (kif = Cur(Cur(Snd))) */
    let kif : u32 = ccl_cur(ccl_cur(ccl_snd()))
    let t3i : u32 = ccl_comp(ccl_app(), ccl_pair(kif, c))
    let t3  : u32 = ccl_comp(ccl_app(), ccl_pair(t3i, d))
    if ccl_struct_eq(ccl_reduce(t3), d) != 1u8 { return 3u64 }

    /* discrimination. */
    if ccl_struct_eq(ccl_reduce(t2), d) != 0u8 { return 4u64 }
    if ccl_struct_eq(ccl_reduce(t3), c) != 0u8 { return 5u64 }

    return 99u64
}

/* ============================================================
 *  DATA KAT: eliminator iota via directed CCL reduction (no substitution).
 *  Methods are lam_. v = Cur(v) (weakening makes the constant body context-free).
 *  99 = all reduce correctly; 1..9 = first failing case.
 * ============================================================ */
fn ccl_data_kat() -> u64 @export {
    ccl_reset()
    let c : u32 = ccl_atom(20u32)
    let d : u32 = ccl_atom(21u32)
    let one : u32 = ccl_app2(ccl_succ_c(), ccl_zero_c())
    let kd : u32 = ccl_cur(d)            /* lam _. d */
    let kc : u32 = ccl_cur(c)            /* lam _. c */

    /* IF: TRUE->t, FALSE->e, discriminates. */
    let ift : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_if_c(), ccl_true_c()), c), d)
    if ccl_struct_eq(ccl_reduce(ift), c) != 1u8 { return 1u64 }
    let iff : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_if_c(), ccl_false_c()), c), d)
    if ccl_struct_eq(ccl_reduce(iff), d) != 1u8 { return 2u64 }
    if ccl_struct_eq(ccl_reduce(ift), d) != 0u8 { return 3u64 }

    /* ITER: ZERO->z ; SUCC m -> s (rec).  s = lam_.d discards -> d. */
    let it0 : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_iter_c(), c), kd), ccl_zero_c())
    if ccl_struct_eq(ccl_reduce(it0), c) != 1u8 { return 4u64 }
    let it1 : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_iter_c(), c), kd), one)
    if ccl_struct_eq(ccl_reduce(it1), d) != 1u8 { return 5u64 }

    /* NATREC: SUCC m -> s m (rec).  s = lam k.lam_.d -> d. */
    let kkd : u32 = ccl_cur(ccl_cur(d))
    let mtv : u32 = ccl_atom(99u32)   /* dummy motive (the iota-rules ignore it) */
    let nr1 : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_app2(ccl_natrec_c(), mtv), c), kkd), one)
    if ccl_struct_eq(ccl_reduce(nr1), d) != 1u8 { return 6u64 }

    /* CASE: INL v -> f v ; INR v -> g v. */
    let e : u32 = ccl_atom(22u32)
    let casel : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_app2(ccl_case_c(), mtv), kc), kd), ccl_app2(ccl_inl_c(), e))
    if ccl_struct_eq(ccl_reduce(casel), c) != 1u8 { return 7u64 }
    let caser : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_app2(ccl_case_c(), mtv), kc), kd), ccl_app2(ccl_inr_c(), e))
    if ccl_struct_eq(ccl_reduce(caser), d) != 1u8 { return 8u64 }

    /* J: REFL a -> d. */
    let jt : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_j_c(), mtv), c), ccl_app2(ccl_refl_c(), ccl_atom(23u32)))
    if ccl_struct_eq(ccl_reduce(jt), c) != 1u8 { return 9u64 }

    return 99u64
}

/* ============================================================
 *  READ-BACK (reification): ccl_to_tc reifies a CCL NORMAL FORM into a TC node,
 *  the inverse of typecheck's tc_to_ccl.  This is what lets tc_whnf / tc_nf run
 *  on the directed CCL reducer (compile -> reduce -> read back) instead of NbE.
 *  Domains are recovered from CurT (CCL_B); motives from the kept eliminator args.
 * ============================================================ */

/* number of Fst's in a right-nested fst-chain (Fst, Fst o Fst, ...), or SENT. */
fn ccl_count_fst(c: u32) -> u32 {
    if CCL_TAG[c] == CCL_FST { return 1u32 }
    if CCL_TAG[c] == CCL_COMP {
        if CCL_TAG[CCL_A[c]] == CCL_FST {
            let rest : u32 = ccl_count_fst(CCL_B[c])
            if rest == CCL_SENT { return CCL_SENT }
            return 1u32 + rest
        }
    }
    return CCL_SENT
}

/* de Bruijn index of a variable form  Snd o Fst^k , or SENT if not a variable. */
fn ccl_rb_varidx(c: u32) -> u32 {
    if CCL_TAG[c] == CCL_SND { return 0u32 }
    if CCL_TAG[c] == CCL_COMP {
        if CCL_TAG[CCL_A[c]] == CCL_SND {
            return ccl_count_fst(CCL_B[c])
        }
    }
    return CCL_SENT
}

fn ccl_to_tc(c: u32) -> u32 @export {
    /* II-CCL-2: node 0 is the reserved INVALID sentinel (ccl_reduce/ccl_mk return 0 on CCL_CAP overflow).
     * Treating it as a real node misreads CCL_TAG[0] and, since CCL_A[0]==0, would self-recurse to a stack
     * overflow. Map it to the same stuck-fallback term the COMP/ATOM arms use (tc_var 0). */
    if c == 0u32 { return tc_var(0u32) }
    let tag : u8 = CCL_TAG[c]
    let vi : u32 = ccl_rb_varidx(c)
    if vi != CCL_SENT { return tc_var(vi) }
    if tag == CCL_CUR {
        let body : u32 = ccl_to_tc(CCL_A[c])
        return tc_lam(ccl_to_tc(CCL_B[c]), body)
    }
    if tag == CCL_TRUE { return tc_true() }
    if tag == CCL_FALSE { return tc_false() }
    if tag == CCL_ZERO { return tc_zero() }
    /* BV64 read-back: flat primitive nodes reify directly (a literal, or a neutral op
     * tree like bvmul(x, lit) that survived reduction).  Without these a BV normal form
     * would hit the tc_var(0) stuck-fallback below and silently lose its meaning. */
    if tag == CCL_BVLIT { return tc_bvlit(CCL_A[c], CCL_B[c]) }
    if tag == CCL_BVADD { return tc_bvadd(ccl_to_tc(CCL_A[c]), ccl_to_tc(CCL_B[c])) }
    if tag == CCL_BVSUB { return tc_bvsub(ccl_to_tc(CCL_A[c]), ccl_to_tc(CCL_B[c])) }
    if tag == CCL_BVMUL { return tc_bvmul(ccl_to_tc(CCL_A[c]), ccl_to_tc(CCL_B[c])) }
    if tag == CCL_BVAND { return tc_bvand(ccl_to_tc(CCL_A[c]), ccl_to_tc(CCL_B[c])) }
    if tag == CCL_BVOR  { return tc_bvor(ccl_to_tc(CCL_A[c]),  ccl_to_tc(CCL_B[c])) }
    if tag == CCL_BVXOR { return tc_bvxor(ccl_to_tc(CCL_A[c]), ccl_to_tc(CCL_B[c])) }
    if tag == CCL_BVSHL { return tc_bvshl(ccl_to_tc(CCL_A[c]), ccl_to_tc(CCL_B[c])) }
    /* wave-4 M17 SOUNDNESS FIX: BVLSHR (8.28) and BVUDIV (8.29) were missing from this readback
     * switch -- a stuck shr/udiv normal form fell to the tc_var(0) fallback below and SILENTLY
     * LOST ITS MEANING, so any two stuck forms compared conv-EQUAL (x/8 == x>>2 was provable).
     * Found by the federation falsifier (1369 arm 3); the pow2-negative teeth now pin it. */
    if tag == CCL_BVLSHR { return tc_bvlshr(ccl_to_tc(CCL_A[c]), ccl_to_tc(CCL_B[c])) }
    if tag == CCL_BVUDIV { return tc_bvudiv(ccl_to_tc(CCL_A[c]), ccl_to_tc(CCL_B[c])) }
    if tag == CCL_BVADDOVF { return tc_bvaddovf(ccl_to_tc(CCL_A[c]), ccl_to_tc(CCL_B[c])) }
    if tag == CCL_BVMULOVF { return tc_bvmulovf(ccl_to_tc(CCL_A[c]), ccl_to_tc(CCL_B[c])) }
    if tag == CCL_ATOM {
        let aid : u32 = CCL_A[c]
        if aid == 2050u32 { return tc_nat() }
        if aid == 2051u32 { return tc_bool() }
        if aid == 2052u32 { return tc_unit() }
        if aid == 2053u32 { return tc_empty() }
        if aid == 2054u32 { return tc_tt() }
        if aid == 2055u32 { return tc_bv() }
        if aid >= 2100u32 { return tc_sort(aid - 2100u32) }
        return tc_var(0u32)
    }
    if tag == CCL_COMP {
        let head : u32 = ccl_unwind(c)
        let k : u32 = CCL_ENARG[0u64]
        if k == 0u32 { return tc_var(0u32) }       /* stuck non-application comp: unreachable in nf */
        let htag : u8 = CCL_TAG[head]
        let mut e0 : u32 = 0u32
        let mut e1 : u32 = 0u32
        let mut e2 : u32 = 0u32
        let mut e3 : u32 = 0u32
        if k >= 1u32 { e0 = CCL_EARG[0u32] }
        if k >= 2u32 { e1 = CCL_EARG[1u32] }
        if k >= 3u32 { e2 = CCL_EARG[2u32] }
        if k >= 4u32 { e3 = CCL_EARG[3u32] }
        if htag == CCL_ATOM {
            let hid : u32 = CCL_A[head]
            if hid == 2060u32 { return tc_pi(ccl_to_tc(e1), ccl_to_tc(CCL_A[e0])) }
            if hid == 2065u32 { return tc_pi_q(ccl_to_tc(e1), ccl_to_tc(CCL_A[e0]), 1u32) }   /* QTT erased Pi */
            if hid == 2066u32 { return tc_pi_q(ccl_to_tc(e1), ccl_to_tc(CCL_A[e0]), 2u32) }   /* QTT linear Pi */
            if hid == 2061u32 { return tc_sig(ccl_to_tc(e1), ccl_to_tc(CCL_A[e0])) }
            if hid == 2062u32 { return tc_id(ccl_to_tc(e2), ccl_to_tc(e1), ccl_to_tc(e0)) }
            if hid == 2063u32 { return tc_sum(ccl_to_tc(e1), ccl_to_tc(e0)) }
            if hid == 2064u32 { return tc_absurd(ccl_to_tc(e1), ccl_to_tc(e0)) }
            if hid == 2068u32 { return tc_w(ccl_to_tc(e1), ccl_to_tc(CCL_A[e0])) }
        }
        if htag == CCL_SUCC { return tc_succ(ccl_to_tc(e0)) }
        if htag == CCL_INL { return tc_inl(ccl_to_tc(e0)) }
        if htag == CCL_INR { return tc_inr(ccl_to_tc(e0)) }
        if htag == CCL_REFL { return tc_refl(ccl_to_tc(e0)) }
        if htag == CCL_IF { return tc_if(ccl_to_tc(e2), ccl_to_tc(e1), ccl_to_tc(e0)) }
        if htag == CCL_ITER { return tc_iter(ccl_to_tc(e2), ccl_to_tc(e1), ccl_to_tc(e0)) }
        if htag == CCL_NATREC { return tc_natrec(ccl_to_tc(e3), ccl_to_tc(e2), ccl_to_tc(e1), ccl_to_tc(e0)) }
        if htag == CCL_WREC { return tc_wrec(ccl_to_tc(e2), ccl_to_tc(e1), ccl_to_tc(e0)) }
        if htag == CCL_CASE { return tc_case(ccl_to_tc(e3), ccl_to_tc(e2), ccl_to_tc(e1), ccl_to_tc(e0)) }
        if htag == CCL_J { return tc_j(ccl_to_tc(e2), ccl_to_tc(e1), ccl_to_tc(e0)) }
        if htag == CCL_SPAIR { return tc_pair(ccl_to_tc(e1), ccl_to_tc(e0)) }
        if htag == CCL_SUP { return tc_sup(ccl_to_tc(e1), ccl_to_tc(e0)) }
        if htag == CCL_SFST { return tc_fst(ccl_to_tc(e0)) }
        if htag == CCL_SSND { return tc_snd(ccl_to_tc(e0)) }
        if htag == CCL_TRANSP { return tc_transp(ccl_to_tc(e2), ccl_to_tc(e1), ccl_to_tc(e0)) }
        /* ordinary application of ARBITRARY arity (II-CCL-1): the old fixed e0..e3
         * fold silently DROPPED args for k>=5 (and the head for k>8). Decompose the
         * outermost App o <inner, arg> structurally instead: `inner` is the (k-1)-arg
         * spine, read back by recursion; the head was already classified non-special
         * above, so the recursive ccl_to_tc(inner) re-derives the same head harmlessly
         * and re-applies it. No dependency on the bounded CCL_EARG scratch, so it is
         * recursion-safe and correct for every arity. (k>=1 here -- the k==0 early-out
         * above guarantees the outermost node is App o Pair.) */
        let sp : u32 = CCL_B[c]              /* the outermost <inner, arg> pair */
        let inner : u32 = CCL_A[sp]
        let arg : u32 = CCL_B[sp]
        return tc_app(ccl_to_tc(inner), ccl_to_tc(arg))
    }
    return tc_var(0u32)
}

/* ETA-COMPLETENESS regression: eta-contraction must work for HIGHER de Bruijn
 * variables, not just #0.  control #0 contracts; #1 exercises the strengthen
 * path (ass right-associates the weakened var chain).  2 = #0 broke; 1 = #1 did
 * not contract (the incompleteness this guards); 99 = complete. */
fn ccl_etahi_kat() -> u64 @export {
    ccl_reset()
    /* #1 = Snd o Fst ; #2 = Snd o (Fst o Fst) */
    let v1 : u32 = ccl_comp(ccl_snd(), ccl_fst())
    let v2 : u32 = ccl_comp(ccl_snd(), ccl_comp(ccl_fst(), ccl_fst()))
    /* CONTROL: eta-long of #0 = Cur(App o <#1, Snd>) -> #0 = Snd */
    let body0 : u32 = ccl_comp(ccl_app(), ccl_pair(v1, ccl_snd()))
    let nf0 : u32 = ccl_reduce(ccl_cur(body0))
    if ccl_struct_eq(nf0, ccl_snd()) != 1u8 { return 2u64 }
    /* TEST: eta-long of #1 = Cur(App o <#2, Snd>) -> #1 = Snd o Fst */
    let body1 : u32 = ccl_comp(ccl_app(), ccl_pair(v2, ccl_snd()))
    let nf1 : u32 = ccl_reduce(ccl_cur(body1))
    if ccl_struct_eq(nf1, v1) != 1u8 { return 1u64 }
    return 99u64
}

/* ============================================================
 *  B18d (de-deferred): the CCL-NATIVE machine critical-pair ENUMERATOR.
 *
 *  The rule set as a machine-readable table (rule id -> LHS pattern -> RHS image):
 *    1 idr   x o Id              -> x
 *    2 idl   Id o x              -> x
 *    3 ass   (x o y) o z         -> x o (y o z)
 *    4 dpair <x,y> o z           -> <x o z, y o z>
 *    5 dcur  Cur(x) o y          -> Cur(x o <y o Fst, Snd>)     (side-cond: y != Id; idr has priority)
 *    6 fst   Fst o <x,y>         -> x
 *    7 snd   Snd o <x,y>         -> y
 *    8 beta  App o <Cur(x) o y, z> -> x o <y, z>
 *    9 bare  App o <Cur(x), z>     -> x o <Id, z>
 *   10 weak  c o y               -> c        (c a constant, tag >= CCL_ATOM)
 *
 *  ccl_cp_lhs(rid) builds the LHS with STRUCTURED fillers (Fst/Snd/App + the rule's own
 *  head); ccl_cp_rhs(rid, t, fault) is the RHS image -- and when fault==rid it returns a
 *  DELIBERATELY WRONG image (the build-time injection the falsifier 939 exercises).
 *  ccl_critpair_enum enumerates every rule-rule overlap and checks the two one-step reducts
 *  JOIN under the real reducer (ccl_reduce).  Unlike the hand list it is GENERATED from the
 *  table, so it certifies confluence as a THEOREM, not a 16-pair sample, and CATCHES an
 *  arbitrary injected divergence (any rule with a wrong RHS). */

fn ccl_cp_lhs(rid: u32) -> u32 {
    if rid == 1u32 { return ccl_comp(ccl_fst(), ccl_id()) }                                   /* idr  x o Id */
    if rid == 2u32 { return ccl_comp(ccl_id(), ccl_fst()) }                                   /* idl  Id o x */
    if rid == 3u32 { return ccl_comp(ccl_comp(ccl_fst(), ccl_snd()), ccl_app()) }             /* ass  (x o y) o z */
    if rid == 4u32 { return ccl_comp(ccl_pair(ccl_fst(), ccl_snd()), ccl_app()) }             /* dpair <x,y> o z */
    if rid == 5u32 { return ccl_comp(ccl_cur(ccl_fst()), ccl_snd()) }                         /* dcur Cur(x) o y (y=Snd!=Id) */
    if rid == 6u32 { return ccl_comp(ccl_fst(), ccl_pair(ccl_snd(), ccl_app())) }             /* fst  Fst o <x,y> */
    if rid == 7u32 { return ccl_comp(ccl_snd(), ccl_pair(ccl_fst(), ccl_app())) }             /* snd  Snd o <x,y> */
    if rid == 8u32 { return ccl_comp(ccl_app(), ccl_pair(ccl_comp(ccl_cur(ccl_fst()), ccl_snd()), ccl_app())) }  /* beta */
    if rid == 9u32 { return ccl_comp(ccl_app(), ccl_pair(ccl_cur(ccl_fst()), ccl_snd())) }    /* bare App o <Cur(x), z> */
    return ccl_comp(ccl_atom(7u32), ccl_fst())                                                /* weak c o y */
}

fn ccl_cp_rhs(rid: u32, t: u32, fault: u32) -> u32 {
    let mut wrong : u32 = 0u32
    if fault == rid { wrong = 1u32 }
    if rid == 1u32 {                                            /* idr: x o Id -> x */
        if wrong == 1u32 { return CCL_B[t] }
        return CCL_A[t]
    }
    if rid == 2u32 {                                            /* idl: Id o x -> x */
        if wrong == 1u32 { return CCL_A[t] }
        return CCL_B[t]
    }
    if rid == 3u32 {                                            /* ass: (x o y) o z -> x o (y o z) */
        let a3 : u32 = CCL_A[t]
        let z3 : u32 = CCL_B[t]
        if wrong == 1u32 { return ccl_comp(CCL_B[a3], ccl_comp(CCL_A[a3], z3)) }
        return ccl_comp(CCL_A[a3], ccl_comp(CCL_B[a3], z3))
    }
    if rid == 4u32 {                                            /* dpair: <x,y> o z -> <x o z, y o z> */
        let a4 : u32 = CCL_A[t]
        let z4 : u32 = CCL_B[t]
        if wrong == 1u32 { return ccl_pair(ccl_comp(CCL_B[a4], z4), ccl_comp(CCL_A[a4], z4)) }
        return ccl_pair(ccl_comp(CCL_A[a4], z4), ccl_comp(CCL_B[a4], z4))
    }
    if rid == 5u32 {                                            /* dcur: Cur(x) o y -> Cur(x o <y o Fst, Snd>) */
        let a5 : u32 = CCL_A[t]
        let y5 : u32 = CCL_B[t]
        let xb5 : u32 = CCL_A[a5]
        if wrong == 1u32 { return ccl_cur(xb5) }
        return ccl_cur(ccl_comp(xb5, ccl_pair(ccl_comp(y5, ccl_fst()), ccl_snd())))
    }
    if rid == 6u32 {                                            /* fst: Fst o <x,y> -> x */
        let b6 : u32 = CCL_B[t]
        if wrong == 1u32 { return CCL_B[b6] }
        return CCL_A[b6]
    }
    if rid == 7u32 {                                            /* snd: Snd o <x,y> -> y */
        let b7 : u32 = CCL_B[t]
        if wrong == 1u32 { return CCL_A[b7] }
        return CCL_B[b7]
    }
    if rid == 8u32 {                                            /* beta: App o <Cur(x) o y, z> -> x o <y, z> */
        let b8 : u32 = CCL_B[t]
        let p8 : u32 = CCL_A[b8]
        let z8 : u32 = CCL_B[b8]
        let xb8 : u32 = CCL_A[CCL_A[p8]]
        let y8 : u32 = CCL_B[p8]
        if wrong == 1u32 { return ccl_comp(xb8, ccl_pair(z8, y8)) }
        return ccl_comp(xb8, ccl_pair(y8, z8))
    }
    if rid == 9u32 {                                            /* bare: App o <Cur(x), z> -> x o <Id, z> */
        let b9 : u32 = CCL_B[t]
        let p9 : u32 = CCL_A[b9]
        let z9 : u32 = CCL_B[b9]
        let xb9 : u32 = CCL_A[p9]
        if wrong == 1u32 { return ccl_comp(xb9, ccl_pair(z9, ccl_id())) }
        return ccl_comp(xb9, ccl_pair(ccl_id(), z9))
    }
    /* rid == 10: weak: c o y -> c */
    if wrong == 1u32 { return CCL_B[t] }
    return CCL_A[t]
}

fn ccl_cp_join(r1: u32, r2: u32) -> u8 {
    return ccl_struct_eq(ccl_reduce(r1), ccl_reduce(r2))
}

fn ccl_critpair_enum(fault: u32) -> u64 @export {
    /* ---- Class A: ass at root vs rule R at the left child  ((R.lhs) o Z) ---- */
    let mut r : u32 = 1u32
    while r <= 10u32 {
        ccl_reset()
        let inner : u32 = ccl_cp_lhs(r)
        let zf : u32 = ccl_fst()
        let t : u32 = ccl_comp(inner, zf)
        let r1 : u32 = ccl_cp_rhs(3u32, t, fault)                       /* ass at root */
        let r2 : u32 = ccl_comp(ccl_cp_rhs(r, inner, fault), zf)        /* R at the child, o Z */
        if ccl_cp_join(r1, r2) != 1u8 { return (100u32 + r) as u64 }
        r = r + 1u32
    }
    /* ---- Class B: idr at root (b = Id) vs free-b rule R at root.  dcur excluded (y!=Id). ---- */
    ccl_reset()
    let tb2 : u32 = ccl_comp(ccl_id(), ccl_id())                        /* idl/idr: Id o Id */
    if ccl_cp_join(ccl_cp_rhs(1u32, tb2, fault), ccl_cp_rhs(2u32, tb2, fault)) != 1u8 { return 202u64 }
    ccl_reset()
    let tb3 : u32 = ccl_comp(ccl_comp(ccl_fst(), ccl_snd()), ccl_id())  /* ass/idr: (x o y) o Id */
    if ccl_cp_join(ccl_cp_rhs(1u32, tb3, fault), ccl_cp_rhs(3u32, tb3, fault)) != 1u8 { return 203u64 }
    ccl_reset()
    let tb4 : u32 = ccl_comp(ccl_pair(ccl_fst(), ccl_snd()), ccl_id())  /* dpair/idr: <x,y> o Id */
    if ccl_cp_join(ccl_cp_rhs(1u32, tb4, fault), ccl_cp_rhs(4u32, tb4, fault)) != 1u8 { return 204u64 }
    ccl_reset()
    let tb10 : u32 = ccl_comp(ccl_atom(7u32), ccl_id())                 /* weak/idr: c o Id */
    if ccl_cp_join(ccl_cp_rhs(1u32, tb10, fault), ccl_cp_rhs(10u32, tb10, fault)) != 1u8 { return 210u64 }

    /* ---- Specials: higher-order subterm overlaps ---- */
    /* S1 beta x dcur: App o <Cur(x) o y, z> ; the subterm Cur(x) o y is a dcur redex. */
    ccl_reset()
    let s1sub : u32 = ccl_comp(ccl_cur(ccl_fst()), ccl_snd())
    let s1t : u32 = ccl_comp(ccl_app(), ccl_pair(s1sub, ccl_app()))
    let s1r1 : u32 = ccl_cp_rhs(8u32, s1t, fault)                                       /* beta at root */
    let s1r2 : u32 = ccl_comp(ccl_app(), ccl_pair(ccl_cp_rhs(5u32, s1sub, fault), ccl_app()))  /* dcur at subterm */
    if ccl_cp_join(s1r1, s1r2) != 1u8 { return 301u64 }
    /* S2 bare x eta: App o <Cur(App o <c o Fst, Snd>), z> ; the Cur body is an eta-redex. */
    ccl_reset()
    let s2body : u32 = ccl_comp(ccl_app(), ccl_pair(ccl_comp(ccl_atom(9u32), ccl_fst()), ccl_snd()))
    let s2t : u32 = ccl_comp(ccl_app(), ccl_pair(ccl_cur(s2body), ccl_app()))
    let s2r1 : u32 = ccl_cp_rhs(9u32, s2t, fault)                                       /* bare at root */
    let s2r2 : u32 = ccl_comp(ccl_app(), ccl_pair(ccl_eta_contract(s2body), ccl_app())) /* eta at subterm */
    if ccl_cp_join(s2r1, s2r2) != 1u8 { return 302u64 }
    /* S3 dcur x eta: Cur(App o <c o Fst, Snd>) o y ; root dcur vs inner eta. */
    ccl_reset()
    let s3body : u32 = ccl_comp(ccl_app(), ccl_pair(ccl_comp(ccl_atom(9u32), ccl_fst()), ccl_snd()))
    let s3t : u32 = ccl_comp(ccl_cur(s3body), ccl_snd())
    let s3r1 : u32 = ccl_cp_rhs(5u32, s3t, fault)                                       /* dcur at root */
    let s3r2 : u32 = ccl_comp(ccl_eta_contract(s3body), ccl_snd())                      /* eta inside Cur, then o y */
    if ccl_cp_join(s3r1, s3r2) != 1u8 { return 303u64 }
    /* S4 iota(IF) x substitution: IF(TRUE,F,A) o S  joins  (then=F) o S. */
    ccl_reset()
    let s4sp : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_if_c(), ccl_true_c()), ccl_fst()), ccl_app())
    if ccl_struct_eq(ccl_reduce(ccl_comp(s4sp, ccl_snd())), ccl_reduce(ccl_comp(ccl_fst(), ccl_snd()))) != 1u8 { return 304u64 }
    /* S5 iota(NATREC) x substitution: NATREC(C,F,S,ZERO) o A  joins  F o A. */
    ccl_reset()
    let s5sp : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_app2(ccl_natrec_c(), ccl_atom(8u32)), ccl_fst()), ccl_snd()), ccl_zero_c())
    if ccl_struct_eq(ccl_reduce(ccl_comp(s5sp, ccl_app())), ccl_reduce(ccl_comp(ccl_fst(), ccl_app()))) != 1u8 { return 305u64 }

    return 99u64
}

/* ============================================================
 *  B18d: CONFLUENCE CERTIFICATE (the bootstrap falsifier).
 *  Local confluence is decided by checking that EVERY critical pair of the CCL
 *  rule set joins: an overlap term with two distinct redexes is contracted each
 *  way to R1,R2, and the two must reduce to a common normal form
 *  (ccl_reduce R1 == ccl_reduce R2).  By Newman's lemma, local confluence +
 *  termination => global confluence (Church-Rosser).  TERMINATION: the sigma
 *  (substitution) fragment + data-iota are structurally decreasing; beta/eta on
 *  the WELL-TYPED terms the kernel reduces are SN by MLTT strong normalisation
 *  (the reducer is only ever applied to well-typed terms -- untyped CCLbeta is
 *  not SN in general, the Mellies obstruction, so termination is necessarily
 *  conditioned on typing, exactly as for NbE).  This REPLACES the now-deleted
 *  NbE differential (860): it certifies the directed reducer confluent on its
 *  OWN, with no second oracle to compare against.  Structured fillers
 *  (Fst/Snd/App/Id + fresh atom) keep the joined forms structured, so a wrong
 *  rule yields a DIFFERENT normal form (proven sensitive by the negative test).
 *  99 = every critical pair joins;  N = critical pair N failed to join.
 *  RETAINED as a regression CROSS-CHECK: the machine enumerator (ccl_critpair_enum) is now
 *  the primary, exhaustive theorem; these 16 hand pairs must still join (the generator must
 *  find AT LEAST these). */
fn ccl_conf_cert_cp16() -> u64 {
    ccl_reset()
    let f  : u32 = ccl_fst()
    let s  : u32 = ccl_snd()
    let ap : u32 = ccl_app()
    let id : u32 = ccl_id()

    /* CP1  ass / idl :  (Id o S) o F   [top ass vs inner idl] */
    let n1a : u32 = ccl_reduce(ccl_comp(id, ccl_comp(s, f)))      /* ass -> Id o (S o F) */
    let n1b : u32 = ccl_reduce(ccl_comp(s, f))                    /* idl -> S o F */
    if ccl_struct_eq(n1a, n1b) != 1u8 { return 1u64 }

    /* CP2  ass / idr :  (F o Id) o S */
    let n2a : u32 = ccl_reduce(ccl_comp(f, ccl_comp(id, s)))      /* ass -> F o (Id o S) */
    let n2b : u32 = ccl_reduce(ccl_comp(f, s))                    /* idr -> F o S */
    if ccl_struct_eq(n2a, n2b) != 1u8 { return 2u64 }

    /* CP3  idr / ass :  (F o S) o Id */
    let n3a : u32 = ccl_reduce(ccl_comp(f, s))                    /* idr -> F o S */
    let n3b : u32 = ccl_reduce(ccl_comp(f, ccl_comp(s, id)))      /* ass -> F o (S o Id) */
    if ccl_struct_eq(n3a, n3b) != 1u8 { return 3u64 }

    /* CP4  ass / ass :  ((F o S) o A) o (S o A) */
    let w4 : u32 = ccl_comp(s, ap)
    let n4a : u32 = ccl_reduce(ccl_comp(ccl_comp(f, s), ccl_comp(ap, w4)))   /* top ass */
    let n4b : u32 = ccl_reduce(ccl_comp(ccl_comp(f, ccl_comp(s, ap)), w4))   /* inner ass */
    if ccl_struct_eq(n4a, n4b) != 1u8 { return 4u64 }

    /* CP5  ass / dpair :  (<F,S> o A) o S */
    let n5a : u32 = ccl_reduce(ccl_comp(ccl_pair(f, s), ccl_comp(ap, s)))    /* top ass */
    let n5b : u32 = ccl_reduce(ccl_comp(ccl_pair(ccl_comp(f, ap), ccl_comp(s, ap)), s)) /* inner dpair */
    if ccl_struct_eq(n5a, n5b) != 1u8 { return 5u64 }

    /* CP6  ass / fst :  (Fst o <S,A>) o S */
    let n6a : u32 = ccl_reduce(ccl_comp(f, ccl_comp(ccl_pair(s, ap), s)))    /* top ass */
    let n6b : u32 = ccl_reduce(ccl_comp(s, s))                              /* inner fst -> S */
    if ccl_struct_eq(n6a, n6b) != 1u8 { return 6u64 }

    /* CP7  ass / snd :  (Snd o <F,A>) o S */
    let n7a : u32 = ccl_reduce(ccl_comp(s, ccl_comp(ccl_pair(f, ap), s)))    /* top ass */
    let n7b : u32 = ccl_reduce(ccl_comp(ap, s))                             /* inner snd -> A */
    if ccl_struct_eq(n7a, n7b) != 1u8 { return 7u64 }

    /* CP8  ass / beta :  (App o <Cur(S), F>) o S */
    let n8a : u32 = ccl_reduce(ccl_comp(ap, ccl_comp(ccl_pair(ccl_cur(s), f), s)))      /* top ass */
    let n8b : u32 = ccl_reduce(ccl_comp(ccl_comp(s, ccl_pair(id, f)), s))               /* inner beta -> (S o <Id,F>) o S */
    if ccl_struct_eq(n8a, n8b) != 1u8 { return 8u64 }

    /* CP9  beta / eta :  App o <Cur(App o <Snd o Fst, Snd>), F>   (the Cur is an eta-redex) */
    let eb9 : u32 = ccl_comp(ap, ccl_pair(ccl_comp(s, f), s))    /* App o <Snd o Fst, Snd> */
    let n9a : u32 = ccl_reduce(ccl_comp(eb9, ccl_pair(id, f)))   /* beta -> ebody o <Id,F> */
    let n9b : u32 = ccl_reduce(ccl_comp(ap, ccl_pair(s, f)))     /* eta inside Cur -> Snd ; App o <Snd,F> */
    if ccl_struct_eq(n9a, n9b) != 1u8 { return 9u64 }

    /* CP10  dcur / eta :  Cur(App o <Snd o Fst, Snd>) o F   (Cur is an eta-redex; dcur
     *  pushes the variable to #2, so joining REQUIRES complete eta strengthen #2 -> #1). */
    let eb10 : u32 = ccl_comp(ap, ccl_pair(ccl_comp(s, f), s))
    let n10a : u32 = ccl_reduce(ccl_comp(s, f))                  /* eta -> Snd ; then Snd o F */
    let n10b : u32 = ccl_reduce(ccl_cur(ccl_comp(eb10, ccl_pair(ccl_comp(f, f), s))))  /* dcur */
    if ccl_struct_eq(n10a, n10b) != 1u8 { return 10u64 }

    /* CP11  ass / atom :  (at7 o S) o F   (atom is left-absorbing) */
    let at7 : u32 = ccl_atom(7u32)
    let n11a : u32 = ccl_reduce(ccl_comp(at7, ccl_comp(s, f)))   /* top ass */
    let n11b : u32 = ccl_reduce(ccl_comp(at7, f))               /* inner atom -> at7 */
    if ccl_struct_eq(n11a, n11b) != 1u8 { return 11u64 }

    /* CP12  iota / substitution :  IF(TRUE,F,A) o S  must join  (then=F) o S
     *  (the substitution distributes through the spine, then iota fires). */
    let ifsp : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_if_c(), ccl_true_c()), f), ap)
    let n12a : u32 = ccl_reduce(ccl_comp(ifsp, s))
    let n12b : u32 = ccl_reduce(ccl_comp(f, s))
    if ccl_struct_eq(n12a, n12b) != 1u8 { return 12u64 }

    /* CP13  natrec iota / substitution :  NATREC(C,z=F,s=S,ZERO) o A  must join  z o A */
    let nrsp : u32 = ccl_app2(ccl_app2(ccl_app2(ccl_app2(ccl_natrec_c(), ccl_atom(8u32)), f), s), ccl_zero_c())
    let n13a : u32 = ccl_reduce(ccl_comp(nrsp, ap))
    let n13b : u32 = ccl_reduce(ccl_comp(f, ap))
    if ccl_struct_eq(n13a, n13b) != 1u8 { return 13u64 }

    /* CP14  beta2 / dcur :  App o <Cur(Snd) o Fst, Snd>   -- the BARE-BETA SHORTCUT
     *  (App o <Cur(g) o r, q> -> g o <r,q>, the precomposed-Cur fast path) must
     *  agree with the long route dcur-then-beta1.  beta2 contracts at the top;
     *  dcur fires on the Cur(Snd) o Fst subterm; both must join -- this certifies
     *  the shortcut sound (it is the ONLY rule no earlier critical pair exercised). */
    let n14a : u32 = ccl_reduce(ccl_comp(s, ccl_pair(f, s)))    /* beta2 -> g o <r,q> = Snd o <Fst,Snd> */
    let n14b : u32 = ccl_reduce(ccl_comp(ap, ccl_pair(ccl_cur(ccl_comp(s, ccl_pair(ccl_comp(f, f), s))), s))) /* dcur form */
    if ccl_struct_eq(n14a, n14b) != 1u8 { return 14u64 }

    /* CP15  ass / dcur :  (Cur(App) o Fst) o Snd   (II-CCL-3: a real overlap the
     *  original 14 omitted -- the left arg of an outer `ass` is itself a `dcur` redex). */
    let n15a : u32 = ccl_reduce(ccl_comp(ccl_cur(ap), ccl_comp(f, s)))                                  /* outer ass first -> Cur(App) o (Fst o Snd) */
    let n15b : u32 = ccl_reduce(ccl_comp(ccl_cur(ccl_comp(ap, ccl_pair(ccl_comp(f, f), s))), s))        /* inner dcur first -> Cur(App o <Fst o Fst,Snd>) o Snd */
    if ccl_struct_eq(n15a, n15b) != 1u8 { return 15u64 }

    /* CP16  beta / idr-then-bare :  App o <Cur(Snd) o Id, Fst>   (the inner `Cur(x) o Id`
     *  is both part of a `beta` redex and an `idr` redex; contracting idr turns it into a
     *  `bare` redex -- both routes must join.  Another overlap absent from the original 14). */
    let n16a : u32 = ccl_reduce(ccl_comp(s, ccl_pair(id, f)))                                           /* beta first -> Snd o <Id, Fst> -> Fst */
    let n16b : u32 = ccl_reduce(ccl_comp(ap, ccl_pair(ccl_cur(s), f)))                                  /* idr first -> App o <Cur(Snd), Fst> -> bare -> Fst */
    if ccl_struct_eq(n16a, n16b) != 1u8 { return 16u64 }

    return 99u64
}

/* SEPARATE-2 / II-CCL-3 (deferral eliminated): confluence is now a THEOREM, not a sample.
 * PRIMARY = the machine-enumerated critical-pair set over the rule TABLE (every rule-rule
 * overlap, generated -- so adding/changing a rule auto-generates its pairs); SECONDARY = the
 * original CP1..CP16 retained as a regression cross-check.  Both must report all-join.
 * 99 = confluent; an enumerator code (1xx/2xx/3xx) or 1000+N (a CP16 regression) on failure. */
fn ccl_conf_cert() -> u64 @export {
    let enr : u64 = ccl_critpair_enum(0u32)
    if enr != 99u64 { return enr }
    let leg : u64 = ccl_conf_cert_cp16()
    if leg != 99u64 { return 1000u64 + leg }
    return 99u64
}
