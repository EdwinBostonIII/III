/* STDLIB/iii/numera/charter_terminal.iii -- the Constitution's TERMINAL GATE: the global
 * run_charter that folds all thirteen Harmony-Invariant clauses into one green/red light.
 *
 * Capability 1 (III-APOTHEOSIS "What III becomes able to do"): "Refuse to ship or run an
 * incoherent self.  The Constitution (M10) is the build's terminal gate; nothing goes green
 * unless every guarantee holds AND its falsifier still catches its broken case AND the seal
 * is stable."  This module IS that gate.  It is also the runtime half of capability 12 ("be
 * one language ... trust collapses to a single green/red light anyone can run, audit, and
 * re-seal"): one call, one verdict, over the whole enmeshment contract.
 *
 * The thirteen Harmony Invariants (H1..H13) are each already a self-falsifying constitutional
 * clause carrying a PAIRED verify-AND-falsify predicate plus a canary that proves its own
 * run_charter goes RED (h{1..13}_charter.iii, corpus 674/688..699).  This module unions them:
 * it registers the thirteen as clauses whose HOLDS is the FULL per-invariant proof --
 * h{N}_selftest() == 99 means H_N's verify held on its good witness, its falsifier caught its
 * bad witness, its canary drove run_charter RED, and its sealed verdict reproduced.  The
 * terminal gate is GREEN iff ALL thirteen pass; else it returns the 1-based index of the
 * first failing clause -- and because the clauses are registered H1,H2,...,H13 in order, that
 * index IS the failing invariant's number (a RED 7 == H7 broke).  This is the
 * union-of-all-module-falsifiers the apotheosis names (M10 / H7 D1): the constitution does
 * not re-prove the invariants, it FOLDS their own falsifiers.
 *
 * The two facets, mirroring the generic h2_charter mechanism one level up:
 *   verify  -- every Harmony Invariant HOLDS: h{1..13}_selftest() each == 99.  Each selftest
 *              is self-contained (it resets its own module-scope registry), so the thirteen
 *              run independently with no cross-contamination; the terminal gate is the only
 *              place all thirteen are demanded at once.  GREEN means the whole contract holds.
 *   falsify -- the gate is a REAL terminal falsifier, not vacuously green: a canary clause
 *              that CLAIMS H1 is broken (h1_selftest() != 99 -- FALSE, it returns 99) does
 *              NOT hold, and registering it drives the fold RED at its 1-based index.  If the
 *              gate ignored a non-holding clause it would stay green; the canary CATCHES that.
 *
 * On GREEN the gate content-addresses its OWN verdict via cad over (count || clause-ids) --
 * dogfooding the one name (H2), routing to the one .iii sha256 (H13), and giving the
 * constitution a stable, reproducible seal (the "seal is stable" of capability 1).
 *
 * The STRUCTURAL companion of capability 1 is the build itself: build_stdlib's FAIL=0 over
 * every module + the DRIFT-gated reseal (golden BARE mhash, ADR-027) is the compile-time
 * terminal gate; this module is its RUNTIME embodiment -- one verdict over the live contract.
 *
 * Hexad: kind_essence.  Ring: R-1 (the constitutional ceremony, above all clauses).  K: 1.00.
 * NIH: cad.iii + the thirteen h{N}_charter.iii only.  No ML, no float, no u64 division.
 * Discipline: W2/W8/W14/W15; single-line fns; ==/!= compares; byte-stores; masked idx.
 */
module numera_charter_terminal

extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_eq(a: *u8, b: *u8) -> u8 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_is_zero(a: *u8) -> u8 from "cad.iii"
extern @abi(c-msvc-x64) fn h1_selftest()  -> u64 from "h1_charter.iii"
extern @abi(c-msvc-x64) fn h2_selftest()  -> u64 from "h2_charter.iii"
extern @abi(c-msvc-x64) fn h3_selftest()  -> u64 from "h3_charter.iii"
extern @abi(c-msvc-x64) fn h4_selftest()  -> u64 from "h4_charter.iii"
extern @abi(c-msvc-x64) fn h5_selftest()  -> u64 from "h5_charter.iii"
extern @abi(c-msvc-x64) fn h6_selftest()  -> u64 from "h6_charter.iii"
extern @abi(c-msvc-x64) fn h7_selftest()  -> u64 from "h7_charter.iii"
extern @abi(c-msvc-x64) fn h8_selftest()  -> u64 from "h8_charter.iii"
extern @abi(c-msvc-x64) fn h9_selftest()  -> u64 from "h9_charter.iii"
extern @abi(c-msvc-x64) fn h10_selftest() -> u64 from "h10_charter.iii"
extern @abi(c-msvc-x64) fn h11_selftest() -> u64 from "h11_charter.iii"
extern @abi(c-msvc-x64) fn h12_selftest() -> u64 from "h12_charter.iii"
extern @abi(c-msvc-x64) fn h13_selftest() -> u64 from "h13_charter.iii"

const CT_OK             : i32 =  0i32
const CT_SUITE_SHA256   : u32 = 0u32     /* cad default; ties the seal to the one .iii sha256 (H13) */
const CT_MAX_CLAUSES    : u32 = 64u32
const CT_PASS           : u64 = 99u64    /* the value every h{N}_selftest returns on pass */
const CT_INVARIANTS     : u32 = 13u32    /* H1..H13 */
const CT_KIND_H1        : u8  = 0u8      /* kind == 0-based invariant index; slot i == kind i == H(i+1) */
const CT_KIND_H2        : u8  = 1u8
const CT_KIND_H3        : u8  = 2u8
const CT_KIND_H4        : u8  = 3u8
const CT_KIND_H5        : u8  = 4u8
const CT_KIND_H6        : u8  = 5u8
const CT_KIND_H7        : u8  = 6u8
const CT_KIND_H8        : u8  = 7u8
const CT_KIND_H9        : u8  = 8u8
const CT_KIND_H10       : u8  = 9u8
const CT_KIND_H11       : u8  = 10u8
const CT_KIND_H12       : u8  = 11u8
const CT_KIND_H13       : u8  = 12u8
const CT_KIND_CANARY    : u8  = 13u8     /* a deliberately-false clause (negative arm only) */
const CT_VERDICT_GREEN  : u64 = 99u64    /* > CT_MAX_CLAUSES, so never a RED index */
const CT_U32MASK        : u64 = 0xFFFFFFFFu64

/* --- clause registry (W8-bounded; kind-tag dispatch, never a fn pointer) --- */
var CT_CLAUSE_KIND  : [u8;  64]
var CT_CLAUSE_ID    : [u8;  2048]   /* 64 * 32-byte clause content-addresses */
var CT_CLAUSE_COUNT : u32 = 0u32

/* --- scratch (module-scope, Trap 7; serialized R-1 use) --- */
var CT_KINDBUF  : [u8; 1]      /* 1-byte clause-text (the kind) for clause_id */
var CT_SAVED    : [u8; 32]     /* selftest: saved green verdict for the re-run compare */
var CT_VERDICT  : [u8; 32]     /* the sealed terminal verdict */
var CT_SEAL_BUF : [u8; 2080]   /* count(4) || clause ids, for the verdict seal */

/* Reset the registry. */
fn ct_init() -> i32 @export {
    CT_CLAUSE_COUNT = 0u32
    return CT_OK
}

/* 1u8 iff a self-test returned the pass sentinel (99); 0u8 otherwise. */
fn ct_pass(code: u64) -> u8 {
    if code == CT_PASS { return 1u8 }
    return 0u8
}

/* Invariant H(k+1) HOLDS iff its full self-test passes (h{k+1}_selftest() == 99).
 * Monomorphic kind-tag dispatch -- one call per Harmony Invariant, never a fn pointer. */
fn ct_invariant_holds(k: u8) -> u8 {
    if k == CT_KIND_H1  { return ct_pass(h1_selftest())  }
    if k == CT_KIND_H2  { return ct_pass(h2_selftest())  }
    if k == CT_KIND_H3  { return ct_pass(h3_selftest())  }
    if k == CT_KIND_H4  { return ct_pass(h4_selftest())  }
    if k == CT_KIND_H5  { return ct_pass(h5_selftest())  }
    if k == CT_KIND_H6  { return ct_pass(h6_selftest())  }
    if k == CT_KIND_H7  { return ct_pass(h7_selftest())  }
    if k == CT_KIND_H8  { return ct_pass(h8_selftest())  }
    if k == CT_KIND_H9  { return ct_pass(h9_selftest())  }
    if k == CT_KIND_H10 { return ct_pass(h10_selftest()) }
    if k == CT_KIND_H11 { return ct_pass(h11_selftest()) }
    if k == CT_KIND_H12 { return ct_pass(h12_selftest()) }
    if k == CT_KIND_H13 { return ct_pass(h13_selftest()) }
    return 0u8
}

/* The canary's holds: it CLAIMS H1 is broken (h1_selftest() != 99) -- FALSE (it returns 99).
 * A genuinely-false clause used ONLY to prove the terminal fold goes RED on a non-holding
 * clause: if the gate ignored a broken invariant it would stay green; this catches that. */
fn ct_canary_holds() -> u8 {
    if h1_selftest() != CT_PASS { return 1u8 }
    return 0u8
}

/* Evaluate one registered clause -> 1 holds / 0 fails.  Kind-tag dispatch (never a fn ptr). */
fn ct_clause_eval(idx: u32) -> u8 {
    let k : u8 = CT_CLAUSE_KIND[(idx as u64) & CT_U32MASK]
    if k == CT_KIND_CANARY { return ct_canary_holds() }
    return ct_invariant_holds(k)
}

/* Register a clause of kind k; clause_id = cad(SHA256, kind-byte) (content-addressed,
 * dogfooding the one name).  Returns the 0-based slot, or -1 if the registry is full. */
fn ct_register(k: u8) -> i32 {
    let n : u32 = CT_CLAUSE_COUNT
    if n >= CT_MAX_CLAUSES { return -1i32 }
    let slot : u64 = (n as u64) & CT_U32MASK
    CT_CLAUSE_KIND[slot] = k
    CT_KINDBUF[0u64] = k
    cad_oneshot(CT_SUITE_SHA256, (&CT_KINDBUF as u64) as *u8, 1u64, ((&CT_CLAUSE_ID as u64) + slot * 32u64) as *u8)
    CT_CLAUSE_COUNT = n + 1u32
    return slot as i32
}

/* Seal the GREEN verdict: CT_VERDICT = cad(SHA256, count(LE4) || clause_ids[0..n*32]). */
fn ct_seal_verdict(n: u32) -> i32 {
    let n64 : u64 = (n as u64) & CT_U32MASK
    CT_SEAL_BUF[0u64] = (n & 0xFFu32) as u8
    CT_SEAL_BUF[1u64] = ((n >> 8u32)  & 0xFFu32) as u8
    CT_SEAL_BUF[2u64] = ((n >> 16u32) & 0xFFu32) as u8
    CT_SEAL_BUF[3u64] = ((n >> 24u32) & 0xFFu32) as u8
    let total : u64 = n64 * 32u64
    let mut b : u64 = 0u64
    while b < total {
        CT_SEAL_BUF[4u64 + b] = CT_CLAUSE_ID[b]
        b = b + 1u64
    }
    cad_oneshot(CT_SUITE_SHA256, (&CT_SEAL_BUF as u64) as *u8, 4u64 + total, (&CT_VERDICT as u64) as *u8)
    return CT_OK
}

/* THE TERMINAL GATE.  Fold every registered clause: GREEN (99) iff all hold; else the
 * 1-based index of the first failing clause (RED) -- which, for the thirteen registered in
 * order, IS the failing Harmony Invariant's number.  GREEN seals the verdict (dogfoods the
 * one name -> the one .iii sha256). */
fn ct_run_charter() -> u64 @export {
    let n : u32 = CT_CLAUSE_COUNT
    let mut i : u32 = 0u32
    while i < n {
        if ct_clause_eval(i) != 1u8 { return ((i as u64) & CT_U32MASK) + 1u64 }
        i = i + 1u32
    }
    ct_seal_verdict(n)
    return CT_VERDICT_GREEN
}

/* Register all thirteen Harmony-Invariant clauses (H1..H13) at slots 0..12.  Returns the
 * count registered, or -1 if any registration failed (registry full / out of order). */
fn ct_register_all() -> i32 {
    ct_init()
    let mut k : u32 = 0u32
    while k < CT_INVARIANTS {
        if ct_register(k as u8) != (k as i32) { return -1i32 }
        k = k + 1u32
    }
    return CT_INVARIANTS as i32
}

/* Copy the last sealed terminal verdict into out[0..32). -1 on null. */
fn ct_verdict(out: *u8) -> i32 @export {
    if (out as u64) == 0u64 { return -1i32 }
    let mut z : u64 = 0u64
    while z < 32u64 { out[z] = CT_VERDICT[z]  z = z + 1u64 }
    return CT_OK
}

/* KAT: 99 = all pass; a distinct code at each failed check (diagnosable).
 * Proves, in order: each of the thirteen Harmony Invariants holds -- code N == H_N's own
 * self-test failed (1..13); the canary is genuinely false (14); registering all thirteen
 * yields slots 0..12 (15); the terminal gate is GREEN over the whole contract (16); its
 * verdict is non-zero (17) and reproducible across a re-run (18,19); and -- the
 * prove-the-negative arm -- registering the canary drives the gate RED, returning the
 * canary's 1-based index (=14), proving the terminal fold is a real falsifier (20,21). */
fn ct_selftest() -> u64 @export {
    ct_init()
    if ct_invariant_holds(CT_KIND_H1)  != 1u8 { return 1u64 }
    if ct_invariant_holds(CT_KIND_H2)  != 1u8 { return 2u64 }
    if ct_invariant_holds(CT_KIND_H3)  != 1u8 { return 3u64 }
    if ct_invariant_holds(CT_KIND_H4)  != 1u8 { return 4u64 }
    if ct_invariant_holds(CT_KIND_H5)  != 1u8 { return 5u64 }
    if ct_invariant_holds(CT_KIND_H6)  != 1u8 { return 6u64 }
    if ct_invariant_holds(CT_KIND_H7)  != 1u8 { return 7u64 }
    if ct_invariant_holds(CT_KIND_H8)  != 1u8 { return 8u64 }
    if ct_invariant_holds(CT_KIND_H9)  != 1u8 { return 9u64 }
    if ct_invariant_holds(CT_KIND_H10) != 1u8 { return 10u64 }
    if ct_invariant_holds(CT_KIND_H11) != 1u8 { return 11u64 }
    if ct_invariant_holds(CT_KIND_H12) != 1u8 { return 12u64 }
    if ct_invariant_holds(CT_KIND_H13) != 1u8 { return 13u64 }
    if ct_canary_holds() != 0u8 { return 14u64 }
    if ct_register_all() != 13i32 { return 15u64 }
    if ct_run_charter() != CT_VERDICT_GREEN { return 16u64 }
    if cad_is_zero((&CT_VERDICT as u64) as *u8) != 0u8 { return 17u64 }
    let mut s : u64 = 0u64
    while s < 32u64 { CT_SAVED[s] = CT_VERDICT[s]  s = s + 1u64 }
    if ct_run_charter() != CT_VERDICT_GREEN { return 18u64 }
    if cad_eq((&CT_VERDICT as u64) as *u8, (&CT_SAVED as u64) as *u8) != 1u8 { return 19u64 }
    if ct_register(CT_KIND_CANARY) != 13i32 { return 20u64 }
    if ct_run_charter() != 14u64 { return 21u64 }
    return 99u64
}

/* charter_terminal EMBODIES capability 1: the Constitution's terminal gate.  It folds the
 * thirteen Harmony-Invariant falsifiers into one verdict -- GREEN (with a stable, reproducible
 * cad-sealed witness) iff every guarantee holds AND every falsifier still catches its broken
 * case; RED at the failing invariant's own number otherwise.  One call, one green/red light
 * over the whole enmeshment contract -- the runtime "refuse to ship an incoherent self," and
 * the single light a stranger runs to trust III (capability 12). */
