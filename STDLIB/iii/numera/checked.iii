/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\checked.iii
 *
 * III STDLIB - numera::checked
 *
 * Overflow-checked arithmetic.  Returns option_u32 / option_u64
 * encoding (low bit = some/none, payload shifted up).  Built atop
 * scalar's did_overflow predicates so the wrapping arithmetic is
 * shared - this module is purely a thin discriminated wrapper.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00 (pure).
 */

module numera_checked

extern @abi(c-msvc-x64) fn scalar_u32_add_did_overflow(a: u32, b: u32) -> u8 from "scalar.iii"
extern @abi(c-msvc-x64) fn scalar_u32_sub_did_underflow(a: u32, b: u32) -> u8 from "scalar.iii"
extern @abi(c-msvc-x64) fn scalar_u32_mul_did_overflow(a: u32, b: u32) -> u8 from "scalar.iii"
extern @abi(c-msvc-x64) fn scalar_u64_add_did_overflow(a: u64, b: u64) -> u8 from "scalar.iii"
extern @abi(c-msvc-x64) fn scalar_u64_sub_did_underflow(a: u64, b: u64) -> u8 from "scalar.iii"
extern @abi(c-msvc-x64) fn scalar_u64_mul_did_overflow(a: u64, b: u64) -> u8 from "scalar.iii"
extern @abi(c-msvc-x64) fn option_u64_some(v: u64) -> u64 from "option.iii"
extern @abi(c-msvc-x64) fn option_u64_unwrap_or(o: u64, default: u64) -> u64 from "option.iii"
extern @abi(c-msvc-x64) fn option_u64_drop(o: u64) -> u8 from "option.iii"

/* --- u32 checked: returns option_u32 encoding --- */

fn checked_u32_add(a: u32, b: u32) -> u64 @provenance_linked_error @export {
    if scalar_u32_add_did_overflow(a, b) == 1u8 { return 0u64 }
    let r : u32 = (a + b) & 0xFFFFFFFFu32
    return ((r as u64) << 1u64) | 1u64
}

fn checked_u32_sub(a: u32, b: u32) -> u64 @provenance_linked_error @export {
    if scalar_u32_sub_did_underflow(a, b) == 1u8 { return 0u64 }
    let r : u32 = (a - b) & 0xFFFFFFFFu32
    return ((r as u64) << 1u64) | 1u64
}

fn checked_u32_mul(a: u32, b: u32) -> u64 @provenance_linked_error @export {
    if scalar_u32_mul_did_overflow(a, b) == 1u8 { return 0u64 }
    let r : u32 = (a * b) & 0xFFFFFFFFu32
    return ((r as u64) << 1u64) | 1u64
}

fn checked_u32_div(a: u32, b: u32) -> u64 @provenance_linked_error @export {
    if b == 0u32 { return 0u64 }
    let r : u32 = a / b
    return ((r as u64) << 1u64) | 1u64
}

/* --- u64 checked: returns an option_u64 handle (0 = none).
 * [W3.22/COMBINE-8/D-CHK-2] ONE TABLE: the former private 64-slot CHK_U64 side
 * table duplicated omnia/option.iii's OPT_U64 table with identical handle
 * encoding ((slot+1), 0 = none) and identical guard semantics.  checked u64
 * handles now ARE option_u64 handles -- interchangeable across both APIs
 * (corpus 1480 pins the unity in both directions).  Contract preserved:
 * checked returns 0 on ANY failure, so option's table-full sentinel
 * (0xFFFFFFFFFFFFFFFF, distinct-from-none by design there) maps to 0 here.
 * Capacity rises 64 -> 256 (the shared table). --- */

fn checked_u64_wrap(v: u64) -> u64 {
    let h : u64 = option_u64_some(v)
    if h == 0xFFFFFFFFFFFFFFFFu64 { return 0u64 }   /* table full -> checked's 0 */
    return h
}

fn checked_u64_add(a: u64, b: u64) -> u64 @provenance_linked_error @export {
    if scalar_u64_add_did_overflow(a, b) == 1u8 { return 0u64 }
    return checked_u64_wrap(a + b)
}

fn checked_u64_sub(a: u64, b: u64) -> u64 @provenance_linked_error @export {
    if scalar_u64_sub_did_underflow(a, b) == 1u8 { return 0u64 }
    return checked_u64_wrap(a - b)
}

fn checked_u64_mul(a: u64, b: u64) -> u64 @provenance_linked_error @export {
    if scalar_u64_mul_did_overflow(a, b) == 1u8 { return 0u64 }
    return checked_u64_wrap(a * b)
}

fn checked_u64_div(a: u64, b: u64) -> u64 @provenance_linked_error @export {
    if b == 0u64 { return 0u64 }
    return checked_u64_wrap(a / b)
}

fn checked_u64_unwrap_or(handle: u64, default: u64) -> u64 @export {
    return option_u64_unwrap_or(handle, default)
}

fn checked_u64_drop(handle: u64) -> u8 @export {
    return option_u64_drop(handle)
}
