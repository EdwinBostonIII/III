/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\coin_change.iii
 *
 * III STDLIB - numera::coin_change  --  MINIMUM-COIN CHANGE, VERIFIED AGAINST BRUTE FORCE.
 *
 * The fewest coins of given denominations that sum to a target amount.  Unlike the 0/1 knapsack, each coin is
 * reusable, so the DP sweeps the amount UPWARD: dp[a] = 1 + min over coins c<=a of dp[a-c], and the upward
 * direction is exactly what lets dp[a-c] already contain coin c (reuse) -- the mirror image of knapsack's
 * downward sweep.  That contrast IS the bounded-vs-unbounded distinction, so it is worth getting exactly
 * right; the III discipline VERIFIES the DP against an exhaustive brute force (enumerate every count of each
 * coin) for EVERY amount.
 *
 * Coins [1,3,4]; amount 6 needs 2 coins (3+3), amount 7 needs 2 (3+4), amount 11 needs 3 (4+4+3).
 *
 * Verified (coin_change_kat): the DP minimum for several amounts equals the known value AND the brute-force
 * reference; the DP equals brute force at every amount 0..20 (the parameterized equivalence).  NIH/self-contained.
 *
 * Public API:
 *   coin_min2(a,b) -> u32 ; coin_dp(amt) -> u32 ; coin_brute(amt) -> u32 ; coin_agree() -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_coin_change

const COIN_BIG : u32 = 1000u32

var COIN_DP : [u32; 21]            /* dp[0..20] */

fn coin_min2(a: u32, b: u32) -> u32 @export {
    if a < b { return a }
    return b
}

/* min coins to make `amt` with denominations {1,3,4}; amount swept upward (coins reusable). */
fn coin_dp(amt: u32) -> u32 @export {
    COIN_DP[0u64] = 0u32
    let mut a : u32 = 1u32
    while a <= amt {
        COIN_DP[a as u64] = COIN_BIG
        a = a + 1u32
    }
    a = 1u32
    while a <= amt {
        if 1u32 <= a { COIN_DP[a as u64] = coin_min2(COIN_DP[a as u64], COIN_DP[(a - 1u32) as u64] + 1u32) }
        if 3u32 <= a { COIN_DP[a as u64] = coin_min2(COIN_DP[a as u64], COIN_DP[(a - 3u32) as u64] + 1u32) }
        if 4u32 <= a { COIN_DP[a as u64] = coin_min2(COIN_DP[a as u64], COIN_DP[(a - 4u32) as u64] + 1u32) }
        a = a + 1u32
    }
    return COIN_DP[amt as u64]
}

/* the exhaustive reference: enumerate every count of 4s and 3s, the rest as 1s; minimum total coins. */
fn coin_brute(amt: u32) -> u32 @export {
    let mut best : u32 = COIN_BIG
    let mut c2 : u32 = 0u32
    while (4u32 * c2) <= amt {
        let mut c1 : u32 = 0u32
        while ((4u32 * c2) + (3u32 * c1)) <= amt {
            let c0 : u32 = (amt - (4u32 * c2)) - (3u32 * c1)
            let total : u32 = (c0 + c1) + c2
            if total < best { best = total }
            c1 = c1 + 1u32
        }
        c2 = c2 + 1u32
    }
    return best
}

/* the DP equals brute force at every amount 0..20. */
fn coin_agree() -> u32 @export {
    let mut amt : u32 = 0u32
    while amt <= 20u32 {
        if coin_dp(amt) != coin_brute(amt) { return 0u32 }
        amt = amt + 1u32
    }
    return 1u32
}

/* =====================================================================================
 * coin_change_kat -- 99 = minimum-coin change is correct, verified against brute force:
 *   (1) amount 6 -> 2 coins, amount 7 -> 2, amount 11 -> 3 (DP and brute agree);
 *   (2) amount 0 -> 0;
 *   (3) the DP equals brute force at every amount 0..20 (the parameterized equivalence);
 *   (4) min2 is correct.
 * ===================================================================================== */
fn coin_change_kat() -> u64 @export {
    /* (1) known amounts */
    if coin_dp(6u32) != 2u32 { return 1u64 }
    if coin_brute(6u32) != 2u32 { return 2u64 }
    if coin_dp(7u32) != 2u32 { return 3u64 }
    if coin_dp(11u32) != 3u32 { return 4u64 }
    if coin_brute(11u32) != 3u32 { return 5u64 }

    /* (2) zero */
    if coin_dp(0u32) != 0u32 { return 6u64 }

    /* (3) the parameterized equivalence */
    if coin_agree() != 1u32 { return 7u64 }

    /* (4) min2 */
    if coin_min2(5u32, 2u32) != 2u32 { return 8u64 }
    if coin_min2(3u32, 8u32) != 3u32 { return 9u64 }

    return 99u64
}
