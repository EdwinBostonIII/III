/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\collatz.iii
 *
 * III STDLIB - numera::collatz  --  THE 3n+1 (COLLATZ) CONJECTURE, EMPIRICALLY VERIFIED.
 *
 * The Collatz conjecture (1937, still open) says that iterating n -> n/2 (n even) or n -> 3n+1 (n odd) from
 * any positive integer eventually reaches 1.  No proof exists, but the trajectory of any single n is finite
 * and checkable.  This module computes stopping times and trajectory peaks, and verifies that EVERY starting
 * value up to 100 reaches 1.  The parity test uses a bit-AND and the halving a shift, so no modulo or division
 * is involved (also sidestepping the `.iii` division-after-call trap).
 *
 * Famous data points: the trajectory of 27 takes 111 steps and peaks at 9232.
 *
 * Verified (collatz_kat): stopping times are exact (1->0, 6->8, 7->16, 27->111); the peak of 27 is 9232;
 * every starting value 1..100 reaches 1; the single-step rule is correct on an even and an odd value.
 * NIH/self-contained.
 *
 * Public API:
 *   collatz_step(n) -> u32 ; collatz_steps(n) -> u32 ; collatz_max(n) -> u32 ; collatz_all_reach_one(limit) -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_collatz

const COLLATZ_DIVERGE : u32 = 0xFFFFFFFFu32     /* sentinel: did not converge within the guard */

/* one Collatz step: halve if even, else 3n+1. */
fn collatz_step(n: u32) -> u32 @export {
    if (n & 1u32) == 0u32 { return n >> 1u32 }
    return (3u32 * n) + 1u32
}

/* the stopping time: number of steps to reach 1 (DIVERGE if it somehow does not within the guard). */
fn collatz_steps(n: u32) -> u32 @export {
    let mut x : u32 = n
    let mut s : u32 = 0u32
    let mut guard : u32 = 0u32
    while x != 1u32 {
        x = collatz_step(x)
        s = s + 1u32
        guard = guard + 1u32
        if guard > 1000u32 { return COLLATZ_DIVERGE }
    }
    return s
}

/* the maximum value the trajectory of n reaches. */
fn collatz_max(n: u32) -> u32 @export {
    let mut x : u32 = n
    let mut peak : u32 = n
    let mut guard : u32 = 0u32
    while x != 1u32 {
        x = collatz_step(x)
        if x > peak { peak = x }
        guard = guard + 1u32
        if guard > 1000u32 { return COLLATZ_DIVERGE }
    }
    return peak
}

/* does every starting value 1..limit reach 1? */
fn collatz_all_reach_one(limit: u32) -> u32 @export {
    let mut n : u32 = 1u32
    while n <= limit {
        if collatz_steps(n) == COLLATZ_DIVERGE { return 0u32 }
        n = n + 1u32
    }
    return 1u32
}

/* =====================================================================================
 * collatz_kat -- 99 = the Collatz conjecture is verified up to 100:
 *   (1) exact stopping times: 1->0, 6->8, 7->16, 27->111;
 *   (2) the trajectory of 27 peaks at 9232;
 *   (3) every starting value 1..100 reaches 1;
 *   (4) the single-step rule: 8 -> 4 (even), 7 -> 22 (odd).
 * ===================================================================================== */
fn collatz_kat() -> u64 @export {
    /* (1) stopping times */
    if collatz_steps(1u32) != 0u32 { return 1u64 }
    if collatz_steps(6u32) != 8u32 { return 2u64 }
    if collatz_steps(7u32) != 16u32 { return 3u64 }
    if collatz_steps(27u32) != 111u32 { return 4u64 }

    /* (2) the famous peak */
    if collatz_max(27u32) != 9232u32 { return 5u64 }

    /* (3) universal convergence up to 100 */
    if collatz_all_reach_one(100u32) != 1u32 { return 6u64 }

    /* (4) the step rule */
    if collatz_step(8u32) != 4u32 { return 7u64 }
    if collatz_step(7u32) != 22u32 { return 8u64 }
    if collatz_step(1u32) != 4u32 { return 9u64 }       /* 1 is odd -> 3*1+1 = 4 */

    return 99u64
}
