/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\con_lattice.iii
 *
 * III STDLIB - numera::con_lattice
 *
 * CONGRUENCE LATTICE OF A FINITE ALGEBRA (one binary operation).
 *
 * ROLE.  Given a finite algebra A = ({0..n-1}, *) with one binary operation, compute its CONGRUENCE LATTICE Con(A):
 * the equivalence relations on A compatible with * (a~a' & b~b' => a*b ~ a'*b'), ordered by refinement.  This is the
 * decidable, finite side of the Finite Lattice Representation Problem (FLRP) -- the open question whether EVERY finite
 * lattice is some Con(finite algebra) (DOCS/III-LATTICE-WALL-FORMAL.md).  The island fact this faculty makes runnable:
 * the Klein four-group's congruence lattice is M3, a NON-distributive lattice (corpus 1873) -- a non-distributive
 * lattice realised as Con of a finite algebra.
 *
 * USE CASES.  Inspect the quotient structure of any finite algebra in III (a group/monoid/semigroup operation table):
 * how many quotients exist, whether the quotient lattice is distributive (a structural invariant), what the simple
 * (2-element-Con) algebras are.  Covers groups, monoids, semigroups -- any single-binary-operation structure.
 *
 * INVOCATION.  cl_reset(n) -> cl_op(a, b, r) to fill the operation table (a*b = r) -> cl_num_congruences() (the size of
 * Con(A)) and cl_is_distributive() (1 if Con(A) is a distributive lattice, 0 otherwise).
 *
 * IMPACTS / LIMITATIONS (honest).
 *   - EXACT for algebras of up to CL_MAX = 6 elements (Con enumeration is over all set partitions; the same-block
 *     relation packs n*n <= 36 bits into a u64).  A documented bound -- Bell(6)=203 partitions, fully enumerated.
 *   - One binary operation only (the common case).  Multi-operation / higher-arity algebras need a richer table (v2).
 *   - General FLRP (every finite lattice = some Con(finite A)?) is OPEN; this computes Con for a GIVEN algebra, the
 *     decidable direction.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 * Discipline: W1, W2, W13, W14, W15 (no recursion).
 * Self-test: cl_kat() -> u64 returns 99 on full KAT pass.
 */
module con_lattice

const CL_MAX : u32 = 6u32

var CL_OP : [u32; 36]    /* operation table: a*b = CL_OP[a*n + b] */
var CL_N : [u32; 1]
var CL_CON : [u64; 64]   /* congruences as same-block relations (n*n bits) */
var CL_NCON : [u32; 1]
var CL_BLOCK : [u32; 8]  /* working block-id assignment (module-level: indexed by a runtime var) */

fn cl_op_at(a: u32, b: u32) -> u32 { return CL_OP[(a * CL_N[0u64] + b) as u64] }
fn cl_sb(rel: u64, i: u32, j: u32) -> u64 { let n : u32 = CL_N[0u64]  return (rel >> ((i * n + j) as u64)) & 1u64 }

fn cl_reset(n: u32) -> i32 @export {
    if n > CL_MAX { return 0i32 - 1i32 }            /* [OOB] @export: n caps CL_OP[36] / packing */
    if n == 0u32 { return 0i32 - 1i32 }
    CL_N[0u64] = n  CL_NCON[0u64] = 0u32
    let mut i : u32 = 0u32  while i < n * n { CL_OP[i as u64] = 0u32  i = i + 1u32 }
    return 0i32
}
fn cl_op(a: u32, b: u32, r: u32) -> i32 @export {
    let n : u32 = CL_N[0u64]
    if a >= n { return 0i32 - 1i32 }                /* [OOB] @export: a,b index CL_OP[n*n]; r is an element < n */
    if b >= n { return 0i32 - 1i32 }
    if r >= n { return 0i32 - 1i32 }
    CL_OP[(a * n + b) as u64] = r
    return 0i32
}
fn cl_build_sb() -> u64 {        /* same-block relation from CL_BLOCK[] */
    let n : u32 = CL_N[0u64]  let mut sb : u64 = 0u64  let mut i : u32 = 0u32
    while i < n { let mut j : u32 = 0u32  while j < n { if CL_BLOCK[i as u64] == CL_BLOCK[j as u64] { sb = sb | (1u64 << ((i * n + j) as u64)) }  j = j + 1u32 }  i = i + 1u32 }
    return sb
}
fn cl_is_congruence(sb: u64) -> u8 {     /* compatible with *: a~a' => a*b ~ a'*b and b*a ~ b*a' (one-sided suffices) */
    let n : u32 = CL_N[0u64]  let mut a : u32 = 0u32
    while a < n { let mut a2 : u32 = 0u32
        while a2 < n { if cl_sb(sb, a, a2) == 1u64 { let mut b : u32 = 0u32
            while b < n {
                if cl_sb(sb, cl_op_at(a, b), cl_op_at(a2, b)) == 0u64 { return 0u8 }
                if cl_sb(sb, cl_op_at(b, a), cl_op_at(b, a2)) == 0u64 { return 0u8 }
                b = b + 1u32
            }
        }  a2 = a2 + 1u32 }
        a = a + 1u32 }
    return 1u8
}
fn cl_collect() -> i32 {     /* enumerate all set partitions (base-n block codes), keep distinct congruences */
    let n : u32 = CL_N[0u64]  CL_NCON[0u64] = 0u32
    let mut lim : u32 = 1u32  let mut e : u32 = 0u32  while e < n { lim = lim * n  e = e + 1u32 }   /* n^n */
    let mut code : u32 = 0u32
    while code < lim {
        let mut c : u32 = code  let mut i : u32 = 0u32
        while i < n { CL_BLOCK[i as u64] = c % n  c = c / n  i = i + 1u32 }
        let sb : u64 = cl_build_sb()
        if cl_is_congruence(sb) == 1u8 {
            let mut seen : u8 = 0u8  let mut k : u32 = 0u32
            while k < CL_NCON[0u64] { if CL_CON[k as u64] == sb { seen = 1u8  k = CL_NCON[0u64] } else { k = k + 1u32 } }
            if seen == 0u8 { if CL_NCON[0u64] < 64u32 { CL_CON[CL_NCON[0u64]] = sb  CL_NCON[0u64] = CL_NCON[0u64] + 1u32 } }
        }
        code = code + 1u32
    }
    return 0i32
}
fn cl_num_congruences() -> u32 @export { cl_collect()  return CL_NCON[0u64] }

/* lattice ops on same-block relations: meet = intersection, join = transitive closure of union */
fn cl_tc(rel: u64) -> u64 {
    let n : u32 = CL_N[0u64]  let mut r : u64 = rel  let mut done : u8 = 0u8
    while done == 0u8 {
        let mut nr : u64 = r  let mut i : u32 = 0u32
        while i < n { let mut k : u32 = 0u32
            while k < n { if cl_sb(r, i, k) == 1u64 { let mut j : u32 = 0u32
                while j < n { if cl_sb(r, k, j) == 1u64 { nr = nr | (1u64 << ((i * n + j) as u64)) }  j = j + 1u32 }
            }  k = k + 1u32 }
            i = i + 1u32 }
        if nr == r { done = 1u8 } else { r = nr }
    }
    return r
}
fn cl_is_distributive() -> u8 @export {     /* Con(A) distributive: x ^ (y v z) == (x^y) v (x^z) for all congruences */
    cl_collect()
    let nc : u32 = CL_NCON[0u64]  let mut a : u32 = 0u32
    while a < nc { let mut b : u32 = 0u32
        while b < nc { let mut c : u32 = 0u32
            while c < nc {
                let x : u64 = CL_CON[a as u64]  let y : u64 = CL_CON[b as u64]  let z : u64 = CL_CON[c as u64]
                let lhs : u64 = x & cl_tc(y | z)
                let rhs : u64 = cl_tc((x & y) | (x & z))
                if lhs != rhs { return 0u8 }
                c = c + 1u32
            }
            b = b + 1u32 }
        a = a + 1u32 }
    return 1u8
}

fn cl_kat() -> u64 @export {
    /* Klein four-group V4 = (Z2 x Z2, XOR): Con(V4) = M3 -> 5 congruences, NON-distributive (corpus 1873) */
    cl_reset(4u32)
    let mut a : u32 = 0u32
    while a < 4u32 { let mut b : u32 = 0u32  while b < 4u32 { cl_op(a, b, a ^ b)  b = b + 1u32 }  a = a + 1u32 }
    if cl_num_congruences() != 5u32 { return 10u64 }
    if cl_is_distributive() != 0u8 { return 11u64 }       /* M3 is non-distributive */
    /* Z3 = (Z/3, +): simple -> Con = {bottom, top} = 2-chain, distributive */
    cl_reset(3u32)
    let mut c : u32 = 0u32
    while c < 3u32 { let mut d : u32 = 0u32  while d < 3u32 { cl_op(c, d, (c + d) % 3u32)  d = d + 1u32 }  c = c + 1u32 }
    if cl_num_congruences() != 2u32 { return 12u64 }
    if cl_is_distributive() != 1u8 { return 13u64 }       /* a 2-chain is distributive */
    /* Z4 = (Z/4, +): congruences {bottom, the 2Z4 partition, top} = 3-chain, distributive */
    cl_reset(4u32)
    let mut e : u32 = 0u32
    while e < 4u32 { let mut f : u32 = 0u32  while f < 4u32 { cl_op(e, f, (e + f) % 4u32)  f = f + 1u32 }  e = e + 1u32 }
    if cl_num_congruences() != 3u32 { return 14u64 }
    if cl_is_distributive() != 1u8 { return 15u64 }       /* a 3-chain is distributive */
    return 99u64
}
