    cl_str(("FA_INV_WITNESS_CHAIN_CONTINUITY" as u64), 31u64, ("witness chain continuity across rings/modules" as u64), 45u64, ("C-17" as u64), 4u64, MT_NEVER)
    cl_str(("FA_INV_IRPD_ONLY_PRIV_WRITES" as u64), 28u64, ("IRPD-only privileged writes (no raw WRMSR/MOV CR3)" as u64), 50u64, ("C-16" as u64), 4u64, MT_NEVER)

    cl_sect(("§19" as u64), 4u64)
    cl_u(("CASCADE_RULE_COUNT" as u64), 18u64, 7u64, ("count" as u64), 5u64, ("§19 table" as u64), 10u64, MT_DERIVED)
    cl_str(("CASCADE_WITNESS_BYTE_SIZE" as u64), 25u64, ("R1.A5+R1.A8+R1.B1" as u64), 17u64, ("§19" as u64), 4u64, MT_AMEND)
    cl_str(("CASCADE_MOBIUS_FLOOR" as u64), 20u64, ("R1.A9+R1.B1+R1.B3" as u64), 17u64, ("§19" as u64), 4u64, MT_AMEND)
    cl_str(("CASCADE_MNEME_PROMOTION_RATE" as u64), 28u64, ("R1.B1" as u64), 5u64, ("§19" as u64), 4u64, MT_AMEND)
    cl_str(("CASCADE_CRYPTO_SUITE" as u64), 20u64, ("R1.A1..R1.IDX (full)" as u64), 20u64, ("§19" as u64), 4u64, MT_AMEND)
    cl_str(("CASCADE_SANCTUM_SLOT_COUNT" as u64), 26u64, ("R1.A8" as u64), 5u64, ("§19" as u64), 4u64, MT_AMEND)
    cl_str(("CASCADE_UNIVERSE_LADDER_DEPTH" as u64), 29u64, ("R1.A3+R1.B3 (R2-territory)" as u64), 26u64, ("§19" as u64), 4u64, MT_R2)
    cl_str(("CASCADE_HEXAD_PILLAR_COUNT" as u64), 26u64, ("R1.A6+R1.A3+R1.B3 (R2-territory)" as u64), 32u64, ("§19" as u64), 4u64, MT_R2)

    /* finalize: write magic + count into the reserved prefix */
    let m : *u8 = (&CL_BUF as u64) as *u8
    let mg : *u8 = ("III-CONSTANTS-D2" as u64) as *u8
    let mut k : u64 = 0u64
    while k < 16u64 { m[k] = mg[k]   k = k + 1u64 }
    m[16u64] = (CL_COUNT & 0xFFu32) as u8
    m[17u64] = ((CL_COUNT >> 8u32)  & 0xFFu32) as u8
    m[18u64] = ((CL_COUNT >> 16u32) & 0xFFu32) as u8
    m[19u64] = ((CL_COUNT >> 24u32) & 0xFFu32) as u8
    CL_BUILT = 1u8
}

/* === public API === */
fn constants_count() -> u32 @export { cl_build()   return CL_COUNT }

/* compute the R1.D2 ledger root into out[0..32). */
fn constants_ledger_root(out: *u8) -> i32 @export {
    if (out as u64) == 0u64 { return -1i32 }
    cl_build()
    sha256_oneshot((&CL_BUF as u64) as *u8, CL_POS, out)
    return 0i32
}

/* slot lookup (1-based) -> 1 if present (fills type/tier via accessors), 0 if out of range. */
fn constants_slot_type(slot: u32) -> u8 @export {
    cl_build()
    if slot == 0u32 { return 0u8 }
    if slot > CL_COUNT { return 0u8 }
    return CL_TYPE[((slot - 1u32) as u64) & 0xFFu64]
}
fn constants_slot_tier(slot: u32) -> u8 @export {
    cl_build()
    if slot == 0u32 { return 0u8 }
    if slot > CL_COUNT { return 0u8 }
    return CL_TIER[((slot - 1u32) as u64) & 0xFFu64]
}

/* linear lookup by name -> 1-based slot, or 0 if not found. */
fn constants_lookup(name: *u8, nlen: u64) -> u32 @export {
    cl_build()
    let np : *u8 = (&CL_NPOOL as u64) as *u8
    let q : *u8 = name as *u8
    let mut i : u32 = 0u32
    while i < CL_COUNT {
        let si : u64 = (i as u64) & 0xFFu64
        if (CL_NLEN[si] as u64) == nlen {
            let off : u64 = CL_NOFF[si] as u64
            let mut j : u64 = 0u64
            let mut eq : u8 = 1u8
            while j < nlen {
                if np[off + j] != q[j] { eq = 0u8   j = nlen }
                else { j = j + 1u64 }
            }
            if eq == 1u8 { return i + 1u32 }
        }
        i = i + 1u32
    }
    return 0u32
}

/* read the current value of slot into out (up to cap bytes); returns value_len. */
fn constants_value(slot: u32, out: *u8, cap: u64) -> u64 @export {
    cl_build()
    if slot == 0u32 { return 0u64 }
    if slot > CL_COUNT { return 0u64 }
    let si : u64 = ((slot - 1u32) as u64) & 0xFFu64
    let vl : u64 = CL_VLEN[si] as u64
    let mut n : u64 = vl
    if vl > cap { n = cap }
    let vp : *u8 = (&CL_VPOOL as u64) as *u8
    let off : u64 = CL_VOFF[si] as u64
    let o : *u8 = out as *u8
    let mut k : u64 = 0u64
    while k < n { o[k] = vp[off + k]   k = k + 1u64 }
    return vl
}

/* === mutation validators (the constitution enforcing its amendment rules) ===
 * compare_numeric: new >= current per type; -1 (returned as CV_INVALID) on a
 * wrong-length value for the type. */
fn cl_new_ge(si: u64, nv: *u8, nvl: u64) -> i32 {
    let t : u8 = CL_TYPE[si]
    let vp : *u8 = (&CL_VPOOL as u64) as *u8
    let off : u64 = CL_VOFF[si] as u64
    if t == CT_U64 {
        if nvl != 8u64 { return -1i32 }
        let mut cur : u64 = 0u64
        let mut neu : u64 = 0u64
        let mut k : u64 = 0u64
        while k < 8u64 {
            cur = cur | ((vp[off + k] as u64) << (k * 8u64))
            neu = neu | ((nv[k] as u64) << (k * 8u64))
            k = k + 1u64
        }
        if neu >= cur { return 1i32 }
        return 0i32
    }
    if t == CT_S64 {
        if nvl != 8u64 { return -1i32 }
        let mut cur : u64 = 0u64
        let mut neu : u64 = 0u64
        let mut k : u64 = 0u64
        while k < 8u64 {
            cur = cur | ((vp[off + k] as u64) << (k * 8u64))
            neu = neu | ((nv[k] as u64) << (k * 8u64))
            k = k + 1u64
        }
        if (neu as i64) >= (cur as i64) { return 1i32 }
        return 0i32
    }
    if t == CT_Q14 {
        if nvl != 2u64 { return -1i32 }
        let cur16 : i64 = (((vp[off] as u64) | ((vp[off + 1u64] as u64) << 8u64)) as u16 as i16) as i64
        let neu16 : i64 = (((nv[0u64] as u64) | ((nv[1u64] as u64) << 8u64)) as u16 as i16) as i64
        if neu16 >= cur16 { return 1i32 }
        return 0i32
    }
    if t == CT_BAND { return cl_hi_ge(si, nv, nvl) }
    if t == CT_TUPLE2 { return cl_hi_ge(si, nv, nvl) }
    if t == CT_BOOL {
        if nvl != 1u64 { return -1i32 }
        if nv[0u64] >= vp[off] { return 1i32 }
        return 0i32
    }
    if t == CT_STRING {
        if nvl >= (CL_VLEN[si] as u64) { return 1i32 }
        return 0i32
    }
    return -1i32
}

/* BAND/TUPLE2: the high u32 (bytes [4..8)) must not regress. */
fn cl_hi_ge(si: u64, nv: *u8, nvl: u64) -> i32 {
    if nvl != 8u64 { return -1i32 }
    let vp : *u8 = (&CL_VPOOL as u64) as *u8
    let off : u64 = CL_VOFF[si] as u64
    let chi : u32 = (vp[off + 4u64] as u32) | ((vp[off + 5u64] as u32) << 8u32) | ((vp[off + 6u64] as u32) << 16u32) | ((vp[off + 7u64] as u32) << 24u32)
    let nhi : u32 = (nv[4u64] as u32) | ((nv[5u64] as u32) << 8u32) | ((nv[6u64] as u32) << 16u32) | ((nv[7u64] as u32) << 24u32)
    if nhi >= chi { return 1i32 }
    return 0i32
}

/* CATALYST-APPEND: tier must be CATALYST_APPEND; value must not regress. */
fn constants_validate_catalyst(name: *u8, nlen: u64, nv: *u8, nvl: u64) -> i32 @export {
    let slot : u32 = constants_lookup(name, nlen)
    if slot == 0u32 { return CV_NOT_FOUND }
    let si : u64 = ((slot - 1u32) as u64) & 0xFFu64
    if CL_TIER[si] == MT_NEVER { return CV_NEVER }
    if CL_TIER[si] != MT_CATALYST { return CV_WRONG_TIER }
    let ge : i32 = cl_new_ge(si, nv, nvl)
    if ge == -1i32 { return CV_INVALID }
    if ge == 0i32 { return CV_REGRESS }
    return CV_OK
}

/* AMEND-APPLY: tier in {AMEND,SEALED,SCHEDULED,OPPOLICY}; NEVER -> founders-locked. */
fn constants_validate_amend(name: *u8, nlen: u64, nv: *u8, nvl: u64) -> i32 @export {
    let slot : u32 = constants_lookup(name, nlen)
    if slot == 0u32 { return CV_NOT_FOUND }
    let si : u64 = ((slot - 1u32) as u64) & 0xFFu64
    let t : u8 = CL_TIER[si]
    if t == MT_NEVER { return CV_LOCKED }
    if t != MT_AMEND { if t != MT_SEALED { if t != MT_SCHED { if t != MT_OPPOLICY { return CV_WRONG_TIER } } } }
    let ge : i32 = cl_new_ge(si, nv, nvl)
    if ge == -1i32 { return CV_INVALID }
    return CV_OK
}

/* R2-MAJOR-BUMP: tier must be R2_MAJOR_BUMP; NEVER -> founders-locked. */
fn constants_validate_r2(name: *u8, nlen: u64, nv: *u8, nvl: u64) -> i32 @export {
    let slot : u32 = constants_lookup(name, nlen)
    if slot == 0u32 { return CV_NOT_FOUND }
    let si : u64 = ((slot - 1u32) as u64) & 0xFFu64
    if CL_TIER[si] == MT_NEVER { return CV_LOCKED }
    if CL_TIER[si] != MT_R2 { return CV_WRONG_TIER }
    let ge : i32 = cl_new_ge(si, nv, nvl)
    if ge == -1i32 { return CV_INVALID }
    return CV_OK
}

/* === the hermetic falsifier (byte-equiv to the C ledger + validator coverage) === */
var CL_RT  : [u8; 32]
var CL_NV8 : [u8; 8]

fn cl_set_nv_u64(v: u64) {
    let mut i : u64 = 0u64
    while i < 8u64 { CL_NV8[i] = ((v >> (i * 8u64)) & 0xFFu64) as u8   i = i + 1u64 }
}

fn constants_selftest() -> u64 @export {
    cl_build()
    if constants_count() != 196u32 { return 1u64 }

    /* byte-equiv: the .iii ledger root reproduces the C R1.D2 reference vector
     * 575b7722 d9c24fad ad5a8305 0eb164fa afa13aa5 1fe491ea 7f76db7c 7670e9ce */
    constants_ledger_root((&CL_RT as u64) as *u8)
    if CL_RT[0u64]  != 0x57u8 { return 2u64 }
    if CL_RT[1u64]  != 0x5bu8 { return 3u64 }
    if CL_RT[2u64]  != 0x77u8 { return 4u64 }
    if CL_RT[3u64]  != 0x22u8 { return 5u64 }
    if CL_RT[4u64]  != 0xd9u8 { return 6u64 }
    if CL_RT[15u64] != 0xfau8 { return 7u64 }
    if CL_RT[30u64] != 0xe9u8 { return 8u64 }
    if CL_RT[31u64] != 0xceu8 { return 9u64 }

    /* reproducibility: a second root is identical */
    constants_ledger_root((&CL_VTMP as u64) as *u8)   /* reuse CL_VTMP[0..32) as scratch */
    let mut z : u64 = 0u64
    while z < 32u64 { if CL_RT[z] != CL_VTMP[z] { return 10u64 }   z = z + 1u64 }

    /* lookup: a known CATALYST_APPEND entry */
    let kw : u32 = constants_lookup(("LEX_KEYWORD_COUNT" as u64) as *u8, 17u64)
    if kw != 1u32 { return 11u64 }
    if constants_slot_tier(kw) != MT_CATALYST { return 12u64 }
    if constants_slot_type(kw) != CT_U64 { return 13u64 }
    /* a missing name -> 0 */
    if constants_lookup(("NOT_A_CONSTANT" as u64) as *u8, 14u64) != 0u32 { return 14u64 }

    /* CATALYST-APPEND validator: 48 (>=47) OK; 46 (<47) REGRESS */
    cl_set_nv_u64(48u64)
    if constants_validate_catalyst(("LEX_KEYWORD_COUNT" as u64) as *u8, 17u64, (&CL_NV8 as u64) as *u8, 8u64) != CV_OK { return 15u64 }
    cl_set_nv_u64(46u64)
    if constants_validate_catalyst(("LEX_KEYWORD_COUNT" as u64) as *u8, 17u64, (&CL_NV8 as u64) as *u8, 8u64) != CV_REGRESS { return 16u64 }
    /* catalyst on an AMEND-tier entry -> WRONG_TIER */
    cl_set_nv_u64(99u64)
    if constants_validate_catalyst(("LEX_PUNCTUATOR_COUNT" as u64) as *u8, 20u64, (&CL_NV8 as u64) as *u8, 8u64) != CV_WRONG_TIER { return 17u64 }
    /* catalyst on a NEVER entry -> NEVER */
    if constants_validate_catalyst(("EFFECT_PFS_BRICKING_OPS" as u64) as *u8, 23u64, (&CL_NV8 as u64) as *u8, 8u64) != CV_NEVER { return 18u64 }

    /* AMEND-APPLY validator: OK on an AMEND entry; LOCKED on a NEVER entry */
    if constants_validate_amend(("LEX_PUNCTUATOR_COUNT" as u64) as *u8, 20u64, (&CL_NV8 as u64) as *u8, 8u64) != CV_OK { return 19u64 }
    if constants_validate_amend(("SANCTUM_SLOT_INVALID" as u64) as *u8, 20u64, (&CL_NV8 as u64) as *u8, 8u64) != CV_LOCKED { return 20u64 }
    /* amend on a CATALYST entry -> WRONG_TIER */
    if constants_validate_amend(("LEX_KEYWORD_COUNT" as u64) as *u8, 17u64, (&CL_NV8 as u64) as *u8, 8u64) != CV_WRONG_TIER { return 21u64 }

    /* R2-MAJOR-BUMP validator: OK on an R2 entry; WRONG_TIER on an AMEND entry */
    if constants_validate_r2(("TYPE_UNIVERSE_COUNT" as u64) as *u8, 19u64, (&CL_NV8 as u64) as *u8, 8u64) != CV_OK { return 22u64 }
    if constants_validate_r2(("LEX_PUNCTUATOR_COUNT" as u64) as *u8, 20u64, (&CL_NV8 as u64) as *u8, 8u64) != CV_WRONG_TIER { return 23u64 }

    /* wrong-length value -> INVALID */
    if constants_validate_amend(("LEX_PUNCTUATOR_COUNT" as u64) as *u8, 20u64, (&CL_NV8 as u64) as *u8, 4u64) != CV_INVALID { return 24u64 }

    return 99u64
}

/* constants EMBODIES the R1.D2 Constitutional Constants Ledger in III's own
 * language: every constitutional constant catalogued, canonical-hashed to the
 * ledger root, and gated by the tier-aware mutation validators -- the
 * constitution enforcing its own amendment rules.  The C CONSTANTS/src retires:
 * III now catalogues and hashes its own constitution, one language. */
