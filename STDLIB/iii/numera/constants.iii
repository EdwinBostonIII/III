/* STDLIB/iii/numera/constants.iii -- the Constitutional Constants Ledger (R1.D2),
 * ported to .iii (H13 one-language; the C CONSTANTS/src retires here).
 *
 * Every constitutional constant from DOCS/III-CONSTANTS.md -- catalogued once,
 * canonical-hashed in slot order to the derivative ledger root R1.D2, and gated
 * by tier-aware mutation validators (the constitution enforcing its OWN amendment
 * rules: NEVER_MUTABLE is unmovable; CATALYST_APPEND must not regress; AMEND_APPLY
 * / R2_MAJOR_BUMP each have their lane).  Until now this lived in C; for H13 III
 * must catalogue and hash its own constitution in its own language.
 *
 * FAITHFUL port: the canonical per-entry encoding matches the C byte-for-byte
 *   magic "III-CONSTANTS-D2"(16) || count(u32 LE) ||
 *   for each: slot(u32 LE) | type(u8) | tier(u8) | lp(name) | lp(units) |
 *             lp(source) | lp(section) | value_len(u32 LE) | value | 0xFF
 * (lp(s) = len(u32 LE) || bytes), hashed by the one .iii sha256.  The 196-entry
 * port reproduces the C ledger root R1.D2 = 575b7722d9c24fadad5a83050eb164fa
 * afa13aa51fe491ea7f76db7c7670e9ce byte-for-byte (the selftest's byte-equiv
 * oracle), proving the transcription faithful.
 *
 * Hexad: kind_essence.  Ring: R-1 (constitutional ledger).  K: 1.00.
 * NIH: sha256 only.  No ML, no float, no u64 division.
 * Discipline: flag loops; module-global pools (never function-local runtime-idx);
 * length-explicit literal reads; sticky section mirrors the C SECT macro.
 */
module numera_constants

extern @abi(c-msvc-x64) fn sha256_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 from "sha256.iii"

/* type tags (mirror iii_constant_type_t) */
const CT_U64    : u8 = 1u8
const CT_S64    : u8 = 2u8
const CT_Q14    : u8 = 3u8
const CT_BAND   : u8 = 4u8
const CT_TUPLE2 : u8 = 5u8
const CT_BOOL   : u8 = 6u8
const CT_STRING : u8 = 7u8

/* mutation tiers (mirror iii_mutation_tier_t) */
const MT_NEVER   : u8 = 1u8
const MT_R2      : u8 = 2u8
const MT_AMEND   : u8 = 3u8
const MT_CATALYST: u8 = 4u8
const MT_DERIVED : u8 = 5u8
const MT_OPTARGET: u8 = 6u8
const MT_OPPOLICY: u8 = 7u8
const MT_SCHED   : u8 = 8u8
const MT_SEALED  : u8 = 9u8

/* validate results (mirror iii_constant_validate_t) */
const CV_OK        : i32 = 0i32
const CV_NOT_FOUND : i32 = 1i32
const CV_WRONG_TIER: i32 = 2i32
const CV_NEVER     : i32 = 3i32
const CV_REGRESS   : i32 = 4i32
const CV_INVALID   : i32 = 5i32
const CV_LOCKED    : i32 = 6i32

const CL_MAX : u32 = 256u32

/* canonical hash buffer + entry pools */
var CL_BUF   : [u8; 24576]
var CL_POS   : u64 = 0u64
var CL_COUNT : u32 = 0u32
var CL_BUILT : u8  = 0u8
var CL_SECT  : [u8; 16]
var CL_SLEN  : u64 = 0u64
var CL_VTMP  : [u8; 64]
var CL_ROOT  : [u8; 32]

/* validator table (parallel; CL_MAX slots) */
var CL_TYPE  : [u8;  256]
var CL_TIER  : [u8;  256]
var CL_NOFF  : [u32; 256]
var CL_NLEN  : [u32; 256]
var CL_VOFF  : [u32; 256]
var CL_VLEN  : [u32; 256]
var CL_NPOOL : [u8; 8192]
var CL_NPOS  : u64 = 0u64
var CL_VPOOL : [u8; 8192]
var CL_VPOS  : u64 = 0u64

/* === canonical-buffer append primitives === */
fn cl_put(src_addr: u64, n: u64) {
    let d : *u8 = (&CL_BUF as u64) as *u8
    let s : *u8 = src_addr as *u8
    let mut i : u64 = 0u64
    while i < n { d[CL_POS + i] = s[i]   i = i + 1u64 }
    CL_POS = CL_POS + n
}
fn cl_u32(v: u32) {
    CL_BUF[CL_POS]        = (v & 0xFFu32) as u8
    CL_BUF[CL_POS + 1u64] = ((v >> 8u32)  & 0xFFu32) as u8
    CL_BUF[CL_POS + 2u64] = ((v >> 16u32) & 0xFFu32) as u8
    CL_BUF[CL_POS + 3u64] = ((v >> 24u32) & 0xFFu32) as u8
    CL_POS = CL_POS + 4u64
}
fn cl_u8(v: u8) { CL_BUF[CL_POS] = v   CL_POS = CL_POS + 1u64 }
fn cl_lp(src_addr: u64, n: u64) { cl_u32(n as u32)   cl_put(src_addr, n) }

/* set the sticky section (mirrors the C #define SECT). */
fn cl_sect(lit: u64, len: u64) {
    let d : *u8 = (&CL_SECT as u64) as *u8
    let s : *u8 = lit as *u8
    let mut i : u64 = 0u64
    while i < len { d[i] = s[i]   i = i + 1u64 }
    CL_SLEN = len
}

/* encode an 8-byte little-endian value into CL_VTMP. */
fn cl_v_u64(v: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < 8u64 { CL_VTMP[i] = ((v >> (i * 8u64)) & 0xFFu64) as u8   i = i + 1u64 }
    return 8u64
}

/* core emit: record the validator entry + append the canonical encoding.
 * val_addr/vlen are the already-encoded value bytes; section is sticky. */
fn cl_emit(name: u64, nlen: u64, typ: u8, tier: u8, units: u64, ulen: u64, src: u64, slen: u64, val_addr: u64, vlen: u64) {
    let slot : u32 = CL_COUNT + 1u32
    let si : u64 = (CL_COUNT as u64) & 0xFFu64
    /* validator record: copy name -> NPOOL, value -> VPOOL */
    CL_NOFF[si] = CL_NPOS as u32
    CL_NLEN[si] = nlen as u32
    let np : *u8 = (&CL_NPOOL as u64) as *u8
    let nsrc : *u8 = name as *u8
    let mut a : u64 = 0u64
    while a < nlen { np[CL_NPOS + a] = nsrc[a]   a = a + 1u64 }
    CL_NPOS = CL_NPOS + nlen
    CL_VOFF[si] = CL_VPOS as u32
    CL_VLEN[si] = vlen as u32
    let vp : *u8 = (&CL_VPOOL as u64) as *u8
    let vsrc : *u8 = val_addr as *u8
    let mut b : u64 = 0u64
    while b < vlen { vp[CL_VPOS + b] = vsrc[b]   b = b + 1u64 }
    CL_VPOS = CL_VPOS + vlen
    CL_TYPE[si] = typ
    CL_TIER[si] = tier
    /* canonical encoding */
    cl_u32(slot)
    cl_u8(typ)
    cl_u8(tier)
    cl_lp(name, nlen)
    cl_lp(units, ulen)
    cl_lp(src, slen)
    cl_lp((&CL_SECT as u64), CL_SLEN)
    cl_u32(vlen as u32)
    cl_put(val_addr, vlen)
    cl_u8(0xFFu8)
    CL_COUNT = CL_COUNT + 1u32
}

/* per-type registration wrappers (cut caller args; encode the value). */
fn cl_u(name: u64, nlen: u64, v: u64, units: u64, ulen: u64, src: u64, slen: u64, tier: u8) {
    let n : u64 = cl_v_u64(v)
    cl_emit(name, nlen, CT_U64, tier, units, ulen, src, slen, (&CL_VTMP as u64), n)
}
fn cl_s(name: u64, nlen: u64, v: i64, units: u64, ulen: u64, src: u64, slen: u64, tier: u8) {
    let n : u64 = cl_v_u64(v as u64)
    cl_emit(name, nlen, CT_S64, tier, units, ulen, src, slen, (&CL_VTMP as u64), n)
}
fn cl_q(name: u64, nlen: u64, v: u64, src: u64, slen: u64, tier: u8) {
    CL_VTMP[0u64] = (v & 0xFFu64) as u8
    CL_VTMP[1u64] = ((v >> 8u64) & 0xFFu64) as u8
    cl_emit(name, nlen, CT_Q14, tier, ("Q14" as u64), 3u64, src, slen, (&CL_VTMP as u64), 2u64)
}
fn cl_b(name: u64, nlen: u64, lo: u32, hi: u32, src: u64, slen: u64, tier: u8) {
    CL_VTMP[0u64] = (lo & 0xFFu32) as u8   CL_VTMP[1u64] = ((lo >> 8u32) & 0xFFu32) as u8
    CL_VTMP[2u64] = ((lo >> 16u32) & 0xFFu32) as u8   CL_VTMP[3u64] = ((lo >> 24u32) & 0xFFu32) as u8
    CL_VTMP[4u64] = (hi & 0xFFu32) as u8   CL_VTMP[5u64] = ((hi >> 8u32) & 0xFFu32) as u8
    CL_VTMP[6u64] = ((hi >> 16u32) & 0xFFu32) as u8   CL_VTMP[7u64] = ((hi >> 24u32) & 0xFFu32) as u8
    cl_emit(name, nlen, CT_BAND, tier, ("range" as u64), 5u64, src, slen, (&CL_VTMP as u64), 8u64)
}
fn cl_t2(name: u64, nlen: u64, a: u32, b: u32, src: u64, slen: u64, tier: u8) {
    CL_VTMP[0u64] = (a & 0xFFu32) as u8   CL_VTMP[1u64] = ((a >> 8u32) & 0xFFu32) as u8
    CL_VTMP[2u64] = ((a >> 16u32) & 0xFFu32) as u8   CL_VTMP[3u64] = ((a >> 24u32) & 0xFFu32) as u8
    CL_VTMP[4u64] = (b & 0xFFu32) as u8   CL_VTMP[5u64] = ((b >> 8u32) & 0xFFu32) as u8
    CL_VTMP[6u64] = ((b >> 16u32) & 0xFFu32) as u8   CL_VTMP[7u64] = ((b >> 24u32) & 0xFFu32) as u8
    cl_emit(name, nlen, CT_TUPLE2, tier, ("(N,K)" as u64), 5u64, src, slen, (&CL_VTMP as u64), 8u64)
}
fn cl_bool(name: u64, nlen: u64, v: u8, src: u64, slen: u64, tier: u8) {
    CL_VTMP[0u64] = v
    cl_emit(name, nlen, CT_BOOL, tier, ("bool" as u64), 4u64, src, slen, (&CL_VTMP as u64), 1u64)
}
fn cl_str(name: u64, nlen: u64, sval: u64, svlen: u64, src: u64, slen: u64, tier: u8) {
    cl_emit(name, nlen, CT_STRING, tier, ("utf8" as u64), 4u64, src, slen, sval, svlen)
}

/* === the ledger: every constitutional constant, in slot order === */
fn cl_build() {
    if CL_BUILT == 1u8 { return }
    CL_POS = 20u64   /* reserve magic(16) + count(4); backpatched at finalize */
    CL_COUNT = 0u32
    CL_NPOS = 0u64
    CL_VPOS = 0u64

    cl_sect(("§2" as u64), 3u64)
    cl_u(("LEX_KEYWORD_COUNT" as u64), 17u64, 47u64, ("count" as u64), 5u64, ("LEX §4" as u64), 7u64, MT_CATALYST)
    cl_u(("LEX_KEYWORD_RESERVED_SLOTS" as u64), 26u64, 16u64, ("count" as u64), 5u64, ("LEX §4" as u64), 7u64, MT_CATALYST)
    cl_u(("LEX_KEYWORD_MAX" as u64), 15u64, 63u64, ("count" as u64), 5u64, ("LEX §4" as u64), 7u64, MT_CATALYST)
    cl_u(("LEX_MODIFIER_COUNT" as u64), 18u64, 19u64, ("count" as u64), 5u64, ("LEX §5" as u64), 7u64, MT_CATALYST)
    cl_u(("LEX_MODIFIER_RESERVED_SLOTS" as u64), 27u64, 8u64, ("count" as u64), 5u64, ("LEX §5" as u64), 7u64, MT_CATALYST)
    cl_u(("LEX_MODIFIER_MAX" as u64), 16u64, 27u64, ("count" as u64), 5u64, ("LEX §5" as u64), 7u64, MT_CATALYST)
    cl_u(("LEX_OPERATOR_COUNT" as u64), 18u64, 23u64, ("count" as u64), 5u64, ("LEX §6" as u64), 7u64, MT_CATALYST)
    cl_u(("LEX_OPERATOR_RESERVED_SLOTS" as u64), 27u64, 7u64, ("count" as u64), 5u64, ("LEX §6" as u64), 7u64, MT_CATALYST)
    cl_u(("LEX_OPERATOR_MAX" as u64), 16u64, 30u64, ("count" as u64), 5u64, ("LEX §6" as u64), 7u64, MT_CATALYST)
    cl_u(("LEX_PUNCTUATOR_COUNT" as u64), 20u64, 25u64, ("count" as u64), 5u64, ("LEX §7" as u64), 7u64, MT_AMEND)
    cl_u(("LEX_RESERVED_UNUSED_CHARS" as u64), 25u64, 5u64, ("count" as u64), 5u64, ("LEX §7.3" as u64), 9u64, MT_CATALYST)
    cl_u(("LEX_LITERAL_TOKEN_KINDS" as u64), 23u64, 9u64, ("count" as u64), 5u64, ("LEX §3.1" as u64), 9u64, MT_AMEND)
    cl_u(("LEX_COMMENT_KINDS" as u64), 17u64, 3u64, ("count" as u64), 5u64, ("LEX §10" as u64), 8u64, MT_AMEND)
    cl_u(("LEX_WHITESPACE_CHARS" as u64), 20u64, 3u64, ("count" as u64), 5u64, ("LEX §11" as u64), 8u64, MT_AMEND)
    cl_u(("LEX_IDENT_MAX_CODEPOINTS" as u64), 24u64, 256u64, ("codepoints" as u64), 10u64, ("LEX §8.3" as u64), 9u64, MT_AMEND)
    cl_u(("LEX_SOURCE_MAX_BYTES" as u64), 20u64, 16777216u64, ("bytes" as u64), 5u64, ("LEX §2.7" as u64), 9u64, MT_AMEND)
    cl_str(("LEX_SOURCE_EXTENSION" as u64), 20u64, (".III" as u64), 4u64, ("LEX §2.6" as u64), 9u64, MT_AMEND)
    cl_u(("LEX_MOBIUS_DIACRITIC" as u64), 20u64, 246u64, ("U+" as u64), 2u64, ("LEX §4.3" as u64), 9u64, MT_AMEND)
    cl_bool(("LEX_BOM_FORBIDDEN" as u64), 17u64, 1u8, ("LEX §2.2" as u64), 9u64, MT_R2)
    cl_str(("LEX_LINE_ENDING" as u64), 15u64, ("LF" as u64), 2u64, ("LEX §2.3" as u64), 9u64, MT_AMEND)

    cl_sect(("§3" as u64), 3u64)
    cl_u(("TYPE_UNIVERSE_COUNT" as u64), 19u64, 7u64, ("count" as u64), 5u64, ("TYPES §2" as u64), 9u64, MT_R2)
    cl_u(("TYPE_IMPREDICATIVE_TOP_INDEX" as u64), 28u64, 6u64, ("index" as u64), 5u64, ("TYPES §2.4" as u64), 11u64, MT_R2)
    cl_u(("TYPE_Q14_BITS_TOTAL" as u64), 19u64, 16u64, ("bits" as u64), 4u64, ("TYPES §6" as u64), 9u64, MT_R2)
    cl_u(("TYPE_Q14_FRAC_BITS" as u64), 18u64, 14u64, ("bits" as u64), 4u64, ("TYPES §6" as u64), 9u64, MT_R2)
    cl_u(("TYPE_MHASH_SIZE" as u64), 15u64, 32u64, ("bytes" as u64), 5u64, ("TYPES §6" as u64), 9u64, MT_AMEND)
    cl_u(("TYPE_GLYPH_SIZE" as u64), 15u64, 192u64, ("bytes" as u64), 5u64, ("LEX §4.1.1" as u64), 11u64, MT_AMEND)
    cl_u(("TYPE_WITNESS_SIZE" as u64), 17u64, 128u64, ("bytes" as u64), 5u64, ("CYCLES §4.1" as u64), 12u64, MT_AMEND)
    cl_u(("TYPE_HEXAD_PACK_BITS_USED" as u64), 25u64, 12u64, ("bits" as u64), 4u64, ("HEXAD §2.2" as u64), 11u64, MT_R2)
    cl_u(("TYPE_HEXAD_PACK_BITS_RESERVED" as u64), 29u64, 4u64, ("bits" as u64), 4u64, ("HEXAD §2.2" as u64), 11u64, MT_R2)
    cl_u(("TYPE_TRIT_CARDINALITY" as u64), 21u64, 3u64, ("count" as u64), 5u64, ("HEXAD §1.1" as u64), 11u64, MT_R2)
    cl_u(("TYPE_REDUCTION_ARITY" as u64), 20u64, 6u64, ("count" as u64), 5u64, ("TYPES §3" as u64), 9u64, MT_R2)
    cl_u(("TYPE_COMPROMISE_TIERS" as u64), 21u64, 3u64, ("count" as u64), 5u64, ("EFFECTS §1.2" as u64), 13u64, MT_AMEND)
    cl_u(("TYPE_PROOF_KERNEL_LOC_BUDGET" as u64), 28u64, 3000u64, ("LoC" as u64), 3u64, ("TYPES §11" as u64), 10u64, MT_AMEND)

    cl_sect(("§4" as u64), 3u64)
    cl_u(("EFFECT_SE_KIND_COUNT" as u64), 20u64, 17u64, ("count" as u64), 5u64, ("EFFECTS §1.1" as u64), 13u64, MT_CATALYST)
    cl_u(("EFFECT_COMPROMISE_TIER_COUNT" as u64), 28u64, 3u64, ("count" as u64), 5u64, ("EFFECTS §1.2" as u64), 13u64, MT_AMEND)
    cl_u(("EFFECT_PFS_BRICKING_OPS" as u64), 23u64, 6u64, ("count" as u64), 5u64, ("EFFECTS §1.3" as u64), 13u64, MT_NEVER)
    cl_u(("EFFECT_WAVEFRONT_TERMINATORS" as u64), 28u64, 3u64, ("count" as u64), 5u64, ("EFFECTS §7" as u64), 11u64, MT_CATALYST)

    cl_sect(("§5" as u64), 3u64)
    cl_u(("CYCLE_WITNESS_BYTE_SIZE" as u64), 23u64, 128u64, ("bytes" as u64), 5u64, ("CYCLES §4.1" as u64), 12u64, MT_AMEND)
    cl_u(("CYCLE_WITNESS_PRED_OFFSET" as u64), 25u64, 0u64, ("offset" as u64), 6u64, ("CYCLES §4.1" as u64), 12u64, MT_R2)
    cl_u(("CYCLE_WITNESS_PRED_BYTES" as u64), 24u64, 32u64, ("bytes" as u64), 5u64, ("CYCLES §4.1" as u64), 12u64, MT_R2)
    cl_u(("CYCLE_WITNESS_SUCC_OFFSET" as u64), 25u64, 32u64, ("offset" as u64), 6u64, ("CYCLES §4.1" as u64), 12u64, MT_R2)
    cl_u(("CYCLE_WITNESS_SUCC_BYTES" as u64), 24u64, 32u64, ("bytes" as u64), 5u64, ("CYCLES §4.1" as u64), 12u64, MT_R2)
    cl_u(("CYCLE_WITNESS_STEP_KIND_OFFSET" as u64), 30u64, 64u64, ("offset" as u64), 6u64, ("CYCLES §4.1" as u64), 12u64, MT_R2)
    cl_u(("CYCLE_WITNESS_STEP_KIND_BYTES" as u64), 29u64, 4u64, ("bytes" as u64), 5u64, ("CYCLES §4.1" as u64), 12u64, MT_R2)
    cl_u(("CYCLE_WITNESS_FLAGS_OFFSET" as u64), 26u64, 100u64, ("offset" as u64), 6u64, ("STDLIB §5.6" as u64), 12u64, MT_CATALYST)
    cl_u(("CYCLE_WITNESS_FLAGS_BYTES" as u64), 25u64, 4u64, ("bytes" as u64), 5u64, ("STDLIB §5.6" as u64), 12u64, MT_CATALYST)
    cl_u(("CYCLE_WITNESS_HEXAD_OFFSET" as u64), 26u64, 104u64, ("offset" as u64), 6u64, ("CYCLES §4.1" as u64), 12u64, MT_R2)
    cl_u(("CYCLE_WITNESS_HEXAD_BYTES" as u64), 25u64, 24u64, ("bytes" as u64), 5u64, ("CYCLES §4.1" as u64), 12u64, MT_R2)
    cl_u(("CYCLE_BCWL_BLOOM_BITS" as u64), 21u64, 4096u64, ("bits" as u64), 4u64, ("CYCLES §4.3" as u64), 12u64, MT_AMEND)
    cl_u(("CYCLE_BCWL_BUCKETS" as u64), 18u64, 16u64, ("count" as u64), 5u64, ("CYCLES §4.3" as u64), 12u64, MT_AMEND)
    cl_u(("CYCLE_BCWL_FP_TARGET_PERCENT" as u64), 28u64, 1u64, ("percent" as u64), 7u64, ("STDLIB §14.3" as u64), 13u64, MT_AMEND)
    cl_u(("CYCLE_STEP_KIND_TOTAL_SLOTS" as u64), 27u64, 512u64, ("count" as u64), 5u64, ("CYCLES §5.3" as u64), 12u64, MT_R2)
    cl_b(("SK_RESERVED_BOOT" as u64), 16u64, 0x0000u32, 0x000Fu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_IRPD_PRIV_WRITE" as u64), 18u64, 0x0010u32, 0x002Fu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_IRPD_PRIV_READ" as u64), 17u64, 0x0030u32, 0x004Fu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_CYCLE_LIFECYCLE" as u64), 18u64, 0x0050u32, 0x006Fu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_WAVEFRONT" as u64), 12u64, 0x0070u32, 0x007Fu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_SANCTUM" as u64), 10u64, 0x0080u32, 0x009Fu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_TRINITY" as u64), 10u64, 0x00A0u32, 0x00BFu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_CEILING" as u64), 10u64, 0x00C0u32, 0x00CFu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_FEDERATION" as u64), 13u64, 0x00D0u32, 0x00EFu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_DRTM" as u64), 7u64, 0x00F0u32, 0x00FFu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_VDF" as u64), 6u64, 0x0100u32, 0x010Fu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_OBSERVATORY" as u64), 14u64, 0x0110u32, 0x012Fu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_CATALYST" as u64), 11u64, 0x0130u32, 0x014Fu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_NARRATIVE" as u64), 12u64, 0x0150u32, 0x015Fu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
    cl_b(("SK_COGNITIVE" as u64), 12u64, 0x0160u32, 0x017Fu32, ("CYCLES §5.3" as u64), 12u64, MT_AMEND)
