/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\contract_gate.iii
 *
 * III STDLIB - numera::contract_gate  --  THE ZERO-TRUST CONTRACT ADMISSION GATE.
 *
 * Commercial chains admit any smart contract and discover its bugs by being drained.  A III-based ledger
 * inverts this: a contract is admitted to the chain ONLY with a kernel-checked proof that it satisfies its
 * SPECIFICATION.  This gate enforces that for the canonical ledger invariant -- CONSERVATION OF VALUE: a
 * transfer must not create or destroy balance.  It applies the Popperian discipline of numera::conjecture_-
 * refute to admission: the contract is admitted iff conservation is PROVEN exhaustively, and rejected the
 * instant a counterexample (a transfer that mints or burns value) is found -- before it ever runs on-chain.
 *
 * Three candidate contracts over 4 accounts (initial balances [3,2,1,0], total 6): c0 a correct guarded
 * transfer (conserves); c1 a MINT bug (credits the receiver without debiting the sender); c2 a DUP-CREDIT
 * bug (a correct transfer plus an extra credit to account 0).  The gate admits c0 and rejects c1/c2 with a
 * witnessing (src,to,amount) counterexample.
 *
 * Verified (contract_gate_kat): the correct contract is admitted; both buggy contracts are rejected; a real
 * counterexample is recorded; the correct contract's transfers always conserve the total.  NIH/self-contained.
 *
 * Public API:
 *   cg_transfer(contract, src, to, amount) ; cg_sum() -> u32 ; cg_conserves(contract) -> u32 ;
 *   cg_admit(contract) -> u32 ; cg_cex_src() -> u32 ; cg_cex_to() -> u32 ; cg_cex_amount() -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_contract_gate

const CG_ACCTS : u32 = 4u32
const CG_TOTAL : u32 = 6u32        /* invariant: sum of initial balances [3,2,1,0] */

var CG_BAL : [u32; 4]
var CG_CEX : [u32; 3]              /* the witnessing (src, to, amount) of a rejection */

fn cg_reset() {
    CG_BAL[0u64]=3u32 ; CG_BAL[1u64]=2u32 ; CG_BAL[2u64]=1u32 ; CG_BAL[3u64]=0u32
}

fn cg_sum() -> u32 @export {
    return CG_BAL[0u64] + CG_BAL[1u64] + CG_BAL[2u64] + CG_BAL[3u64]
}

/* apply a contract's transfer logic to CG_BAL. */
fn cg_transfer(contract: u32, src: u32, to: u32, amount: u32) -> i32 @export {
    if contract == 0u32 {                                  /* correct: guarded move */
        if CG_BAL[src as u64] >= amount {
            CG_BAL[src as u64] = CG_BAL[src as u64] - amount
            CG_BAL[to as u64] = CG_BAL[to as u64] + amount
        }
        return 0i32
    }
    if contract == 1u32 {                                  /* MINT bug: credit without debit */
        CG_BAL[to as u64] = CG_BAL[to as u64] + amount
        return 0i32
    }
    /* contract 2 -- DUP-CREDIT bug: a correct move plus an extra credit to account 0 */
    if CG_BAL[src as u64] >= amount {
        CG_BAL[src as u64] = CG_BAL[src as u64] - amount
        CG_BAL[to as u64] = CG_BAL[to as u64] + amount
        CG_BAL[0u64] = CG_BAL[0u64] + amount
    }
    return 0i32
}

/* PROVE conservation: 1 iff every transfer over the input domain preserves the total; else 0 with a
 * counterexample recorded. */
fn cg_conserves(contract: u32) -> u32 @export {
    let mut src : u32 = 0u32
    while src < CG_ACCTS {
        let mut to : u32 = 0u32
        while to < CG_ACCTS {
            let mut amount : u32 = 0u32
            while amount < 4u32 {
                cg_reset()
                cg_transfer(contract, src, to, amount)
                if cg_sum() != CG_TOTAL {
                    CG_CEX[0u64] = src ; CG_CEX[1u64] = to ; CG_CEX[2u64] = amount
                    return 0u32
                }
                amount = amount + 1u32
            }
            to = to + 1u32
        }
        src = src + 1u32
    }
    return 1u32
}

/* the admission verdict: admit iff conservation is proven. */
fn cg_admit(contract: u32) -> u32 @export { return cg_conserves(contract) }

fn cg_cex_src() -> u32 @export { return CG_CEX[0u64] }
fn cg_cex_to() -> u32 @export { return CG_CEX[1u64] }
fn cg_cex_amount() -> u32 @export { return CG_CEX[2u64] }

/* =====================================================================================
 * contract_gate_kat -- 99 = zero-trust contract admission is sound, self-checked:
 *   (1) the correct contract c0 is ADMITTED (conservation proven over all transfers);
 *   (2) the MINT bug c1 is REJECTED with a real counterexample (a transfer that raises the total);
 *   (3) the DUP-CREDIT bug c2 is REJECTED;
 *   (4) the correct contract really conserves the total on a sampled transfer.
 * ===================================================================================== */
fn contract_gate_kat() -> u64 @export {
    /* (1) correct contract admitted */
    if cg_admit(0u32) != 1u32 { return 1u64 }

    /* (2) mint bug rejected, with a counterexample that actually breaks conservation */
    if cg_admit(1u32) != 0u32 { return 2u64 }
    cg_reset()
    cg_transfer(1u32, cg_cex_src(), cg_cex_to(), cg_cex_amount())
    if cg_sum() == CG_TOTAL { return 3u64 }              /* the witness really violates conservation */
    if cg_cex_amount() == 0u32 { return 4u64 }           /* a zero-amount transfer cannot mint */

    /* (3) dup-credit bug rejected */
    if cg_admit(2u32) != 0u32 { return 5u64 }

    /* (4) the correct contract conserves on a concrete transfer */
    cg_reset()
    cg_transfer(0u32, 0u32, 3u32, 2u32)                  /* move 2 src acct0 to acct3 */
    if cg_sum() != CG_TOTAL { return 6u64 }
    if CG_BAL[0u64] != 1u32 { return 7u64 }              /* 3-2 */
    if CG_BAL[3u64] != 2u32 { return 8u64 }              /* 0+2 */

    return 99u64
}
