/* III/STDLIB/iii/numera/cost_lattice_synth.iii
 *
 * III STDLIB - numera::cost_lattice_synth
 *
 * The V3 cost lattice extension. A 64-byte extended cost vector:
 *   bytes 0..55  : eight u64 little-endian additive/max dimensions
 *     0 time  1 memory  2 witness_growth  3 proof_term_size
 *     4 lib_cite_depth  5 branch_depth  6 synth_budget  7 reflect_budget
 *   bytes 56..60 : five K-vector components (u8 fixed-point 0..100)
 *     K, K_synth, K_reflect, K_memo, K_theorem  (dims 8..12)
 *   byte  61     : reserved (dim 13)   bytes 62..63 : reserved
 *
 * Operations:
 *   sequential composition : additive add (saturating), K product/100
 *   parallel   composition : time/budgets max, memory/witness/proof sum
 *                            (saturating), K min
 *   order cls_le           : <= on additive dims, >= on K dims
 *   admission cls_admit    : refuse a declared vector not <= the bound
 *   cls_emit_overrun       : publish a schema-conformant COST_OVERRUN
 *                            fragment via the witness hook
 *
 * Determinism: fixed-width integer only, no FP, counted loops, no
 * recursion. Saturating composition is the M19 boundedness guarantee:
 * no composed cost escapes the lattice by overflow. W43 binds (no
 * synthesis output beyond the cost lattice); M19 binds.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00.
 *
 * NIH: depends on identifier.iii (ids + content_address Keccak256) and
 * aether/witness_hook.iii (wh_publish). The base numera/cost_lattice.iii
 * uses a different 6-u64 representation and is NOT externed here.
 *
 * The one impure path (cls_emit_overrun) uses module-scope staging
 * buffers and is therefore non-reentrant -- acceptable, since witness
 * chain append is a serialized, ordered operation by construction.
 */

module numera_cost_lattice_synth

extern @abi(c-msvc-x64) fn ident_zero(out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_copy(src: *u8, dst: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_from_bytes(input: *u8, in_len: u64, out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn wh_publish(producer: *u8, opid: *u8, in_commit: *u8, out_commit: *u8, revtag: u8, phase: u8, pillar: u16, antecedents: *u8, n_ante: u32, payload: *u8, payload_len: u32, out_frag_id: *u8) -> u64 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn wh_get_payload(idx: u64, out_buf: *u8, max_len: u64, out_len: *u64) -> i32 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn wh_init(initial_time: u64) -> i32 from "witness_hook.iii"

const CLS_OK              : i32 =  0i32
const CLS_E_NULL          : i32 = -1i32
const CLS_E_DIM           : i32 = -2i32
const CLS_E_BOUND         : i32 = -3i32
const CLS_E_EMIT          : i32 = -4i32

const CLS_BYTES           : u64 = 72u64   /* 8 u64 dims (bytes 0..63) + 6 K bytes (dims 8..13 at CLS_K_BYTE0..+5 = 64..69), padded to 72 */

const CLS_DIM_TIME            : u8 = 0u8
const CLS_DIM_MEMORY          : u8 = 1u8
const CLS_DIM_WITNESS_GROWTH  : u8 = 2u8
const CLS_DIM_PROOF_TERM_SIZE : u8 = 3u8
const CLS_DIM_LIB_CITE_DEPTH  : u8 = 4u8
const CLS_DIM_BRANCH_DEPTH    : u8 = 5u8
const CLS_DIM_SYNTH_BUDGET    : u8 = 6u8
const CLS_DIM_REFLECT_BUDGET  : u8 = 7u8

const CLS_K_BASE          : u8  = 8u8
const CLS_K_END           : u8  = 13u8
const CLS_DIM_RESERVED    : u8  = 13u8
const CLS_DIM_COUNT       : u8  = 14u8
const CLS_DIM_NONE        : u8  = 0xFFu8
const CLS_K_BYTE0         : u64 = 64u64   /* K bytes start AFTER the 8 u64 dims (bytes 0..63); 56 overlapped dim 7's u64 (bytes 56..63) -> cls_le mis-read K8 as dim7 */
const CLS_K_FP_ONE        : u64 = 100u64

const CLS_U64_MAX         : u64 = 0xFFFFFFFFFFFFFFFFu64
const CLS_WH_FAIL         : u64 = 0xFFFFFFFFFFFFFFFFu64

const CLS_V3_SENTINEL     : u8  = 0xE3u8
const CLS_KIND_OVERRUN    : u8  = 0x11u8

const CLS_DESC_BYTES      : u64 = 24u64
const CLS_OVERRUN_INNER   : u64 = 9u64
const CLS_PAYLOAD_BYTES   : u64 = 81u64

/* module-scope staging (Trap-7 fix; cls_emit_overrun non-reentrant) */
var CLS_PAYLOAD   : [u8; 81]
var CLS_PRODUCER  : [u8; 32]
var CLS_OPID      : [u8; 32]
var CLS_IN_C      : [u8; 32]
var CLS_OUT_C     : [u8; 32]
var CLS_CADDR_IN  : [u8; 96]

/* KAT scratch (self-test only) */
var CLS_KA        : [u8; 64]
var CLS_KB        : [u8; 64]
var CLS_KOUT      : [u8; 64]
var CLS_KDESC     : [u8; 24]
var CLS_KOPID     : [u8; 32]
var CLS_KFRAG     : [u8; 32]
var CLS_KRDBUF    : [u8; 128]
var CLS_KRDLEN    : [u64; 1]
var CLS_KCADDR    : [u8; 32]

/* --- file-private helpers (single-line; not @export) --- */

fn cls_sat_add(a: u64, b: u64) -> u64 {
    let s : u64 = a + b
    if s < a { return CLS_U64_MAX }
    return s
}

fn cls_max_u64(a: u64, b: u64) -> u64 {
    if a > b { return a }
    return b
}

fn cls_min_u64(a: u64, b: u64) -> u64 {
    if a < b { return a }
    return b
}

/* --- dimension codec --- */

fn cls_zero(out: *u8) -> i32 @export {
    if (out as u64) == 0u64 { return CLS_E_NULL }
    let mut i : u64 = 0u64
    while i < CLS_BYTES { out[i] = 0u8 ; i = i + 1u64 }
    return CLS_OK
}

fn cls_dimension_get(v: *u8, dim: u8) -> u64 @export {
    if (v as u64) == 0u64 { return 0u64 }
    if dim < 8u8 {
        let base : u64 = (dim as u64) * 8u64
        let mut val : u64 = 0u64
        let mut k : u64 = 0u64
        while k < 8u64 {
            val = val | ((v[base + k] as u64) << (k * 8u64))
            k = k + 1u64
        }
        return val
    }
    if dim < CLS_DIM_COUNT {
        let idx : u64 = CLS_K_BYTE0 + ((dim - 8u8) as u64)
        return v[idx] as u64
    }
    return 0u64
}

fn cls_dimension_set(v: *u8, dim: u8, value: u64) -> i32 @export {
    if (v as u64) == 0u64 { return CLS_E_NULL }
    if dim < 8u8 {
        let base : u64 = (dim as u64) * 8u64
        let mut k : u64 = 0u64
        while k < 8u64 {
            v[base + k] = ((value >> (k * 8u64)) & 0xFFu64) as u8
            k = k + 1u64
        }
        return CLS_OK
    }
    if dim < CLS_DIM_COUNT {
        let mut kv : u64 = value & 0xFFu64
        if kv > CLS_K_FP_ONE { kv = CLS_K_FP_ONE }
        let idx : u64 = CLS_K_BYTE0 + ((dim - 8u8) as u64)
        v[idx] = kv as u8
        return CLS_OK
    }
    return CLS_E_DIM
}

/* --- composition --- */

fn cls_compose_sequential(left: *u8, right: *u8, out: *u8) -> i32 @export {
    if (left as u64) == 0u64 { return CLS_E_NULL }
    if (right as u64) == 0u64 { return CLS_E_NULL }
    if (out as u64) == 0u64 { return CLS_E_NULL }
    let mut d : u8 = 0u8
    while d < 8u8 {
        let lv : u64 = cls_dimension_get(left, d)
        let rv : u64 = cls_dimension_get(right, d)
        let sum : u64 = cls_sat_add(lv, rv)
        cls_dimension_set(out, d, sum)
        d = d + 1u8
    }
    let mut k : u8 = CLS_K_BASE
    while k < CLS_K_END {
        let lk : u64 = cls_dimension_get(left, k)
        let rk : u64 = cls_dimension_get(right, k)
        let prodraw : u64 = lk * rk
        let prod : u64 = prodraw / CLS_K_FP_ONE
        cls_dimension_set(out, k, prod)
        k = k + 1u8
    }
    return CLS_OK
}

fn cls_compose_parallel(left: *u8, right: *u8, out: *u8) -> i32 @export {
    if (left as u64) == 0u64 { return CLS_E_NULL }
    if (right as u64) == 0u64 { return CLS_E_NULL }
    if (out as u64) == 0u64 { return CLS_E_NULL }
    let mut d : u8 = 0u8
    while d < 8u8 {
        let lv : u64 = cls_dimension_get(left, d)
        let rv : u64 = cls_dimension_get(right, d)
        let mut is_sum : u8 = 0u8
        if d == CLS_DIM_MEMORY { is_sum = 1u8 }
        if d == CLS_DIM_WITNESS_GROWTH { is_sum = 1u8 }
        if d == CLS_DIM_PROOF_TERM_SIZE { is_sum = 1u8 }
        let mut res : u64 = cls_max_u64(lv, rv)
        if is_sum == 1u8 { res = cls_sat_add(lv, rv) }
        cls_dimension_set(out, d, res)
        d = d + 1u8
    }
    let mut k : u8 = CLS_K_BASE
    while k < CLS_K_END {
        let lk : u64 = cls_dimension_get(left, k)
        let rk : u64 = cls_dimension_get(right, k)
        let m : u64 = cls_min_u64(lk, rk)
        cls_dimension_set(out, k, m)
        k = k + 1u8
    }
    return CLS_OK
}

/* --- order + admission --- */

fn cls_le(a: *u8, b: *u8) -> u8 @export {
    if (a as u64) == 0u64 { return 0u8 }
    if (b as u64) == 0u64 { return 0u8 }
    let mut ok : u8 = 1u8
    let mut d : u8 = 0u8
    while d < 8u8 {
        if ok == 1u8 {
            let av : u64 = cls_dimension_get(a, d)
            let bv : u64 = cls_dimension_get(b, d)
            if av > bv { ok = 0u8 }
        }
        d = d + 1u8
    }
    let mut k : u8 = CLS_K_BASE
    while k < CLS_K_END {
        if ok == 1u8 {
            let ak : u64 = cls_dimension_get(a, k)
            let bk : u64 = cls_dimension_get(b, k)
            if ak < bk { ok = 0u8 }
        }
        k = k + 1u8
    }
    return ok
}

fn cls_first_exceeded(declared: *u8, bound: *u8, out_dim: *u8) -> i32 @export {
    if (declared as u64) == 0u64 { return CLS_E_NULL }
    if (bound as u64) == 0u64 { return CLS_E_NULL }
    if (out_dim as u64) == 0u64 { return CLS_E_NULL }
    let mut found_dim : u8 = CLS_DIM_NONE
    let mut done : u8 = 0u8
    let mut i : u8 = 0u8
    while i < CLS_K_END {
        if done == 0u8 {
            let dv : u64 = cls_dimension_get(declared, i)
            let bv : u64 = cls_dimension_get(bound, i)
            let mut viol : u8 = 0u8
            if i < 8u8 {
                if dv > bv { viol = 1u8 }
            } else {
                if dv < bv { viol = 1u8 }
            }
            if viol == 1u8 { found_dim = i ; done = 1u8 }
        }
        i = i + 1u8
    }
    out_dim[0u64] = found_dim
    return CLS_OK
}

fn cls_admit(declared: *u8, bound: *u8) -> i32 @export {
    if (declared as u64) == 0u64 { return CLS_E_NULL }
    if (bound as u64) == 0u64 { return CLS_E_NULL }
    if cls_le(declared, bound) == 1u8 { return CLS_OK }
    return CLS_E_BOUND
}

/* --- overrun witness emission --- */

fn cls_overrun_desc_pack(dim: u8, declared: u64, observed: u64, out_desc: *u8) -> i32 @export {
    if (out_desc as u64) == 0u64 { return CLS_E_NULL }
    if dim >= CLS_DIM_COUNT { return CLS_E_DIM }
    out_desc[0u64] = dim
    let mut z : u64 = 1u64
    while z < 8u64 { out_desc[z] = 0u8 ; z = z + 1u64 }
    let mut k : u64 = 0u64
    while k < 8u64 {
        out_desc[8u64 + k]  = ((declared >> (k * 8u64)) & 0xFFu64) as u8
        out_desc[16u64 + k] = ((observed >> (k * 8u64)) & 0xFFu64) as u8
        k = k + 1u64
    }
    return CLS_OK
}

fn cls_emit_overrun(operation_id: *u8, desc: *u8, out_frag_id: *u8) -> i32 @export {
    if (operation_id as u64) == 0u64 { return CLS_E_NULL }
    if (desc as u64) == 0u64 { return CLS_E_NULL }
    if (out_frag_id as u64) == 0u64 { return CLS_E_NULL }
    let prod_p : *u8 = (&CLS_PRODUCER as u64) as *u8
    let op_p   : *u8 = (&CLS_OPID as u64) as *u8
    let inc_p  : *u8 = (&CLS_IN_C as u64) as *u8
    let outc_p : *u8 = (&CLS_OUT_C as u64) as *u8
    let pay_p  : *u8 = (&CLS_PAYLOAD as u64) as *u8
    let caddr_p : *u8 = (&CLS_CADDR_IN as u64) as *u8
    ident_zero(prod_p)
    ident_zero(op_p)
    ident_copy(operation_id, inc_p)
    ident_zero(outc_p)
    /* zero the full payload staging first (branch_id + reserved tail) */
    let mut z : u64 = 0u64
    while z < CLS_PAYLOAD_BYTES { pay_p[z] = 0u8 ; z = z + 1u64 }
    /* content_address input = producer || op || operation_id (3 * 32) */
    ident_copy(prod_p, ((&CLS_CADDR_IN as u64) + 0u64) as *u8)
    ident_copy(op_p,   ((&CLS_CADDR_IN as u64) + 32u64) as *u8)
    ident_copy(inc_p,  ((&CLS_CADDR_IN as u64) + 64u64) as *u8)
    ident_from_bytes(caddr_p, 96u64, ((&CLS_PAYLOAD as u64) + 4u64) as *u8)
    /* V3 header */
    pay_p[0u64] = CLS_V3_SENTINEL
    pay_p[1u64] = CLS_KIND_OVERRUN
    pay_p[2u64] = 0u8
    pay_p[3u64] = 0u8
    /* bytes 4..36 = content_address (written above); bytes 36..68 = branch_id = 0 (already zeroed) */
    pay_p[68u64] = (CLS_OVERRUN_INNER & 0xFFu64) as u8
    pay_p[69u64] = 0u8
    pay_p[70u64] = 0u8
    pay_p[71u64] = 0u8
    /* inner payload: dim + saturating(observed - declared) LE */
    pay_p[72u64] = desc[0u64]
    let mut dec : u64 = 0u64
    let mut obs : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        dec = dec | ((desc[8u64 + k]  as u64) << (k * 8u64))
        obs = obs | ((desc[16u64 + k] as u64) << (k * 8u64))
        k = k + 1u64
    }
    let mut mag : u64 = obs - dec
    if obs < dec { mag = 0u64 }
    let mut m : u64 = 0u64
    while m < 8u64 {
        pay_p[73u64 + m] = ((mag >> (m * 8u64)) & 0xFFu64) as u8
        m = m + 1u64
    }
    let fi : u64 = wh_publish(prod_p, op_p, inc_p, outc_p, 0u8, 0u8, 0u16, outc_p, 0u32, pay_p, CLS_PAYLOAD_BYTES as u32, out_frag_id)
    if fi == CLS_WH_FAIL { return CLS_E_EMIT }
    return CLS_OK
}

/* --- KAT helpers (self-test only) --- */

fn cls_ka_le_u64(buf: *u8, off: u64) -> u64 {
    let mut val : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        val = val | ((buf[off + k] as u64) << (k * 8u64))
        k = k + 1u64
    }
    return val
}

/* Self-test.  99 = pass; a distinct small code at each failed check. */
fn cls_selftest() -> u64 @export {
    /* witness hook must be live before KAT 4's cls_emit_overrun publishes
     * (self-contained; the corpus harness does not pre-init it). */
    wh_init(0u64)
    let a : *u8 = (&CLS_KA as u64) as *u8
    let b : *u8 = (&CLS_KB as u64) as *u8
    let o : *u8 = (&CLS_KOUT as u64) as *u8

    /* KAT 1: codec + sequential composition + K clamp */
    cls_zero(a)
    cls_dimension_set(a, CLS_DIM_TIME, 10u64)
    cls_dimension_set(a, CLS_DIM_MEMORY, 200u64)
    cls_dimension_set(a, 8u8, 90u64)
    if cls_dimension_get(a, CLS_DIM_TIME) != 10u64 { return 1u64 }
    if cls_dimension_get(a, CLS_DIM_MEMORY) != 200u64 { return 2u64 }
    if cls_dimension_get(a, 8u8) != 90u64 { return 3u64 }
    cls_zero(b)
    cls_dimension_set(b, CLS_DIM_TIME, 5u64)
    cls_dimension_set(b, CLS_DIM_MEMORY, 50u64)
    cls_dimension_set(b, 8u8, 80u64)
    cls_compose_sequential(a, b, o)
    if cls_dimension_get(o, CLS_DIM_TIME) != 15u64 { return 4u64 }
    if cls_dimension_get(o, CLS_DIM_MEMORY) != 250u64 { return 5u64 }
    if cls_dimension_get(o, 8u8) != 72u64 { return 6u64 }
    cls_dimension_set(a, 8u8, 250u64)
    if cls_dimension_get(a, 8u8) != 100u64 { return 7u64 }

    /* KAT 2: parallel composition + mixed product order */
    cls_zero(a)
    cls_dimension_set(a, CLS_DIM_TIME, 10u64)
    cls_dimension_set(a, CLS_DIM_MEMORY, 200u64)
    cls_dimension_set(a, CLS_DIM_WITNESS_GROWTH, 4u64)
    cls_dimension_set(a, 8u8, 90u64)
    cls_zero(b)
    cls_dimension_set(b, CLS_DIM_TIME, 5u64)
    cls_dimension_set(b, CLS_DIM_MEMORY, 50u64)
    cls_dimension_set(b, CLS_DIM_WITNESS_GROWTH, 9u64)
    cls_dimension_set(b, 8u8, 80u64)
    cls_compose_parallel(a, b, o)
    if cls_dimension_get(o, CLS_DIM_TIME) != 10u64 { return 8u64 }
    if cls_dimension_get(o, CLS_DIM_MEMORY) != 250u64 { return 9u64 }
    if cls_dimension_get(o, CLS_DIM_WITNESS_GROWTH) != 13u64 { return 10u64 }
    if cls_dimension_get(o, 8u8) != 80u64 { return 11u64 }
    /* order: lo = TIME 5/MEM 50/K 90 ; hi = TIME 10/MEM 200/K 80 */
    cls_zero(a)
    cls_dimension_set(a, CLS_DIM_TIME, 5u64)
    cls_dimension_set(a, CLS_DIM_MEMORY, 50u64)
    cls_dimension_set(a, 8u8, 90u64)
    cls_zero(b)
    cls_dimension_set(b, CLS_DIM_TIME, 10u64)
    cls_dimension_set(b, CLS_DIM_MEMORY, 200u64)
    cls_dimension_set(b, 8u8, 80u64)
    if cls_le(a, b) != 1u8 { return 12u64 }
    if cls_le(b, a) != 0u8 { return 13u64 }
    if cls_le(a, a) != 1u8 { return 14u64 }
    /* flip trust: lo2 = TIME 5/MEM 50/K 70 -> not <= hi (K 70 < 80) */
    cls_dimension_set(a, 8u8, 70u64)
    if cls_le(a, b) != 0u8 { return 15u64 }

    /* KAT 3: admission gate + first-exceeded + saturation */
    cls_zero(b)
    cls_dimension_set(b, CLS_DIM_TIME, 100u64)
    cls_dimension_set(b, CLS_DIM_MEMORY, 1000u64)
    cls_dimension_set(b, 8u8, 50u64)
    /* declared_ok = TIME 80, MEM 900, K 60 */
    cls_zero(a)
    cls_dimension_set(a, CLS_DIM_TIME, 80u64)
    cls_dimension_set(a, CLS_DIM_MEMORY, 900u64)
    cls_dimension_set(a, 8u8, 60u64)
    if cls_admit(a, b) != CLS_OK { return 16u64 }
    let dn : *u8 = (&CLS_KDESC as u64) as *u8
    if cls_first_exceeded(a, b, dn) != CLS_OK { return 17u64 }
    if dn[0u64] != CLS_DIM_NONE { return 18u64 }
    /* declared_bad = TIME 80, MEM 1200, K 60 -> refuse, first dim = MEMORY */
    cls_dimension_set(a, CLS_DIM_MEMORY, 1200u64)
    if cls_admit(a, b) != CLS_E_BOUND { return 19u64 }
    cls_first_exceeded(a, b, dn)
    if dn[0u64] != CLS_DIM_MEMORY { return 20u64 }
    /* K-violation: TIME 80, MEM 900, K 40 -> first dim = 8 */
    cls_dimension_set(a, CLS_DIM_MEMORY, 900u64)
    cls_dimension_set(a, 8u8, 40u64)
    cls_first_exceeded(a, b, dn)
    if dn[0u64] != 8u8 { return 21u64 }
    /* saturation: x = MEM U64_MAX ; y = MEM 5 -> seq compose MEM == U64_MAX */
    cls_zero(a)
    cls_dimension_set(a, CLS_DIM_MEMORY, CLS_U64_MAX)
    cls_zero(b)
    cls_dimension_set(b, CLS_DIM_MEMORY, 5u64)
    cls_compose_sequential(a, b, o)
    if cls_dimension_get(o, CLS_DIM_MEMORY) != CLS_U64_MAX { return 22u64 }

    /* KAT 4: schema-conformant COST_OVERRUN emission (harness calls wh_init) */
    let desc : *u8 = (&CLS_KDESC as u64) as *u8
    if cls_overrun_desc_pack(CLS_DIM_MEMORY, 1000u64, 1200u64, desc) != CLS_OK { return 23u64 }
    if desc[0u64] != CLS_DIM_MEMORY { return 24u64 }
    if cls_ka_le_u64(desc, 8u64) != 1000u64 { return 25u64 }
    if cls_ka_le_u64(desc, 16u64) != 1200u64 { return 26u64 }
    let opid : *u8 = (&CLS_KOPID as u64) as *u8
    let mut oi : u64 = 0u64
    while oi < 32u64 { opid[oi] = 0xABu8 ; oi = oi + 1u64 }
    let frag : *u8 = (&CLS_KFRAG as u64) as *u8
    if cls_emit_overrun(opid, desc, frag) != CLS_OK { return 27u64 }
    /* frag id non-zero (32 bytes written by wh_publish) */
    let mut facc : u32 = 0u32
    let mut fk : u64 = 0u64
    while fk < 32u64 { facc = facc | (frag[fk] as u32) ; fk = fk + 1u64 }
    if facc == 0u32 { return 28u64 }
    /* read back payload via wh_publish-stored fragment at idx 0 (first publish) */
    let rb : *u8 = (&CLS_KRDBUF as u64) as *u8
    let rl : *u64 = (&CLS_KRDLEN as u64) as *u64
    if wh_get_payload(0u64, rb, 128u64, rl) != 0i32 { return 29u64 }
    if CLS_KRDLEN[0] != CLS_PAYLOAD_BYTES { return 30u64 }
    if rb[0u64] != CLS_V3_SENTINEL { return 31u64 }
    if rb[1u64] != CLS_KIND_OVERRUN { return 32u64 }
    if rb[2u64] != 0u8 { return 33u64 }
    if rb[3u64] != 0u8 { return 34u64 }
    /* content_address = Keccak256(zero32 || zero32 || operation_id), recomputable */
    let mut ci : u64 = 0u64
    while ci < 64u64 { CLS_CADDR_IN[ci] = 0u8 ; ci = ci + 1u64 }
    let mut cj : u64 = 0u64
    while cj < 32u64 { CLS_CADDR_IN[64u64 + cj] = 0xABu8 ; cj = cj + 1u64 }
    ident_from_bytes((&CLS_CADDR_IN as u64) as *u8, 96u64, (&CLS_KCADDR as u64) as *u8)
    let mut ce : u64 = 0u64
    let mut cmism : u8 = 0u8
    while ce < 32u64 {
        if rb[4u64 + ce] != CLS_KCADDR[ce] { cmism = 1u8 }
        ce = ce + 1u64
    }
    if cmism == 1u8 { return 35u64 }
    /* branch_id (36..68) all zero */
    let mut be : u64 = 36u64
    let mut bmism : u8 = 0u8
    while be < 68u64 {
        if rb[be] != 0u8 { bmism = 1u8 }
        be = be + 1u64
    }
    if bmism == 1u8 { return 36u64 }
    /* inner_len = 9 LE */
    if rb[68u64] != 9u8 { return 37u64 }
    if rb[69u64] != 0u8 { return 38u64 }
    if rb[70u64] != 0u8 { return 39u64 }
    if rb[71u64] != 0u8 { return 40u64 }
    /* inner: dim = MEMORY, magnitude = 1200 - 1000 = 200 LE */
    if rb[72u64] != CLS_DIM_MEMORY { return 41u64 }
    if cls_ka_le_u64(rb, 73u64) != 200u64 { return 42u64 }
    /* null path */
    let nullp : *u8 = 0u64 as *u8
    if cls_emit_overrun(nullp, desc, frag) != CLS_E_NULL { return 43u64 }

    /* negative cases: bad dim + null on the pure gates */
    if cls_dimension_set(a, 14u8, 1u64) != CLS_E_DIM { return 44u64 }
    if cls_overrun_desc_pack(14u8, 0u64, 0u64, desc) != CLS_E_DIM { return 45u64 }
    if cls_admit(nullp, b) != CLS_E_NULL { return 46u64 }
    if cls_zero(nullp) != CLS_E_NULL { return 47u64 }
    if cls_le(nullp, b) != 0u8 { return 48u64 }

    return 99u64
}
