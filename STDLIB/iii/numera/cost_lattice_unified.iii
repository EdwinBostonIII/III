/* STDLIB/iii/numera/cost_lattice_unified.iii -- APOTHEOSIS C.14: the mechanistic PROVABLE cycle bound.
 *
 * A fast path's cycle BOUND is DERIVED from the §C.8 cost manifold (`uc_formula_latency` = the
 * critical path = the analytic lower bound on cycles under unbounded parallelism) -- not hand-
 * measured. So a regression becomes PROVABLE: a path whose measured cycle ratio exceeds its derived
 * bound (plus a host-margin) FAILS a gate, rather than being merely advisory ("fast on this host").
 *
 * The /math-olympiad spine: the critical path is a sound LOWER bound (no schedule can finish a DAG
 * before its longest weighted chain), so a measurement BELOW the bound is impossible (a measurement
 * error) and a measurement ABOVE bound+margin is a real regression -- both caught. This turns
 * "fast on my machine" into "provably within its derived bound."  Compiler-UNREFERENCED -> LIBNATIVE.
 * Hexad: kind_essence.  Ring: R0.  NIH: composes unified_cost_manifold (§C.8) only.  K: 1.00. */
module numera_cost_lattice_unified

extern @abi(c-msvc-x64) fn uc_reset() -> i32 from "unified_cost_manifold.iii"
extern @abi(c-msvc-x64) fn uc_set_op(latency: u64, energy: u64, regs: u64, dcache: u64) -> i64 from "unified_cost_manifold.iii"
extern @abi(c-msvc-x64) fn uc_add_dep(a: u32, b: u32) -> i32 from "unified_cost_manifold.iii"
extern @abi(c-msvc-x64) fn uc_formula_latency() -> u64 from "unified_cost_manifold.iii"

/* the derived cycle bound for the currently-loaded op/dep graph = its critical path. */
fn clu_derived_bound() -> u64 @export { return uc_formula_latency() }

/* the regression gate: a measured cycle count is ACCEPTABLE iff it is >= the analytic lower bound
 * (below is impossible) AND <= bound + margin (above is a PROVABLE regression).  1 = within budget. */
fn clu_within_bound(measured: u64, margin: u64) -> u8 @export {
    let bound : u64 = uc_formula_latency()
    let b : u64 = bound      /* settle the call result before arithmetic (iiis post-call trap safety) */
    let m : u64 = margin
    if measured < b { return 0u8 }          /* below the sound LOWER bound -> impossible / mis-measure */
    let upper : u64 = b + m
    if upper < b { return 1u8 }             /* b+m overflowed u64 -> true bound+margin exceeds any u64 measured -> within budget */
    if measured > upper { return 0u8 }      /* exceeds bound+margin -> a PROVABLE regression (FAIL) */
    return 1u8
}

var CLU_OUT : [u64; 1]

/* Self-test: the bound is the critical path of a known graph; a measurement at the bound or within
 * margin passes; below the bound or above bound+margin FAILS (a provable regression, not advisory).
 * 99 = pass. */
fn cost_lattice_unified_selftest() -> u64 @export {
    /* the §C.8 parallel example: critical path = 13 (longest branch 0-1-3 = 2+10+1). */
    uc_reset()
    uc_set_op(2u64, 1u64, 1u64, 0u64)   /* 0 */
    uc_set_op(10u64,1u64, 1u64, 0u64)   /* 1 */
    uc_set_op(3u64, 1u64, 1u64, 0u64)   /* 2 */
    uc_set_op(1u64, 1u64, 1u64, 0u64)   /* 3 */
    uc_add_dep(0u32,1u32)  uc_add_dep(0u32,2u32)  uc_add_dep(1u32,3u32)  uc_add_dep(2u32,3u32)
    if clu_derived_bound() != 13u64 { return 1u64 }
    /* at the bound -> within budget */
    if clu_within_bound(13u64, 5u64) != 1u8 { return 2u64 }
    /* within the host margin -> within budget */
    if clu_within_bound(18u64, 5u64) != 1u8 { return 3u64 }
    /* ABOVE bound+margin -> a PROVABLE regression (the headline negative arm) */
    if clu_within_bound(20u64, 5u64) != 0u8 { return 4u64 }
    /* BELOW the sound lower bound -> impossible / mis-measure (rejected) */
    if clu_within_bound(10u64, 5u64) != 0u8 { return 5u64 }
    /* the bound TRACKS the graph: a leaner graph (drop op 1's weight to 2) shortens the critical
     * path to max(0-1-3=2+2+1=5, 0-2-3=2+3+1=6)=6, so a 13-cycle measurement now REGRESSES. */
    uc_reset()
    uc_set_op(2u64, 1u64, 1u64, 0u64)
    uc_set_op(2u64, 1u64, 1u64, 0u64)   /* op 1 now cheap */
    uc_set_op(3u64, 1u64, 1u64, 0u64)
    uc_set_op(1u64, 1u64, 1u64, 0u64)
    uc_add_dep(0u32,1u32)  uc_add_dep(0u32,2u32)  uc_add_dep(1u32,3u32)  uc_add_dep(2u32,3u32)
    if clu_derived_bound() != 6u64 { return 6u64 }
    if clu_within_bound(13u64, 5u64) != 0u8 { return 7u64 }   /* 13 > 6+5=11 -> regression */
    if clu_within_bound(6u64, 5u64)  != 1u8 { return 8u64 }
    return 99u64
}
