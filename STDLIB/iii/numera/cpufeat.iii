/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\cpufeat.iii
 *
 * III STDLIB - numera::cpufeat  (P4.1: C-SEPARATED)
 *
 * Runtime CPU-feature detection via NATIVE CPUID + XGETBV (COMPILER/BOOT/
 * cpuid_helper.s), replacing the former kernel32 `IsProcessorFeaturePresent`
 * umbilical.  No kernel32, no msvcrt -- this module now bottoms out on the
 * silicon, under III's own consistency umbrella.
 *
 * Correctness note: the Win32 path under-reported SHA-NI (it queried a guessed
 * PF_* constant that returns 0 on this OS); native CPUID reads the authoritative
 * leaf-7 EBX[29] bit.  This is a verified improvement (differential KAT) and is
 * runtime-safe: sha256_dispatch always takes the software path, so no crypto
 * behaviour depends on the SHA bit -- only the hw_offload codegen hint.
 *
 * Public surface (each returns 0 or 1, summary returns u32):
 *   cpufeat_has_{sse2,sse41,aesni,avx2,avx512f,bmi2,sha,rdrand,rdseed,
 *                bmi1,popcnt,lzcnt}()
 *   cpufeat_summary() -> u32   bitmask: SSE2=0 SSE41=1 AESNI=2 AVX2=3 SHA=4
 *                              RDRAND=5 RDSEED=6 AVX512F=7 BMI2=8 AVX512DQ=9
 *                              BMI1=10 POPCNT=11 LZCNT=12
 *
 * CPUID map (Intel SDM): L1.EDX[26]=SSE2; L1.ECX[19]=SSE4.1,[23]=POPCNT,
 * [25]=AESNI,[27]=OSXSAVE,[30]=RDRAND; L7.0.EBX[3]=BMI1,[5]=AVX2,[8]=BMI2,
 * [16]=AVX512F,[18]=RDSEED,[29]=SHA; L0x80000001.ECX[5]=LZCNT (ABM).
 * AVX2/AVX-512 are AND-gated on XCR0 (XGETBV): bits 1,2 (mask 0x6)
 * for AVX2, bits 1,2,5,6,7 (mask 0xE6) for AVX-512 -- the OS-XSAVE half that a
 * raw CPUID would miss (#UD on EVEX otherwise).  bmi2 := avx2 (sound proxy: no
 * shipping x86-64 part has AVX-2 without BMI2).  BMI1/POPCNT/LZCNT are the
 * chip's OWN report, no proxy -- they gate which atoms enter the ISA-born
 * algebra (aether/isa_ontogenesis: the atom source is CPUID, never a menu).
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00 (pure runtime query).
 */

module numera_cpufeat

extern @abi(c-msvc-x64) fn iii_cpuid(leaf: u32, subleaf: u32, out: *u8) -> u64 from "cpuid_helper"
extern @abi(c-msvc-x64) fn iii_xgetbv(xcr: u32) -> u64 from "cpuid_helper"

const CPUFEAT_BIT_SSE2    : u32 = 0u32
const CPUFEAT_BIT_SSE41   : u32 = 1u32
const CPUFEAT_BIT_AESNI   : u32 = 2u32
const CPUFEAT_BIT_AVX2    : u32 = 3u32
const CPUFEAT_BIT_SHA     : u32 = 4u32
const CPUFEAT_BIT_RDRAND  : u32 = 5u32
const CPUFEAT_BIT_RDSEED  : u32 = 6u32
const CPUFEAT_BIT_AVX512F : u32 = 7u32
const CPUFEAT_BIT_BMI2    : u32 = 8u32
const CPUFEAT_BIT_AVX512DQ : u32 = 9u32   /* AVX-512DQ (CPUID.7.0:EBX[17]) [RIPPLE-8 / D-BI-1] */
const CPUFEAT_BIT_BMI1     : u32 = 10u32  /* BMI1: ANDN/BLSI/BLSMSK/BLSR/TZCNT (CPUID.7.0:EBX[3]) */
const CPUFEAT_BIT_POPCNT   : u32 = 11u32  /* POPCNT (CPUID.1:ECX[23])                              */
const CPUFEAT_BIT_LZCNT    : u32 = 12u32  /* LZCNT / ABM (CPUID.0x80000001:ECX[5])                 */

/* X17 forced-path enabler: an AND-mask over the summary so a KAT can force a feature
 * OFF and exercise the fallback path on any host (default all-ones = no override). */
var CPUFEAT_FORCE_MASK : u32 = 0xFFFFFFFFu32
fn cpufeat_force_mask(m: u32) -> i32 @export { CPUFEAT_FORCE_MASK = m ; return 0i32 }

/* 16-byte CPUID output scratch (module-global; no heap dependency). */
var CPUFEAT_OUT : [u8; 16]

fn cf_ld_u32(p: *u8, off: u64) -> u32 {
    let b0 : u32 = p[off] as u32
    let b1 : u32 = p[off + 1u64] as u32
    let b2 : u32 = p[off + 2u64] as u32
    let b3 : u32 = p[off + 3u64] as u32
    return b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32)
}

fn cf_bit(v: u32, pos: u32) -> u32 {
    let s : u32 = v >> pos
    return s & 1u32
}

fn cpufeat_summary() -> u32 @export {
    let buf : *u8 = (&CPUFEAT_OUT) as u64 as *u8
    iii_cpuid(1u32, 0u32, buf)
    let ecx1 : u32 = cf_ld_u32(buf, 8u64)
    let edx1 : u32 = cf_ld_u32(buf, 12u64)
    iii_cpuid(7u32, 0u32, buf)
    let ebx7 : u32 = cf_ld_u32(buf, 4u64)
    iii_cpuid(0x80000001u32, 0u32, buf)
    let ecx8 : u32 = cf_ld_u32(buf, 8u64)

    let sse2 : u32 = cf_bit(edx1, 26u32)
    let sse41 : u32 = cf_bit(ecx1, 19u32)
    let aesni : u32 = cf_bit(ecx1, 25u32)
    let rdrand : u32 = cf_bit(ecx1, 30u32)
    let osxsave : u32 = cf_bit(ecx1, 27u32)
    let sha : u32 = cf_bit(ebx7, 29u32)
    let rdseed : u32 = cf_bit(ebx7, 18u32)
    let avx2_bit : u32 = cf_bit(ebx7, 5u32)
    let avx512_bit : u32 = cf_bit(ebx7, 16u32)
    let avx512dq_bit : u32 = cf_bit(ebx7, 17u32)

    let mut avx2 : u32 = 0u32
    let mut avx512 : u32 = 0u32
    let mut avx512dq : u32 = 0u32
    if osxsave == 1u32 {
        let xcr0 : u64 = iii_xgetbv(0u32)
        let avxlanes : u64 = xcr0 & 6u64
        let av512lanes : u64 = xcr0 & 0xE6u64
        if avx2_bit == 1u32 {
            if avxlanes == 6u64 { avx2 = 1u32 }
        }
        if avx512_bit == 1u32 {
            if av512lanes == 0xE6u64 { avx512 = 1u32 }
        }
        if avx512dq_bit == 1u32 {
            if av512lanes == 0xE6u64 { avx512dq = 1u32 }   /* DQ requires the same AVX-512 OS-XSAVE lanes */
        }
    }
    let bmi2 : u32 = avx2
    let bmi1 : u32 = cf_bit(ebx7, 3u32)
    let popcnt : u32 = cf_bit(ecx1, 23u32)
    let lzcnt : u32 = cf_bit(ecx8, 5u32)

    let mut bits : u32 = 0u32
    let one : u32 = 1u32
    if sse2 == 1u32   { bits = bits | (one << CPUFEAT_BIT_SSE2) }
    if sse41 == 1u32  { bits = bits | (one << CPUFEAT_BIT_SSE41) }
    if aesni == 1u32  { bits = bits | (one << CPUFEAT_BIT_AESNI) }
    if avx2 == 1u32   { bits = bits | (one << CPUFEAT_BIT_AVX2) }
    if sha == 1u32    { bits = bits | (one << CPUFEAT_BIT_SHA) }
    if rdrand == 1u32 { bits = bits | (one << CPUFEAT_BIT_RDRAND) }
    if rdseed == 1u32 { bits = bits | (one << CPUFEAT_BIT_RDSEED) }
    if avx512 == 1u32 { bits = bits | (one << CPUFEAT_BIT_AVX512F) }
    if avx512dq == 1u32 { bits = bits | (one << CPUFEAT_BIT_AVX512DQ) }
    if bmi2 == 1u32   { bits = bits | (one << CPUFEAT_BIT_BMI2) }
    if bmi1 == 1u32   { bits = bits | (one << CPUFEAT_BIT_BMI1) }
    if popcnt == 1u32 { bits = bits | (one << CPUFEAT_BIT_POPCNT) }
    if lzcnt == 1u32  { bits = bits | (one << CPUFEAT_BIT_LZCNT) }
    return bits
}

/* APOTHEOSIS S.5: memoize the summary.  cpufeat_summary() re-runs CPUID(1) +
 * CPUID(7) + XGETBV on EVERY call; every cpufeat_has_* dispatch went through it,
 * so a hot crypto dispatch re-serialised CPUID per call.  Compute ONCE, cache the
 * u32 bitmask.  The FORCE_MASK override stays PER-CALL (applied to the cached raw
 * summary in cf_has), so the KAT force-path still exercises fallbacks. */
var CPUFEAT_SUMMARY_CACHE : u32 = 0u32
var CPUFEAT_CACHED        : u8  = 0u8
fn cpufeat_summary_cached() -> u32 @export {
    if CPUFEAT_CACHED == 1u8 { return CPUFEAT_SUMMARY_CACHE }
    let s : u32 = cpufeat_summary()
    CPUFEAT_SUMMARY_CACHE = s
    CPUFEAT_CACHED = 1u8
    return s
}

fn cf_has(b: u32) -> u8 {
    let s : u32 = cpufeat_summary_cached() & CPUFEAT_FORCE_MASK
    let v : u32 = s >> b
    let w : u32 = v & 1u32
    if w == 1u32 { return 1u8 }
    return 0u8
}

fn cpufeat_has_sse2() -> u8 @export    { return cf_has(CPUFEAT_BIT_SSE2) }
fn cpufeat_has_sse41() -> u8 @export   { return cf_has(CPUFEAT_BIT_SSE41) }
fn cpufeat_has_aesni() -> u8 @export   { return cf_has(CPUFEAT_BIT_AESNI) }
fn cpufeat_has_avx2() -> u8 @export    { return cf_has(CPUFEAT_BIT_AVX2) }
fn cpufeat_has_avx512f() -> u8 @export { return cf_has(CPUFEAT_BIT_AVX512F) }
fn cpufeat_has_avx512dq() -> u8 @export { return cf_has(CPUFEAT_BIT_AVX512DQ) }
fn cpufeat_has_bmi2() -> u8 @export    { return cf_has(CPUFEAT_BIT_BMI2) }
fn cpufeat_has_sha() -> u8 @export     { return cf_has(CPUFEAT_BIT_SHA) }
fn cpufeat_has_rdrand() -> u8 @export  { return cf_has(CPUFEAT_BIT_RDRAND) }
fn cpufeat_has_rdseed() -> u8 @export  { return cf_has(CPUFEAT_BIT_RDSEED) }
fn cpufeat_has_bmi1() -> u8 @export    { return cf_has(CPUFEAT_BIT_BMI1) }
fn cpufeat_has_popcnt() -> u8 @export  { return cf_has(CPUFEAT_BIT_POPCNT) }
fn cpufeat_has_lzcnt() -> u8 @export   { return cf_has(CPUFEAT_BIT_LZCNT) }

/* ============================================================================================================
 * CPU SELF-IDENTITY via native CPUID -- the UNIVERSAL, UNPRIVILEGED, side-effect-free, VIRTUALIZATION-TRANSPARENT
 * oracle present on every x86-64 machine.  These DERIVE the host's identity from the silicon, with NO hardcoded
 * facts: leaf 0 = vendor string (EBX/EDX/ECX); leaf 1 EAX = family/model/stepping, EBX[23:16] = logical-processor
 * count, ECX[31] = hypervisor-present; leaf 0x40000000 EBX = hypervisor vendor (when virtualized -- a hypervisor
 * MUST answer here or stay invisible, so III reads the truth either way).  This is the safe, stable LATCH from which
 * III reads its host's DNA on ANY machine without privilege and without risk -- the dual of the bootstrap's trust
 * seed: the bottom anchor of the descent. */
fn cf_cpuid_word(leaf: u32, off: u64) -> u32 {
    let buf : *u8 = (&CPUFEAT_OUT) as u64 as *u8
    iii_cpuid(leaf, 0u32, buf)
    return cf_ld_u32(buf, off)
}
fn cpufeat_vendor_ebx() -> u32 @export { return cf_cpuid_word(0u32, 4u64) }
fn cpufeat_vendor_edx() -> u32 @export { return cf_cpuid_word(0u32, 12u64) }
fn cpufeat_vendor_ecx() -> u32 @export { return cf_cpuid_word(0u32, 8u64) }
fn cpufeat_fms() -> u32 @export { return cf_cpuid_word(1u32, 0u64) }
fn cpufeat_logical_count() -> u32 @export { let ebx : u32 = cf_cpuid_word(1u32, 4u64)  return (ebx >> 16u32) & 0xFFu32 }
fn cpufeat_hypervisor_present() -> u8 @export { let ecx : u32 = cf_cpuid_word(1u32, 8u64)  if cf_bit(ecx, 31u32) == 1u32 { return 1u8 }  return 0u8 }
fn cpufeat_hv_ebx() -> u32 @export { return cf_cpuid_word(0x40000000u32, 4u64) }
