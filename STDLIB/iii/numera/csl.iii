/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\csl.iii
 *
 * III STDLIB - numera::csl  --  CONCURRENT SEPARATION LOGIC: NON-INTERFERENCE.
 *
 * THE CAPSTONE of the state/memory layer.  It fuses the three pillars below it into the single theorem
 * that makes concurrency tractable:
 *
 *     if two threads own DISJOINT memory footprints (the separating conjunction  F_A * F_B), then their
 *     concurrent execution is INTERLEAVING-INDEPENDENT: every interleaving produces the exact same result.
 *
 * Equivalently -- "an optimization in Thread A mathematically cannot break Thread B, because their memory
 * footprints are proven disjoint."  This is the concurrent frame rule: a thread reasons about its own
 * memory in isolation, and the rest of the system provably cannot perturb it.
 *
 * Fusion:
 *   - numera::heaplet  : the two footprints are heaplets; hl_disjoint witnesses  F_A * F_B  (separation).
 *   - numera::tso (idea): the result is checked over EVERY interleaving (here, exhaustive SC interleavings,
 *                         enumerated as the C(nA+nB, nA) merges of the two op streams).
 *   - the separation principle: disjoint footprints => no communication => no interference.
 *
 * Verified (csl_kat): for disjoint-footprint thread pairs, hl_disjoint=1 AND all interleavings AGREE
 * (interleaving-independent => deterministic concurrency); and the NEGATIVE -- a SHARED cell makes
 * hl_disjoint=0 AND makes interleavings DISAGREE (a load races a store), so the disjointness premise is
 * load-bearing.  This is the byte-level proof that disjoint ownership defeats data races.
 *
 * NIH; composes numera::heaplet.  Public API:
 *   csl_set_a(i,op,cell,val) / csl_set_b(...) / csl_lens(nA,nB)
 *   csl_footprints_disjoint() -> u32     (the separation witness, via heaplet)
 *   csl_interleavings_agree() -> u32     (non-interference: every interleaving yields the same result)
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_csl

extern @abi(c-msvc-x64) fn hl_init() -> i32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_empty() -> u32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_set(h: u32, a: u32, v: u32) -> i32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_disjoint(h1: u32, h2: u32) -> u32 from "heaplet.iii"

const C_STORE : u32 = 0u32
const C_LOAD  : u32 = 1u32

var A_OP : [u32; 8]
var A_CELL : [u32; 8]
var A_VAL : [u32; 8]
var B_OP : [u32; 8]
var B_CELL : [u32; 8]
var B_VAL : [u32; 8]
var CSL_NA : [u32; 1]
var CSL_NB : [u32; 1]

var CSL_MEM : [u32; 16]
var CSL_TA  : [u32; 16]
var CSL_TB  : [u32; 16]
var CSL_RES : [u32; 64]
var CSL_REF : [u32; 64]
var CSL_RLEN : [u32; 1]

fn csl_lens(na: u32, nb: u32) -> i32 @export { CSL_NA[0u32] = na ; CSL_NB[0u32] = nb ; return 0i32 }
fn csl_set_a(i: u32, op: u32, cell: u32, val: u32) -> i32 @export {
    A_OP[i as u64] = op ; A_CELL[i as u64] = cell ; A_VAL[i as u64] = val ; return 0i32
}
fn csl_set_b(i: u32, op: u32, cell: u32, val: u32) -> i32 @export {
    B_OP[i as u64] = op ; B_CELL[i as u64] = cell ; B_VAL[i as u64] = val ; return 0i32
}

/* the separation witness F_A * F_B, decided by heaplet disjoint-union definedness. */
fn csl_footprints_disjoint() -> u32 @export {
    hl_init()
    let ha : u32 = hl_empty()
    let hb : u32 = hl_empty()
    let na : u32 = CSL_NA[0u32]
    let nb : u32 = CSL_NB[0u32]
    let mut i : u32 = 0u32
    while i < na { hl_set(ha, A_CELL[i as u64], 1u32) ; i = i + 1u32 }
    let mut j : u32 = 0u32
    while j < nb { hl_set(hb, B_CELL[j as u64], 1u32) ; j = j + 1u32 }
    return hl_disjoint(ha, hb)
}

fn csl_popcount(m: u32) -> u32 {
    let mut x : u32 = m
    let mut n : u32 = 0u32
    while x != 0u32 { n = n + (x & 1u32) ; x = x >> 1u32 }
    return n
}

/* run one interleaving (bit step=1 -> B advances, 0 -> A advances) into CSL_RES; len in CSL_RLEN. */
fn csl_run_inter(mask: u32, total: u32) {
    let mut p : u32 = 0u32
    while p < 16u32 { CSL_MEM[p as u64] = 0u32 ; p = p + 1u32 }
    let mut pca : u32 = 0u32
    let mut pcb : u32 = 0u32
    let mut tai : u32 = 0u32
    let mut tbi : u32 = 0u32
    let mut step : u32 = 0u32
    while step < total {
        if ((mask >> step) & 1u32) == 1u32 {
            let op : u32 = B_OP[pcb as u64]
            let cell : u32 = B_CELL[pcb as u64]
            if op == C_STORE { CSL_MEM[cell as u64] = B_VAL[pcb as u64] }
            else { CSL_TB[tbi as u64] = CSL_MEM[cell as u64] ; tbi = tbi + 1u32 }
            pcb = pcb + 1u32
        } else {
            let op : u32 = A_OP[pca as u64]
            let cell : u32 = A_CELL[pca as u64]
            if op == C_STORE { CSL_MEM[cell as u64] = A_VAL[pca as u64] }
            else { CSL_TA[tai as u64] = CSL_MEM[cell as u64] ; tai = tai + 1u32 }
            pca = pca + 1u32
        }
        step = step + 1u32
    }
    /* assemble result = A-trace ++ B-trace ++ final memory */
    let mut ri : u32 = 0u32
    let mut i : u32 = 0u32
    while i < tai { CSL_RES[ri as u64] = CSL_TA[i as u64] ; ri = ri + 1u32 ; i = i + 1u32 }
    let mut k : u32 = 0u32
    while k < tbi { CSL_RES[ri as u64] = CSL_TB[k as u64] ; ri = ri + 1u32 ; k = k + 1u32 }
    let mut m : u32 = 0u32
    while m < 16u32 { CSL_RES[ri as u64] = CSL_MEM[m as u64] ; ri = ri + 1u32 ; m = m + 1u32 }
    CSL_RLEN[0u32] = ri
}

/* NON-INTERFERENCE: 1 iff EVERY valid interleaving produces an identical result. */
fn csl_interleavings_agree() -> u32 @export {
    let na : u32 = CSL_NA[0u32]
    let nb : u32 = CSL_NB[0u32]
    let total : u32 = na + nb
    let limit : u32 = 1u32 << total
    let mut first : u32 = 1u32
    let mut reflen : u32 = 0u32
    let mut mask : u32 = 0u32
    while mask < limit {
        if csl_popcount(mask) == nb {           /* exactly nb B-steps, na A-steps */
            csl_run_inter(mask, total)
            if first == 1u32 {
                reflen = CSL_RLEN[0u32]
                let mut i : u32 = 0u32
                while i < reflen { CSL_REF[i as u64] = CSL_RES[i as u64] ; i = i + 1u32 }
                first = 0u32
            } else {
                let mut i : u32 = 0u32
                while i < reflen { if CSL_RES[i as u64] != CSL_REF[i as u64] { return 0u32 } ; i = i + 1u32 }
            }
        }
        mask = mask + 1u32
    }
    return 1u32
}

/* ===== KAT ===== */

/* scenario DISJOINT: A owns {0,1}, B owns {8,9}; each reads its own writes. */
fn csl_load_disjoint() {
    csl_lens(4u32, 4u32)
    csl_set_a(0u32, C_STORE, 0u32, 10u32)
    csl_set_a(1u32, C_STORE, 1u32, 20u32)
    csl_set_a(2u32, C_LOAD,  0u32, 0u32)
    csl_set_a(3u32, C_LOAD,  1u32, 0u32)
    csl_set_b(0u32, C_STORE, 8u32, 80u32)
    csl_set_b(1u32, C_LOAD,  8u32, 0u32)
    csl_set_b(2u32, C_STORE, 9u32, 90u32)
    csl_set_b(3u32, C_LOAD,  9u32, 0u32)
}

/* scenario OVERLAP: A owns {1,2}, B owns {1,3}; B LOADS the shared cell 1 that A STORES. */
fn csl_load_overlap() {
    csl_lens(3u32, 2u32)
    csl_set_a(0u32, C_STORE, 1u32, 77u32)
    csl_set_a(1u32, C_LOAD,  1u32, 0u32)
    csl_set_a(2u32, C_STORE, 2u32, 88u32)
    csl_set_b(0u32, C_LOAD,  1u32, 0u32)         /* races A's store to cell 1 */
    csl_set_b(1u32, C_STORE, 3u32, 99u32)
}

/* scenario DISJOINT-2: A owns {3,4,5}, B owns {12,13}; non-trivial values. */
fn csl_load_disjoint2() {
    csl_lens(3u32, 3u32)
    csl_set_a(0u32, C_STORE, 3u32, 111u32)
    csl_set_a(1u32, C_STORE, 4u32, 222u32)
    csl_set_a(2u32, C_LOAD,  3u32, 0u32)
    csl_set_b(0u32, C_STORE, 12u32, 33u32)
    csl_set_b(1u32, C_LOAD,  12u32, 0u32)
    csl_set_b(2u32, C_STORE, 13u32, 44u32)
}

/* =====================================================================================
 * csl_kat -- 99 = the CSL non-interference theorem, self-checked:
 *   (1) DISJOINT footprints: hl_disjoint=1 (F_A * F_B holds) AND every interleaving AGREES
 *       (concurrency is deterministic -- Thread A cannot perturb Thread B);
 *   (2) DISJOINT-2 (a second, different disjoint pair): same -- non-vacuous;
 *   (3) NEGATIVE -- OVERLAPPING footprints: hl_disjoint=0 (separation fails) AND interleavings DISAGREE
 *       (B's load of the shared cell races A's store), so the disjointness premise is load-bearing.
 * ===================================================================================== */
fn csl_kat() -> u64 @export {
    /* (1) disjoint */
    csl_load_disjoint()
    if csl_footprints_disjoint() != 1u32 { return 1u64 }
    if csl_interleavings_agree() != 1u32 { return 2u64 }

    /* (2) a second disjoint scenario */
    csl_load_disjoint2()
    if csl_footprints_disjoint() != 1u32 { return 3u64 }
    if csl_interleavings_agree() != 1u32 { return 4u64 }

    /* (3) NEGATIVE: overlapping footprints -> interference */
    csl_load_overlap()
    if csl_footprints_disjoint() != 0u32 { return 5u64 }     /* separation MUST fail */
    if csl_interleavings_agree() != 0u32 { return 6u64 }     /* interleavings MUST disagree */

    return 99u64
}
