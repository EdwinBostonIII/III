/* III/STDLIB/iii/numera/curry_howard.iii
 *
 * numera::curry_howard -- the operational Curry-Howard correspondence.
 * Programs (tag 0x50 'P') and proof terms (tag 0x54 'T') are syntactic
 * variants: the map is a canonical structural rewrite -- toggle the lead
 * tag, copy the body verbatim -- and the two directions are exact
 * inverses by construction (clause cp_curry_howard_total, M11). Each
 * translation publishes a witnessed v3 fragment (kind 0x15 / 0x16).
 *
 * Hexad: kind_essence + kind_cognition.  Ring: R0.  K: 1.00.
 * NIH: identifier.iii, keccak256.iii, witness_hook.iii (all built).
 * Non-reentrant: shared module-scope scratch + shared keccak256 sponge;
 *   called on the serialized admission path (cf. witness_hook.iii).
 * Discipline: W2 (5-param CH surface retained by ABI, see spec G7), W9,
 *   W10, W11/Trap3 (equality-only sentinel tests), W14 (sentinel loops,
 *   no break), W15 (no recursion -- the rewrite is a flat bounded copy),
 *   M19 (CURRYH_MAX_BODY bounds every copy/hash).
 */

module numera_curry_howard

extern @abi(c-msvc-x64) fn ident_zero(out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn cad_begin(suite: u32) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_payload(payload: u64, payload_len: u64) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_final(out_32: u64) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn keccak256_oneshot(msg_ptr: u64, msg_len: u64, out_ptr: u64) -> i32 from "keccak256.iii"
extern @abi(c-msvc-x64) fn wh_init(initial_time: u64) -> i32 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn wh_publish(producer: *u8, opid: *u8, in_commit: *u8, out_commit: *u8, revtag: u8, phase: u8, pillar: u16, antecedents: *u8, n_ante: u32, payload: *u8, payload_len: u32, out_frag_id: *u8) -> u64 from "witness_hook.iii"

const CURRYH_OK                      : i32 =  0i32
const CURRYH_E_NULL                  : i32 = -1i32
const CURRYH_E_BUF_TOO_SMALL         : i32 = -2i32
const CURRYH_E_MALFORMED             : i32 = -3i32
const CURRYH_E_NO_CORRESPONDENCE     : i32 = -4i32
const CURRYH_E_WITNESS               : i32 = -5i32
const CURRYH_TAG_PROGRAM             : u8  = 0x50u8
const CURRYH_TAG_PROOF               : u8  = 0x54u8
const CURRYH_V3_MAGIC                : u8  = 0xE3u8
const CURRYH_FRAG_PROGRAM_FROM_PROOF : u8  = 0x15u8
const CURRYH_FRAG_PROOF_FROM_PROGRAM : u8  = 0x16u8
const CURRYH_PAYLOAD_LEN             : u64 = 72u64
const CURRYH_MAX_BODY                : u64 = 67108863u64

var CURRYH_IN_C      : [u8; 32]    /* input commitment digest        */
var CURRYH_OUT_C     : [u8; 32]    /* output commitment digest       */
var CURRYH_PAYLOAD   : [u8; 72]    /* v3 marker fragment payload      */
var CURRYH_PRODUCER  : [u8; 32]    /* canonical zero producer id      */
var CURRYH_OP        : [u8; 32]    /* canonical zero op id            */
var CURRYH_TAG1      : [u8; 1]     /* single-byte toggled-tag stage   */
var CURRYH_FRAG_SINK : [u8; 32]    /* frag id sink / KAT scratch      */

/* KAT-only module-scope input buffers (Trap 7: no local var arrays). */
var CURRYH_KAT_PROG  : [u8; 8]
var CURRYH_KAT_PROOF : [u8; 8]
var CURRYH_KAT_OUT   : [u8; 8]
var CURRYH_KAT_RT    : [u8; 8]
var CURRYH_KAT_REF   : [u8; 32]
var CURRYH_KAT_LEN   : [u64; 1]

/* ch_program_to_proof: toggle lead tag 0x50 -> 0x54, copy body verbatim. */
fn ch_program_to_proof(program: *u8, program_len: u64, out_proof: *u8, out_proof_cap: u64, out_len: *u64) -> i32 @export {
    if (program as u64) == 0u64 { return CURRYH_E_NULL }
    if (out_proof as u64) == 0u64 { return CURRYH_E_NULL }
    if (out_len as u64) == 0u64 { return CURRYH_E_NULL }
    if program_len < 1u64 { return CURRYH_E_MALFORMED }
    if program_len > CURRYH_MAX_BODY { return CURRYH_E_MALFORMED }
    if program[0u64] != CURRYH_TAG_PROGRAM { return CURRYH_E_MALFORMED }
    if out_proof_cap < program_len { return CURRYH_E_BUF_TOO_SMALL }
    out_proof[0u64] = CURRYH_TAG_PROOF
    let mut i : u64 = 1u64
    while i < program_len {
        out_proof[i] = program[i]
        i = i + 1u64
    }
    out_len[0u64] = program_len
    return CURRYH_OK
}

/* ch_proof_to_program: inverse -- toggle lead tag 0x54 -> 0x50, copy body. */
fn ch_proof_to_program(proof: *u8, proof_len: u64, out_prog: *u8, out_prog_cap: u64, out_len: *u64) -> i32 @export {
    if (proof as u64) == 0u64 { return CURRYH_E_NULL }
    if (out_prog as u64) == 0u64 { return CURRYH_E_NULL }
    if (out_len as u64) == 0u64 { return CURRYH_E_NULL }
    if proof_len < 1u64 { return CURRYH_E_MALFORMED }
    if proof_len > CURRYH_MAX_BODY { return CURRYH_E_MALFORMED }
    if proof[0u64] != CURRYH_TAG_PROOF { return CURRYH_E_MALFORMED }
    if out_prog_cap < proof_len { return CURRYH_E_BUF_TOO_SMALL }
    out_prog[0u64] = CURRYH_TAG_PROGRAM
    let mut i : u64 = 1u64
    while i < proof_len {
        out_prog[i] = proof[i]
        i = i + 1u64
    }
    out_len[0u64] = proof_len
    return CURRYH_OK
}

/* ch_verify_correspondence: 1 iff program/proof are the same body under the
 * tag toggle.  XOR/OR fold over the whole body (no early break -- W14). */
fn ch_verify_correspondence(program: *u8, program_len: u64, proof: *u8, proof_len: u64) -> u8 @export {
    if (program as u64) == 0u64 { return 0u8 }
    if (proof as u64) == 0u64 { return 0u8 }
    if program_len != proof_len { return 0u8 }
    if program_len < 1u64 { return 0u8 }
    if program[0u64] != CURRYH_TAG_PROGRAM { return 0u8 }
    if proof[0u64] != CURRYH_TAG_PROOF { return 0u8 }
    let mut acc : u32 = 0u32
    let mut i : u64 = 1u64
    while i < program_len {
        acc = acc | ((program[i] as u32) ^ (proof[i] as u32))
        i = i + 1u64
    }
    if acc == 0u32 { return 1u8 }
    return 0u8
}

/* ch_emit_program_from_proof: publish a witnessed PROGRAM_FROM_PROOF (kind
 * 0x15) fragment.  in_commit = Keccak256(proof); out_commit =
 * Keccak256(0x50 || proof[1..]) computed streaming (program never built). */
fn ch_emit_program_from_proof(proof: *u8, proof_len: u64, out_frag_id: *u8) -> i32 @export {
    if (proof as u64) == 0u64 { return CURRYH_E_NULL }
    if (out_frag_id as u64) == 0u64 { return CURRYH_E_NULL }
    if proof_len < 1u64 { return CURRYH_E_MALFORMED }
    if proof_len > CURRYH_MAX_BODY { return CURRYH_E_MALFORMED }
    cad_begin(1u32)
    cad_payload(proof as u64, proof_len)
    cad_final((&CURRYH_IN_C as u64))
    CURRYH_TAG1[0u64] = CURRYH_TAG_PROGRAM
    cad_begin(1u32)
    cad_payload((&CURRYH_TAG1 as u64), 1u64)
    cad_payload(((proof as u64) + 1u64), proof_len - 1u64)
    cad_final((&CURRYH_OUT_C as u64))
    let mut z : u64 = 0u64
    while z < CURRYH_PAYLOAD_LEN {
        CURRYH_PAYLOAD[z] = 0u8
        z = z + 1u64
    }
    CURRYH_PAYLOAD[0u64] = CURRYH_V3_MAGIC
    CURRYH_PAYLOAD[1u64] = CURRYH_FRAG_PROGRAM_FROM_PROOF
    let mut k : u64 = 0u64
    while k < 32u64 {
        CURRYH_PAYLOAD[8u64 + k] = CURRYH_IN_C[k]
        CURRYH_PAYLOAD[40u64 + k] = CURRYH_OUT_C[k]
        k = k + 1u64
    }
    ident_zero((&CURRYH_PRODUCER as u64) as *u8)
    ident_zero((&CURRYH_OP as u64) as *u8)
    let nullante : *u8 = 0u64 as *u8
    let fid : u64 = wh_publish((&CURRYH_PRODUCER as u64) as *u8, (&CURRYH_OP as u64) as *u8, (&CURRYH_IN_C as u64) as *u8, (&CURRYH_OUT_C as u64) as *u8, 0u8, 0u8, 0u16, nullante, 0u32, (&CURRYH_PAYLOAD as u64) as *u8, CURRYH_PAYLOAD_LEN as u32, out_frag_id)
    if fid == 0xFFFFFFFFFFFFFFFFu64 { return CURRYH_E_WITNESS }
    return CURRYH_OK
}

/* ch_emit_proof_from_program: publish a witnessed PROOF_FROM_PROGRAM (kind
 * 0x16) fragment.  in_commit = Keccak256(program); out_commit =
 * Keccak256(0x54 || program[1..]) computed streaming. */
fn ch_emit_proof_from_program(program: *u8, program_len: u64, out_frag_id: *u8) -> i32 @export {
    if (program as u64) == 0u64 { return CURRYH_E_NULL }
    if (out_frag_id as u64) == 0u64 { return CURRYH_E_NULL }
    if program_len < 1u64 { return CURRYH_E_MALFORMED }
    if program_len > CURRYH_MAX_BODY { return CURRYH_E_MALFORMED }
    cad_begin(1u32)
    cad_payload(program as u64, program_len)
    cad_final((&CURRYH_IN_C as u64))
    CURRYH_TAG1[0u64] = CURRYH_TAG_PROOF
    cad_begin(1u32)
    cad_payload((&CURRYH_TAG1 as u64), 1u64)
    cad_payload(((program as u64) + 1u64), program_len - 1u64)
    cad_final((&CURRYH_OUT_C as u64))
    let mut z : u64 = 0u64
    while z < CURRYH_PAYLOAD_LEN {
        CURRYH_PAYLOAD[z] = 0u8
        z = z + 1u64
    }
    CURRYH_PAYLOAD[0u64] = CURRYH_V3_MAGIC
    CURRYH_PAYLOAD[1u64] = CURRYH_FRAG_PROOF_FROM_PROGRAM
    let mut k : u64 = 0u64
    while k < 32u64 {
        CURRYH_PAYLOAD[8u64 + k] = CURRYH_IN_C[k]
        CURRYH_PAYLOAD[40u64 + k] = CURRYH_OUT_C[k]
        k = k + 1u64
    }
    ident_zero((&CURRYH_PRODUCER as u64) as *u8)
    ident_zero((&CURRYH_OP as u64) as *u8)
    let nullante : *u8 = 0u64 as *u8
    let fid : u64 = wh_publish((&CURRYH_PRODUCER as u64) as *u8, (&CURRYH_OP as u64) as *u8, (&CURRYH_IN_C as u64) as *u8, (&CURRYH_OUT_C as u64) as *u8, 0u8, 0u8, 0u16, nullante, 0u32, (&CURRYH_PAYLOAD as u64) as *u8, CURRYH_PAYLOAD_LEN as u32, out_frag_id)
    if fid == 0xFFFFFFFFFFFFFFFFu64 { return CURRYH_E_WITNESS }
    return CURRYH_OK
}

/* Self-test: K1..K7 per spec KAT Vectors.  99 = all pass; else first failing
 * case number.  Negative cases (K5/K7) prove the guards REJECT bad input. */
fn curryh_kat() -> u64 @export {
    /* K1: program -> proof, tag toggle + body identity. "Pabc" -> "Tabc". */
    CURRYH_KAT_PROG[0u64] = 0x50u8
    CURRYH_KAT_PROG[1u64] = 0x61u8
    CURRYH_KAT_PROG[2u64] = 0x62u8
    CURRYH_KAT_PROG[3u64] = 0x63u8
    CURRYH_KAT_LEN[0u64] = 0u64
    if ch_program_to_proof((&CURRYH_KAT_PROG as u64) as *u8, 4u64, (&CURRYH_KAT_OUT as u64) as *u8, 8u64, (&CURRYH_KAT_LEN as u64) as *u64) != CURRYH_OK { return 1u64 }
    if CURRYH_KAT_LEN[0u64] != 4u64 { return 2u64 }
    if CURRYH_KAT_OUT[0u64] != 0x54u8 { return 3u64 }
    if CURRYH_KAT_OUT[1u64] != 0x61u8 { return 4u64 }
    if CURRYH_KAT_OUT[2u64] != 0x62u8 { return 5u64 }
    if CURRYH_KAT_OUT[3u64] != 0x63u8 { return 6u64 }

    /* K2: proof -> program inverse direction. "Tabc" -> "Pabc". */
    CURRYH_KAT_PROOF[0u64] = 0x54u8
    CURRYH_KAT_PROOF[1u64] = 0x61u8
    CURRYH_KAT_PROOF[2u64] = 0x62u8
    CURRYH_KAT_PROOF[3u64] = 0x63u8
    CURRYH_KAT_LEN[0u64] = 0u64
    if ch_proof_to_program((&CURRYH_KAT_PROOF as u64) as *u8, 4u64, (&CURRYH_KAT_OUT as u64) as *u8, 8u64, (&CURRYH_KAT_LEN as u64) as *u64) != CURRYH_OK { return 7u64 }
    if CURRYH_KAT_LEN[0u64] != 4u64 { return 8u64 }
    if CURRYH_KAT_OUT[0u64] != 0x50u8 { return 9u64 }
    if CURRYH_KAT_OUT[1u64] != 0x61u8 { return 10u64 }
    if CURRYH_KAT_OUT[2u64] != 0x62u8 { return 11u64 }
    if CURRYH_KAT_OUT[3u64] != 0x63u8 { return 12u64 }

    /* K3: verify correspondence true / false. */
    if ch_verify_correspondence((&CURRYH_KAT_PROG as u64) as *u8, 4u64, (&CURRYH_KAT_PROOF as u64) as *u8, 4u64) != 1u8 { return 13u64 }
    /* mutate one body byte of the proof (0x62 -> 0x63) -> not corresponding */
    CURRYH_KAT_PROOF[2u64] = 0x63u8
    if ch_verify_correspondence((&CURRYH_KAT_PROG as u64) as *u8, 4u64, (&CURRYH_KAT_PROOF as u64) as *u8, 4u64) != 0u8 { return 14u64 }
    CURRYH_KAT_PROOF[2u64] = 0x62u8
    /* wrong proof tag (0x55) -> 0 */
    CURRYH_KAT_PROOF[0u64] = 0x55u8
    if ch_verify_correspondence((&CURRYH_KAT_PROG as u64) as *u8, 4u64, (&CURRYH_KAT_PROOF as u64) as *u8, 4u64) != 0u8 { return 15u64 }
    CURRYH_KAT_PROOF[0u64] = 0x54u8
    /* mismatched lengths -> 0 */
    if ch_verify_correspondence((&CURRYH_KAT_PROG as u64) as *u8, 4u64, (&CURRYH_KAT_PROOF as u64) as *u8, 3u64) != 0u8 { return 16u64 }

    /* K4: inverse-totality round-trip (M11). Body contains tag-valued bytes
     * 0x54/0x50 to prove only byte0 is touched.  program -> proof -> program. */
    CURRYH_KAT_PROG[0u64] = 0x50u8
    CURRYH_KAT_PROG[1u64] = 0x00u8
    CURRYH_KAT_PROG[2u64] = 0xFFu8
    CURRYH_KAT_PROG[3u64] = 0x10u8
    CURRYH_KAT_PROG[4u64] = 0x54u8
    CURRYH_KAT_LEN[0u64] = 0u64
    if ch_program_to_proof((&CURRYH_KAT_PROG as u64) as *u8, 5u64, (&CURRYH_KAT_OUT as u64) as *u8, 8u64, (&CURRYH_KAT_LEN as u64) as *u64) != CURRYH_OK { return 17u64 }
    if CURRYH_KAT_OUT[0u64] != 0x54u8 { return 18u64 }
    CURRYH_KAT_LEN[0u64] = 0u64
    if ch_proof_to_program((&CURRYH_KAT_OUT as u64) as *u8, 5u64, (&CURRYH_KAT_RT as u64) as *u8, 8u64, (&CURRYH_KAT_LEN as u64) as *u64) != CURRYH_OK { return 19u64 }
    let mut r : u64 = 0u64
    while r < 5u64 {
        if CURRYH_KAT_RT[r] != CURRYH_KAT_PROG[r] { return 20u64 }
        r = r + 1u64
    }
    /* symmetric: proof -> program -> proof on [0x54, ...] */
    CURRYH_KAT_PROOF[0u64] = 0x54u8
    CURRYH_KAT_PROOF[1u64] = 0x00u8
    CURRYH_KAT_PROOF[2u64] = 0xFFu8
    CURRYH_KAT_PROOF[3u64] = 0x10u8
    CURRYH_KAT_PROOF[4u64] = 0x50u8
    CURRYH_KAT_LEN[0u64] = 0u64
    if ch_proof_to_program((&CURRYH_KAT_PROOF as u64) as *u8, 5u64, (&CURRYH_KAT_OUT as u64) as *u8, 8u64, (&CURRYH_KAT_LEN as u64) as *u64) != CURRYH_OK { return 21u64 }
    if CURRYH_KAT_OUT[0u64] != 0x50u8 { return 22u64 }
    CURRYH_KAT_LEN[0u64] = 0u64
    if ch_program_to_proof((&CURRYH_KAT_OUT as u64) as *u8, 5u64, (&CURRYH_KAT_RT as u64) as *u8, 8u64, (&CURRYH_KAT_LEN as u64) as *u64) != CURRYH_OK { return 23u64 }
    r = 0u64
    while r < 5u64 {
        if CURRYH_KAT_RT[r] != CURRYH_KAT_PROOF[r] { return 24u64 }
        r = r + 1u64
    }

    /* K5: error paths -- prove the negative cases FAIL. */
    /* restore "Pabc" */
    CURRYH_KAT_PROG[0u64] = 0x50u8
    CURRYH_KAT_PROG[1u64] = 0x61u8
    CURRYH_KAT_PROG[2u64] = 0x62u8
    CURRYH_KAT_PROG[3u64] = 0x63u8
    /* program_len = 0 -> MALFORMED */
    if ch_program_to_proof((&CURRYH_KAT_PROG as u64) as *u8, 0u64, (&CURRYH_KAT_OUT as u64) as *u8, 8u64, (&CURRYH_KAT_LEN as u64) as *u64) != CURRYH_E_MALFORMED { return 25u64 }
    /* wrong lead tag 0x51 -> MALFORMED */
    CURRYH_KAT_PROG[0u64] = 0x51u8
    if ch_program_to_proof((&CURRYH_KAT_PROG as u64) as *u8, 4u64, (&CURRYH_KAT_OUT as u64) as *u8, 8u64, (&CURRYH_KAT_LEN as u64) as *u64) != CURRYH_E_MALFORMED { return 26u64 }
    CURRYH_KAT_PROG[0u64] = 0x50u8
    /* out_proof_cap = 2 < len = 4 -> BUF_TOO_SMALL */
    if ch_program_to_proof((&CURRYH_KAT_PROG as u64) as *u8, 4u64, (&CURRYH_KAT_OUT as u64) as *u8, 2u64, (&CURRYH_KAT_LEN as u64) as *u64) != CURRYH_E_BUF_TOO_SMALL { return 27u64 }
    /* null out_len -> NULL */
    let nulllen : *u64 = 0u64 as *u64
    if ch_program_to_proof((&CURRYH_KAT_PROG as u64) as *u8, 4u64, (&CURRYH_KAT_OUT as u64) as *u8, 8u64, nulllen) != CURRYH_E_NULL { return 28u64 }

    /* K6: witness commitment determinism (M10). Requires wh_init first. */
    wh_init(0u64)
    if ch_emit_proof_from_program((&CURRYH_KAT_PROG as u64) as *u8, 4u64, (&CURRYH_FRAG_SINK as u64) as *u8) != CURRYH_OK { return 29u64 }
    /* recompute Keccak256("Pabc") independently; must equal CURRYH_IN_C */
    keccak256_oneshot(&CURRYH_KAT_PROG as u64, 4u64, &CURRYH_KAT_REF as u64)
    let mut a : u64 = 0u64
    while a < 32u64 {
        if CURRYH_KAT_REF[a] != CURRYH_IN_C[a] { return 30u64 }
        a = a + 1u64
    }
    /* recompute Keccak256("Tabc"); must equal CURRYH_OUT_C (out = toggled prog) */
    CURRYH_KAT_PROOF[0u64] = 0x54u8
    CURRYH_KAT_PROOF[1u64] = 0x61u8
    CURRYH_KAT_PROOF[2u64] = 0x62u8
    CURRYH_KAT_PROOF[3u64] = 0x63u8
    keccak256_oneshot(&CURRYH_KAT_PROOF as u64, 4u64, &CURRYH_KAT_REF as u64)
    a = 0u64
    while a < 32u64 {
        if CURRYH_KAT_REF[a] != CURRYH_OUT_C[a] { return 31u64 }
        a = a + 1u64
    }

    /* K7: emit underflow guard -- proof_len = 0 must FAIL (not wrap len-1). */
    if ch_emit_program_from_proof((&CURRYH_KAT_PROOF as u64) as *u8, 0u64, (&CURRYH_FRAG_SINK as u64) as *u8) != CURRYH_E_MALFORMED { return 32u64 }

    return 99u64
}

fn curryh_selftest() -> u64 @export {
    return curryh_kat()
}
