/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\diophantine.iii
 *
 * III STDLIB - numera::diophantine
 *
 * LINEAR DIOPHANTINE SOLVER + EXTENDED EUCLID + MODULAR INVERSE.
 *
 * ROLE.  The decidable ISLAND of Hilbert's 10th problem: linear Diophantine equations a*x + b*y = c over the integers,
 * solved exactly by the extended Euclidean algorithm (Bezout).  a*x+b*y=c has an integer solution iff gcd(a,b) | c, and
 * when it does this faculty returns a particular solution; the general solution is x = x0 + k*(b/g), y = y0 - k*(a/g).
 * It also exposes the two primitives every modular-arithmetic client needs: gcd, the Bezout coefficients, and the
 * modular inverse a^-1 mod m.  It also provides the CHINESE REMAINDER primitive (dio_crt2) -- simultaneous congruences,
 * the wall's natural multi-modulus capability, built on the same ext-gcd machinery and handling NON-coprime moduli.
 * (General polynomial Diophantine solvability is UNDECIDABLE, MRDP -- the open core of the Diophantine wall; this is
 * exactly its decidable linear island, DOCS/III-DIOPHANTINE-WALL-FORMAL.md.)
 *
 * USE CASES.  Modular inverses (RSA/EC scalar ops, CRT recomposition, Barrett/Montgomery setup), solving congruences,
 * lattice/Bezout computations -- AVAILABLE for any client that re-derives extended Euclid inline to call instead; the
 * existing call sites are NOT yet migrated (today this module is a callable library, not wired into them).
 *
 * INVOCATION.
 *   dio_gcd(a, b) -> i64 (>=0).
 *   dio_ext_gcd(a, b) -> i64 gcd, and stores Bezout x,y with a*x + b*y = gcd; read via dio_bezout_x() / dio_bezout_y().
 *   dio_solve(a, b, c) -> 1 if solvable (gcd|c) else 0; on 1 stores a particular (x0,y0): dio_sol_x() / dio_sol_y().
 *   dio_mod_inverse(a, m) -> a^-1 mod m in [0,m), or -1 if gcd(a,m) != 1.
 *
 * IMPACTS / LIMITATIONS (honest).
 *   - EXACT over i64.  Inputs and the running Bezout coefficients must stay within i64 (no bignum); for cryptographic
 *     widths use the bigint path.  A documented domain bound, not a correctness gap.
 *   - dio_mod_inverse requires m > 0; the result is normalised to [0, m).
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 * Discipline: W1, W2, W13, W14, W15 (no recursion -- iterative extended Euclid).
 * Self-test: dio_kat() -> u64 returns 99 on full KAT pass.
 */
module diophantine

var DIO_X : [i64; 1]    /* Bezout x from the last dio_ext_gcd */
var DIO_Y : [i64; 1]    /* Bezout y */
var DIO_SX : [i64; 1]   /* particular x0 from the last dio_solve */
var DIO_SY : [i64; 1]   /* particular y0 */
var DIO_CRT_X : [i64; 1]    /* CRT solution x in [0, lcm) from the last dio_crt2 */
var DIO_CRT_MOD : [i64; 1]  /* the combined modulus lcm(m1,m2) */

fn dio_iabs(x: i64) -> i64 { if x < 0i64 { return 0i64 - x } return x }
fn dio_gcd(a: i64, b: i64) -> i64 @export {
    let mut x : i64 = dio_iabs(a)  let mut y : i64 = dio_iabs(b)
    while y != 0i64 { let t : i64 = x % y  x = y  y = t }
    return x
}
/* iterative extended Euclid on |a|,|b|, then fix signs for the original a,b; stores Bezout x,y */
fn dio_ext_gcd(a: i64, b: i64) -> i64 @export {
    let mut old_r : i64 = a  let mut r : i64 = b
    let mut old_s : i64 = 1i64  let mut s : i64 = 0i64
    let mut old_t : i64 = 0i64  let mut t : i64 = 1i64
    while r != 0i64 {
        let q : i64 = old_r / r
        let nr : i64 = old_r - q * r  old_r = r  r = nr
        let ns : i64 = old_s - q * s  old_s = s  s = ns
        let nt : i64 = old_t - q * t  old_t = t  t = nt
    }
    /* old_r may be negative if a<0/b<0; normalise gcd to >=0 and flip coefficients with it */
    if old_r < 0i64 { old_r = 0i64 - old_r  old_s = 0i64 - old_s  old_t = 0i64 - old_t }
    DIO_X[0u64] = old_s  DIO_Y[0u64] = old_t
    return old_r
}
fn dio_bezout_x() -> i64 @export { return DIO_X[0u64] }
fn dio_bezout_y() -> i64 @export { return DIO_Y[0u64] }
fn dio_solve(a: i64, b: i64, c: i64) -> u8 @export {
    let g : i64 = dio_ext_gcd(a, b)
    if g == 0i64 { if c == 0i64 { DIO_SX[0u64] = 0i64  DIO_SY[0u64] = 0i64  return 1u8 }  return 0u8 }  /* a=b=0 */
    if (c % g) != 0i64 { return 0u8 }
    let k : i64 = c / g
    DIO_SX[0u64] = DIO_X[0u64] * k  DIO_SY[0u64] = DIO_Y[0u64] * k
    return 1u8
}
fn dio_sol_x() -> i64 @export { return DIO_SX[0u64] }
fn dio_sol_y() -> i64 @export { return DIO_SY[0u64] }
fn dio_mod_inverse(a: i64, m: i64) -> i64 @export {
    if m <= 0i64 { return (0i64 - 1i64) }
    let g : i64 = dio_ext_gcd(a, m)
    if g != 1i64 { return (0i64 - 1i64) }
    /* a * DIO_X == 1 (mod m); normalise to [0,m) */
    let mut inv : i64 = DIO_X[0u64] % m
    if inv < 0i64 { inv = inv + m }
    return inv
}

/* CHINESE REMAINDER (the simultaneous-congruence capability of the Diophantine wall, built on ext-gcd).
 * Solve x == a1 (mod m1) and x == a2 (mod m2).  Solvable iff gcd(m1,m2) | (a2-a1); the solution is unique mod
 * lcm(m1,m2).  Handles NON-coprime moduli.  Returns 1 on solvable (x in [0,lcm) via dio_crt_x, lcm via dio_crt_mod),
 * 0 if no solution.  (i64 domain: m1*k and the intermediate products must stay within i64.) */
fn dio_crt2(a1: i64, m1: i64, a2: i64, m2: i64) -> u8 @export {
    if m1 <= 0i64 { return 0u8 }
    if m2 <= 0i64 { return 0u8 }
    let g : i64 = dio_ext_gcd(m1, m2)              /* sets DIO_X = Bezout x of m1: m1*DIO_X + m2*DIO_Y = g */
    let diff : i64 = a2 - a1
    if (diff % g) != 0i64 { return 0u8 }           /* unsolvable */
    let m2g : i64 = m2 / g
    /* (m1/g)*DIO_X == 1 (mod m2/g), so k0 = (diff/g)*DIO_X (mod m2/g) */
    let mut k0 : i64 = (((diff / g) % m2g) * (DIO_X[0u64] % m2g)) % m2g
    if k0 < 0i64 { k0 = k0 + m2g }
    let lcm : i64 = (m1 / g) * m2
    let mut x : i64 = a1 + m1 * k0
    x = ((x % lcm) + lcm) % lcm                     /* normalise to [0, lcm) */
    DIO_CRT_X[0u64] = x  DIO_CRT_MOD[0u64] = lcm
    return 1u8
}
fn dio_crt_x() -> i64 @export { return DIO_CRT_X[0u64] }
fn dio_crt_mod() -> i64 @export { return DIO_CRT_MOD[0u64] }

fn dio_kat() -> u64 @export {
    /* extended Euclid: 240*x + 46*y = gcd(240,46)=2 */
    let g1 : i64 = dio_ext_gcd(240i64, 46i64)
    if g1 != 2i64 { return 10u64 }
    if 240i64 * dio_bezout_x() + 46i64 * dio_bezout_y() != 2i64 { return 11u64 }
    /* solvable: 3x+5y=1 */
    if dio_solve(3i64, 5i64, 1i64) != 1u8 { return 12u64 }
    if 3i64 * dio_sol_x() + 5i64 * dio_sol_y() != 1i64 { return 13u64 }
    /* unsolvable: 2x+4y=3 (gcd 2 does not divide 3) */
    if dio_solve(2i64, 4i64, 3i64) != 0u8 { return 14u64 }
    /* solvable with a larger c: 6x+15y=21 (gcd 3 | 21) */
    if dio_solve(6i64, 15i64, 21i64) != 1u8 { return 15u64 }
    if 6i64 * dio_sol_x() + 15i64 * dio_sol_y() != 21i64 { return 16u64 }
    /* negative coefficients: -4x + 6y = 2 (gcd 2 | 2) */
    if dio_solve(0i64 - 4i64, 6i64, 2i64) != 1u8 { return 17u64 }
    if (0i64 - 4i64) * dio_sol_x() + 6i64 * dio_sol_y() != 2i64 { return 18u64 }
    /* modular inverse: 3^-1 mod 11 = 4 */
    if dio_mod_inverse(3i64, 11i64) != 4i64 { return 19u64 }
    if (3i64 * 4i64) % 11i64 != 1i64 { return 20u64 }
    /* no inverse: gcd(2,4) != 1 */
    if dio_mod_inverse(2i64, 4i64) != (0i64 - 1i64) { return 21u64 }
    /* gcd basics */
    if dio_gcd(0i64 - 240i64, 46i64) != 2i64 { return 22u64 }
    if dio_gcd(17i64, 0i64) != 17i64 { return 23u64 }
    /* CRT coprime: x==2 (mod 3), x==3 (mod 5) -> x=8, lcm=15 */
    if dio_crt2(2i64, 3i64, 3i64, 5i64) != 1u8 { return 24u64 }
    if dio_crt_x() != 8i64 { return 25u64 }
    if dio_crt_mod() != 15i64 { return 26u64 }
    /* CRT non-coprime solvable: x==1 (mod 6), x==4 (mod 9) -> x=13, lcm=18 */
    if dio_crt2(1i64, 6i64, 4i64, 9i64) != 1u8 { return 27u64 }
    if dio_crt_x() != 13i64 { return 28u64 }
    if dio_crt_mod() != 18i64 { return 29u64 }
    /* CRT non-coprime unsolvable: x==1 (mod 6), x==2 (mod 9) -> gcd 3 does not divide 1 */
    if dio_crt2(1i64, 6i64, 2i64, 9i64) != 0u8 { return 30u64 }
    return 99u64
}
