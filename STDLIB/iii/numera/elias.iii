/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\elias.iii
 *
 * III STDLIB - numera::elias
 *
 * Verified Elias gamma and delta universal codes for positive integers -- self-delimiting,
 * prefix-free variable-length codes (no length field needed; the codeword tells you where it ends).
 * The encoding behind inverted-index gap lists and integer-stream compression. Built on III's own
 * numera::bitio (module HARMONY -- it is the first real consumer of the bit substrate):
 *   gamma(n) = (bitlen(n)-1) zero bits, then n in bitlen(n) bits   -> 2*floor(log2 n)+1 bits
 *   delta(n) = gamma(bitlen(n)), then the low bitlen(n)-1 bits of n  -> better for large n
 *
 * The verified property is ROUND-TRIP IDENTITY across a stream: encoding a sequence of integers then
 * decoding it (with NO delimiters) reproduces every integer exactly -- which also proves the codes
 * are genuinely prefix-free. NIH; pure (consumes bitio).
 *
 * Public API:
 *   elias_bitlen(n) -> u32
 *   elias_gamma_put(n) / elias_gamma_get() -> u64        (n >= 1)
 *   elias_delta_put(n) / elias_delta_get() -> u64        (n >= 1)
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99 (pure; no allocation).
 */
module numera_elias

extern @abi(c-msvc-x64) fn bw_init(buf_ptr: u64, cap: u32) -> i32 from "bitio.iii"
extern @abi(c-msvc-x64) fn bw_put(v: u64, n: u32) -> i32 from "bitio.iii"
extern @abi(c-msvc-x64) fn bw_bytelen() -> u32 from "bitio.iii"
extern @abi(c-msvc-x64) fn br_init(buf_ptr: u64, len: u32) -> i32 from "bitio.iii"
extern @abi(c-msvc-x64) fn br_get(n: u32) -> u64 from "bitio.iii"

fn elias_bitlen(n: u64) -> u32 @export {
    let mut b : u32 = 0u32
    let mut x : u64 = n
    while x != 0u64 { b = b + 1u32 ; x = x >> 1u64 }
    return b
}

fn elias_gamma_put(n: u64) -> i32 @export {
    let b : u32 = elias_bitlen(n)
    if b > 1u32 { bw_put(0u64, b - 1u32) }    /* b-1 leading zeros */
    bw_put(n, b)                              /* n in b bits (MSB = 1) */
    return 0i32
}

fn elias_gamma_get() -> u64 @export {
    let mut z : u32 = 0u32
    while br_get(1u32) == 0u64 { z = z + 1u32 }   /* count zeros; the 1 we read is the value's MSB */
    let mut v : u64 = 1u64
    let mut i : u32 = 0u32
    while i < z {
        v = (v << 1u64) | br_get(1u32)
        i = i + 1u32
    }
    return v
}

fn elias_delta_put(n: u64) -> i32 @export {
    let b : u32 = elias_bitlen(n)
    elias_gamma_put(b as u64)                 /* encode the bit-length via gamma (b >= 1) */
    if b > 1u32 { bw_put(n, b - 1u32) }       /* the low b-1 bits of n (the MSB is implicit) */
    return 0i32
}

fn elias_delta_get() -> u64 @export {
    let b : u32 = elias_gamma_get() as u32
    let mut v : u64 = 1u64                     /* implicit leading 1 */
    let mut i : u32 = 0u32
    while i < (b - 1u32) {
        v = (v << 1u64) | br_get(1u32)
        i = i + 1u32
    }
    return v
}

/* ===== KAT ===== */
var EL_BUF  : [u8; 2048]
var EL_VALS : [u64; 300]
var EL_RNG  : [u64; 1]

fn el_rng() -> u64 {
    let mut z : u64 = EL_RNG[0u64]
    z = z ^ (z << 13u64)
    z = z ^ (z >> 7u64)
    z = z ^ (z << 17u64)
    EL_RNG[0u64] = z
    return z
}

/* =====================================================================================
 * elias_kat -- 99 = ROUND-TRIP IDENTITY of a delimiter-free integer stream under BOTH codes:
 *   (1) 200 random integers (1..2^20) gamma-encoded back to back, then decoded in order, recover
 *       every value EXACTLY (proving the code is genuinely prefix-free);
 *   (2) the same under delta;
 *   (3) edge values 1, 2, 2^20, and the bitlen oracle;
 *   (4) delta is no larger than gamma on the large-value stream.
 * ===================================================================================== */
fn elias_kat() -> u64 @export {
    EL_RNG[0u64] = 0xBB67AE8584CAA73Bu64
    let m : u32 = 200u32
    let mut i : u32 = 0u32
    while i < m {
        let r : u64 = el_rng()
        EL_VALS[i] = 1u64 + (r % 1048576u64)      /* 1..2^20 */
        i = i + 1u32
    }

    /* (1) gamma stream round-trip */
    bw_init(&EL_BUF as u64, 2048u32)
    let mut g : u32 = 0u32
    while g < m { elias_gamma_put(EL_VALS[g]) ; g = g + 1u32 }
    let glen : u32 = bw_bytelen()
    br_init(&EL_BUF as u64, glen)
    let mut gg : u32 = 0u32
    while gg < m {
        if elias_gamma_get() != EL_VALS[gg] { return 1000u64 + (gg as u64) }
        gg = gg + 1u32
    }

    /* (2) delta stream round-trip */
    bw_init(&EL_BUF as u64, 2048u32)
    let mut d : u32 = 0u32
    while d < m { elias_delta_put(EL_VALS[d]) ; d = d + 1u32 }
    let dlen : u32 = bw_bytelen()
    br_init(&EL_BUF as u64, dlen)
    let mut dd : u32 = 0u32
    while dd < m {
        if elias_delta_get() != EL_VALS[dd] { return 2000u64 + (dd as u64) }
        dd = dd + 1u32
    }

    /* (3) edges + bitlen oracle */
    if elias_bitlen(1u64) != 1u32 { return 3u64 }
    if elias_bitlen(2u64) != 2u32 { return 4u64 }
    if elias_bitlen(1048576u64) != 21u32 { return 5u64 }   /* 2^20 has 21 bits */
    bw_init(&EL_BUF as u64, 2048u32)
    elias_gamma_put(1u64) ; elias_delta_put(2u64) ; elias_gamma_put(1048576u64) ; elias_delta_put(1048576u64)
    let el : u32 = bw_bytelen()
    br_init(&EL_BUF as u64, el)
    if elias_gamma_get() != 1u64 { return 6u64 }
    if elias_delta_get() != 2u64 { return 7u64 }
    if elias_gamma_get() != 1048576u64 { return 8u64 }
    if elias_delta_get() != 1048576u64 { return 9u64 }

    /* (4) delta <= gamma on the large-value stream */
    if dlen > glen { return 10u64 }

    return 99u64
}
