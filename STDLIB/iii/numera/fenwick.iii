/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\fenwick.iii
 *
 * III STDLIB - numera::fenwick  --  FENWICK TREE / BINARY INDEXED TREE (verified).
 *
 * A Fenwick tree answers prefix-sum queries and applies point updates in O(log n) instead of O(n), by laying
 * the partial sums out along the binary structure of the indices: index j is responsible for the range of
 * length (j AND -j) -- its lowest set bit -- ending at j, so a prefix sum walks down the set bits and an
 * update walks up them.  The index arithmetic (the lowbit jumps, the 1-based offset) is famously error-prone,
 * so the III discipline VERIFIES the tree against a naive O(n) prefix sum for EVERY index after every update.
 *
 * Values [3,1,4,1,5,9,2,6]; prefix sums must match the naive reference; range [2,5] sums to 19; a point
 * update is reflected immediately and the tree still agrees with naive everywhere.
 *
 * Verified (fenwick_kat): every prefix sum equals the naive reference; a specific range sum is correct; a
 * point update changes exactly the right sums and the tree still agrees with naive at all indices; the lowbit
 * helper is correct.  NIH/self-contained.
 *
 * Public API:
 *   fen_init() ; fen_lowbit(x) -> u32 ; fen_update(i,delta) ; fen_prefix(i) -> u32 ; fen_range(l,r) -> u32 ;
 *   fen_naive_prefix(i) -> u32 ; fen_agree() -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_fenwick

const FEN_N : u32 = 8u32

var FEN_TREE : [u32; 9]       /* 1-indexed BIT, size N+1 */
var FEN_VAL  : [u32; 8]       /* the actual element values, for the naive reference */

fn fen_init() -> i32 @export {
    let mut i : u32 = 0u32
    while i <= FEN_N { FEN_TREE[i as u64] = 0u32 ; i = i + 1u32 }
    let mut k : u32 = 0u32
    while k < FEN_N { FEN_VAL[k as u64] = 0u32 ; k = k + 1u32 }
    return 0i32
}

/* the lowest set bit of x (the range length index x is responsible for). */
fn fen_lowbit(x: u32) -> u32 @export { return x & (0u32 - x) }

/* add delta to element i (0-indexed); walk up the set bits. */
fn fen_update(i: u32, delta: u32) -> i32 @export {
    FEN_VAL[i as u64] = FEN_VAL[i as u64] + delta
    let mut j : u32 = i + 1u32
    while j <= FEN_N {
        FEN_TREE[j as u64] = FEN_TREE[j as u64] + delta
        j = j + fen_lowbit(j)
    }
    return 0i32
}

/* prefix sum of elements [0, i] (0-indexed); walk down the set bits. */
fn fen_prefix(i: u32) -> u32 @export {
    let mut sum : u32 = 0u32
    let mut j : u32 = i + 1u32
    while j > 0u32 {
        sum = sum + FEN_TREE[j as u64]
        j = j - fen_lowbit(j)
    }
    return sum
}

/* the naive O(n) reference prefix sum. */
fn fen_naive_prefix(i: u32) -> u32 @export {
    let mut sum : u32 = 0u32
    let mut k : u32 = 0u32
    while k <= i {
        sum = sum + FEN_VAL[k as u64]
        k = k + 1u32
    }
    return sum
}

/* range sum [l, r] (0-indexed, l <= r). */
fn fen_range(l: u32, r: u32) -> u32 @export {
    if l == 0u32 { return fen_prefix(r) }
    return fen_prefix(r) - fen_prefix(l - 1u32)
}

/* the BIT agrees with the naive prefix sum at every index. */
fn fen_agree() -> u32 @export {
    let mut i : u32 = 0u32
    while i < FEN_N {
        if fen_prefix(i) != fen_naive_prefix(i) { return 0u32 }
        i = i + 1u32
    }
    return 1u32
}

/* =====================================================================================
 * fenwick_kat -- 99 = the Fenwick tree is correct, verified against naive:
 *   (1) after building [3,1,4,1,5,9,2,6] the prefix sums are 3, 9 (at index 3), 31 (at index 7);
 *   (2) the BIT agrees with the naive reference at every index;
 *   (3) range [2,5] sums to 19; a point update (+10 at index 2) is reflected and the tree still agrees;
 *   (4) the lowbit helper is correct.
 * ===================================================================================== */
fn fenwick_kat() -> u64 @export {
    fen_init()
    fen_update(0u32, 3u32) ; fen_update(1u32, 1u32) ; fen_update(2u32, 4u32) ; fen_update(3u32, 1u32)
    fen_update(4u32, 5u32) ; fen_update(5u32, 9u32) ; fen_update(6u32, 2u32) ; fen_update(7u32, 6u32)

    /* (1) prefix sums */
    if fen_prefix(0u32) != 3u32 { return 1u64 }
    if fen_prefix(3u32) != 9u32 { return 2u64 }           /* 3+1+4+1 */
    if fen_prefix(7u32) != 31u32 { return 3u64 }          /* full sum */

    /* (2) agreement with naive at every index */
    if fen_agree() != 1u32 { return 4u64 }

    /* (3) range query + point update */
    if fen_range(2u32, 5u32) != 19u32 { return 5u64 }     /* 4+1+5+9 */
    fen_update(2u32, 10u32)                               /* element 2: 4 -> 14 */
    if fen_prefix(3u32) != 19u32 { return 6u64 }          /* 3+1+14+1 */
    if fen_range(2u32, 5u32) != 29u32 { return 7u64 }     /* 14+1+5+9 */
    if fen_agree() != 1u32 { return 8u64 }                /* still consistent everywhere */

    /* (4) lowbit */
    if fen_lowbit(12u32) != 4u32 { return 9u64 }          /* 1100 -> 0100 */
    if fen_lowbit(8u32) != 8u32 { return 10u64 }
    if fen_lowbit(6u32) != 2u32 { return 11u64 }

    return 99u64
}
