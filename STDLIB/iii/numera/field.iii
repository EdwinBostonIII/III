/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\field.iii
 *
 * III STDLIB - numera::field
 *
 * Finite field arithmetic Fp using bigint as the underlying
 * representation.  The modulus p is supplied per-operation; the field
 * type is implicitly the residue ring Z/pZ.  For PRIME p, all non-zero
 * elements have multiplicative inverses (computed via extended
 * Euclidean / Fermat's-little-theorem variants).  For composite p,
 * fp_inv may fail.
 *
 * Phase D scope:
 *   - fp_add / fp_sub / fp_mul                (any modulus)
 *   - fp_pow                                  (square-and-multiply)
 *   - fp_inv_fermat                           (assumes p prime; retained as the prime-path
 *                                              differential oracle for fp_inv)
 *   - fp_inv                                  (harmony item 11: extended Euclid, ANY modulus --
 *                                              refuses gcd(a,m) != 1 instead of silently corrupting)
 *
 *
 * APOTHEOSIS S.3 (audit -- the generic escape hatch).  This is the arbitrary-
 * odd-prime Fp fallback (modulus supplied per call).  A single fp_mul is
 * bigint_mul + bigint_mod (Knuth division), NOT a Montgomery CIOS, and is
 * DELIBERATELY not routed to the shared S.2 organ: for ONE multiply, building a
 * modulus_ctx + to/from-Montgomery costs more than one Knuth reduction
 * (Montgomery wins only across a modpow's many multiplies).  fp_pow DOES inherit
 * the shared organ -- it calls bigint_modpow, which dispatches odd moduli to the
 * ctx-driven Montgomery ladder (numera::bigint_div).  The four fixed-prime NIST
 * fields (fp256/fn256/fp384/fn384) were the genuine CIOS duplicates and ARE
 * consolidated onto that organ; this generic path stays generic.
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */

module numera_field

extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_copy(arena: u64, src: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_eq(a: u64, b: u64) -> u8 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_is_zero(id: u64) -> u8 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_cmp(a: u64, b: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_add(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_sub(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mul(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mod(arena: u64, a: u64, m: u64) -> u64 from "bigint_div.iii"
extern @abi(c-msvc-x64) fn bigint_modpow(arena: u64, base: u64, exp: u64, m: u64) -> u64 from "bigint_div.iii"
extern @abi(c-msvc-x64) fn bigint_div_qr(arena: u64, a: u64, b: u64) -> u64 from "bigint_div.iii"
extern @abi(c-msvc-x64) fn bigint_remainder_take() -> u64 from "bigint_div.iii"

const FIELD_INVALID : u64 = 0u64

/* a + b mod m */
fn fp_add(arena: u64, a: u64, b: u64, m: u64) -> u64 @export {
    let s : u64 = bigint_add(arena, a, b)
    if s == 0u64 { return FIELD_INVALID }
    let r : u64 = bigint_mod(arena, s, m)
    bigint_drop(s)
    return r
}

/* a - b mod m (returns m - (b - a) when a < b) */
fn fp_sub(arena: u64, a: u64, b: u64, m: u64) -> u64 @export {
    /* First compute (a + m - b) mod m to avoid going negative. */
    let am : u64 = bigint_mod(arena, a, m)
    if am == 0u64 { return FIELD_INVALID }                      /* OOM guard, matching fp_add */
    let bm : u64 = bigint_mod(arena, b, m)
    if bm == 0u64 { bigint_drop(am) return FIELD_INVALID }
    let cmp : i32 = bigint_cmp(am, bm)
    let mut ge : u8 = 0u8
    if cmp != -1i32 { ge = 1u8 }   /* [W2810] cmp in {-1,0,1}; consolidate the two == writes (cmp is a local, != is iiis-safe) */
    if ge == 1u8 {
        let diff : u64 = bigint_sub(arena, am, bm)
        bigint_drop(am)
        bigint_drop(bm)
        return diff
    }
    /* am < bm: result = (am + m) - bm */
    let am_plus_m : u64 = bigint_add(arena, am, m)
    if am_plus_m == 0u64 { bigint_drop(am) bigint_drop(bm) return FIELD_INVALID }   /* OOM guard */
    let diff : u64 = bigint_sub(arena, am_plus_m, bm)
    bigint_drop(am)
    bigint_drop(bm)
    bigint_drop(am_plus_m)
    return diff
}

/* a * b mod m */
fn fp_mul(arena: u64, a: u64, b: u64, m: u64) -> u64 @export {
    let p : u64 = bigint_mul(arena, a, b)
    if p == 0u64 { return FIELD_INVALID }
    let r : u64 = bigint_mod(arena, p, m)
    bigint_drop(p)
    return r
}

/* base^exp mod m */
fn fp_pow(arena: u64, base: u64, exp: u64, m: u64) -> u64 @export {
    return bigint_modpow(arena, base, exp, m)
}

/* Fermat's little theorem inversion: a^(p-2) mod p, valid when p is prime
 * and a != 0 mod p.  Returns FIELD_INVALID if a == 0 mod p or p < 2. */
fn fp_inv_fermat(arena: u64, a: u64, p: u64) -> u64 @export {
    /* a_mod = a mod p; must be non-zero */
    let am : u64 = bigint_mod(arena, a, p)
    if bigint_is_zero(am) == 1u8 {
        bigint_drop(am)
        return FIELD_INVALID
    }
    /* exp = p - 2 (assumes p >= 2; we don't verify primality) */
    let two : u64 = bigint_from_u64(arena, 2u64)
    if bigint_cmp(p, two) == -1i32 {
        bigint_drop(am)
        bigint_drop(two)
        return FIELD_INVALID
    }
    let exp : u64 = bigint_sub(arena, p, two)
    let inv : u64 = bigint_modpow(arena, am, exp, p)
    bigint_drop(am)
    bigint_drop(two)
    bigint_drop(exp)
    return inv
}

/* ===== harmony item 11: the COMPOSITE-SAFE modular inverse (extended Euclid, all-residue) ========
 * fp_inv_fermat is sound ONLY for prime p: for composite m, a^(m-2) mod m is silently WRONG -- no
 * error, no refusal, just corrupted downstream math.  fp_inv closes that soundness hole with the
 * iterative extended Euclid whose Bezout coefficient is tracked MOD m, so no signed bigints are
 * ever needed:  s' = old_s - q*s  ==  fp_sub(old_s, fp_mul(q, s, m), m),  every value in [0, m).
 * The r-sequence is exact unsigned Euclid (r' = old_r mod r, straight from the Knuth divider's
 * remainder).  Returns the unique inverse in [1, m) iff gcd(a, m) == 1; FIELD_INVALID otherwise
 * (a == 0 mod m, m < 2, OOM, or gcd != 1) -- the non-invertible case is REFUSED, never silently
 * wrong.  The guard bound 16384 >= 2*bits(max bigint)+2 (Fibonacci worst case) is defense-in-depth,
 * not truncation.  Per-iteration temporaries are dropped eagerly (the 64-slot bigint handle table
 * is the binding constraint); steady-state live handles: old_r, r, old_s, s. */
fn fp_inv(arena: u64, a: u64, m: u64) -> u64 @export {
    let two : u64 = bigint_from_u64(arena, 2u64)
    if two == 0u64 { return FIELD_INVALID }
    let mlt : i32 = bigint_cmp(m, two)
    bigint_drop(two)
    if mlt == -1i32 { return FIELD_INVALID }
    let am : u64 = bigint_mod(arena, a, m)
    if am == 0u64 { return FIELD_INVALID }
    if bigint_is_zero(am) == 1u8 { bigint_drop(am) return FIELD_INVALID }
    let mut old_r : u64 = bigint_copy(arena, m)
    if old_r == 0u64 { bigint_drop(am) return FIELD_INVALID }
    let mut r : u64 = am
    let mut old_s : u64 = bigint_from_u64(arena, 0u64)
    if old_s == 0u64 { bigint_drop(old_r) bigint_drop(r) return FIELD_INVALID }
    let mut s : u64 = bigint_from_u64(arena, 1u64)
    if s == 0u64 { bigint_drop(old_r) bigint_drop(r) bigint_drop(old_s) return FIELD_INVALID }
    let mut fail : u8 = 0u8
    let mut live : u8 = 1u8
    let mut guard : u64 = 0u64
    while live == 1u8 {
        if bigint_is_zero(r) == 1u8 { live = 0u8 }
        else {
            guard = guard + 1u64
            if guard > 16384u64 { fail = 1u8 live = 0u8 }
            else {
                let q : u64 = bigint_div_qr(arena, old_r, r)      /* quotient; remainder parked */
                let rn : u64 = bigint_remainder_take()            /* r' = old_r mod r (ownership taken) */
                if q == 0u64 { fail = 1u8 live = 0u8 if rn != 0u64 { bigint_drop(rn) } }
                else { if rn == 0u64 { bigint_drop(q) fail = 1u8 live = 0u8 }
                else {
                    let qs : u64 = fp_mul(arena, q, s, m)         /* q*s mod m */
                    bigint_drop(q)
                    if qs == 0u64 { bigint_drop(rn) fail = 1u8 live = 0u8 }
                    else {
                        let sn : u64 = fp_sub(arena, old_s, qs, m)  /* s' = old_s - q*s (mod m) */
                        bigint_drop(qs)
                        if sn == 0u64 { bigint_drop(rn) fail = 1u8 live = 0u8 }
                        else {
                            bigint_drop(old_r)
                            old_r = r
                            r = rn
                            bigint_drop(old_s)
                            old_s = s
                            s = sn
                        }
                    }
                } }
            }
        }
    }
    /* gcd(a, m) = old_r; invertible iff gcd == 1, and then old_s IS the inverse (already in [0,m)). */
    let mut res : u64 = FIELD_INVALID
    if fail == 0u8 {
        let one : u64 = bigint_from_u64(arena, 1u64)
        if one != 0u64 {
            if bigint_eq(old_r, one) == 1u8 {
                res = old_s                                       /* transfer ownership to the caller */
                old_s = 0u64
            }
            bigint_drop(one)
        }
    }
    bigint_drop(old_r)
    bigint_drop(r)
    if old_s != 0u64 { bigint_drop(old_s) }
    bigint_drop(s)
    return res
}

/* a / b mod m -- COMPOSITE-SAFE (harmony item 11): routed through fp_inv, so a non-invertible b
 * (gcd(b,m) != 1, including b == 0 mod m) is REFUSED with FIELD_INVALID instead of the old
 * Fermat path's silently-wrong value on composite m.  For prime m the result is unchanged. */
fn fp_div(arena: u64, a: u64, b: u64, p: u64) -> u64 @export {
    let inv_b : u64 = fp_inv(arena, b, p)
    if inv_b == FIELD_INVALID { return FIELD_INVALID }
    let r : u64 = fp_mul(arena, a, inv_b, p)
    bigint_drop(inv_b)
    return r
}
