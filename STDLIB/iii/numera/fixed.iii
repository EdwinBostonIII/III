/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\fixed.iii
 *
 * III STDLIB - numera::fixed
 *
 * Q32.32 fixed-point: 32 integer bits + 32 fractional bits stored
 * inside a u64.  Operations are exact for the integer portion,
 * truncating for the fractional.  Sign is unsigned in this
 * implementation; signed Q31.32 is a Phase C addition.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00.
 */

module numera_fixed

const FIX_FRAC_BITS : u32 = 32u32
const FIX_ONE       : u64 = 0x100000000u64    /* 1.0 in Q32.32 = 2^32 */
const FIX_HALF      : u64 = 0x80000000u64     /* 0.5 in Q32.32 = 2^31 */

fn fix_from_u32(v: u32) -> u64 @export {
    return (v as u64) << 32u64
}

fn fix_to_u32_truncate(q: u64) -> u32 @export {
    return ((q >> 32u64) & 0xFFFFFFFFu64) as u32
}

fn fix_to_u32_round(q: u64) -> u32 @export {
    let r : u64 = q + FIX_HALF
    return ((r >> 32u64) & 0xFFFFFFFFu64) as u32
}

fn fix_frac(q: u64) -> u32 @export {
    return (q & 0xFFFFFFFFu64) as u32
}

fn fix_add(a: u64, b: u64) -> u64 @export {
    return a + b
}

fn fix_sub(a: u64, b: u64) -> u64 @export {
    return a - b
}

/* mul: (a * b) >> 32, with a 128-bit intermediate computed via
 * schoolbook 64x64 split.  Each line keeps at most one parenthesised
 * subexpression to keep iiis-2's parser happy. */
fn fix_mul(a: u64, b: u64) -> u64 @export {
    let a_shifted : u64 = a >> 32u64
    let a_hi : u64 = a_shifted & 0xFFFFFFFFu64
    let a_lo : u64 = a & 0xFFFFFFFFu64
    let b_shifted : u64 = b >> 32u64
    let b_hi : u64 = b_shifted & 0xFFFFFFFFu64
    let b_lo : u64 = b & 0xFFFFFFFFu64
    let pp_lo_lo : u64 = a_lo * b_lo
    let pp_lo_hi : u64 = a_lo * b_hi
    let pp_hi_lo : u64 = a_hi * b_lo
    let pp_hi_hi : u64 = a_hi * b_hi
    let lo_lo_high : u64 = pp_lo_lo >> 32u64
    let pp_lo_hi_lo : u64 = pp_lo_hi & 0xFFFFFFFFu64
    let pp_hi_lo_lo : u64 = pp_hi_lo & 0xFFFFFFFFu64
    let mid_a : u64 = lo_lo_high + pp_lo_hi_lo
    let mid : u64 = mid_a + pp_hi_lo_lo
    let mid_high : u64 = mid >> 32u64
    let mid_low : u64 = mid & 0xFFFFFFFFu64
    let pp_lo_hi_hi : u64 = pp_lo_hi >> 32u64
    let pp_hi_lo_hi : u64 = pp_hi_lo >> 32u64
    let pp_hi_hi_lo : u64 = pp_hi_hi & 0xFFFFFFFFu64
    let s1 : u64 = pp_hi_hi_lo + pp_lo_hi_hi
    let s2 : u64 = s1 + pp_hi_lo_hi
    let bits_64_95 : u64 = s2 + mid_high
    let high_part : u64 = bits_64_95 << 32u64
    return high_part | mid_low
}

fn fix_div(a: u64, b: u64) -> u64 @export {
    if b == 0u64 { return 0xFFFFFFFFFFFFFFFFu64 }
    /* (a << 32) / b - but (a << 32) overflows for large a.  Approach:
     * compute a / b first (integer Q part), then ((a mod b) << 32) / b
     * for the fractional part. */
    let int_part : u64 = a / b
    let rem      : u64 = a % b
    let mut frac_part : u64 = 0u64
    if rem != 0u64 {
        /* (rem << 32) / b: rem fits in 32 bits OR less only after
         * dividing.  Worst-case rem could be up to b-1 which is up
         * to 2^64-2, so rem << 32 overflows.  Instead long-divide
         * by repeated subtract-and-shift: compute frac_part bit by
         * bit. */
        let mut acc : u64 = rem
        let mut bit : u32 = 32u32
        while bit > 0u32 {
            bit = bit - 1u32
            /* [W13-FIX] acc<<1 drops the top bit when acc >= 2^63 (reachable when b > 2^63,
             * since the invariant is acc < b).  Capture that bit: the true 65-bit value is
             * carry*2^64 + (acc<<1).  When carry=1 the true value exceeds any u64 b, so the
             * subtract is unconditional; (true - b) reduces to (acc - b) in wrapping u64
             * because true - b = 2^64 + acc - b and that is < 2^64 (true < 2b).  For b <= 2^63
             * (all normal Q32.32 use) carry is always 0 -> byte-identical to the old path. */
            let carry : u64 = acc >> 63u64
            acc = acc << 1u64
            let bit_u64 : u64 = bit as u64
            let one_shifted : u64 = 1u64 << bit_u64
            if carry == 1u64 {
                acc = acc - b
                frac_part = frac_part | one_shifted
            } else {
                if acc >= b {
                    acc = acc - b
                    frac_part = frac_part | one_shifted
                }
            }
        }
    }
    return (int_part << 32u64) | (frac_part & 0xFFFFFFFFu64)
}

fn fix_eq(a: u64, b: u64) -> u8 @export {
    if a == b { return 1u8 }
    return 0u8
}

fn fix_lt(a: u64, b: u64) -> u8 @export {
    if a < b { return 1u8 }
    return 0u8
}

/* === Signed Q31.32 (the Phase C deferral, closed): 1 sign + 31 int + 32 frac, stored as i64; value =
 * bits / 2^32.  add/sub/eq are two's-complement bit-identical to the unsigned ops; lt uses i64 ordering
 * (SOUND in iiis-2 -- unlike i32 ordering, which is unsigned); mul/div use SIGN-MAGNITUDE (run the unsigned
 * 128-bit mul / long-division on the absolute values, then reapply the XOR of the operand signs).  The
 * most-negative value (i64::MIN) has no positive magnitude and is outside the supported domain. === */

fn fix_from_i32_signed(i: i32) -> i64 @export {
    let v : i64 = i as i64
    return v << 32i64
}

fn fix_to_i32_signed(q: i64) -> i32 @export {
    let mut mag : u64 = q as u64
    let mut neg : u8 = 0u8
    if q < 0i64 {
        neg = 1u8
        let m : i64 = 0i64 - q
        mag = m as u64
    }
    let int_mag : u64 = mag >> 32u64
    let r : i64 = int_mag as i64
    if neg == 1u8 { return (0i64 - r) as i32 }
    return r as i32
}

fn fix_add_signed(a: i64, b: i64) -> i64 @export {
    return a + b
}

fn fix_sub_signed(a: i64, b: i64) -> i64 @export {
    return a - b
}

fn fix_eq_signed(a: i64, b: i64) -> u8 @export {
    if a == b { return 1u8 }
    return 0u8
}

fn fix_lt_signed(a: i64, b: i64) -> u8 @export {
    if a < b { return 1u8 }
    return 0u8
}

fn fix_mul_signed(a: i64, b: i64) -> i64 @export {
    let mut ma : u64 = a as u64
    let mut sa : u8 = 0u8
    if a < 0i64 {
        sa = 1u8
        let na : i64 = 0i64 - a
        ma = na as u64
    }
    let mut mb : u64 = b as u64
    let mut sb : u8 = 0u8
    if b < 0i64 {
        sb = 1u8
        let nb : i64 = 0i64 - b
        mb = nb as u64
    }
    let m : u64 = fix_mul(ma, mb)
    if sa != sb { return 0i64 - (m as i64) }
    return m as i64
}

fn fix_div_signed(a: i64, b: i64) -> i64 @export {
    let mut ma : u64 = a as u64
    let mut sa : u8 = 0u8
    if a < 0i64 {
        sa = 1u8
        let na : i64 = 0i64 - a
        ma = na as u64
    }
    let mut mb : u64 = b as u64
    let mut sb : u8 = 0u8
    if b < 0i64 {
        sb = 1u8
        let nb : i64 = 0i64 - b
        mb = nb as u64
    }
    let m : u64 = fix_div(ma, mb)
    if sa != sb { return 0i64 - (m as i64) }
    return m as i64
}

/* 99 = the signed Q31.32 ops are correct across the sign tables (compared to from_i32_signed references). */
fn fix_signed_selftest() -> u64 @export {
    /* round-trip (incl. negative) */
    if fix_to_i32_signed(fix_from_i32_signed(0i32 - 5i32)) != (0i32 - 5i32) { return 1u64 }
    if fix_to_i32_signed(fix_from_i32_signed(7i32)) != 7i32 { return 2u64 }
    /* add (incl. sign crossover) */
    if fix_add_signed(fix_from_i32_signed(0i32 - 3i32), fix_from_i32_signed(7i32)) != fix_from_i32_signed(4i32) { return 3u64 }
    if fix_add_signed(fix_from_i32_signed(2i32), fix_from_i32_signed(0i32 - 5i32)) != fix_from_i32_signed(0i32 - 3i32) { return 4u64 }
    /* sub */
    if fix_sub_signed(fix_from_i32_signed(3i32), fix_from_i32_signed(8i32)) != fix_from_i32_signed(0i32 - 5i32) { return 5u64 }
    /* mul sign table {-,+},{-,-},{+,-},{+,+} */
    if fix_mul_signed(fix_from_i32_signed(0i32 - 2i32), fix_from_i32_signed(3i32)) != fix_from_i32_signed(0i32 - 6i32) { return 6u64 }
    if fix_mul_signed(fix_from_i32_signed(0i32 - 2i32), fix_from_i32_signed(0i32 - 3i32)) != fix_from_i32_signed(6i32) { return 7u64 }
    if fix_mul_signed(fix_from_i32_signed(4i32), fix_from_i32_signed(0i32 - 5i32)) != fix_from_i32_signed(0i32 - 20i32) { return 8u64 }
    if fix_mul_signed(fix_from_i32_signed(4i32), fix_from_i32_signed(5i32)) != fix_from_i32_signed(20i32) { return 9u64 }
    /* div sign table */
    if fix_div_signed(fix_from_i32_signed(0i32 - 6i32), fix_from_i32_signed(3i32)) != fix_from_i32_signed(0i32 - 2i32) { return 10u64 }
    if fix_div_signed(fix_from_i32_signed(6i32), fix_from_i32_signed(0i32 - 2i32)) != fix_from_i32_signed(0i32 - 3i32) { return 11u64 }
    if fix_div_signed(fix_from_i32_signed(0i32 - 20i32), fix_from_i32_signed(0i32 - 4i32)) != fix_from_i32_signed(5i32) { return 12u64 }
    /* lt (i64 ordering, SOUND) + the teeth: a negative is < a positive (the i32-unsigned trap would invert this) */
    if fix_lt_signed(fix_from_i32_signed(0i32 - 1i32), fix_from_i32_signed(1i32)) != 1u8 { return 13u64 }
    if fix_lt_signed(fix_from_i32_signed(1i32), fix_from_i32_signed(0i32 - 1i32)) != 0u8 { return 14u64 }
    if fix_lt_signed(fix_from_i32_signed(0i32 - 5i32), fix_from_i32_signed(0i32 - 2i32)) != 1u8 { return 15u64 }
    /* eq */
    if fix_eq_signed(fix_from_i32_signed(0i32 - 5i32), fix_from_i32_signed(0i32 - 5i32)) != 1u8 { return 16u64 }
    if fix_eq_signed(fix_from_i32_signed(0i32 - 5i32), fix_from_i32_signed(5i32)) != 0u8 { return 17u64 }
    return 99u64
}
