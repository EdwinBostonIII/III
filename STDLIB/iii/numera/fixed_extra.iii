/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\fixed_extra.iii
 *
 * III STDLIB - numera::fixed_extra
 *
 * Lattice plan Step 0033 -- additional fixed-point instantiations beyond
 * the existing Q32.32 in numera/fixed.iii.  Three monomorphic widths,
 * each with a complete arithmetic surface:
 *
 *   Q16.16:  16 integer bits + 16 fractional bits, packed into u32.
 *   Q24.8:   24 integer bits + 8 fractional bits, packed into u32.
 *   Q48.16:  48 integer bits + 16 fractional bits, packed into u64.
 *
 * For each format f:
 *   f_from_int(i) -> u64                   -- pack integer i (low bits)
 *   f_to_int(x) -> u64                     -- extract integer part
 *   f_add(a, b) -> u64                     -- saturating add (caps at max)
 *   f_sub(a, b) -> u64                     -- saturating sub (floors at 0)
 *   f_mul(a, b) -> u64                     -- multiply with scaling
 *   f_div(a, b) -> u64                     -- divide with scaling (b != 0)
 *
 * Storage is unsigned (no negative values) for simplicity.  Saturation
 * is the @bounded(min=0, max=MAX) discipline mentioned by the master
 * plan.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99 (saturation may quietly cap).
 */

module numera_fixed_extra

/* ─── Q16.16 (u32-packed) ──────────────────────────────────────── */

const FX16_FRAC_BITS : u64 = 16u64
const FX16_MASK      : u64 = 0xFFFFFFFFu64
const FX16_MAX       : u64 = 0xFFFFFFFFu64    /* saturate cap */

fn fx16_from_int(i: u64) -> u64 @export {
    /* Q16.16 integer part caps at 2^16-1; guard BEFORE the shift because
     * i<<16 wraps mod 2^64 for i>=2^48 (bypassing the v>FX16_MAX check and
     * returning a small wrong value).  [audit D-FX-2] */
    if i > 0xFFFFu64 { return FX16_MAX }
    return (i << FX16_FRAC_BITS) & FX16_MASK
}

fn fx16_to_int(x: u64) -> u64 @export {
    return (x & FX16_MASK) >> FX16_FRAC_BITS
}

fn fx16_add(a: u64, b: u64) -> u64 @export {
    let aa : u64 = a & FX16_MASK
    let bb : u64 = b & FX16_MASK
    let s : u64 = aa + bb
    if s > FX16_MAX { return FX16_MAX }
    return s
}

fn fx16_sub(a: u64, b: u64) -> u64 @export {
    let aa : u64 = a & FX16_MASK
    let bb : u64 = b & FX16_MASK
    if bb > aa { return 0u64 }
    return aa - bb
}

fn fx16_mul(a: u64, b: u64) -> u64 @export {
    let aa : u64 = a & FX16_MASK
    let bb : u64 = b & FX16_MASK
    let prod : u64 = aa * bb
    let scaled : u64 = prod >> FX16_FRAC_BITS
    if scaled > FX16_MAX { return FX16_MAX }
    return scaled
}

fn fx16_div(a: u64, b: u64) -> u64 @export {
    let aa : u64 = a & FX16_MASK
    let bb : u64 = b & FX16_MASK
    if bb == 0u64 { return FX16_MAX }
    let scaled : u64 = aa << FX16_FRAC_BITS
    let q : u64 = scaled / bb
    if q > FX16_MAX { return FX16_MAX }
    return q
}

/* ─── Q24.8 (u32-packed) ───────────────────────────────────────── */

const FX24_FRAC_BITS : u64 = 8u64
const FX24_MASK      : u64 = 0xFFFFFFFFu64
const FX24_MAX       : u64 = 0xFFFFFFFFu64

fn fx24_from_int(i: u64) -> u64 @export {
    /* Q24.8 integer part caps at 2^24-1; guard BEFORE the shift because
     * i<<8 wraps mod 2^64 for i>=2^56 (bypassing the v>FX24_MAX check).
     * [audit D-FX-3] */
    if i > 0xFFFFFFu64 { return FX24_MAX }
    return (i << FX24_FRAC_BITS) & FX24_MASK
}

fn fx24_to_int(x: u64) -> u64 @export {
    return (x & FX24_MASK) >> FX24_FRAC_BITS
}

fn fx24_add(a: u64, b: u64) -> u64 @export {
    let aa : u64 = a & FX24_MASK
    let bb : u64 = b & FX24_MASK
    let s : u64 = aa + bb
    if s > FX24_MAX { return FX24_MAX }
    return s
}

fn fx24_sub(a: u64, b: u64) -> u64 @export {
    let aa : u64 = a & FX24_MASK
    let bb : u64 = b & FX24_MASK
    if bb > aa { return 0u64 }
    return aa - bb
}

fn fx24_mul(a: u64, b: u64) -> u64 @export {
    let aa : u64 = a & FX24_MASK
    let bb : u64 = b & FX24_MASK
    let prod : u64 = aa * bb
    let scaled : u64 = prod >> FX24_FRAC_BITS
    if scaled > FX24_MAX { return FX24_MAX }
    return scaled
}

fn fx24_div(a: u64, b: u64) -> u64 @export {
    let aa : u64 = a & FX24_MASK
    let bb : u64 = b & FX24_MASK
    if bb == 0u64 { return FX24_MAX }
    let scaled : u64 = aa << FX24_FRAC_BITS
    let q : u64 = scaled / bb
    if q > FX24_MAX { return FX24_MAX }
    return q
}

/* ─── Q48.16 (u64) ─────────────────────────────────────────────── */

const FX48_FRAC_BITS : u64 = 16u64
const FX48_MAX       : u64 = 0xFFFFFFFFFFFFFFFFu64

fn fx48_from_int(i: u64) -> u64 @export {
    /* If i << 16 would overflow u64, saturate. */
    if i > 0xFFFFFFFFFFFFu64 { return FX48_MAX }
    return i << FX48_FRAC_BITS
}

fn fx48_to_int(x: u64) -> u64 @export {
    return x >> FX48_FRAC_BITS
}

fn fx48_add(a: u64, b: u64) -> u64 @export {
    /* Saturating add: detect overflow via wrap. */
    let s : u64 = a + b
    if s < a { return FX48_MAX }
    return s
}

fn fx48_sub(a: u64, b: u64) -> u64 @export {
    if b > a { return 0u64 }
    return a - b
}

fn fx48_mul(a: u64, b: u64) -> u64 @export {
    /* Q48.16 * Q48.16 -> Q48.16 = (a*b) >> 16.  a*b is a genuine 128-bit
     * product; form it EXACTLY as (hi,lo) via 32-bit schoolbook (mirrors
     * fix_mul in numera/fixed.iii), then (a*b)>>16 = (lo>>16) | (hi<<48).
     * Saturate ONLY when hi >= 2^16 -- the unique case where the shifted
     * result exceeds u64 (hi*2^48 >= 2^64).  The old code formed partial
     * products and saturated on premature high-half guards, capping ~99.9%
     * of valid non-overflowing operands.  No intermediate overflows:
     * hi = floor(a*b / 2^64) < 2^64 for a,b < 2^64, and the partial sums
     * forming it are monotone.  [audit D-FX-1] */
    let a_hi : u64 = a >> 32u64
    let a_lo : u64 = a & 0xFFFFFFFFu64
    let b_hi : u64 = b >> 32u64
    let b_lo : u64 = b & 0xFFFFFFFFu64
    let ll : u64 = a_lo * b_lo
    let lh : u64 = a_lo * b_hi
    let hl : u64 = a_hi * b_lo
    let hh : u64 = a_hi * b_hi
    /* cross_lo = (ll>>32) + lh_lo + hl_lo  (< 3*2^32, fits u64). */
    let cross_lo : u64 = (ll >> 32u64) + (lh & 0xFFFFFFFFu64) + (hl & 0xFFFFFFFFu64)
    let lo : u64 = (ll & 0xFFFFFFFFu64) | ((cross_lo & 0xFFFFFFFFu64) << 32u64)
    let hi : u64 = (cross_lo >> 32u64) + (lh >> 32u64) + (hl >> 32u64) + hh
    if hi >= 0x10000u64 { return FX48_MAX }
    return (lo >> FX48_FRAC_BITS) | (hi << 48u64)
}

fn fx48_div(a: u64, b: u64) -> u64 @export {
    if b == 0u64 { return FX48_MAX }
    /* result = (a << 16) / b -- careful of (a << 16) overflow. */
    if a > (FX48_MAX >> FX48_FRAC_BITS) { return FX48_MAX }
    return (a << FX48_FRAC_BITS) / b
}
