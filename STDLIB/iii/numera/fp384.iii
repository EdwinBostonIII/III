/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\fp384.iii
 *
 * III STDLIB - numera::fp384 -- constant-time prime field GF(p384) for NIST
 * P-384 ECDSA (RITCHIE Stage 4.11).  p384 = 2^384 - 2^128 - 2^96 + 2^32 - 1.
 * 12 x u32 little-endian limbs in a slot pool; MONTGOMERY domain (R=2^384).
 * Same CIOS design as fp256; p384[0]=0xffffffff so n'[0]=1 (free reduction).
 * R^2 derived at init by doublings.  Constant-time (masked conditional sub).
 *
 * Hexad: kind_essence.  Ring: R3.  K: 1.00.
 */

module numera_fp384

var FQ_P    : [u32; 12]
var FQ_R2   : [u32; 12]
var FQ_ONE  : [u32; 12]
var FQ      : [u32; 576]    /* 48 slots * 12 limbs */
var FQ_T    : [u64; 14]
var FQ_INIT : [u32; 1]
var FQ_PM2  : [u32; 12]

fn fp384_init() -> i32 {
    if FQ_INIT[0] == 1u32 { return 0i32 }
    /* p384 LE limbs */
    FQ_P[0]=0xFFFFFFFFu32 FQ_P[1]=0x00000000u32 FQ_P[2]=0x00000000u32 FQ_P[3]=0xFFFFFFFFu32
    FQ_P[4]=0xFFFFFFFEu32 FQ_P[5]=0xFFFFFFFFu32 FQ_P[6]=0xFFFFFFFFu32 FQ_P[7]=0xFFFFFFFFu32
    FQ_P[8]=0xFFFFFFFFu32 FQ_P[9]=0xFFFFFFFFu32 FQ_P[10]=0xFFFFFFFFu32 FQ_P[11]=0xFFFFFFFFu32
    /* R mod p = 2^384 - p (one's-complement style: 0 - p mod 2^384) */
    let mut borrow : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 12u64 {
        let v : u64 = 0u64 + 0x100000000u64 - (FQ_P[i] as u64) - borrow
        FQ_ONE[i] = (v & 0xFFFFFFFFu64) as u32
        if v < 0x100000000u64 { borrow = 1u64 } else { borrow = 0u64 }
        i = i + 1u64
    }
    /* R^2 = 2^768 mod p: start at R mod p, double 384x */
    i = 0u64
    while i < 12u64 { FQ_R2[i] = FQ_ONE[i] ; i = i + 1u64 }
    let mut d : u64 = 0u64
    while d < 384u64 { fq_dbl_raw(&FQ_R2 as u64) ; d = d + 1u64 }
    FQ_INIT[0] = 1u32
    return 0i32
}

fn fq_dbl_raw(addr: u64) -> i32 {
    let a : *u32 = addr as *u32
    let mut carry : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 12u64 {
        let v : u64 = ((a[i] as u64) << 1u64) | carry
        a[i] = (v & 0xFFFFFFFFu64) as u32
        carry = v >> 32u64
        i = i + 1u64
    }
    fq_csub_p(addr, carry)
    return 0i32
}

fn fq_csub_p(addr: u64, extra_high: u64) -> i32 {
    let a : *u32 = addr as *u32
    let pp : *u32 = &FQ_P as *u32
    let mut borrow : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 12u64 {
        let v : u64 = 0x100000000u64 + (a[i] as u64) - (pp[i] as u64) - borrow
        FQ_T[i] = v & 0xFFFFFFFFu64
        if v < 0x100000000u64 { borrow = 1u64 } else { borrow = 0u64 }
        i = i + 1u64
    }
    let mut ge : u64 = 0u64
    if extra_high != 0u64 { ge = 1u64 }
    if borrow == 0u64 { ge = 1u64 }
    let mask : u64 = 0u64 - ge
    let notm : u64 = mask ^ 0xFFFFFFFFFFFFFFFFu64
    i = 0u64
    while i < 12u64 {
        a[i] = (((FQ_T[i] & mask) | ((a[i] as u64) & notm)) & 0xFFFFFFFFu64) as u32
        i = i + 1u64
    }
    return 0i32
}

fn fq_copy(dst: u64, src: u64) -> i32 {
    let db : u64 = dst * 12u64
    let sb : u64 = src * 12u64
    let mut i : u64 = 0u64
    while i < 12u64 { FQ[db + i] = FQ[sb + i] ; i = i + 1u64 }
    return 0i32
}
fn fq_add(r: u64, a: u64, b: u64) -> i32 {
    let rb : u64 = r * 12u64
    let ab : u64 = a * 12u64
    let bb : u64 = b * 12u64
    let mut carry : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 12u64 {
        let v : u64 = (FQ[ab + i] as u64) + (FQ[bb + i] as u64) + carry
        FQ[rb + i] = (v & 0xFFFFFFFFu64) as u32
        carry = v >> 32u64
        i = i + 1u64
    }
    fq_csub_p((&FQ as u64) + rb * 4u64, carry)
    return 0i32
}
fn fq_sub(r: u64, a: u64, b: u64) -> i32 {
    let rb : u64 = r * 12u64
    let ab : u64 = a * 12u64
    let bb : u64 = b * 12u64
    let mut borrow : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 12u64 {
        let v : u64 = 0x100000000u64 + (FQ[ab + i] as u64) - (FQ[bb + i] as u64) - borrow
        FQ[rb + i] = (v & 0xFFFFFFFFu64) as u32
        if v < 0x100000000u64 { borrow = 1u64 } else { borrow = 0u64 }
        i = i + 1u64
    }
    let mask : u64 = 0u64 - borrow
    let pp : *u32 = &FQ_P as *u32
    let mut c2 : u64 = 0u64
    i = 0u64
    while i < 12u64 {
        let v : u64 = (FQ[rb + i] as u64) + ((pp[i] as u64) & mask) + c2
        FQ[rb + i] = (v & 0xFFFFFFFFu64) as u32
        c2 = v >> 32u64
        i = i + 1u64
    }
    return 0i32
}
fn fq_mul(r: u64, a: u64, b: u64) -> i32 {
    let ab : u64 = a * 12u64
    let bb : u64 = b * 12u64
    let pp : *u32 = &FQ_P as *u32
    let mut k : u64 = 0u64
    while k < 14u64 { FQ_T[k] = 0u64 ; k = k + 1u64 }
    let mut i : u64 = 0u64
    while i < 12u64 {
        let bi : u64 = FQ[bb + i] as u64
        let mut c : u64 = 0u64
        let mut j : u64 = 0u64
        while j < 12u64 {
            let uv : u64 = FQ_T[j] + (FQ[ab + j] as u64) * bi + c
            FQ_T[j] = uv & 0xFFFFFFFFu64
            c = uv >> 32u64
            j = j + 1u64
        }
        let uv12 : u64 = FQ_T[12] + c
        FQ_T[12] = uv12 & 0xFFFFFFFFu64
        FQ_T[13] = uv12 >> 32u64
        let m : u64 = FQ_T[0]
        let uv0 : u64 = FQ_T[0] + m * (pp[0] as u64)
        c = uv0 >> 32u64
        j = 1u64
        while j < 12u64 {
            let uv : u64 = FQ_T[j] + m * (pp[j] as u64) + c
            FQ_T[j - 1u64] = uv & 0xFFFFFFFFu64
            c = uv >> 32u64
            j = j + 1u64
        }
        let uvs : u64 = FQ_T[12] + c
        FQ_T[11] = uvs & 0xFFFFFFFFu64
        FQ_T[12] = FQ_T[13] + (uvs >> 32u64)
        i = i + 1u64
    }
    let rb : u64 = r * 12u64
    let mut q : u64 = 0u64
    while q < 12u64 { FQ[rb + q] = FQ_T[q] as u32 ; q = q + 1u64 }
    fq_csub_p((&FQ as u64) + rb * 4u64, FQ_T[12])
    return 0i32
}
fn fq_sqr(r: u64, a: u64) -> i32 { return fq_mul(r, a, a) }
fn fq_to_mont(r: u64, a: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < 12u64 { FQ[47u64*12u64 + i] = FQ_R2[i] ; i = i + 1u64 }
    return fq_mul(r, a, 47u64)
}
fn fq_from_mont(r: u64, a: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < 12u64 { FQ[47u64*12u64 + i] = 0u32 ; i = i + 1u64 }
    FQ[47u64*12u64] = 1u32
    return fq_mul(r, a, 47u64)
}
fn fq_inv(r: u64, a: u64) -> i32 {
    fp384_init()
    let mut i : u64 = 0u64
    while i < 12u64 { FQ_PM2[i] = FQ_P[i] ; i = i + 1u64 }
    FQ_PM2[0] = (FQ_P[0] as u64 - 2u64) as u32
    fq_copy(45u64, a)
    i = 0u64
    while i < 12u64 { FQ[46u64*12u64 + i] = FQ_ONE[i] ; i = i + 1u64 }
    let mut idx : u64 = 384u64
    while idx > 0u64 {
        idx = idx - 1u64
        fq_sqr(46u64, 46u64)
        let limb : u64 = idx / 32u64
        let off : u64 = idx % 32u64
        let bit : u64 = ((FQ_PM2[limb] as u64) >> off) & 1u64
        if bit == 1u64 { fq_mul(46u64, 46u64, 45u64) }
    }
    fq_copy(r, 46u64)
    return 0i32
}

/* @export surface */
fn fp384_boot() -> i32 @export { return fp384_init() }
fn fq_set_u32(slot: u64, v: u32) -> i32 @export {
    let b : u64 = slot * 12u64
    FQ[b] = v
    let mut i : u64 = 1u64
    while i < 12u64 { FQ[b + i] = 0u32 ; i = i + 1u64 }
    return 0i32
}
fn fq_set_limb(slot: u64, idx: u64, v: u32) -> i32 @export { FQ[slot * 12u64 + idx] = v ; return 0i32 }
fn fq_get_limb(slot: u64, idx: u64) -> u32 @export { return FQ[slot * 12u64 + idx] }
fn fq_add_x(r: u64, a: u64, b: u64) -> i32 @export { return fq_add(r, a, b) }
fn fq_sub_x(r: u64, a: u64, b: u64) -> i32 @export { return fq_sub(r, a, b) }
fn fq_mul_x(r: u64, a: u64, b: u64) -> i32 @export { return fq_mul(r, a, b) }
fn fq_sqr_x(r: u64, a: u64) -> i32 @export { return fq_sqr(r, a) }
fn fq_copy_x(dst: u64, src: u64) -> i32 @export { return fq_copy(dst, src) }
fn fq_inv_x(r: u64, a: u64) -> i32 @export { return fq_inv(r, a) }
fn fq_to_mont_x(r: u64, a: u64) -> i32 @export { return fq_to_mont(r, a) }
fn fq_from_mont_x(r: u64, a: u64) -> i32 @export { return fq_from_mont(r, a) }
fn fq_csel_x(r: u64, a: u64, b: u64, cond: u64) -> i32 @export {
    let rb : u64 = r * 12u64
    let ab : u64 = a * 12u64
    let bb : u64 = b * 12u64
    let mask : u64 = 0u64 - cond
    let notm : u64 = mask ^ 0xFFFFFFFFFFFFFFFFu64
    let mut i : u64 = 0u64
    while i < 12u64 {
        FQ[rb + i] = ((((FQ[ab + i] as u64) & mask) | ((FQ[bb + i] as u64) & notm)) & 0xFFFFFFFFu64) as u32
        i = i + 1u64
    }
    return 0i32
}
