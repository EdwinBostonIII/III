/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\graph_refine.iii
 *
 * III STDLIB - numera::graph_refine
 *
 * GRAPH FINGERPRINTING (1-WL colour refinement) + EXACT ISOMORPHISM.
 *
 * ROLE.  Two services for structural-equivalence of finite undirected graphs:
 *   (1) a FAST, SOUND fingerprint -- the 1-dimensional Weisfeiler-Leman (colour refinement) stable colouring, a
 *       polynomial graph invariant: equal fingerprints are NECESSARY for isomorphism, so DIFFERENT fingerprints
 *       SOUNDLY reject (the graphs are non-isomorphic).  Complete for trees; on general graphs it is sound but
 *       incomplete (it cannot tell K_{3,3} from the triangular prism -- corpus 1871), so it is a filter, not a decider.
 *   (2) an EXACT decision -- gr_iso() runs the 1-WL filter first, then colour-pruned backtracking, giving a
 *       SOUND + COMPLETE isomorphism test.
 *
 * USE CASES.  De-duplicating III's systems graphs / subgraphs (cf. carto, DOCS/III-WALLS-CASHED-IN.md): fingerprint to
 * bucket candidates in poly time, then gr_iso to confirm true equivalence.  Never treat a fingerprint match as
 * isomorphism (incomplete) -- always confirm with gr_iso.
 *
 * INVOCATION.  gr_reset_a(n) -> gr_edge_a(u,v) (undirected) ; same for B ; gr_iso() (1=isomorphic, 0=not).  Fingerprint:
 * gr_reset_a + gr_edge_a -> gr_fingerprint_a() (u64 hash of the stable colour-class multiset) and gr_ncolours_a().
 *
 * IMPACTS / LIMITATIONS (honest).
 *   - SOUND + COMPLETE isomorphism on graphs up to GR_MAX = 32 vertices (adjacency rows are u64; the disjoint union for
 *     the filter is <=64).  A documented bound; wider needs [u64;k] rows (v2).
 *   - The fingerprint is sound-but-INCOMPLETE (1-WL's limit, the GI wall boundary) -- it MUST be confirmed by gr_iso.
 *   - General graph isomorphism is quasi-polynomial / not known in P (the open GI wall); gr_iso is exact, not
 *     worst-case-poly (backtracking), and is the practical decider for moderate graphs.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 * Discipline: W1, W2, W13, W14, W15.  (Backtracking recursion: depth <= GR_MAX, stack-bounded.)
 * Self-test: gr_kat() -> u64 returns 99 on full KAT pass.
 */
module graph_refine

const GR_MAX : u32 = 32u32

var GR_A : [u64; 32]    /* graph A adjacency (undirected) */
var GR_B : [u64; 32]
var GR_NA : [u32; 1]
var GR_NB : [u32; 1]
var GR_U : [u64; 64]  /* working: a single graph (n) or the disjoint union (2n) */
var GR_COL : [u64; 64]
var GR_NEW : [u64; 64]
var GR_CM : [u64; 64]
var GR_PI : [u32; 32]    /* iso mapping A->B */
var GR_USED : [u64; 1]   /* B vertices already used in the mapping */
var GR_WN : [u32; 1]     /* current working vertex count */

fn gr_popc(x: u64) -> u32 { let mut c : u32 = 0u32  let mut v : u32 = 0u32  while v < 64u32 { if (x & (1u64 << (v as u64))) != 0u64 { c = c + 1u32 }  v = v + 1u32 }  return c }

fn gr_reset_a(n: u32) -> i32 @export {
    if n > GR_MAX { return 0i32 - 1i32 }            /* [OOB] @export: n caps GR_A[32] / GR_PI[32] */
    GR_NA[0u64] = n  let mut i : u32 = 0u32  while i < n { GR_A[i as u64] = 0u64  i = i + 1u32 }
    return 0i32
}
fn gr_reset_b(n: u32) -> i32 @export {
    if n > GR_MAX { return 0i32 - 1i32 }            /* [OOB] @export: n caps GR_B[32] */
    GR_NB[0u64] = n  let mut i : u32 = 0u32  while i < n { GR_B[i as u64] = 0u64  i = i + 1u32 }
    return 0i32
}
fn gr_edge_a(u: u32, w: u32) -> i32 @export {
    let n : u32 = GR_NA[0u64]  if u >= n { return 0i32 - 1i32 }  if w >= n { return 0i32 - 1i32 }   /* [OOB] @export */
    GR_A[u as u64] = GR_A[u as u64] | (1u64 << (w as u64))  GR_A[w as u64] = GR_A[w as u64] | (1u64 << (u as u64))
    return 0i32
}
fn gr_edge_b(u: u32, w: u32) -> i32 @export {
    let n : u32 = GR_NB[0u64]  if u >= n { return 0i32 - 1i32 }  if w >= n { return 0i32 - 1i32 }   /* [OOB] @export */
    GR_B[u as u64] = GR_B[u as u64] | (1u64 << (w as u64))  GR_B[w as u64] = GR_B[w as u64] | (1u64 << (u as u64))
    return 0i32
}

/* ---- 1-WL colour refinement over GR_U[0..N) ---- */
fn gr_same_sig(u: u32, v: u32, oldnc: u32) -> u8 {
    if GR_COL[u as u64] != GR_COL[v as u64] { return 0u8 }
    let mut c : u32 = 0u32
    while c < oldnc { if gr_popc(GR_U[u as u64] & GR_CM[c as u64]) != gr_popc(GR_U[v as u64] & GR_CM[c as u64]) { return 0u8 }  c = c + 1u32 }
    return 1u8
}
fn gr_refine(N: u32) -> u32 {
    let mut v : u32 = 0u32  while v < N { GR_COL[v as u64] = 0u64  v = v + 1u32 }
    let mut nc : u32 = 1u32  let mut done : u8 = 0u8
    while done == 0u8 {
        let oldnc : u32 = nc
        let mut c : u32 = 0u32  while c < oldnc { GR_CM[c as u64] = 0u64  c = c + 1u32 }
        let mut w : u32 = 0u32  while w < N { GR_CM[GR_COL[w as u64]] = GR_CM[GR_COL[w as u64]] | (1u64 << (w as u64))  w = w + 1u32 }
        let mut x : u32 = 0u32  while x < N { GR_NEW[x as u64] = 0xFFFFFFFFFFFFFFFFu64  x = x + 1u32 }
        let mut nid : u32 = 0u32  let mut a : u32 = 0u32
        while a < N {
            if GR_NEW[a as u64] == 0xFFFFFFFFFFFFFFFFu64 {
                GR_NEW[a as u64] = nid as u64
                let mut b : u32 = a + 1u32
                while b < N { if GR_NEW[b as u64] == 0xFFFFFFFFFFFFFFFFu64 { if gr_same_sig(a, b, oldnc) == 1u8 { GR_NEW[b as u64] = nid as u64 } }  b = b + 1u32 }
                nid = nid + 1u32
            }
            a = a + 1u32
        }
        let mut y : u32 = 0u32  while y < N { GR_COL[y as u64] = GR_NEW[y as u64]  y = y + 1u32 }
        if nid == oldnc { done = 1u8 } else { nc = nid }
    }
    return nc
}
fn gr_ncolours_a() -> u32 @export {
    let n : u32 = GR_NA[0u64]  let mut i : u32 = 0u32  while i < n { GR_U[i as u64] = GR_A[i as u64]  i = i + 1u32 }
    return gr_refine(n)
}
fn gr_fingerprint_a() -> u64 @export {   /* hash of the stable colour-class size multiset -- a sound graph invariant */
    let n : u32 = GR_NA[0u64]  let mut i : u32 = 0u32  while i < n { GR_U[i as u64] = GR_A[i as u64]  i = i + 1u32 }
    let nc : u32 = gr_refine(n)
    /* class sizes, sorted by color id (colors are canonical by first-appearance), folded into a hash */
    let mut h : u64 = 1469598103934665603u64           /* FNV-1a 64 */
    let mut c : u32 = 0u32
    while c < nc {
        let mut cnt : u64 = 0u64  let mut v : u32 = 0u32
        while v < n { if GR_COL[v as u64] == (c as u64) { cnt = cnt + 1u64 }  v = v + 1u32 }
        h = (h ^ cnt) * 1099511628211u64
        c = c + 1u32
    }
    h = (h ^ (nc as u64)) * 1099511628211u64
    return h
}

/* ---- exact isomorphism: 1-WL filter + colour-pruned backtracking ---- */
fn gr_iso_bt(i: u32, na: u32, nb: u32) -> u8 {
    if i == na { return 1u8 }
    let mut w : u32 = 0u32
    while w < nb {
        if (GR_USED[0u64] & (1u64 << (w as u64))) == 0u64 {
            if GR_COL[i as u64] == GR_COL[(na + w) as u64] {            /* union 1-WL colours must match */
                let mut ok : u8 = 1u8  let mut j : u32 = 0u32
                while j < i {
                    let eA : u64 = (GR_A[i as u64] >> (j as u64)) & 1u64
                    let eB : u64 = (GR_B[w as u64] >> (GR_PI[j as u64] as u64)) & 1u64
                    if eA != eB { ok = 0u8  j = i } else { j = j + 1u32 }
                }
                if ok == 1u8 {
                    GR_PI[i as u64] = w  GR_USED[0u64] = GR_USED[0u64] | (1u64 << (w as u64))
                    if gr_iso_bt(i + 1u32, na, nb) == 1u8 { return 1u8 }
                    GR_USED[0u64] = GR_USED[0u64] & ((1u64 << (w as u64)) ^ 0xFFFFFFFFFFFFFFFFu64)
                }
            }
        }
        w = w + 1u32
    }
    return 0u8
}
fn gr_iso() -> u8 @export {
    let na : u32 = GR_NA[0u64]  let nb : u32 = GR_NB[0u64]
    if na != nb { return 0u8 }
    if na == 0u32 { return 1u8 }
    /* build the disjoint union: A on 0..na-1, B on na..na+nb-1 */
    let mut i : u32 = 0u32
    while i < na { GR_U[i as u64] = GR_A[i as u64]  GR_U[(na + i) as u64] = GR_B[i as u64] << (na as u64)  i = i + 1u32 }
    gr_refine(2u32 * na)
    /* 1-WL filter: the two halves must have the same colour histogram */
    let mut c : u32 = 0u32
    while c < 2u32 * na {                                 /* colours are in 0..2na; check each */
        let mut lo : u32 = 0u32  let mut hi : u32 = 0u32  let mut v : u32 = 0u32
        while v < na { if GR_COL[v as u64] == (c as u64) { lo = lo + 1u32 }  if GR_COL[(na + v) as u64] == (c as u64) { hi = hi + 1u32 }  v = v + 1u32 }
        if lo != hi { return 0u8 }                        /* sound reject */
        c = c + 1u32
    }
    /* exact: colour-pruned backtracking */
    GR_USED[0u64] = 0u64
    return gr_iso_bt(0u32, na, nb)
}

fn gr_kat() -> u64 @export {
    /* two isomorphic trees (relabelled path 0-1-2-3) */
    gr_reset_a(4u32)  gr_edge_a(0u32,1u32)  gr_edge_a(1u32,2u32)  gr_edge_a(2u32,3u32)
    gr_reset_b(4u32)  gr_edge_b(3u32,1u32)  gr_edge_b(1u32,0u32)  gr_edge_b(0u32,2u32)   /* path 3-1-0-2 */
    if gr_iso() != 1u8 { return 10u64 }
    /* path vs star on 4 vertices -> non-isomorphic, and 1-WL distinguishes them */
    gr_reset_b(4u32)  gr_edge_b(0u32,1u32)  gr_edge_b(0u32,2u32)  gr_edge_b(0u32,3u32)   /* star */
    if gr_iso() != 0u8 { return 11u64 }
    /* the 1-WL blind spot (corpus 1871): K_{3,3} vs prism -- both 3-regular, 1-WL-equal, NOT isomorphic.
     * gr_iso must STILL return 0 (the backtracking layer is complete where the fingerprint is blind). */
    gr_reset_a(6u32)
    gr_edge_a(0u32,3u32) gr_edge_a(0u32,4u32) gr_edge_a(0u32,5u32)
    gr_edge_a(1u32,3u32) gr_edge_a(1u32,4u32) gr_edge_a(1u32,5u32)
    gr_edge_a(2u32,3u32) gr_edge_a(2u32,4u32) gr_edge_a(2u32,5u32)                         /* K_{3,3} */
    gr_reset_b(6u32)
    gr_edge_b(0u32,1u32) gr_edge_b(1u32,2u32) gr_edge_b(2u32,0u32)
    gr_edge_b(3u32,4u32) gr_edge_b(4u32,5u32) gr_edge_b(5u32,3u32)
    gr_edge_b(0u32,3u32) gr_edge_b(1u32,4u32) gr_edge_b(2u32,5u32)                         /* prism */
    if gr_fingerprint_a() == 0u64 { return 12u64 }        /* fingerprint computes */
    if gr_iso() != 0u8 { return 13u64 }                   /* exact decision is correct despite the 1-WL blind spot */
    /* fingerprint soundness: isomorphic graphs share a fingerprint */
    gr_reset_a(4u32)  gr_edge_a(0u32,1u32)  gr_edge_a(1u32,2u32)  gr_edge_a(2u32,3u32)
    let fpa : u64 = gr_fingerprint_a()
    gr_reset_a(4u32)  gr_edge_a(3u32,1u32)  gr_edge_a(1u32,0u32)  gr_edge_a(0u32,2u32)
    if gr_fingerprint_a() != fpa { return 14u64 }
    return 99u64
}
