/* STDLIB/iii/numera/h12_charter.iii -- the H12 falsifier as a run_charter constitutional clause.
 *
 * H12 ("one determinism"): the substrate is DETERMINISTIC.  No float; equality-only compares;
 * deterministic allocation (M22) and scheduling; wall-clock/IO enter ONLY as quarantined sealed
 * inputs; and the build is bit-identical across iiis-0/1/2.  The falsifier is ANY nondeterminism
 * on a determinism path.  This module makes H12 a *constitutional clause* with a paired verify-AND-
 * falsify predicate (the mig6 falsifier-per-clause discipline) folded by a terminal-gate
 * run_charter: the charter is GREEN iff every clause both HOLDS on its good witness AND CATCHES its
 * bad witness.  It mirrors the GENERIC mechanism in constitution.iii (cons_clause_holds /
 * cons_holds_selftest, 673_constitution_holds) and the sibling h2/h11 charters, but H12's
 * RUNTIME-checkable CORE is REPRODUCIBILITY -- a deterministic computation yields byte-identical
 * results across independent runs -- a property the COP witness-VM cannot express, so
 * h12_canary_holds is the H12 module's OWN falsifier, ready to be unioned into the constitution's
 * run_charter (the union-of-all-module-falsifiers, mig6 gap b).
 *
 * The two concrete witnesses are the M1 content-address (numera/cad.iii) and the M22 bump arena
 * (memoria/region.iii, the determinism keystone proven by 682_arena_determinism):
 *   verify  -- a deterministic computation is REPRODUCIBLE.  (a) cad_oneshot(SHA256, msg, len)
 *              computed TWICE into two buffers is byte-identical (cad_eq == 1) -- the digest does
 *              not drift across runs.  (b) deterministic allocation: in a fresh region an alloc
 *              SEQUENCE yields addresses A; region_reset; the SAME sequence yields addresses B;
 *              A == B exactly (reproducible offsets, modeled on 682's reproducibility keystone).
 *              1 iff BOTH reproduce.  So a determinism-path computation loses NOTHING across runs.
 *   falsify -- the computation is a REAL deterministic FUNCTION, not a trivial constant (so
 *              "reproducible" is non-vacuous): cad_oneshot(SHA256, msgA) and cad_oneshot(SHA256,
 *              msgB) for DIFFERENT msgA != msgB are NOT cad_eq -- distinct inputs give distinct
 *              outputs.  If the "computation" ignored its input these would be equal; the clause
 *              CATCHES that.  1 iff distinct inputs give distinct outputs.  HOLDS = verify & falsify.
 *
 * run_charter folds every registered clause; RED (the 1-based failing-clause index) unless all
 * hold.  The negative arm in h12_selftest registers a deliberately-false canary clause (it CLAIMS a
 * deterministic op is NON-reproducible -- the same input hashed twice gives cad_eq == 0 -- which is
 * FALSE, it is reproducible) and proves the gate goes RED at index 2: the gate is a real falsifier,
 * not vacuously green.
 *
 * The STRUCTURAL half of H12 (no float, equality-only compares on determinism paths, and the
 * bit-identical iiis-0/1/2 build) is a source/build invariant a runtime clause cannot see -- it is
 * the DRIFT-gated reseal (golden BARE mhash, ADR-027).  Together (the runtime reproducibility clause
 * + the structural build-gate) they are the complete H12 falsifier.
 *
 * Hexad: kind_essence.  Ring: R-1 (a constitutional ceremony).  K: 1.00.
 * NIH: cad.iii + region.iii only.  No ML, no float, no u64 division.
 * Discipline: W2/W8/W14/W15; single-line fns; ==/!= compares; byte-stores; masked idx.
 */
module numera_h12_charter

extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_eq(a: *u8, b: *u8) -> u8 from "cad.iii"
extern @abi(c-msvc-x64) fn region_create(bytes: u64) -> u64 from "region.iii"
extern @abi(c-msvc-x64) fn region_alloc(id: u64, n: u64, align: u64) -> u64 from "region.iii"
extern @abi(c-msvc-x64) fn region_reset(id: u64) -> i32 from "region.iii"
extern @abi(c-msvc-x64) fn region_release(id: u64) -> i32 from "region.iii"
extern @abi(c-msvc-x64) fn xcc_verify(out_live: u64) -> u8 from "xii_conf_cert.iii"
extern @abi(c-msvc-x64) fn xsd_strategy_is_deterministic() -> u8 from "xii_strategy_det.iii"

const H12_OK              : i32 =  0i32
const H12_SUITE_SHA256    : u32 = 0u32
const H12_MAX_CLAUSES     : u32 = 64u32
const H12_KIND_REPRODUCE  : u8  = 0u8    /* the H12 clause: reproducible AND input-sensitive */
const H12_KIND_CANARY     : u8  = 1u8    /* a deliberately-false clause (negative arm only) */
const H12_VERDICT_GREEN   : u64 = 99u64  /* > H12_MAX_CLAUSES, so never a RED index */
const H12_U32MASK         : u64 = 0xFFFFFFFFu64

/* --- clause registry (W8-bounded; kind-tag dispatch, never a fn pointer) --- */
var H12_CLAUSE_KIND  : [u8;  64]
var H12_CLAUSE_COUNT : u32 = 0u32

/* --- test messages + digest scratch (module scope, Trap 7; serialized R-1 use; NO local var
 * arrays; two-digit prefix so no h1_ collision).  MSGA = "abc", MSGB = "abd" (one byte differs). --- */
var H12_MSGA : [u8; 8]
var H12_MSGB : [u8; 8]
var H12_D1   : [u8; 32]    /* first digest of a re-run pair */
var H12_D2   : [u8; 32]    /* second digest of a re-run pair */
var H12_LIVE : [u8; 32]    /* C.4: scratch for xcc_verify's freshly-computed live rule-semantics mhash */

/* --- region alloc-address witnesses (run A; compared against the post-reset run B) --- */
var H12_A1 : u64 = 0u64
var H12_A2 : u64 = 0u64
var H12_A3 : u64 = 0u64

/* Reset the registry + load the canonical messages "abc" (0x61,0x62,0x63) and "abd". */
fn h12_init() -> i32 @export {
    H12_CLAUSE_COUNT = 0u32
    H12_MSGA[0u64] = 0x61u8
    H12_MSGA[1u64] = 0x62u8
    H12_MSGA[2u64] = 0x63u8
    H12_MSGB[0u64] = 0x61u8
    H12_MSGB[1u64] = 0x62u8
    H12_MSGB[2u64] = 0x64u8
    return H12_OK
}

/* SHA-256 of MSGA[0..len) is REPRODUCIBLE: hash twice into D1,D2 -> cad_eq == 1.  1 = reproducible. */
fn h12_hash_reproduces(len: u64) -> u8 {
    let m : *u8 = (&H12_MSGA as u64) as *u8
    let n : u64 = len
    cad_oneshot(H12_SUITE_SHA256, m, n, (&H12_D1 as u64) as *u8)
    cad_oneshot(H12_SUITE_SHA256, m, n, (&H12_D2 as u64) as *u8)
    return cad_eq((&H12_D1 as u64) as *u8, (&H12_D2 as u64) as *u8)
}

/* Deterministic ALLOCATION is REPRODUCIBLE (M22, modeled on 682): a fresh region's alloc SEQUENCE
 * yields addresses A; region_reset; the SAME sequence yields B; A == B exactly.  1 = reproducible. */
fn h12_region_reproduces() -> u8 {
    let r : u64 = region_create(4096u64)
    if r == 0u64 { return 0u8 }
    H12_A1 = region_alloc(r, 100u64, 8u64)
    H12_A2 = region_alloc(r, 50u64, 16u64)
    H12_A3 = region_alloc(r, 30u64, 1u64)
    if H12_A1 == 0u64 { region_release(r)  return 0u8 }
    if region_reset(r) != H12_OK { region_release(r)  return 0u8 }
    let b1 : u64 = region_alloc(r, 100u64, 8u64)
    let b2 : u64 = region_alloc(r, 50u64, 16u64)
    let b3 : u64 = region_alloc(r, 30u64, 1u64)
    let mut ok : u8 = 1u8
    if b1 != H12_A1 { ok = 0u8 }
    if b2 != H12_A2 { ok = 0u8 }
    if b3 != H12_A3 { ok = 0u8 }
    region_release(r)
    return ok
}

/* The H12 clause VERIFY arm: a deterministic computation is REPRODUCIBLE -- the SHA-256 digest is
 * byte-identical across runs (on the empty string AND on "abc") AND deterministic allocation yields
 * identical addresses across a reset.  1 iff every reproduction holds. */
fn h12_verify() -> u8 @export {
    if h12_hash_reproduces(0u64) != 1u8 { return 0u8 }
    if h12_hash_reproduces(3u64) != 1u8 { return 0u8 }
    if h12_region_reproduces() != 1u8 { return 0u8 }
    /* C.4: H12 ("one determinism") also binds the XII rewrite engine's determinism.  (a) the
     * confluence-core certificate's SEALED rule-semantics mhash equals the live rules (xcc_verify) --
     * a guard/RHS/rule-set drift reddens this clause loudly (the teeth are demonstrated in corpus 826,
     * xcc_selftest's flipped-byte arm).  (b) the canonicaliser reduces by the FIXED deterministic
     * bottom-up strategy (xsd) -- the determinism floor every confluence discharge rests on. */
    if xcc_verify((&H12_LIVE as u64)) != 1u8 { return 0u8 }
    if xsd_strategy_is_deterministic() != 1u8 { return 0u8 }
    return 1u8
}

/* The H12 clause FALSIFY arm: the computation is a REAL function, not a trivial constant.  Distinct
 * inputs give DISTINCT outputs: cad_oneshot(SHA256, MSGA) != cad_oneshot(SHA256, MSGB) for the
 * DIFFERENT 3-byte messages "abc" != "abd".  1 iff the two digests are NOT equal. */
fn h12_falsify() -> u8 @export {
    cad_oneshot(H12_SUITE_SHA256, (&H12_MSGA as u64) as *u8, 3u64, (&H12_D1 as u64) as *u8)
    cad_oneshot(H12_SUITE_SHA256, (&H12_MSGB as u64) as *u8, 3u64, (&H12_D2 as u64) as *u8)
    if cad_eq((&H12_D1 as u64) as *u8, (&H12_D2 as u64) as *u8) != 0u8 { return 0u8 }
    return 1u8
}

/* The canary's holds: it CLAIMS a deterministic op is NON-reproducible -- the same input ("abc")
 * hashed twice gives cad_eq == 0 -- which is FALSE (it IS reproducible, cad_eq == 1).  A genuinely-
 * false clause used ONLY to prove run_charter goes RED on a failure.  Returns 1 iff the digest of
 * "abc" hashed twice is NON-identical (it never is) -- i.e. returns 0. */
fn h12_canary_holds() -> u8 {
    let m : *u8 = (&H12_MSGA as u64) as *u8
    cad_oneshot(H12_SUITE_SHA256, m, 3u64, (&H12_D1 as u64) as *u8)
    cad_oneshot(H12_SUITE_SHA256, m, 3u64, (&H12_D2 as u64) as *u8)
    if cad_eq((&H12_D1 as u64) as *u8, (&H12_D2 as u64) as *u8) != 1u8 { return 1u8 }
    return 0u8
}

/* Evaluate one registered clause -> 1 holds / 0 fails.  Kind-tag dispatch (never a fn ptr). */
fn h12_clause_eval(idx: u32) -> u8 {
    let k : u8 = H12_CLAUSE_KIND[(idx as u64) & H12_U32MASK]
    if k == H12_KIND_REPRODUCE {
        if h12_verify() != 1u8 { return 0u8 }
        if h12_falsify() != 1u8 { return 0u8 }
        return 1u8
    }
    if k == H12_KIND_CANARY { return h12_canary_holds() }
    return 0u8
}

/* Register a clause of kind k.  Returns the 0-based slot, or -1 if the registry is full. */
fn h12_register(k: u8) -> i32 {
    let n : u32 = H12_CLAUSE_COUNT
    if n >= H12_MAX_CLAUSES { return -1i32 }
    let slot : u64 = (n as u64) & H12_U32MASK
    H12_CLAUSE_KIND[slot] = k
    H12_CLAUSE_COUNT = n + 1u32
    return slot as i32
}

/* The terminal gate.  Fold every registered clause: GREEN (99) iff all hold; else the
 * 1-based index of the first failing clause (RED). */
fn h12_run_charter() -> u64 @export {
    let n : u32 = H12_CLAUSE_COUNT
    let mut i : u32 = 0u32
    while i < n {
        if h12_clause_eval(i) != 1u8 { return ((i as u64) & H12_U32MASK) + 1u64 }
        i = i + 1u32
    }
    return H12_VERDICT_GREEN
}

/* KAT: 99 = all pass; a distinct small code at each failed check (diagnosable).
 * Proves: a deterministic computation is REPRODUCIBLE -- digest byte-identical across runs AND
 * allocation addresses identical across a reset (1); the computation is a REAL function, not a
 * constant -- distinct inputs give distinct outputs (2); the canary is genuinely false -- the same
 * input hashed twice IS reproducible, so the "non-reproducible" claim does NOT hold (3); run_charter
 * GREEN with the H12 clause registered (4,5); GREEN is reproducible across a re-run (6); and -- the
 * prove-the-negative arm -- registering the false canary drives run_charter RED, returning the
 * canary's 1-based index (=2), proving the gate is a real falsifier, not vacuously green (7,8). */
fn h12_selftest() -> u64 @export {
    h12_init()
    if h12_verify() != 1u8 { return 1u64 }
    if h12_falsify() != 1u8 { return 2u64 }
    if h12_canary_holds() != 0u8 { return 3u64 }
    if h12_register(H12_KIND_REPRODUCE) != 0i32 { return 4u64 }
    if h12_run_charter() != H12_VERDICT_GREEN { return 5u64 }
    if h12_run_charter() != H12_VERDICT_GREEN { return 6u64 }
    if h12_register(H12_KIND_CANARY) != 1i32 { return 7u64 }
    if h12_run_charter() != 2u64 { return 8u64 }
    return 99u64
}

/* h12_charter EMBODIES the H12 invariant as a self-falsifying constitutional clause: a determinism-
 * path computation is REPRODUCIBLE (the content-address digest is byte-identical across runs and
 * deterministic allocation yields identical addresses across a reset), and -- so reproducibility is
 * non-vacuous -- the computation is a REAL function whose distinct inputs give distinct outputs,
 * while the terminal gate proves itself RED on a clause that pretends a deterministic op is non-
 * reproducible.  The structural companion (no float, equality-only compares, the bit-identical
 * iiis-0/1/2 reseal) completes the H12 falsifier. */
