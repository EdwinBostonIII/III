/* STDLIB/iii/numera/h1_charter.iii — the H1 falsifier as a run_charter constitutional clause.
 *
 * H1 ("one value"): every datum crossing a boundary is a Sovereign Value (M5) --
 * SovVal = { payload(gap+provenance, M4) | hexad(M3) | witness(M6 cad digest) |
 * cost(M13) }.  A non-sovereign boundary is a type error; the falsifier is a raw
 * value at a boundary.  This module makes H1 a *constitutional clause* with a paired
 * verify-AND-falsify predicate (the falsifier-per-clause discipline) folded by a
 * terminal-gate run_charter: the charter is GREEN iff every clause both HOLDS on its
 * good witness AND CATCHES its bad witness.  It mirrors h2_charter.iii (the H2 sibling
 * clause) exactly: const/var prefixed h1_; a kind-tag clause registry (never a fn
 * pointer); h1_init; verify/falsify arms; a deliberately-false canary; clause_eval;
 * register; the terminal-gate run_charter; and a selftest whose negative arm registers
 * the canary then asserts the gate goes RED.  H1 is the value-shape boundary property
 * the constitution VM cannot express, so h1_charter is H1's OWN falsifier, ready to be
 * unioned into the constitution's run_charter (the union-of-all-module-falsifiers).
 *
 * The H1 clause's two runtime-checkable facets, evaluated through the M5 boundary
 * constructor sv_make(payload, hexad, cost, out):
 *   verify  -- the boundary ADMITS a sovereign value: sv_make on a VALID input (a
 *              reachable hexad (728, all-POS) + an in-budget cost + a Known payload)
 *              returns SV_OK and yields a WELL-FORMED SovVal -- its facets read back
 *              exactly: status not-refused, hexad == 728, payload Known-value == the
 *              input.  So routing a valid datum through the one currency loses NOTHING.
 *   falsify -- the boundary REFUSES a non-sovereign value: sv_make REFUSES a
 *              non-reachable hexad (0, pillar0=NEG -> M3 unreachable) AND REFUSES an
 *              over-budget cost (M13: cost must be <= the K-floor ceiling).  If the
 *              boundary admitted raw/invalid values these would be SV_OK; the clause
 *              CATCHES that.  The arm is 1 iff BOTH refusals happen.  HOLDS = verify & falsify.
 *
 * run_charter folds every registered clause; RED (the 1-based failing-clause index)
 * unless all hold.  The negative arm in h1_selftest registers a deliberately-false
 * canary clause (sv_make ACCEPTS a non-reachable hexad, which is FALSE since the
 * boundary refuses it) and proves the gate goes RED -- the gate is a real falsifier,
 * not vacuously green.
 *
 * The STRUCTURAL half of H1 ("no raw value computed across a boundary") is the
 * compiler-level @sovereign boundary checker (migration #3) -- a property a runtime
 * clause cannot see.  Together (runtime admission/refusal clause + structural
 * boundary-type gate) they are the complete H1 falsifier.
 *
 * Hexad: kind_essence.  Ring: R-1 (a constitutional ceremony).  K: 1.00.
 * NIH: sovval.iii (+ its M3/M4/M13/M1 facet-organs) + uncertainty.iii only.  No ML,
 * no float, no u64 division.
 * Discipline: W2/W8/W14/W15; single-line fns; ==/!= compares; masked idx.
 */
module numera_h1_charter

extern @abi(c-msvc-x64) fn sv_make(payload_cell: *u8, hexad: u64, cost: *u64, out: *u8) -> i32 from "sovval.iii"
extern @abi(c-msvc-x64) fn sv_hexad(sv: *u8) -> u64 from "sovval.iii"
extern @abi(c-msvc-x64) fn sv_is_refused(sv: *u8) -> u8 from "sovval.iii"
extern @abi(c-msvc-x64) fn unc_set_known(cell: *u8, v: i64) -> i32 from "uncertainty.iii"
extern @abi(c-msvc-x64) fn unc_is_gap(cell: *u8) -> u8 from "uncertainty.iii"
extern @abi(c-msvc-x64) fn unc_known_val(cell: *u8) -> i64 from "uncertainty.iii"

const H1_OK            : i32 =  0i32
const H1_SV_OK         : i32 =  0i32    /* sovval SV_OK: the boundary admitted the value */
const H1_SV_REFUSED    : i32 =  1i32    /* sovval SV_REFUSED: the boundary rejected the value */
const H1_HEXAD_GOOD    : u64 = 728u64   /* reachable hexad (all-POS) */
const H1_HEXAD_BAD     : u64 = 0u64     /* non-reachable hexad (pillar0=NEG) */
const H1_PAYLOAD_VAL   : i64 = 7i64     /* the Known payload carried across the boundary */
const H1_MAX_CLAUSES   : u32 = 64u32
const H1_KIND_SOVEREIGN: u8  = 0u8      /* the H1 clause: boundary admits sovereign AND refuses raw */
const H1_KIND_CANARY   : u8  = 1u8      /* a deliberately-false clause (negative arm only) */
const H1_VERDICT_GREEN : u64 = 99u64    /* > H1_MAX_CLAUSES, so never a RED index */
const H1_U32MASK       : u64 = 0xFFFFFFFFu64

/* --- clause registry (W8-bounded; kind-tag dispatch, never a fn pointer) --- */
var H1_CLAUSE_KIND  : [u8;  64]
var H1_CLAUSE_COUNT : u32 = 0u32

/* --- SovVal scratch (module-scope, Trap 7; serialized R-1 use) --- */
var H1_SV     : [u8; 112]    /* a SovVal cell (112 bytes, u64-aligned) */
var H1_PC     : [u8; 16]     /* a payload (M4 ucell) */
var H1_COST_LO: [u64; 6]     /* an in-budget cost vector (all 1) */
var H1_COST_HI: [u64; 6]     /* an over-budget cost vector (dim0 = 2000000 > budget 1000000) */

/* Reset the registry + load the two canonical cost vectors (lo = in-budget, hi = over). */
fn h1_init() -> i32 @export {
    H1_CLAUSE_COUNT = 0u32
    let mut i : u64 = 0u64
    while i < 6u64 { H1_COST_LO[i] = 1u64  H1_COST_HI[i] = 1u64  i = i + 1u64 }
    H1_COST_HI[0u64] = 2000000u64
    unc_set_known((&H1_PC as u64) as *u8, H1_PAYLOAD_VAL)
    return H1_OK
}

/* The H1 clause VERIFY arm: the boundary ADMITS a sovereign value and it reads back
 * well-formed.  sv_make(valid hexad + in-budget cost + Known payload) -> SV_OK, status
 * not-refused, hexad == 728, payload Known-value == 7.  1 iff all hold. */
fn h1_verify() -> u8 @export {
    let sv : *u8 = (&H1_SV as u64) as *u8
    let pc : *u8 = (&H1_PC as u64) as *u8
    let lo : *u64 = (&H1_COST_LO as u64) as *u64
    unc_set_known(pc, H1_PAYLOAD_VAL)
    if sv_make(pc, H1_HEXAD_GOOD, lo, sv) != H1_SV_OK { return 0u8 }
    if sv_is_refused(sv) != 0u8 { return 0u8 }
    if sv_hexad(sv) != H1_HEXAD_GOOD { return 0u8 }
    if unc_is_gap(sv) != 0u8 { return 0u8 }
    if unc_known_val(sv) != H1_PAYLOAD_VAL { return 0u8 }
    return 1u8
}

/* The H1 clause FALSIFY arm: the boundary REFUSES a non-sovereign value.  sv_make
 * refuses a non-reachable hexad (0) AND refuses an over-budget cost.  1 iff BOTH
 * refusals happen (both SV_REFUSED, both sv_is_refused == 1). */
fn h1_falsify() -> u8 @export {
    let sv : *u8 = (&H1_SV as u64) as *u8
    let pc : *u8 = (&H1_PC as u64) as *u8
    let lo : *u64 = (&H1_COST_LO as u64) as *u64
    let hi : *u64 = (&H1_COST_HI as u64) as *u64
    unc_set_known(pc, H1_PAYLOAD_VAL)
    /* refusal 1: non-reachable hexad with an otherwise-valid (in-budget) cost */
    if sv_make(pc, H1_HEXAD_BAD, lo, sv) != H1_SV_REFUSED { return 0u8 }
    if sv_is_refused(sv) != 1u8 { return 0u8 }
    /* refusal 2: over-budget cost with an otherwise-valid (reachable) hexad */
    if sv_make(pc, H1_HEXAD_GOOD, hi, sv) != H1_SV_REFUSED { return 0u8 }
    if sv_is_refused(sv) != 1u8 { return 0u8 }
    return 1u8
}

/* The canary's holds: sv_make ACCEPTS a non-reachable hexad -- i.e. claims the boundary
 * returns SV_OK on hexad 0.  This is FALSE (the boundary refuses it), so this returns 0.
 * A genuinely-false clause used ONLY to prove run_charter goes RED on a failure. */
fn h1_canary_holds() -> u8 {
    let sv : *u8 = (&H1_SV as u64) as *u8
    let pc : *u8 = (&H1_PC as u64) as *u8
    let lo : *u64 = (&H1_COST_LO as u64) as *u64
    unc_set_known(pc, H1_PAYLOAD_VAL)
    if sv_make(pc, H1_HEXAD_BAD, lo, sv) == H1_SV_OK { return 1u8 }
    return 0u8
}

/* Evaluate one registered clause -> 1 holds / 0 fails.  Kind-tag dispatch (never a fn ptr). */
fn h1_clause_eval(idx: u32) -> u8 {
    let k : u8 = H1_CLAUSE_KIND[(idx as u64) & H1_U32MASK]
    if k == H1_KIND_SOVEREIGN {
        if h1_verify() != 1u8 { return 0u8 }
        if h1_falsify() != 1u8 { return 0u8 }
        return 1u8
    }
    if k == H1_KIND_CANARY { return h1_canary_holds() }
    return 0u8
}

/* Register a clause of kind k.  Returns the 0-based slot, or -1 if the registry is full. */
fn h1_register(k: u8) -> i32 {
    let n : u32 = H1_CLAUSE_COUNT
    if n >= H1_MAX_CLAUSES { return -1i32 }
    let slot : u64 = (n as u64) & H1_U32MASK
    H1_CLAUSE_KIND[slot] = k
    H1_CLAUSE_COUNT = n + 1u32
    return slot as i32
}

/* The terminal gate.  Fold every registered clause: GREEN (99) iff all hold; else the
 * 1-based index of the first failing clause (RED). */
fn h1_run_charter() -> u64 @export {
    let n : u32 = H1_CLAUSE_COUNT
    let mut i : u32 = 0u32
    while i < n {
        if h1_clause_eval(i) != 1u8 { return ((i as u64) & H1_U32MASK) + 1u64 }
        i = i + 1u32
    }
    return H1_VERDICT_GREEN
}

/* KAT: 99 = all pass; a distinct small code at each failed check (diagnosable).
 * Proves: the boundary admits a well-formed sovereign value (1); the boundary refuses
 * both a non-reachable hexad and an over-budget cost (2); the canary is genuinely false
 * (3); run_charter GREEN with the H1 clause registered (4,5); reproducible (6); and --
 * the prove-the-negative arm -- run_charter goes RED, returning the failing canary's
 * 1-based index (=2), proving the gate is a real falsifier, not vacuously green (7,8). */
fn h1_selftest() -> u64 @export {
    h1_init()
    if h1_verify() != 1u8 { return 1u64 }
    if h1_falsify() != 1u8 { return 2u64 }
    if h1_canary_holds() != 0u8 { return 3u64 }
    if h1_register(H1_KIND_SOVEREIGN) != 0i32 { return 4u64 }
    if h1_run_charter() != H1_VERDICT_GREEN { return 5u64 }
    if h1_run_charter() != H1_VERDICT_GREEN { return 6u64 }
    if h1_register(H1_KIND_CANARY) != 1i32 { return 7u64 }
    if h1_run_charter() != 2u64 { return 8u64 }
    return 99u64
}

/* h1_charter EMBODIES the H1 invariant as a self-falsifying constitutional clause:
 * the one value (the Sovereign Value, M5) is the only datum a boundary admits -- the
 * boundary admits a well-formed sovereign and refuses every non-sovereign (unreachable
 * hexad / over-budget cost), and the terminal gate proves itself RED on a failing
 * clause.  The structural companion (the @sovereign boundary checker) forbids any raw
 * value crossing a boundary. */
