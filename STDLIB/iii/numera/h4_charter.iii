/* STDLIB/iii/numera/h4_charter.iii -- the H4 falsifier as a run_charter constitutional clause.
 *
 * H4 ("one engine"): every computation is evaluated by XII (M7); confluence makes rewrite
 * ORDER irrelevant, so a term has exactly ONE normal form.  The single trusted evaluator is
 * the XII canonicaliser (omnia/xii_canonicalise.iii) over the sealed, confluence-certified
 * rule set (omnia/xii_rewrite.iii); there is no second evaluator and no term with two normal
 * forms.  This module makes H4 a *constitutional clause* with a paired verify-AND-falsify
 * predicate (the falsifier-per-clause discipline) folded by a terminal-gate run_charter: the
 * charter is GREEN iff every clause both HOLDS on its good witness AND CATCHES its bad
 * witness.  It mirrors h3_charter.iii / h6_charter.iii (the sibling clauses) exactly:
 * const/var prefixed h4_; a kind-tag clause registry (never a fn pointer); h4_init;
 * verify/falsify arms; a deliberately-false canary; clause_eval; register; the terminal-gate
 * run_charter; and a selftest whose negative arm registers the canary then asserts the gate
 * goes RED at index 2.  H4 is the one-engine "every computation reduces through XII to a
 * unique normal form" property the constitution VM cannot express, so h4_charter is H4's OWN
 * falsifier, ready to be unioned into the constitution's run_charter (the union-of-all-
 * module-falsifiers).
 *
 * The H4 clause is evaluated through the one engine -- the XII canonicaliser over trit terms
 * (the M2 algebra evaluated AS XII rewrite rules R/101-105, the M7 keystone).  TRIT_VAL leaf
 * subform encodes the trit (NEG=0, ZERO=1, POS=2; make_basis(VAL, trit+1)); a TRIT_op of two
 * VAL leaves reduces to the VAL of the proven M2 result.  Its two runtime-checkable facets:
 *   verify  -- XII is the ONE DETERMINISTIC evaluator with ONE normal form, and it actually
 *              REDUCES.  (a) Determinism / one-NF: build AND(VAL(POS),VAL(POS)) twice (both
 *              refs live in one arena -- the engine's allocation is deterministic), canonicalise
 *              each independently to NF1, NF2; struct_eq(NF1, NF2) == 1 -- the same term has one
 *              normal form regardless of which copy / firing trace produced it.  (b) Reduces:
 *              the un-reduced fusion AND(VAL(POS),VAL(POS)) (kind 26) is NOT struct_eq to its
 *              normal form NF1 (a VAL leaf, kind 24) -- a rewrite genuinely fired; the engine
 *              evaluates, it does not just re-emit the input.  1 iff both hold.
 *   falsify -- the engine DISTINGUISHES non-equivalent terms (it is a real evaluator, not a
 *              collapse-everything): AND(VAL(POS),VAL(POS)) -> VAL(POS) and OR(VAL(NEG),VAL(NEG))
 *              -> VAL(NEG) have DIFFERENT normal forms, so struct_eq(NF_and, NF_or) == 0.  If the
 *              engine mapped everything to one term, these would be equal; the clause CATCHES
 *              that.  1 iff distinct inputs reach distinct normal forms.  HOLDS = verify & falsify.
 *
 * run_charter folds every registered clause; RED (the 1-based failing-clause index) unless all
 * hold.  The negative arm in h4_selftest registers a deliberately-false canary clause -- it
 * claims the SAME term canonicalises to TWO DIFFERENT normal forms (struct_eq(NF1,NF2) == 0),
 * which is FALSE since XII is deterministic -- and proves the gate goes RED at index 2: the
 * gate is a real falsifier, not vacuously green.
 *
 * The STRUCTURAL half of H4 ("no computation evaluated outside XII; no second evaluator
 * exists") is a source/build invariant a runtime clause cannot see.  Together (runtime one-NF /
 * distinguishing clause + structural one-engine gate) they are the complete H4 falsifier.
 *
 * Hexad: kind_compose.  Ring: R-1 (a constitutional ceremony over R0 XII terms).  K: 1.00.
 * NIH: xii_term.iii + xii_canonicalise.iii + xii_rewrite.iii only.  No ML, no float, no u64 div.
 * Discipline: W2/W8/W14/W15; single-line fns; ==/!= compares; masked idx.
 */
module numera_h4_charter

extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_fusion2(kind: u8, a: u32, b: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_canonicalise(t: u32) -> u32 from "xii_canonicalise.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_struct_eq(a: u32, b: u32) -> u8 from "xii_rewrite.iii"

const H4_OK              : i32 =  0i32
const H4_TRIT_VAL        : u8  = 24u8    /* TRIT_VAL leaf kind; subform = trit + 1 */
const H4_TRIT_AND        : u8  = 26u8    /* strong-Kleene AND (= min) */
const H4_TRIT_OR         : u8  = 27u8    /* strong-Kleene OR  (= max) */
const H4_TRIT_SUM        : u8  = 28u8    /* clamped balanced add */
const H4_VAL_NEG         : u32 = 0u32    /* make_basis(VAL, NEG=-1 + 1) */
const H4_VAL_ZERO        : u32 = 1u32    /* make_basis(VAL, ZERO=0 + 1) */
const H4_VAL_POS         : u32 = 2u32    /* make_basis(VAL, POS=+1 + 1) */
const H4_NULL_REF        : u32 = 0xFFFFFFFFu32
const H4_MAX_CLAUSES     : u32 = 64u32
const H4_KIND_ONEENGINE  : u8  = 0u8     /* the H4 clause: one-NF + reduces + distinguishes */
const H4_KIND_CANARY     : u8  = 1u8     /* a deliberately-false clause (negative arm only) */
const H4_VERDICT_GREEN   : u64 = 99u64   /* > H4_MAX_CLAUSES, so never a RED index */
const H4_U32MASK         : u64 = 0xFFFFFFFFu64

/* --- clause registry (W8-bounded; kind-tag dispatch, never a fn pointer) --- */
var H4_CLAUSE_KIND  : [u8;  64]
var H4_CLAUSE_COUNT : u32 = 0u32

/* Reset the registry.  (The XII arena is reset per-witness inside the arms.) */
fn h4_init() -> i32 @export {
    H4_CLAUSE_COUNT = 0u32
    return H4_OK
}

/* Build a TRIT_VAL leaf carrying trit value `tv` (already +1-encoded subform). */
fn h4_mkval(tv: u32) -> u32 {
    return xii_term_make_basis(H4_TRIT_VAL, tv)
}

/* Build op(VAL(va), VAL(vb)) as a fresh fusion in the current arena. */
fn h4_mkop(op: u8, va: u32, vb: u32) -> u32 {
    return xii_term_make_fusion2(op, h4_mkval(va), h4_mkval(vb))
}

/* The H4 clause VERIFY arm.  XII is the ONE DETERMINISTIC evaluator that actually REDUCES.
 *   (a) one normal form: AND(VAL(POS),VAL(POS)) built twice (both refs live in one arena)
 *       canonicalises to NF1, NF2 with struct_eq(NF1,NF2) == 1 -- one term, one normal form.
 *   (b) reduces: the un-reduced fusion (the second copy, kept before its canonicalise) is NOT
 *       struct_eq to NF1 -- a rewrite genuinely fired.
 * 1 iff both hold. */
fn h4_verify() -> u8 @export {
    xii_term_arena_reset()
    let t0 : u32 = h4_mkop(H4_TRIT_AND, H4_VAL_POS, H4_VAL_POS)
    let t1 : u32 = h4_mkop(H4_TRIT_AND, H4_VAL_POS, H4_VAL_POS)
    if t0 == H4_NULL_REF { return 0u8 }
    if t1 == H4_NULL_REF { return 0u8 }
    let nf1 : u32 = xii_canonicalise(t0)
    /* (b) reduces: t1 is still the un-reduced AND fusion (kind 26); NF1 is a VAL leaf
     * (kind 24).  struct_eq must be 0 -- a rule fired, the engine did not re-emit input. */
    if xii_rewrite_struct_eq(nf1, t1) != 0u8 { return 0u8 }
    let nf2 : u32 = xii_canonicalise(t1)
    /* (a) one normal form: the two independent canonicalisations agree. */
    if xii_rewrite_struct_eq(nf1, nf2) != 1u8 { return 0u8 }
    return 1u8
}

/* The H4 clause FALSIFY arm: the one engine DISTINGUISHES non-equivalent terms (it is a real
 * evaluator, not a collapse-everything map).  AND(VAL(POS),VAL(POS)) -> VAL(POS) and
 * OR(VAL(NEG),VAL(NEG)) -> VAL(NEG) have DIFFERENT normal forms.  1 iff struct_eq(NF_and,
 * NF_or) == 0 -- distinct inputs reach distinct normal forms. */
fn h4_falsify() -> u8 @export {
    xii_term_arena_reset()
    let ta : u32 = h4_mkop(H4_TRIT_AND, H4_VAL_POS, H4_VAL_POS)
    let to : u32 = h4_mkop(H4_TRIT_OR, H4_VAL_NEG, H4_VAL_NEG)
    if ta == H4_NULL_REF { return 0u8 }
    if to == H4_NULL_REF { return 0u8 }
    let nf_and : u32 = xii_canonicalise(ta)
    let nf_or : u32 = xii_canonicalise(to)
    if xii_rewrite_struct_eq(nf_and, nf_or) != 0u8 { return 0u8 }
    return 1u8
}

/* The canary's holds: it CLAIMS the SAME term canonicalises to TWO DIFFERENT normal forms --
 * i.e. struct_eq(NF1, NF2) == 0 on a re-canonicalisation of identical inputs.  This is FALSE
 * (XII is deterministic: one term, one normal form), so this returns 0.  A genuinely-false
 * clause used ONLY to prove run_charter goes RED on a failure.  Returns 1 iff the (false)
 * two-normal-forms claim were true. */
fn h4_canary_holds() -> u8 {
    xii_term_arena_reset()
    let t0 : u32 = h4_mkop(H4_TRIT_AND, H4_VAL_POS, H4_VAL_POS)
    let t1 : u32 = h4_mkop(H4_TRIT_AND, H4_VAL_POS, H4_VAL_POS)
    if t0 == H4_NULL_REF { return 0u8 }
    if t1 == H4_NULL_REF { return 0u8 }
    let nf1 : u32 = xii_canonicalise(t0)
    let nf2 : u32 = xii_canonicalise(t1)
    if xii_rewrite_struct_eq(nf1, nf2) == 0u8 { return 1u8 }
    return 0u8
}

/* Evaluate one registered clause -> 1 holds / 0 fails.  Kind-tag dispatch (never a fn ptr). */
fn h4_clause_eval(idx: u32) -> u8 {
    let k : u8 = H4_CLAUSE_KIND[(idx as u64) & H4_U32MASK]
    if k == H4_KIND_ONEENGINE {
        if h4_verify() != 1u8 { return 0u8 }
        if h4_falsify() != 1u8 { return 0u8 }
        return 1u8
    }
    if k == H4_KIND_CANARY { return h4_canary_holds() }
    return 0u8
}

/* Register a clause of kind k.  Returns the 0-based slot, or -1 if the registry is full. */
fn h4_register(k: u8) -> i32 {
    let n : u32 = H4_CLAUSE_COUNT
    if n >= H4_MAX_CLAUSES { return -1i32 }
    let slot : u64 = (n as u64) & H4_U32MASK
    H4_CLAUSE_KIND[slot] = k
    H4_CLAUSE_COUNT = n + 1u32
    return slot as i32
}

/* The terminal gate.  Fold every registered clause: GREEN (99) iff all hold; else the
 * 1-based index of the first failing clause (RED). */
fn h4_run_charter() -> u64 @export {
    let n : u32 = H4_CLAUSE_COUNT
    let mut i : u32 = 0u32
    while i < n {
        if h4_clause_eval(i) != 1u8 { return ((i as u64) & H4_U32MASK) + 1u64 }
        i = i + 1u32
    }
    return H4_VERDICT_GREEN
}

/* KAT: 99 = all pass; a distinct small code at each failed check (diagnosable).
 * Proves: XII is the one deterministic evaluator with one normal form and it actually reduces
 * (1); the engine distinguishes non-equivalent terms -- AND(POS,POS) and OR(NEG,NEG) have
 * different normal forms (2); the canary is genuinely false -- the same term does NOT have two
 * normal forms (3); run_charter GREEN with the H4 clause registered (4,5); reproducible (6);
 * and -- the prove-the-negative arm -- run_charter goes RED, returning the failing canary's
 * 1-based index (=2), proving the gate is a real falsifier, not vacuously green (7,8). */
fn h4_selftest() -> u64 @export {
    h4_init()
    if h4_verify() != 1u8 { return 1u64 }
    if h4_falsify() != 1u8 { return 2u64 }
    if h4_canary_holds() != 0u8 { return 3u64 }
    if h4_register(H4_KIND_ONEENGINE) != 0i32 { return 4u64 }
    if h4_run_charter() != H4_VERDICT_GREEN { return 5u64 }
    if h4_run_charter() != H4_VERDICT_GREEN { return 6u64 }
    if h4_register(H4_KIND_CANARY) != 1i32 { return 7u64 }
    if h4_run_charter() != 2u64 { return 8u64 }
    return 99u64
}

/* h4_charter EMBODIES the H4 invariant as a self-falsifying constitutional clause: the one
 * engine (XII, M7) evaluates every computation to a UNIQUE normal form -- the same term has
 * one normal form regardless of firing order (confluence), the engine genuinely reduces
 * (a rule fires), and it DISTINGUISHES non-equivalent terms (a real evaluator, not a
 * collapse) -- and the terminal gate proves itself RED on a clause that pretends one term has
 * two normal forms.  The structural companion (no computation evaluated outside XII, no
 * second evaluator) completes the H4 falsifier. */
