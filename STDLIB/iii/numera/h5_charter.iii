/* STDLIB/iii/numera/h5_charter.iii -- the H5 falsifier as a run_charter constitutional clause.
 *
 * H5 ("one logic"): safety (hexad, M3) and uncertainty (gap, M4) are the ONE ternary
 * Kleene algebra (M2); errors are sealed crystals (M27); all are readings of the SovVal.
 * This module makes H5 a *constitutional clause* with a paired verify-AND-falsify
 * predicate (the falsifier-per-clause discipline) folded by a terminal-gate run_charter:
 * the charter is GREEN iff every clause both HOLDS on its good witness AND CATCHES its
 * bad witness.  This mirrors the GENERIC mechanism in h2_charter.iii -- a
 * verify(good) AND falsify(bad) clause folded by run_charter -- but where H2 is a
 * hash-byte-identity property, H5 is the algebraic-law property of the ONE logic, so
 * h5_holds is the H5 module's OWN falsifier, ready to be unioned into the constitution's
 * run_charter (the union-of-all-module-falsifiers).
 *
 * The H5 clause's two runtime-checkable facets, over the trit values NEG/ZERO/POS
 * (compared by EQUALITY ONLY -- the i32-ordering SIGSEGV trap):
 *   verify  -- the ONE logic OBEYS the Kleene laws over the WHOLE 3x3 domain:
 *              De Morgan  NOT(AND a b) == OR(NOT a, NOT b),
 *              double-negation  NOT(NOT a) == a,
 *              commutativity  AND(a,b)==AND(b,a) and OR(a,b)==OR(b,a),
 *              and the ZERO annihilator  MUL(ZERO,a)==ZERO.  Because hexad safety,
 *              gap uncertainty, and crystal errors are ALL readings of THIS algebra,
 *              proving the algebra's laws is proving the one logic is sound -- this is
 *              *why* M3/M4/M27 can share a single logic; the clause proves the premise.
 *   falsify -- the algebra is the REAL Kleene one, not a degenerate one where every
 *              value collapses to one: specific WRONG relations are FALSE here --
 *              AND(POS,POS) != NEG, NOT(ZERO) != POS, OR(NEG,NEG) != POS.  In a
 *              collapsed algebra these would all hold; the clause CATCHES that.
 *              HOLDS = verify & falsify.
 *
 * run_charter folds every registered clause; RED (the 1-based failing-clause index)
 * unless all hold.  The negative arm in h5_selftest registers a deliberately-false
 * canary clause (AND(POS,POS) == NEG, which is FALSE since AND(POS,POS)==POS) and
 * proves the gate goes RED at index 2 -- the gate is a real falsifier, not vacuously
 * green.  On GREEN the charter seals a small numeric verdict over its clause kinds.
 *
 * The STRUCTURAL half of H5 (hexad/gap/crystal are the readings; one logic, no second
 * algebra) is the source-level unification across M3/M4/M27 -- a property a runtime
 * clause cannot see.  Together (runtime law clause + structural single-algebra) they
 * are the complete H5 falsifier.
 *
 * Hexad: kind_essence.  Ring: R-1 (a constitutional ceremony).  K: 1.00.
 * NIH: trit.iii only (the one algebra).  No ML, no float, no u64 division.
 * Discipline: W2/W8/W14/W15; single-line fns; ==/!= compares; masked idx.
 */
module numera_h5_charter

extern @abi(c-msvc-x64) fn iii_trit_valid(v: i32) -> u8 from "trit.iii"
extern @abi(c-msvc-x64) fn iii_trit_not(a: i32) -> i32 from "trit.iii"
extern @abi(c-msvc-x64) fn iii_trit_and(a: i32, b: i32) -> i32 from "trit.iii"
extern @abi(c-msvc-x64) fn iii_trit_or(a: i32, b: i32) -> i32 from "trit.iii"
extern @abi(c-msvc-x64) fn iii_trit_mul(a: i32, b: i32) -> i32 from "trit.iii"

const H5_OK            : i32 =  0i32
const H5_NEG           : i32 = -1i32    /* the three trit values of the one logic */
const H5_ZERO          : i32 =  0i32
const H5_POS           : i32 =  1i32
const H5_MAX_CLAUSES    : u32 = 64u32
const H5_KIND_KLEENE    : u8  = 0u8     /* the H5 clause: laws hold AND non-Kleene relations are false */
const H5_KIND_CANARY    : u8  = 1u8     /* a deliberately-false clause (negative arm only) */
const H5_VERDICT_GREEN  : u64 = 99u64   /* > H5_MAX_CLAUSES, so never a RED index */
const H5_U32MASK        : u64 = 0xFFFFFFFFu64

/* --- clause registry (W8-bounded; kind-tag dispatch, never a fn pointer) --- */
var H5_CLAUSE_KIND  : [u8;  64]
var H5_CLAUSE_COUNT : u32 = 0u32

/* --- verdict scratch (module-scope, Trap 7; serialized R-1 use) --- */
var H5_VERDICT  : u64 = 0u64   /* the sealed charter verdict (a small numeric seal) */
var H5_SAVED    : u64 = 0u64   /* selftest: saved green verdict for the re-run compare */

/* Reset the registry. */
fn h5_init() -> i32 @export {
    H5_CLAUSE_COUNT = 0u32
    H5_VERDICT = 0u64
    return H5_OK
}

/* The H5 clause VERIFY arm: the Kleene laws HOLD over the WHOLE 3x3 trit domain.
 * De Morgan, double-negation, commutativity (AND/OR), ZERO annihilator. 1 = all hold. */
fn h5_verify() -> u8 @export {
    let mut ai : u64 = 0u64
    while ai < 3u64 {
        let a : i32 = (ai as i32) - 1i32
        let mut bi : u64 = 0u64
        while bi < 3u64 {
            let b : i32 = (bi as i32) - 1i32
            /* De Morgan: not(and) == or(not,not) */
            if iii_trit_not(iii_trit_and(a, b)) != iii_trit_or(iii_trit_not(a), iii_trit_not(b)) { return 0u8 }
            /* commutativity of and/or */
            if iii_trit_and(a, b) != iii_trit_and(b, a) { return 0u8 }
            if iii_trit_or(a, b) != iii_trit_or(b, a) { return 0u8 }
            bi = bi + 1u64
        }
        /* double-negation involution + ZERO annihilator (per a) */
        if iii_trit_not(iii_trit_not(a)) != a { return 0u8 }
        if iii_trit_mul(H5_ZERO, a) != H5_ZERO { return 0u8 }
        ai = ai + 1u64
    }
    return 1u8
}

/* The H5 clause FALSIFY arm: specific NON-Kleene relations are FALSE in the one logic
 * (the algebra is the real Kleene one, not a degenerate collapse). 1 = all wrong relations
 * are indeed false. */
fn h5_falsify() -> u8 @export {
    /* AND(POS,POS) is POS, NOT NEG */
    if iii_trit_and(H5_POS, H5_POS) == H5_NEG { return 0u8 }
    /* NOT(ZERO) is ZERO, NOT POS */
    if iii_trit_not(H5_ZERO) == H5_POS { return 0u8 }
    /* OR(NEG,NEG) is NEG, NOT POS */
    if iii_trit_or(H5_NEG, H5_NEG) == H5_POS { return 0u8 }
    /* the values are genuinely distinct (no collapse): NEG, ZERO, POS pairwise unequal */
    if H5_NEG == H5_ZERO { return 0u8 }
    if H5_ZERO == H5_POS { return 0u8 }
    if H5_NEG == H5_POS { return 0u8 }
    /* and all three are valid trits (the readings live in the one algebra) */
    if iii_trit_valid(H5_NEG) != 1u8 { return 0u8 }
    if iii_trit_valid(H5_ZERO) != 1u8 { return 0u8 }
    if iii_trit_valid(H5_POS) != 1u8 { return 0u8 }
    return 1u8
}

/* The canary's holds: AND(POS,POS) == NEG -- FALSE (AND(POS,POS) is POS).
 * A genuinely-false clause used ONLY to prove run_charter goes RED on a failure. */
fn h5_canary_holds() -> u8 {
    if iii_trit_and(H5_POS, H5_POS) == H5_NEG { return 1u8 }
    return 0u8
}

/* Evaluate one registered clause -> 1 holds / 0 fails.  Kind-tag dispatch (never a fn ptr). */
fn h5_clause_eval(idx: u32) -> u8 {
    let k : u8 = H5_CLAUSE_KIND[(idx as u64) & H5_U32MASK]
    if k == H5_KIND_KLEENE {
        if h5_verify() != 1u8 { return 0u8 }
        if h5_falsify() != 1u8 { return 0u8 }
        return 1u8
    }
    if k == H5_KIND_CANARY { return h5_canary_holds() }
    return 0u8
}

/* Register a clause of kind k.  Returns the 0-based slot, or -1 if the registry is full. */
fn h5_register(k: u8) -> i32 {
    let n : u32 = H5_CLAUSE_COUNT
    if n >= H5_MAX_CLAUSES { return -1i32 }
    let slot : u64 = (n as u64) & H5_U32MASK
    H5_CLAUSE_KIND[slot] = k
    H5_CLAUSE_COUNT = n + 1u32
    return slot as i32
}

/* Seal the GREEN verdict: a small numeric fold over count and clause kinds (no externs,
 * the one logic needs no hash to witness its own GREEN). */
fn h5_seal_verdict(n: u32) -> i32 {
    let n64 : u64 = (n as u64) & H5_U32MASK
    let mut acc : u64 = 0x9E3779B9u64 + n64
    let mut b : u64 = 0u64
    while b < n64 {
        acc = acc + (H5_CLAUSE_KIND[b] as u64) + 1u64
        acc = acc + (acc + 1u64)
        b = b + 1u64
    }
    H5_VERDICT = acc
    return H5_OK
}

/* The terminal gate.  Fold every registered clause: GREEN (99) iff all hold; else the
 * 1-based index of the first failing clause (RED).  GREEN seals the numeric verdict. */
fn h5_run_charter() -> u64 @export {
    let n : u32 = H5_CLAUSE_COUNT
    let mut i : u32 = 0u32
    while i < n {
        if h5_clause_eval(i) != 1u8 { return ((i as u64) & H5_U32MASK) + 1u64 }
        i = i + 1u32
    }
    h5_seal_verdict(n)
    return H5_VERDICT_GREEN
}

/* Return the last sealed verdict. */
fn h5_verdict() -> u64 @export {
    return H5_VERDICT
}

/* KAT: 99 = all pass; a distinct small code at each failed check (diagnosable).
 * Proves: the Kleene laws hold (1); the non-Kleene relations are false (2); the canary is
 * genuinely false (3); run_charter GREEN with the H5 clause (4,5); the verdict is
 * non-zero (6) and reproducible (7,8); and -- the prove-the-negative arm -- run_charter
 * goes RED, returning the failing canary's 1-based index (=2), proving the gate is a
 * real falsifier, not vacuously green (9,10). */
fn h5_selftest() -> u64 @export {
    h5_init()
    if h5_verify() != 1u8 { return 1u64 }
    if h5_falsify() != 1u8 { return 2u64 }
    if h5_canary_holds() != 0u8 { return 3u64 }
    if h5_register(H5_KIND_KLEENE) != 0i32 { return 4u64 }
    if h5_run_charter() != H5_VERDICT_GREEN { return 5u64 }
    if h5_verdict() == 0u64 { return 6u64 }
    H5_SAVED = H5_VERDICT
    if h5_run_charter() != H5_VERDICT_GREEN { return 7u64 }
    if h5_verdict() != H5_SAVED { return 8u64 }
    if h5_register(H5_KIND_CANARY) != 1i32 { return 9u64 }
    if h5_run_charter() != 2u64 { return 10u64 }
    return 99u64
}

/* h5_charter EMBODIES the H5 invariant as a self-falsifying constitutional clause:
 * the one ternary Kleene algebra (M2) obeys its laws and is genuinely the real Kleene
 * algebra (not a collapse), and the terminal gate proves itself RED on a failing clause.
 * Safety (M3), uncertainty (M4), and sealed-crystal errors (M27) are all readings of
 * THIS one logic; the structural single-algebra unification forbids any second algebra. */
