/* STDLIB/iii/numera/hdl.iii -- III -> Silicon, HW1: the certified combinator/boolean -> GATE
 * lowering (DOCS/III-SILICON-FRONTIER.md).  A combinator/boolean term that denotes a finite
 * function maps 1-to-1 onto hardware gates -- the realizable fragment SKI/CCL shares with silicon.
 * Each boolean connective -> one BinaryGate; each trit op -> one TernaryGate; state -> DFlipFlop.
 *
 * THE CERTIFICATION (the whole point -- "pure algebraic translation, no heuristics"): hdl_equiv*
 * is the EXHAUSTIVE TRUTH TABLE -- two netlists are equivalent IFF they compute the identical
 * function over every input assignment (2^n for binary, 3^n for trit).  A lowering is accepted
 * only when proven equivalent to its source; a mis-lowering is caught.  This is what no HLS
 * toolchain gives: the netlist is correct BY PROOF, not by hope.
 *
 * Unified i32 gate value: binary gates use {0,1}, trit gates use the balanced trit {-1,0,+1}
 * (iii_trit_*; compared by EQUALITY only -- never ordered).  Gates are added in topological order
 * (inputs precede consumers), so hdl_eval is ONE linear pass over a value array -- no recursion,
 * no allocator.  Compiler-UNREFERENCED -> LIBNATIVE.  Hexad: kind_essence (computation given form).
 * Ring: R0.  K: 1.00.  NIH: composes trit only. */
module numera_hdl

extern @abi(c-msvc-x64) fn iii_trit_not(a: i32) -> i32 from "trit.iii"
extern @abi(c-msvc-x64) fn iii_trit_and(a: i32, b: i32) -> i32 from "trit.iii"
extern @abi(c-msvc-x64) fn iii_trit_or(a: i32, b: i32) -> i32 from "trit.iii"

/* gate kinds */
const HG_IN   : u32 = 0u32     /* primary input (A = input index) */
const HG_C0   : u32 = 1u32     /* constant 0  (K) */
const HG_C1   : u32 = 2u32     /* constant 1  (K) */
const HG_BUF  : u32 = 3u32     /* wire / identity (I) */
const HG_NOT  : u32 = 4u32     /* BinaryGate: not */
const HG_AND  : u32 = 5u32
const HG_OR   : u32 = 6u32
const HG_XOR  : u32 = 7u32
const HG_NAND : u32 = 8u32     /* universal */
const HG_TNOT : u32 = 10u32    /* TernaryGate: Kleene negation (input A) */
const HG_TAND : u32 = 11u32    /* TernaryGate: Kleene min */
const HG_TOR  : u32 = 12u32    /* TernaryGate: Kleene max */
const HG_DFF  : u32 = 13u32    /* DFlipFlop: state element (combinationally = its input) */

const HG_MAXG : u32 = 4096u32
const HG_MAXIN: u32 = 64u32

var HG_KIND  : [u32; 4096]
var HG_A     : [u32; 4096]
var HG_B     : [u32; 4096]
var HG_VAL   : [i32; 4096]
var HG_INPUT : [i32; 64]
var HG_N     : [u32; 1]
var HG_DEPTH : [u32; 4096]    /* HW2: critical-path depth scratch */
var HG_STATE : [i32; 4096]    /* SX1: DFlipFlop held state (sequential) */

fn hdl_reset() -> u64 @export { HG_N[0u32] = 0u32 ; return 0u64 }

/* add a primary input reading slot `input_idx`; returns the gate id */
fn hdl_add_in(input_idx: u32) -> u32 @export {
    let g : u32 = HG_N[0u32]
    if g >= HG_MAXG { return 0xFFFFFFFFu32 }
    HG_KIND[g] = HG_IN ; HG_A[g] = input_idx ; HG_B[g] = 0u32
    HG_N[0u32] = g + 1u32
    return g
}
/* add a gate of `kind` with input gate-ids a, b (b ignored for unary kinds); returns the gate id */
fn hdl_add(kind: u32, a: u32, b: u32) -> u32 @export {
    let g : u32 = HG_N[0u32]
    if g >= HG_MAXG { return 0xFFFFFFFFu32 }
    HG_KIND[g] = kind ; HG_A[g] = a ; HG_B[g] = b
    HG_N[0u32] = g + 1u32
    return g
}
fn hdl_set_input(idx: u32, val: i32) -> u64 @export { HG_INPUT[idx] = val ; return 0u64 }
fn hdl_gate_count() -> u32 @export { return HG_N[0u32] }

/* topological one-pass evaluation -> the value of gate `out` under the current HG_INPUT. */
fn hdl_eval(out: u32) -> i32 @export {
    let n : u32 = HG_N[0u32]
    let mut g : u32 = 0u32
    while g < n {
        let k : u32 = HG_KIND[g]
        if k == HG_IN   { HG_VAL[g] = HG_INPUT[HG_A[g]] }
        if k == HG_C0   { HG_VAL[g] = 0i32 }
        if k == HG_C1   { HG_VAL[g] = 1i32 }
        if k == HG_BUF  { HG_VAL[g] = HG_VAL[HG_A[g]] }
        if k == HG_NOT  { HG_VAL[g] = 1i32 - HG_VAL[HG_A[g]] }
        if k == HG_AND  { HG_VAL[g] = HG_VAL[HG_A[g]] & HG_VAL[HG_B[g]] }
        if k == HG_OR   { HG_VAL[g] = HG_VAL[HG_A[g]] | HG_VAL[HG_B[g]] }
        if k == HG_XOR  { HG_VAL[g] = HG_VAL[HG_A[g]] ^ HG_VAL[HG_B[g]] }
        if k == HG_NAND { HG_VAL[g] = 1i32 - (HG_VAL[HG_A[g]] & HG_VAL[HG_B[g]]) }
        if k == HG_DFF  { HG_VAL[g] = HG_STATE[g] }
        if k == HG_TNOT { HG_VAL[g] = iii_trit_not(HG_VAL[HG_A[g]]) }
        if k == HG_TAND { HG_VAL[g] = iii_trit_and(HG_VAL[HG_A[g]], HG_VAL[HG_B[g]]) }
        if k == HG_TOR  { HG_VAL[g] = iii_trit_or(HG_VAL[HG_A[g]], HG_VAL[HG_B[g]]) }
        g = g + 1u32
    }
    return HG_VAL[out]
}

/* BINARY certification: identical truth table over all 2^n input assignments (0/1). */
fn hdl_equiv2(a: u32, b: u32, n: u32) -> u32 @export {
    let total : u32 = 1u32 << n
    let mut v : u32 = 0u32
    while v < total {
        let mut i : u32 = 0u32
        while i < n { let bit : i32 = ((v >> i) & 1u32) as i32 ; hdl_set_input(i, bit) ; i = i + 1u32 }
        if hdl_eval(a) != hdl_eval(b) { return 0u32 }
        v = v + 1u32
    }
    return 1u32
}

/* TERNARY certification (2 inputs): identical over all 3^2 = 9 balanced-trit assignments. */
fn hdl_equiv3_2(a: u32, b: u32) -> u32 @export {
    let mut i0 : u32 = 0u32
    while i0 < 3u32 {
        let mut i1 : u32 = 0u32
        while i1 < 3u32 {
            hdl_set_input(0u32, (i0 as i32) - 1i32)
            hdl_set_input(1u32, (i1 as i32) - 1i32)
            if hdl_eval(a) != hdl_eval(b) { return 0u32 }
            i1 = i1 + 1u32
        }
        i0 = i0 + 1u32
    }
    return 1u32
}

/* ===== HW2: the PHYSICAL cost lattice -- the cost stops being x86/ARM cycles and becomes silicon:
 * gate count, gate-delay (critical-path depth), wire (a topological proxy -- NOT NP-hard placed
 * routing), and the Landauer thermodynamic floor. The e-graph selects the min-physical-cost member
 * of an equivalence class (every member proven === by HW1's hdl_equiv). ===== */

/* physical gate count: the logic gates (primary inputs + constants are free). */
fn pc_gate_count() -> u32 @export {
    let n : u32 = HG_N[0u32]
    let mut c : u32 = 0u32
    let mut g : u32 = 0u32
    while g < n {
        let k : u32 = HG_KIND[g]
        if k != HG_IN { if k != HG_C0 { if k != HG_C1 { c = c + 1u32 } } }
        g = g + 1u32
    }
    return c
}

/* the critical path: the longest gate-chain from inputs to `out` (the gate-delay bounding the
 * clock period). One topological pass: depth = 0 for inputs/consts, else 1 + max(depth of inputs). */
fn pc_logic_depth(out: u32) -> u32 @export {
    let n : u32 = HG_N[0u32]
    let mut g : u32 = 0u32
    while g < n {
        let k : u32 = HG_KIND[g]
        if k == HG_IN { HG_DEPTH[g] = 0u32 }
        if k == HG_C0 { HG_DEPTH[g] = 0u32 }
        if k == HG_C1 { HG_DEPTH[g] = 0u32 }
        if k != HG_IN { if k != HG_C0 { if k != HG_C1 {
            let da : u32 = HG_DEPTH[HG_A[g]]
            let db : u32 = HG_DEPTH[HG_B[g]]
            let mut m : u32 = da
            if db > m { m = db }
            HG_DEPTH[g] = m + 1u32
        } } }
        g = g + 1u32
    }
    return HG_DEPTH[out]
}

/* total wire count = sum of gate in-edges -- a topological proxy for wire load (NOT placed wire
 * capacitance, which is NP-hard place-&-route, the toolchain's job; see III-SILICON-FRONTIER.md). */
fn pc_wire_count() -> u32 @export {
    let n : u32 = HG_N[0u32]
    let mut w : u32 = 0u32
    let mut g : u32 = 0u32
    while g < n {
        let k : u32 = HG_KIND[g]
        if k == HG_NOT  { w = w + 1u32 }
        if k == HG_BUF  { w = w + 1u32 }
        if k == HG_TNOT { w = w + 1u32 }
        if k == HG_DFF  { w = w + 1u32 }
        if k == HG_AND  { w = w + 2u32 }
        if k == HG_OR   { w = w + 2u32 }
        if k == HG_XOR  { w = w + 2u32 }
        if k == HG_NAND { w = w + 2u32 }
        if k == HG_TAND { w = w + 2u32 }
        if k == HG_TOR  { w = w + 2u32 }
        g = g + 1u32
    }
    return w
}

/* the thermodynamic floor: each irreversible 2-input gate erases ~1 bit; E >= bits * kT*ln2.
 * kT*ln2 at 300 K = 2.871e-21 J = 2871 yoctojoules. Returned in yJ -- the universe's irreducible
 * LOWER BOUND for the algorithm, NOT the (higher, process-dependent) silicon draw. */
const PC_LANDAUER_YJ : u64 = 2871u64
fn pc_landauer_yj() -> u64 @export {
    let n : u32 = HG_N[0u32]
    let mut bits : u64 = 0u64
    let mut g : u32 = 0u32
    while g < n {
        let k : u32 = HG_KIND[g]
        if k == HG_AND  { bits = bits + 1u64 }
        if k == HG_OR   { bits = bits + 1u64 }
        if k == HG_XOR  { bits = bits + 1u64 }
        if k == HG_NAND { bits = bits + 1u64 }
        if k == HG_TAND { bits = bits + 1u64 }
        if k == HG_TOR  { bits = bits + 1u64 }
        g = g + 1u32
    }
    return bits * PC_LANDAUER_YJ
}

/* the cost-lattice order: fewer gates, then shallower depth. 1 iff (ga,da) strictly precedes (gb,db). */
fn pc_better(ga: u32, da: u32, gb: u32, db: u32) -> u32 @export {
    if ga < gb { return 1u32 }
    if ga > gb { return 0u32 }
    if da < db { return 1u32 }
    return 0u32
}

/* ===== SX1: SEQUENTIAL circuits -- the DFlipFlop made real (clocked state) ===== */

/* zero all DFF held states (power-on reset). */
fn hdl_seq_init() -> u64 @export {
    let n : u32 = HG_N[0u32]
    let mut g : u32 = 0u32
    while g < n { HG_STATE[g] = 0i32 ; g = g + 1u32 }
    return 0u64
}
/* set gate g's input-A to gate a -- used to close a feedback loop after both gates exist. */
fn hdl_set_a(g: u32, a: u32) -> u64 @export { HG_A[g] = a ; return 0u64 }
/* read a DFF's current held state. */
fn hdl_dff_state(g: u32) -> i32 @export { return HG_STATE[g] }
/* one clock cycle: combinational eval (each DFF outputs its HELD state), then latch (each DFF's
 * next state = its input's value). A synchronous-circuit step -- a bounded evaluation, NOT the
 * halting problem (no unbounded fixpoint search). */
fn hdl_step() -> u64 @export {
    hdl_eval(0u32)                              /* combinational pass: computes all HG_VAL */
    let n : u32 = HG_N[0u32]
    let mut g : u32 = 0u32
    while g < n {
        if HG_KIND[g] == HG_DFF { HG_STATE[g] = HG_VAL[HG_A[g]] }   /* latch the input -> next state */
        g = g + 1u32
    }
    return 0u64
}

/* ===== SX2: REALISTIC physical cost -- gate delay + wire capacitance (the literal mechanic) ===== */

/* per-gate-TYPE propagation delay (relative units): a simple 2-input boolean gate = 1; XOR = 2 (a
 * 2-level structure); trit AND/OR = 2 (3-valued min/max is deeper); NOT/BUF = 1; register/source
 * gates (DFF/IN/const) = 0 (a path endpoint -- no combinational delay through it). */
fn pc_gate_delay(kind: u32) -> u32 @export {
    if kind == HG_NOT  { return 1u32 }
    if kind == HG_BUF  { return 1u32 }
    if kind == HG_AND  { return 1u32 }
    if kind == HG_OR   { return 1u32 }
    if kind == HG_NAND { return 1u32 }
    if kind == HG_XOR  { return 2u32 }
    if kind == HG_TNOT { return 1u32 }
    if kind == HG_TAND { return 2u32 }
    if kind == HG_TOR  { return 2u32 }
    return 0u32
}
/* the WEIGHTED critical path to `out`: the gate-delay-weighted longest path (the timing bounding the
 * clock period -- finer than pc_logic_depth's uniform 1/gate). DFFs/inputs start fresh (delay 0). */
fn pc_crit_delay(out: u32) -> u32 @export {
    let n : u32 = HG_N[0u32]
    let mut g : u32 = 0u32
    while g < n {
        let k : u32 = HG_KIND[g]
        if k == HG_IN  { HG_DEPTH[g] = 0u32 }
        if k == HG_C0  { HG_DEPTH[g] = 0u32 }
        if k == HG_C1  { HG_DEPTH[g] = 0u32 }
        if k == HG_DFF { HG_DEPTH[g] = 0u32 }
        if k != HG_IN { if k != HG_C0 { if k != HG_C1 { if k != HG_DFF {
            let da : u32 = HG_DEPTH[HG_A[g]]
            let db : u32 = HG_DEPTH[HG_B[g]]
            let mut m : u32 = da
            if db > m { m = db }
            HG_DEPTH[g] = m + pc_gate_delay(k)
        } } } }
        g = g + 1u32
    }
    return HG_DEPTH[out]
}
/* binary-arity test (real B input). */
fn pc_is_binary(kind: u32) -> u32 {
    if kind == HG_AND  { return 1u32 }
    if kind == HG_OR   { return 1u32 }
    if kind == HG_XOR  { return 1u32 }
    if kind == HG_NAND { return 1u32 }
    if kind == HG_TAND { return 1u32 }
    if kind == HG_TOR  { return 1u32 }
    return 0u32
}
/* fan-out capacitance: per net, the number of gate-input pins it drives, SQUARED (capacitive load
 * grows super-linearly with fan-out -- a heavily-loaded net is disproportionately costly). A
 * topological load proxy, NOT placed wire capacitance (that is NP-hard P&R, the toolchain's). */
fn pc_fanout_cap() -> u32 @export {
    let n : u32 = HG_N[0u32]
    let mut cap : u32 = 0u32
    let mut g : u32 = 0u32
    while g < n {
        let mut fo : u32 = 0u32
        let mut h : u32 = 0u32
        while h < n {
            let kh : u32 = HG_KIND[h]
            if kh != HG_IN {                       /* IN's A is an input index, not a gate ref */
                if HG_A[h] == g { fo = fo + 1u32 }
                if pc_is_binary(kh) == 1u32 { if HG_B[h] == g { fo = fo + 1u32 } }
            }
            h = h + 1u32
        }
        cap = cap + fo * fo
        g = g + 1u32
    }
    return cap
}
