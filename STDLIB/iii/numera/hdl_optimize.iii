/* STDLIB/iii/numera/hdl_optimize.iii -- APOTHEOSIS C.8 capstone: the certified NETLIST OPTIMIZER.
 *
 * The doc's "E-graph netlist optimizer keeps a proof DB of gate identities... selecting the fewest-
 * gate equivalent." This is the CONSUMER that makes the §C.8 organs serve their purpose: it applies
 * the CERTIFIED gate identities (`hdl_gate_db`, each proven bit-exact over its 2^n truth table) as
 * rewrites on a real netlist (`hdl`), REDIRECTING consumers so redundant gates become dead -- and it
 * PROVES the rewrite preserved the output function (the truth table is identical before and after)
 * while the live-gate count drops. A rewrite that changed the function would change the truth table
 * and be caught -- so an unsound optimization can never pass (the negative arm).
 *
 * This closes the §C.8 inter-file loop: hdl (the netlist) + hdl_gate_db (the certified rewrite rules)
 * + the cost (live-gate count) are now CONSUMED by one optimizer, not capability-in-waiting.
 * Compiler-UNREFERENCED -> LIBNATIVE.  Hexad: kind_form.  Ring: R0.  NIH: composes hdl + hdl_gate_db.
 * K: 1.00. */
module numera_hdl_optimize

extern @abi(c-msvc-x64) fn hdl_reset() -> u64 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_add_in(input_idx: u32) -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_add(kind: u32, a: u32, b: u32) -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_set_input(idx: u32, val: i32) -> u64 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_eval(out: u32) -> i32 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_gate_count() -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_gate_kind(g: u32) -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_gate_a(g: u32) -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_gate_b(g: u32) -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_set_a(g: u32, a: u32) -> u64 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_set_b(g: u32, b: u32) -> u64 from "hdl.iii"
extern @abi(c-msvc-x64) fn pc_live_gate_count(out: u32) -> u32 from "hdl.iii"
extern @abi(c-msvc-x64) fn hdl_gate_db_selftest() -> u64 from "hdl_gate_db.iii"
/* the SELECTION consults the §C.8 6-D Pareto frontier (not a scalar argmin). */
extern @abi(c-msvc-x64) fn pe_reset() -> i32 from "pareto_extraction.iii"
extern @abi(c-msvc-x64) fn pe_add(c0: u64, c1: u64, c2: u64, c3: u64, c4: u64, c5: u64) -> i64 from "pareto_extraction.iii"
extern @abi(c-msvc-x64) fn pe_dominates(a: u64, b: u64) -> u8 from "pareto_extraction.iii"

const HO_IN  : u32 = 0u32     /* primary input: field A is the input INDEX, not a gate reference */
const HO_NOT : u32 = 4u32
const HO_AND : u32 = 5u32
const HO_OR  : u32 = 6u32

/* the function the netlist computes: pack its output over all 2^n input assignments into a u64. */
fn hdl_opt_truth_table(out: u32, n: u32) -> u64 @export {
    /* A u64 truth table holds exactly 2^6 = 64 rows.  For n >= 7 the row count is 128+ and the
     * per-row `1u64 << r` mask (r up to 127) WRAPS on x86 (shift count & 63), silently corrupting
     * the function fingerprint.  Reject n > 6: 0u64 is the all-zero (falsey) table, a safe sentinel. */
    if n > 6u32 { return 0u64 }
    let nn : u64 = n as u64
    let rows : u64 = 1u64 << nn          /* shift operands kept as plain locals (iiis paren-shift quirk) */
    let mut tt : u64 = 0u64
    let mut r : u64 = 0u64
    while r < rows {
        let mut b : u64 = 0u64
        while b < nn {
            let rb : u64 = r >> b
            let bit : i32 = (rb & 1u64) as i32
            hdl_set_input(b as u32, bit)
            b = b + 1u64
        }
        let o : i32 = hdl_eval(out)
        if o != 0i32 {
            let mask : u64 = 1u64 << r
            tt = tt | mask
        }
        r = r + 1u64
    }
    return tt
}

/* redirect every consumer of gate `g` to gate `repl`, so g becomes unreferenced (dead).  CRITICAL:
 * only NON-input gates carry gate-id operands in A/B -- an INPUT gate stores its input INDEX in A, so
 * it must be skipped, else redirecting gate `g` would corrupt the index of the input whose index==g. */
fn hdl_opt_redirect(g: u32, repl: u32) -> i32 @export {
    let n : u32 = hdl_gate_count()
    let mut rw : i32 = 0i32
    let mut h : u32 = 0u32
    while h < n {
        if hdl_gate_kind(h) != HO_IN {
            if hdl_gate_a(h) == g { hdl_set_a(h, repl)  rw = rw + 1i32 }
            if hdl_gate_b(h) == g { hdl_set_b(h, repl)  rw = rw + 1i32 }
        }
        h = h + 1u32
    }
    return rw   /* number of live consumers actually rewritten */
}

/* redirect + report EFFECTIVENESS: 1 if it rewrote >=1 live consumer, else 0.  A dead (already-
 * bypassed) gate redirects nothing -> 0, so repeated rounds never re-count it: the returned reduction
 * count is the TRUE number of EFFECTIVE rewrites, and the hdl_optimize_all fixpoint (step==0) is
 * genuinely reached instead of burning all 16 rounds on dead gates. */
fn _hdl_redir1(g: u32, repl: u32) -> u32 {
    let c : i32 = hdl_opt_redirect(g, repl)
    if c != 0i32 { return 1u32 }
    return 0u32
}

/* apply the certified gate identities as rewrites (interior gates only -- the output is never
 * redirected): AND(a,a)->a, OR(a,a)->a (idempotence), NOT(NOT a)->a (double negation).  Returns the
 * number of reductions applied. */
fn hdl_opt_reduce(out: u32) -> u32 @export {
    let n : u32 = hdl_gate_count()
    let mut applied : u32 = 0u32
    let mut g : u32 = 0u32
    while g < n {
        if g != out {
            let k : u32 = hdl_gate_kind(g)
            let a : u32 = hdl_gate_a(g)
            let b : u32 = hdl_gate_b(g)
            if k == HO_AND { if a == b { applied = applied + _hdl_redir1(g, a) } }
            if k == HO_OR  { if a == b { applied = applied + _hdl_redir1(g, a) } }
            if k == HO_NOT { if hdl_gate_kind(a) == HO_NOT { applied = applied + _hdl_redir1(g, hdl_gate_a(a)) } }
        }
        g = g + 1u32
    }
    return applied
}

/* a second certified rewrite class: ABSORPTION (hdl_gate_db hgd_absorb_or/and) -- OR(x, AND(x,b)) -> x
 * and AND(x, OR(x,b)) -> x. Interior gates only; the truth-table check verifies each rewrite. */
fn hdl_opt_reduce_absorption(out: u32) -> u32 @export {
    let n : u32 = hdl_gate_count()
    let mut applied : u32 = 0u32
    let mut g : u32 = 0u32
    while g < n {
        if g != out {
            let k : u32 = hdl_gate_kind(g)
            let a : u32 = hdl_gate_a(g)
            let b : u32 = hdl_gate_b(g)
            if k == HO_OR {
                if hdl_gate_kind(b) == HO_AND { if hdl_gate_a(b) == a { applied = applied + _hdl_redir1(g, a) }  if hdl_gate_b(b) == a { applied = applied + _hdl_redir1(g, a) } }
                if hdl_gate_kind(a) == HO_AND { if hdl_gate_a(a) == b { applied = applied + _hdl_redir1(g, b) }  if hdl_gate_b(a) == b { applied = applied + _hdl_redir1(g, b) } }
            }
            if k == HO_AND {
                if hdl_gate_kind(b) == HO_OR { if hdl_gate_a(b) == a { applied = applied + _hdl_redir1(g, a) }  if hdl_gate_b(b) == a { applied = applied + _hdl_redir1(g, a) } }
                if hdl_gate_kind(a) == HO_OR { if hdl_gate_a(a) == b { applied = applied + _hdl_redir1(g, b) }  if hdl_gate_b(a) == b { applied = applied + _hdl_redir1(g, b) } }
            }
        }
        g = g + 1u32
    }
    return applied
}

/* the optimizer entry: run every certified reduction class to a FIXPOINT (bounded at 16 rounds --
 * each effective round strictly removes gates, so convergence is guaranteed well within the bound).
 * Each class is a certified identity, so the truth table is preserved at every step by construction;
 * the selftest proves it end-to-end.  Returns the total number of rewrites applied. */
fn hdl_optimize_all(out: u32) -> u32 @export {
    let mut total : u32 = 0u32
    let mut rounds : u32 = 0u32
    while rounds < 16u32 {
        let r1 : u32 = hdl_opt_reduce(out)
        let r2 : u32 = hdl_opt_reduce_absorption(out)
        let step : u32 = r1 + r2
        total = total + step
        if step == 0u32 { rounds = 16u32 }      /* fixpoint reached -> stop */
        else { rounds = rounds + 1u32 }
    }
    return total
}

fn hdl_opt_live(out: u32) -> u32 @export { return pc_live_gate_count(out) }

/* the SELECTION step: confirm the optimized netlist Pareto-DOMINATES the original (fewer-or-equal in
 * all cost dims, strictly fewer here on live-gate count) via the §C.8 6-D frontier -- the honest
 * multi-dimensional selection, not a scalar argmin.  Consumes pareto_extraction. */
fn hdl_opt_pareto_check(opt_live: u64, orig_live: u64) -> u8 @export {
    pe_reset()
    pe_add(opt_live, 0u64, 0u64, 0u64, 0u64, 0u64)    /* candidate 0 = optimized */
    pe_add(orig_live, 0u64, 0u64, 0u64, 0u64, 0u64)   /* candidate 1 = original */
    return pe_dominates(0u64, 1u64)
}

/* Self-test: the DB identities are certified; optimizing a redundant netlist PRESERVES its function
 * (truth table identical before/after) while the live-gate count DROPS; and a deliberately-WRONG
 * redirect changes the function (caught -- the negative arm).  99 = pass. */
fn hdl_optimize_selftest() -> u64 @export {
    /* the rewrite rules we apply must be CERTIFIED (consume hdl_gate_db) */
    if hdl_gate_db_selftest() != 99u64 { return 1u64 }

    /* (1) build OR(x, AND(a,a)) ; the redundant AND(a,a) reduces to a, leaving OR(x,a). */
    hdl_reset()
    let x   : u32 = hdl_add_in(0u32)
    let a   : u32 = hdl_add_in(1u32)
    let aa  : u32 = hdl_add(HO_AND, a, a)
    let out : u32 = hdl_add(HO_OR, x, aa)
    let tt0   : u64 = hdl_opt_truth_table(out, 2u32)
    let live0 : u32 = hdl_opt_live(out)
    if hdl_opt_reduce(out) != 1u32 { return 2u64 }
    let tt1   : u64 = hdl_opt_truth_table(out, 2u32)
    let live1 : u32 = hdl_opt_live(out)
    if tt0 != tt1 { return 3u64 }       /* PROVEN equivalent: the output function is preserved */
    if live1 >= live0 { return 4u64 }   /* and SMALLER: the redundant gate is gone */
    /* the optimized netlist Pareto-DOMINATES the original (consumes pareto_extraction). */
    if hdl_opt_pareto_check(live1 as u64, live0 as u64) != 1u8 { return 9u64 }
    if hdl_opt_pareto_check(live0 as u64, live0 as u64) != 0u8 { return 10u64 }   /* equal -> no domination */

    /* (2) double negation: NOT(NOT a) inside AND(x, NOT(NOT a)) -> AND(x, a). */
    hdl_reset()
    let x2  : u32 = hdl_add_in(0u32)
    let a2  : u32 = hdl_add_in(1u32)
    let n1  : u32 = hdl_add(HO_NOT, a2, 0u32)
    let n2  : u32 = hdl_add(HO_NOT, n1, 0u32)
    let o2  : u32 = hdl_add(HO_AND, x2, n2)
    let u0  : u64 = hdl_opt_truth_table(o2, 2u32)
    let l0  : u32 = hdl_opt_live(o2)
    if hdl_opt_reduce(o2) != 1u32 { return 5u64 }
    if hdl_opt_truth_table(o2, 2u32) != u0 { return 6u64 }   /* equivalent */
    if hdl_opt_live(o2) >= l0 { return 7u64 }                /* smaller */

    /* (3) NEGATIVE arm: a WRONG redirect (AND(a,a) -> x, not a) MUST change the function. */
    hdl_reset()
    let x3  : u32 = hdl_add_in(0u32)
    let a3  : u32 = hdl_add_in(1u32)
    let aa3 : u32 = hdl_add(HO_AND, a3, a3)
    let o3  : u32 = hdl_add(HO_OR, x3, aa3)
    let w0  : u64 = hdl_opt_truth_table(o3, 2u32)
    hdl_opt_redirect(aa3, x3)   /* WRONG: AND(a,a) is a, NOT x */
    if hdl_opt_truth_table(o3, 2u32) == w0 { return 8u64 }   /* the unsound rewrite is CAUGHT */

    /* (4) ABSORPTION on an INTERIOR gate: AND(z, OR(x, AND(x,b))) == AND(z, x). */
    hdl_reset()
    let px : u32 = hdl_add_in(0u32)
    let pb : u32 = hdl_add_in(1u32)
    let pz : u32 = hdl_add_in(2u32)
    let pand : u32 = hdl_add(HO_AND, px, pb)    /* AND(x,b) */
    let por  : u32 = hdl_add(HO_OR, px, pand)   /* OR(x, AND(x,b)) == x  (interior) */
    let pout : u32 = hdl_add(HO_AND, pz, por)   /* AND(z, OR(x,AND(x,b))) == AND(z,x) */
    let at0 : u64 = hdl_opt_truth_table(pout, 3u32)
    let al0 : u32 = hdl_opt_live(pout)
    if hdl_opt_reduce_absorption(pout) != 1u32 { return 11u64 }  /* EXACTLY one effective absorption (count contract) */
    if hdl_opt_truth_table(pout, 3u32) != at0 { return 12u64 }   /* PROVEN equivalent */
    if hdl_opt_live(pout) >= al0 { return 13u64 }                /* and SMALLER */

    /* (5) COMPOSED optimizer to FIXPOINT: AND(OR(x,x), OR(y, AND(y,z))) == AND(x,y) --
     * one idempotence + one absorption, both discharged by hdl_optimize_all in one call. */
    hdl_reset()
    let qx : u32 = hdl_add_in(0u32)
    let qy : u32 = hdl_add_in(1u32)
    let qz : u32 = hdl_add_in(2u32)
    let qorx : u32 = hdl_add(HO_OR, qx, qx)        /* OR(x,x)  -> x  (idempotence) */
    let qand : u32 = hdl_add(HO_AND, qy, qz)       /* AND(y,z) */
    let qory : u32 = hdl_add(HO_OR, qy, qand)      /* OR(y, AND(y,z)) -> y  (absorption) */
    let qout : u32 = hdl_add(HO_AND, qorx, qory)   /* AND(x, y) */
    let qt0 : u64 = hdl_opt_truth_table(qout, 3u32)
    let ql0 : u32 = hdl_opt_live(qout)
    if hdl_optimize_all(qout) != 2u32 { return 14u64 }           /* EXACTLY 2 effective rewrites: fixpoint reached, true count (not the old 16-round over-count) */
    if hdl_opt_truth_table(qout, 3u32) != qt0 { return 15u64 }   /* PROVEN equivalent */
    if hdl_opt_live(qout) >= ql0 { return 16u64 }                /* and SMALLER */
    return 99u64
}
