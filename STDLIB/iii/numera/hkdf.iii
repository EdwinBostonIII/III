/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\hkdf.iii
 *
 * III STDLIB - numera::hkdf
 *
 * RFC 5869 HKDF using HMAC-SHA256.
 *
 * Public API (singleton state, two-step):
 *   hkdf_sha256_extract(salt:*u8, salt_len:u64, ikm:*u8, ikm_len:u64) -> i32
 *      -- Derives PRK = HMAC-SHA256(salt, IKM).  Stored internally.
 *      -- If salt_len == 0, an all-zero 32-byte salt is used.
 *   hkdf_sha256_expand(info:*u8, info_len:u64, out:*u8, out_len:u64) -> i32
 *      -- Generates out_len bytes of OKM into out.  out_len <= 255 * 32 = 8160.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00.
 */

module numera_hkdf

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_alloc1(arena: u64, n: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn hmac_sha256(key: *u8, key_len: u64, msg: *u8, msg_len: u64) -> i32 from "hmac.iii"
extern @abi(c-msvc-x64) fn hmac_sha256_tag(out_32: *u8) -> i32 from "hmac.iii"

const HKDF_OK : i32 = 0i32
const HKDF_E_INIT : i32 = -1i32
const HKDF_E_TOOLONG : i32 = -2i32

const HKDF_HASH_LEN : u32 = 32u32
const HKDF_MAX_OUT  : u64 = 8160u64    /* 255 * 32 */

var HKDF_ARENA   : u64 = 0u64
var HKDF_PRK_BUF : u64 = 0u64    /* 32-byte PRK */
var HKDF_T_BUF   : u64 = 0u64    /* 32-byte block T(i) */
var HKDF_MSG_BUF : u64 = 0u64    /* T(i-1) || info || counter */
var HKDF_ZERO_SALT : u64 = 0u64  /* 32-byte zero salt (constant) */

fn hkdf_alloc() -> i32 {
    if HKDF_ARENA != 0u64 { return HKDF_OK }
    HKDF_ARENA = arena_new(8192u64)
    if HKDF_ARENA == 0u64 { return HKDF_E_INIT }
    HKDF_PRK_BUF   = arena_alloc1(HKDF_ARENA, 32u64)
    HKDF_T_BUF     = arena_alloc1(HKDF_ARENA, 32u64)
    HKDF_MSG_BUF   = arena_alloc1(HKDF_ARENA, 4096u64)
    HKDF_ZERO_SALT = arena_alloc1(HKDF_ARENA, 32u64)
    let zp : *u8 = HKDF_ZERO_SALT as *u8
    let mut i : u32 = 0u32
    while i < 32u32 {
        zp[i] = 0u8
        i = i + 1u32
    }
    return HKDF_OK
}

fn hkdf_sha256_extract(salt: *u8, salt_len: u64, ikm: *u8, ikm_len: u64) -> i32 @export {
    if hkdf_alloc() != HKDF_OK { return HKDF_E_INIT }
    /* PRK = HMAC-SHA256(salt, IKM) */
    let mut k : *u8 = salt
    let mut k_len : u64 = salt_len
    if k_len == 0u64 {
        k = HKDF_ZERO_SALT as *u8
        k_len = 32u64
    }
    hmac_sha256(k, k_len, ikm, ikm_len)
    hmac_sha256_tag(HKDF_PRK_BUF as *u8)
    return HKDF_OK
}

fn hkdf_sha256_expand(info: *u8, info_len: u64, out: *u8, out_len: u64) -> i32 @export {
    if HKDF_PRK_BUF == 0u64 { return HKDF_E_INIT }
    if out_len > HKDF_MAX_OUT { return HKDF_E_TOOLONG }
    /* N = ceil(out_len / 32).  T(0) = empty.
     * For i = 1..N: T(i) = HMAC-SHA256(PRK, T(i-1) || info || [i]) */
    let mut written : u64 = 0u64
    let mut counter : u32 = 1u32
    let mp : *u8 = HKDF_MSG_BUF as *u8
    let tp : *u8 = HKDF_T_BUF as *u8
    let mut prev_len : u64 = 0u64    /* length of T(i-1); 0 for i=1 */
    while written < out_len {
        /* Build msg: T(i-1) || info || [counter] */
        let mut mi : u64 = 0u64
        let mut k : u64 = 0u64
        while k < prev_len {
            mp[mi] = tp[k]
            mi = mi + 1u64
            k = k + 1u64
        }
        let mut j : u64 = 0u64
        while j < info_len {
            mp[mi] = info[j]
            mi = mi + 1u64
            j = j + 1u64
        }
        mp[mi] = (counter & 0xFFu32) as u8
        mi = mi + 1u64
        /* T(i) = HMAC-SHA256(PRK, msg) */
        hmac_sha256(HKDF_PRK_BUF as *u8, 32u64, HKDF_MSG_BUF as *u8, mi)
        hmac_sha256_tag(HKDF_T_BUF as *u8)
        prev_len = 32u64
        /* Copy chunk from T(i) to out */
        let mut chunk : u64 = 32u64
        if written + chunk > out_len { chunk = out_len - written }
        let mut c : u64 = 0u64
        while c < chunk {
            out[written + c] = tp[c]
            c = c + 1u64
        }
        written = written + chunk
        counter = counter + 1u32
    }
    return HKDF_OK
}
