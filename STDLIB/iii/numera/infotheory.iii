/* STDLIB/iii/numera/infotheory.iii -- EXACT INFORMATION THEORY
 * (III-PHASE4-PROBABILITY, Layer 6).
 *
 * Information-theoretic quantities over EXACT-rational distributions, with no float.  The Shannon entropy
 * carries a logarithm, so it is reported as a rational interval (proven log truncations); but the
 * COLLISION quantity -- collision probability  C(p) = sum_i p_i^2  (the base of Renyi-2 / collision
 * entropy) -- is itself an EXACT rational and needs no log: C = (sum_i mass_i^2) / D^2.  It is minimized
 * (= 1/n) by the UNIFORM distribution and maximized (= 1) by a DETERMINISTIC one, exactly.  Two further
 * exact facts: KL(p||q) = 0 iff p == q (Gibbs' equality case), and H(p) = 0 iff p is deterministic.
 *
 * THE HONEST FLOOR: the numeric Shannon entropy / KL value needs log bounded by proven rational intervals;
 * the EXACT structural facts and the exact collision quantity are provided here, the logarithmic value a
 * bound refinement.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00.  Pairs with numera/distribution + evidence_calculus (exact
 * rationals).  Determinism: integer-only; no float, no log on any decide path.
 */
module numera_infotheory

var IT_MASS : [u64; 4]
var IT_DEN  : u64 = 1u64

fn it_set(m0: u64, m1: u64, m2: u64, m3: u64) -> i32 @export {
    IT_MASS[0u64] = m0  IT_MASS[1u64] = m1  IT_MASS[2u64] = m2  IT_MASS[3u64] = m3
    IT_DEN = m0 + m1 + m2 + m3
    return 0i32
}

/* collision probability NUMERATOR = sum_i mass_i^2  (the exact rational C = this / D^2). */
fn it_collision_num() -> u64 @export {
    let s01 : u64 = IT_MASS[0u64] * IT_MASS[0u64] + IT_MASS[1u64] * IT_MASS[1u64]
    let s23 : u64 = IT_MASS[2u64] * IT_MASS[2u64] + IT_MASS[3u64] * IT_MASS[3u64]
    return s01 + s23
}
fn it_collision_den() -> u64 @export { return IT_DEN * IT_DEN }

/* H(p) = 0 iff p is DETERMINISTIC (some mass equals the whole denominator). */
fn it_entropy_zero() -> u8 @export {
    let mut i : u64 = 0u64
    while i < 4u64 {
        if IT_MASS[i] == IT_DEN { return 1u8 }
        i = i + 1u64
    }
    return 0u8
}

/* KL(p||q) = 0 iff p == q (Gibbs' equality case).  q is given over the SAME denominator IT_DEN, so
 * equality is componentwise mass equality. */
fn it_kl_zero(q0: u64, q1: u64, q2: u64, q3: u64) -> u8 @export {
    if IT_MASS[0u64] != q0 { return 0u8 }
    if IT_MASS[1u64] != q1 { return 0u8 }
    if IT_MASS[2u64] != q2 { return 0u8 }
    if IT_MASS[3u64] != q3 { return 0u8 }
    return 1u8
}
