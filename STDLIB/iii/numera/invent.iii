/* STDLIB/iii/numera/invent.iii -- THE GENERATIVE INVENTION LOOP (de-novo law synthesis).
 *
 * The first organ that lets III speak its OWN words: it invents algebraic laws that are in no human
 * template, proves them, and keeps only those that are computationally valuable.  Here, on the strength-
 * reduction domain: given a target mul(x, k), search the OPERATION ALGEBRA itself (shifts, adds, subs of x)
 * for a provably-equal but CHEAPER form -- e.g. 7*x = (x<<3) - x, a reduction NO power-of-two grid contains.
 *
 * The two-tier engine separates VALUE from TRUTH:
 *   (1) GENERATE: enumerate candidate forms over {shl, add, sub, x}, cheapest shapes first.
 *   (2) SIEVE (the transmission, PRE-judge): drop any candidate whose op-cost is not strictly below the best
 *       form found so far -- it cannot improve the optimizer, so it never earns a proof cycle.  This is the
 *       answer to Combinatorial Triviality: the judge is never flooded with true-but-worthless forms.
 *   (3) JUDGE (the kernel): bb_equal -- a Tseitin+CDCL UNSAT miter at the machine width proves the survivor
 *       equal for ALL inputs, or refutes it.  The CIC convertibility check is too weak for linear BV
 *       identities (it cannot fold mul-vs-shift-sub); the SAT miter is the sound, general decision procedure.
 *   (4) ADOPT: the cheapest proven form becomes a new rewrite law the optimizer did not have.
 *
 * Honest boundary: the operation algebra {shl,add,sub} is III's, but the SHAPES are invented by search, not
 * handed in -- this is de-novo relative to every template.  Pointing the same loop at a richer algebra
 * lifts it to new primitives + abstractions.  Hexad: kind_cognition.  Ring: R0.  K: 1.00.  Composes
 * numera/bv_bits (the SAT decision procedure) -- no ML, no guessing.
 */
module numera_invent

extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shl(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shr(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_add(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_sub(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_mul(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_and(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_or(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_xor(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_not(a: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn eqv_eq(a: u32, b: u32) -> u8 from "memo.iii"
/* the adoption soundness gates consult the EIDOS memoisation substrate: a repeated equivalence proof is
 * RECALLED by content-address, skipping the SAT solve.  eqv_equal returns bb_equal's verdict EXACTLY (sound);
 * it only removes the re-solving.  This is the EIDOS-consulted-substrate pattern (a decision faculty consults
 * the coincidence engine), acyclic: memo's deps (bv_bits/coincidence/cad) never reach invent. */
extern @abi(c-msvc-x64) fn eqv_equal(a: u32, b: u32, nvars: u32) -> u8 from "memo.iii"
extern @abi(c-msvc-x64) fn bb_count_and() -> u64 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn l6_and(a: u32, b: u32) -> u32 from "logic6.iii"
extern @abi(c-msvc-x64) fn l6_or(a: u32, b: u32) -> u32 from "logic6.iii"
extern @abi(c-msvc-x64) fn l6_not(v: u32) -> u32 from "logic6.iii"
/* THE COST-TRUTH BRIDGE: cost an invented form by III's EXISTING analytic microarch cycle model
 * (numera/microarch_model -- the same oracle numera/cost_calculus uses), not a crude op-count. */
extern @abi(c-msvc-x64) fn ma_init() -> i32 from "microarch_model.iii"
extern @abi(c-msvc-x64) fn ma_set_latency(opcode: u32, cycles: u32) -> i32 from "microarch_model.iii"
extern @abi(c-msvc-x64) fn ma_simulate(ops: *u32, n: u32, deps: *u32, dep_n: u32, out_cycles: *u64) -> i32 from "microarch_model.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn fs_open(cap: u64, path: u64, mode: u32) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_read(h: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_write(h: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_close(h: u64) -> i32 from "fs.iii"

const GIL_W        : u64 = 64u64       /* prove at the deployment machine width */
const GIL_MUL_COST : u32 = 4u32        /* the value gradient: a multiply is the expensive baseline */
const GIL_MAXA     : u64 = 12u64       /* shift-amount search bound */

var GIL_KERNEL_CALLS : u64 = 0u64      /* candidates that reached the SAT judge */
var GIL_SIEVE_DROPS  : u64 = 0u64      /* candidates the value-sieve dropped PRE-judge */
var GIL_BEST_COST    : u32 = 0u32      /* the cheapest proven-equal form's op-cost */
var GIL_BEST_KIND    : u32 = 0u32      /* the winning shape (1..5) */
var GIL_BEST_A       : u64 = 0u64
var GIL_BEST_B       : u64 = 0u64

/* the op-cost of a candidate shape (the value gradient). */
fn gil_cost(kind: u32) -> u32 {
    if kind == 1u32 { return 1u32 }    /* shl(x,a)                */
    if kind == 2u32 { return 2u32 }    /* (x<<a) - x              */
    if kind == 3u32 { return 2u32 }    /* (x<<a) + x              */
    if kind == 4u32 { return 3u32 }    /* (x<<a) + (x<<b)         */
    if kind == 5u32 { return 3u32 }    /* (x<<a) - (x<<b)         */
    return 0xFFFFFFFFu32
}

/* build candidate shape `kind` over the bit-blaster variable x. */
fn gil_build(kind: u32, x: u32, a: u64, b: u64) -> u32 {
    if kind == 1u32 { return bb_shl(x, a) }
    if kind == 2u32 { return bb_sub(bb_shl(x, a), x) }
    if kind == 3u32 { return bb_add(bb_shl(x, a), x) }
    if kind == 4u32 { return bb_add(bb_shl(x, a), bb_shl(x, b)) }
    if kind == 5u32 { return bb_sub(bb_shl(x, a), bb_shl(x, b)) }
    return 0xFFFFFFFFu32
}

/* SIEVE then (if it can improve) JUDGE one candidate against mul(x,k).  Adopts it as the new best iff the
 * SAT miter PROVES equality and it is strictly cheaper.  Returns 1 iff adopted. */
fn gil_consider(k: u64, kind: u32, a: u64, b: u64) -> i32 {
    let c : u32 = gil_cost(kind)
    if c >= GIL_BEST_COST {                       /* the value sieve: cannot beat the incumbent -> no proof cycle */
        GIL_SIEVE_DROPS = GIL_SIEVE_DROPS + 1u64
        return 0i32
    }
    bb_reset(GIL_W)
    let x : u32 = bb_var(0u32)
    let target : u32 = bb_mul(x, bb_const(k))
    let cand : u32 = gil_build(kind, x, a, b)
    GIL_KERNEL_CALLS = GIL_KERNEL_CALLS + 1u64
    if eqv_eq(target, cand) == 1u8 {
        GIL_BEST_COST = c
        GIL_BEST_KIND = kind
        GIL_BEST_A = a
        GIL_BEST_B = b
        return 1i32
    }
    return 0i32
}

/* FORGE: invent the cheapest provably-equal strength-reduction for mul(x,k), searching cheapest shapes
 * first so the sieve tightens as it goes.  Returns the invented form's op-cost (GIL_MUL_COST if none beats
 * the multiply -- e.g. a prime with no compact shift form in range). */
fn gil_forge(k: u64) -> u32 @export {
    GIL_KERNEL_CALLS = 0u64
    GIL_SIEVE_DROPS = 0u64
    GIL_BEST_KIND = 0u32
    GIL_BEST_A = 0u64
    GIL_BEST_B = 0u64
    GIL_BEST_COST = GIL_MUL_COST       /* incumbent: the multiply itself */

    /* cost 1: shl(x,a) -- the power-of-two case */
    let mut a : u64 = 0u64
    while a <= GIL_MAXA { gil_consider(k, 1u32, a, 0u64)  a = a + 1u64 }
    /* cost 2: (x<<a) - x  [k = 2^a - 1] */
    a = 1u64
    while a <= GIL_MAXA { gil_consider(k, 2u32, a, 0u64)  a = a + 1u64 }
    /* cost 2: (x<<a) + x  [k = 2^a + 1] */
    a = 1u64
    while a <= GIL_MAXA { gil_consider(k, 3u32, a, 0u64)  a = a + 1u64 }
    /* cost 3: (x<<a) +/- (x<<b)  [k = 2^a +/- 2^b] */
    a = 1u64
    while a <= GIL_MAXA {
        let mut b : u64 = 0u64
        while b < a {
            gil_consider(k, 4u32, a, b)
            gil_consider(k, 5u32, a, b)
            b = b + 1u64
        }
        a = a + 1u64
    }
    return GIL_BEST_COST
}

fn gil_best_cost() -> u32 @export { return GIL_BEST_COST }
fn gil_best_kind() -> u32 @export { return GIL_BEST_KIND }
fn gil_best_a() -> u64 @export { return GIL_BEST_A }
fn gil_best_b() -> u64 @export { return GIL_BEST_B }
fn gil_kernel_calls() -> u64 @export { return GIL_KERNEL_CALLS }
fn gil_sieve_drops() -> u64 @export { return GIL_SIEVE_DROPS }

/* Cheap STRUCTURAL pre-check (NO SAT): will gil_forge find a cheaper-than-multiply reduction for mul(x,k)?
 * It mirrors gil_forge's own search (shapes 1..5 over the same a,b ranges) but only checks whether k EQUALS a
 * shape's value -- which is exactly when that shape equals k*x (e.g. (x<<a)-x == k*x  iff  k == 2^a - 1).  So this
 * is SOUND BOTH WAYS: gil_reducible(k) == 1  iff  gil_forge(k) < GIL_MUL_COST (proven by the differential sweep,
 * corpus 1948).  Lets a caller (eidos/optgate) estimate the SAT route's benefit WITHOUT paying the battery. */
fn gil_reducible(k: u64) -> u8 @export {
    let mut a : u64 = 0u64                                  /* shape 1: shl(x,a) == 2^a, a = 0..GIL_MAXA */
    while a <= GIL_MAXA {
        if k == (1u64 << a) { return 1u8 }
        a = a + 1u64
    }
    a = 1u64                                                /* shapes 2,3: 2^a -/+ 1, a = 1..GIL_MAXA */
    while a <= GIL_MAXA {
        let pa : u64 = 1u64 << a
        if k == (pa - 1u64) { return 1u8 }
        if k == (pa + 1u64) { return 1u8 }
        a = a + 1u64
    }
    a = 1u64                                                /* shapes 4,5: 2^a +/- 2^b, a = 1..GIL_MAXA, b = 0..a-1 */
    while a <= GIL_MAXA {
        let pa : u64 = 1u64 << a
        let mut b : u64 = 0u64
        while b < a {
            let pb : u64 = 1u64 << b
            if k == (pa + pb) { return 1u8 }
            if k == (pa - pb) { return 1u8 }
            b = b + 1u64
        }
        a = a + 1u64
    }
    return 0u8
}

/* the safety check, exposed: the SAT judge REFUSES a false strength reduction (k*x where k != 2^a - 1
 * against (x<<a)-x).  1 iff correctly refuted. */
fn gil_refutes_false(k: u64, a: u64) -> u8 @export {
    bb_reset(GIL_W)
    let x : u32 = bb_var(0u32)
    let target : u32 = bb_mul(x, bb_const(k))
    let cand : u32 = bb_sub(bb_shl(x, a), x)
    if eqv_eq(target, cand) == 0u8 { return 1u8 }
    return 0u8
}

/* ===================================================================================================
 * EXPANDED ALPHABET -- the two-variable arithmetic<->bitwise CROSSOVER forge.
 *
 * Single-variable mul(x,k) cannot benefit from bitwise ops (you cannot build multiplication from
 * and/or/xor of constants).  The "alien" bit-twiddling lives in TWO variables, where an ARITHMETIC
 * combination of BITWISE terms collapses to a single cheap op.  The same engine -- generate, value-sieve,
 * SAT-judge -- now over the algebra {and, or, xor, not, shl, add, sub} on a leaf set {x, y, x&y, x|y, x^y,
 * ~x, ~y}.  III rediscovers the folklore crossover identities (x^y = (x|y)-(x&y); x|y = (x^y)+(x&y);
 * x+y = (x^y)+2(x&y), the carry-save adder) entirely de-novo -- the SHAPE found by cost-directed search,
 * the EQUALITY proven by the SAT judge for all inputs.
 * =================================================================================================== */
const GILX_W : u64 = 64u64

var GILX_KERNEL_CALLS : u64 = 0u64
var GILX_SIEVE_DROPS  : u64 = 0u64
var GILX_BEST_COST    : u32 = 0u32
var GILX_BEST_MODE    : u32 = 0u32       /* 99 = single leaf; 0..4 = op(leaf_a, leaf_b) */
var GILX_BEST_A       : u32 = 0u32
var GILX_BEST_B       : u32 = 0u32

/* the 7-leaf set; leaves 0..1 (x,y) are free, 2..6 (and/or/xor/not_x/not_y) cost 1. */
fn gilx_leaf(idx: u32, x: u32, y: u32) -> u32 {
    if idx == 0u32 { return x }
    if idx == 1u32 { return y }
    if idx == 2u32 { return bb_and(x, y) }
    if idx == 3u32 { return bb_or(x, y) }
    if idx == 4u32 { return bb_xor(x, y) }
    if idx == 5u32 { return bb_not(x) }
    if idx == 6u32 { return bb_not(y) }
    return 0xFFFFFFFFu32
}
fn gilx_leaf_cost(idx: u32) -> u32 { if idx <= 1u32 { return 0u32 }  return 1u32 }

fn gilx_op(op: u32, p: u32, q: u32) -> u32 {
    if op == 0u32 { return bb_and(p, q) }
    if op == 1u32 { return bb_or(p, q) }
    if op == 2u32 { return bb_xor(p, q) }
    if op == 3u32 { return bb_add(p, q) }
    if op == 4u32 { return bb_sub(p, q) }
    return 0xFFFFFFFFu32
}

/* the mixed TARGET expressions to reduce, and their op-costs (the incumbent to beat). */
fn gilx_target(kind: u32, x: u32, y: u32) -> u32 {
    if kind == 1u32 { return bb_sub(bb_or(x, y), bb_and(x, y)) }                  /* (x|y) - (x&y) */
    if kind == 2u32 { return bb_add(bb_xor(x, y), bb_and(x, y)) }                 /* (x^y) + (x&y) */
    if kind == 3u32 { return bb_add(bb_xor(x, y), bb_shl(bb_and(x, y), 1u64)) }   /* (x^y) + ((x&y)<<1) */
    return 0xFFFFFFFFu32
}
fn gilx_target_cost(kind: u32) -> u32 {
    if kind == 1u32 { return 3u32 }
    if kind == 2u32 { return 3u32 }
    if kind == 3u32 { return 4u32 }
    return 0xFFFFFFFFu32
}

/* SIEVE then JUDGE one candidate (single leaf if mode==99, else op(leaf_a,leaf_b)) against the target. */
fn gilx_consider(kind: u32, cost: u32, mode: u32, a: u32, b: u32) -> i32 {
    if cost >= GILX_BEST_COST {
        GILX_SIEVE_DROPS = GILX_SIEVE_DROPS + 1u64
        return 0i32
    }
    bb_reset(GILX_W)
    let x : u32 = bb_var(0u32)
    let y : u32 = bb_var(1u32)
    let target : u32 = gilx_target(kind, x, y)
    let mut cand : u32 = 0u32
    if mode == 99u32 { cand = gilx_leaf(a, x, y) } else { cand = gilx_op(mode, gilx_leaf(a, x, y), gilx_leaf(b, x, y)) }
    GILX_KERNEL_CALLS = GILX_KERNEL_CALLS + 1u64
    if eqv_eq(target, cand) == 1u8 {
        GILX_BEST_COST = cost
        GILX_BEST_MODE = mode
        GILX_BEST_A = a
        GILX_BEST_B = b
        return 1i32
    }
    return 0i32
}

/* CROSSOVER FORGE: invent the cheapest provably-equal form of mixed target `kind`. */
fn gilx_forge(kind: u32) -> u32 @export {
    GILX_KERNEL_CALLS = 0u64
    GILX_SIEVE_DROPS = 0u64
    GILX_BEST_MODE = 0xFFFFFFFFu32
    GILX_BEST_A = 0u32
    GILX_BEST_B = 0u32
    GILX_BEST_COST = gilx_target_cost(kind)        /* incumbent: the mixed form itself */

    /* single leaves first (cheapest) */
    let mut li : u32 = 0u32
    while li < 7u32 { gilx_consider(kind, gilx_leaf_cost(li), 99u32, li, 0u32)  li = li + 1u32 }
    /* then op(leaf_a, leaf_b) */
    let mut op : u32 = 0u32
    while op < 5u32 {
        let mut i : u32 = 0u32
        while i < 7u32 {
            let mut j : u32 = 0u32
            while j < 7u32 {
                gilx_consider(kind, gilx_leaf_cost(i) + gilx_leaf_cost(j) + 1u32, op, i, j)
                j = j + 1u32
            }
            i = i + 1u32
        }
        op = op + 1u32
    }
    return GILX_BEST_COST
}

fn gilx_best_cost() -> u32 @export { return GILX_BEST_COST }
fn gilx_best_mode() -> u32 @export { return GILX_BEST_MODE }
fn gilx_best_a() -> u32 @export { return GILX_BEST_A }
fn gilx_best_b() -> u32 @export { return GILX_BEST_B }
fn gilx_kernel_calls() -> u64 @export { return GILX_KERNEL_CALLS }
fn gilx_sieve_drops() -> u64 @export { return GILX_SIEVE_DROPS }

/* ===================================================================================================
 * THE NIH PURGE -- inventing a proven modular-reduction fold that beats Montgomery (for special primes).
 *
 * Montgomery reduction is near-optimal for ARBITRARY odd moduli -- it is not beatable in general, and this
 * forge does not claim to.  But for SPECIAL-FORM primes p = 2^k - c (Mersenne c=1, pseudo-Mersenne small c,
 * Solinas/Goldilocks) -- the primes that dominate modern STARK provers and ECC -- the reduction is a FOLD,
 *     r = (x & (2^k - 1)) + c * (x >> k)
 * which is pure shift/mask/add with NO multiply, versus Montgomery's two multiplies.  III invents this fold
 * by SEARCHING the multiplier (it is not told c), and PROVES it congruent without any urem reference via the
 * identity  x - r == (x >> k) * p  (which proves r === x (mod p) for all x).  A wrong multiplier is refuted.
 *
 * This is the de-novo, proven, strictly-cheaper "III-fold" -- superior to Montgomery for these primes,
 * honestly NOT a universal replacement.  Hexad: kind_cognition.  Ring: R0.  K: 1.00.
 * =================================================================================================== */
const GILR_W : u64 = 64u64
const GILR_MONT_COST : u32 = 8u32      /* Montgomery reduction: ~two multiplies (the baseline to beat) */

var GILR_FOUND_C   : u64 = 0u64        /* the multiplier the forge proved (0 = none in range) */
var GILR_FOLD_COST : u32 = 0u32        /* the invented fold's op-cost */
var GILR_PROBES    : u64 = 0u64        /* multipliers tried at the judge */

/* prove the fold r = (x & (2^k - 1)) + cc*(x>>k) is congruent to x mod (2^k - c): 1 iff x - r == (x>>k)*p
 * for ALL x (the SAT judge, no urem reference).  Sound only when the candidate's cc matches the modulus c. */
fn gilr_proves(k: u64, c: u64, cc: u64) -> u8 @export {
    let twok : u64 = 1u64 << k         /* hoisted: a bare top-level shift (avoids the 1u64<<var misparse) */
    bb_reset(GILR_W)
    let x  : u32 = bb_var(0u32)
    let hi : u32 = bb_shr(x, k)
    let lo : u32 = bb_and(x, bb_const(twok - 1u64))
    let mut r : u32 = lo
    if cc == 1u64 { r = bb_add(lo, hi) } else { r = bb_add(lo, bb_mul(hi, bb_const(cc))) }
    let lhs : u32 = bb_sub(x, r)
    let p   : u64 = twok - c
    let rhs : u32 = bb_mul(hi, bb_const(p))
    return eqv_eq(lhs, rhs)
}

/* the op-cost of the fold for multiplier cc: and + shr + add, plus a multiply iff cc != 1. */
fn gilr_fold_cost_of(cc: u64) -> u32 {
    if cc == 1u64 { return 3u32 }      /* and, shr, add */
    return 4u32                        /* and, shr, mul-by-c, add */
}

/* FORGE: invent the reduction fold for p = 2^k - c by searching the multiplier (1..32); the value-sieve
 * only proceeds while the fold can still beat Montgomery; the SAT judge confirms the congruence.  Returns
 * the proven multiplier (== c), or 0 if none in range proves congruent. */
fn gilr_forge(k: u64, c: u64) -> u64 @export {
    GILR_FOUND_C = 0u64
    GILR_FOLD_COST = GILR_MONT_COST
    GILR_PROBES = 0u64
    let mut cc : u64 = 1u64
    let mut going : u8 = 1u8
    while going == 1u8 {
        if cc > 32u64 { going = 0u8 } else {
            if gilr_fold_cost_of(cc) >= GILR_MONT_COST {     /* value sieve: a fold this costly is no win -> skip the judge */
                cc = cc + 1u64
            } else {
                GILR_PROBES = GILR_PROBES + 1u64
                if gilr_proves(k, c, cc) == 1u8 {
                    GILR_FOUND_C = cc
                    GILR_FOLD_COST = gilr_fold_cost_of(cc)
                    going = 0u8
                } else {
                    cc = cc + 1u64
                }
            }
        }
    }
    return GILR_FOUND_C
}

fn gilr_fold_cost() -> u32 @export { return GILR_FOLD_COST }
fn gilr_mont_cost() -> u32 @export { return GILR_MONT_COST }
fn gilr_probes() -> u64 @export { return GILR_PROBES }

/* ===================================================================================================
 * THE 6-STATE FORGE -- the invention engine pointed at numera/logic6 (the completed bounded lattice).
 *
 * Over Boolean the forge invented the carry-save adder.  Over the six-valued lattice it invents COLLAPSE:
 * tangles of paradox-routing (Both) and void-routing (Null/All-present) that reduce to almost nothing --
 * the provable "don't-care collapse".  The judge here is not SAT but EXHAUSTIVE equivalence over the 36
 * (a,b) value pairs (the finite algebra is decided directly); the value-sieve still gates pre-judge.
 *
 * Leaves: 0=a, 1=b, 2=Null, 3=All-present, 4=NOT a, 5=NOT b  (a,b,Null,All cost 0; NOT cost 1).
 * Ops: 0=AND(meet), 1=OR(join).
 * =================================================================================================== */
const L6_NULL_C : u32 = 4u32
const L6_ALL_C  : u32 = 5u32

var GIL6_BEST_COST : u32 = 0u32
var GIL6_BEST_MODE : u32 = 0u32          /* 99 = single leaf; 0..1 = op(leaf_a, leaf_b) */
var GIL6_BEST_A    : u32 = 0u32
var GIL6_BEST_B    : u32 = 0u32
var GIL6_JUDGED    : u64 = 0u64
var GIL6_DROPS     : u64 = 0u64

/* the mixed TARGET expressions (and their op-cost incumbent), each a routing tangle that should collapse. */
fn gil6_target(tid: u32, a: u32, b: u32) -> u32 {
    if tid == 1u32 { return l6_or(l6_and(a, L6_NULL_C), b) }   /* (a AND Null) OR b      -> collapses to b */
    if tid == 2u32 { return l6_and(a, l6_or(a, b)) }           /* a AND (a OR b)         -> collapses to a (absorption) */
    if tid == 3u32 { return l6_and(l6_or(a, L6_ALL_C), b) }    /* (a OR All-present) AND b -> collapses to b */
    return 0xFFFFFFFFu32
}
fn gil6_target_cost(tid: u32) -> u32 { if tid <= 3u32 { return 2u32 }  return 0xFFFFFFFFu32 }

fn gil6_leaf(idx: u32, a: u32, b: u32) -> u32 {
    if idx == 0u32 { return a }
    if idx == 1u32 { return b }
    if idx == 2u32 { return L6_NULL_C }
    if idx == 3u32 { return L6_ALL_C }
    if idx == 4u32 { return l6_not(a) }
    if idx == 5u32 { return l6_not(b) }
    return 0xFFFFFFFFu32
}
fn gil6_leaf_cost(idx: u32) -> u32 { if idx <= 3u32 { return 0u32 }  return 1u32 }
fn gil6_op(op: u32, p: u32, q: u32) -> u32 { if op == 0u32 { return l6_and(p, q) }  return l6_or(p, q) }

/* EXHAUSTIVE equivalence: candidate == target tid over all 36 valid (a,b) pairs (values 0..5). */
fn gil6_equiv(tid: u32, mode: u32, la: u32, lb: u32) -> u8 {
    let mut a : u32 = 0u32
    while a < 6u32 {
        let mut b : u32 = 0u32
        while b < 6u32 {
            let t : u32 = gil6_target(tid, a, b)
            let mut cand : u32 = 0u32
            if mode == 99u32 { cand = gil6_leaf(la, a, b) } else { cand = gil6_op(mode, gil6_leaf(la, a, b), gil6_leaf(lb, a, b)) }
            if t != cand { return 0u8 }
            b = b + 1u32
        }
        a = a + 1u32
    }
    return 1u8
}

fn gil6_consider(tid: u32, cost: u32, mode: u32, la: u32, lb: u32) -> i32 {
    if cost >= GIL6_BEST_COST { GIL6_DROPS = GIL6_DROPS + 1u64  return 0i32 }
    GIL6_JUDGED = GIL6_JUDGED + 1u64
    if gil6_equiv(tid, mode, la, lb) == 1u8 {
        GIL6_BEST_COST = cost
        GIL6_BEST_MODE = mode
        GIL6_BEST_A = la
        GIL6_BEST_B = lb
        return 1i32
    }
    return 0i32
}

/* FORGE: invent the cheapest 6-valued form equivalent to the routing tangle `tid`. */
fn gil6_forge(tid: u32) -> u32 @export {
    GIL6_JUDGED = 0u64
    GIL6_DROPS = 0u64
    GIL6_BEST_MODE = 0xFFFFFFFFu32
    GIL6_BEST_A = 0u32
    GIL6_BEST_B = 0u32
    GIL6_BEST_COST = gil6_target_cost(tid)
    let mut li : u32 = 0u32
    while li < 6u32 { gil6_consider(tid, gil6_leaf_cost(li), 99u32, li, 0u32)  li = li + 1u32 }
    let mut op : u32 = 0u32
    while op < 2u32 {
        let mut i : u32 = 0u32
        while i < 6u32 {
            let mut j : u32 = 0u32
            while j < 6u32 {
                gil6_consider(tid, gil6_leaf_cost(i) + gil6_leaf_cost(j) + 1u32, op, i, j)
                j = j + 1u32
            }
            i = i + 1u32
        }
        op = op + 1u32
    }
    return GIL6_BEST_COST
}

fn gil6_best_cost() -> u32 @export { return GIL6_BEST_COST }
fn gil6_best_mode() -> u32 @export { return GIL6_BEST_MODE }
fn gil6_best_a() -> u32 @export { return GIL6_BEST_A }
fn gil6_judged() -> u64 @export { return GIL6_JUDGED }
fn gil6_drops() -> u64 @export { return GIL6_DROPS }

/* ============================================================================================================
 * THE CASH-IN: the invention engine, cost-validated against III's REAL microarch model (numera/microarch_model)
 * ------------------------------------------------------------------------------------------------------------
 * The value-sieve (gil_cost) ranks candidates by an abstract OP-COUNT -- correct for a gate-count / zk target
 * where a multiply is the dominant cost.  But on real silicon "cheaper" is TARGET-RELATIVE: a strength
 * reduction that wins by op-count can LOSE by cycles if the target's multiplier is fast.  This bridge feeds a
 * gil-invented form to the same analytic cycle model the optimizer's cost_calculus already trusts, so the
 * invention engine's "cheaper" becomes COST-TRUE -- additive (the op-count search is untouched; this only adds
 * a cycle-truth verdict).  Two existing faculties connected, no island.
 *
 * Opcodes are caller-defined latency labels for the model; deps are (consumer_index, producer_index) pairs. */
const GIL_MA_MUL : u32 = 10u32
const GIL_MA_SHL : u32 = 11u32
const GIL_MA_SUB : u32 = 12u32
const GIL_MA_ADD : u32 = 13u32

var GIL_MA_OPS  : [u32; 8]
var GIL_MA_DEPS : [u32; 16]
var GIL_MA_CYC  : [u64; 1]

fn gil_ma_cycles(n: u32, dep_n: u32) -> u64 {
    ma_simulate((&GIL_MA_OPS as u64) as *u32, n, (&GIL_MA_DEPS as u64) as *u32, dep_n, (&GIL_MA_CYC as u64) as *u64)
    return GIL_MA_CYC[0u64]
}

/* Validate the gil-invented reduction of mul(x,k) against the cycle model, for a target whose MULTIPLY latency
 * is `mul_latency` (shift/add/sub fixed at 1).  Returns 1 iff the invented form is STRICTLY fewer cycles than a
 * single imul on that target -- so the SAME reduction returns 1 on a slow-multiply target and 0 on a fast one. */
fn gil_cycle_validate(k: u64, mul_latency: u32) -> u8 @export {
    gil_forge(k)
    let kind : u32 = gil_best_kind()
    ma_init()
    ma_set_latency(GIL_MA_MUL, mul_latency)
    ma_set_latency(GIL_MA_SHL, 1u32)
    ma_set_latency(GIL_MA_SUB, 1u32)
    ma_set_latency(GIL_MA_ADD, 1u32)
    /* baseline: a single imul */
    GIL_MA_OPS[0u64] = GIL_MA_MUL
    let cyc_imul : u64 = gil_ma_cycles(1u32, 0u32)
    /* the invented form, by winning shape (gil_best_kind 1..5) */
    let mut n  : u32 = 0u32
    let mut dn : u32 = 0u32
    if kind == 1u32 {                                  /* shl(x,a) */
        GIL_MA_OPS[0u64] = GIL_MA_SHL  n = 1u32  dn = 0u32
    }
    if kind == 2u32 {                                  /* (x<<a) - x */
        GIL_MA_OPS[0u64] = GIL_MA_SHL  GIL_MA_OPS[1u64] = GIL_MA_SUB
        GIL_MA_DEPS[0u64] = 1u32  GIL_MA_DEPS[1u64] = 0u32  n = 2u32  dn = 1u32
    }
    if kind == 3u32 {                                  /* (x<<a) + x */
        GIL_MA_OPS[0u64] = GIL_MA_SHL  GIL_MA_OPS[1u64] = GIL_MA_ADD
        GIL_MA_DEPS[0u64] = 1u32  GIL_MA_DEPS[1u64] = 0u32  n = 2u32  dn = 1u32
    }
    if kind == 4u32 {                                  /* (x<<a) + (x<<b) */
        GIL_MA_OPS[0u64] = GIL_MA_SHL  GIL_MA_OPS[1u64] = GIL_MA_SHL  GIL_MA_OPS[2u64] = GIL_MA_ADD
        GIL_MA_DEPS[0u64] = 2u32  GIL_MA_DEPS[1u64] = 0u32  GIL_MA_DEPS[2u64] = 2u32  GIL_MA_DEPS[3u64] = 1u32  n = 3u32  dn = 2u32
    }
    if kind == 5u32 {                                  /* (x<<a) - (x<<b) */
        GIL_MA_OPS[0u64] = GIL_MA_SHL  GIL_MA_OPS[1u64] = GIL_MA_SHL  GIL_MA_OPS[2u64] = GIL_MA_SUB
        GIL_MA_DEPS[0u64] = 2u32  GIL_MA_DEPS[1u64] = 0u32  GIL_MA_DEPS[2u64] = 2u32  GIL_MA_DEPS[3u64] = 1u32  n = 3u32  dn = 2u32
    }
    if n == 0u32 { return 0u8 }                        /* no reduction found -> not cheaper */
    let cyc_form : u64 = gil_ma_cycles(n, dn)
    if cyc_form < cyc_imul { return 1u8 }
    return 0u8
}

/* ============================================================================================================
 * THE WEAVE FORGE -- invent fills out the weave independently.
 *
 * Points the same generate->value-sieve->SAT-judge engine at the WEAVE's own structural primitives: the SHA-2
 * round functions Ch and Maj.  primweb PROVED their cheaper forms by hand; this forge DISCOVERS them de-novo --
 * the SHAPE found by cost-directed search over the leaf set {a,b,c, a^b, a^c, b^c} and the op set {and,or,xor},
 * the EQUALITY proven by the bb_equal SAT miter for ALL inputs.  III rediscovers Ch(e,f,g) = g ^ (e&(f^g))
 * (one AND fewer, no NOT) and Maj(a,b,c) = (a&b) ^ (c&(a^b)) (the carry-save / adder-carry form) without being
 * handed either.  The winning descriptor is recorded, so gilw_build_best rebuilds the discovered circuit on
 * any var set -- and bv_bits' bb_eval EXECUTES it: discovered, proven, runnable -- one object on one substrate.
 *
 * Grammar: mode 1 = outer(leaf_i, inner(leaf_j,leaf_k)) [Ch's shape]; mode 2 = outer(inner(leaf_i,leaf_j),
 * inner(leaf_k,leaf_l)) [Maj's shape].  NOT-leaves are deliberately excluded -- the discovery is the NO-NOT
 * cheaper form, so the grammar must be able to express it without them.  Proven at w=8 (Ch/Maj are bitwise --
 * per-bit identities hold at every width); the rebuilt circuit is width-agnostic. */
const GILW_W : u64 = 8u64

var GILW_KCALLS    : u64 = 0u64
var GILW_BEST_COST : u32 = 0u32
var GILW_FOUND     : u8  = 0u8
var GILW_B_MODE : u32 = 0u32
var GILW_B_OO   : u32 = 0u32
var GILW_B_AOP  : u32 = 0u32
var GILW_B_BOP  : u32 = 0u32
var GILW_B_AI   : u32 = 0u32
var GILW_B_AJ   : u32 = 0u32
var GILW_B_BI   : u32 = 0u32
var GILW_B_BJ   : u32 = 0u32

/* leaf set over var nodes a,b,c -- base (cost 0) + the three xor-pairs (cost 1). */
fn gilw_leaf(idx: u32, a: u32, b: u32, c: u32) -> u32 {
    if idx == 0u32 { return a }
    if idx == 1u32 { return b }
    if idx == 2u32 { return c }
    if idx == 3u32 { return bb_xor(a, b) }
    if idx == 4u32 { return bb_xor(a, c) }
    if idx == 5u32 { return bb_xor(b, c) }
    return 0xFFFFFFFFu32
}
fn gilw_leafcost(idx: u32) -> u32 { if idx <= 2u32 { return 0u32 }  return 1u32 }
fn gilw_op(op: u32, p: u32, q: u32) -> u32 {
    if op == 0u32 { return bb_and(p, q) }
    if op == 1u32 { return bb_or(p, q) }
    return bb_xor(p, q)
}

/* the weave target function (the incumbent op-count to beat). 1 = Ch, 2 = Maj. */
fn gilw_target(kind: u32, a: u32, b: u32, c: u32) -> u32 {
    if kind == 1u32 { return bb_xor(bb_and(a, b), bb_and(bb_not(a), c)) }            /* Ch = (a&b)^(~a&c) */
    return bb_xor(bb_xor(bb_and(a, b), bb_and(a, c)), bb_and(b, c))                  /* Maj = (a&b)^(a&c)^(b&c) */
}
fn gilw_target_cost(kind: u32) -> u32 { if kind == 1u32 { return 4u32 }  return 5u32 }

/* build a candidate from the descriptor over var nodes a,b,c. */
fn gilw_build(mode: u32, oo: u32, aop: u32, ai: u32, aj: u32, bop: u32, bi: u32, bj: u32, a: u32, b: u32, c: u32) -> u32 {
    if mode == 1u32 {
        return gilw_op(oo, gilw_leaf(ai, a, b, c), gilw_op(aop, gilw_leaf(bi, a, b, c), gilw_leaf(bj, a, b, c)))
    }
    return gilw_op(oo, gilw_op(aop, gilw_leaf(ai, a, b, c), gilw_leaf(aj, a, b, c)), gilw_op(bop, gilw_leaf(bi, a, b, c), gilw_leaf(bj, a, b, c)))
}

/* rebuild the DISCOVERED best form over the caller's var nodes (so bb_eval can EXECUTE it). */
fn gilw_build_best(a: u32, b: u32, c: u32) -> u32 @export {
    return gilw_build(GILW_B_MODE, GILW_B_OO, GILW_B_AOP, GILW_B_AI, GILW_B_AJ, GILW_B_BOP, GILW_B_BI, GILW_B_BJ, a, b, c)
}

/* sieve then judge one candidate; adopt + record descriptor iff strictly cheaper and SAT-proven equal. */
fn gilw_consider(kind: u32, mode: u32, oo: u32, aop: u32, ai: u32, aj: u32, bop: u32, bi: u32, bj: u32) -> i32 {
    let mut cost : u32 = 0u32
    if mode == 1u32 { cost = gilw_leafcost(ai) + gilw_leafcost(bi) + gilw_leafcost(bj) + 2u32 }
    else { cost = gilw_leafcost(ai) + gilw_leafcost(aj) + gilw_leafcost(bi) + gilw_leafcost(bj) + 3u32 }
    if cost >= GILW_BEST_COST { return 0i32 }
    bb_reset(GILW_W)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    let c : u32 = bb_var(2u32)
    let target : u32 = gilw_target(kind, a, b, c)
    let cand : u32 = gilw_build(mode, oo, aop, ai, aj, bop, bi, bj, a, b, c)
    GILW_KCALLS = GILW_KCALLS + 1u64
    if eqv_eq(target, cand) == 1u8 {
        GILW_BEST_COST = cost
        GILW_FOUND = 1u8
        GILW_B_MODE = mode  GILW_B_OO = oo  GILW_B_AOP = aop  GILW_B_BOP = bop
        GILW_B_AI = ai  GILW_B_AJ = aj  GILW_B_BI = bi  GILW_B_BJ = bj
        return 1i32
    }
    return 0i32
}

/* FORGE: discover the cheapest provably-equal form of weave function `kind`. */
fn gilw_forge(kind: u32) -> u32 @export {
    GILW_KCALLS = 0u64
    GILW_FOUND = 0u8
    GILW_BEST_COST = gilw_target_cost(kind)
    /* mode 1: outer(leaf, inner(leaf,leaf)) -- Ch's shape */
    let mut oo : u32 = 0u32
    while oo < 3u32 {
        let mut aop : u32 = 0u32
        while aop < 3u32 {
            let mut ai : u32 = 0u32
            while ai < 6u32 {
                let mut bi : u32 = 0u32
                while bi < 6u32 {
                    let mut bj : u32 = 0u32
                    while bj < 6u32 {
                        gilw_consider(kind, 1u32, oo, aop, ai, 0u32, 0u32, bi, bj)
                        bj = bj + 1u32
                    }
                    bi = bi + 1u32
                }
                ai = ai + 1u32
            }
            aop = aop + 1u32
        }
        oo = oo + 1u32
    }
    /* mode 2: outer(inner(leaf,leaf), inner(leaf,leaf)) -- Maj's shape */
    oo = 0u32
    while oo < 3u32 {
        let mut aop : u32 = 0u32
        while aop < 3u32 {
            let mut bop : u32 = 0u32
            while bop < 3u32 {
                let mut ai : u32 = 0u32
                while ai < 6u32 {
                    let mut aj : u32 = 0u32
                    while aj < 6u32 {
                        let mut bi : u32 = 0u32
                        while bi < 6u32 {
                            let mut bj : u32 = 0u32
                            while bj < 6u32 {
                                gilw_consider(kind, 2u32, oo, aop, ai, aj, bop, bi, bj)
                                bj = bj + 1u32
                            }
                            bi = bi + 1u32
                        }
                        aj = aj + 1u32
                    }
                    ai = ai + 1u32
                }
                bop = bop + 1u32
            }
            aop = aop + 1u32
        }
        oo = oo + 1u32
    }
    return GILW_BEST_COST
}

fn gilw_best_cost() -> u32 @export { return GILW_BEST_COST }
fn gilw_found() -> u8 @export { return GILW_FOUND }
fn gilw_kcalls() -> u64 @export { return GILW_KCALLS }
fn gilw_best_mode() -> u32 @export { return GILW_B_MODE }

/* ============================================================================================================
 * THE WEAVE-FILL PASS -- III fills out the weave, unassisted, in ONE run.
 *
 * The granular substrate (each primitive a bv circuit that the SAT judge proves and bb_eval runs) is exactly
 * what lets the invention engine populate the weave on its own.  weave_fill drives every FAST forge across its
 * targets in a single pass and tallies how many distinct algebraic laws III discovered AND proved -- the
 * round-function family (gilw: Ch, Maj), the arithmetic<->bitwise crossover family (gilx: x^y, x|y, the
 * carry-save adder), and the six-valued collapse family (gil6: the routing-tangle absorptions).  Each is a
 * SHAPE found by cost-directed search and an EQUALITY proven (SAT miter for gilw/gilx, exhaustive decision for
 * gil6) -- no human hands any of them in.  Returns the count of proven discoveries (8 when the substrate is
 * whole), the concrete answer to "is III yet capable of inventing, system-wide, unassisted?" -- run and count. */
fn weave_fill() -> u64 @export {
    let mut count : u64 = 0u64
    gilw_forge(1u32)  if gilw_found() == 1u8 { count = count + 1u64 }                          /* Ch  */
    gilw_forge(2u32)  if gilw_found() == 1u8 { count = count + 1u64 }                          /* Maj */
    gilx_forge(1u32)  if gilx_best_mode() != 0xFFFFFFFFu32 { count = count + 1u64 }            /* x^y = (x|y)-(x&y) */
    gilx_forge(2u32)  if gilx_best_mode() != 0xFFFFFFFFu32 { count = count + 1u64 }            /* x|y = (x^y)+(x&y) */
    gilx_forge(3u32)  if gilx_best_mode() != 0xFFFFFFFFu32 { count = count + 1u64 }            /* x+y = carry-save  */
    gil6_forge(1u32)  if gil6_best_mode() != 0xFFFFFFFFu32 { count = count + 1u64 }            /* (a&Null)|b -> b   */
    gil6_forge(2u32)  if gil6_best_mode() != 0xFFFFFFFFu32 { count = count + 1u64 }            /* a&(a|b) -> a      */
    gil6_forge(3u32)  if gil6_best_mode() != 0xFFFFFFFFu32 { count = count + 1u64 }            /* (a|All)&b -> b    */
    return count
}

/* ============================================================================================================
 * GILD -- GENERATIVE IDENTITY DISCOVERY: the weave's STRUCTURAL strands EMERGE, they are not hand-authored.
 *
 * primweb proved structural relations one at a time, each a human-picked instance (rotation duality at ONE k,
 * the self-coincidence asserted at k=16).  gild makes those strands SELF-DISCOVERED: it searches the relation
 * space and the SAT judge proves what holds, so the weave populates its own structural web -- and finds the
 * WHOLE family the hand-authored strand only sampled.  Discovery, not verification: the engine is NOT told the
 * dual amount; it searches for the j that makes rotl(x,k) == rotr(x,j) and proves it.  Width 32 = the crypto
 * word, so the discovered self-coincidence is k=16 exactly as primewb's pw_rot_coincide hand-asserts. */
const GILD_W : u64 = 32u64

fn gild_rotl(x: u32, k: u64) -> u32 {
    if k == 0u64 { return x }
    return bb_or(bb_shl(x, k), bb_shr(x, GILD_W - k))
}
fn gild_rotr(x: u32, k: u64) -> u32 {
    if k == 0u64 { return x }
    return bb_or(bb_shr(x, k), bb_shl(x, GILD_W - k))
}

/* DISCOVER the dual rotation j such that rotl(x,k) == rotr(x,j) for ALL x; -1 if none in range.  The engine is
 * not told j = w-k -- it searches and the SAT miter proves the survivor. */
fn gild_rotdual_find(k: u64) -> i64 @export {
    let mut j : u64 = 1u64
    while j < GILD_W {
        bb_reset(GILD_W)
        let x : u32 = bb_var(0u32)
        if eqv_eq(gild_rotl(x, k), gild_rotr(x, j)) == 1u8 { return j as i64 }
        j = j + 1u64
    }
    return -1i64
}

/* DISCOVER the FULL rotation-duality family: for every k in 1..w-1 the discovered dual exists and equals w-k.
 * Returns the count whose discovered dual satisfies j == w-k (= w-1 = 31 when the whole family is present) --
 * the complete strand primweb only hand-sampled. */
fn gild_rotdual_count() -> u64 @export {
    let mut count : u64 = 0u64
    let mut k : u64 = 1u64
    while k < GILD_W {
        let j : i64 = gild_rotdual_find(k)
        if j == (GILD_W - k) as i64 { count = count + 1u64 }
        k = k + 1u64
    }
    return count
}

/* DISCOVER the unique self-dual amount: the k where rotl(x,k) == rotr(x,k) (the half-width coincidence, k=16). */
fn gild_selfdual_k() -> i64 @export {
    let mut k : u64 = 1u64
    while k < GILD_W {
        bb_reset(GILD_W)
        let x : u32 = bb_var(0u32)
        if eqv_eq(gild_rotl(x, k), gild_rotr(x, k)) == 1u8 { return k as i64 }
        k = k + 1u64
    }
    return -1i64
}

/* DISCOVER the SELF-LAW family: what does op(x,x) collapse to?  The engine applies op in {sub,xor,and,or} to
 * (x,x) and SEARCHES the RHS among {0, x, all-ones}, the SAT judge proving the collapse.  It rediscovers the
 * very laws bv_commons HAND-LISTS (sub.self=0, xor.self=0, and.self=x, or.self=x) -- now found, not authored.
 * op: 0=sub 1=xor 2=and 3=or.  Returns 0 if op(x,x)==0, 1 if ==x, 2 if ==all-ones, -1 if none. */
fn gild_selflaw_lhs(op: u32, x: u32) -> u32 {
    if op == 0u32 { return bb_sub(x, x) }
    if op == 1u32 { return bb_xor(x, x) }
    if op == 2u32 { return bb_and(x, x) }
    return bb_or(x, x)
}
fn gild_selflaw_rhs(op: u32) -> i32 @export {
    bb_reset(GILD_W)
    let x : u32 = bb_var(0u32)
    let lhs : u32 = gild_selflaw_lhs(op, x)
    if eqv_eq(lhs, bb_const(0u64)) == 1u8 { return 0i32 }                       /* collapses to 0 */
    if eqv_eq(lhs, bb_var(0u32)) == 1u8 { return 1i32 }                         /* collapses to x */
    if eqv_eq(lhs, bb_const(0xFFFFFFFFu64)) == 1u8 { return 2i32 }              /* collapses to all-ones */
    return -1i32
}

/* ============================================================================================================
 * COST-TRUE ADOPTION: a discovered cheaper form is adopted only where it is ACTUALLY cheaper on the target.
 *
 * The Ch/Maj optforms gild/gilw discover have strictly FEWER ANDs (Ch: 1 vs 2; Maj: 2 vs 3).  On a gate-count
 * or zk-proving target every AND is a multiplication-gate / a constraint, so the optform is a real win and is
 * ADOPTED.  On x86 the spec ops are ~1 cycle and the multiplexer is native, so the win is marginal -> the gate
 * ABSTAINS (cost-true, not forced -- forcing adoption against the proven cost model would be a regression).
 * The adoption is gated on a SOUND equivalence proof: a form that does not bb_equal the spec is never adopted. */

/* AND-count of the Ch SPEC form (e&f)^(~e&g). */
fn gild_ch_spec_ands() -> u64 @export {
    bb_reset(GILD_W)
    let e : u32 = bb_var(0u32)
    let f : u32 = bb_var(1u32)
    let g : u32 = bb_var(2u32)
    bb_xor(bb_and(e, f), bb_and(bb_not(e), g))
    return bb_count_and()
}
/* AND-count of the Ch OPTFORM g^(e&(f^g)). */
fn gild_ch_opt_ands() -> u64 @export {
    bb_reset(GILD_W)
    let e : u32 = bb_var(0u32)
    let f : u32 = bb_var(1u32)
    let g : u32 = bb_var(2u32)
    bb_xor(g, bb_and(e, bb_xor(f, g)))
    return bb_count_and()
}

/* DECIDE adoption of the Ch optform for `target` (0 = x86/cycle, 1 = gate-count/zk).  Returns 1 = adopt,
 * 0 = abstain, -1 = REFUSED (the optform is not proven equal to the spec -> never adopt an unproven form). */
fn gild_adopt_ch(target: u32) -> i32 @export {
    let spec_ands : u64 = gild_ch_spec_ands()
    let opt_ands  : u64 = gild_ch_opt_ands()
    bb_reset(GILD_W)
    let e : u32 = bb_var(0u32)
    let f : u32 = bb_var(1u32)
    let g : u32 = bb_var(2u32)
    let spec : u32 = bb_xor(bb_and(e, f), bb_and(bb_not(e), g))
    let opt  : u32 = bb_xor(g, bb_and(e, bb_xor(f, g)))
    if eqv_equal(spec, opt, 3u32) != 1u8 { return -1i32 }                  /* soundness gate: prove before adopt */
    if target == 1u32 {
        if opt_ands < spec_ands { return 1i32 }                    /* gate-count: the AND saving is real -> ADOPT */
        return 0i32
    }
    return 0i32                                                    /* x86: marginal -> abstain (cost-true) */
}

/* the same, for Maj: spec (a&b)^(a&c)^(b&c) [3 ANDs] vs carry-save (a&b)^(c&(a^b)) [2 ANDs]. */
fn gild_adopt_maj(target: u32) -> i32 @export {
    bb_reset(GILD_W)
    let a1 : u32 = bb_var(0u32)
    let b1 : u32 = bb_var(1u32)
    let c1 : u32 = bb_var(2u32)
    bb_xor(bb_xor(bb_and(a1, b1), bb_and(a1, c1)), bb_and(b1, c1))
    let spec_ands : u64 = bb_count_and()
    bb_reset(GILD_W)
    let a2 : u32 = bb_var(0u32)
    let b2 : u32 = bb_var(1u32)
    let c2 : u32 = bb_var(2u32)
    bb_xor(bb_and(a2, b2), bb_and(c2, bb_xor(a2, b2)))
    let opt_ands : u64 = bb_count_and()
    bb_reset(GILD_W)
    let a3 : u32 = bb_var(0u32)
    let b3 : u32 = bb_var(1u32)
    let c3 : u32 = bb_var(2u32)
    let spec : u32 = bb_xor(bb_xor(bb_and(a3, b3), bb_and(a3, c3)), bb_and(b3, c3))
    let opt  : u32 = bb_xor(bb_and(a3, b3), bb_and(c3, bb_xor(a3, b3)))
    if eqv_equal(spec, opt, 3u32) != 1u8 { return -1i32 }
    if target == 1u32 {
        if opt_ands < spec_ands { return 1i32 }
        return 0i32
    }
    return 0i32
}

/* ============================================================================================================
 * THE RATCHET (gilm) -- the lemma library that makes re-discovery FREE: search shrinks as the commons grows.
 *
 * Every forged-and-proven law is deposited in a memo keyed by its target.  A later request for a KNOWN target
 * returns the cached result with ZERO kernel work (a cite); only an UNKNOWN target pays a forge.  This is the
 * Phase III lemma-forge ratchet made concrete: "every later search cites it by hash instead of re-deriving it,
 * so the search space shrinks monotonically as the lemma library grows."  Counters (gilm_forged/gilm_cited)
 * make the ratchet measurable -- pass 1 forges, pass 2 over the same targets does ZERO forges. */
var GILM_KEYS   : [u32; 64]
var GILM_VALS   : [i64; 64]
var GILM_N      : u64 = 0u64
var GILM_FORGED : u64 = 0u64
var GILM_CITED  : u64 = 0u64

fn gilm_reset() -> i32 @export { GILM_N = 0u64 ; GILM_FORGED = 0u64 ; GILM_CITED = 0u64 ; return 0i32 }
fn gilm_forged() -> u64 @export { return GILM_FORGED }
fn gilm_cited() -> u64 @export { return GILM_CITED }
fn gilm_size() -> u64 @export { return GILM_N }

fn gilm_lookup(key: u32) -> i64 {
    let mut i : u64 = 0u64
    while i < GILM_N {
        if GILM_KEYS[i] == key { GILM_CITED = GILM_CITED + 1u64 ; return GILM_VALS[i] }
        i = i + 1u64
    }
    return -999i64
}
fn gilm_store(key: u32, val: i64) -> i32 {
    if GILM_N < 64u64 { GILM_KEYS[GILM_N] = key ; GILM_VALS[GILM_N] = val ; GILM_N = GILM_N + 1u64 }
    return 0i32
}

/* cite-before-forge for the round-function forge: a known kind is cited (no kernel work), else forged once. */
fn gilw_forge_cited(kind: u32) -> u32 @export {
    let key : u32 = 0x10000u32 | kind
    let hit : i64 = gilm_lookup(key)
    if hit != -999i64 { return hit as u32 }                /* CITED -- zero kernel work */
    GILM_FORGED = GILM_FORGED + 1u64
    let cost : u32 = gilw_forge(kind)                      /* FORGE -- the only kernel work */
    gilm_store(key, cost as i64)
    return cost
}
/* cite-before-forge for the (expensive ~500-SAT) rotation-duality family discovery. */
fn gild_rotdual_count_cited() -> u64 @export {
    let key : u32 = 0x20001u32
    let hit : i64 = gilm_lookup(key)
    if hit != -999i64 { return hit as u64 }
    GILM_FORGED = GILM_FORGED + 1u64
    let c : u64 = gild_rotdual_count()
    gilm_store(key, c as i64)
    return c
}

/* ============================================================================================================
 * THE ALGEBRA gild DISCOVERS: III finds the foundational laws of Boolean algebra over its own substrate, each
 * proven by the SAT judge for ALL inputs.  Not authored -- discovered + proven: De Morgan, absorption,
 * distributivity, the XOR involution, and the complete shift-mask family.  This is the weave filling out its
 * structural floor to the laws every algebra rests on.
 *
 * shift-mask family: (x>>k)<<k clears the low k bits == x & (all-ones<<k), for EVERY k -> the full 31 members. */
fn gild_shiftmask_ok(k: u64) -> u8 {
    let maskval : u64 = (0xFFFFFFFFu64 << k) & 0xFFFFFFFFu64
    bb_reset(GILD_W)
    let x : u32 = bb_var(0u32)
    return eqv_eq(bb_shl(bb_shr(x, k), k), bb_and(x, bb_const(maskval)))
}
fn gild_shiftmask_count() -> u64 @export {
    let mut count : u64 = 0u64
    let mut k : u64 = 1u64
    while k < GILD_W {
        if gild_shiftmask_ok(k) == 1u8 { count = count + 1u64 }
        k = k + 1u64
    }
    return count
}

/* De Morgan: ~(a&b)==~a|~b  AND  ~(a|b)==~a&~b.  1 iff III proves both. */
fn gild_demorgan() -> u8 @export {
    bb_reset(GILD_W)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    if eqv_eq(bb_not(bb_and(a, b)), bb_or(bb_not(a), bb_not(b))) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a2 : u32 = bb_var(0u32)
    let b2 : u32 = bb_var(1u32)
    return eqv_eq(bb_not(bb_or(a2, b2)), bb_and(bb_not(a2), bb_not(b2)))
}

/* absorption: a|(a&b)==a  AND  a&(a|b)==a. */
fn gild_absorb() -> u8 @export {
    bb_reset(GILD_W)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    if eqv_eq(bb_or(a, bb_and(a, b)), a) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a2 : u32 = bb_var(0u32)
    let b2 : u32 = bb_var(1u32)
    return eqv_eq(bb_and(a2, bb_or(a2, b2)), a2)
}

/* distributivity: a&(b|c)==(a&b)|(a&c)  AND  a|(b&c)==(a|b)&(a|c). */
fn gild_distrib() -> u8 @export {
    bb_reset(GILD_W)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    let c : u32 = bb_var(2u32)
    if eqv_eq(bb_and(a, bb_or(b, c)), bb_or(bb_and(a, b), bb_and(a, c))) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a2 : u32 = bb_var(0u32)
    let b2 : u32 = bb_var(1u32)
    let c2 : u32 = bb_var(2u32)
    return eqv_eq(bb_or(a2, bb_and(b2, c2)), bb_and(bb_or(a2, b2), bb_or(a2, c2)))
}

/* the XOR involution: (x^c)^c == x for all x -- xor-with-c is self-inverse (the cipher round's reversibility). */
fn gild_xor_involution(c: u64) -> u8 @export {
    bb_reset(GILD_W)
    let x  : u32 = bb_var(0u32)
    let cc : u32 = bb_const(c)
    return eqv_eq(bb_xor(bb_xor(x, cc), cc), x)
}

/* associativity: (a&b)&c==a&(b&c), (a|b)|c==a|(b|c), (a^b)^c==a^(b^c).  1 iff all three proven. */
fn gild_assoc() -> u8 @export {
    bb_reset(GILD_W)
    let a : u32 = bb_var(0u32)  let b : u32 = bb_var(1u32)  let c : u32 = bb_var(2u32)
    if eqv_eq(bb_and(bb_and(a, b), c), bb_and(a, bb_and(b, c))) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a1 : u32 = bb_var(0u32)  let b1 : u32 = bb_var(1u32)  let c1 : u32 = bb_var(2u32)
    if eqv_eq(bb_or(bb_or(a1, b1), c1), bb_or(a1, bb_or(b1, c1))) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a2 : u32 = bb_var(0u32)  let b2 : u32 = bb_var(1u32)  let c2 : u32 = bb_var(2u32)
    return eqv_eq(bb_xor(bb_xor(a2, b2), c2), bb_xor(a2, bb_xor(b2, c2)))
}

/* commutativity: a&b==b&a, a|b==b|a, a^b==b^a. */
fn gild_comm() -> u8 @export {
    bb_reset(GILD_W)
    let a : u32 = bb_var(0u32)  let b : u32 = bb_var(1u32)
    if eqv_eq(bb_and(a, b), bb_and(b, a)) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a1 : u32 = bb_var(0u32)  let b1 : u32 = bb_var(1u32)
    if eqv_eq(bb_or(a1, b1), bb_or(b1, a1)) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a2 : u32 = bb_var(0u32)  let b2 : u32 = bb_var(1u32)
    return eqv_eq(bb_xor(a2, b2), bb_xor(b2, a2))
}

/* complement: a&~a==0, a|~a==all-ones, ~~a==a (double negation). */
fn gild_complement() -> u8 @export {
    bb_reset(GILD_W)
    let a : u32 = bb_var(0u32)
    if eqv_eq(bb_and(a, bb_not(a)), bb_const(0u64)) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a1 : u32 = bb_var(0u32)
    if eqv_eq(bb_or(a1, bb_not(a1)), bb_const(0xFFFFFFFFu64)) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a2 : u32 = bb_var(0u32)
    return eqv_eq(bb_not(bb_not(a2)), a2)
}

/* identity + annihilator: a&0==0, a|0==a, a^0==a, a|all-ones==all-ones, a&all-ones==a. */
fn gild_identity() -> u8 @export {
    bb_reset(GILD_W)
    let a : u32 = bb_var(0u32)
    if eqv_eq(bb_and(a, bb_const(0u64)), bb_const(0u64)) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a1 : u32 = bb_var(0u32)
    if eqv_eq(bb_or(a1, bb_const(0u64)), a1) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a2 : u32 = bb_var(0u32)
    if eqv_eq(bb_xor(a2, bb_const(0u64)), a2) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a3 : u32 = bb_var(0u32)
    if eqv_eq(bb_or(a3, bb_const(0xFFFFFFFFu64)), bb_const(0xFFFFFFFFu64)) != 1u8 { return 0u8 }
    bb_reset(GILD_W)
    let a4 : u32 = bb_var(0u32)
    return eqv_eq(bb_and(a4, bb_const(0xFFFFFFFFu64)), a4)
}

/* THE CONSENSUS THEOREM (a non-trivial identity): (a&b)|(~a&c)|(b&c) == (a&b)|(~a&c) -- the consensus term b&c
 * is redundant.  A genuine theorem of Boolean algebra, discovered + proven, not a mere axiom. */
fn gild_consensus() -> u8 @export {
    bb_reset(GILD_W)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    let c : u32 = bb_var(2u32)
    let full : u32 = bb_or(bb_or(bb_and(a, b), bb_and(bb_not(a), c)), bb_and(b, c))
    let red  : u32 = bb_or(bb_and(a, b), bb_and(bb_not(a), c))
    return eqv_eq(full, red)
}

/* rotation composition: rotl(rotl(x,a),b) == rotl(x,(a+b) mod 32) -- the rotations form a cyclic group, a
 * structural fact the cipher schedule rests on.  Discovered + proven for the given (a,b). */
fn gild_rotcompose(a: u64, b: u64) -> u8 @export {
    let s : u64 = (a + b) & 31u64
    bb_reset(GILD_W)
    let x : u32 = bb_var(0u32)
    return eqv_eq(gild_rotl(gild_rotl(x, a), b), gild_rotl(x, s))
}

/* ============================================================================================================
 * AUTONOMOUS CONJECTURE: III generates its OWN candidate identities and discovers which hold -- no templates.
 *
 * Until here a human named each family and III proved it.  Here III itself enumerates a library of small 2-var
 * Boolean expressions and tests EVERY distinct pair for equivalence; the SAT judge proves or refutes each, and
 * the proven equivalences are identities III FOUND without being told them (e.g. nor==~a&~b and nand==~a|~b are
 * De Morgan; xnor == a&b|~a&~b; ~a^b==xnor).  Sound by construction: bb_equal never reports a false equivalence,
 * so every discovery is a true theorem.  This is invention proper -- conjecture, then proof. */
fn gild_expr(idx: u32, a: u32, b: u32) -> u32 {
    if idx == 0u32 { return a }
    if idx == 1u32 { return b }
    if idx == 2u32 { return bb_and(a, b) }
    if idx == 3u32 { return bb_or(a, b) }
    if idx == 4u32 { return bb_xor(a, b) }
    if idx == 5u32 { return bb_not(bb_and(a, b)) }                                  /* nand */
    if idx == 6u32 { return bb_not(bb_or(a, b)) }                                   /* nor  */
    if idx == 7u32 { return bb_not(bb_xor(a, b)) }                                  /* xnor */
    if idx == 8u32 { return bb_and(bb_not(a), bb_not(b)) }                          /* ~a&~b */
    if idx == 9u32 { return bb_or(bb_not(a), bb_not(b)) }                           /* ~a|~b */
    if idx == 10u32 { return bb_xor(bb_not(a), b) }                                 /* ~a^b  */
    if idx == 11u32 { return bb_and(a, bb_not(b)) }                                 /* a&~b  */
    if idx == 12u32 { return bb_or(a, bb_not(b)) }                                  /* a|~b  */
    if idx == 13u32 { return bb_or(bb_and(a, b), bb_and(bb_not(a), bb_not(b))) }    /* a&b | ~a&~b */
    return 0xFFFFFFFFu32
}
const GILC_N : u32 = 14u32

var GILC_KCALLS : u64 = 0u64       /* SAT judgements made (every distinct pair) */

/* test every distinct expression pair; return the count of PROVEN equivalences III discovered. */
fn gild_conjecture_count() -> u64 @export {
    GILC_KCALLS = 0u64
    let mut found : u64 = 0u64
    let mut i : u32 = 0u32
    while i < GILC_N {
        let mut j : u32 = i + 1u32
        while j < GILC_N {
            bb_reset(GILD_W)
            let a : u32 = bb_var(0u32)
            let b : u32 = bb_var(1u32)
            GILC_KCALLS = GILC_KCALLS + 1u64
            if eqv_eq(gild_expr(i, a, b), gild_expr(j, a, b)) == 1u8 { found = found + 1u64 }
            j = j + 1u32
        }
        i = i + 1u32
    }
    return found
}
fn gild_conjecture_kcalls() -> u64 @export { return GILC_KCALLS }

/* ============================================================================================================
 * AUTONOMOUS CONJECTURE AT 3 VARIABLES -- where the deep identities live.  III enumerates a 20-expression
 * library over (a,b,c) -- deliberately including STRUCTURALLY DIFFERENT forms of the same functions -- and
 * exhaustively judges all 190 distinct pairs.  Without being told, it discovers that the SHA round functions
 * have many equal forms (Ch = mux = OR-mux = optform = consensus; Maj = XOR-spec = carry-save = OR-form), that
 * the consensus term is redundant, and 3-var distributivity + De Morgan.  Conjecture, then proof; no template. */
fn gild3_expr(idx: u32, a: u32, b: u32, c: u32) -> u32 {
    if idx == 0u32 { return a }
    if idx == 1u32 { return b }
    if idx == 2u32 { return c }
    if idx == 3u32 { return bb_and(a, b) }
    if idx == 4u32 { return bb_or(a, b) }
    if idx == 5u32 { return bb_xor(a, b) }
    if idx == 6u32 { return bb_xor(bb_and(a, b), bb_and(bb_not(a), c)) }                          /* Ch spec */
    if idx == 7u32 { return bb_or(bb_and(a, b), bb_and(bb_not(a), c)) }                           /* Ch OR-mux */
    if idx == 8u32 { return bb_xor(c, bb_and(a, bb_xor(b, c))) }                                  /* Ch optform */
    if idx == 9u32 { return bb_xor(bb_xor(bb_and(a, b), bb_and(a, c)), bb_and(b, c)) }            /* Maj XOR-spec */
    if idx == 10u32 { return bb_xor(bb_and(a, b), bb_and(c, bb_xor(a, b))) }                      /* Maj carry-save */
    if idx == 11u32 { return bb_or(bb_or(bb_and(a, b), bb_and(a, c)), bb_and(b, c)) }             /* Maj OR-form */
    if idx == 12u32 { return bb_or(bb_or(bb_and(a, b), bb_and(bb_not(a), c)), bb_and(b, c)) }     /* consensus (==Ch) */
    if idx == 13u32 { return bb_and(a, bb_or(b, c)) }                                             /* a&(b|c) */
    if idx == 14u32 { return bb_or(bb_and(a, b), bb_and(a, c)) }                                  /* (a&b)|(a&c) */
    if idx == 15u32 { return bb_or(a, bb_and(b, c)) }                                             /* a|(b&c) */
    if idx == 16u32 { return bb_and(bb_or(a, b), bb_or(a, c)) }                                   /* (a|b)&(a|c) */
    if idx == 17u32 { return bb_xor(bb_xor(a, b), c) }                                            /* parity a^b^c */
    if idx == 18u32 { return bb_not(bb_and(bb_and(a, b), c)) }                                    /* ~(a&b&c) */
    if idx == 19u32 { return bb_or(bb_or(bb_not(a), bb_not(b)), bb_not(c)) }                      /* ~a|~b|~c */
    return 0xFFFFFFFFu32
}
const GILC3_N : u32 = 20u32
var GILC3_KCALLS : u64 = 0u64
var GILC3_DI : [u32; 64]        /* discovered pairs: left index */
var GILC3_DJ : [u32; 64]        /* discovered pairs: right index */
var GILC3_DN : u64 = 0u64       /* count of discovered pairs */

fn gild3_conjecture_count() -> u64 @export {
    GILC3_KCALLS = 0u64
    GILC3_DN = 0u64
    let mut i : u32 = 0u32
    while i < GILC3_N {
        let mut j : u32 = i + 1u32
        while j < GILC3_N {
            bb_reset(GILD_W)
            let a : u32 = bb_var(0u32)
            let b : u32 = bb_var(1u32)
            let c : u32 = bb_var(2u32)
            GILC3_KCALLS = GILC3_KCALLS + 1u64
            if eqv_eq(gild3_expr(i, a, b, c), gild3_expr(j, a, b, c)) == 1u8 {
                if GILC3_DN < 64u64 { GILC3_DI[GILC3_DN] = i ; GILC3_DJ[GILC3_DN] = j ; GILC3_DN = GILC3_DN + 1u64 }
            }
            j = j + 1u32
        }
        i = i + 1u32
    }
    return GILC3_DN
}
fn gild3_conjecture_kcalls() -> u64 @export { return GILC3_KCALLS }
/* expose the discovered pairs so the Rosetta layer can render + accumulate them into the commons. */
fn gild3_disc_count() -> u64 @export { return GILC3_DN }
fn gild3_disc_i(k: u64) -> u32 @export { if k >= GILC3_DN { return 0xFFu32 }  return GILC3_DI[k] }
fn gild3_disc_j(k: u64) -> u32 @export { if k >= GILC3_DN { return 0xFFu32 }  return GILC3_DJ[k] }

/* ============================================================================================================
 * THE WEAVE CENSUS -- III knows the full extent of the mathematics it has discovered + proven over its weave.
 *
 * A single number that IS the wealth of the self-discovered weave: every proven law across every family,
 * re-derived live and summed.  This is III's self-knowledge of its own invention -- not a stored count, a
 * RE-PROVEN one, so the census cannot drift from the truth.  82 when the weave is whole. */
fn weave_census() -> u64 @export {
    let mut total : u64 = 0u64
    total = total + weave_fill()                                       /* 8: Ch, Maj, 3 crossover, 3 collapse */
    total = total + gild_rotdual_count()                              /* 31: the rotation-duality family */
    if gild_selfdual_k() == 16i64 { total = total + 1u64 }            /* 1: the self-coincidence */
    if gild_selflaw_rhs(0u32) >= 0i32 { total = total + 1u64 }        /* 4: the self-laws */
    if gild_selflaw_rhs(1u32) >= 0i32 { total = total + 1u64 }
    if gild_selflaw_rhs(2u32) >= 0i32 { total = total + 1u64 }
    if gild_selflaw_rhs(3u32) >= 0i32 { total = total + 1u64 }
    total = total + gild_shiftmask_count()                            /* 31: the shift-mask family */
    if gild_demorgan() == 1u8 { total = total + 2u64 }               /* 2: De Morgan */
    if gild_absorb() == 1u8 { total = total + 2u64 }                /* 2: absorption */
    if gild_distrib() == 1u8 { total = total + 2u64 }              /* 2: distributivity */
    if gild_xor_involution(0xDEADBEEFu64) == 1u8 { total = total + 1u64 }  /* 1: the XOR involution */
    if gild_assoc() == 1u8 { total = total + 3u64 }                  /* 3: associativity (and/or/xor) */
    if gild_comm() == 1u8 { total = total + 3u64 }                  /* 3: commutativity (and/or/xor) */
    if gild_complement() == 1u8 { total = total + 3u64 }            /* 3: a&~a=0, a|~a=1s, ~~a=a */
    if gild_identity() == 1u8 { total = total + 5u64 }              /* 5: identity + annihilator */
    if gild_consensus() == 1u8 { total = total + 1u64 }            /* 1: the consensus theorem */
    if gild_rotcompose(7u64, 12u64) == 1u8 { total = total + 1u64 } /* 1: rotation-group composition */
    return total
}

/* ============================================================================================================
 * THE RATCHET ACROSS TIME: the lemma library (gilm) PERSISTS, so a future run inherits the solved targets and
 * skips re-forging them.  Image = [magic u32][n u32]([key u32][val u64])*, with an appended cad seal; reload
 * re-checks the seal (tamper -> refused) and restores keys+vals.  The ratchet now spans runs -- search shrinks
 * across time, not just within one process. */
const GILM_MAGIC  : u32 = 0x4D4C4947u32        /* 'GILM' LE */
const GILM_IMGCAP : u64 = 2048u64
var GILM_IMG  : [u8; 2048]
var GILM_SEAL : [u8; 32]

fn _gilm_put_u32le(off: u64, v: u32) -> u64 {
    GILM_IMG[off] = (v & 0xFFu32) as u8
    GILM_IMG[off + 1u64] = ((v >> 8u32) & 0xFFu32) as u8
    GILM_IMG[off + 2u64] = ((v >> 16u32) & 0xFFu32) as u8
    GILM_IMG[off + 3u64] = ((v >> 24u32) & 0xFFu32) as u8
    return off + 4u64
}
fn _gilm_get_u32le(off: u64) -> u32 {
    return (GILM_IMG[off] as u32) | ((GILM_IMG[off + 1u64] as u32) << 8u32) | ((GILM_IMG[off + 2u64] as u32) << 16u32) | ((GILM_IMG[off + 3u64] as u32) << 24u32)
}
fn _gilm_put_u64le(off: u64, v: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < 8u64 { GILM_IMG[off + i] = ((v >> (i * 8u64)) & 0xFFu64) as u8 ; i = i + 1u64 }
    return off + 8u64
}
fn _gilm_get_u64le(off: u64) -> u64 {
    let mut v : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 8u64 { v = v | ((GILM_IMG[off + i] as u64) << (i * 8u64)) ; i = i + 1u64 }
    return v
}

fn gilm_persist(cap: u64, path: u64) -> i32 @export {
    let mut off : u64 = 0u64
    off = _gilm_put_u32le(off, GILM_MAGIC)
    off = _gilm_put_u32le(off, GILM_N as u32)
    let mut i : u64 = 0u64
    while i < GILM_N {
        off = _gilm_put_u32le(off, GILM_KEYS[i])
        off = _gilm_put_u64le(off, GILM_VALS[i] as u64)
        i = i + 1u64
    }
    cad_oneshot(0u32, (&GILM_IMG as u64) as *u8, off, ((&GILM_IMG as u64) + off) as *u8)   /* append seal */
    let total : u64 = off + 32u64
    let h : u64 = fs_open(cap, path, 2u32)
    if h == 0u64 { return -1i32 }
    let w : u64 = fs_write(h, (&GILM_IMG as u64), total)
    fs_close(h)
    if w != total { return -2i32 }
    return 0i32
}

fn gilm_reload(cap: u64, path: u64) -> i32 @export {
    let h : u64 = fs_open(cap, path, 1u32)
    if h == 0u64 { return -3i32 }
    let nread : u64 = fs_read(h, (&GILM_IMG as u64), GILM_IMGCAP)
    fs_close(h)
    if nread < 40u64 { return -2i32 }
    let bodylen : u64 = nread - 32u64
    cad_oneshot(0u32, (&GILM_IMG as u64) as *u8, bodylen, (&GILM_SEAL as u64) as *u8)
    let mut k : u64 = 0u64
    while k < 32u64 { if GILM_SEAL[k] != GILM_IMG[bodylen + k] { return -1i32 }  k = k + 1u64 }   /* tamper */
    if _gilm_get_u32le(0u64) != GILM_MAGIC { return -2i32 }
    let n : u32 = _gilm_get_u32le(4u64)
    if (n as u64) > 64u64 { return -2i32 }
    GILM_N = 0u64
    let mut off : u64 = 8u64
    let mut i : u32 = 0u32
    while i < n {
        let key : u32 = _gilm_get_u32le(off)
        off = off + 4u64
        let val : u64 = _gilm_get_u64le(off)
        off = off + 8u64
        if GILM_N < 64u64 { GILM_KEYS[GILM_N] = key ; GILM_VALS[GILM_N] = val as i64 ; GILM_N = GILM_N + 1u64 }
        i = i + 1u32
    }
    return GILM_N as i32
}
