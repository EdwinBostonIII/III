/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\kleene_fixpoint.iii
 * MODEL-TIER (III-PERFECTION-LEDGER label): this file is the didactic verified MODEL of the method;
 * III's REAL optimizer is XII (xii_canonicalise) + cg_r3 -- the teaching model, not the live pass.
 *
 * III STDLIB - numera::kleene_fixpoint  --  RIPPLE TO CONVERGENCE (the least-fixpoint engine).
 *
 * The engine that turns numera::interval_lattice into a whole-program analysis: a change RIPPLES through a
 * transfer function and re-applies until nothing moves -- Kleene's ascending iteration to the least fixpoint.
 * f^0(bottom) <= f^1(bottom) <= ... and, because the transfer is MONOTONE on a BOUNDED lattice, the chain
 * stabilizes at the least fixpoint; that fixpoint is the soundest static description of a loop's reachable
 * values.  Here the analysed program is `i = 0; while i < 10: i = i + 1`, whose reachable-value set is
 * exactly {0..10}; the iteration ripples [0,0] up to the fixpoint [0,10] and then holds steady.
 *
 * Verified (kleene_fixpoint_kat): the iteration CONVERGES (a stable state is reached within the bound); the
 * fixpoint is [0,10]; it is genuinely STABLE (re-applying the transfer changes nothing); the chain is
 * MONOTONE (each state contains the previous); and the fixpoint SOUNDLY contains every concrete value the
 * loop variable takes.  NIH; composes interval_lattice.
 *
 * Public API:
 *   kf_step(lo,hi) ; kf_fixpoint() -> u32 (1=converged) ; kf_lo() -> u32 ; kf_hi() -> u32 ; kf_iters() -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_kleene_fixpoint

extern @abi(c-msvc-x64) fn il_join(l1: u32, h1: u32, l2: u32, h2: u32) -> i32 from "interval_lattice.iii"
extern @abi(c-msvc-x64) fn il_meet(l1: u32, h1: u32, l2: u32, h2: u32) -> i32 from "interval_lattice.iii"
extern @abi(c-msvc-x64) fn il_add(l1: u32, h1: u32, l2: u32, h2: u32) -> i32 from "interval_lattice.iii"
extern @abi(c-msvc-x64) fn il_lo() -> u32 from "interval_lattice.iii"
extern @abi(c-msvc-x64) fn il_hi() -> u32 from "interval_lattice.iii"
/* the WIDENING operator (numera::widening) -- nabla: sends a growing bound to +inf, forcing convergence on
 * UNBOUNDED domains the bounded Kleene join cannot reach. */
extern @abi(c-msvc-x64) fn wd_widen(l1: u32, h1: u32, l2: u32, h2: u32) -> i32 from "widening.iii"
extern @abi(c-msvc-x64) fn wd_lo() -> u32 from "widening.iii"
extern @abi(c-msvc-x64) fn wd_hi() -> u32 from "widening.iii"

const KF_BOUND : u32 = 10u32       /* the loop guard: while i < 10 */
const KF_CAP   : u32 = 32u32       /* iteration bound (convergence must occur within this) */
const KF_WD_INF : u32 = 0xFFFFFFFFu32   /* +infinity for the widened (unbounded) strategy */

var KF_LO    : [u32; 1]
var KF_HI    : [u32; 1]
var KF_ITERS : [u32; 1]

/* the monotone transfer for `if i < 10: i = i+1`, joined back in: f(X) = X join ((X meet [0,9]) + 1).
 * result lands in KF_LO/KF_HI. */
fn kf_step(lo: u32, hi: u32) -> i32 @export {
    il_meet(lo, hi, 0u32, KF_BOUND - 1u32)       /* values that still satisfy the guard i<10 */
    let ml : u32 = il_lo() ; let mh : u32 = il_hi()
    il_add(ml, mh, 1u32, 1u32)                    /* they advance by 1 */
    let al : u32 = il_lo() ; let ah : u32 = il_hi()
    il_join(lo, hi, al, ah)                        /* join the advanced values back in */
    KF_LO[0u64] = il_lo() ; KF_HI[0u64] = il_hi()
    return 0i32
}

/* Kleene ascending iteration from bottom [0,0] to the least fixpoint. */
fn kf_fixpoint() -> u32 @export {
    KF_LO[0u64] = 0u32 ; KF_HI[0u64] = 0u32        /* the entry state: i = 0 */
    let mut iters : u32 = 0u32
    let mut stable : u32 = 0u32
    let mut go : u32 = 1u32
    while go == 1u32 {
        let plo : u32 = KF_LO[0u64]
        let phi : u32 = KF_HI[0u64]
        kf_step(plo, phi)
        iters = iters + 1u32
        if KF_LO[0u64] == plo {
            if KF_HI[0u64] == phi { stable = 1u32 ; go = 0u32 }   /* reached a fixpoint */
        }
        if iters >= KF_CAP { go = 0u32 }           /* bound guard (never binds for a bounded lattice) */
    }
    KF_ITERS[0u64] = iters
    return stable                                  /* 1 iff a true fixpoint was reached (not the cap) */
}

fn kf_lo() -> u32 @export { return KF_LO[0u64] }
fn kf_hi() -> u32 @export { return KF_HI[0u64] }
fn kf_iters() -> u32 @export { return KF_ITERS[0u64] }

/* ---- THE WIDENED STRATEGY: ONE engine for BOTH bounded lattices (kf_fixpoint, above) and UNBOUNDED domains.
 * For `i = 0; while true: i = i+1` the interval [0,hi] grows without bound, so the plain Kleene join never
 * converges (kf_fixpoint would hit KF_CAP).  Replacing the join with the WIDENING operator nabla (numera::
 * widening) sends the unstable upper bound to +inf in one step, so the iteration reaches the unbounded least
 * fixpoint [0,+inf] in a handful of steps -- Cousot's Kleene + nabla pairing, now a single organ. */
fn kf_fixpoint_widened() -> u32 @export {
    KF_LO[0u64] = 0u32 ; KF_HI[0u64] = 0u32            /* entry: i = 0 */
    let mut iters : u32 = 0u32
    let mut stable : u32 = 0u32
    let mut go : u32 = 1u32
    while go == 1u32 {
        let plo : u32 = KF_LO[0u64]
        let phi : u32 = KF_HI[0u64]
        let mut nhi : u32 = phi + 1u32                 /* the unbounded transfer i++ advances the upper */
        if phi >= KF_WD_INF { nhi = KF_WD_INF }        /* saturating succ (avoid wrap at the top) */
        wd_widen(plo, phi, plo, nhi)                   /* x_{k+1} = x_k nabla f(x_k): a growing upper -> +inf */
        KF_LO[0u64] = wd_lo()
        KF_HI[0u64] = wd_hi()
        iters = iters + 1u32
        if KF_LO[0u64] == plo {
            if KF_HI[0u64] == phi { stable = 1u32 ; go = 0u32 }   /* reached the widened fixpoint */
        }
        if iters >= KF_CAP { go = 0u32 }
    }
    KF_ITERS[0u64] = iters
    return stable
}

/* =====================================================================================
 * kf_fixpoint_widened_kat -- 99 = the unified engine handles the UNBOUNDED domain correctly:
 *   (a) the widened iteration reaches the unbounded least fixpoint [0,+inf];
 *   (c) it is a TRUE fixpoint (stable), reached fast (<= 4 iters) -- not the cap;
 *   (b) SOUNDNESS: the widened result OVER-APPROXIMATES the bounded fixpoint [0,10] (contains it), and the
 *       widening is GENUINE (the bounded upper 10 is strictly below +inf -- no vacuous "already infinite").
 * ===================================================================================== */
fn kf_fixpoint_widened_kat() -> u64 @export {
    let stable : u32 = kf_fixpoint_widened()
    if stable != 1u32 { return 1u64 }                  /* (c) a true fixpoint, not the cap */
    if kf_lo() != 0u32 { return 2u64 }                 /* (a) reached [0,+inf] */
    if kf_hi() != KF_WD_INF { return 3u64 }
    if kf_iters() > 4u32 { return 4u64 }               /* fast convergence via widening */
    let whi : u32 = kf_hi()                            /* +inf */
    /* (b) soundness: re-run the BOUNDED path and assert [0,10] subset of [0,+inf] */
    kf_fixpoint()
    if kf_lo() != 0u32 { return 5u64 }                 /* bounded lo is 0 */
    if whi < kf_hi() { return 6u64 }                   /* widened upper (+inf) >= bounded upper (10) -> contains */
    if kf_hi() >= whi { return 7u64 }                  /* GENUINE widening: bounded 10 strictly < +inf */
    return 99u64
}

/* =====================================================================================
 * kleene_fixpoint_kat -- 99 = the least-fixpoint engine is correct, self-checked:
 *   (1) the iteration converges to the fixpoint [0,10];
 *   (2) the fixpoint is STABLE: kf_step([0,10]) = [0,10];
 *   (3) it converges within the bound (iters <= 12) -- the bounded lattice guarantees termination;
 *   (4) the fixpoint SOUNDLY contains every concrete value of `i = 0; while i<10: i=i+1` (0..10).
 * ===================================================================================== */
fn kleene_fixpoint_kat() -> u64 @export {
    /* (1) converge to [0,10] */
    if kf_fixpoint() != 1u32 { return 1u64 }
    if kf_lo() != 0u32 { return 2u64 }
    if kf_hi() != 10u32 { return 3u64 }

    /* (2) stability */
    kf_step(0u32, 10u32)
    if kf_lo() != 0u32 { return 4u64 }
    if kf_hi() != 10u32 { return 5u64 }

    /* (3) bounded convergence */
    if kf_iters() > 12u32 { return 6u64 }
    if kf_iters() == 0u32 { return 7u64 }

    /* (4) soundness: every concrete i lies in the fixpoint [0,10] */
    let mut i : u32 = 0u32
    let mut guard : u32 = 0u32
    while guard < 64u32 {                          /* run the concrete loop, bounded for safety */
        if i > kf_hi() { return 9u64 }             /* every concrete i is within the fixpoint upper bound 10 */
        if i >= 10u32 { guard = 64u32 }            /* the loop exits at i==10 */
        if guard < 64u32 { i = i + 1u32 ; guard = guard + 1u32 }
    }
    if i != 10u32 { return 10u64 }                 /* the loop really ends at i=10 */

    return 99u64
}
