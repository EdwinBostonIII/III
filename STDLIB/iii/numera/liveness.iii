/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\liveness.iii
 *
 * III STDLIB - numera::liveness  --  BACKWARD DATAFLOW LIVENESS (verified).
 *
 * The other direction of the dataflow framework, and the analysis numera::reg_alloc consumes: a variable is
 * LIVE at a program point if it will be used before being redefined.  Liveness flows BACKWARD -- a block's
 * live-out is the union of its successors' live-in, and live_in = use union (live_out minus def).  Iterating
 * to a fixpoint computes exactly the variables that must be kept in a register across each block, the input
 * to register allocation; it complements the forward analyses (numera::sccp, numera::taint_analysis,
 * numera::kleene_fixpoint) to span both flow directions.
 *
 * CFG b0->b1->b2->b3 over variables x,y,z: b0 defs x; b1 uses x defs y; b2 uses y defs z; b3 uses x and z.
 * So x is live from the end of b0 all the way to b3, y is live across b1, z across b2.
 *
 * Verified (liveness_kat): x is live at the exit of b0 (computed early, used late) while y is not; live-in of
 * b2 is {x,y} and live-out is {x,z}; a variable dies at its last use; the fixpoint is stable.  NIH/self-contained.
 *
 * Public API:
 *   lv_setup() ; lv_solve() ; lv_in(b) -> u32 ; lv_out(b) -> u32 ; lv_live_at_out(b,var) -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_liveness

const LV_N    : u32 = 4u32
const LV_FULL : u32 = 7u32         /* three variables x,y,z = bits 0,1,2 */

var LV_USE  : [u32; 4]             /* variables used in each block (bitset) */
var LV_DEF  : [u32; 4]             /* variables defined in each block */
var LV_SUCC : [u32; 4]            /* successor blocks (bitset) */
var LV_IN   : [u32; 4]
var LV_OUT  : [u32; 4]

fn lv_setup() -> i32 @export {
    /* x=bit0, y=bit1, z=bit2 */
    LV_USE[0u64]=0u32      ; LV_DEF[0u64]=1u32 ; LV_SUCC[0u64]=1u32 << 1u32   /* b0: def x ; -> b1 */
    LV_USE[1u64]=1u32      ; LV_DEF[1u64]=2u32 ; LV_SUCC[1u64]=1u32 << 2u32   /* b1: use x def y ; -> b2 */
    LV_USE[2u64]=2u32      ; LV_DEF[2u64]=4u32 ; LV_SUCC[2u64]=1u32 << 3u32   /* b2: use y def z ; -> b3 */
    LV_USE[3u64]=1u32|4u32 ; LV_DEF[3u64]=0u32 ; LV_SUCC[3u64]=0u32           /* b3: use x,z ; exit */
    return 0i32
}

/* backward dataflow to a fixpoint (N passes converge for this CFG). */
fn lv_solve() -> i32 @export {
    let mut i : u32 = 0u32
    while i < LV_N { LV_IN[i as u64] = 0u32 ; LV_OUT[i as u64] = 0u32 ; i = i + 1u32 }
    let mut pass : u32 = 0u32
    while pass < LV_N {
        let mut b : u32 = 0u32
        while b < LV_N {
            /* live_out = union of successors' live_in */
            let mut out : u32 = 0u32
            let mut s : u32 = 0u32
            while s < LV_N {
                if ((LV_SUCC[b as u64] >> s) & 1u32) == 1u32 { out = out | LV_IN[s as u64] }
                s = s + 1u32
            }
            LV_OUT[b as u64] = out
            /* live_in = use union (live_out minus def) */
            LV_IN[b as u64] = LV_USE[b as u64] | (out & (LV_FULL ^ LV_DEF[b as u64]))
            b = b + 1u32
        }
        pass = pass + 1u32
    }
    return 0i32
}

fn lv_in(b: u32) -> u32 @export { return LV_IN[b as u64] }
fn lv_out(b: u32) -> u32 @export { return LV_OUT[b as u64] }
fn lv_live_at_out(b: u32, vbit: u32) -> u32 @export {
    if ((LV_OUT[b as u64] >> vbit) & 1u32) == 1u32 { return 1u32 }
    return 0u32
}

/* =====================================================================================
 * liveness_kat -- 99 = backward liveness is correct, self-checked:
 *   (1) x (bit 0) is live at the exit of b0 -- computed early, used late; y (bit 1) is NOT;
 *   (2) live-in of b2 is {x,y} (bits 0,1 = 3); live-out of b2 is {x,z} (bits 0,2 = 5);
 *   (3) z (bit 2) is not live before its definition (not in live-out of b1);
 *   (4) re-solving is stable (idempotent fixpoint).
 * ===================================================================================== */
fn liveness_kat() -> u64 @export {
    lv_setup()
    lv_solve()

    /* (1) x live across b0, y not */
    if lv_live_at_out(0u32, 0u32) != 1u32 { return 1u64 }
    if lv_live_at_out(0u32, 1u32) != 0u32 { return 2u64 }

    /* (2) block-2 live sets */
    if lv_in(2u32) != 3u32 { return 3u64 }         /* {x,y} */
    if lv_out(2u32) != 5u32 { return 4u64 }        /* {x,z} */

    /* (3) z is not live before its def (b1's live-out) */
    if lv_live_at_out(1u32, 2u32) != 0u32 { return 5u64 }
    if lv_live_at_out(1u32, 0u32) != 1u32 { return 6u64 }   /* but x is */

    /* (4) idempotent fixpoint */
    lv_solve()
    if lv_in(2u32) != 3u32 { return 7u64 }
    if lv_out(2u32) != 5u32 { return 8u64 }

    return 99u64
}
