/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\loop_bounds_prover.iii
 * MODEL-TIER (III-PERFECTION-LEDGER label): this file is the didactic verified MODEL of the method;
 * III's REAL optimizer is XII (xii_canonicalise) + cg_r3 -- the teaching model, not the live pass.
 *
 * III STDLIB - numera::loop_bounds_prover  --  MEMORY SAFETY OVER A FAMILY OF TRIP COUNTS (composition).
 *
 * Out-of-bounds access is the #1 source of security bugs; this proves a whole FAMILY of loops free of it.
 * It consumes numera::affine_check (which decides in-bounds for one loop) and lifts the result over every
 * trip count n in [0,N] at once.  The key is MONOTONICITY: for a non-negative stride the highest address an
 * affine access A[a*i+b] touches grows with the iteration count, so the worst case is the largest trip count
 * -- a SINGLE in-bounds check at n=N decides safety for the entire family.  The prover verifies that
 * monotonicity holds (the one check agrees with the exhaustive family) rather than assuming it.
 *
 * Verified (loop_bounds_prover_kat): a safe family (A[2*i+1], all n<=12, size 32) is proven safe and the
 * exhaustive family agrees; an unsafe family (A[3*i+2], n<=8, size 16) contains an out-of-bounds trip count
 * and is rejected; and for several parameterizations the single n=N check EQUALS the whole-family verdict
 * (monotonicity), so one abstract check certifies infinitely-bounded many loops.  NIH; composes affine_check.
 *
 * Public API:
 *   lbp_family_safe(a,b,cap_n,size) -> u32 ; lbp_one_check(a,b,cap_n,size) -> u32 ;
 *   lbp_monotone_complete(a,b,cap_n,size) -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_loop_bounds_prover

extern @abi(c-msvc-x64) fn ac_in_bounds(a: u32, b: u32, n: u32, size: u32) -> u32 from "affine_check.iii"

/* the family is safe iff EVERY trip count n in [0,cap_n] keeps the affine access in bounds. */
fn lbp_family_safe(a: u32, b: u32, cap_n: u32, size: u32) -> u32 @export {
    let mut n : u32 = 0u32
    while n <= cap_n {
        if ac_in_bounds(a, b, n, size) == 0u32 { return 0u32 }
        n = n + 1u32
    }
    return 1u32
}

/* the single worst-case check: in-bounds at the largest trip count (the monotone worst case). */
fn lbp_one_check(a: u32, b: u32, cap_n: u32, size: u32) -> u32 @export {
    return ac_in_bounds(a, b, cap_n, size)
}

/* monotonicity: the single n=N check is EQUIVALENT to checking the whole family. */
fn lbp_monotone_complete(a: u32, b: u32, cap_n: u32, size: u32) -> u32 @export {
    if lbp_one_check(a, b, cap_n, size) == lbp_family_safe(a, b, cap_n, size) { return 1u32 }
    return 0u32
}

/* =====================================================================================
 * loop_bounds_prover_kat -- 99 = family-wide memory-safety proof is correct, self-checked:
 *   (1) a safe family A[2*i+1], n<=12, size 32 is proven safe and the exhaustive family agrees;
 *   (2) an unsafe family A[3*i+2], n<=8, size 16 contains an out-of-bounds trip count and is rejected;
 *   (3) MONOTONICITY: for several parameterizations the single n=N check equals the whole-family verdict,
 *       so one abstract check certifies the entire family;
 *   (4) the one-check verdict matches the family verdict for both the safe and unsafe cases.
 * ===================================================================================== */
fn loop_bounds_prover_kat() -> u64 @export {
    /* (1) safe family */
    if lbp_family_safe(2u32, 1u32, 12u32, 32u32) != 1u32 { return 1u64 }   /* max access 2*11+1=23 < 32 */
    if lbp_one_check(2u32, 1u32, 12u32, 32u32) != 1u32 { return 2u64 }

    /* (2) unsafe family */
    if lbp_family_safe(3u32, 2u32, 8u32, 16u32) != 0u32 { return 3u64 }    /* some n overflows 16 */
    if lbp_one_check(3u32, 2u32, 8u32, 16u32) != 0u32 { return 4u64 }

    /* (3) monotonicity holds across several parameterizations -> one check certifies the family */
    if lbp_monotone_complete(2u32, 1u32, 12u32, 32u32) != 1u32 { return 5u64 }
    if lbp_monotone_complete(3u32, 2u32, 8u32, 16u32) != 1u32 { return 6u64 }
    if lbp_monotone_complete(1u32, 0u32, 31u32, 32u32) != 1u32 { return 7u64 }   /* unit stride, exactly fits */
    if lbp_monotone_complete(5u32, 3u32, 10u32, 64u32) != 1u32 { return 8u64 }
    if lbp_monotone_complete(4u32, 0u32, 20u32, 50u32) != 1u32 { return 9u64 }

    /* (4) the one-check verdict equals the family verdict (safe and unsafe) */
    if lbp_one_check(2u32, 1u32, 12u32, 32u32) != lbp_family_safe(2u32, 1u32, 12u32, 32u32) { return 10u64 }
    if lbp_one_check(3u32, 2u32, 8u32, 16u32) != lbp_family_safe(3u32, 2u32, 8u32, 16u32) { return 11u64 }

    return 99u64
}
