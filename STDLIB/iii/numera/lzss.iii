/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\lzss.iii
 *
 * III STDLIB - numera::lzss
 *
 * Verified LZSS lossless compression (the LZ77 family with explicit literal/match flags). A byte
 * stream is compressed into groups of 8 tokens preceded by a control byte (one flag bit per token);
 * a literal is 1 byte, a back-reference match is 2 bytes (12-bit offset up to 4095 + 4-bit length,
 * MIN_MATCH..MIN_MATCH+15). Decompression replays the tokens, copying matches byte-by-byte so
 * overlapping runs (offset < length) reconstruct correctly.
 *
 * The verified property is ROUNDTRIP IDENTITY: decompress(compress(x)) == x for ALL x (the only
 * thing a lossless codec must guarantee); compression RATIO is a bonus the KAT also checks on
 * repetitive input. NIH / self-contained: pure byte arithmetic, no field, no externs.
 *
 * Buffers are caller-provided (u64 bases, *u8). The KAT uses module-global buffers.
 *
 * Public API:
 *   lzss_compress(in_ptr, in_len, out_ptr, out_cap) -> i32   compressed length, or -1 if out_cap hit
 *   lzss_decompress(in_ptr, in_len, out_ptr, out_cap) -> i32 decompressed length, or -1 on overflow
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99 (pure; no allocation).
 */
module numera_lzss

const LZSS_MIN_MATCH : u32 = 3u32
const LZSS_MAX_MATCH : u32 = 18u32      /* MIN_MATCH + 15 (4-bit length field) */
const LZSS_MAX_OFFS  : u32 = 4095u32    /* 12-bit offset */

/* longest match of in[pos..] within the window [win, pos); writes length to LZSS_BL, offset to
 * LZSS_BO (module globals -- a single return value in this toolchain). */
var LZSS_BL : [u32; 1]
var LZSS_BO : [u32; 1]
fn lzss_find(ip: u64, win: u32, pos: u32, in_len: u32) -> i32 {
    let p : *u8 = ip as *u8
    let mut best_len : u32 = 0u32
    let mut best_off : u32 = 0u32
    let mut j : u32 = win
    while j < pos {
        let mut l : u32 = 0u32
        let mut cont : u32 = 1u32
        while cont == 1u32 {
            if l >= LZSS_MAX_MATCH { cont = 0u32 }
            else {
                if (pos + l) >= in_len { cont = 0u32 }
                else {
                    if p[(j + l) as u64] != p[(pos + l) as u64] { cont = 0u32 }
                    else { l = l + 1u32 }
                }
            }
        }
        if l > best_len { best_len = l ; best_off = pos - j }
        j = j + 1u32
    }
    LZSS_BL[0u32] = best_len
    LZSS_BO[0u32] = best_off
    return 0i32
}

fn lzss_compress(in_ptr: u64, in_len: u32, out_ptr: u64, out_cap: u32) -> i32 @export {
    let ip : *u8 = in_ptr as *u8
    let op : *u8 = out_ptr as *u8
    let mut pos : u32 = 0u32
    let mut outp : u32 = 0u32
    while pos < in_len {
        if outp >= out_cap { return -1i32 }
        let ctrl_idx : u32 = outp
        outp = outp + 1u32
        let mut ctrl : u32 = 0u32
        let mut t : u32 = 0u32
        while t < 8u32 {
            if pos < in_len {
                let mut win : u32 = 0u32
                if pos > LZSS_MAX_OFFS { win = pos - LZSS_MAX_OFFS }
                lzss_find(in_ptr, win, pos, in_len)
                let best_len : u32 = LZSS_BL[0u32]
                let best_off : u32 = LZSS_BO[0u32]
                if best_len >= LZSS_MIN_MATCH {
                    ctrl = ctrl | (1u32 << t)
                    if (outp + 2u32) > out_cap { return -1i32 }
                    op[outp as u64] = (best_off & 0xFFu32) as u8
                    op[(outp + 1u32) as u64] = (((best_off >> 8u32) << 4u32) | ((best_len - LZSS_MIN_MATCH) & 0x0Fu32)) as u8
                    outp = outp + 2u32
                    pos = pos + best_len
                } else {
                    if outp >= out_cap { return -1i32 }
                    op[outp as u64] = ip[pos as u64]
                    outp = outp + 1u32
                    pos = pos + 1u32
                }
            }
            t = t + 1u32
        }
        op[ctrl_idx as u64] = ctrl as u8
    }
    return outp as i32
}

fn lzss_decompress(in_ptr: u64, in_len: u32, out_ptr: u64, out_cap: u32) -> i32 @export {
    let ip : *u8 = in_ptr as *u8
    let op : *u8 = out_ptr as *u8
    let mut inp : u32 = 0u32
    let mut outp : u32 = 0u32
    while inp < in_len {
        let ctrl : u32 = ip[inp as u64] as u32
        inp = inp + 1u32
        let mut t : u32 = 0u32
        while t < 8u32 {
            if inp < in_len {
                if ((ctrl >> t) & 1u32) == 1u32 {
                    let b0 : u32 = ip[inp as u64] as u32
                    let b1 : u32 = ip[(inp + 1u32) as u64] as u32
                    inp = inp + 2u32
                    let off : u32 = b0 | ((b1 >> 4u32) << 8u32)
                    let mlen : u32 = (b1 & 0x0Fu32) + LZSS_MIN_MATCH
                    if off > outp { return -1i32 }
                    let src : u32 = outp - off
                    let mut c : u32 = 0u32
                    while c < mlen {
                        if outp >= out_cap { return -1i32 }
                        op[outp as u64] = op[(src + c) as u64]
                        outp = outp + 1u32
                        c = c + 1u32
                    }
                } else {
                    if outp >= out_cap { return -1i32 }
                    op[outp as u64] = ip[inp as u64]
                    inp = inp + 1u32
                    outp = outp + 1u32
                }
            }
            t = t + 1u32
        }
    }
    return outp as i32
}

/* ===== KAT ===== */
var LZSS_IN  : [u8; 600]
var LZSS_CMP : [u8; 1200]
var LZSS_OUT : [u8; 600]
var LZSS_RNG : [u64; 1]

fn lzss_rng() -> u64 {
    let mut x : u64 = LZSS_RNG[0u64]
    x = x ^ (x << 13u64)
    x = x ^ (x >> 7u64)
    x = x ^ (x << 17u64)
    LZSS_RNG[0u64] = x
    return x
}

/* 1 iff x < 0 -- via the sign bit, NOT i32 `<`/`>=` (which compile UNSIGNED in this toolchain,
 * so a naive `result < 0` would MISS a failure and vacuously pass the gate -- a greenwash). */
fn lzss_is_neg(x: i32) -> u32 { return (x as u32) >> 31u32 }

var LZSS_CL : [u32; 1]    /* last successful compressed length (for the ratio checks) */

/* compress LZSS_IN[0..n), decompress, assert byte-exact roundtrip; returns 0 on success (LZSS_CL
 * set to the compressed length), else a NONZERO error code. */
fn lzss_roundtrip(n: u32) -> u32 {
    let cl : i32 = lzss_compress(&LZSS_IN as u64, n, &LZSS_CMP as u64, 1200u32)
    if lzss_is_neg(cl) == 1u32 { return 10u32 }
    LZSS_CL[0u32] = cl as u32
    let dl : i32 = lzss_decompress(&LZSS_CMP as u64, cl as u32, &LZSS_OUT as u64, 600u32)
    if lzss_is_neg(dl) == 1u32 { return 20u32 }
    if (dl as u32) != n { return 30u32 }
    let mut i : u32 = 0u32
    while i < n {
        if LZSS_OUT[i] != LZSS_IN[i] { return 40u32 }
        i = i + 1u32
    }
    return 0u32
}

/* =====================================================================================
 * lzss_kat -- 99 = ROUNDTRIP IDENTITY decompress(compress(x))==x on a battery of inputs spanning
 * the cases a lossless codec must handle, plus the compression-ratio check on repetitive data:
 *   (1) random/incompressible; (2) constant run (max overlap matches); (3) periodic pattern;
 *   (4) text-like with repeats; (5) empty; (6) 100 seeded random lengths/contents.
 * ===================================================================================== */
fn lzss_kat() -> u64 @export {
    /* (1) random 300 bytes -> roundtrip */
    LZSS_RNG[0u64] = 0x1571B2C3D4E5F607u64
    let mut i : u32 = 0u32
    while i < 300u32 { LZSS_IN[i] = (lzss_rng() & 0xFFu64) as u8 ; i = i + 1u32 }
    if lzss_roundtrip(300u32) != 0u32 { return 1u64 }

    /* (2) constant run 256 (overlapping matches) -> roundtrip + compresses */
    let mut j : u32 = 0u32
    while j < 256u32 { LZSS_IN[j] = 0x41u8 ; j = j + 1u32 }
    if lzss_roundtrip(256u32) != 0u32 { return 2u64 }
    if LZSS_CL[0u32] >= 256u32 { return 3u64 }     /* must actually compress */

    /* (3) periodic "ABCD" x 100 = 400 -> roundtrip + compresses */
    let mut k : u32 = 0u32
    while k < 400u32 { LZSS_IN[k] = (0x41u32 + (k & 3u32)) as u8 ; k = k + 1u32 }
    if lzss_roundtrip(400u32) != 0u32 { return 4u64 }
    if LZSS_CL[0u32] >= 400u32 { return 5u64 }

    /* (4) text-like: a repeated phrase -> roundtrip + compresses */
    let mut m : u32 = 0u32
    while m < 480u32 {
        let ph : u32 = m % 16u32      /* 16-byte phrase repeated */
        LZSS_IN[m] = (0x61u32 + ph) as u8
        m = m + 1u32
    }
    if lzss_roundtrip(480u32) != 0u32 { return 6u64 }
    if LZSS_CL[0u32] >= 480u32 { return 7u64 }

    /* (5) empty input */
    if lzss_roundtrip(0u32) != 0u32 { return 8u64 }

    /* (6) 100 seeded random inputs of random length 0..512 -> roundtrip identity */
    LZSS_RNG[0u64] = 0x9E3779B97F4A7C15u64
    let mut tr : u32 = 0u32
    while tr < 100u32 {
        let r0 : u64 = lzss_rng()
        let n : u32 = (r0 % 513u64) as u32         /* 0..512 */
        let mut z : u32 = 0u32
        while z < n {
            let r1 : u64 = lzss_rng()
            /* mix incompressible + repetitive regions so matches AND literals both exercise */
            if (r1 & 3u64) == 0u64 { LZSS_IN[z] = (r1 & 0xFFu64) as u8 }
            else { LZSS_IN[z] = (0x30u32 + (z & 7u32)) as u8 }
            z = z + 1u32
        }
        if lzss_roundtrip(n) != 0u32 { return 9000u64 + (tr as u64) }
        tr = tr + 1u32
    }

    return 99u64
}
