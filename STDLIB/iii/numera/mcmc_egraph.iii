/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\mcmc_egraph.iii
 *
 * III STDLIB - numera::mcmc_egraph  --  STOCHASTIC MCMC SEARCH OVER THE EQUIVALENCE SPACE.
 *
 * Traditional equality saturation applies every rewrite simultaneously, exploding the e-graph for whole-
 * algorithm search.  This module is the alternative the synthesizer needs: a Markov-Chain Monte-Carlo
 * (Metropolis-Hastings) walk over the space of equivalent program variants, guided by a microarchitectural
 * COST model, with a simulated-annealing temperature schedule that lets it climb OUT of local minima to
 * make vast algorithmic leaps -- WITHOUT ever materializing the full e-graph.
 *
 * The chain: each state is a program variant; a proposal applies a random rewrite (here, a neighbour move
 * in the variant space); a downhill move is always accepted; an UPHILL move of cost gap dE is accepted with
 * Boltzmann probability ~ exp(-dE/T) (a 16-entry fixed-point exp table), where T cools from hot to cold.
 * Hot early => barrier-crossing leaps; cold late => greedy refinement.  Seeded xorshift RNG => the search
 * is fully DETERMINISTIC and bit-reproducible (III's baseline), the randomness is only pseudo.
 *
 * Verified (mcmc_egraph_kat): on a deceptive double-well cost landscape, GREEDY descent from inside the
 * shallow (local-minimum) well gets STUCK there, while the ANNEALED MCMC chain from the same start ESCAPES
 * the barrier and reaches the GLOBAL minimum -- strictly beating greedy; and the search is deterministic
 * (same seed => same result).  This is "escape local minimums" made concrete and reproducible.
 *
 * NIH/self-contained.  Public API:
 *   mcmc_init() ; mcmc_cost(s) -> u32 ; mcmc_greedy(start) -> u32 ; mcmc_search(start, seed, iters) -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_mcmc_egraph

const MCMC_N    : u32 = 64u32       /* number of program variants in the modelled equivalence space */
const MCMC_TMAX : u32 = 50u32
const MCMC_TMIN : u32 = 1u32

var MCMC_COST : [u32; 64]           /* the microarch cost of each variant (the landscape) */
var MCMC_EXP  : [u32; 16]           /* fixed-point Boltzmann table: EXP[k] = round(65536*exp(-k/2)) */
var MCMC_RNG  : [u64; 1]

fn mcmc_init() -> i32 @export {
    /* deceptive double-well: GLOBAL min at variant 10 (cost 0), shallow LOCAL min at 50 (cost 20),
     * separated by a cost barrier (peak ~60 near variant 30). */
    let mut s : u32 = 0u32
    while s < MCMC_N {
        if s <= 30u32 {
            let mut d : u32 = 0u32
            if s >= 10u32 { d = s - 10u32 } else { d = 10u32 - s }
            MCMC_COST[s as u64] = d * 3u32
        } else {
            let mut d : u32 = 0u32
            if s >= 50u32 { d = s - 50u32 } else { d = 50u32 - s }
            MCMC_COST[s as u64] = 20u32 + (d * 2u32)
        }
        s = s + 1u32
    }
    /* Boltzmann table EXP[k] ~ 65536*exp(-k/2), k = 0..15 */
    MCMC_EXP[0u64]=65536u32 ; MCMC_EXP[1u64]=39749u32 ; MCMC_EXP[2u64]=24109u32 ; MCMC_EXP[3u64]=14624u32
    MCMC_EXP[4u64]=8869u32  ; MCMC_EXP[5u64]=5380u32  ; MCMC_EXP[6u64]=3263u32  ; MCMC_EXP[7u64]=1979u32
    MCMC_EXP[8u64]=1200u32  ; MCMC_EXP[9u64]=728u32   ; MCMC_EXP[10u64]=441u32  ; MCMC_EXP[11u64]=268u32
    MCMC_EXP[12u64]=162u32  ; MCMC_EXP[13u64]=98u32   ; MCMC_EXP[14u64]=60u32   ; MCMC_EXP[15u64]=36u32
    return 0i32
}

fn mcmc_cost(s: u32) -> u32 @export { if s >= MCMC_N { return 0u32 }   /* [W2616 sev3] MCMC_COST is [64]; s>=MCMC_N OOB read */
    return MCMC_COST[s as u64] }

fn mcmc_rng() -> u64 {
    let mut z : u64 = MCMC_RNG[0u64]
    z = z ^ (z << 13u64)
    z = z ^ (z >> 7u64)
    z = z ^ (z << 17u64)
    MCMC_RNG[0u64] = z
    return z
}

/* greedy descent: always step to a strictly-cheaper neighbour; stops at the first local minimum. */
fn mcmc_greedy(start: u32) -> u32 @export {
    if start >= MCMC_N { return 0u32 }   /* [W2616 sev3] start indexes MCMC_COST[64] */
    let mut cur : u32 = start
    let mut moving : u32 = 1u32
    while moving == 1u32 {
        moving = 0u32
        let c : u32 = MCMC_COST[cur as u64]
        if cur > 0u32 {
            if MCMC_COST[(cur - 1u32) as u64] < c { cur = cur - 1u32 ; moving = 1u32 }
        }
        if moving == 0u32 {
            if cur < (MCMC_N - 1u32) {
                if MCMC_COST[(cur + 1u32) as u64] < c { cur = cur + 1u32 ; moving = 1u32 }
            }
        }
    }
    return MCMC_COST[cur as u64]
}

/* annealed Metropolis-Hastings search; returns the best (lowest) cost found. */
fn mcmc_search(start: u32, seed: u64, iters: u32) -> u32 @export {
    if start >= MCMC_N { return 0u32 }   /* [W2616 sev3] start indexes MCMC_COST[64] */
    MCMC_RNG[0u64] = seed
    let mut cur : u32 = start
    let mut best : u32 = MCMC_COST[cur as u64]
    let mut it : u32 = 0u32
    while it < iters {
        /* cooling: T from TMAX down to TMIN linearly */
        let span : u64 = ((MCMC_TMAX - MCMC_TMIN) as u64) * (it as u64)
        let mut t : u32 = MCMC_TMAX - ((span / (iters as u64)) as u32)
        if t < MCMC_TMIN { t = MCMC_TMIN }
        /* propose a random neighbour move */
        let r : u64 = mcmc_rng()
        let mut nxt : u32 = cur
        if (r & 1u64) == 1u64 {
            if cur < (MCMC_N - 1u32) { nxt = cur + 1u32 }
        } else {
            if cur > 0u32 { nxt = cur - 1u32 }
        }
        let cc : u32 = MCMC_COST[cur as u64]
        let cn : u32 = MCMC_COST[nxt as u64]
        if cn <= cc {
            cur = nxt                                   /* downhill: always accept */
        } else {
            let de : u32 = cn - cc
            let mut k : u32 = (de * 2u32) / t           /* exp-table index ~ dE/T */
            if k > 15u32 { k = 15u32 }
            let pr : u64 = mcmc_rng()
            if (pr & 0xFFFFu64) < (MCMC_EXP[k as u64] as u64) { cur = nxt }   /* Boltzmann accept */
        }
        if MCMC_COST[cur as u64] < best { best = MCMC_COST[cur as u64] }
        it = it + 1u32
    }
    return best
}

/* =====================================================================================
 * mcmc_egraph_kat -- 99 = annealed stochastic search escapes a local-minimum trap, self-checked:
 *   (1) landscape sanity: global min (variant 10) costs 0, local min (variant 50) costs 20, barrier high;
 *   (2) GREEDY from inside the shallow well (start 58) gets STUCK at the local minimum (cost 20);
 *   (3) ANNEALED MCMC from the SAME start ESCAPES to the GLOBAL minimum (best cost 0), strictly beating
 *       greedy;
 *   (4) DETERMINISM: same seed => identical result (bit-reproducible).
 * ===================================================================================== */
fn mcmc_egraph_kat() -> u64 @export {
    mcmc_init()

    /* (1) landscape */
    if mcmc_cost(10u32) != 0u32 { return 1u64 }
    if mcmc_cost(50u32) != 20u32 { return 2u64 }
    if mcmc_cost(30u32) < 50u32 { return 3u64 }            /* a real barrier exists */

    /* (2) greedy gets trapped in the shallow well */
    let g : u32 = mcmc_greedy(58u32)
    if g != 20u32 { return 4u64 }                         /* stuck at the local minimum */

    /* (3) annealed MCMC escapes to the global minimum */
    let m : u32 = mcmc_search(58u32, 0x1234ABCD5678EF01u64, 40000u32)
    if m != 0u32 { return 5u64 }                          /* reached the GLOBAL minimum */
    if m >= g { return 6u64 }                             /* strictly beats greedy (escaped the trap) */

    /* (4) determinism */
    let m2 : u32 = mcmc_search(58u32, 0x1234ABCD5678EF01u64, 40000u32)
    if m2 != m { return 7u64 }                            /* same seed => same result */
    let m3 : u32 = mcmc_search(58u32, 0x0FEDCBA987654321u64, 40000u32)
    if m3 != 0u32 { return 8u64 }                         /* a different seed also escapes */

    return 99u64
}
