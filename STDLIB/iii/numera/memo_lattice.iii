/* III/STDLIB/iii/numera/memo_lattice.iii
 *
 * III STDLIB -- numera::memo_lattice  (Layer 4, Module 58)
 *
 * Content-addressed cache of past computations. Keys are 32-byte content
 * addresses (computed upstream by content_addr.iii). Values are
 * (output_commitment, chain_id) pairs with a per-entry K_memo confidence
 * (u8 0..100). Open-addressed linear probe over 65536 slots (Keccak-key
 * low-16 bucket hash, power-of-two mask -- no division, Trap 11).
 *
 * Hexad: kind_essence + kind_cognition.  Ring: R0.  K: 1.00.
 *
 * NIH: identifier.iii (built), witness_hook.iii (built),
 *      witness_spine.iii (built), constitution.iii (built).
 * Keys are content-addressed by the caller; this module never hashes.
 *
 * M17 / W36 / W50 DISCIPLINE (load-bearing):
 *   - Admission verifies the producing chain (ws_lookup_id) BEFORE insertion --
 *     an unregistered fragment chain NEVER enters the lattice.
 *   - ml_lookup returning MEMOL_OK means "present, not stale", NOT "trusted":
 *     the caller MUST call ws_lookup_id(out_chain_id) and get OK before
 *     consuming out_commit. The lattice never propagates an unverified result.
 *   - A stale entry is invisible to lookup; ml_revalidate replays the
 *     chain before clearing the stale mark (no un-stale without reval).
 *
 * Non-reentrant: MEMOL_SCR_* scratch buffers are module-scope (Trap 7).
 * Single-threaded R0 use only.
 *
 * BSS discipline (Trap 19): all buffers > 1 MiB use the frugal [u64; N/8]
 * representation accessed via byte pointer; the 65536-slot status/k tables
 * use [u64; 8192] (65536 / 8). Total .bss contribution ~6 MiB.
 */

module numera_memo_lattice

extern @abi(c-msvc-x64) fn ident_zero(out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_eq(a: *u8, b: *u8) -> u8 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_copy(src: *u8, dst: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_from_bytes(input: *u8, in_len: u64, out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn wh_publish(producer: *u8, opid: *u8, in_commit: *u8, out_commit: *u8, revtag: u8, phase: u8, pillar: u16, antecedents: *u8, n_ante: u32, payload: *u8, payload_len: u32, out_frag_id: *u8) -> u64 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn ws_lookup_id(frag_id: *u8, out_idx: *u64) -> i32 from "witness_spine.iii"
extern @abi(c-msvc-x64) fn cons_find(clause_id: *u8) -> u32 from "constitution.iii"

/* ---- Status codes (W9: negative i32 errors) ---- */
const MEMOL_OK              : i32 =  0i32
const MEMOL_E_NULL          : i32 = -1i32
const MEMOL_E_ABSENT        : i32 = -2i32
const MEMOL_E_STALE         : i32 = -3i32
const MEMOL_E_DUPLICATE     : i32 = -4i32
const MEMOL_E_FULL          : i32 = -5i32
const MEMOL_E_CLAUSE_ABSENT : i32 = -6i32
const MEMOL_E_VERIFY_FAIL   : i32 = -7i32
const MEMOL_E_NOT_INITED    : i32 = -8i32

/* ---- Capacity + layout ---- */
const MEMOL_SLOTS           : u64 = 65536u64
const MEMOL_SLOT_MASK       : u64 = 0xFFFFu64
const MEMOL_KEY_BYTES       : u64 = 32u64

/* ---- K_memo confidence values ---- */
const MEMOL_K_FULL          : u8  = 100u8
const MEMOL_K_STALE         : u8  = 0u8

/* ---- Witness fragment event sub-tags (payload[1] under 0xE3 tag) ---- */
const MEMOL_PAYLOAD_TAG     : u8  = 0xE3u8
const MEMOL_EVT_RECORD      : u8  = 0x0Du8
const MEMOL_EVT_HIT         : u8  = 0x0Eu8
const MEMOL_EVT_STALE       : u8  = 0x0Fu8
const MEMOL_EVT_REVAL       : u8  = 0x17u8

/* ---- Constitution absent sentinel (matches CONS_SENT = 0xFFFFFFFFu32) ---- */
const MEMOL_CONS_ABSENT     : u32 = 0xFFFFFFFFu32

/* ---- Module-scope scalars ---- */
var MEMOL_INITED : u8  = 0u8
var MEMOL_COUNT  : u64 = 0u64

/* ---- Slot tables (frugal [u64; N/8] representation, Trap 19) ----
 * KEYS/OUT_COMMITS/CHAIN_IDS: 65536 slots * 32 bytes = 2097152 bytes each.
 * Frugal: [u64; 262144] = 8 bytes * 262144 = 2 MiB each. Total 6 MiB.
 * Accessed via byte pointer: slot s, byte i -> base + s*32 + i.
 *
 * LIVE/STALE/K_MEMO: 65536 bytes each.
 * Frugal: [u64; 8192] = 8 bytes * 8192 = 64 KiB each. Total 192 KiB.
 * Accessed via byte pointer: slot s -> base + s.
 */
var MEMOL_KEYS       : [u64; 262144]
var MEMOL_OUT_COMMITS : [u64; 262144]
var MEMOL_CHAIN_IDS  : [u64; 262144]
var MEMOL_LIVE       : [u64; 8192]
var MEMOL_STALE      : [u64; 8192]
var MEMOL_K_MEMO     : [u64; 8192]

/* ---- Module-scope scratch buffers (Trap 7: no local var arrays) ---- */
var MEMOL_SCR_PAYLOAD      : [u8; 72]
var MEMOL_SCR_PRODUCER     : [u8; 32]
var MEMOL_SCR_OP           : [u8; 32]
var MEMOL_SCR_INC          : [u8; 32]
var MEMOL_SCR_OUTC         : [u8; 32]
var MEMOL_SCR_FRAGID       : [u8; 32]
var MEMOL_SCR_CLAUSE_LABEL : [u8; 13]
var MEMOL_SCR_CLAUSE_ID    : [u8; 32]
var MEMOL_SCR_WSIDX        : [u64; 1]
var MEMOL_SCR_ZEROSLOT     : [u8; 32]

/* ---- KAT scratch (selftest only) ---- */
var MEMOL_T_K0  : [u8; 32]
var MEMOL_T_K1  : [u8; 32]
var MEMOL_T_C0  : [u8; 32]
var MEMOL_T_C1  : [u8; 32]
var MEMOL_T_CH0 : [u8; 32]
var MEMOL_T_CH1 : [u8; 32]
var MEMOL_T_OC  : [u8; 32]
var MEMOL_T_OCH : [u8; 32]
var MEMOL_T_KM  : [u8; 1]

/* ---- Private helpers ---- */

/* Slot hash: low 16 bits of key (key is a Keccak-256 content address,
 * uniformly distributed -- low 16 bits are a sound bucket index). */
fn ml_hash_slot(key: *u8) -> u64 {
    let h0 : u64 = key[0u64] as u64
    let h1 : u64 = key[1u64] as u64
    return (h0 | (h1 << 8u64)) & MEMOL_SLOT_MASK
}

/* Byte-pointer helper: address of slot s, field-base base, byte i. */
fn ml_slot_byte_ptr(base: u64, s: u64, i: u64) -> *u8 {
    return (base + s * MEMOL_KEY_BYTES + i) as *u8
}

/* Status byte for slot s in a [u64; 8192] table. */
fn ml_status_ptr(base: u64, s: u64) -> *u8 {
    return (base + s) as *u8
}

/* Linear probe: find slot holding key; returns slot index or -1i64.
 * Sentinel-flag loop (W14, no break). Stops at the first empty slot
 * (open-addressing invariant: absent key has no slot past an empty one). */
fn ml_slot_find(key: *u8) -> i64 {
    let start : u64 = ml_hash_slot(key)
    let mut probe : u64 = 0u64
    let mut sentinel : u8 = 0u8
    let mut result : i64 = -1i64
    while probe < MEMOL_SLOTS {
        if sentinel == 0u8 {
            let s : u64 = (start + probe) & MEMOL_SLOT_MASK
            let lp : *u8 = ml_status_ptr(&MEMOL_LIVE as u64, s)
            if lp[0u64] == 0u8 {
                sentinel = 1u8
            } else {
                let kp : *u8 = ml_slot_byte_ptr(&MEMOL_KEYS as u64, s, 0u64)
                if ident_eq(kp, key) == 1u8 { result = s as i64  sentinel = 1u8 }
            }
        }
        /* early-exit: once resolved (match found or empty slot reached), stop the linear
         * probe instead of spinning to the full MEMOL_SLOTS (no-break idiom, witness_spine:201).
         * Result is bit-identical -- only the dead tail iterations are removed. */
        if sentinel == 1u8 { probe = MEMOL_SLOTS } else { probe = probe + 1u64 }
    }
    return result
}

/* Linear probe: find first free slot; returns slot index or -1i64. */
fn ml_slot_alloc(key: *u8) -> i64 {
    let start : u64 = ml_hash_slot(key)
    let mut probe : u64 = 0u64
    let mut sentinel : u8 = 0u8
    let mut result : i64 = -1i64
    while probe < MEMOL_SLOTS {
        if sentinel == 0u8 {
            let s : u64 = (start + probe) & MEMOL_SLOT_MASK
            let lp : *u8 = ml_status_ptr(&MEMOL_LIVE as u64, s)
            if lp[0u64] == 0u8 { result = s as i64  sentinel = 1u8 }
        }
        /* early-exit on the first free slot (bit-identical to scanning the full table). */
        if sentinel == 1u8 { probe = MEMOL_SLOTS } else { probe = probe + 1u64 }
    }
    return result
}

/* Emit a witness fragment for a lattice event (RECORD/HIT/STALE/REVAL).
 * Payload layout: [0]=0xE3, [1]=tag, [8..40]=key, [40..72]=chain_id (if non-null).
 * chain_id_ptr == 0 -> stale/reval events with no out-commit; payload_len=40.
 * Returns wh_publish index or 0xFFFF...FF on publish failure; caller treats
 * any value != 0xFFFFFFFFFFFFFFFFu64 as success. */
fn ml_emit_event(tag: u8, key: *u8, chain_id_ptr: *u8) -> i32 {
    let mut i : u64 = 0u64
    while i < 72u64 { MEMOL_SCR_PAYLOAD[i] = 0u8  i = i + 1u64 }
    MEMOL_SCR_PAYLOAD[0u64] = MEMOL_PAYLOAD_TAG
    MEMOL_SCR_PAYLOAD[1u64] = tag
    let mut j : u64 = 0u64
    while j < 32u64 { MEMOL_SCR_PAYLOAD[8u64 + j] = key[j]  j = j + 1u64 }
    let mut plen : u32 = 40u32
    if (chain_id_ptr as u64) != 0u64 {
        let mut k : u64 = 0u64
        while k < 32u64 { MEMOL_SCR_PAYLOAD[40u64 + k] = chain_id_ptr[k]  k = k + 1u64 }
        plen = 72u32
    }
    let mut z : u64 = 0u64
    while z < 32u64 { MEMOL_SCR_PRODUCER[z] = 0u8  MEMOL_SCR_OP[z] = 0u8  z = z + 1u64 }
    let mut ci : u64 = 0u64
    while ci < 32u64 { MEMOL_SCR_INC[ci] = key[ci]  ci = ci + 1u64 }
    let mut co : u64 = 0u64
    if (chain_id_ptr as u64) != 0u64 {
        while co < 32u64 { MEMOL_SCR_OUTC[co] = chain_id_ptr[co]  co = co + 1u64 }
    } else {
        while co < 32u64 { MEMOL_SCR_OUTC[co] = 0u8  co = co + 1u64 }
    }
    let nullp : *u8 = 0u64 as *u8
    let fid_ret : u64 = wh_publish((&MEMOL_SCR_PRODUCER as u64) as *u8, (&MEMOL_SCR_OP as u64) as *u8, (&MEMOL_SCR_INC as u64) as *u8, (&MEMOL_SCR_OUTC as u64) as *u8, 0u8, 0u8, 0xDu16, nullp, 0u32, (&MEMOL_SCR_PAYLOAD as u64) as *u8, plen, (&MEMOL_SCR_FRAGID as u64) as *u8)
    if fid_ret == 0xFFFFFFFFFFFFFFFFu64 { return -1i32 }
    return MEMOL_OK
}

/* ---- Public API ---- */

/* Initialize (idempotent; never fails). Zeros all slot-status tables.
 * Key/commit/chain-id tables need not be zeroed -- LIVE gates all reads. */
fn ml_init() -> i32 @export {
    if MEMOL_INITED == 1u8 { return MEMOL_OK }
    let lbase : u64 = &MEMOL_LIVE as u64
    let sbase : u64 = &MEMOL_STALE as u64
    let kbase : u64 = &MEMOL_K_MEMO as u64
    let mut i : u64 = 0u64
    while i < MEMOL_SLOTS {
        let lp : *u8 = (lbase + i) as *u8
        let sp : *u8 = (sbase + i) as *u8
        let kp : *u8 = (kbase + i) as *u8
        lp[0u64] = 0u8
        sp[0u64] = 0u8
        kp[0u64] = 0u8
        i = i + 1u64
    }
    MEMOL_COUNT = 0u64
    MEMOL_INITED = 1u8
    return MEMOL_OK
}

/* Admit a new result into the lattice. Guards: init, 3 null params,
 * clause-governance (M8), chain-verification (M17), duplicate, full.
 * On pass: writes slot, increments COUNT, emits RECORD fragment (M6). */
fn ml_admit(key: *u8, out_commit: *u8, chain_id: *u8) -> i32 @export {
    if MEMOL_INITED == 0u8 { return MEMOL_E_NOT_INITED }
    if (key as u64) == 0u64 { return MEMOL_E_NULL }
    if (out_commit as u64) == 0u64 { return MEMOL_E_NULL }
    if (chain_id as u64) == 0u64 { return MEMOL_E_NULL }
    /* Clause governance (M8): verify cp_memo_admit clause is ratified.
     * ASCII bytes of "cp_memo_admit" written directly (no loop, no local array). */
    MEMOL_SCR_CLAUSE_LABEL[0u64]  = 0x63u8
    MEMOL_SCR_CLAUSE_LABEL[1u64]  = 0x70u8
    MEMOL_SCR_CLAUSE_LABEL[2u64]  = 0x5Fu8
    MEMOL_SCR_CLAUSE_LABEL[3u64]  = 0x6Du8
    MEMOL_SCR_CLAUSE_LABEL[4u64]  = 0x65u8
    MEMOL_SCR_CLAUSE_LABEL[5u64]  = 0x6Du8
    MEMOL_SCR_CLAUSE_LABEL[6u64]  = 0x6Fu8
    MEMOL_SCR_CLAUSE_LABEL[7u64]  = 0x5Fu8
    MEMOL_SCR_CLAUSE_LABEL[8u64]  = 0x61u8
    MEMOL_SCR_CLAUSE_LABEL[9u64]  = 0x64u8
    MEMOL_SCR_CLAUSE_LABEL[10u64] = 0x6Du8
    MEMOL_SCR_CLAUSE_LABEL[11u64] = 0x69u8
    MEMOL_SCR_CLAUSE_LABEL[12u64] = 0x74u8
    ident_from_bytes((&MEMOL_SCR_CLAUSE_LABEL as u64) as *u8, 13u64, (&MEMOL_SCR_CLAUSE_ID as u64) as *u8)
    if cons_find((&MEMOL_SCR_CLAUSE_ID as u64) as *u8) == MEMOL_CONS_ABSENT { return MEMOL_E_CLAUSE_ABSENT }
    /* Chain verification (M17): chain_id must be a registered fragment. */
    if ws_lookup_id(chain_id, (&MEMOL_SCR_WSIDX as u64) as *u64) != 0i32 { return MEMOL_E_VERIFY_FAIL }
    /* Duplicate guard. */
    let found : i64 = ml_slot_find(key)
    if found != -1i64 { return MEMOL_E_DUPLICATE }
    /* Allocate slot. */
    let slot : i64 = ml_slot_alloc(key)
    if slot == -1i64 { return MEMOL_E_FULL }
    let s : u64 = slot as u64
    /* Write key, out_commit, chain_id into their tables. */
    let kbase : u64 = &MEMOL_KEYS as u64
    let ocbase : u64 = &MEMOL_OUT_COMMITS as u64
    let cbase : u64 = &MEMOL_CHAIN_IDS as u64
    let mut wi : u64 = 0u64
    while wi < 32u64 {
        let kp : *u8 = (kbase + s * 32u64 + wi) as *u8
        let ocp : *u8 = (ocbase + s * 32u64 + wi) as *u8
        let cp : *u8 = (cbase + s * 32u64 + wi) as *u8
        kp[0u64] = key[wi]
        ocp[0u64] = out_commit[wi]
        cp[0u64] = chain_id[wi]
        wi = wi + 1u64
    }
    let lp : *u8 = (&MEMOL_LIVE as u64 + s) as *u8
    let sp : *u8 = (&MEMOL_STALE as u64 + s) as *u8
    let kmp : *u8 = (&MEMOL_K_MEMO as u64 + s) as *u8
    lp[0u64] = 1u8
    sp[0u64] = 0u8
    kmp[0u64] = MEMOL_K_FULL
    MEMOL_COUNT = MEMOL_COUNT + 1u64
    return ml_emit_event(MEMOL_EVT_RECORD, key, chain_id)
}

/* Look up a key. Returns OK with output params filled on hit (not stale),
 * E_ABSENT if missing, E_STALE if stale.
 * M17 CONTRACT: MEMOL_OK means "present, not stale", NOT "trusted".
 * Caller MUST ws_lookup_id(out_chain_id) == OK before consuming out_commit. */
fn ml_lookup(key: *u8, out_commit: *u8, out_chain_id: *u8, out_k_memo: *u8) -> i32 @export {
    if MEMOL_INITED == 0u8 { return MEMOL_E_NOT_INITED }
    if (key as u64) == 0u64 { return MEMOL_E_NULL }
    if (out_commit as u64) == 0u64 { return MEMOL_E_NULL }
    if (out_chain_id as u64) == 0u64 { return MEMOL_E_NULL }
    if (out_k_memo as u64) == 0u64 { return MEMOL_E_NULL }
    let found : i64 = ml_slot_find(key)
    if found == -1i64 { return MEMOL_E_ABSENT }
    let s : u64 = found as u64
    let sp : *u8 = (&MEMOL_STALE as u64 + s) as *u8
    if sp[0u64] == 1u8 { return MEMOL_E_STALE }
    let ocbase : u64 = &MEMOL_OUT_COMMITS as u64
    let cbase : u64 = &MEMOL_CHAIN_IDS as u64
    let kmp : *u8 = (&MEMOL_K_MEMO as u64 + s) as *u8
    let mut ri : u64 = 0u64
    while ri < 32u64 {
        let ocp : *u8 = (ocbase + s * 32u64 + ri) as *u8
        let cp : *u8 = (cbase + s * 32u64 + ri) as *u8
        out_commit[ri] = ocp[0u64]
        out_chain_id[ri] = cp[0u64]
        ri = ri + 1u64
    }
    out_k_memo[0u64] = kmp[0u64]
    let chain_ptr : *u8 = (&MEMOL_CHAIN_IDS as u64 + s * 32u64) as *u8
    ml_emit_event(MEMOL_EVT_HIT, key, chain_ptr)
    return MEMOL_OK
}

/* TRUSTED single-call read: ml_lookup returns "present, not stale" but NOT "trusted" -- the M17 invariant
 * requires the caller to chain-verify out_chain_id before consuming out_commit (header lines 20-22).  This
 * INTERNALIZES that discipline: present + not-stale + M17 chain-verified in ONE call, so a caller cannot forget
 * the verify and propagate an unverified result.  Purely additive over the already-exported ws_lookup_id;
 * ml_lookup itself is byte-identical, so every existing path is unaffected. */
fn ml_lookup_verified(key: *u8, out_commit: *u8, out_chain_id: *u8, out_k_memo: *u8) -> i32 @export {
    let r : i32 = ml_lookup(key, out_commit, out_chain_id, out_k_memo)
    if r != MEMOL_OK { return r }                                            /* absent / stale / null propagate */
    if ws_lookup_id(out_chain_id, (&MEMOL_SCR_WSIDX as u64) as *u64) != 0i32 { return MEMOL_E_VERIFY_FAIL }
    return MEMOL_OK
}

/* Mark slot stale (makes it invisible to lookup; M9: reversible by revalidate).
 * Emits STALE fragment (M6 witness continuity). */
fn ml_mark_stale(key: *u8) -> i32 @export {
    if MEMOL_INITED == 0u8 { return MEMOL_E_NOT_INITED }
    if (key as u64) == 0u64 { return MEMOL_E_NULL }
    let found : i64 = ml_slot_find(key)
    if found == -1i64 { return MEMOL_E_ABSENT }
    let s : u64 = found as u64
    let sp : *u8 = (&MEMOL_STALE as u64 + s) as *u8
    let kmp : *u8 = (&MEMOL_K_MEMO as u64 + s) as *u8
    sp[0u64] = 1u8
    kmp[0u64] = MEMOL_K_STALE
    let nullp : *u8 = 0u64 as *u8
    return ml_emit_event(MEMOL_EVT_STALE, key, nullp)
}

/* Revalidate a stale slot: replay chain (M17), then clear stale mark.
 * Emits REVAL fragment on success (Gap #2 fix -- restores witness symmetry). */
fn ml_revalidate(key: *u8) -> i32 @export {
    if MEMOL_INITED == 0u8 { return MEMOL_E_NOT_INITED }
    if (key as u64) == 0u64 { return MEMOL_E_NULL }
    let found : i64 = ml_slot_find(key)
    if found == -1i64 { return MEMOL_E_ABSENT }
    let s : u64 = found as u64
    let chain_ptr : *u8 = (&MEMOL_CHAIN_IDS as u64 + s * 32u64) as *u8
    /* Chain re-verification (W50: no un-stale without reval). */
    if ws_lookup_id(chain_ptr, (&MEMOL_SCR_WSIDX as u64) as *u64) != 0i32 { return MEMOL_E_VERIFY_FAIL }
    let sp : *u8 = (&MEMOL_STALE as u64 + s) as *u8
    let kmp : *u8 = (&MEMOL_K_MEMO as u64 + s) as *u8
    sp[0u64] = 0u8
    kmp[0u64] = MEMOL_K_FULL
    return ml_emit_event(MEMOL_EVT_REVAL, key, chain_ptr)
}

/* Return live+stale entry count. */
fn ml_size() -> u64 @export {
    return MEMOL_COUNT
}

/* ---- Phase-2 read-only slot accessors (for M79 memo_compactor_coordination) ----
 * Pure getters over the existing slot tables; no behavior change to admit/lookup/
 * mark/revalidate.  Bounds-checked (slot >= MEMOL_SLOTS is u64 ordering -- safe).
 * chain_eq/key gate on live and never let a pointer escape (compare against /
 * copy into the caller's buffer).  Idioms mirror ml_admit/ml_revalidate exactly:
 * MEMOL_LIVE is byte-per-slot ((&MEMOL_LIVE as u64 + slot) as *u8); MEMOL_CHAIN_IDS
 * /MEMOL_KEYS are 32-byte-per-slot id-arrays ((&ARR as u64 + slot*32) as *u8). */
fn ml_slot_count() -> u64 @export {
    return MEMOL_SLOTS
}

fn ml_slot_is_live(slot: u64) -> u8 @export {
    if slot >= MEMOL_SLOTS { return 0u8 }
    let lp : *u8 = (&MEMOL_LIVE as u64 + slot) as *u8
    return lp[0u64]
}

fn ml_slot_chain_eq(slot: u64, chain_id: *u8) -> u8 @export {
    if slot >= MEMOL_SLOTS { return 0u8 }
    if (chain_id as u64) == 0u64 { return 0u8 }
    let lp : *u8 = (&MEMOL_LIVE as u64 + slot) as *u8
    if lp[0u64] != 1u8 { return 0u8 }
    let cp : *u8 = (&MEMOL_CHAIN_IDS as u64 + slot * 32u64) as *u8
    return ident_eq(cp, chain_id)
}

fn ml_slot_key(slot: u64, out_key: *u8) -> i32 @export {
    if slot >= MEMOL_SLOTS { return MEMOL_E_ABSENT }
    if (out_key as u64) == 0u64 { return MEMOL_E_NULL }
    let lp : *u8 = (&MEMOL_LIVE as u64 + slot) as *u8
    if lp[0u64] != 1u8 { return MEMOL_E_ABSENT }
    let kp : *u8 = (&MEMOL_KEYS as u64 + slot * 32u64) as *u8
    ident_copy(kp, out_key)
    return MEMOL_OK
}

/* ---- Self-test (99 = full pass; distinct small code per failed check) ----
 *
 * The selftest is self-contained: it does NOT call wh_init/ws_init (those are
 * the domain of the witness integration harness). Instead it exercises every
 * lattice-internal code path via direct calls, using known-good chain_ids that
 * ws_lookup_id will succeed on (after publishing them via wh_publish) and
 * known-absent ids that must fail.
 *
 * To keep the selftest linkable without wh_init dependencies:
 *   - We call ml_init() to reset lattice state.
 *   - We publish two witness fragments to get valid chain_ids, then test admit.
 *   - We exercise all negative gates (null, verify-fail, clause-absent is
 *     approximated: cons_find over an unknown id WILL return CONS_ABSENT =
 *     0xFFFFFFFFu32 because no clause is installed, so the clause gate fires).
 *
 * KAT map:
 *   1. Empty-lattice absence + ml_size()==0
 *   2. Admit then hit, K_memo=100, re-admit -> DUPLICATE
 *   3. Stale then revalidate
 *   4. Negative: null-arg guards
 *   5. Negative: absent key -> E_ABSENT
 *   6. Clause-absent gate (no clause ratified -> E_CLAUSE_ABSENT on fresh ml_admit)
 *      [skipped in selftest because constitution state is shared; verified by gate logic path]
 *   7. Verify-fail gate: bogus chain_id -> E_VERIFY_FAIL
 *
 * Note: clause-governance uses cons_find against a fresh constitution (no ratified
 * clause) so ml_admit will return E_CLAUSE_ABSENT unless a ratified cp_memo_admit
 * clause exists. In the selftest we use a stub path: we pre-ratify by inserting a
 * known clause via the constitution's own API is not available from here; instead
 * we verify the gate fires by checking return == E_CLAUSE_ABSENT on a clean system,
 * which IS the negative-arm proof for M8 governance.
 */
extern @abi(c-msvc-x64) fn wh_init(initial_time: u64) -> i32 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn ws_init() -> i32 from "witness_spine.iii"
extern @abi(c-msvc-x64) fn ws_register(frag_idx: u64) -> i32 from "witness_spine.iii"
extern @abi(c-msvc-x64) fn cons_init() -> i32 from "constitution.iii"
extern @abi(c-msvc-x64) fn cons_ratify(req: *u8) -> u64 from "constitution.iii"

var MEMOL_RATIFY_BUF : [u64; 128]   /* scratch for cons_ratify request (1024 bytes) */

/* Selftest split into two helpers to keep each under W13's 20-local limit. */

/* ml_st_phase1: KATs 1, 4a/4b (null guards), 6 (clause-absent gate), 7 (verify-fail).
 * Returns 0 on pass, or a non-zero failure code. */
fn ml_st_phase1() -> u64 {
    /* KAT 1: empty-lattice absence and ml_size()==0. */
    if ml_size() != 0u64 { return 1u64 }
    if ml_lookup((&MEMOL_T_K0 as u64) as *u8, (&MEMOL_T_OC as u64) as *u8, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_E_ABSENT { return 2u64 }
    /* KAT 4a: null-arg guards on ml_admit. */
    let nullp : *u8 = 0u64 as *u8
    if ml_admit(nullp, (&MEMOL_T_C0 as u64) as *u8, (&MEMOL_T_CH0 as u64) as *u8) != MEMOL_E_NULL { return 3u64 }
    if ml_admit((&MEMOL_T_K0 as u64) as *u8, nullp, (&MEMOL_T_CH0 as u64) as *u8) != MEMOL_E_NULL { return 4u64 }
    if ml_admit((&MEMOL_T_K0 as u64) as *u8, (&MEMOL_T_C0 as u64) as *u8, nullp) != MEMOL_E_NULL { return 5u64 }
    /* KAT 4b: null-arg guards on ml_lookup. */
    if ml_lookup(nullp, (&MEMOL_T_OC as u64) as *u8, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_E_NULL { return 6u64 }
    if ml_lookup((&MEMOL_T_K0 as u64) as *u8, nullp, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_E_NULL { return 7u64 }
    /* KAT 6 (negative: clause-absent gate fires on clean constitution). */
    cons_init()
    if ml_admit((&MEMOL_T_K0 as u64) as *u8, (&MEMOL_T_C0 as u64) as *u8, (&MEMOL_T_CH0 as u64) as *u8) != MEMOL_E_CLAUSE_ABSENT { return 8u64 }
    if ml_size() != 0u64 { return 9u64 }
    if ml_lookup((&MEMOL_T_K0 as u64) as *u8, (&MEMOL_T_OC as u64) as *u8, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_E_ABSENT { return 10u64 }
    /* KAT 7 (negative: verify-fail -- CH0 not registered in fresh spine). */
    if ws_lookup_id((&MEMOL_T_CH0 as u64) as *u8, (&MEMOL_SCR_WSIDX as u64) as *u64) == 0i32 { return 11u64 }
    return 0u64
}

/* ml_st_phase2: publish chain fragments; KATs 2 (admit/hit/dup), 3 (stale/reval), 5 (absent).
 * Assumes phase1 passed and wh/ws already reset. Returns 0 on pass or failure code. */
fn ml_st_phase2() -> u64 {
    /* Zero the scratch buffer and publish two fragments to get valid chain_ids. */
    let mut zi : u64 = 0u64
    while zi < 32u64 { MEMOL_SCR_ZEROSLOT[zi] = 0u8  zi = zi + 1u64 }
    let fa : u64 = wh_publish((&MEMOL_SCR_ZEROSLOT as u64) as *u8, (&MEMOL_SCR_ZEROSLOT as u64) as *u8, (&MEMOL_SCR_ZEROSLOT as u64) as *u8, (&MEMOL_T_C0 as u64) as *u8, 0u8, 0u8, 0xEu16, (&MEMOL_SCR_ZEROSLOT as u64) as *u8, 0u32, (&MEMOL_SCR_ZEROSLOT as u64) as *u8, 0u32, (&MEMOL_T_CH0 as u64) as *u8)
    if fa == 0xFFFFFFFFFFFFFFFFu64 { return 12u64 }
    ws_register(fa)
    let fb : u64 = wh_publish((&MEMOL_SCR_ZEROSLOT as u64) as *u8, (&MEMOL_SCR_ZEROSLOT as u64) as *u8, (&MEMOL_SCR_ZEROSLOT as u64) as *u8, (&MEMOL_T_C1 as u64) as *u8, 0u8, 0u8, 0xEu16, (&MEMOL_SCR_ZEROSLOT as u64) as *u8, 0u32, (&MEMOL_SCR_ZEROSLOT as u64) as *u8, 0u32, (&MEMOL_T_CH1 as u64) as *u8)
    if fb == 0xFFFFFFFFFFFFFFFFu64 { return 13u64 }
    ws_register(fb)
    /* CH0 now registered -- ws_lookup_id must succeed. */
    if ws_lookup_id((&MEMOL_T_CH0 as u64) as *u8, (&MEMOL_SCR_WSIDX as u64) as *u64) != 0i32 { return 14u64 }
    /* Direct slot write: bypass clause gate to test lookup/stale/reval. */
    let ds64 : i64 = ml_slot_alloc((&MEMOL_T_K0 as u64) as *u8)
    if ds64 == -1i64 { return 15u64 }
    let ds : u64 = ds64 as u64
    let mut dw : u64 = 0u64
    while dw < 32u64 {
        let dkp : *u8 = (&MEMOL_KEYS as u64 + ds * 32u64 + dw) as *u8
        let docp : *u8 = (&MEMOL_OUT_COMMITS as u64 + ds * 32u64 + dw) as *u8
        let dcp : *u8 = (&MEMOL_CHAIN_IDS as u64 + ds * 32u64 + dw) as *u8
        dkp[0u64] = MEMOL_T_K0[dw]
        docp[0u64] = MEMOL_T_C0[dw]
        dcp[0u64] = MEMOL_T_CH0[dw]
        dw = dw + 1u64
    }
    let dlp : *u8 = (&MEMOL_LIVE as u64 + ds) as *u8
    let dsp2 : *u8 = (&MEMOL_STALE as u64 + ds) as *u8
    let dkmp : *u8 = (&MEMOL_K_MEMO as u64 + ds) as *u8
    dlp[0u64] = 1u8
    dsp2[0u64] = 0u8
    dkmp[0u64] = MEMOL_K_FULL
    MEMOL_COUNT = MEMOL_COUNT + 1u64
    /* KAT 2: lookup K0 -> OK, C0, CH0, km=100. */
    if ml_lookup((&MEMOL_T_K0 as u64) as *u8, (&MEMOL_T_OC as u64) as *u8, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_OK { return 16u64 }
    let mut acc : u32 = 0u32
    let mut ai : u64 = 0u64
    while ai < 32u64 {
        acc = acc | ((MEMOL_T_OC[ai] as u32) ^ (MEMOL_T_C0[ai] as u32))
        acc = acc | ((MEMOL_T_OCH[ai] as u32) ^ (MEMOL_T_CH0[ai] as u32))
        ai = ai + 1u64
    }
    if acc != 0u32 { return 17u64 }
    if MEMOL_T_KM[0u64] != MEMOL_K_FULL { return 18u64 }
    if ml_size() != 1u64 { return 19u64 }
    /* KAT 2: find -> success. */
    if ml_slot_find((&MEMOL_T_K0 as u64) as *u8) == -1i64 { return 20u64 }
    /* KAT 3: stale -> E_STALE, K_MEMO=0. */
    if ml_mark_stale((&MEMOL_T_K0 as u64) as *u8) != MEMOL_OK { return 21u64 }
    if ml_lookup((&MEMOL_T_K0 as u64) as *u8, (&MEMOL_T_OC as u64) as *u8, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_E_STALE { return 22u64 }
    if dkmp[0u64] != MEMOL_K_STALE { return 23u64 }
    /* KAT 3: reval -> OK, km=100. */
    if ml_revalidate((&MEMOL_T_K0 as u64) as *u8) != MEMOL_OK { return 24u64 }
    if ml_lookup((&MEMOL_T_K0 as u64) as *u8, (&MEMOL_T_OC as u64) as *u8, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_OK { return 25u64 }
    if MEMOL_T_KM[0u64] != MEMOL_K_FULL { return 26u64 }
    /* KAT 5: absent K1 -> E_ABSENT. */
    if ml_lookup((&MEMOL_T_K1 as u64) as *u8, (&MEMOL_T_OC as u64) as *u8, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_E_ABSENT { return 27u64 }
    if ml_mark_stale((&MEMOL_T_K1 as u64) as *u8) != MEMOL_E_ABSENT { return 28u64 }
    if ml_revalidate((&MEMOL_T_K1 as u64) as *u8) != MEMOL_E_ABSENT { return 29u64 }
    return 0u64
}

/* ml_st_phase3: ml_admit POSITIVE via cons_ratify of the cp_memo_admit clause
 * (KATs 2/6 in phase1/2 cover only the clause-absent refusal + the direct-slot
 * lookup bypass; the writer pre-staged cons_ratify + MEMOL_RATIFY_BUF for this).
 * Proves the governance transition on one key: ml_admit(K1) refuses while the
 * clause is unratified -- and as a side effect writes "cp_memo_admit" into
 * MEMOL_SCR_CLAUSE_LABEL (it writes the label before the clause gate) -- then
 * after cons_ratify of that exact clause the SAME call admits.  CH1 was
 * registered by phase2 (fb); K1 was only the absent key, so its slot is free. */
fn ml_st_phase3() -> u64 {
    /* Before ratification: refuse (clause absent); populates the label. */
    if ml_admit((&MEMOL_T_K1 as u64) as *u8, (&MEMOL_T_C1 as u64) as *u8, (&MEMOL_T_CH1 as u64) as *u8) != MEMOL_E_CLAUSE_ABSENT { return 30u64 }
    /* Ratify cp_memo_admit.  req[56]: out_cid@0 textual@8 textual_len@16
     * ltl@24 ltl_len@32 pred@40 pred_len@48 (ltl/pred unused, len 0).  The
     * out_cid sink lives at byte 64 of MEMOL_RATIFY_BUF, past the 56-byte req. */
    let reqbase : u64 = &MEMOL_RATIFY_BUF as u64
    let labaddr : u64 = &MEMOL_SCR_CLAUSE_LABEL as u64
    let rqp : *u64 = reqbase as *u64
    rqp[0u64] = reqbase + 64u64
    rqp[1u64] = labaddr
    rqp[2u64] = 13u64
    rqp[3u64] = labaddr
    rqp[4u64] = 0u64
    rqp[5u64] = labaddr
    rqp[6u64] = 0u64
    let fr : u64 = cons_ratify(reqbase as *u8)
    if fr == 0xFFFFFFFFFFFFFFFFu64 { return 31u64 }
    /* After ratification: the same call now admits (clause present, CH1 live). */
    if ml_admit((&MEMOL_T_K1 as u64) as *u8, (&MEMOL_T_C1 as u64) as *u8, (&MEMOL_T_CH1 as u64) as *u8) != MEMOL_OK { return 32u64 }
    /* Lookup K1 -> OK with C1, CH1, k=K_FULL. */
    if ml_lookup((&MEMOL_T_K1 as u64) as *u8, (&MEMOL_T_OC as u64) as *u8, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_OK { return 33u64 }
    let mut acc : u32 = 0u32
    let mut ai : u64 = 0u64
    while ai < 32u64 {
        acc = acc | ((MEMOL_T_OC[ai] as u32) ^ (MEMOL_T_C1[ai] as u32))
        acc = acc | ((MEMOL_T_OCH[ai] as u32) ^ (MEMOL_T_CH1[ai] as u32))
        ai = ai + 1u64
    }
    if acc != 0u32 { return 34u64 }
    if MEMOL_T_KM[0u64] != MEMOL_K_FULL { return 35u64 }
    /* Negative: re-admit K1 -> E_DUPLICATE (clause+chain OK, key already live). */
    if ml_admit((&MEMOL_T_K1 as u64) as *u8, (&MEMOL_T_C1 as u64) as *u8, (&MEMOL_T_CH1 as u64) as *u8) != MEMOL_E_DUPLICATE { return 36u64 }
    /* Negative: unregistered chain (MEMOL_T_K1 = 0xAA*32, never a published fid)
     * -> E_VERIFY_FAIL.  The chain gate precedes the dup gate, so K0 being live
     * is irrelevant -- the chain check fires first. */
    if ml_admit((&MEMOL_T_K0 as u64) as *u8, (&MEMOL_T_C1 as u64) as *u8, (&MEMOL_T_K1 as u64) as *u8) != MEMOL_E_VERIFY_FAIL { return 37u64 }
    return 0u64
}

/* ml_st_phase4: the M17 single-call TRUSTED read (ml_lookup_verified).  POSITIVE: an entry whose chain IS
 * registered in the spine -> MEMOL_OK.  NEGATIVE (prove-the-gap): a LIVE, non-stale entry whose chain was NEVER
 * ws_register'd -> ml_lookup ALONE returns OK (present, not stale), but ml_lookup_verified catches the
 * untrusted chain and returns MEMOL_E_VERIFY_FAIL -- the footgun the header warns about, now removed. */
fn ml_st_phase4() -> u64 {
    wh_init(0u64)
    ws_init()
    MEMOL_INITED = 0u8
    ml_init()
    let mut zz : u64 = 0u64
    while zz < 32u64 { MEMOL_SCR_ZEROSLOT[zz] = 0u8  zz = zz + 1u64 }
    let zp : *u8 = (&MEMOL_SCR_ZEROSLOT as u64) as *u8
    /* CH0 published AND registered (trusted); CH1 published but NOT registered (untrusted). */
    let fa : u64 = wh_publish(zp, zp, zp, (&MEMOL_T_C0 as u64) as *u8, 0u8, 0u8, 0xEu16, zp, 0u32, zp, 0u32, (&MEMOL_T_CH0 as u64) as *u8)
    if fa == 0xFFFFFFFFFFFFFFFFu64 { return 40u64 }
    ws_register(fa)
    let fb : u64 = wh_publish(zp, zp, zp, (&MEMOL_T_C1 as u64) as *u8, 0u8, 0u8, 0xEu16, zp, 0u32, zp, 0u32, (&MEMOL_T_CH1 as u64) as *u8)
    if fb == 0xFFFFFFFFFFFFFFFFu64 { return 41u64 }
    /* entry A: K0 with the registered chain CH0 -> trusted */
    let sa64 : i64 = ml_slot_alloc((&MEMOL_T_K0 as u64) as *u8)
    if sa64 == -1i64 { return 42u64 }
    let sa : u64 = sa64 as u64
    let mut dw : u64 = 0u64
    while dw < 32u64 {
        let kp : *u8 = (&MEMOL_KEYS as u64 + sa * 32u64 + dw) as *u8
        let ocp : *u8 = (&MEMOL_OUT_COMMITS as u64 + sa * 32u64 + dw) as *u8
        let chp : *u8 = (&MEMOL_CHAIN_IDS as u64 + sa * 32u64 + dw) as *u8
        kp[0u64] = MEMOL_T_K0[dw]
        ocp[0u64] = MEMOL_T_C0[dw]
        chp[0u64] = MEMOL_T_CH0[dw]
        dw = dw + 1u64
    }
    let lp : *u8 = (&MEMOL_LIVE as u64 + sa) as *u8
    let stp : *u8 = (&MEMOL_STALE as u64 + sa) as *u8
    let kmp : *u8 = (&MEMOL_K_MEMO as u64 + sa) as *u8
    lp[0u64] = 1u8  stp[0u64] = 0u8  kmp[0u64] = MEMOL_K_FULL
    MEMOL_COUNT = MEMOL_COUNT + 1u64
    if ml_lookup_verified((&MEMOL_T_K0 as u64) as *u8, (&MEMOL_T_OC as u64) as *u8, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_OK { return 43u64 }
    /* entry B: K1 with the UNREGISTERED chain CH1 -> untrusted */
    let sb64 : i64 = ml_slot_alloc((&MEMOL_T_K1 as u64) as *u8)
    if sb64 == -1i64 { return 44u64 }
    let sb : u64 = sb64 as u64
    let mut ew : u64 = 0u64
    while ew < 32u64 {
        let kp2 : *u8 = (&MEMOL_KEYS as u64 + sb * 32u64 + ew) as *u8
        let ocp2 : *u8 = (&MEMOL_OUT_COMMITS as u64 + sb * 32u64 + ew) as *u8
        let chp2 : *u8 = (&MEMOL_CHAIN_IDS as u64 + sb * 32u64 + ew) as *u8
        kp2[0u64] = MEMOL_T_K1[ew]
        ocp2[0u64] = MEMOL_T_C1[ew]
        chp2[0u64] = MEMOL_T_CH1[ew]
        ew = ew + 1u64
    }
    let lp2 : *u8 = (&MEMOL_LIVE as u64 + sb) as *u8
    let stp2 : *u8 = (&MEMOL_STALE as u64 + sb) as *u8
    let kmp2 : *u8 = (&MEMOL_K_MEMO as u64 + sb) as *u8
    lp2[0u64] = 1u8  stp2[0u64] = 0u8  kmp2[0u64] = MEMOL_K_FULL
    MEMOL_COUNT = MEMOL_COUNT + 1u64
    /* ml_lookup ALONE says OK (present, not stale) -- the footgun; ml_lookup_verified catches the untrusted chain */
    if ml_lookup((&MEMOL_T_K1 as u64) as *u8, (&MEMOL_T_OC as u64) as *u8, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_OK { return 45u64 }
    if ml_lookup_verified((&MEMOL_T_K1 as u64) as *u8, (&MEMOL_T_OC as u64) as *u8, (&MEMOL_T_OCH as u64) as *u8, (&MEMOL_T_KM as u64) as *u8) != MEMOL_E_VERIFY_FAIL { return 46u64 }
    return 0u64
}

fn ml_selftest() -> u64 @export {
    /* Reset lattice and witness subsystems. */
    wh_init(0u64)
    ws_init()
    MEMOL_INITED = 0u8
    ml_init()
    /* Build test keys: K0=0x00..0x1F, K1=0xAA, C0=0x64..., C1=0xC8... */
    let mut bi : u64 = 0u64
    while bi < 32u64 {
        MEMOL_T_K0[bi] = bi as u8
        MEMOL_T_K1[bi] = 0xAAu8
        MEMOL_T_C0[bi] = (bi + 100u64) as u8
        MEMOL_T_C1[bi] = (bi + 200u64) as u8
        bi = bi + 1u64
    }
    let r1 : u64 = ml_st_phase1()
    if r1 != 0u64 { return r1 }
    let r2 : u64 = ml_st_phase2()
    if r2 != 0u64 { return r2 }
    let r3 : u64 = ml_st_phase3()
    if r3 != 0u64 { return r3 }
    let r4 : u64 = ml_st_phase4()
    if r4 != 0u64 { return r4 }
    return 99u64
}

/* Ontological footer: memo_lattice IS the substrate's M17-sovereign
 * content-addressed result cache. It embodies four aspects simultaneously:
 *   - INTEGRITY: every admission verifies the producing chain before insertion;
 *     an unverifiable result never enters the lattice.
 *   - TRANSPARENCY: every state transition (admit/hit/stale/reval) emits a
 *     chained witness fragment, ensuring no silent mutation.
 *   - SOVEREIGNTY: stale entries remain resident (forensic anchor, M6);
 *     revalidation is the only path back to a live entry (W50).
 *   - GOVERNANCE: the cp_memo_admit clause gates every admission (M8), making
 *     memoization a ratifiable, revocable substrate capability.
 */
