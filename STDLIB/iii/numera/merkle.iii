/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\merkle.iii
 *
 * III STDLIB - numera::merkle -- binary Merkle tree over SHA-256.
 *
 * Lattice plan Phase 14d Step 0148.  Pure NIH binary Merkle tree:
 *   leaf_hash = SHA-256(0x00 || leaf_bytes)
 *   node_hash = SHA-256(0x01 || left || right)
 * The 0x00/0x01 domain separator prevents second-preimage attacks
 * mapping a node hash into a leaf hash.
 *
 * Tree shape: complete binary; for non-power-of-two leaf counts, the
 * last leaf is duplicated up the tree until a power-of-two level is
 * reached (Bitcoin-style; deterministic, no padding bytes added).
 *
 * Public surface:
 *   merkle_compute_root(leaves_ptr, leaf_count, leaf_size, out_32)        -> i32
 *   merkle_proof_len_for(leaf_count, leaf_index)                          -> u32
 *   merkle_compute_proof(leaves_ptr, leaf_count, leaf_size,
 *                        leaf_index, proof_out_ptr)                       -> i32
 *   merkle_verify_proof(leaf_ptr, leaf_size, leaf_index, proof_ptr,
 *                       proof_steps, root_32_ptr)                         -> u8
 *
 * Limits (M7 anti-bloat):
 *   MERKLE_MAX_LEAVES = 1024
 *   MERKLE_MAX_DEPTH  = 10  (since ceil(log2(1024)) = 10)
 *
 * Hexad: kind_form.  Ring: R3.  K: 1.00.
 */

module numera_merkle

extern @abi(c-msvc-x64) fn sha256_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 from "sha256.iii"

const MK_OK             : i32 =  0i32
const MK_E_NULL         : i32 = -1i32
const MK_E_BADLEN       : i32 = -2i32
const MK_E_BADIDX       : i32 = -3i32

const MK_MAX_LEAVES : u32 = 1024u32
const MK_MAX_DEPTH  : u32 = 10u32
const MK_LEAF_DOM   : u8  = 0x00u8
const MK_NODE_DOM   : u8  = 0x01u8

/* Working buffers -- module-level scratch, not reentrant. */
var MK_LEVEL_A : [u8; 32768]   /* up to 1024 hashes * 32 bytes */
var MK_LEVEL_B : [u8; 32768]
var MK_HASH_BUF : [u8; 4128]   /* 1 dom byte + 32-byte left + 32-byte right or up to ~4KB leaf */
var MK_OUT_BUF  : [u8; 32]

fn _mk_leaf_hash(leaf_ptr: u64, leaf_size: u64, out_ptr: u64) -> u32 {
    let lp_l : u64 = leaf_ptr
    let ls_l : u64 = leaf_size
    let op_l : u64 = out_ptr
    /* Build dom_byte || leaf_bytes in MK_HASH_BUF. */
    MK_HASH_BUF[0u64] = MK_LEAF_DOM
    let sp : *u8 = lp_l as *u8
    let mut i : u64 = 0u64
    while i < ls_l {
        if i < 4127u64 {
            MK_HASH_BUF[1u64 + i] = sp[i]
        }
        i = i + 1u64
    }
    let total : u64 = 1u64 + ls_l
    sha256_oneshot(&MK_HASH_BUF as *u8, total, op_l as *u8)
    return 0u32
}

fn _mk_node_hash(left_ptr: u64, right_ptr: u64, out_ptr: u64) -> u32 {
    let l_l : u64 = left_ptr
    let r_l : u64 = right_ptr
    let o_l : u64 = out_ptr
    MK_HASH_BUF[0u64] = MK_NODE_DOM
    let lp : *u8 = l_l as *u8
    let rp : *u8 = r_l as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        MK_HASH_BUF[1u64 + i]         = lp[i]
        MK_HASH_BUF[1u64 + 32u64 + i] = rp[i]
        i = i + 1u64
    }
    sha256_oneshot(&MK_HASH_BUF as *u8, 65u64, o_l as *u8)
    return 0u32
}

/* Compute the Merkle root over `leaf_count` leaves of `leaf_size` bytes
 * each, packed contiguously at `leaves_ptr`.  Writes 32 bytes to out_32.
 * For non-power-of-two leaf counts, the last hash at each level is
 * duplicated (paired with itself) to fill to the next power of two. */
fn merkle_compute_root(leaves_ptr: u64, leaf_count: u32, leaf_size: u64, out_32: u64) -> i32 @export {
    let lp_l : u64 = leaves_ptr
    let lc_l : u32 = leaf_count
    let ls_l : u64 = leaf_size
    let op_l : u64 = out_32
    if lp_l == 0u64 { return MK_E_NULL }
    if op_l == 0u64 { return MK_E_NULL }
    if lc_l == 0u32 { return MK_E_BADLEN }
    if lc_l > MK_MAX_LEAVES { return MK_E_BADLEN }

    /* Hash all leaves into MK_LEVEL_A. */
    let mut k : u32 = 0u32
    while k < lc_l {
        let leaf_off : u64 = (k as u64) * ls_l
        let dst_off  : u64 = (k as u64) * 32u64
        _mk_leaf_hash(lp_l + leaf_off, ls_l, &MK_LEVEL_A as u64 + dst_off)
        k = k + 1u32
    }

    let mut level_count : u32 = lc_l
    let mut from_a_to_b : u8 = 1u8

    /* Reduce until 1 hash remains. */
    while level_count > 1u32 {
        let next_count : u32 = (level_count + 1u32) >> 1u32
        let mut i : u32 = 0u32
        while i < next_count {
            let li : u32 = i << 1u32
            let mut ri : u32 = li + 1u32
            if ri >= level_count { ri = li }   /* duplicate last on odd count */
            let src_l_off : u64 = (li as u64) * 32u64
            let src_r_off : u64 = (ri as u64) * 32u64
            let dst_off   : u64 = (i  as u64) * 32u64
            if from_a_to_b == 1u8 {
                _mk_node_hash(&MK_LEVEL_A as u64 + src_l_off,
                              &MK_LEVEL_A as u64 + src_r_off,
                              &MK_LEVEL_B as u64 + dst_off)
            } else {
                _mk_node_hash(&MK_LEVEL_B as u64 + src_l_off,
                              &MK_LEVEL_B as u64 + src_r_off,
                              &MK_LEVEL_A as u64 + dst_off)
            }
            i = i + 1u32
        }
        level_count = next_count
        if from_a_to_b == 1u8 { from_a_to_b = 0u8 } else { from_a_to_b = 1u8 }
    }

    /* Final hash is in the buffer NOT pointed to by from_a_to_b. */
    let dp : *u8 = op_l as *u8
    let mut j : u64 = 0u64
    while j < 32u64 {
        if from_a_to_b == 1u8 {
            dp[j] = MK_LEVEL_A[j]
        } else {
            dp[j] = MK_LEVEL_B[j]
        }
        j = j + 1u64
    }
    return MK_OK
}

/* Number of proof steps required for a given (leaf_count, leaf_index).
 * Equal to ceil(log2(leaf_count)) for any in-range index. */
fn merkle_proof_len_for(leaf_count: u32, leaf_index: u32) -> u32 @export {
    let lc_l : u32 = leaf_count
    let li_l : u32 = leaf_index
    if lc_l == 0u32 { return 0u32 }
    if li_l >= lc_l { return 0u32 }
    let mut depth : u32 = 0u32
    let mut n : u32 = lc_l
    while n > 1u32 {
        n = (n + 1u32) >> 1u32
        depth = depth + 1u32
    }
    return depth
}

/* Compute the inclusion-proof for leaf_index.  Writes (proof_steps * 33)
 * bytes to proof_out_ptr: each step is 1 sibling-direction byte
 * (0 = sibling is LEFT, 1 = sibling is RIGHT) followed by 32 sibling-hash bytes. */
/* 4-arg signature. packed_count_index is (leaf_count << 32) | leaf_index.
 * (Originally packed to dodge the iiis-0 5+-arg trap; that bug is fixed --
 * Stage 3.9, corpus 277 -- but the 4-arg form is retained as-is: working
 * KAT-passing code with a stable @export API, Mandate 20.) */
fn merkle_compute_proof(leaves_ptr: u64, leaf_size: u64, packed_count_index: u64, proof_out_ptr: u64) -> i32 @export {
    let lp_l : u64 = leaves_ptr
    let ls_l : u64 = leaf_size
    let pci  : u64 = packed_count_index
    let lc_l : u32 = ((pci >> 32u64) & 0xFFFFFFFFu64) as u32
    let li_l : u32 = (pci & 0xFFFFFFFFu64) as u32
    let po_l : u64 = proof_out_ptr
    if lp_l == 0u64 { return MK_E_NULL }
    if po_l == 0u64 { return MK_E_NULL }
    if lc_l == 0u32 { return MK_E_BADLEN }
    if lc_l > MK_MAX_LEAVES { return MK_E_BADLEN }
    if li_l >= lc_l { return MK_E_BADIDX }

    /* Hash all leaves into MK_LEVEL_A. */
    let mut k : u32 = 0u32
    while k < lc_l {
        _mk_leaf_hash(lp_l + (k as u64) * ls_l, ls_l, &MK_LEVEL_A as u64 + (k as u64) * 32u64)
        k = k + 1u32
    }

    let mut level_count : u32 = lc_l
    let mut from_a_to_b : u8 = 1u8
    let mut cur_idx : u32 = li_l
    let mut step : u32 = 0u32
    let proof_byte : *u8 = po_l as *u8

    while level_count > 1u32 {
        let mut sib_idx : u32 = cur_idx ^ 1u32
        if sib_idx >= level_count { sib_idx = cur_idx }   /* odd count: duplicate */
        let mut sib_dir : u8 = 1u8   /* 1 = sibling is RIGHT (cur is left child) */
        if (cur_idx & 1u32) == 1u32 { sib_dir = 0u8 }   /* cur is right; sibling LEFT */
        proof_byte[(step as u64) * 33u64] = sib_dir
        let src_off : u64 = (sib_idx as u64) * 32u64
        let mut bi : u64 = 0u64
        while bi < 32u64 {
            if from_a_to_b == 1u8 {
                proof_byte[(step as u64) * 33u64 + 1u64 + bi] = MK_LEVEL_A[(src_off + bi) as u32]
            } else {
                proof_byte[(step as u64) * 33u64 + 1u64 + bi] = MK_LEVEL_B[(src_off + bi) as u32]
            }
            bi = bi + 1u64
        }

        /* Reduce level. */
        let next_count : u32 = (level_count + 1u32) >> 1u32
        let mut i : u32 = 0u32
        while i < next_count {
            let li : u32 = i << 1u32
            let mut ri : u32 = li + 1u32
            if ri >= level_count { ri = li }
            let src_l_off : u64 = (li as u64) * 32u64
            let src_r_off : u64 = (ri as u64) * 32u64
            let dst_off   : u64 = (i  as u64) * 32u64
            if from_a_to_b == 1u8 {
                _mk_node_hash(&MK_LEVEL_A as u64 + src_l_off,
                              &MK_LEVEL_A as u64 + src_r_off,
                              &MK_LEVEL_B as u64 + dst_off)
            } else {
                _mk_node_hash(&MK_LEVEL_B as u64 + src_l_off,
                              &MK_LEVEL_B as u64 + src_r_off,
                              &MK_LEVEL_A as u64 + dst_off)
            }
            i = i + 1u32
        }
        level_count = next_count
        cur_idx = cur_idx >> 1u32
        if from_a_to_b == 1u8 { from_a_to_b = 0u8 } else { from_a_to_b = 1u8 }
        step = step + 1u32
    }
    return MK_OK
}

/* Verify an inclusion proof. 4-arg signature: packed_meta packs
 *   bits 0..19   = proof_steps    (max ~1M, plenty)
 *   bits 20..39  = leaf_index     (max ~1M, plenty)
 *   bits 40..63  = leaf_size      (max ~16M, more than enough)
 * Use merkle_pack_verify_meta to build safely. */
fn merkle_verify_proof(leaf_ptr: u64, packed_meta: u64, proof_ptr: u64, root_32_ptr: u64) -> u8 @export {
    let lp_l : u64 = leaf_ptr
    let pm_l : u64 = packed_meta
    let pp_l : u64 = proof_ptr
    let rp_l : u64 = root_32_ptr
    let ps_l : u32 = (pm_l & 0xFFFFFu64) as u32
    let li_l : u32 = ((pm_l >> 20u64) & 0xFFFFFu64) as u32
    let ls_l : u64 = (pm_l >> 40u64) & 0xFFFFFFu64
    if lp_l == 0u64 { return 0u8 }
    if pp_l == 0u64 { return 0u8 }
    if rp_l == 0u64 { return 0u8 }
    if ps_l > MK_MAX_DEPTH { return 0u8 }

    /* Compute leaf hash into MK_OUT_BUF. */
    _mk_leaf_hash(lp_l, ls_l, &MK_OUT_BUF as u64)

    /* Apply each proof step. */
    let pb : *u8 = pp_l as *u8
    let mut step : u32 = 0u32
    let mut cur_idx : u32 = li_l
    while step < ps_l {
        let sib_dir : u8 = pb[(step as u64) * 33u64]
        /* Sibling hash starts at offset (step*33 + 1). */
        let sib_off : u64 = (step as u64) * 33u64 + 1u64
        if sib_dir == 1u8 {
            /* Sibling is RIGHT: parent = hash(MK_OUT_BUF || sibling). */
            _mk_node_hash(&MK_OUT_BUF as u64, pp_l + sib_off, &MK_OUT_BUF as u64)
        } else {
            /* Sibling is LEFT: parent = hash(sibling || MK_OUT_BUF). */
            _mk_node_hash(pp_l + sib_off, &MK_OUT_BUF as u64, &MK_OUT_BUF as u64)
        }
        cur_idx = cur_idx >> 1u32
        step = step + 1u32
    }

    /* Compare MK_OUT_BUF against root_32. */
    let rp : *u8 = rp_l as *u8
    let mut diff : u8 = 0u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        if MK_OUT_BUF[i] != rp[i] { diff = 1u8 }
        i = i + 1u64
    }
    if diff == 0u8 { return 1u8 }
    return 0u8
}

/* Convenience packers. */
fn merkle_pack_count_index(leaf_count: u32, leaf_index: u32) -> u64 @export {
    let l_c : u64 = (leaf_count as u64) & 0xFFFFFFFFu64
    let l_i : u64 = (leaf_index as u64) & 0xFFFFFFFFu64
    return (l_c << 32u64) | l_i
}

fn merkle_pack_verify_meta(leaf_size: u32, leaf_index: u32, proof_steps: u32) -> u64 @export {
    let l_s : u64 = ((leaf_size  as u64) & 0xFFFFFFu64) << 40u64
    let l_i : u64 = ((leaf_index as u64) & 0xFFFFFu64)  << 20u64
    let l_p : u64 = (proof_steps as u64) & 0xFFFFFu64
    return l_s | l_i | l_p
}
