/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\merkle_log.iii
 *
 * III STDLIB - numera::merkle_log  --  AUTHENTICATED APPEND-ONLY LOG (Merkle inclusion, verified).
 *
 * The data structure under certificate transparency and a zero-trust ledger: a Merkle tree over the log
 * entries whose ROOT commits to every leaf at once.  Any entry's membership is proven by a logarithmic path
 * of SIBLING hashes -- recompute the root from the leaf and its siblings and it must equal the published
 * root -- so a verifier trusts the whole log from a single hash plus a tiny proof.  Tampering with any entry
 * changes the root, which is exactly what makes the log tamper-evident.
 *
 * Four entries form a balanced tree; root = mix(mix(l0,l1), mix(l2,l3)).  The inclusion path for a leaf is
 * its sibling leaf and the opposite subtree hash, combined in the order its index dictates (left/right).
 *
 * Verified (merkle_log_kat): the root is deterministic; every genuine leaf's inclusion proof recomputes the
 * root; a tampered value fails verification for left and right leaves alike; the left/right combination
 * order is respected.  NIH/self-contained.
 *
 * Public API:
 *   mtree_setup() ; mtree_mix(a,b) -> u32 ; mtree_root() -> u32 ; mtree_sib0(idx) -> u32 ;
 *   mtree_sib1(idx) -> u32 ; mtree_verify(idx,val) -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_merkle_log

var MTREE_LEAF : [u32; 4]

fn mtree_mix(a: u32, b: u32) -> u32 @export {
    return (a * 1000003u32) + b                  /* a deterministic 2-to-1 combine (wraps in u32) */
}

fn mtree_setup() -> i32 @export {
    MTREE_LEAF[0u64]=11u32 ; MTREE_LEAF[1u64]=22u32 ; MTREE_LEAF[2u64]=33u32 ; MTREE_LEAF[3u64]=44u32
    return 0i32
}

fn mtree_root() -> u32 @export {
    let h01 : u32 = mtree_mix(MTREE_LEAF[0u64], MTREE_LEAF[1u64])
    let h23 : u32 = mtree_mix(MTREE_LEAF[2u64], MTREE_LEAF[3u64])
    return mtree_mix(h01, h23)
}

/* the level-0 sibling: the adjacent leaf (flip the low index bit). */
fn mtree_sib0(idx: u32) -> u32 @export { return MTREE_LEAF[(idx ^ 1u32) as u64] }

/* the level-1 sibling: the hash of the opposite subtree. */
fn mtree_sib1(idx: u32) -> u32 @export {
    if idx < 2u32 { return mtree_mix(MTREE_LEAF[2u64], MTREE_LEAF[3u64]) }
    return mtree_mix(MTREE_LEAF[0u64], MTREE_LEAF[1u64])
}

/* verify that value `val` at leaf `idx` is included: recompute the root via the sibling path. */
fn mtree_verify(idx: u32, val: u32) -> u32 @export {
    let s0 : u32 = mtree_sib0(idx)
    let s1 : u32 = mtree_sib1(idx)
    let mut h : u32 = val
    /* level 0: the leaf's position decides left/right */
    if (idx & 1u32) == 0u32 { h = mtree_mix(h, s0) }
    if (idx & 1u32) == 1u32 { h = mtree_mix(s0, h) }
    /* level 1: the subtree's position decides left/right */
    if ((idx >> 1u32) & 1u32) == 0u32 { h = mtree_mix(h, s1) }
    if ((idx >> 1u32) & 1u32) == 1u32 { h = mtree_mix(s1, h) }
    if h == mtree_root() { return 1u32 }
    return 0u32
}

/* =====================================================================================
 * merkle_log_kat -- 99 = the authenticated log is sound, self-checked:
 *   (1) the root is deterministic (recomputing gives the same value);
 *   (2) every genuine leaf's inclusion proof recomputes the published root;
 *   (3) a tampered value fails verification, for a left leaf and a right leaf alike;
 *   (4) the left/right combination order matters (a right leaf verifies only in right position).
 * ===================================================================================== */
fn merkle_log_kat() -> u64 @export {
    mtree_setup()

    /* (1) deterministic root */
    if mtree_root() != mtree_root() { return 1u64 }

    /* (2) genuine inclusion proofs */
    if mtree_verify(0u32, 11u32) != 1u32 { return 2u64 }
    if mtree_verify(1u32, 22u32) != 1u32 { return 3u64 }
    if mtree_verify(2u32, 33u32) != 1u32 { return 4u64 }
    if mtree_verify(3u32, 44u32) != 1u32 { return 5u64 }

    /* (3) tampered values rejected (left subtree leaf 0, right subtree leaf 2) */
    if mtree_verify(0u32, 12u32) != 0u32 { return 6u64 }
    if mtree_verify(2u32, 999u32) != 0u32 { return 7u64 }

    /* (4) order sensitivity: leaf 2's value placed at the wrong index does not verify there */
    if mtree_verify(1u32, 33u32) != 0u32 { return 8u64 }

    return 99u64
}
