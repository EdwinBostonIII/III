/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\mldsa.iii
 *
 * III STDLIB - numera::mldsa -- ML-DSA (FIPS 204 / Dilithium) signature.
 * RITCHIE Stage 4.4.1: native .iii port of the now-correct (post-4.3)
 * CRYPTO-AGILITY/src/mldsa.c.  q = 8380417, n = 256, d = 13.
 *
 * Arithmetic is UNSIGNED mod-q throughout (coeffs in [0,q); values > (q-1)/2
 * represent negatives).  This dodges the iiis signed-i64/i32 ordering traps
 * (W11/3.12) -- every signed compare from the C ref is reformulated to an
 * unsigned mod-q compare (proven equivalent by standalone probes, 4.4.1).
 *
 * Storage: a flat pool of 256-coeff slots; a "poly" is a slot index.  The
 * NTT/invNTT run on a dedicated WORK slot (the verbatim proven probe code,
 * no slot-offset) with copy-in/out; per-coeff ops are slot-indexed directly.
 *
 * Public surface (byte-identical to the C ref for cross-KAT):
 *   iii_mldsa_keygen(level, seed, pk, sk) -> i32
 *   iii_mldsa_sign(level, sk, msg, msglen, sig, siglen_ptr) -> i32
 *   iii_mldsa_verify(level, pk, msg, msglen, sig, siglen) -> i32
 *
 * Hexad: kind_prove.  Ring: R3.  K: 1.00.
 */

module numera_mldsa

extern @abi(c-msvc-x64) fn keccak_state_zero(state_ptr: u64) -> i32 from "keccak.iii"
extern @abi(c-msvc-x64) fn keccak_absorb(state_ptr: u64, msg_ptr: u64, msg_len: u64, rate_dom: u64) -> i32 from "keccak.iii"
extern @abi(c-msvc-x64) fn keccak_squeeze(state_ptr: u64, out_ptr: u64, out_len: u64, rate_bytes: u32) -> i32 from "keccak.iii"
extern @abi(c-msvc-x64) fn keccak_pack_rate_dom(rate_bytes: u32, dom_sep: u8) -> u64 from "keccak.iii"
extern @abi(c-msvc-x64) fn keccak_f1600(state_ptr: u64) -> i32 from "keccak.iii"
/* W0.7 / COMBINE-1: the Dilithium NTT butterfly now lives in the shared organ
 * (numera/ntt.iii); mldsa_ntt_work/mldsa_invntt_work delegate to the tabled cores
 * (min_len=1 -> complete; start_k=255).  MLDSA_ZETAS is u64 so the organ's u64
 * zeta-table reader can index it directly.  Final ×n^-1 inverse scale stays here. */
/* APOTHEOSIS C.1: the per-q descriptor over the same organ (consumes ntt_ctx). */
extern @abi(c-msvc-x64) fn ntt_ctx_forward(row: u64, base: u64, zeta_addr: u64) -> i32 from "ntt_ctx.iii"
extern @abi(c-msvc-x64) fn ntt_ctx_inverse(row: u64, base: u64, zeta_addr: u64) -> i32 from "ntt_ctx.iii"
extern @abi(c-msvc-x64) fn ntt_ctx_mldsa() -> u64 from "ntt_ctx.iii"
/* W0.5: Montgomery-form zetas for the organ NTT cores (Dilithium pointwise is
 * zeta-free, so no plain-zeta consumer remains -- MLDSA_ZETAS_MONT[i]=ZETAS[i]*R mod q). */
extern @abi(c-msvc-x64) fn mont_to_form(a: u64, n: u64) -> u64 from "modular_mont.iii"

const MLDSA_Q  : u64 = 8380417u64
const MLDSA_QH : u64 = 4190208u64    /* (q-1)/2 */
const MLDSA_N  : u64 = 256u64

/* zeta^brv(i) mod q, plain domain, computed once.  u64 so the shared NTT organ's
 * u64 zeta-table reader can index it directly (W0.7); values < q < 2^23. */
var MLDSA_ZETAS : [u64; 256]
var MLDSA_ZETAS_MONT : [u64; 256]   /* Montgomery-form zetas for the NTT (W0.5) */
var MLDSA_ZINIT : [u32; 1]

/* slot pool: 160 slots of 256 coeffs.  A=k*l (<=56) + ~12 vectors of <=8
 * (sign's worst case) + scratch.  160*256 = 40960 u32 (160 KiB). */
var MLDSA_POOL : [u32; 40960]
var MLDSA_WORK : [u32; 256]     /* NTT/invNTT work slot (proven code) */

fn mldsa_powmod(base: u64, exp: u64) -> u64 {
    let mut r : u64 = 1u64
    let mut b : u64 = base % MLDSA_Q
    let mut e : u64 = exp
    while e > 0u64 {
        if (e & 1u64) == 1u64 { r = (r * b) % MLDSA_Q }
        b = (b * b) % MLDSA_Q
        e = e >> 1u64
    }
    return r
}

fn mldsa_init_zetas() -> i32 {
    if MLDSA_ZINIT[0] == 1u32 { return 0i32 }
    let mut i : u64 = 0u64
    while i < 256u64 {
        let mut br : u64 = 0u64
        let mut x : u64 = i
        let mut bb : u64 = 0u64
        while bb < 8u64 {
            br = (br << 1u64) | (x & 1u64)
            x = x >> 1u64
            bb = bb + 1u64
        }
        MLDSA_ZETAS[i] = mldsa_powmod(1753u64, br)
        i = i + 1u64
    }
    /* W0.5: derive the Montgomery-form zetas (ZETAS*R mod q) for the organ NTT cores. */
    let mut m : u64 = 0u64
    while m < 256u64 { MLDSA_ZETAS_MONT[m] = mont_to_form(MLDSA_ZETAS[m], MLDSA_Q)  m = m + 1u64 }
    MLDSA_ZINIT[0] = 1u32
    return 0i32
}

/* copy slot s -> WORK and WORK -> slot s */
fn mldsa_work_in(s: u64) -> i32 {
    let base : u64 = s * 256u64
    let mut j : u64 = 0u64
    while j < 256u64 { MLDSA_WORK[j] = MLDSA_POOL[base + j] ; j = j + 1u64 }
    return 0i32
}
fn mldsa_work_out(s: u64) -> i32 {
    let base : u64 = s * 256u64
    let mut j : u64 = 0u64
    while j < 256u64 { MLDSA_POOL[base + j] = MLDSA_WORK[j] ; j = j + 1u64 }
    return 0i32
}

/* Complete Dilithium NTT on WORK -- delegates to the shared organ (W0.7/COMBINE-1),
 * byte-identical to the prior inline transform. */
fn mldsa_ntt_work() -> i32 {
    return ntt_ctx_forward(ntt_ctx_mldsa(), (&MLDSA_WORK as u64), (&MLDSA_ZETAS_MONT as u64))
}
fn mldsa_invntt_work() -> i32 {
    ntt_ctx_inverse(ntt_ctx_mldsa(), (&MLDSA_WORK as u64), (&MLDSA_ZETAS_MONT as u64))
    /* Dilithium-specific final inverse scale (×256^-1 mod q). */
    let f : u64 = mldsa_powmod(256u64, MLDSA_Q - 2u64)
    let mut i : u64 = 0u64
    while i < 256u64 {
        MLDSA_WORK[i] = ((f * (MLDSA_WORK[i] as u64)) % MLDSA_Q) as u32
        i = i + 1u64
    }
    return 0i32
}

/* slot-level NTT/invNTT.  [E-MLD-3] IN PLACE at the pool slot: the shared organ
 * takes a base address (it indexes *u32, 4-byte stride -- the same packed
 * layout the typed MLDSA_POOL[i] access uses), so the 512 copy-moves per
 * transform (work_in + work_out) are gone.  The copy path is retained below
 * as the ORACLE (mldsa_ntt_scratch/mldsa_invntt_scratch); corpus 1494 drives
 * the in-module differential KAT proving slot-identical results both ways
 * plus the round-trip identity. */
fn mldsa_ntt(s: u64) -> i32 {
    mldsa_init_zetas()
    let base : u64 = (&MLDSA_POOL as u64) + s * 1024u64
    return ntt_ctx_forward(ntt_ctx_mldsa(), base, (&MLDSA_ZETAS_MONT as u64))
}
fn mldsa_invntt(s: u64) -> i32 {
    mldsa_init_zetas()
    let base : u64 = (&MLDSA_POOL as u64) + s * 1024u64
    ntt_ctx_inverse(ntt_ctx_mldsa(), base, (&MLDSA_ZETAS_MONT as u64))
    /* Dilithium-specific final inverse scale (x 256^-1 mod q), in place. */
    let f : u64 = mldsa_powmod(256u64, MLDSA_Q - 2u64)
    let pbase : u64 = s * 256u64
    let mut i : u64 = 0u64
    while i < 256u64 {
        MLDSA_POOL[pbase + i] = ((f * (MLDSA_POOL[pbase + i] as u64)) % MLDSA_Q) as u32
        i = i + 1u64
    }
    return 0i32
}

/* [E-MLD-3 ORACLE] the original copy-in/transform/copy-out path, verbatim. */
fn mldsa_ntt_scratch(s: u64) -> i32 {
    mldsa_init_zetas()
    mldsa_work_in(s)
    mldsa_ntt_work()
    mldsa_work_out(s)
    return 0i32
}
fn mldsa_invntt_scratch(s: u64) -> i32 {
    mldsa_init_zetas()
    mldsa_work_in(s)
    mldsa_invntt_work()
    mldsa_work_out(s)
    return 0i32
}

/* [E-MLD-3] the differential KAT (corpus 1494): the in-place transforms are
 * slot-identical to the scratch ORACLE, and ntt -> invntt is the identity.
 * Uses pool slots 0/1/2 as scratch (KAT-process only).  99 = pass. */
fn mldsa_ntt_inplace_kat() -> u64 @export {
    mldsa_init_zetas()
    /* deterministic fill < q into slot 0, copies into slots 1 and 2 */
    let mut x : u64 = 0x12345u64
    let mut i : u64 = 0u64
    while i < 256u64 {
        x = (x * 1103515245u64 + 12345u64) & 0x7FFFFFFFu64
        let v : u32 = (x % MLDSA_Q) as u32
        MLDSA_POOL[i] = v
        MLDSA_POOL[256u64 + i] = v
        MLDSA_POOL[512u64 + i] = v
        i = i + 1u64
    }
    /* forward: in-place slot 0 vs scratch slot 1 */
    mldsa_ntt(0u64)
    mldsa_ntt_scratch(1u64)
    i = 0u64
    while i < 256u64 {
        if MLDSA_POOL[i] != MLDSA_POOL[256u64 + i] { return 1u64 }
        i = i + 1u64
    }
    /* inverse: in-place slot 0 vs scratch slot 1 */
    mldsa_invntt(0u64)
    mldsa_invntt_scratch(1u64)
    i = 0u64
    while i < 256u64 {
        if MLDSA_POOL[i] != MLDSA_POOL[256u64 + i] { return 2u64 }
        i = i + 1u64
    }
    /* round-trip identity: slot 0 == the untouched original in slot 2 */
    i = 0u64
    while i < 256u64 {
        if MLDSA_POOL[i] != MLDSA_POOL[512u64 + i] { return 3u64 }
        i = i + 1u64
    }
    return 99u64
}

/* pointwise r = a (.) b ; add r = a + b ; sub r = a - b ; all mod q, slot-indexed */
fn mldsa_pointwise(rs: u64, as_: u64, bs: u64) -> i32 {
    let rb : u64 = rs * 256u64
    let ab : u64 = as_ * 256u64
    let bb : u64 = bs * 256u64
    let mut j : u64 = 0u64
    while j < 256u64 {
        let p : u64 = ((MLDSA_POOL[ab + j] as u64) * (MLDSA_POOL[bb + j] as u64)) % MLDSA_Q
        MLDSA_POOL[rb + j] = p as u32
        j = j + 1u64
    }
    return 0i32
}
fn mldsa_add(rs: u64, as_: u64, bs: u64) -> i32 {
    let rb : u64 = rs * 256u64
    let ab : u64 = as_ * 256u64
    let bb : u64 = bs * 256u64
    let mut j : u64 = 0u64
    while j < 256u64 {
        MLDSA_POOL[rb + j] = (((MLDSA_POOL[ab + j] as u64) + (MLDSA_POOL[bb + j] as u64)) % MLDSA_Q) as u32
        j = j + 1u64
    }
    return 0i32
}
fn mldsa_sub(rs: u64, as_: u64, bs: u64) -> i32 {
    let rb : u64 = rs * 256u64
    let ab : u64 = as_ * 256u64
    let bb : u64 = bs * 256u64
    let mut j : u64 = 0u64
    while j < 256u64 {
        MLDSA_POOL[rb + j] = (((MLDSA_POOL[ab + j] as u64) + MLDSA_Q - (MLDSA_POOL[bb + j] as u64)) % MLDSA_Q) as u32
        j = j + 1u64
    }
    return 0i32
}

/* reduce32: keep slot coeffs in [0,q) (already maintained; normalize copy) */
fn mldsa_caddq_slot(s: u64) -> i32 {
    let base : u64 = s * 256u64
    let mut j : u64 = 0u64
    while j < 256u64 {
        MLDSA_POOL[base + j] = ((MLDSA_POOL[base + j] as u64) % MLDSA_Q) as u32
        j = j + 1u64
    }
    return 0i32
}

/* ---- Per-level parameters (level 2/3/5 = ML-DSA-44/65/87). Precomputed
 * (no `1<<N` shifts -- avoids the literal-shift-in-paren trap, §4.4.1). ---- */
fn mldsa_k(level: u64) -> u64 { if level == 2u64 { return 4u64 } if level == 3u64 { return 6u64 } return 8u64 }
fn mldsa_l(level: u64) -> u64 { if level == 2u64 { return 4u64 } if level == 3u64 { return 5u64 } return 7u64 }
fn mldsa_eta(level: u64) -> u64 { if level == 3u64 { return 4u64 } return 2u64 }
fn mldsa_tau(level: u64) -> u64 { if level == 2u64 { return 39u64 } if level == 3u64 { return 49u64 } return 60u64 }
fn mldsa_omega(level: u64) -> u64 { if level == 2u64 { return 80u64 } if level == 3u64 { return 55u64 } return 75u64 }
fn mldsa_gamma1(level: u64) -> u64 { if level == 2u64 { return 131072u64 } return 524288u64 }
fn mldsa_gamma2(level: u64) -> u64 { if level == 2u64 { return 95232u64 } return 261888u64 }
fn mldsa_beta(level: u64) -> u64 { return mldsa_tau(level) * mldsa_eta(level) }
fn mldsa_polyz_packed(level: u64) -> u64 { if level == 2u64 { return 576u64 } return 640u64 }
fn mldsa_polyw1_packed(level: u64) -> u64 { if level == 2u64 { return 192u64 } return 128u64 }
fn mldsa_polyeta_packed(level: u64) -> u64 { if level == 3u64 { return 128u64 } return 96u64 }

/* ---- Rounding / hint (value fns, unsigned mod-q -- verbatim §4.4.1-proven).
 * decompose() writes its low part (mod-q) to DEC_A0[0] and returns a1. ---- */
var DEC_A0 : [u64; 1]

fn mldsa_power2round_a1(a: u64) -> u64 { return (a + 4095u64) >> 13u64 }
fn mldsa_power2round_a0(a: u64) -> u64 {
    let a1 : u64 = (a + 4095u64) >> 13u64
    let hi : u64 = (a1 << 13u64) % MLDSA_Q
    return (a + MLDSA_Q - hi) % MLDSA_Q
}
fn mldsa_decompose(a: u64, gamma2: u64) -> u64 {
    let mut a1 : u64 = (a + 127u64) >> 7u64
    if gamma2 == 261888u64 {
        a1 = (a1 * 1025u64 + 2097152u64) >> 22u64
        a1 = a1 & 15u64
    } else {
        a1 = (a1 * 11275u64 + 8388608u64) >> 24u64
        if a1 > 43u64 { a1 = 0u64 }
    }
    let prod : u64 = (a1 * 2u64 * gamma2) % MLDSA_Q
    DEC_A0[0] = (a + MLDSA_Q - prod) % MLDSA_Q
    return a1
}
fn mldsa_make_hint(a0: u64, a1: u64, gamma2: u64) -> u64 {
    if a0 > gamma2 {
        if a0 < MLDSA_Q - gamma2 { return 1u64 }
    }
    if a0 == MLDSA_Q - gamma2 {
        if a1 != 0u64 { return 1u64 }
    }
    return 0u64
}
fn mldsa_use_hint(a: u64, hint: u64, gamma2: u64) -> u64 {
    let a1 : u64 = mldsa_decompose(a, gamma2)
    if hint == 0u64 { return a1 }
    let a0 : u64 = DEC_A0[0]
    let mut pos : u64 = 0u64
    if a0 != 0u64 {
        if a0 <= MLDSA_QH { pos = 1u64 }
    }
    if gamma2 == 261888u64 {
        if pos == 1u64 { return (a1 + 1u64) & 15u64 }
        return (a1 + 15u64) & 15u64
    }
    if pos == 1u64 {
        if a1 == 43u64 { return 0u64 }
        return a1 + 1u64
    }
    if a1 == 0u64 { return 43u64 }
    return a1 - 1u64
}

/* ---- Bit packers (slot -> buf[off..] / buf[off..] -> slot).  Unsigned
 * mod-q; signed offset-coeff reproduced as (offset+q-coeff)%q (§4.4.1).
 * Byte writes via *u8 (§3.13).  Variable-left shifts only. ---- */
var MLDSA_T8 : [u64; 8]
var MLDSA_TZ : [u64; 4]

fn mldsa_polyt1_pack(s: u64, buf: u64, off: u64) -> i32 {
    let base : u64 = s * 256u64
    let o : *u8 = buf as *u8
    let mut i : u64 = 0u64
    while i < 64u64 {
        let a0 : u64 = MLDSA_POOL[base + 4u64*i + 0u64] as u64
        let a1 : u64 = MLDSA_POOL[base + 4u64*i + 1u64] as u64
        let a2 : u64 = MLDSA_POOL[base + 4u64*i + 2u64] as u64
        let a3 : u64 = MLDSA_POOL[base + 4u64*i + 3u64] as u64
        o[off + 5u64*i + 0u64] = (a0 & 0xFFu64) as u8
        o[off + 5u64*i + 1u64] = (((a0 >> 8u64) | (a1 << 2u64)) & 0xFFu64) as u8
        o[off + 5u64*i + 2u64] = (((a1 >> 6u64) | (a2 << 4u64)) & 0xFFu64) as u8
        o[off + 5u64*i + 3u64] = (((a2 >> 4u64) | (a3 << 6u64)) & 0xFFu64) as u8
        o[off + 5u64*i + 4u64] = ((a3 >> 2u64) & 0xFFu64) as u8
        i = i + 1u64
    }
    return 0i32
}
fn mldsa_polyt1_unpack(s: u64, buf: u64, off: u64) -> i32 {
    let base : u64 = s * 256u64
    let o : *u8 = buf as *u8
    let mut i : u64 = 0u64
    while i < 64u64 {
        let b0 : u64 = o[off + 5u64*i + 0u64] as u64
        let b1 : u64 = o[off + 5u64*i + 1u64] as u64
        let b2 : u64 = o[off + 5u64*i + 2u64] as u64
        let b3 : u64 = o[off + 5u64*i + 3u64] as u64
        let b4 : u64 = o[off + 5u64*i + 4u64] as u64
        MLDSA_POOL[base + 4u64*i + 0u64] = ((b0 | (b1 << 8u64)) & 0x3FFu64) as u32
        MLDSA_POOL[base + 4u64*i + 1u64] = (((b1 >> 2u64) | (b2 << 6u64)) & 0x3FFu64) as u32
        MLDSA_POOL[base + 4u64*i + 2u64] = (((b2 >> 4u64) | (b3 << 4u64)) & 0x3FFu64) as u32
        MLDSA_POOL[base + 4u64*i + 3u64] = (((b3 >> 6u64) | (b4 << 2u64)) & 0x3FFu64) as u32
        i = i + 1u64
    }
    return 0i32
}

fn mldsa_polyt0_pack(s: u64, buf: u64, off: u64) -> i32 {
    let base : u64 = s * 256u64
    let o : *u8 = buf as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        let mut j : u64 = 0u64
        while j < 8u64 {
            MLDSA_T8[j] = (4096u64 + MLDSA_Q - (MLDSA_POOL[base + 8u64*i + j] as u64)) % MLDSA_Q
            j = j + 1u64
        }
        o[off + 13u64*i + 0u64]  = (MLDSA_T8[0] & 0xFFu64) as u8
        o[off + 13u64*i + 1u64]  = (((MLDSA_T8[0] >> 8u64) | (MLDSA_T8[1] << 5u64)) & 0xFFu64) as u8
        o[off + 13u64*i + 2u64]  = ((MLDSA_T8[1] >> 3u64) & 0xFFu64) as u8
        o[off + 13u64*i + 3u64]  = (((MLDSA_T8[1] >> 11u64) | (MLDSA_T8[2] << 2u64)) & 0xFFu64) as u8
        o[off + 13u64*i + 4u64]  = (((MLDSA_T8[2] >> 6u64) | (MLDSA_T8[3] << 7u64)) & 0xFFu64) as u8
        o[off + 13u64*i + 5u64]  = ((MLDSA_T8[3] >> 1u64) & 0xFFu64) as u8
        o[off + 13u64*i + 6u64]  = (((MLDSA_T8[3] >> 9u64) | (MLDSA_T8[4] << 4u64)) & 0xFFu64) as u8
        o[off + 13u64*i + 7u64]  = ((MLDSA_T8[4] >> 4u64) & 0xFFu64) as u8
        o[off + 13u64*i + 8u64]  = (((MLDSA_T8[4] >> 12u64) | (MLDSA_T8[5] << 1u64)) & 0xFFu64) as u8
        o[off + 13u64*i + 9u64]  = (((MLDSA_T8[5] >> 7u64) | (MLDSA_T8[6] << 6u64)) & 0xFFu64) as u8
        o[off + 13u64*i + 10u64] = ((MLDSA_T8[6] >> 2u64) & 0xFFu64) as u8
        o[off + 13u64*i + 11u64] = (((MLDSA_T8[6] >> 10u64) | (MLDSA_T8[7] << 3u64)) & 0xFFu64) as u8
        o[off + 13u64*i + 12u64] = ((MLDSA_T8[7] >> 5u64) & 0xFFu64) as u8
        i = i + 1u64
    }
    return 0i32
}
fn mldsa_polyt0_unpack(s: u64, buf: u64, off: u64) -> i32 {
    let base : u64 = s * 256u64
    let o : *u8 = buf as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        let r0 : u64 = o[off + 13u64*i + 0u64] as u64
        let r1 : u64 = o[off + 13u64*i + 1u64] as u64
        let r2 : u64 = o[off + 13u64*i + 2u64] as u64
        let r3 : u64 = o[off + 13u64*i + 3u64] as u64
        let r4 : u64 = o[off + 13u64*i + 4u64] as u64
        let r5 : u64 = o[off + 13u64*i + 5u64] as u64
        let r6 : u64 = o[off + 13u64*i + 6u64] as u64
        let r7 : u64 = o[off + 13u64*i + 7u64] as u64
        let r8 : u64 = o[off + 13u64*i + 8u64] as u64
        let r9 : u64 = o[off + 13u64*i + 9u64] as u64
        let r10 : u64 = o[off + 13u64*i + 10u64] as u64
        let r11 : u64 = o[off + 13u64*i + 11u64] as u64
        let r12 : u64 = o[off + 13u64*i + 12u64] as u64
        MLDSA_T8[0] = (r0 | (r1 << 8u64)) & 0x1FFFu64
        MLDSA_T8[1] = ((r1 >> 5u64) | (r2 << 3u64) | (r3 << 11u64)) & 0x1FFFu64
        MLDSA_T8[2] = ((r3 >> 2u64) | (r4 << 6u64)) & 0x1FFFu64
        MLDSA_T8[3] = ((r4 >> 7u64) | (r5 << 1u64) | (r6 << 9u64)) & 0x1FFFu64
        MLDSA_T8[4] = ((r6 >> 4u64) | (r7 << 4u64) | (r8 << 12u64)) & 0x1FFFu64
        MLDSA_T8[5] = ((r8 >> 1u64) | (r9 << 7u64)) & 0x1FFFu64
        MLDSA_T8[6] = ((r9 >> 6u64) | (r10 << 2u64) | (r11 << 10u64)) & 0x1FFFu64
        MLDSA_T8[7] = ((r11 >> 3u64) | (r12 << 5u64)) & 0x1FFFu64
        let mut j : u64 = 0u64
        while j < 8u64 {
            MLDSA_POOL[base + 8u64*i + j] = ((4096u64 + MLDSA_Q - MLDSA_T8[j]) % MLDSA_Q) as u32
            j = j + 1u64
        }
        i = i + 1u64
    }
    return 0i32
}

fn mldsa_polyz_pack(s: u64, buf: u64, off: u64, gamma1: u64) -> i32 {
    let base : u64 = s * 256u64
    let o : *u8 = buf as *u8
    if gamma1 == 131072u64 {
        let mut i : u64 = 0u64
        while i < 64u64 {
            let mut j : u64 = 0u64
            while j < 4u64 {
                MLDSA_TZ[j] = (131072u64 + MLDSA_Q - (MLDSA_POOL[base + 4u64*i + j] as u64)) % MLDSA_Q
                j = j + 1u64
            }
            o[off + 9u64*i + 0u64] = (MLDSA_TZ[0] & 0xFFu64) as u8
            o[off + 9u64*i + 1u64] = ((MLDSA_TZ[0] >> 8u64) & 0xFFu64) as u8
            o[off + 9u64*i + 2u64] = (((MLDSA_TZ[0] >> 16u64) | (MLDSA_TZ[1] << 2u64)) & 0xFFu64) as u8
            o[off + 9u64*i + 3u64] = ((MLDSA_TZ[1] >> 6u64) & 0xFFu64) as u8
            o[off + 9u64*i + 4u64] = (((MLDSA_TZ[1] >> 14u64) | (MLDSA_TZ[2] << 4u64)) & 0xFFu64) as u8
            o[off + 9u64*i + 5u64] = ((MLDSA_TZ[2] >> 4u64) & 0xFFu64) as u8
            o[off + 9u64*i + 6u64] = (((MLDSA_TZ[2] >> 12u64) | (MLDSA_TZ[3] << 6u64)) & 0xFFu64) as u8
            o[off + 9u64*i + 7u64] = ((MLDSA_TZ[3] >> 2u64) & 0xFFu64) as u8
            o[off + 9u64*i + 8u64] = ((MLDSA_TZ[3] >> 10u64) & 0xFFu64) as u8
            i = i + 1u64
        }
    } else {
        let mut i : u64 = 0u64
        while i < 128u64 {
            let t0 : u64 = (524288u64 + MLDSA_Q - (MLDSA_POOL[base + 2u64*i + 0u64] as u64)) % MLDSA_Q
            let t1 : u64 = (524288u64 + MLDSA_Q - (MLDSA_POOL[base + 2u64*i + 1u64] as u64)) % MLDSA_Q
            o[off + 5u64*i + 0u64] = (t0 & 0xFFu64) as u8
            o[off + 5u64*i + 1u64] = ((t0 >> 8u64) & 0xFFu64) as u8
            o[off + 5u64*i + 2u64] = (((t0 >> 16u64) | (t1 << 4u64)) & 0xFFu64) as u8
            o[off + 5u64*i + 3u64] = ((t1 >> 4u64) & 0xFFu64) as u8
            o[off + 5u64*i + 4u64] = ((t1 >> 12u64) & 0xFFu64) as u8
            i = i + 1u64
        }
    }
    return 0i32
}
fn mldsa_polyz_unpack(s: u64, buf: u64, off: u64, gamma1: u64) -> i32 {
    let base : u64 = s * 256u64
    let o : *u8 = buf as *u8
    if gamma1 == 131072u64 {
        let mut i : u64 = 0u64
        while i < 64u64 {
            let c0 : u64 = o[off + 9u64*i + 0u64] as u64
            let c1 : u64 = o[off + 9u64*i + 1u64] as u64
            let c2 : u64 = o[off + 9u64*i + 2u64] as u64
            let c3 : u64 = o[off + 9u64*i + 3u64] as u64
            let c4 : u64 = o[off + 9u64*i + 4u64] as u64
            let c5 : u64 = o[off + 9u64*i + 5u64] as u64
            let c6 : u64 = o[off + 9u64*i + 6u64] as u64
            let c7 : u64 = o[off + 9u64*i + 7u64] as u64
            let c8 : u64 = o[off + 9u64*i + 8u64] as u64
            MLDSA_TZ[0] = (c0 | (c1 << 8u64) | (c2 << 16u64)) & 0x3FFFFu64
            MLDSA_TZ[1] = ((c2 >> 2u64) | (c3 << 6u64) | (c4 << 14u64)) & 0x3FFFFu64
            MLDSA_TZ[2] = ((c4 >> 4u64) | (c5 << 4u64) | (c6 << 12u64)) & 0x3FFFFu64
            MLDSA_TZ[3] = ((c6 >> 6u64) | (c7 << 2u64) | (c8 << 10u64)) & 0x3FFFFu64
            let mut j : u64 = 0u64
            while j < 4u64 {
                MLDSA_POOL[base + 4u64*i + j] = ((131072u64 + MLDSA_Q - MLDSA_TZ[j]) % MLDSA_Q) as u32
                j = j + 1u64
            }
            i = i + 1u64
        }
    } else {
        let mut i : u64 = 0u64
        while i < 128u64 {
            let c0 : u64 = o[off + 5u64*i + 0u64] as u64
            let c1 : u64 = o[off + 5u64*i + 1u64] as u64
            let c2 : u64 = o[off + 5u64*i + 2u64] as u64
            let c3 : u64 = o[off + 5u64*i + 3u64] as u64
            let c4 : u64 = o[off + 5u64*i + 4u64] as u64
            let t0 : u64 = (c0 | (c1 << 8u64) | (c2 << 16u64)) & 0xFFFFFu64
            let t1 : u64 = ((c2 >> 4u64) | (c3 << 4u64) | (c4 << 12u64)) & 0xFFFFFu64
            MLDSA_POOL[base + 2u64*i + 0u64] = ((524288u64 + MLDSA_Q - t0) % MLDSA_Q) as u32
            MLDSA_POOL[base + 2u64*i + 1u64] = ((524288u64 + MLDSA_Q - t1) % MLDSA_Q) as u32
            i = i + 1u64
        }
    }
    return 0i32
}

fn mldsa_polyeta_pack(s: u64, buf: u64, off: u64, eta: u64) -> i32 {
    let base : u64 = s * 256u64
    let o : *u8 = buf as *u8
    if eta == 2u64 {
        let mut i : u64 = 0u64
        while i < 32u64 {
            let mut j : u64 = 0u64
            while j < 8u64 {
                MLDSA_T8[j] = (2u64 + MLDSA_Q - (MLDSA_POOL[base + 8u64*i + j] as u64)) % MLDSA_Q
                j = j + 1u64
            }
            o[off + 3u64*i + 0u64] = ((MLDSA_T8[0] | (MLDSA_T8[1] << 3u64) | (MLDSA_T8[2] << 6u64)) & 0xFFu64) as u8
            o[off + 3u64*i + 1u64] = (((MLDSA_T8[2] >> 2u64) | (MLDSA_T8[3] << 1u64) | (MLDSA_T8[4] << 4u64) | (MLDSA_T8[5] << 7u64)) & 0xFFu64) as u8
            o[off + 3u64*i + 2u64] = (((MLDSA_T8[5] >> 1u64) | (MLDSA_T8[6] << 2u64) | (MLDSA_T8[7] << 5u64)) & 0xFFu64) as u8
            i = i + 1u64
        }
    } else {
        let mut i : u64 = 0u64
        while i < 128u64 {
            let t0 : u64 = (4u64 + MLDSA_Q - (MLDSA_POOL[base + 2u64*i + 0u64] as u64)) % MLDSA_Q
            let t1 : u64 = (4u64 + MLDSA_Q - (MLDSA_POOL[base + 2u64*i + 1u64] as u64)) % MLDSA_Q
            o[off + i] = ((t0 | (t1 << 4u64)) & 0xFFu64) as u8
            i = i + 1u64
        }
    }
    return 0i32
}
fn mldsa_polyeta_unpack(s: u64, buf: u64, off: u64, eta: u64) -> i32 {
    let base : u64 = s * 256u64
    let o : *u8 = buf as *u8
    if eta == 2u64 {
        let mut i : u64 = 0u64
        while i < 32u64 {
            let r0 : u64 = o[off + 3u64*i + 0u64] as u64
            let r1 : u64 = o[off + 3u64*i + 1u64] as u64
            let r2 : u64 = o[off + 3u64*i + 2u64] as u64
            MLDSA_T8[0] = r0 & 7u64
            MLDSA_T8[1] = (r0 >> 3u64) & 7u64
            MLDSA_T8[2] = ((r0 >> 6u64) | (r1 << 2u64)) & 7u64
            MLDSA_T8[3] = (r1 >> 1u64) & 7u64
            MLDSA_T8[4] = (r1 >> 4u64) & 7u64
            MLDSA_T8[5] = ((r1 >> 7u64) | (r2 << 1u64)) & 7u64
            MLDSA_T8[6] = (r2 >> 2u64) & 7u64
            MLDSA_T8[7] = (r2 >> 5u64) & 7u64
            let mut j : u64 = 0u64
            while j < 8u64 {
                MLDSA_POOL[base + 8u64*i + j] = ((2u64 + MLDSA_Q - MLDSA_T8[j]) % MLDSA_Q) as u32
                j = j + 1u64
            }
            i = i + 1u64
        }
    } else {
        let mut i : u64 = 0u64
        while i < 128u64 {
            let r : u64 = o[off + i] as u64
            let t0 : u64 = r & 0x0Fu64
            let t1 : u64 = r >> 4u64
            MLDSA_POOL[base + 2u64*i + 0u64] = ((4u64 + MLDSA_Q - t0) % MLDSA_Q) as u32
            MLDSA_POOL[base + 2u64*i + 1u64] = ((4u64 + MLDSA_Q - t1) % MLDSA_Q) as u32
            i = i + 1u64
        }
    }
    return 0i32
}

/* polyw1_pack: w1 coeffs are small non-negative high-bits (no offset). */
fn mldsa_polyw1_pack(s: u64, buf: u64, off: u64, gamma2: u64) -> i32 {
    let base : u64 = s * 256u64
    let o : *u8 = buf as *u8
    if gamma2 == 261888u64 {
        let mut i : u64 = 0u64
        while i < 128u64 {
            let a0 : u64 = MLDSA_POOL[base + 2u64*i + 0u64] as u64
            let a1 : u64 = MLDSA_POOL[base + 2u64*i + 1u64] as u64
            o[off + i] = ((a0 | (a1 << 4u64)) & 0xFFu64) as u8
            i = i + 1u64
        }
    } else {
        let mut i : u64 = 0u64
        while i < 64u64 {
            let t0 : u64 = MLDSA_POOL[base + 4u64*i + 0u64] as u64
            let t1 : u64 = MLDSA_POOL[base + 4u64*i + 1u64] as u64
            let t2 : u64 = MLDSA_POOL[base + 4u64*i + 2u64] as u64
            let t3 : u64 = MLDSA_POOL[base + 4u64*i + 3u64] as u64
            o[off + 3u64*i + 0u64] = ((t0 | (t1 << 6u64)) & 0xFFu64) as u8
            o[off + 3u64*i + 1u64] = (((t1 >> 2u64) | (t2 << 4u64)) & 0xFFu64) as u8
            o[off + 3u64*i + 2u64] = (((t2 >> 4u64) | (t3 << 2u64)) & 0xFFu64) as u8
            i = i + 1u64
        }
    }
    return 0i32
}

/* ---- Incremental SHAKE256 (rate 136, dom 0x1f) over arbitrary segments,
 * built on keccak_f1600 (exported) -- enables mu=SHAKE256(tr||msg) for
 * ARBITRARY msg length without a concat-buffer limit (keccak_absorb is
 * one-shot). ---- */
var MLDSA_KST  : [u8; 200]
var MLDSA_KPOS : [u64; 1]

fn mldsa_sh_init() -> i32 {
    keccak_state_zero(&MLDSA_KST as u64)
    MLDSA_KPOS[0] = 0u64
    return 0i32
}
fn mldsa_sh_absorb(addr: u64, len: u64) -> i32 {
    let s : *u8 = &MLDSA_KST as *u8
    let m : *u8 = addr as *u8
    let mut pos : u64 = MLDSA_KPOS[0]
    let mut i : u64 = 0u64
    while i < len {
        s[pos] = s[pos] ^ m[i]
        pos = pos + 1u64
        if pos == 136u64 {
            keccak_f1600(&MLDSA_KST as u64)
            pos = 0u64
        }
        i = i + 1u64
    }
    MLDSA_KPOS[0] = pos
    return 0i32
}
fn mldsa_sh_finish(out: u64, outlen: u64) -> i32 {
    let s : *u8 = &MLDSA_KST as *u8
    let pos : u64 = MLDSA_KPOS[0]
    s[pos] = s[pos] ^ 0x1Fu8
    s[135] = s[135] ^ 0x80u8
    keccak_f1600(&MLDSA_KST as u64)
    keccak_squeeze(&MLDSA_KST as u64, out, outlen, 136u32)
    return 0i32
}

/* ---- Samplers (one-shot keccak_absorb on bounded inputs; the multi-block
 * one-shot squeeze reproduces the C-ref incremental stream exactly --
 * poly_uniform exact-match-verified §4.4.1). ---- */
var MLDSA_SST  : [u8; 200]
var MLDSA_SIN  : [u8; 66]
var MLDSA_SBUF : [u8; 2048]

/* poly_uniform: A[i][j] from SHAKE128(rho || nonce_le2); rejection t<q. */
fn mldsa_poly_uniform(slot: u64, rho_addr: u64, nonce: u64) -> i32 {
    let rho : *u8 = rho_addr as *u8
    let si  : *u8 = &MLDSA_SIN as *u8
    let mut i : u64 = 0u64
    while i < 32u64 { si[i] = rho[i] ; i = i + 1u64 }
    si[32] = (nonce & 0xFFu64) as u8
    si[33] = ((nonce >> 8u64) & 0xFFu64) as u8
    keccak_state_zero(&MLDSA_SST as u64)
    keccak_absorb(&MLDSA_SST as u64, &MLDSA_SIN as u64, 34u64, keccak_pack_rate_dom(168u32, 0x1Fu8))
    keccak_squeeze(&MLDSA_SST as u64, &MLDSA_SBUF as u64, 2016u64, 168u32)
    let buf : *u8 = &MLDSA_SBUF as *u8
    let base : u64 = slot * 256u64
    let mut ctr : u64 = 0u64
    let mut j : u64 = 0u64
    while j + 3u64 <= 2016u64 {
        if ctr < 256u64 {
            let b0 : u64 = buf[j] as u64
            let b1 : u64 = buf[j + 1u64] as u64
            let b2 : u64 = (buf[j + 2u64] as u64) & 0x7Fu64
            let t : u64 = b0 | (b1 << 8u64) | (b2 << 16u64)
            if t < MLDSA_Q { MLDSA_POOL[base + ctr] = t as u32 ; ctr = ctr + 1u64 }
        }
        j = j + 3u64
    }
    return 0i32
}

/* poly_uniform_eta: s1/s2 from SHAKE256(seed64 || nonce_le2); rejection. */
fn mldsa_poly_uniform_eta(slot: u64, seed_addr: u64, nonce: u64, eta: u64) -> i32 {
    let sd : *u8 = seed_addr as *u8
    let si : *u8 = &MLDSA_SIN as *u8
    let mut i : u64 = 0u64
    while i < 64u64 { si[i] = sd[i] ; i = i + 1u64 }
    si[64] = (nonce & 0xFFu64) as u8
    si[65] = ((nonce >> 8u64) & 0xFFu64) as u8
    keccak_state_zero(&MLDSA_SST as u64)
    keccak_absorb(&MLDSA_SST as u64, &MLDSA_SIN as u64, 66u64, keccak_pack_rate_dom(136u32, 0x1Fu8))
    keccak_squeeze(&MLDSA_SST as u64, &MLDSA_SBUF as u64, 1360u64, 136u32)
    let buf : *u8 = &MLDSA_SBUF as *u8
    let base : u64 = slot * 256u64
    let mut ctr : u64 = 0u64
    let mut j : u64 = 0u64
    while j < 1360u64 {
        if ctr < 256u64 {
            let b : u64 = buf[j] as u64
            let t0 : u64 = b & 0x0Fu64
            let t1 : u64 = b >> 4u64
            if eta == 2u64 {
                if t0 < 15u64 { MLDSA_POOL[base + ctr] = ((2u64 + MLDSA_Q - (t0 % 5u64)) % MLDSA_Q) as u32 ; ctr = ctr + 1u64 }
                if ctr < 256u64 {
                    if t1 < 15u64 { MLDSA_POOL[base + ctr] = ((2u64 + MLDSA_Q - (t1 % 5u64)) % MLDSA_Q) as u32 ; ctr = ctr + 1u64 }
                }
            } else {
                if t0 < 9u64 { MLDSA_POOL[base + ctr] = ((4u64 + MLDSA_Q - t0) % MLDSA_Q) as u32 ; ctr = ctr + 1u64 }
                if ctr < 256u64 {
                    if t1 < 9u64 { MLDSA_POOL[base + ctr] = ((4u64 + MLDSA_Q - t1) % MLDSA_Q) as u32 ; ctr = ctr + 1u64 }
                }
            }
        }
        j = j + 1u64
    }
    return 0i32
}

/* poly_uniform_gamma1: y in (-gamma1, gamma1] from SHAKE256(seed64||nonce).
 * Replicates the C-ref stride (18 bytes/group @ 2^17, 20 @ 2^19; 9/10 used). */
fn mldsa_poly_uniform_gamma1(slot: u64, seed_addr: u64, nonce: u64, gamma1: u64) -> i32 {
    let sd : *u8 = seed_addr as *u8
    let si : *u8 = &MLDSA_SIN as *u8
    let mut i : u64 = 0u64
    while i < 64u64 { si[i] = sd[i] ; i = i + 1u64 }
    si[64] = (nonce & 0xFFu64) as u8
    si[65] = ((nonce >> 8u64) & 0xFFu64) as u8
    keccak_state_zero(&MLDSA_SST as u64)
    keccak_absorb(&MLDSA_SST as u64, &MLDSA_SIN as u64, 66u64, keccak_pack_rate_dom(136u32, 0x1Fu8))
    let buf : *u8 = &MLDSA_SBUF as *u8
    let base : u64 = slot * 256u64
    if gamma1 == 131072u64 {
        keccak_squeeze(&MLDSA_SST as u64, &MLDSA_SBUF as u64, 1152u64, 136u32)
        let mut g : u64 = 0u64
        while g < 64u64 {
            let p : u64 = 18u64 * g
            let b0 : u64 = buf[p + 0u64] as u64
            let b1 : u64 = buf[p + 1u64] as u64
            let b2 : u64 = buf[p + 2u64] as u64
            let b3 : u64 = buf[p + 3u64] as u64
            let b4 : u64 = buf[p + 4u64] as u64
            let b5 : u64 = buf[p + 5u64] as u64
            let b6 : u64 = buf[p + 6u64] as u64
            let b7 : u64 = buf[p + 7u64] as u64
            let b8 : u64 = buf[p + 8u64] as u64
            let v0 : u64 = (b0 | (b1 << 8u64) | ((b2 & 0x03u64) << 16u64)) & 0x3FFFFu64
            let v1 : u64 = ((b2 >> 2u64) | (b3 << 6u64) | ((b4 & 0x0Fu64) << 14u64)) & 0x3FFFFu64
            let v2 : u64 = ((b4 >> 4u64) | (b5 << 4u64) | ((b6 & 0x3Fu64) << 12u64)) & 0x3FFFFu64
            let v3 : u64 = ((b6 >> 6u64) | (b7 << 2u64) | (b8 << 10u64)) & 0x3FFFFu64
            MLDSA_POOL[base + 4u64*g + 0u64] = ((131072u64 + MLDSA_Q - v0) % MLDSA_Q) as u32
            MLDSA_POOL[base + 4u64*g + 1u64] = ((131072u64 + MLDSA_Q - v1) % MLDSA_Q) as u32
            MLDSA_POOL[base + 4u64*g + 2u64] = ((131072u64 + MLDSA_Q - v2) % MLDSA_Q) as u32
            MLDSA_POOL[base + 4u64*g + 3u64] = ((131072u64 + MLDSA_Q - v3) % MLDSA_Q) as u32
            g = g + 1u64
        }
    } else {
        keccak_squeeze(&MLDSA_SST as u64, &MLDSA_SBUF as u64, 1280u64, 136u32)
        let mut g : u64 = 0u64
        while g < 64u64 {
            let p : u64 = 20u64 * g
            let b0 : u64 = buf[p + 0u64] as u64
            let b1 : u64 = buf[p + 1u64] as u64
            let b2 : u64 = buf[p + 2u64] as u64
            let b3 : u64 = buf[p + 3u64] as u64
            let b4 : u64 = buf[p + 4u64] as u64
            let b5 : u64 = buf[p + 5u64] as u64
            let b6 : u64 = buf[p + 6u64] as u64
            let b7 : u64 = buf[p + 7u64] as u64
            let b8 : u64 = buf[p + 8u64] as u64
            let b9 : u64 = buf[p + 9u64] as u64
            let v0 : u64 = (b0 | (b1 << 8u64) | ((b2 & 0x0Fu64) << 16u64)) & 0xFFFFFu64
            let v1 : u64 = ((b2 >> 4u64) | (b3 << 4u64) | (b4 << 12u64)) & 0xFFFFFu64
            let v2 : u64 = (b5 | (b6 << 8u64) | ((b7 & 0x0Fu64) << 16u64)) & 0xFFFFFu64
            let v3 : u64 = ((b7 >> 4u64) | (b8 << 4u64) | (b9 << 12u64)) & 0xFFFFFu64
            MLDSA_POOL[base + 4u64*g + 0u64] = ((524288u64 + MLDSA_Q - v0) % MLDSA_Q) as u32
            MLDSA_POOL[base + 4u64*g + 1u64] = ((524288u64 + MLDSA_Q - v1) % MLDSA_Q) as u32
            MLDSA_POOL[base + 4u64*g + 2u64] = ((524288u64 + MLDSA_Q - v2) % MLDSA_Q) as u32
            MLDSA_POOL[base + 4u64*g + 3u64] = ((524288u64 + MLDSA_Q - v3) % MLDSA_Q) as u32
            g = g + 1u64
        }
    }
    return 0i32
}

/* challenge: tau coeffs in {-1,+1} (mod q: q-1 / 1), rest 0; SampleInBall. */
fn mldsa_challenge(slot: u64, seed_addr: u64, tau: u64) -> i32 {
    keccak_state_zero(&MLDSA_SST as u64)
    keccak_absorb(&MLDSA_SST as u64, seed_addr, 32u64, keccak_pack_rate_dom(136u32, 0x1Fu8))
    keccak_squeeze(&MLDSA_SST as u64, &MLDSA_SBUF as u64, 264u64, 136u32)
    let buf : *u8 = &MLDSA_SBUF as *u8
    let base : u64 = slot * 256u64
    let mut signs : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 8u64 {
        signs = signs | ((buf[i] as u64) << (8u64 * i))
        i = i + 1u64
    }
    i = 0u64
    while i < 256u64 { MLDSA_POOL[base + i] = 0u32 ; i = i + 1u64 }
    let mut pos : u64 = 8u64
    let mut ii : u64 = 256u64 - tau
    while ii < 256u64 {
        let mut b : u64 = buf[pos]  as u64
        pos = pos + 1u64
        while b > ii {
            b = buf[pos] as u64
            pos = pos + 1u64
        }
        MLDSA_POOL[base + ii] = MLDSA_POOL[base + b]
        if (signs & 1u64) == 1u64 {
            MLDSA_POOL[base + b] = (MLDSA_Q - 1u64) as u32
        } else {
            MLDSA_POOL[base + b] = 1u32
        }
        signs = signs >> 1u64
        ii = ii + 1u64
    }
    return 0i32
}

/* ---- matrix / vector helpers (slot-based) ---- */
const MLDSA_MULTMP : u64 = 152u64   /* reserved scratch slot for matrix_mul */

fn mldsa_copy_slot(dst: u64, src: u64) -> i32 {
    let db : u64 = dst * 256u64
    let sb : u64 = src * 256u64
    let mut j : u64 = 0u64
    while j < 256u64 { MLDSA_POOL[db + j] = MLDSA_POOL[sb + j] ; j = j + 1u64 }
    return 0i32
}

fn mldsa_matrix_expand(a_base: u64, rho_addr: u64, k: u64, l: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < k {
        let mut j : u64 = 0u64
        while j < l {
            let nonce : u64 = (i << 8u64) | j
            mldsa_poly_uniform(a_base + i*l + j, rho_addr, nonce)
            j = j + 1u64
        }
        i = i + 1u64
    }
    return 0i32
}
fn mldsa_matrix_mul(t_base: u64, a_base: u64, s_base: u64, k: u64, l: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < k {
        mldsa_pointwise(t_base + i, a_base + i*l + 0u64, s_base + 0u64)
        let mut j : u64 = 1u64
        while j < l {
            mldsa_pointwise(MLDSA_MULTMP, a_base + i*l + j, s_base + j)
            mldsa_add(t_base + i, t_base + i, MLDSA_MULTMP)
            j = j + 1u64
        }
        i = i + 1u64
    }
    return 0i32
}
fn mldsa_vec_ntt(base: u64, n: u64) -> i32 { let mut i : u64 = 0u64 while i < n { mldsa_ntt(base + i) ; i = i + 1u64 } return 0i32 }
fn mldsa_vec_invntt(base: u64, n: u64) -> i32 { let mut i : u64 = 0u64 while i < n { mldsa_invntt(base + i) ; i = i + 1u64 } return 0i32 }
fn mldsa_vec_caddq(base: u64, n: u64) -> i32 { let mut i : u64 = 0u64 while i < n { mldsa_caddq_slot(base + i) ; i = i + 1u64 } return 0i32 }
fn mldsa_vec_add(rb: u64, ab: u64, bb: u64, n: u64) -> i32 { let mut i : u64 = 0u64 while i < n { mldsa_add(rb + i, ab + i, bb + i) ; i = i + 1u64 } return 0i32 }
fn mldsa_vec_sub(rb: u64, ab: u64, bb: u64, n: u64) -> i32 { let mut i : u64 = 0u64 while i < n { mldsa_sub(rb + i, ab + i, bb + i) ; i = i + 1u64 } return 0i32 }

/* ---- keygen ---- (slot map: A=0, s1=56, s2=64, s1hat=72, t1v=80, t1=88, t0=96) */
var MLDSA_KGIN   : [u8; 34]
var MLDSA_BUF128 : [u8; 128]

fn iii_mldsa_keygen(level: u64, seed: u64, pk: u64, sk: u64) -> i32 @export {
    let k : u64 = mldsa_k(level)
    let l : u64 = mldsa_l(level)
    let eta : u64 = mldsa_eta(level)
    let etapk : u64 = mldsa_polyeta_packed(level)
    /* rho||rhoprime||K = SHAKE256(seed(32) || k || l, 128) */
    let sd : *u8 = seed as *u8
    let gi : *u8 = &MLDSA_KGIN as *u8
    let mut i : u64 = 0u64
    while i < 32u64 { gi[i] = sd[i] ; i = i + 1u64 }
    gi[32] = (k & 0xFFu64) as u8
    gi[33] = (l & 0xFFu64) as u8
    keccak_state_zero(&MLDSA_SST as u64)
    keccak_absorb(&MLDSA_SST as u64, &MLDSA_KGIN as u64, 34u64, keccak_pack_rate_dom(136u32, 0x1Fu8))
    keccak_squeeze(&MLDSA_SST as u64, &MLDSA_BUF128 as u64, 128u64, 136u32)
    let b128 : u64 = &MLDSA_BUF128 as u64
    let rho_addr : u64 = b128
    let rhop_addr : u64 = b128 + 32u64
    /* A from rho (slot 0..), s1 (56..) s2 (64..) via eta */
    mldsa_matrix_expand(0u64, rho_addr, k, l)
    i = 0u64
    while i < l { mldsa_poly_uniform_eta(56u64 + i, rhop_addr, i, eta) ; i = i + 1u64 }
    i = 0u64
    while i < k { mldsa_poly_uniform_eta(64u64 + i, rhop_addr, l + i, eta) ; i = i + 1u64 }
    /* s1hat = NTT(copy s1) (72..); t1v = A*s1hat (80..) invNTT caddq + s2 */
    i = 0u64
    while i < l { mldsa_copy_slot(72u64 + i, 56u64 + i) ; i = i + 1u64 }
    mldsa_vec_ntt(72u64, l)
    mldsa_matrix_mul(80u64, 0u64, 72u64, k, l)
    mldsa_vec_invntt(80u64, k)
    mldsa_vec_caddq(80u64, k)
    mldsa_vec_add(80u64, 80u64, 64u64, k)
    /* power2round -> t1 (88..), t0 (96..) */
    i = 0u64
    while i < k {
        let tvb : u64 = (80u64 + i) * 256u64
        let t1b : u64 = (88u64 + i) * 256u64
        let t0b : u64 = (96u64 + i) * 256u64
        let mut j : u64 = 0u64
        while j < 256u64 {
            let a : u64 = MLDSA_POOL[tvb + j] as u64
            MLDSA_POOL[t1b + j] = mldsa_power2round_a1(a) as u32
            MLDSA_POOL[t0b + j] = mldsa_power2round_a0(a) as u32
            j = j + 1u64
        }
        i = i + 1u64
    }
    /* pk = rho || polyt1_pack(t1[i]) */
    let pkp  : *u8 = pk as *u8
    let rho8 : *u8 = b128 as *u8
    i = 0u64
    while i < 32u64 { pkp[i] = rho8[i] ; i = i + 1u64 }
    i = 0u64
    while i < k { mldsa_polyt1_pack(88u64 + i, pk, 32u64 + 320u64*i) ; i = i + 1u64 }
    /* sk = rho || K || tr || polyeta(s1) || polyeta(s2) || polyt0(t0) */
    let skp : *u8 = sk as *u8
    i = 0u64
    while i < 32u64 { skp[i] = rho8[i] ; i = i + 1u64 }
    let kk8 : *u8 = (b128 + 96u64) as *u8
    i = 0u64
    while i < 32u64 { skp[32u64 + i] = kk8[i] ; i = i + 1u64 }
    let pkbytes : u64 = 32u64 + 320u64 * k
    keccak_state_zero(&MLDSA_SST as u64)
    keccak_absorb(&MLDSA_SST as u64, pk, pkbytes, keccak_pack_rate_dom(136u32, 0x1Fu8))
    keccak_squeeze(&MLDSA_SST as u64, sk + 64u64, 64u64, 136u32)
    let mut off : u64 = 128u64
    i = 0u64
    while i < l { mldsa_polyeta_pack(56u64 + i, sk, off, eta) ; off = off + etapk ; i = i + 1u64 }
    i = 0u64
    while i < k { mldsa_polyeta_pack(64u64 + i, sk, off, eta) ; off = off + etapk ; i = i + 1u64 }
    i = 0u64
    while i < k { mldsa_polyt0_pack(96u64 + i, sk, off) ; off = off + 416u64 ; i = i + 1u64 }
    return 0i32
}

/* chknorm: 1 if any |coeff| (centered) >= bound, else 0 (unsigned mod-q). */
fn mldsa_chknorm(s: u64, n: u64, bound: u64) -> u64 {
    let mut p : u64 = 0u64
    while p < n {
        let base : u64 = (s + p) * 256u64
        let mut j : u64 = 0u64
        while j < 256u64 {
            let c : u64 = MLDSA_POOL[base + j] as u64
            let mut cabs : u64 = c
            if c > MLDSA_QH { cabs = MLDSA_Q - c }
            if cabs >= bound { return 1u64 }
            j = j + 1u64
        }
        p = p + 1u64
    }
    return 0u64
}

/* ---- sign ---- (slot map: A=0, s1hat=56, s2hat=63, t0hat=71, y=79, z=86,
 * w=93, w1p=101, w0p/H=109, cs1=117, cs2=124, ct0=132, r0=140, chat=148) */
var MLDSA_MU    : [u8; 64]
var MLDSA_RHOP  : [u8; 64]
var MLDSA_RPIN  : [u8; 96]
var MLDSA_CSEED : [u8; 32]
var MLDSA_CSIN  : [u8; 1664]

/* APOTHEOSIS C.1 sealed ABI: the signature-length output is an EXPLICIT *u64
 * the caller owns (was siglen:u64 cast to *u8 below -- a type that lied about
 * direction).  sig_out is the signature buffer (*u8).  iii_mldsa_sign is kept
 * as a deprecated thin wrapper for back-compat. */
fn iii_mldsa_sign_sealed(level: u64, sk: u64, msg: u64, msglen: u64, sig_out: *u8, sig_len_out: *u64) -> i32 @export {
    let sig : u64 = sig_out as u64
    let k : u64 = mldsa_k(level)
    let l : u64 = mldsa_l(level)
    let eta : u64 = mldsa_eta(level)
    let etapk : u64 = mldsa_polyeta_packed(level)
    let gamma1 : u64 = mldsa_gamma1(level)
    let gamma2 : u64 = mldsa_gamma2(level)
    let tau : u64 = mldsa_tau(level)
    let beta : u64 = mldsa_beta(level)
    let omega : u64 = mldsa_omega(level)
    let pzp : u64 = mldsa_polyz_packed(level)
    let pwp : u64 = mldsa_polyw1_packed(level)
    /* unpack sk: rho=sk[0..32], K=sk[32..64], tr=sk[64..128], s1/s2/t0 */
    let rho_addr : u64 = sk
    let mut off : u64 = 128u64
    let mut i : u64 = 0u64
    while i < l { mldsa_polyeta_unpack(56u64 + i, sk, off, eta) ; off = off + etapk ; i = i + 1u64 }
    i = 0u64
    while i < k { mldsa_polyeta_unpack(63u64 + i, sk, off, eta) ; off = off + etapk ; i = i + 1u64 }
    i = 0u64
    while i < k { mldsa_polyt0_unpack(71u64 + i, sk, off) ; off = off + 416u64 ; i = i + 1u64 }
    /* A from rho */
    mldsa_matrix_expand(0u64, rho_addr, k, l)
    /* mu = SHAKE256(tr || msg) -- incremental (arbitrary msg) */
    mldsa_sh_init()
    mldsa_sh_absorb(sk + 64u64, 64u64)
    mldsa_sh_absorb(msg, msglen)
    mldsa_sh_finish(&MLDSA_MU as u64, 64u64)
    /* rhoprime = SHAKE256(K || mu) */
    let rp : *u8 = &MLDSA_RPIN as *u8
    let skp : *u8 = sk as *u8
    let mup : *u8 = &MLDSA_MU as *u8
    i = 0u64
    while i < 32u64 { rp[i] = skp[32u64 + i] ; i = i + 1u64 }
    i = 0u64
    while i < 64u64 { rp[32u64 + i] = mup[i] ; i = i + 1u64 }
    keccak_state_zero(&MLDSA_SST as u64)
    keccak_absorb(&MLDSA_SST as u64, &MLDSA_RPIN as u64, 96u64, keccak_pack_rate_dom(136u32, 0x1Fu8))
    keccak_squeeze(&MLDSA_SST as u64, &MLDSA_RHOP as u64, 64u64, 136u32)
    /* s1hat/s2hat/t0hat = NTT in place */
    mldsa_vec_ntt(56u64, l)
    mldsa_vec_ntt(63u64, k)
    mldsa_vec_ntt(71u64, k)
    let rhop_addr : u64 = &MLDSA_RHOP as u64
    let mut kappa : u64 = 0u64
    let mut iter : u64 = 0u64
    while iter < 1000u64 {
        iter = iter + 1u64
        /* y (79..) via gamma1 */
        i = 0u64
        while i < l { mldsa_poly_uniform_gamma1(79u64 + i, rhop_addr, kappa + i, gamma1) ; i = i + 1u64 }
        kappa = kappa + l
        /* z=NTT(y) (86..), w=A*z (93..), invNTT, caddq */
        i = 0u64
        while i < l { mldsa_copy_slot(86u64 + i, 79u64 + i) ; i = i + 1u64 }
        mldsa_vec_ntt(86u64, l)
        mldsa_matrix_mul(93u64, 0u64, 86u64, k, l)
        mldsa_vec_invntt(93u64, k)
        mldsa_vec_caddq(93u64, k)
        /* decompose w -> w1p (101..), w0p (109..) */
        i = 0u64
        while i < k {
            let wb  : u64 = (93u64 + i) * 256u64
            let w1b : u64 = (101u64 + i) * 256u64
            let w0b : u64 = (109u64 + i) * 256u64
            let mut j : u64 = 0u64
            while j < 256u64 {
                let a1 : u64 = mldsa_decompose(MLDSA_POOL[wb + j] as u64, gamma2)
                MLDSA_POOL[w1b + j] = a1 as u32
                MLDSA_POOL[w0b + j] = DEC_A0[0] as u32
                j = j + 1u64
            }
            i = i + 1u64
        }
        /* c_seed = SHAKE256(mu || polyw1_pack(w1p)) */
        let ci : *u8 = &MLDSA_CSIN as *u8
        i = 0u64
        while i < 64u64 { ci[i] = mup[i] ; i = i + 1u64 }
        i = 0u64
        while i < k { mldsa_polyw1_pack(101u64 + i, &MLDSA_CSIN as u64, 64u64 + i*pwp, gamma2) ; i = i + 1u64 }
        keccak_state_zero(&MLDSA_SST as u64)
        keccak_absorb(&MLDSA_SST as u64, &MLDSA_CSIN as u64, 64u64 + k*pwp, keccak_pack_rate_dom(136u32, 0x1Fu8))
        keccak_squeeze(&MLDSA_SST as u64, &MLDSA_CSEED as u64, 32u64, 136u32)
        /* c = challenge (148), chat = NTT(c) */
        mldsa_challenge(148u64, &MLDSA_CSEED as u64, tau)
        mldsa_ntt(148u64)
        /* cs1 = invNTT(chat * s1hat) (117..); z = y + cs1 (z at 86) */
        i = 0u64
        while i < l { mldsa_pointwise(117u64 + i, 148u64, 56u64 + i) ; mldsa_invntt(117u64 + i) ; i = i + 1u64 }
        i = 0u64
        while i < l { mldsa_add(86u64 + i, 79u64 + i, 117u64 + i) ; i = i + 1u64 }
        let mut bad : u64 = mldsa_chknorm(86u64, l, gamma1 - beta)
        /* cs2 = invNTT(chat * s2hat) (124..); r0 = w0p - cs2 (140..) */
        if bad == 0u64 {
            i = 0u64
            while i < k { mldsa_pointwise(124u64 + i, 148u64, 63u64 + i) ; mldsa_invntt(124u64 + i) ; i = i + 1u64 }
            i = 0u64
            while i < k { mldsa_sub(140u64 + i, 109u64 + i, 124u64 + i) ; i = i + 1u64 }
            bad = mldsa_chknorm(140u64, k, gamma2 - beta)
        }
        /* ct0 = invNTT(chat * t0hat) (132..) */
        if bad == 0u64 {
            i = 0u64
            while i < k { mldsa_pointwise(132u64 + i, 148u64, 71u64 + i) ; mldsa_invntt(132u64 + i) ; i = i + 1u64 }
            bad = mldsa_chknorm(132u64, k, gamma2)
        }
        /* h = MakeHint(r0+ct0, w1p) -> H (reuse w0p 109..); hsum <= omega */
        if bad == 0u64 {
            let mut hsum : u64 = 0u64
            i = 0u64
            while i < k {
                let r0b : u64 = (140u64 + i) * 256u64
                let c0b : u64 = (132u64 + i) * 256u64
                let w1b : u64 = (101u64 + i) * 256u64
                let hb  : u64 = (109u64 + i) * 256u64
                let mut j : u64 = 0u64
                while j < 256u64 {
                    let a0 : u64 = (MLDSA_POOL[r0b + j] as u64 + MLDSA_POOL[c0b + j] as u64) % MLDSA_Q
                    let hbit : u64 = mldsa_make_hint(a0, MLDSA_POOL[w1b + j] as u64, gamma2)
                    MLDSA_POOL[hb + j] = hbit as u32
                    hsum = hsum + hbit
                    j = j + 1u64
                }
                i = i + 1u64
            }
            if hsum > omega { bad = 1u64 }
            if bad == 0u64 {
                /* pack sig = c_seed || polyz_pack(z) || hint_encode(H) */
                let sp : *u8 = sig as *u8
                let cs : *u8 = &MLDSA_CSEED as *u8
                i = 0u64
                while i < 32u64 { sp[i] = cs[i] ; i = i + 1u64 }
                i = 0u64
                while i < l { mldsa_polyz_pack(86u64 + i, sig, 32u64 + i*pzp, gamma1) ; i = i + 1u64 }
                let hoff : u64 = 32u64 + l*pzp
                i = 0u64
                while i < omega + k { sp[hoff + i] = 0u8 ; i = i + 1u64 }
                let mut idx : u64 = 0u64
                i = 0u64
                while i < k {
                    let hb : u64 = (109u64 + i) * 256u64
                    let mut j : u64 = 0u64
                    while j < 256u64 {
                        if MLDSA_POOL[hb + j] != 0u32 { sp[hoff + idx] = (j & 0xFFu64) as u8 ; idx = idx + 1u64 }
                        j = j + 1u64
                    }
                    sp[hoff + omega + i] = (idx & 0xFFu64) as u8
                    i = i + 1u64
                }
                let total : u64 = 32u64 + l*pzp + omega + k
                sig_len_out[0u64] = total   /* typed *u64 store: lands in the caller-owned u64 */
                return 0i32
            }
        }
    }
    return 0i32 - 1i32
}

/* Deprecated back-compat wrapper (pre-C.1 ABI: siglen passed as a u64 then
 * cast to *u8).  New callers use iii_mldsa_sign_sealed with an explicit *u64
 * length output.  Retained so corpus 198 + the pq_dispatch router link. */
fn iii_mldsa_sign(level: u64, sk: u64, msg: u64, msglen: u64, sig: u64, siglen: u64) -> i32 @export {
    return iii_mldsa_sign_sealed(level, sk, msg, msglen, sig as *u8, siglen as *u64)
}

/* ---- verify ---- (slot map: A=0, t1=56, z=64, chat=71, zhat=72, Az=79,
 * t1hat=87, ct1=95, h=103, w1p=111) */
var MLDSA_TR : [u8; 64]

fn iii_mldsa_verify(level: u64, pk: u64, msg: u64, msglen: u64, sig: u64, siglen: u64) -> i32 @export {
    let k : u64 = mldsa_k(level)
    let l : u64 = mldsa_l(level)
    let gamma1 : u64 = mldsa_gamma1(level)
    let gamma2 : u64 = mldsa_gamma2(level)
    let tau : u64 = mldsa_tau(level)
    let beta : u64 = mldsa_beta(level)
    let omega : u64 = mldsa_omega(level)
    let pzp : u64 = mldsa_polyz_packed(level)
    let pwp : u64 = mldsa_polyw1_packed(level)
    let pkbytes : u64 = 32u64 + 320u64 * k
    let sigbytes : u64 = 32u64 + l*pzp + omega + k
    if siglen != sigbytes { return 0i32 - 1i32 }
    /* unpack t1 from pk (56..) */
    let mut i : u64 = 0u64
    while i < k { mldsa_polyt1_unpack(56u64 + i, pk, 32u64 + 320u64*i) ; i = i + 1u64 }
    /* unpack z from sig (64..), bound check */
    i = 0u64
    while i < l { mldsa_polyz_unpack(64u64 + i, sig, 32u64 + i*pzp, gamma1) ; i = i + 1u64 }
    if mldsa_chknorm(64u64, l, gamma1 - beta) != 0u64 { return 0i32 - 1i32 }
    /* decode hint -> h (103..); validate monotonic + bounds */
    let sp : *u8 = sig as *u8
    let hoff : u64 = 32u64 + l*pzp
    i = 0u64
    while i < k {
        let hb : u64 = (103u64 + i) * 256u64
        let mut j : u64 = 0u64
        while j < 256u64 { MLDSA_POOL[hb + j] = 0u32 ; j = j + 1u64 }
        i = i + 1u64
    }
    let mut idx : u64 = 0u64
    i = 0u64
    while i < k {
        let cnt : u64 = sp[hoff + omega + i] as u64
        if cnt < idx { return 0i32 - 1i32 }
        if cnt > omega { return 0i32 - 1i32 }
        let hb : u64 = (103u64 + i) * 256u64
        let mut j : u64 = idx
        while j < cnt {
            if j > idx {
                let cur : u64 = sp[hoff + j] as u64
                let prv : u64 = sp[hoff + j - 1u64] as u64
                if cur <= prv { return 0i32 - 1i32 }
            }
            MLDSA_POOL[hb + (sp[hoff + j] as u64)] = 1u32
            j = j + 1u64
        }
        idx = cnt
        i = i + 1u64
    }
    let mut j2 : u64 = idx
    while j2 < omega {
        if sp[hoff + j2] != 0u8 { return 0i32 - 1i32 }
        j2 = j2 + 1u64
    }
    /* chat = NTT(challenge(c_seed)) at 71 */
    mldsa_challenge(71u64, sig, tau)
    mldsa_ntt(71u64)
    /* A from rho (pk[0..32]) */
    mldsa_matrix_expand(0u64, pk, k, l)
    /* zhat = NTT(z) (72..); Az = A*zhat (79..) */
    i = 0u64
    while i < l { mldsa_copy_slot(72u64 + i, 64u64 + i) ; i = i + 1u64 }
    mldsa_vec_ntt(72u64, l)
    mldsa_matrix_mul(79u64, 0u64, 72u64, k, l)
    /* t1hat = NTT(t1 << d) (87..); ct1 = chat*t1hat (95..) */
    i = 0u64
    while i < k {
        let t1b : u64 = (56u64 + i) * 256u64
        let thb : u64 = (87u64 + i) * 256u64
        let mut j : u64 = 0u64
        while j < 256u64 {
            MLDSA_POOL[thb + j] = (((MLDSA_POOL[t1b + j] as u64) << 13u64) % MLDSA_Q) as u32
            j = j + 1u64
        }
        mldsa_ntt(87u64 + i)
        i = i + 1u64
    }
    i = 0u64
    while i < k { mldsa_pointwise(95u64 + i, 71u64, 87u64 + i) ; i = i + 1u64 }
    /* Az = Az - ct1; invNTT; caddq */
    mldsa_vec_sub(79u64, 79u64, 95u64, k)
    mldsa_vec_invntt(79u64, k)
    mldsa_vec_caddq(79u64, k)
    /* w1p = UseHint(h, Az) (111..) */
    i = 0u64
    while i < k {
        let ab : u64 = (79u64 + i) * 256u64
        let hb : u64 = (103u64 + i) * 256u64
        let wb : u64 = (111u64 + i) * 256u64
        let mut j : u64 = 0u64
        while j < 256u64 {
            MLDSA_POOL[wb + j] = mldsa_use_hint(MLDSA_POOL[ab + j] as u64, MLDSA_POOL[hb + j] as u64, gamma2) as u32
            j = j + 1u64
        }
        i = i + 1u64
    }
    /* tr = SHAKE256(pk); mu = SHAKE256(tr || msg); c_check = SHAKE256(mu || w1packed) */
    keccak_state_zero(&MLDSA_SST as u64)
    keccak_absorb(&MLDSA_SST as u64, pk, pkbytes, keccak_pack_rate_dom(136u32, 0x1Fu8))
    keccak_squeeze(&MLDSA_SST as u64, &MLDSA_TR as u64, 64u64, 136u32)
    mldsa_sh_init()
    mldsa_sh_absorb(&MLDSA_TR as u64, 64u64)
    mldsa_sh_absorb(msg, msglen)
    mldsa_sh_finish(&MLDSA_MU as u64, 64u64)
    let ci : *u8 = &MLDSA_CSIN as *u8
    let mup : *u8 = &MLDSA_MU as *u8
    i = 0u64
    while i < 64u64 { ci[i] = mup[i] ; i = i + 1u64 }
    i = 0u64
    while i < k { mldsa_polyw1_pack(111u64 + i, &MLDSA_CSIN as u64, 64u64 + i*pwp, gamma2) ; i = i + 1u64 }
    keccak_state_zero(&MLDSA_SST as u64)
    keccak_absorb(&MLDSA_SST as u64, &MLDSA_CSIN as u64, 64u64 + k*pwp, keccak_pack_rate_dom(136u32, 0x1Fu8))
    keccak_squeeze(&MLDSA_SST as u64, &MLDSA_CSEED as u64, 32u64, 136u32)
    let cc : *u8 = &MLDSA_CSEED as *u8
    let mut diff : u64 = 0u64
    i = 0u64
    while i < 32u64 {
        let d : u64 = (cc[i] as u64) ^ (sp[i] as u64)
        diff = diff | d
        i = i + 1u64
    }
    if diff == 0u64 { return 0i32 }
    return 0i32 - 1i32
}
