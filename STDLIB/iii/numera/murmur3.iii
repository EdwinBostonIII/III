/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\murmur3.iii
 *
 * III STDLIB - numera::murmur3
 *
 * MurmurHash3 32-bit (Austin Appleby 2011).  Non-cryptographic;
 * suitable for hash tables, bloom filters, content-addressed lookups
 * where collision-resistance is not security-critical.
 *
 * Public API:
 *   murmur3_32(data:*u8, len:u64, seed:u32) -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.85 (non-crypto).
 */

module numera_murmur3

/* COMBINE-10: the block load is byte-identically endian's little-endian u32 load. */
extern @abi(c-msvc-x64) fn endian_load_u32_le(p: *u8, off: u64) -> u32 from "endian.iii"

/* THE UNIFIED WEAVE: murmur's rotate IS the universal 32-bit rotation (numera/weave_blocks). */
extern @abi(c-msvc-x64) fn wvb_rotl32(x: u32, n: u32) -> u32 from "weave_blocks.iii"
fn mm3_rotl32(x: u32, n: u32) -> u32 {
    return wvb_rotl32(x, n)}

fn mm3_fmix32(h: u32) -> u32 {
    let mut x : u32 = h    x = (x ^ (x >> 16u32))    x = (x * 0x85EBCA6Bu32)    x = (x ^ (x >> 13u32))    x = (x * 0xC2B2AE35u32)    x = (x ^ (x >> 16u32))    return x
}

fn murmur3_32(data: *u8, len: u64, seed: u32) -> u32 @export {
    let c1 : u32 = 0xCC9E2D51u32
    let c2 : u32 = 0x1B873593u32
    let mut h : u32 = seed    /* Body: process 4-byte chunks. */
    let nblocks : u64 = len >> 2u64
    let mut i : u64 = 0u64
    while i < nblocks {
        let off : u64 = i * 4u64
        let mut k : u32 = endian_load_u32_le(data, off)   /* COMBINE-10: was b0|b1<<8|b2<<16|b3<<24 */
        k = (k * c1)        k = mm3_rotl32(k, 15u32)
        k = (k * c2)        h = h ^ k
        h = mm3_rotl32(h, 13u32)
        h = (h * 5u32 + 0xE6546B64u32)        i = i + 1u64
    }
    /* Tail: handle remaining 1..3 bytes. */
    let tail_start : u64 = nblocks * 4u64
    let tail_len : u64 = len - tail_start
    let mut k1 : u32 = 0u32
    if tail_len == 3u64 {
        k1 = k1 ^ ((data[tail_start + 2u64] as u32) << 16u32)
    }
    if tail_len >= 2u64 {
        k1 = k1 ^ ((data[tail_start + 1u64] as u32) << 8u32)
    }
    if tail_len >= 1u64 {
        k1 = k1 ^ (data[tail_start + 0u64] as u32)
        k1 = (k1 * c1)        k1 = mm3_rotl32(k1, 15u32)
        k1 = (k1 * c2)        h = h ^ k1
    }
    /* Finalize. */
    h = h ^ (len as u32)
    h = mm3_fmix32(h)
    return h
}
