/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\parity_game.iii
 *
 * III STDLIB - numera::parity_game
 *
 * THE PARITY-GAME / MODAL-mu-CALCULUS VERIFICATION ENGINE.
 *
 * ROLE.  This is III's exact solver for max-parity games and, by the games=logic equivalence, its back-end for full
 * modal-mu-calculus model-checking -- the most expressive standard specification logic (it subsumes CTL, CTL*, LTL).
 * A parity game G = (V0 union V1, E, pr) is solved by computing the winning region of player Even (parity 0): the set
 * of vertices from which Even can force the maximal infinitely-recurring priority to be even.  The algorithm is
 * Zielonka's recursive attractor decomposition -- SOUND and COMPLETE, and the III-internal ground truth that was
 * cross-validated byte-for-byte against two independent solver families (Voge-Jurdzinski strategy improvement;
 * Jurdzinski small progress measures) on ~29k games (corpus 1839/1841/1843/1845), and against which the whole
 * parity-wall edifice (DOCS/III-THE-PARITY-WALL-CAPSTONE.md) is gated.
 *
 * USE CASES.  Verifying omega-regular / temporal properties of III's own state graphs and transformations: the
 * alternation-free fragment of any branching-time specification reduces here (mu-calculus model-checking IS this
 * solver, corpus 1853); equivalence/refinement checks that compile to nested fixpoints; any "can the controller force
 * an even/odd recurrent objective" question on a finite arena.  See DOCS/III-WALLS-CASHED-IN.md (cg_r3 verification face).
 *
 * INVOCATION.  pg_reset(n) -> pg_set_owner / pg_set_prio / pg_add_edge (build the arena) -> pg_solve_even() (returns the
 * Even winning region as a 64-bit set) -> pg_winner(v) (0=Even wins v, 1=Odd wins v).  Re-entrant per pg_reset.
 *
 * IMPACTS / LIMITATIONS (honest, per the parity wall).
 *   - SOUND + COMPLETE on its domain: arenas of up to PG_MAX = 64 vertices (winning regions are u64 bitmasks passed by
 *     value through the recursion).  For larger arenas a future v2 needs wider bitsets; this is a documented bound, not
 *     a correctness gap.
 *   - The arena MUST be total (every vertex has >=1 out-edge) -- pg_solve_even returns PG_E_DEADEND (all-ones is never a
 *     valid Even region for a nonempty arena, so the sentinel is distinguishable) if a deadend is detected.
 *   - WORST-CASE COMPLEXITY is quasi-polynomial in general -- this is the open "parity in P?" frontier (O1); the engine
 *     is exact, not fast in the worst case.  On the alternation-free / bounded-priority fragment it is polynomial
 *     (corpus 1857/1861): most real verification tasks live there.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 * Discipline: W1, W2, W13, W14, W15.  (Zielonka recursion: depth <= #distinct priorities <= PG_MAX, stack-bounded.)
 * Self-test: pg_kat() -> u64 returns 99 on full KAT pass.
 */
module parity_game

const PG_MAX : u32 = 64u32
const PG_E_DEADEND : u64 = 0xFFFFFFFFFFFFFFFFu64    /* sentinel from pg_solve_even on a non-total arena */

var PG_OWN : [u8;  64]    /* PG_OWN[v] = 0 (Even / V0) or 1 (Odd / V1) */
var PG_PRI : [u32; 64]    /* PG_PRI[v] = priority of v */
var PG_SUC : [u64; 64]    /* PG_SUC[v] = out-neighbour set of v (bit u set => edge v->u) */
var PG_NV  : [u32; 1]
var PG_WE  : [u64; 1]     /* cached Even winning region after pg_solve_even */
var PG_SOLVED : [u8; 1]

fn pg_nv() -> u32 { return PG_NV[0u64] }
fn pg_full() -> u64 { let n : u32 = PG_NV[0u64]  if n >= 64u32 { return 0xFFFFFFFFFFFFFFFFu64 }  return (1u64 << (n as u64)) - 1u64 }

/* ---- public arena construction ---- */
fn pg_reset(n: u32) -> i32 @export {
    if n > PG_MAX { return 0i32 - 1i32 }            /* [OOB] @export: n caps the PG_* arrays at 64 */
    PG_NV[0u64] = n  PG_SOLVED[0u64] = 0u8  PG_WE[0u64] = 0u64
    let mut v : u32 = 0u32
    while v < n { PG_OWN[v as u64] = 0u8  PG_PRI[v as u64] = 0u32  PG_SUC[v as u64] = 0u64  v = v + 1u32 }
    return 0i32
}
fn pg_set_owner(v: u32, owner: u8) -> i32 @export {
    if v >= PG_NV[0u64] { return 0i32 - 1i32 }       /* [OOB] @export: v indexes PG_OWN[64] */
    if owner == 0u8 { PG_OWN[v as u64] = 0u8 } else { PG_OWN[v as u64] = 1u8 }
    PG_SOLVED[0u64] = 0u8
    return 0i32
}
fn pg_set_prio(v: u32, p: u32) -> i32 @export {
    if v >= PG_NV[0u64] { return 0i32 - 1i32 }       /* [OOB] @export: v indexes PG_PRI[64] */
    PG_PRI[v as u64] = p  PG_SOLVED[0u64] = 0u8
    return 0i32
}
fn pg_add_edge(u: u32, w: u32) -> i32 @export {
    let n : u32 = PG_NV[0u64]
    if u >= n { return 0i32 - 1i32 }                 /* [OOB] @export: u indexes PG_SUC[64]; w is a bit position < 64 */
    if w >= n { return 0i32 - 1i32 }
    PG_SUC[u as u64] = PG_SUC[u as u64] | (1u64 << (w as u64))
    PG_SOLVED[0u64] = 0u8
    return 0i32
}

/* ---- Zielonka internals (operate on u64 region bitmasks) ---- */
fn pg_max_prio(region: u64) -> u32 {
    let n : u32 = PG_NV[0u64]  let mut m : u32 = 0u32  let mut v : u32 = 0u32
    while v < n { if (region & (1u64 << (v as u64))) != 0u64 { if PG_PRI[v as u64] > m { m = PG_PRI[v as u64] } }  v = v + 1u32 }
    return m
}
fn pg_attractor(region: u64, player: u32, target: u64) -> u64 {
    let n : u32 = PG_NV[0u64]  let mut a : u64 = target & region  let mut done : u8 = 0u8
    while done == 0u8 {
        let mut added : u8 = 0u8  let mut v : u32 = 0u32
        while v < n {
            let bit : u64 = 1u64 << (v as u64)
            if (region & bit) != 0u64 { if (a & bit) == 0u64 {
                if PG_OWN[v as u64] == (player as u8) {
                    if (PG_SUC[v as u64] & a & region) != 0u64 { a = a | bit  added = 1u8 }
                } else {
                    let sir : u64 = PG_SUC[v as u64] & region
                    if sir != 0u64 { if (sir & (a ^ 0xFFFFFFFFFFFFFFFFu64)) == 0u64 { a = a | bit  added = 1u8 } }
                }
            } }
            v = v + 1u32
        }
        if added == 0u8 { done = 1u8 }
    }
    return a
}
/* returns the Even (player-0) winning region WITHIN `region` */
fn pg_zielonka(region: u64) -> u64 {
    if region == 0u64 { return 0u64 }
    let d : u32 = pg_max_prio(region)  let p : u32 = d & 1u32
    let n : u32 = PG_NV[0u64]  let mut u : u64 = 0u64  let mut v : u32 = 0u32
    while v < n { if (region & (1u64 << (v as u64))) != 0u64 { if PG_PRI[v as u64] == d { u = u | (1u64 << (v as u64)) } }  v = v + 1u32 }
    let a : u64 = pg_attractor(region, p, u)
    let rest1 : u64 = region & (a ^ 0xFFFFFFFFFFFFFFFFu64)
    let we1 : u64 = pg_zielonka(rest1)
    let wo1 : u64 = rest1 & (we1 ^ 0xFFFFFFFFFFFFFFFFu64)
    let mut wopp : u64 = wo1  if p != 0u32 { wopp = we1 }
    if wopp == 0u64 {
        if p == 0u32 { return region }              /* Even is the top player and wins all of region */
        return 0u64                                  /* Odd wins all of region -> Even wins none */
    }
    let opp : u32 = 1u32 - p
    let b : u64 = pg_attractor(region, opp, wopp)
    let we2 : u64 = pg_zielonka(region & (b ^ 0xFFFFFFFFFFFFFFFFu64))
    if p == 0u32 { return we2 }                      /* Even=p: Even keeps we2; Odd gets b + its sub-win */
    return we2 | b                                   /* Odd=p: Even gets b + we2 */
}

/* ---- public solve / query ---- */
fn pg_solve_even() -> u64 @export {
    let n : u32 = PG_NV[0u64]
    if n == 0u32 { PG_WE[0u64] = 0u64  PG_SOLVED[0u64] = 1u8  return 0u64 }
    /* totality check: every vertex must have an out-edge */
    let mut v : u32 = 0u32
    while v < n { if PG_SUC[v as u64] == 0u64 { return PG_E_DEADEND }  v = v + 1u32 }
    let we : u64 = pg_zielonka(pg_full())
    PG_WE[0u64] = we  PG_SOLVED[0u64] = 1u8
    return we
}
fn pg_winner(v: u32) -> u8 @export {                 /* 0 = Even wins v, 1 = Odd wins v; requires pg_solve_even first */
    if v >= PG_NV[0u64] { return 0xFFu8 }            /* [OOB] @export: v indexes the winning-region bit */
    if PG_SOLVED[0u64] == 0u8 { return 0xFFu8 }
    if (PG_WE[0u64] & (1u64 << (v as u64))) != 0u64 { return 0u8 }
    return 1u8
}

/* ---- self-test: the control-blindness witness (corpus 1848) -- owner of v flips the winner with the graph fixed ---- */
fn pg_kat() -> u64 @export {
    /* V = {0:v, 1:x, 2:y}; pr = (0,1,2); E = { v<->x, v<->y } */
    /* scenario A: v owned by Even -> Even forces the v<->y cycle (max prio 2, even) -> Even wins ALL */
    pg_reset(3u32)
    pg_set_prio(0u32, 0u32)  pg_set_prio(1u32, 1u32)  pg_set_prio(2u32, 2u32)
    pg_set_owner(0u32, 0u8)  pg_set_owner(1u32, 1u8)  pg_set_owner(2u32, 1u8)
    pg_add_edge(0u32, 1u32)  pg_add_edge(1u32, 0u32)
    pg_add_edge(0u32, 2u32)  pg_add_edge(2u32, 0u32)
    let wa : u64 = pg_solve_even()
    if wa != 7u64 { return 10u64 }                   /* Even wins {0,1,2} = 0b111 */
    /* scenario B: same graph, v owned by Odd -> Odd forces v<->x (max prio 1, odd) -> Even wins NONE */
    pg_set_owner(0u32, 1u8)
    let wb : u64 = pg_solve_even()
    if wb != 0u64 { return 11u64 }                   /* Even wins nothing */
    if pg_winner(0u32) != 1u8 { return 12u64 }       /* Odd wins v */
    /* a deadend arena returns the sentinel */
    pg_reset(2u32)  pg_set_prio(0u32, 2u32)  pg_add_edge(0u32, 1u32)   /* vertex 1 has no out-edge */
    if pg_solve_even() != PG_E_DEADEND { return 13u64 }
    /* a clean 1-vertex even self-loop: Even wins it */
    pg_reset(1u32)  pg_set_prio(0u32, 2u32)  pg_set_owner(0u32, 0u8)  pg_add_edge(0u32, 0u32)
    if pg_solve_even() != 1u64 { return 14u64 }
    return 99u64
}
