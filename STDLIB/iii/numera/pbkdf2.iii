/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\pbkdf2.iii
 *
 * III STDLIB - numera::pbkdf2
 *
 * RFC 8018 / 2898 PBKDF2 password-based key derivation using HMAC-SHA256.
 * Slow by design (iteration count parameter).
 *
 * Split API:
 *   pbkdf2_sha256_set_salt(salt:*u8, salt_len:u64) -> i32   (salt_len <= 256)
 *   pbkdf2_sha256_set_iter(iterations:u32) -> i32
 *   pbkdf2_sha256_derive(password:*u8, password_len:u64, dk:*u8, dk_len:u64) -> i32
 * Oneshot (APOTHEOSIS S.5):
 *   pbkdf2_sha256_oneshot(password, password_len, salt, salt_len, iterations, dk, dk_len) -> i32
 *
 * APOTHEOSIS S.5 (H-2).  Work buffers are now FIXED .bss module arrays
 * (PBK_WORK_*), not arena allocations -- pbkdf2 no longer depends on arena.iii.
 * (The prior arena_new(8192) was a ONE-TIME lazy init, not per-call; pure module
 * buffers are leaner: zero allocation, one fewer dependency.)
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00.
 */

module numera_pbkdf2

extern @abi(c-msvc-x64) fn hmac_sha256(key: *u8, key_len: u64, msg: *u8, msg_len: u64) -> i32 from "hmac.iii"
extern @abi(c-msvc-x64) fn hmac_sha256_tag(out_32: *u8) -> i32 from "hmac.iii"

const PBKDF2_OK : i32 = 0i32
const PBKDF2_E_INIT : i32 = -1i32

/* Fixed module work buffers (S.5: no arena). */
var PBK_WORK_SALT : [u8; 256]      /* caller salt copy */
var PBK_WORK_MSG  : [u8; 4096]     /* salt || INT(i) */
var PBK_WORK_T    : [u8; 32]       /* T_i */
var PBK_WORK_U    : [u8; 32]       /* U_j */
var PBK_SALT_LEN  : u64 = 0u64
var PBK_ITER      : u32 = 1u32
var PBK_SALT_SET  : u8  = 0u8

fn pbkdf2_sha256_set_salt(salt: *u8, salt_len: u64) -> i32 @export {
    if salt_len > 256u64 { return PBKDF2_E_INIT }       /* fixed-buffer bound guard */
    let sp : *u8 = (&PBK_WORK_SALT) as u64 as *u8
    let mut i : u64 = 0u64
    while i < salt_len {
        sp[i] = salt[i]
        i = i + 1u64
    }
    PBK_SALT_LEN = salt_len
    PBK_SALT_SET = 1u8
    return PBKDF2_OK
}

fn pbkdf2_sha256_set_iter(iterations: u32) -> i32 @export {
    PBK_ITER = iterations
    return PBKDF2_OK
}

fn pbkdf2_sha256_derive(password: *u8, password_len: u64, dk: *u8, dk_len: u64) -> i32 @export {
    if PBK_SALT_SET == 0u8 { return PBKDF2_E_INIT }
    /* For each 32-byte block i: T_i = U_1 ^ ... ^ U_iter;
     * U_1 = HMAC(password, salt || INT(i)),  U_j = HMAC(password, U_{j-1}). */
    let mut block_idx : u32 = 1u32
    let mut written : u64 = 0u64
    let mp : *u8 = (&PBK_WORK_MSG) as u64 as *u8
    let tp : *u8 = (&PBK_WORK_T) as u64 as *u8
    let up : *u8 = (&PBK_WORK_U) as u64 as *u8
    let sp : *u8 = (&PBK_WORK_SALT) as u64 as *u8
    while written < dk_len {
        /* Build salt || INT(block_idx) BE */
        let mut k : u64 = 0u64
        while k < PBK_SALT_LEN {
            mp[k] = sp[k]
            k = k + 1u64
        }
        mp[PBK_SALT_LEN + 0u64] = ((block_idx >> 24u32) & 0xFFu32) as u8
        mp[PBK_SALT_LEN + 1u64] = ((block_idx >> 16u32) & 0xFFu32) as u8
        mp[PBK_SALT_LEN + 2u64] = ((block_idx >> 8u32)  & 0xFFu32) as u8
        mp[PBK_SALT_LEN + 3u64] = (block_idx & 0xFFu32) as u8
        /* U_1 = HMAC(password, salt||INT) -> tp; copy to up */
        hmac_sha256(password, password_len, mp, PBK_SALT_LEN + 4u64)
        hmac_sha256_tag(tp)
        let mut c : u32 = 0u32
        while c < 32u32 {
            up[c] = tp[c]
            c = c + 1u32
        }
        /* For j = 2..iter: U_j = HMAC(password, U_{j-1}); T ^= U_j */
        let mut j : u32 = 1u32
        while j < PBK_ITER {
            hmac_sha256(password, password_len, up, 32u64)
            hmac_sha256_tag(up)
            let mut x : u32 = 0u32
            while x < 32u32 {
                let tv : u32 = tp[x] as u32
                let uv : u32 = up[x] as u32
                tp[x] = (tv ^ uv) as u8
                x = x + 1u32
            }
            j = j + 1u32
        }
        /* Copy T into dk */
        let mut chunk : u64 = 32u64
        if written + chunk > dk_len { chunk = dk_len - written }
        let mut q : u64 = 0u64
        while q < chunk {
            dk[written + q] = tp[q]
            q = q + 1u64
        }
        written = written + chunk
        block_idx = block_idx + 1u32
    }
    return PBKDF2_OK
}

/* APOTHEOSIS S.5: single-call PBKDF2 (set salt + iter, then derive).  7 params. */
fn pbkdf2_sha256_oneshot(password: *u8, password_len: u64, salt: *u8, salt_len: u64, iterations: u32, dk: *u8, dk_len: u64) -> i32 @export {
    let s : i32 = pbkdf2_sha256_set_salt(salt, salt_len)
    if s != PBKDF2_OK { return s }
    pbkdf2_sha256_set_iter(iterations)
    return pbkdf2_sha256_derive(password, password_len, dk, dk_len)
}
