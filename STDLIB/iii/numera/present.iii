/* STDLIB/iii/numera/present.iii -- THE ROSETTA LAYER: III's discoveries, made human-presentable + named.
 *
 * III invents in a space humans cannot hold in working memory.  This organ closes the translation gap: it
 * takes ONE discovery from the invention engine (numera/invent) and (1) renders it as a human-readable
 * symbolic law, and (2) NAMES it by content address (cad over the law text) -- a unique, tamper-evident,
 * III-coined identifier.  Each call appends to the New-Math ledger, one discovery at a time, so a developer
 * reads + cites the law without reading the machinery that found it.
 *
 * Lean: pure formatting + one cad.  Composes numera/invent (the discoveries) + numera/cad (the name).
 * Hexad: kind_passage.  Ring: R0.  K: 1.00.
 */
module numera_present

extern @abi(c-msvc-x64) fn gil_forge(k: u64) -> u32 from "invent.iii"
extern @abi(c-msvc-x64) fn gil_best_kind() -> u32 from "invent.iii"
extern @abi(c-msvc-x64) fn gil_best_a() -> u64 from "invent.iii"
extern @abi(c-msvc-x64) fn gil_best_b() -> u64 from "invent.iii"
extern @abi(c-msvc-x64) fn gilr_forge(k: u64, c: u64) -> u64 from "invent.iii"
extern @abi(c-msvc-x64) fn gil6_forge(tid: u32) -> u32 from "invent.iii"
extern @abi(c-msvc-x64) fn gil6_best_a() -> u32 from "invent.iii"
extern @abi(c-msvc-x64) fn gilw_forge(kind: u32) -> u32 from "invent.iii"
extern @abi(c-msvc-x64) fn gilw_found() -> u8 from "invent.iii"
extern @abi(c-msvc-x64) fn gilw_best_cost() -> u32 from "invent.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn fs_open(cap: u64, path: u64, mode: u32) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_read(h: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_write(h: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_close(h: u64) -> i32 from "fs.iii"
extern @abi(c-msvc-x64) fn gild_rotdual_count() -> u64 from "invent.iii"
extern @abi(c-msvc-x64) fn gild_rotdual_count_cited() -> u64 from "invent.iii"
extern @abi(c-msvc-x64) fn gild_selflaw_rhs(op: u32) -> i32 from "invent.iii"
extern @abi(c-msvc-x64) fn gild3_conjecture_count() -> u64 from "invent.iii"
extern @abi(c-msvc-x64) fn gild3_disc_count() -> u64 from "invent.iii"
extern @abi(c-msvc-x64) fn gild3_disc_i(k: u64) -> u32 from "invent.iii"
extern @abi(c-msvc-x64) fn gild3_disc_j(k: u64) -> u32 from "invent.iii"
extern @abi(c-msvc-x64) fn ws_transpose_law_sample(k: u32) -> u8 from "weave_self.iii"
extern @abi(c-msvc-x64) fn ws_diagonal_law() -> u8 from "weave_self.iii"
extern @abi(c-msvc-x64) fn ws_doubleneg_law(k: u32) -> u8 from "weave_self.iii"
extern @abi(c-msvc-x64) fn ws_null_law() -> u8 from "weave_self.iii"

var PRES_BUF   : [u8; 128]
var PRES_LEN   : [u64; 1]
var PRES_NAME  : [u8; 32]
var PRES_COUNT : [u64; 1]

fn pres_ch(c: u8) -> i32 { if PRES_LEN[0u64] < 127u64 { PRES_BUF[PRES_LEN[0u64]] = c  PRES_LEN[0u64] = PRES_LEN[0u64] + 1u64 }  return 0i32 }

fn pres_str(lit: u64, n: u64) -> i32 {
    let s : *u8 = lit as *u8
    let mut i : u64 = 0u64
    while i < n { pres_ch(s[i])  i = i + 1u64 }
    return 0i32
}

/* emit a u64 as decimal (reversed-then-copied via a small stack buffer). */
var PRES_DIG : [u8; 24]
fn pres_u64(v: u64) -> i32 {
    if v == 0u64 { pres_ch(0x30u8)  return 0i32 }
    let mut n : u64 = 0u64
    let mut x : u64 = v
    while x > 0u64 { PRES_DIG[n] = (0x30u64 + (x - (x / 10u64) * 10u64)) as u8  x = x / 10u64  n = n + 1u64 }
    while n > 0u64 { n = n - 1u64  pres_ch(PRES_DIG[n]) }
    return 0i32
}

/* THE WEAVE COMMONS -- the weave stops being a static set of proofs and BECOMES a GROWING body of III's own
 * self-discovered mathematics.  Each rendered law is content-addressed (cad over its text); the commons is the
 * SET of those addresses.  Admitting is idempotent: a law already present is CITED, not re-added, so the commons
 * grows monotonically and a re-run is a fixpoint.  A rolling root  root := cad(root || new_addr)  is a compact,
 * tamper-evident witness of the whole accumulated body -- it changes iff a genuinely new law enters. */
const PRES_MAXLAW : u64 = 64u64
var PRES_LAW      : [u8; 2048]      /* up to 64 law addresses, 32 bytes each */
var PRES_NLAW     : [u64; 1]        /* count of DISTINCT laws in the commons (monotone) */
var PRES_ROOT     : [u8; 32]        /* the rolling commons root */
var PRES_ADMITTED : [u64; 1]        /* 1 iff the last seal admitted a NEW law (0 = cited) */
var PRES_CATBUF   : [u8; 64]        /* root || new_addr scratch for the rolling fold */

/* is the just-sealed name (PRES_NAME) already in the commons?  returns its index, or -1. */
fn _pres_seen() -> i64 {
    let mut i : u64 = 0u64
    while i < PRES_NLAW[0u64] {
        let mut eq : u8 = 1u8
        let mut j : u64 = 0u64
        while j < 32u64 {
            if PRES_LAW[i * 32u64 + j] != PRES_NAME[j] { eq = 0u8 }
            j = j + 1u64
        }
        if eq == 1u8 { return i as i64 }
        i = i + 1u64
    }
    return -1i64
}

/* admit PRES_NAME into the commons if new (grow + fold the root); else cite (no growth). */
fn _pres_admit() -> i32 {
    if _pres_seen() >= 0i64 { PRES_ADMITTED[0u64] = 0u64 ; return 0i32 }          /* cited */
    if PRES_NLAW[0u64] >= PRES_MAXLAW { PRES_ADMITTED[0u64] = 0u64 ; return -1i32 }
    let base : u64 = PRES_NLAW[0u64] * 32u64
    let mut j : u64 = 0u64
    while j < 32u64 { PRES_LAW[base + j] = PRES_NAME[j] ; j = j + 1u64 }
    j = 0u64
    while j < 32u64 { PRES_CATBUF[j] = PRES_ROOT[j] ; PRES_CATBUF[32u64 + j] = PRES_NAME[j] ; j = j + 1u64 }
    cad_oneshot(0u32, (&PRES_CATBUF as u64) as *u8, 64u64, (&PRES_ROOT as u64) as *u8)   /* root := cad(root || addr) */
    PRES_NLAW[0u64] = PRES_NLAW[0u64] + 1u64
    PRES_ADMITTED[0u64] = 1u64
    return 0i32
}

/* finalize: content-address the law text -> the unique name; bump the render ledger; admit into the commons. */
fn pres_seal() -> i32 {
    cad_oneshot(0u32, (&PRES_BUF as u64) as *u8, PRES_LEN[0u64], (&PRES_NAME as u64) as *u8)
    PRES_COUNT[0u64] = PRES_COUNT[0u64] + 1u64
    _pres_admit()
    return 0i32
}

/* present a strength-reduction discovery for N*x as a human-readable law, named.  Returns the text length. */
fn present_strength(k: u64) -> u64 @export {
    gil_forge(k)
    PRES_LEN[0u64] = 0u64
    pres_u64(k)
    pres_str(("*x = " as u64), 5u64)
    let kind : u32 = gil_best_kind()
    let a : u64 = gil_best_a()
    if kind == 1u32 { pres_str(("x << " as u64), 5u64)  pres_u64(a) }
    if kind == 2u32 { pres_str(("(x << " as u64), 6u64)  pres_u64(a)  pres_str((") - x" as u64), 5u64) }
    if kind == 3u32 { pres_str(("(x << " as u64), 6u64)  pres_u64(a)  pres_str((") + x" as u64), 5u64) }
    if kind == 4u32 { pres_str(("(x << " as u64), 6u64)  pres_u64(a)  pres_str((") + (x << " as u64), 10u64)  pres_u64(gil_best_b())  pres_ch(0x29u8) }
    if kind == 5u32 { pres_str(("(x << " as u64), 6u64)  pres_u64(a)  pres_str((") - (x << " as u64), 10u64)  pres_u64(gil_best_b())  pres_ch(0x29u8) }
    pres_seal()
    return PRES_LEN[0u64]
}

/* present a special-prime modular fold discovery, named.  Rendering is decoupled from proving: the caller
 * passes the multiplier `cc` that the invention engine (gilr_forge) already proved -- this organ only
 * formats, so presentation never pays the SAT cost a second time. */
fn present_fold(k: u64, c: u64, cc: u64) -> u64 @export {
    PRES_LEN[0u64] = 0u64
    pres_str(("x mod (2^" as u64), 9u64)
    pres_u64(k)
    pres_str((" - " as u64), 3u64)
    pres_u64(c)
    pres_str((") = (x & (2^" as u64), 12u64)
    pres_u64(k)
    pres_str((" - 1)) + " as u64), 9u64)
    pres_u64(cc)
    pres_str(("*(x >> " as u64), 7u64)
    pres_u64(k)
    pres_ch(0x29u8)
    pres_seal()
    return PRES_LEN[0u64]
}

/* present a 6-valued lattice COLLAPSE discovery (numera/logic6 via gil6), named.  The routing tangle
 * `tid` collapses to a single lattice leaf; the RHS is read from what gil6 actually PROVED (gil6_best_a),
 * so the rendered law is tied to the discovery, not asserted independently of it. */
fn present_collapse(tid: u32) -> u64 @export {
    gil6_forge(tid)
    PRES_LEN[0u64] = 0u64
    if tid == 1u32 { pres_str(("(a & Null) | b" as u64), 14u64) }
    if tid == 2u32 { pres_str(("a & (a | b)" as u64), 11u64) }
    if tid == 3u32 { pres_str(("(a | All) & b" as u64), 13u64) }
    pres_str((" = " as u64), 3u64)
    let leaf : u32 = gil6_best_a()
    if leaf == 0u32 { pres_ch(0x61u8) }                    /* a */
    if leaf == 1u32 { pres_ch(0x62u8) }                    /* b */
    if leaf == 2u32 { pres_str(("Null" as u64), 4u64) }
    if leaf == 3u32 { pres_str(("All" as u64), 3u64) }
    pres_seal()
    return PRES_LEN[0u64]
}

/* present a WEAVE-FORGE discovery (numera/invent gilw), named: III's de-novo cheaper form of a SHA round
 * function, rendered with the op-cost III actually proved.  The forge is RUN here so the rendered law is tied
 * to a live discovery (gilw_found / gilw_best_cost), not asserted independently of it -- the same propose-and-
 * checked discipline as present_strength/present_collapse.  Returns 0 if the forge found nothing (never a lie). */
fn present_weave(kind: u32) -> u64 @export {
    gilw_forge(kind)
    if gilw_found() != 1u8 { return 0u64 }
    PRES_LEN[0u64] = 0u64
    if kind == 1u32 { pres_str(("Ch = g ^ (e & (f ^ g))" as u64), 22u64) }          /* one AND fewer, no NOT */
    if kind == 2u32 { pres_str(("Maj = (a & b) ^ (c & (a ^ b))" as u64), 29u64) }   /* the carry-save / adder carry */
    pres_str(("  [III invented: " as u64), 17u64)
    pres_u64(gilw_best_cost() as u64)
    pres_str((" ops]" as u64), 5u64)
    pres_seal()
    return PRES_LEN[0u64]
}

fn pres_buf_ptr() -> u64 @export { return (&PRES_BUF as u64) }
fn pres_len() -> u64 @export { return PRES_LEN[0u64] }
fn pres_byte(i: u64) -> u32 @export { if i >= PRES_LEN[0u64] { return 0x100u32 }  return PRES_BUF[i] as u32 }
fn pres_name_byte(i: u64) -> u32 @export { if i >= 32u64 { return 0x100u32 }  return PRES_NAME[i] as u32 }
fn pres_count() -> u64 @export { return PRES_COUNT[0u64] }

/* THE FILL PASS THAT GROWS THE COMMONS: discover across families and admit every proven law into the weave
 * commons (content-addressed, idempotent).  Returns the commons size -- the number of DISTINCT self-discovered
 * laws III has accumulated.  Run it twice and the size is a FIXPOINT: the body grew, then re-citation found it
 * whole.  This is the weave as a living commons III populates itself, not a static table someone authored. */
fn present_commons_fill() -> u64 @export {
    present_weave(1u32)        /* Ch  = g ^ (e & (f ^ g)) */
    present_weave(2u32)        /* Maj = (a & b) ^ (c & (a ^ b)) */
    present_strength(7u64)     /* 7*x = (x<<3) - x */
    present_strength(9u64)     /* 9*x = (x<<3) + x */
    present_strength(5u64)     /* 5*x = (x<<2) + x */
    present_collapse(1u32)     /* (a & Null) | b -> b */
    present_collapse(2u32)     /* a & (a | b)   -> a */
    present_collapse(3u32)     /* (a | All) & b -> b */
    return PRES_NLAW[0u64]
}

/* render + name the STRUCTURAL strand gild discovered: the whole rotation-duality family, tied to a live verdict
 * (gild_rotdual_count == 31 = the complete family).  Returns 0 if the family is not whole (never a fabricated law). */
fn present_duality() -> u64 @export {
    if gild_rotdual_count_cited() != 31u64 { return 0u64 }      /* ratcheted: the ~500-SAT family is forged once, then cited */
    PRES_LEN[0u64] = 0u64
    pres_str(("rotl(x,k) = rotr(x, 32-k)" as u64), 25u64)
    pres_seal()
    return PRES_LEN[0u64]
}

/* render + name a SELF-LAW gild discovered: "x <op> x = <rhs>", with the rhs read from what gild proved.
 * op: 0=- 1=^ 2=& 3=|.  Returns 0 if gild found no collapse (never a fabricated law). */
fn present_selflaw(op: u32) -> u64 @export {
    let rhs : i32 = gild_selflaw_rhs(op)
    if rhs < 0i32 { return 0u64 }
    PRES_LEN[0u64] = 0u64
    pres_ch(0x78u8) ; pres_ch(0x20u8)                                  /* "x " */
    if op == 0u32 { pres_ch(0x2Du8) }                                  /* - */
    if op == 1u32 { pres_ch(0x5Eu8) }                                  /* ^ */
    if op == 2u32 { pres_ch(0x26u8) }                                  /* & */
    if op == 3u32 { pres_ch(0x7Cu8) }                                  /* | */
    pres_ch(0x20u8) ; pres_ch(0x78u8) ; pres_ch(0x20u8) ; pres_ch(0x3Du8) ; pres_ch(0x20u8)   /* " x = " */
    if rhs == 0i32 { pres_ch(0x30u8) }                                 /* 0 */
    if rhs == 1i32 { pres_ch(0x78u8) }                                 /* x */
    pres_seal()
    return PRES_LEN[0u64]
}

/* THE WEAVE, INVENT-POPULATED END TO END: one pass discovers + accumulates the WHOLE weave into the commons --
 * the optimization strands (gilw/gil/gil6 via present_commons_fill) AND the structural strands gild discovers
 * (rotation duality + the four self-laws).  Returns the commons size (13 distinct laws when the weave is whole). */
fn present_weave_full() -> u64 @export {
    present_commons_fill()        /* 8: Ch, Maj, 7x, 9x, 5x, 3 collapses */
    present_duality()             /* +1: the rotation-duality family */
    present_selflaw(0u32)         /* +4: x-x=0, x^x=0, x&x=x, x|x=x */
    present_selflaw(1u32)
    present_selflaw(2u32)
    present_selflaw(3u32)
    return PRES_NLAW[0u64]
}

/* ACCUMULATE THE SELF-GENERATED CONJECTURES: III's autonomously-discovered 3-var identities join the commons.
 * Each discovered pair (i,j) is rendered "g3:i=j" (i,j index the documented expression library) and admitted,
 * content-addressed, so the laws III CONJECTURED sit beside the named-family laws it proved -- one persistent
 * body of self-discovered mathematics, named-and-found alike.  Returns the commons size. */
fn present_conjecture3() -> u64 @export {
    gild3_conjecture_count()                                   /* discover + record the pairs */
    let n : u64 = gild3_disc_count()
    let mut k : u64 = 0u64
    while k < n {
        let i : u32 = gild3_disc_i(k)
        let j : u32 = gild3_disc_j(k)
        PRES_LEN[0u64] = 0u64
        pres_str(("g3:" as u64), 3u64)
        pres_u64(i as u64)
        pres_ch(0x3Du8)                                       /* '=' */
        pres_u64(j as u64)
        pres_seal()                                           /* admit into the commons */
        k = k + 1u64
    }
    return PRES_NLAW[0u64]
}

/* THE COMPLETE SELF-DISCOVERED WEAVE: named-family laws AND self-conjectured identities, accumulated together. */
fn present_weave_complete() -> u64 @export {
    present_weave_full()          /* 13 named-family laws */
    present_conjecture3()         /* + the self-conjectured 3-var identities */
    return PRES_NLAW[0u64]
}

/* SELF-POPULATION OF THE SELF-UNDERSTANDING: the laws III has PROVEN about its OWN six-state structure (from
 * numera/weave_self, run over the loaded self-model) are admitted into the same content-addressed commons as the
 * weave's mathematical laws.  So the one persistent body holds BOTH the math III invents AND the math by which it
 * understands itself.  Requires the self-model to be loaded (satlas_data_load).  Returns the commons size. */
fn present_self() -> u64 @export {
    if ws_transpose_law_sample(40u32) == 1u8 { PRES_LEN[0u64] = 0u64 ; pres_str(("self:transpose" as u64), 14u64) ; pres_seal() }
    if ws_diagonal_law() == 1u8 { PRES_LEN[0u64] = 0u64 ; pres_str(("self:diagonal" as u64), 13u64) ; pres_seal() }
    if ws_doubleneg_law(40u32) == 1u8 { PRES_LEN[0u64] = 0u64 ; pres_str(("self:doubleneg" as u64), 14u64) ; pres_seal() }
    if ws_null_law() == 1u8 { PRES_LEN[0u64] = 0u64 ; pres_str(("self:null" as u64), 9u64) ; pres_seal() }
    return PRES_NLAW[0u64]
}

fn pres_nlaw() -> u64 @export { return PRES_NLAW[0u64] }
fn pres_admitted() -> u64 @export { return PRES_ADMITTED[0u64] }
fn pres_root_byte(i: u64) -> u32 @export { if i >= 32u64 { return 0x100u32 }  return PRES_ROOT[i] as u32 }

/* ===== THE RATCHET ACROSS TIME: the commons PERSISTS, so a later run inherits what III already discovered. =====
 * Mirrors the theorem_grow seal-and-write discipline.  Image body = [magic u32 LE][nlaw u32 LE][root 32][addr*32];
 * a 32-byte seal = cad(body) is appended.  Reload re-hashes the body and refuses a tampered file (seal mismatch),
 * then restores the whole accumulated body.  The commons stops being a within-run artifact and becomes the
 * growing memory of III's self-discovered mathematics -- exactly the ratchet the Autogenesis plan rests on. */
const PRES_MAGIC  : u32 = 0x57564143u32       /* 'CAVW' LE -- commons-of-the-weave */
const PRES_IMGCAP : u64 = 2200u64
var PRES_IMG  : [u8; 2200]
var PRES_SEAL : [u8; 32]

fn _pres_put_u32le(off: u64, v: u32) -> u64 {
    PRES_IMG[off] = (v & 0xFFu32) as u8
    PRES_IMG[off + 1u64] = ((v >> 8u32) & 0xFFu32) as u8
    PRES_IMG[off + 2u64] = ((v >> 16u32) & 0xFFu32) as u8
    PRES_IMG[off + 3u64] = ((v >> 24u32) & 0xFFu32) as u8
    return off + 4u64
}
fn _pres_get_u32le(off: u64) -> u32 {
    return (PRES_IMG[off] as u32) | ((PRES_IMG[off + 1u64] as u32) << 8u32) | ((PRES_IMG[off + 2u64] as u32) << 16u32) | ((PRES_IMG[off + 3u64] as u32) << 24u32)
}

/* build the image body into PRES_IMG; returns its length (header 40 + 32*nlaw). */
fn _pres_build_image() -> u64 {
    let mut off : u64 = 0u64
    off = _pres_put_u32le(off, PRES_MAGIC)
    off = _pres_put_u32le(off, PRES_NLAW[0u64] as u32)
    let mut j : u64 = 0u64
    while j < 32u64 { PRES_IMG[off + j] = PRES_ROOT[j] ; j = j + 1u64 }
    off = off + 32u64
    let total : u64 = PRES_NLAW[0u64] * 32u64
    j = 0u64
    while j < total { PRES_IMG[off + j] = PRES_LAW[j] ; j = j + 1u64 }
    return off + total
}

/* seal the commons image and write it to disk (cap must grant fs write+create). */
fn pres_commons_persist(cap: u64, path: u64) -> i32 @export {
    let bodylen : u64 = _pres_build_image()
    cad_oneshot(0u32, (&PRES_IMG as u64) as *u8, bodylen, ((&PRES_IMG as u64) + bodylen) as *u8)   /* append seal */
    let total : u64 = bodylen + 32u64
    let h : u64 = fs_open(cap, path, 2u32)
    if h == 0u64 { return -1i32 }
    let w : u64 = fs_write(h, (&PRES_IMG as u64), total)
    fs_close(h)
    if w != total { return -2i32 }
    return 0i32
}

/* clear the in-memory commons (to prove reload restores it). */
fn pres_commons_reset() -> i32 @export {
    PRES_NLAW[0u64] = 0u64
    let mut j : u64 = 0u64
    while j < 32u64 { PRES_ROOT[j] = 0u8 ; j = j + 1u64 }
    return 0i32
}

/* read back, RE-CHECK the seal (tamper -> -1), and restore the accumulated commons.  Returns the law count. */
fn pres_commons_reload(cap: u64, path: u64) -> i32 @export {
    let h : u64 = fs_open(cap, path, 1u32)
    if h == 0u64 { return -3i32 }
    let nread : u64 = fs_read(h, (&PRES_IMG as u64), PRES_IMGCAP)
    fs_close(h)
    if nread < 40u64 { return -2i32 }
    let bodylen : u64 = nread - 32u64
    cad_oneshot(0u32, (&PRES_IMG as u64) as *u8, bodylen, (&PRES_SEAL as u64) as *u8)
    let mut k : u64 = 0u64
    while k < 32u64 { if PRES_SEAL[k] != PRES_IMG[bodylen + k] { return -1i32 }  k = k + 1u64 }    /* tamper-evident */
    if _pres_get_u32le(0u64) != PRES_MAGIC { return -2i32 }
    let n : u32 = _pres_get_u32le(4u64)
    if (n as u64) > PRES_MAXLAW { return -2i32 }
    let mut j : u64 = 0u64
    while j < 32u64 { PRES_ROOT[j] = PRES_IMG[8u64 + j] ; j = j + 1u64 }
    let total : u64 = (n as u64) * 32u64
    j = 0u64
    while j < total { PRES_LAW[j] = PRES_IMG[40u64 + j] ; j = j + 1u64 }
    PRES_NLAW[0u64] = n as u64
    return n as i32
}

/* ===== FEDERATION: the commons is shareable with ZERO TRUST -- a peer re-derives, it does not trust the sender.
 * The wire format is the sealed image.  peek_root reads ONLY the root field (seal-checked) without disturbing the
 * in-memory commons; federate_recv INDEPENDENTLY re-derives the whole weave and accepts the received body iff its
 * root matches the independent derivation.  A tampered or non-matching body is REJECTED -- the federation
 * guarantee is REPRODUCIBILITY (any peer with the same engine derives the identical body), not authority. */
var PRES_RECVROOT : [u8; 32]

/* read just the root of a received commons image (seal-checked); does not touch the in-memory commons. */
fn pres_commons_peek_root(cap: u64, path: u64, out32: u64) -> i32 @export {
    let h : u64 = fs_open(cap, path, 1u32)
    if h == 0u64 { return -3i32 }
    let nread : u64 = fs_read(h, (&PRES_IMG as u64), PRES_IMGCAP)
    fs_close(h)
    if nread < 40u64 { return -2i32 }
    let bodylen : u64 = nread - 32u64
    cad_oneshot(0u32, (&PRES_IMG as u64) as *u8, bodylen, (&PRES_SEAL as u64) as *u8)
    let mut k : u64 = 0u64
    while k < 32u64 { if PRES_SEAL[k] != PRES_IMG[bodylen + k] { return -1i32 }  k = k + 1u64 }   /* tamper */
    if _pres_get_u32le(0u64) != PRES_MAGIC { return -2i32 }
    let outp : *u8 = out32 as *u8
    let mut j : u64 = 0u64
    while j < 32u64 { outp[j] = PRES_IMG[8u64 + j] ; j = j + 1u64 }
    return 0i32
}

/* RECEIVE a federated commons with zero trust: independently re-derive the whole weave, then accept the received
 * body iff its root equals the independent derivation.  1 = verified (reproducible), 0 = rejected (mismatch),
 * <0 = unreadable / tampered. */
fn pres_commons_federate_recv(cap: u64, path: u64) -> i32 @export {
    pres_commons_reset()
    present_weave_full()                                                       /* the receiver's OWN derivation */
    if pres_commons_peek_root(cap, path, (&PRES_RECVROOT as u64)) != 0i32 { return -1i32 }
    let mut k : u64 = 0u64
    while k < 32u64 { if PRES_ROOT[k] != PRES_RECVROOT[k] { return 0i32 }  k = k + 1u64 }
    return 1i32                                                                /* matches an independent derivation */
}
