/* STDLIB/iii/numera/proof_jit.iii -- THE KERNEL JIT, VERDICT-IDENTICAL BY CONSTRUCTION
 * (III-PHASE3-WALLS, Campaign II, organ 2).
 *
 * Campaign II makes the kernel FASTER while provably computing the SAME verdicts.  A JIT rewrites a hot-
 * path operation into a cheaper one and emits hand-tuned ISA; the danger is that a rewrite silently
 * changes an answer.  This organ forbids that: every rewrite the JIT performs must be DISCHARGED by the
 * kernel's own conversion oracle (tc_conv) before it is allowed, so a verdict-changing "optimization" is
 * structurally impossible.
 *
 * THE REWRITE: strength-reduce  x * 8  (a multiply) to  x << 3  (a shift) -- the canonical JIT win.  It is
 * admitted ONLY because the kernel certifies x<<3 == x*8 (tc_conv == 1); a WRONG reduction x*8 -> x<<2 is
 * REFUSED by the same oracle (tc_conv == 0), so the JIT cannot substitute a non-equivalent op.  The two
 * forms also evaluate (tc_eval) to identical values at every concrete input.
 *
 * THE EMISSION: omnia/xii_kernel_emit produces the optimized op's machine-code fragment DETERMINISTICALLY
 * (same kind -> byte-identical bytes) and non-empty -- a real ISA emitter (168 sealed fragments), not a
 * placeholder.
 *
 * THE HONEST FLOOR: this certifies the SOURCE-LEVEL verdict-identity of the rewrite (kernel-proved) and
 * the integrity of the emission.  Proving the EMITTED MACHINE CODE itself computes the certified op --
 * assembling the bytes, executing them, and byte/value-diffing against the reference -- is the build-time
 * differential gate (the gcc-assemble -> objdump-lift -> offline-execute pattern), a receding boundary,
 * never faked: the in-organ guarantee is "the JIT may only emit a kernel-certified-equivalent op".
 *
 * Hexad: kind_cognition.  Ring: R0.  K: 0.99.  Composes numera/typecheck (tc_conv/tc_eval, the verdict
 * oracle) + omnia/xii_kernel_emit (the ISA emitter) -- no island.  Determinism: integer-only; byte-wise
 * fragment compare; no float.
 */
module numera_proof_jit

extern @abi(c-msvc-x64) fn tc_reset() -> u64 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_var(k: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bvlit(lo: u32, hi: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bvmul(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bvshl(a: u32, b: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_conv(x: u32, y: u32) -> u8 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_eval(t: u32, x0: u64, x1: u64) -> u64 from "typecheck.iii"
extern @abi(c-msvc-x64) fn xii_kernel_emit_fragment(kind: u8, target: u8, out: *u8) -> u32 from "xii_kernel_emit.iii"
extern @abi(c-msvc-x64) fn xii_kernel_emit_fragment_count() -> u32 from "xii_kernel_emit.iii"

var PJ_BUF1 : [u8; 256]
var PJ_BUF2 : [u8; 256]

fn pj_lit(v: u64) -> u32 { return tc_bvlit((v & 0xFFFFFFFFu64) as u32, (v >> 32u64) as u32) }

/* the JIT rewrite x*8 -> x<<3 is verdict-identical iff the kernel certifies it (tc_conv == 1). */
fn pj_opt_certified() -> u8 @export {
    tc_reset()
    let x : u32 = tc_var(0u32)
    let refm : u32 = tc_bvmul(x, pj_lit(8u64))
    let opt  : u32 = tc_bvshl(x, pj_lit(3u64))
    return tc_conv(opt, refm)
}

/* a WRONG reduction x*8 -> x<<2 is REFUSED by the kernel -- the verdict-identity guard has teeth. */
fn pj_bad_rejected() -> u8 @export {
    tc_reset()
    let x : u32 = tc_var(0u32)
    let refm : u32 = tc_bvmul(x, pj_lit(8u64))
    let bad  : u32 = tc_bvshl(x, pj_lit(2u64))
    if tc_conv(bad, refm) == 0u8 { return 1u8 }
    return 0u8
}

/* value-differential: the optimized op computes the SAME value as the reference at a concrete input. */
fn pj_value_identical(v: u64) -> u8 @export {
    tc_reset()
    let x : u32 = tc_var(0u32)
    let refm : u32 = tc_bvmul(x, pj_lit(8u64))
    let opt  : u32 = tc_bvshl(x, pj_lit(3u64))
    if tc_eval(refm, v, 0u64) == tc_eval(opt, v, 0u64) { return 1u8 }
    return 0u8
}

/* a WRONG reduction also DIVERGES in value (so the kernel guard is not the only line of defence). */
fn pj_bad_value_diverges(v: u64) -> u8 @export {
    tc_reset()
    let x : u32 = tc_var(0u32)
    let refm : u32 = tc_bvmul(x, pj_lit(8u64))
    let bad  : u32 = tc_bvshl(x, pj_lit(2u64))
    if tc_eval(refm, v, 0u64) != tc_eval(bad, v, 0u64) { return 1u8 }
    return 0u8
}

/* the kernel-ISA emitter produces a non-empty fragment for `kind`, deterministically (byte-identical). */
fn pj_emit_deterministic(kind: u8) -> u8 @export {
    let l1 : u32 = xii_kernel_emit_fragment(kind, 0u8, (&PJ_BUF1 as u64) as *u8)
    let l2 : u32 = xii_kernel_emit_fragment(kind, 0u8, (&PJ_BUF2 as u64) as *u8)
    if l1 == 0u32 { return 0u8 }
    if l1 != l2 { return 0u8 }
    if l1 > 256u32 { return 0u8 }
    let mut i : u64 = 0u64
    while i < (l1 as u64) {
        if PJ_BUF1[i] != PJ_BUF2[i] { return 0u8 }
        i = i + 1u64
    }
    return 1u8
}

fn pj_fragment_count() -> u32 @export { return xii_kernel_emit_fragment_count() }
