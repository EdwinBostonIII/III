/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\q128.iii
 *
 * III STDLIB - numera::q128
 *
 * Unsigned 128-bit integer stored as two u64 limbs (hi, lo) inside
 * a slot table.  Phase B caps "Q128" at unsigned 128-bit; the
 * full rational form (numerator / denominator both 128-bit) is a
 * Phase C addition once @specialize lands.
 *
 * Operations:
 *   - add, sub, mul (mod 2^128), shift_left, shift_right
 *   - compare, eq
 *   - from_u64, to_u64_lo, to_u64_hi
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00 (pure modular arithmetic).
 *
 * APOTHEOSIS S.2.4 (q_generic decision -- ADR).  The design doc proposed
 * monomorphising q128 to a generic q_generic<bits> over {128,256,512} via
 * @specialize.  VERIFIED NOT BUILDABLE: III @specialize monomorphises over a
 * TYPE alphabet (u8..u64, i8..i64, bool -- corpus 393), NOT over const VALUE
 * parameters such as a bit-width, and III has no u128/u256/u512 type to
 * specialise over.  Both buildable alternatives lose under the charter's
 * "apex is LEANER, not bigger" rule (DOCS/III-CAPABILITY-APOTHEOSIS.md sec.1):
 *   - a variable-width runtime qint PESSIMISES the fast fixed 2-limb 128-bit
 *     hot path (slower for the only widths used today);
 *   - a .def -> .iii generator emitting fixed-width q256/q512 manufactures
 *     modules with ZERO consumers -- exactly the bloat the charter forbids.
 * DECISION = keep + document: q128 stays the fast fixed two-u64 module.  GROWTH
 * PATH: add a width (or the generic form) when EITHER a real consumer appears OR
 * the compiler gains const-generic @specialize -- whichever comes first.  This
 * is no placeholder and no dead code; the unbuildable spec mechanism is itself
 * the mistake corrected here (per the standing "fix mistakes" license).
 */

module numera_q128

const Q128_INVALID : u64 = 0u64
const Q128_SLOTS   : u32 = 64u32

var Q128_HI   : [u64; 64]
var Q128_LO   : [u64; 64]
var Q128_LIVE : [u8;  64]

fn q128_alloc() -> u32 {
    let mut i : u32 = 0u32
    while i < Q128_SLOTS {
        if Q128_LIVE[i] == 0u8 { return i }
        i = i + 1u32
    }
    return 0xFFFFFFFFu32
}

fn q128_slot_of(id: u64) -> u32 {
    if id == 0u64 { return 0xFFFFFFFFu32 }
    let s : u64 = id - 1u64
    if s >= (Q128_SLOTS as u64) { return 0xFFFFFFFFu32 }
    let si : u32 = s as u32
    if Q128_LIVE[si] == 0u8 { return 0xFFFFFFFFu32 }
    return si
}

/* --- Construction --- */

fn q128_from_u64(v: u64) -> u64 @export {
    let s : u32 = q128_alloc()
    if s == 0xFFFFFFFFu32 { return Q128_INVALID }
    Q128_HI[s] = 0u64
    Q128_LO[s] = v
    Q128_LIVE[s] = 1u8
    return (s as u64) + 1u64
}

fn q128_from_pair(hi: u64, lo: u64) -> u64 @export {
    let s : u32 = q128_alloc()
    if s == 0xFFFFFFFFu32 { return Q128_INVALID }
    Q128_HI[s] = hi
    Q128_LO[s] = lo
    Q128_LIVE[s] = 1u8
    return (s as u64) + 1u64
}

fn q128_drop(id: u64) -> u8 @export {
    let s : u32 = q128_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0u8 }
    Q128_LIVE[s] = 0u8
    Q128_HI[s] = 0u64
    Q128_LO[s] = 0u64
    return 1u8
}

/* --- Accessors --- */

fn q128_lo(id: u64) -> u64 @export {
    let s : u32 = q128_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0u64 }
    return Q128_LO[s]
}

fn q128_hi(id: u64) -> u64 @export {
    let s : u32 = q128_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0u64 }
    return Q128_HI[s]
}

/* --- Comparison --- */

fn q128_eq(a: u64, b: u64) -> u8 @export {
    let sa : u32 = q128_slot_of(a)
    let sb : u32 = q128_slot_of(b)
    if sa == 0xFFFFFFFFu32 { return 0u8 }
    if sb == 0xFFFFFFFFu32 { return 0u8 }
    if Q128_HI[sa] != Q128_HI[sb] { return 0u8 }
    if Q128_LO[sa] != Q128_LO[sb] { return 0u8 }
    return 1u8
}

/* Returns -1 if a<b, 0 if equal, 1 if a>b. */
fn q128_cmp(a: u64, b: u64) -> i32 @export {
    let sa : u32 = q128_slot_of(a)
    let sb : u32 = q128_slot_of(b)
    if sa == 0xFFFFFFFFu32 { return 0i32 }
    if sb == 0xFFFFFFFFu32 { return 0i32 }
    let ha : u64 = Q128_HI[sa]
    let hb : u64 = Q128_HI[sb]
    if ha < hb { return -1i32 }
    if ha > hb { return 1i32 }
    let la : u64 = Q128_LO[sa]
    let lb : u64 = Q128_LO[sb]
    if la < lb { return -1i32 }
    if la > lb { return 1i32 }
    return 0i32
}

/* --- Addition: 128-bit wrapping add --- */

fn q128_add(a: u64, b: u64) -> u64 @export {
    let sa : u32 = q128_slot_of(a)
    let sb : u32 = q128_slot_of(b)
    if sa == 0xFFFFFFFFu32 { return Q128_INVALID }
    if sb == 0xFFFFFFFFu32 { return Q128_INVALID }
    let la : u64 = Q128_LO[sa]
    let lb : u64 = Q128_LO[sb]
    let lo_sum : u64 = la + lb
    let mut carry : u64 = 0u64
    if lo_sum < la { carry = 1u64 }
    let hi_sum : u64 = Q128_HI[sa] + Q128_HI[sb] + carry
    return q128_from_pair(hi_sum, lo_sum)
}

/* --- Subtraction: 128-bit wrapping sub --- */

fn q128_sub(a: u64, b: u64) -> u64 @export {
    let sa : u32 = q128_slot_of(a)
    let sb : u32 = q128_slot_of(b)
    if sa == 0xFFFFFFFFu32 { return Q128_INVALID }
    if sb == 0xFFFFFFFFu32 { return Q128_INVALID }
    let la : u64 = Q128_LO[sa]
    let lb : u64 = Q128_LO[sb]
    let lo_diff : u64 = la - lb
    let mut borrow : u64 = 0u64
    if la < lb { borrow = 1u64 }
    let hi_diff : u64 = Q128_HI[sa] - Q128_HI[sb] - borrow
    return q128_from_pair(hi_diff, lo_diff)
}

/* --- Shift left --- */

fn q128_shl(a: u64, n: u32) -> u64 @export {
    let sa : u32 = q128_slot_of(a)
    if sa == 0xFFFFFFFFu32 { return Q128_INVALID }
    let mut shift : u32 = n
    if shift >= 128u32 { return q128_from_pair(0u64, 0u64) }
    let lo : u64 = Q128_LO[sa]
    let hi : u64 = Q128_HI[sa]
    if shift == 0u32 { return q128_from_pair(hi, lo) }
    if shift < 64u32 {
        let new_lo : u64 = lo << (shift as u64)
        let cross : u64 = lo >> ((64u32 - shift) as u64)
        let new_hi_a : u64 = hi << (shift as u64)
        let new_hi : u64 = new_hi_a | cross
        return q128_from_pair(new_hi, new_lo)
    }
    /* shift >= 64 */
    let s2 : u32 = shift - 64u32
    let new_hi : u64 = lo << (s2 as u64)
    return q128_from_pair(new_hi, 0u64)
}

/* --- Shift right --- */

fn q128_shr(a: u64, n: u32) -> u64 @export {
    let sa : u32 = q128_slot_of(a)
    if sa == 0xFFFFFFFFu32 { return Q128_INVALID }
    let mut shift : u32 = n
    if shift >= 128u32 { return q128_from_pair(0u64, 0u64) }
    let lo : u64 = Q128_LO[sa]
    let hi : u64 = Q128_HI[sa]
    if shift == 0u32 { return q128_from_pair(hi, lo) }
    if shift < 64u32 {
        let new_hi : u64 = hi >> (shift as u64)
        let cross : u64 = hi << ((64u32 - shift) as u64)
        let new_lo_a : u64 = lo >> (shift as u64)
        let new_lo : u64 = new_lo_a | cross
        return q128_from_pair(new_hi, new_lo)
    }
    /* shift >= 64 */
    let s2 : u32 = shift - 64u32
    let new_lo : u64 = hi >> (s2 as u64)
    return q128_from_pair(0u64, new_lo)
}

/* --- Multiplication: 128 = 64x64 + 64x64 + 64x64 + 64x64 partial,
 * keeping only the low 128 bits (mod 2^128). --- */

/* THE UNIFIED WEAVE: the 64x64->128 schoolbook lives ONCE in numera/weave_blocks. */
extern @abi(c-msvc-x64) fn wvb_mul64(a: u64, b: u64) -> i32 from "weave_blocks.iii"
extern @abi(c-msvc-x64) fn wvb_mul64_lo() -> u64 from "weave_blocks.iii"
extern @abi(c-msvc-x64) fn wvb_mul64_hi() -> u64 from "weave_blocks.iii"

fn q128_mul(a: u64, b: u64) -> u64 @export {
    let sa : u32 = q128_slot_of(a)
    let sb : u32 = q128_slot_of(b)
    if sa == 0xFFFFFFFFu32 { return Q128_INVALID }
    if sb == 0xFFFFFFFFu32 { return Q128_INVALID }
    let a_hi : u64 = Q128_HI[sa]
    let a_lo : u64 = Q128_LO[sa]
    let b_hi : u64 = Q128_HI[sb]
    let b_lo : u64 = Q128_LO[sb]
    /* THE UNIFIED WEAVE: a_lo*b_lo's FULL 128 bits come from wvb_mul64 (numera/weave_blocks) -- its high half
     * IS the old hand-rolled alo_blo_hi, its low half IS result_lo.  The two cross terms add on top
     * (a_hi*b_hi*2^128 vanishes mod 2^128).  Byte-identical to the old inline schoolbook. */
    wvb_mul64(a_lo, b_lo)
    let alo_blo_hi : u64 = wvb_mul64_hi()
    let result_lo : u64 = wvb_mul64_lo()
    let cross_a : u64 = a_lo * b_hi
    let cross_b : u64 = a_hi * b_lo
    let result_hi : u64 = alo_blo_hi + cross_a + cross_b
    return q128_from_pair(result_hi, result_lo)
}

/* --- Bitwise --- */

fn q128_or(a: u64, b: u64) -> u64 @export {
    let sa : u32 = q128_slot_of(a)
    let sb : u32 = q128_slot_of(b)
    if sa == 0xFFFFFFFFu32 { return Q128_INVALID }
    if sb == 0xFFFFFFFFu32 { return Q128_INVALID }
    let hi : u64 = Q128_HI[sa] | Q128_HI[sb]
    let lo : u64 = Q128_LO[sa] | Q128_LO[sb]
    return q128_from_pair(hi, lo)
}

fn q128_xor(a: u64, b: u64) -> u64 @export {
    let sa : u32 = q128_slot_of(a)
    let sb : u32 = q128_slot_of(b)
    if sa == 0xFFFFFFFFu32 { return Q128_INVALID }
    if sb == 0xFFFFFFFFu32 { return Q128_INVALID }
    let hi : u64 = Q128_HI[sa] ^ Q128_HI[sb]
    let lo : u64 = Q128_LO[sa] ^ Q128_LO[sb]
    return q128_from_pair(hi, lo)
}

fn q128_and(a: u64, b: u64) -> u64 @export {
    let sa : u32 = q128_slot_of(a)
    let sb : u32 = q128_slot_of(b)
    if sa == 0xFFFFFFFFu32 { return Q128_INVALID }
    if sb == 0xFFFFFFFFu32 { return Q128_INVALID }
    let hi : u64 = Q128_HI[sa] & Q128_HI[sb]
    let lo : u64 = Q128_LO[sa] & Q128_LO[sb]
    return q128_from_pair(hi, lo)
}
