/* STDLIB/iii/numera/quine6.iii -- THE SIX-STATE QUINE: a native-weave self-describing content-address.
 *
 * POC for the user's six-state-quine idea + the "more basal than CPUID" behavioral seed.  A six-state symbol is one
 * of {0..5}; q6_addr folds a six-state string into a 24-bit (3-byte) content-address with a deterministic base-6
 * fold + diffusion.  A QUINE here is a self-describing construct: [k six-state symbols][3-byte address of those k] --
 * q6_self_coincident verifies the embedded address equals the freshly-computed one.  This is identity-by-construction
 * (the construct carries + proves its own content-address), the native-weave alternative to a foreign 32-byte hash
 * for the INTERNAL seal (R3-can't-forge; not the external attest, which needs crypto width).  Deterministic +
 * content-sensitive + tamper-evident.  Pure, NIH, no deps.  Ring R0.  KAT: corpus 1815. */
module numera_quine6

const Q6_MASK : u32 = 0xFFFFFFu32   /* 24 bits = 3 bytes */

/* one six-state fold step: base-6 absorb + a 24-bit rotate-xor diffusion (content-sensitive, deterministic). */
fn q6_step(acc: u32, sym: u32) -> u32 {
    let a : u32 = ((acc * 6u32) + (sym % 6u32)) & Q6_MASK
    let r : u32 = ((a << 7u32) | (a >> 17u32)) & Q6_MASK
    return (a ^ r ^ 0x5A5A5Au32) & Q6_MASK
}

/* fold n six-state symbols (one per byte, value taken mod 6) into a 24-bit content-address. */
fn q6_addr(input_ptr: u64, n: u32) -> u32 @export {
    let mut acc : u32 = 0x111111u32
    let mut i : u32 = 0u32
    while i < n {
        let p : *u8 = (input_ptr + (i as u64)) as *u8
        acc = q6_step(acc, p[0u64] as u32)
        i = i + 1u32
    }
    return acc & Q6_MASK
}

/* SEAL: compute the address of the k-symbol prefix and embed it (LE) at offset k -- forging the self-describing
 * quine.  Returns the embedded address. */
fn q6_seal_into(buf_ptr: u64, k: u32) -> u32 @export {
    let a : u32 = q6_addr(buf_ptr, k)
    let p : *u8 = (buf_ptr + (k as u64)) as *u8
    p[0u64] = (a & 0xFFu32) as u8
    p[1u64] = ((a >> 8u32) & 0xFFu32) as u8
    p[2u64] = ((a >> 16u32) & 0xFFu32) as u8
    return a
}

/* SELF-COINCIDENCE: 1 iff the embedded 3-byte address equals the freshly-recomputed address of the prefix --
 * the construct reproduces its own identity (a quine), and any tamper of the prefix breaks it (fail-closed). */
fn q6_self_coincident(buf_ptr: u64, k: u32) -> u8 @export {
    let computed : u32 = q6_addr(buf_ptr, k)
    let p : *u8 = (buf_ptr + (k as u64)) as *u8
    let embedded : u32 = (p[0u64] as u32) | ((p[1u64] as u32) << 8u32) | ((p[2u64] as u32) << 16u32)
    if (computed & Q6_MASK) == (embedded & Q6_MASK) { return 1u8 }
    return 0u8
}
