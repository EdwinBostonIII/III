/* III/STDLIB/iii/numera/reflection_constrained.iii -- Layer 7, Module 70.
 *
 * III STDLIB - numera::reflection_constrained
 *
 * The substrate's bounded self-reflection capability.  Ring R-3, strict
 * isolation: reads R-2 storage, writes nothing R-2 stores.  Constructs
 * machine-checked proof terms ABOUT other modules and enqueues (never
 * ratifies) constitutional / synthesis proposals.
 *
 * LOAD-BEARING INVARIANT (M13/M20/W46): a reflection target may NEVER be this
 * module, the reflection_governance module, or the constitution_preserver.  The
 * forbidden-self-set is built at init and enforced INSIDE the capability
 * (defense-in-depth, both at request-begin and at construct), not left to the
 * caller.
 *
 * Hexad: kind_cognition.  Ring: R-3.  K_reflect: per call (budget, M19).
 * NIH: identifier, algebraic_time, capability, witness_hook, proof_term.
 *
 * SPEC FIXES (intent preserved):
 *   - proof_term is BUILT (spec "NOT-YET-BUILT" stale); its REAL
 *     pt_add_inference is `(args: *u8) -> i32` taking a PACKED aggregate
 *     ([0..32)=tid, [32]=kind, [36..40)=pcount LE, [40..44)=clen LE,
 *     premises, conclusion) -- NOT the spec's 6-scalar gospel form.  The
 *     proof-construct positive arm runs for real (not stubbed): pt_alloc ->
 *     pt_add_inference(AXIOM, pc=0, conclusion=target||property) -> pt_finalize
 *     -> pt_verify==PT_OK.  conclusion capped at PT_CONCLUSION_BYTES=512.
 *   - budget compare is unsigned u64 `>` (Trap-3 is signed-only; unsigned safe).
 *   - all buffer access via *u8 byte pointers; byte-wise LE (Trap 4/5).
 */

module numera_reflection_constrained

extern @abi(c-msvc-x64) fn ident_zero(out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_eq(a: *u8, b: *u8) -> u8 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_copy(src: *u8, dst: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_from_bytes(input: *u8, in_len: u64, out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn at_current() -> u64 from "algebraic_time.iii"
extern @abi(c-msvc-x64) fn cap_verify_rights(id: u64, required: u64) -> u8 from "capability.iii"
/* W4.4 (RIPPLE-13): the single canonical reflect right -- shared with reflection_governance. */
extern @abi(c-msvc-x64) fn cap_right_reflect() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn wh_publish(producer: *u8, opid: *u8, in_commit: *u8, out_commit: *u8, revtag: u8, phase: u8, pillar: u16, antecedents: *u8, n_ante: u32, payload: *u8, payload_len: u32, out_frag_id: *u8) -> u64 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn pt_alloc(out_term_id: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_add_inference(args: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_finalize(term_id: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn pt_verify(term_id: *u8) -> i32 from "proof_term.iii"

// --- KAT-harness externs ---
extern @abi(c-msvc-x64) fn pt_init() -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn wh_init(initial_time: u64) -> i32 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent_id: u64, rights_mask: u64, expires_at: u64) -> u64 from "capability.iii"

const RFLC_OK                 : i32 =  0i32
const RFLC_E_NULL             : i32 = -1i32
const RFLC_E_TARGET_FORBIDDEN : i32 = -2i32
const RFLC_E_BUDGET_EXHAUSTED : i32 = -3i32
const RFLC_E_PROOF_FAILED     : i32 = -4i32
const RFLC_E_NOT_INITED       : i32 = -5i32
const RFLC_E_QUEUE_FULL       : i32 = -6i32
const RFLC_E_CAP_DENIED       : i32 = -7i32
const RFLC_E_NO_REQUEST       : i32 = -8i32
const RFLC_E_PROPERTY_OVERFLOW: i32 = -9i32
const RFLC_E_BAD_SLOT         : i32 = -10i32

const RFLC_PROPOSAL_SLOTS       : u64 = 1024u64
const RFLC_PROPOSAL_PAYLOAD_CAP : u64 = 4096u64
const RFLC_PROPERTY_CAP         : u64 = 4096u64
const RFLC_IDENT_BYTES          : u64 = 32u64
const RFLC_FORBIDDEN_SLOTS      : u64 = 3u64
const RFLC_CONCL_CAP            : u64 = 512u64    // == PT_CONCLUSION_BYTES
const RFLC_PROP_BIND_MAX        : u64 = 480u64    // 512 - 32 (target id)
const RFLC_BUDGET_MAX           : u64 = 1000000u64 // per-call K_reflect ceiling (M19)

const RFLC_KIND_CLAUSE    : u8 = 0u8
const RFLC_KIND_SYNTHESIS : u8 = 1u8
const RFLC_KIND_LIB_ADMIT : u8 = 2u8

const RFLC_PT_AXIOM       : u8  = 0x01u8         // == PT_RULE_AXIOM
const RFLC_PT_OK          : i32 = 0i32           // == PT_OK
const RFLC_FRAG_MAGIC_HI  : u8  = 0xE3u8
const RFLC_FRAG_MAGIC_LO  : u8  = 0x09u8
/* W4.4: cap_right_reflect() removed -- the required right is now the shared cap_right_reflect()
 * (CAP_RIGHT_AMEND), identical to reflection_governance's gate.  See capability.iii. */
const RFLC_PILLAR         : u16 = 0x0046u16
const RFLC_PHASE          : u8  = 0u8
const RFLC_REVTAG         : u8  = 1u8
const RFLC_U64_SENT       : u64 = 0xFFFFFFFFFFFFFFFFu64

const RFLC_TAG_SELF       : u8 = 0x01u8
const RFLC_TAG_GOVERN     : u8 = 0x02u8
const RFLC_TAG_PRESERVER  : u8 = 0x04u8

var RFLC_INITED            : u8 = 0u8
var RFLC_FORBIDDEN_READY   : u8 = 0u8

var RFLC_PROPOSAL_IDS      : [u64; 4096]      // 1024 * 32 bytes (id-array idiom)
var RFLC_PROPOSAL_KINDS    : [u8; 1024]
var RFLC_PROPOSAL_PAYLOADS : [u64; 524288]    // 1024 * 4096 bytes
var RFLC_PROPOSAL_LENS     : [u32; 1024]
var RFLC_PROPOSAL_LIVE     : [u8; 1024]
var RFLC_PROPOSAL_COUNT    : u64 = 0u64

var RFLC_FORBIDDEN_IDS     : [u8; 96]         // 3 * 32: self, governance, preserver

var RFLC_REQ_TARGET        : [u8; 32]
var RFLC_REQ_BUDGET        : [u8; 32]
var RFLC_REQ_PROPERTY      : [u8; 4096]
var RFLC_REQ_PROP_LEN      : u64 = 0u64
var RFLC_REQ_CAP           : u64 = 0u64
var RFLC_REQ_OPEN          : u8  = 0u8

var RFLC_SEED_BUF          : [u8; 8]
var RFLC_PROOF_SEED        : [u8; 544]        // target(32) || property(<=480) -> <=512
var RFLC_PT_ARGS           : [u8; 576]        // pt_add_inference aggregate: 44 hdr + <=512 conclusion
var RFLC_FRAG_PAYLOAD      : [u8; 72]
var RFLC_PRODUCER          : [u8; 32]
var RFLC_OPID              : [u8; 32]
var RFLC_IN_COMMIT         : [u8; 32]
var RFLC_OUT_COMMIT        : [u8; 32]
var RFLC_FRAG_ID           : [u8; 32]
var RFLC_ZERO_ANTE         : [u8; 32]

// --- self-test scratch ---
var RFLC_ST_SELF           : [u8; 32]
var RFLC_ST_GOV            : [u8; 32]
var RFLC_ST_PRES           : [u8; 32]
var RFLC_ST_OTHER          : [u8; 32]
var RFLC_ST_TERM           : [u8; 32]
var RFLC_ST_PID            : [u8; 32]
var RFLC_ST_PID2           : [u8; 32]
var RFLC_ST_SPEC           : [u8; 32]
var RFLC_ST_PROP           : [u8; 64]
var RFLC_ST_BUD            : [u8; 32]
var RFLC_ST_BIG            : [u8; 4096]
var RFLC_ST_KIND           : [u8; 8]
var RFLC_ST_CLAUSEREQ      : [u8; 128]

// =========================== internal ===========================

fn rflc_prop_id_ptr(slot: u64) -> *u8 { return ((&RFLC_PROPOSAL_IDS as u64) + (slot & 0xFFFFFFFFFFFFFFFFu64) * 32u64) as *u8 }
fn rflc_prop_payload_ptr(slot: u64) -> *u8 { return ((&RFLC_PROPOSAL_PAYLOADS as u64) + slot * 4096u64) as *u8 }

/* W4.4 (F-RFLC-2): the single canonical proposal-payload capacity (max producer write).  A
 * consumer dequeuing a proposal MUST provide a buffer at least this large; reflection_governance
 * sizes/validates its dequeue buffer against THIS value, so the producer and consumer can never
 * silently drift to two different sizes (the F-RFLC-2 overrun). */
fn rc_proposal_payload_cap() -> u64 @export {
    return RFLC_PROPOSAL_PAYLOAD_CAP
}
fn rflc_forbidden_ptr(i: u64) -> *u8 { return ((&RFLC_FORBIDDEN_IDS as u64) + i * 32u64) as *u8 }

// Derive a forbidden-style id: ident_from_bytes("FORB"||tag||000, 8) into out.
fn rflc_derive_id(tag: u8, out: u64) -> i32 {
    let sp : *u8 = (&RFLC_SEED_BUF as u64) as *u8
    sp[0u64] = 0x46u8  sp[1u64] = 0x4Fu8  sp[2u64] = 0x52u8  sp[3u64] = 0x42u8
    sp[4u64] = tag
    sp[5u64] = 0u8  sp[6u64] = 0u8  sp[7u64] = 0u8
    ident_from_bytes(sp, 8u64, out as *u8)
    return RFLC_OK
}

// Emit a witness fragment recording (in_commit, out_commit, payload-tagged kind).
fn rflc_emit(in_id: u64, out_id: u64, tagbyte: u8) -> i32 {
    ident_zero((&RFLC_PRODUCER as u64) as *u8)
    ident_zero((&RFLC_OPID as u64) as *u8)
    ident_zero((&RFLC_ZERO_ANTE as u64) as *u8)
    ident_copy(in_id as *u8, (&RFLC_IN_COMMIT as u64) as *u8)
    ident_copy(out_id as *u8, (&RFLC_OUT_COMMIT as u64) as *u8)
    let pp : *u8 = (&RFLC_FRAG_PAYLOAD as u64) as *u8
    let mut z : u64 = 0u64
    while z < 72u64 { pp[z] = 0u8  z = z + 1u64 }
    pp[0u64] = RFLC_FRAG_MAGIC_HI
    pp[1u64] = RFLC_FRAG_MAGIC_LO
    pp[2u64] = tagbyte
    let oidp : *u8 = out_id as *u8
    let mut c : u64 = 0u64
    while c < 32u64 { pp[8u64 + c] = oidp[c]  c = c + 1u64 }
    let zp : *u8 = (&RFLC_PRODUCER as u64) as *u8
    wh_publish(zp, (&RFLC_OPID as u64) as *u8, (&RFLC_IN_COMMIT as u64) as *u8, (&RFLC_OUT_COMMIT as u64) as *u8, RFLC_REVTAG, RFLC_PHASE, RFLC_PILLAR, (&RFLC_ZERO_ANTE as u64) as *u8, 0u32, pp, 72u32, (&RFLC_FRAG_ID as u64) as *u8)
    return RFLC_OK
}

// Build the AXIOM-step args aggregate + add it (conclusion already in RFLC_PROOF_SEED).
fn rflc_pt_axiom(term_id: u64, clen: u64) -> i32 {
    let ap : *u8 = (&RFLC_PT_ARGS as u64) as *u8
    let tidp : *u8 = term_id as *u8
    let mut t : u64 = 0u64
    while t < 32u64 { ap[t] = tidp[t]  t = t + 1u64 }
    ap[32u64] = RFLC_PT_AXIOM
    ap[33u64] = 0u8  ap[34u64] = 0u8  ap[35u64] = 0u8
    ap[36u64] = 0u8  ap[37u64] = 0u8  ap[38u64] = 0u8  ap[39u64] = 0u8   // pcount = 0
    ap[40u64] = (clen & 0xFFu64) as u8
    ap[41u64] = ((clen >> 8u64) & 0xFFu64) as u8
    ap[42u64] = ((clen >> 16u64) & 0xFFu64) as u8
    ap[43u64] = ((clen >> 24u64) & 0xFFu64) as u8
    let sp : *u8 = (&RFLC_PROOF_SEED as u64) as *u8
    let mut j : u64 = 0u64
    while j < clen { ap[44u64 + j] = sp[j]  j = j + 1u64 }
    return pt_add_inference(ap)
}

// =========================== public surface ===========================

fn rc_init() -> i32 @export {
    if RFLC_INITED == 1u8 { return RFLC_OK }
    let mut i : u64 = 0u64
    while i < RFLC_PROPOSAL_SLOTS { RFLC_PROPOSAL_LIVE[i] = 0u8  i = i + 1u64 }
    RFLC_PROPOSAL_COUNT = 0u64
    rflc_derive_id(RFLC_TAG_SELF, rflc_forbidden_ptr(0u64) as u64)
    rflc_derive_id(RFLC_TAG_GOVERN, rflc_forbidden_ptr(1u64) as u64)
    rflc_derive_id(RFLC_TAG_PRESERVER, rflc_forbidden_ptr(2u64) as u64)
    RFLC_FORBIDDEN_READY = 1u8
    RFLC_REQ_OPEN = 0u8
    RFLC_INITED = 1u8
    return RFLC_OK
}

fn rc_forbidden_target(target: *u8) -> u8 @export {
    if RFLC_INITED == 0u8 { return 0u8 }
    if (target as u64) == 0u64 { return 0u8 }
    let mut found : u8 = 0u8
    let mut i : u64 = 0u64
    while i < RFLC_FORBIDDEN_SLOTS {
        if found == 0u8 {
            if ident_eq(target, rflc_forbidden_ptr(i)) == 1u8 { found = 1u8 }
        }
        i = i + 1u64
    }
    return found
}

fn rc_request_begin(target_module: *u8, cap: u64) -> i32 @export {
    let vcap : u64 = cap
    if RFLC_INITED == 0u8 { return RFLC_E_NOT_INITED }
    if (target_module as u64) == 0u64 { return RFLC_E_NULL }
    if rc_forbidden_target(target_module) == 1u8 { return RFLC_E_TARGET_FORBIDDEN }
    if cap_verify_rights(vcap, cap_right_reflect()) == 0u8 { return RFLC_E_CAP_DENIED }
    ident_copy(target_module, (&RFLC_REQ_TARGET as u64) as *u8)
    RFLC_REQ_CAP = vcap
    RFLC_REQ_PROP_LEN = 0u64
    ident_zero((&RFLC_REQ_BUDGET as u64) as *u8)
    RFLC_REQ_OPEN = 1u8
    return RFLC_OK
}

fn rc_request_push_property(chunk: *u8, chunk_len: u32) -> i32 @export {
    let cp : u64 = chunk as u64
    let cl : u64 = (chunk_len as u64) & 0xFFFFFFFFu64
    if RFLC_INITED == 0u8 { return RFLC_E_NOT_INITED }
    if RFLC_REQ_OPEN == 0u8 { return RFLC_E_NO_REQUEST }
    if cp == 0u64 { return RFLC_E_NULL }
    let need : u64 = RFLC_REQ_PROP_LEN + cl
    if need > RFLC_PROPERTY_CAP { return RFLC_E_PROPERTY_OVERFLOW }
    let dst : *u8 = (&RFLC_REQ_PROPERTY as u64) as *u8
    let src : *u8 = cp as *u8
    let mut i : u64 = 0u64
    while i < cl { dst[RFLC_REQ_PROP_LEN + i] = src[i]  i = i + 1u64 }
    RFLC_REQ_PROP_LEN = RFLC_REQ_PROP_LEN + cl
    return RFLC_OK
}

fn rc_request_set_budget(budget: *u8) -> i32 @export {
    if RFLC_INITED == 0u8 { return RFLC_E_NOT_INITED }
    if RFLC_REQ_OPEN == 0u8 { return RFLC_E_NO_REQUEST }
    if (budget as u64) == 0u64 { return RFLC_E_NULL }
    ident_copy(budget, (&RFLC_REQ_BUDGET as u64) as *u8)
    return RFLC_OK
}

fn rc_construct_proof(out_term_id: *u8) -> i32 @export {
    let op : u64 = out_term_id as u64
    if RFLC_INITED == 0u8 { return RFLC_E_NOT_INITED }
    if RFLC_REQ_OPEN == 0u8 { return RFLC_E_NO_REQUEST }
    if op == 0u64 { return RFLC_E_NULL }
    if rc_forbidden_target((&RFLC_REQ_TARGET as u64) as *u8) == 1u8 { return RFLC_E_TARGET_FORBIDDEN }
    if cap_verify_rights(RFLC_REQ_CAP, cap_right_reflect()) == 0u8 { return RFLC_E_CAP_DENIED }
    let bp : *u8 = (&RFLC_REQ_BUDGET as u64) as *u8
    let mut weight : u64 = 0u64
    let mut b : u64 = 0u64
    while b < 8u64 { weight = weight | ((bp[b] as u64) << (b * 8u64))  b = b + 1u64 }
    if weight > RFLC_BUDGET_MAX { return RFLC_E_BUDGET_EXHAUSTED }
    let mut pbind : u64 = RFLC_REQ_PROP_LEN
    if pbind > RFLC_PROP_BIND_MAX { pbind = RFLC_PROP_BIND_MAX }
    let clen : u64 = 32u64 + pbind
    let seed : *u8 = (&RFLC_PROOF_SEED as u64) as *u8
    let tgt : *u8 = (&RFLC_REQ_TARGET as u64) as *u8
    let prop : *u8 = (&RFLC_REQ_PROPERTY as u64) as *u8
    let mut k : u64 = 0u64
    while k < 32u64 { seed[k] = tgt[k]  k = k + 1u64 }
    let mut m : u64 = 0u64
    while m < pbind { seed[32u64 + m] = prop[m]  m = m + 1u64 }
    if pt_alloc(out_term_id) != RFLC_PT_OK { return RFLC_E_PROOF_FAILED }
    if rflc_pt_axiom(op, clen) != RFLC_PT_OK { return RFLC_E_PROOF_FAILED }
    if pt_finalize(out_term_id) != RFLC_PT_OK { return RFLC_E_PROOF_FAILED }
    if pt_verify(out_term_id) != RFLC_PT_OK { return RFLC_E_PROOF_FAILED }
    rflc_emit((&RFLC_REQ_TARGET as u64), op, 0x10u8)
    RFLC_REQ_OPEN = 0u8
    return RFLC_OK
}

// Find first free proposal slot; RFLC_PROPOSAL_SLOTS if none.
fn rflc_free_slot() -> u64 {
    let mut chosen : u64 = RFLC_PROPOSAL_SLOTS
    let mut i : u64 = 0u64
    while i < RFLC_PROPOSAL_SLOTS {
        if chosen == RFLC_PROPOSAL_SLOTS {
            if RFLC_PROPOSAL_LIVE[i] == 0u8 { chosen = i }
        }
        i = i + 1u64
    }
    return chosen
}

fn rc_propose_clause(req: *u8, cap: u64, out_proposal_id: *u8) -> i32 @export {
    let rp : u64 = req as u64
    let vcap : u64 = cap
    if RFLC_INITED == 0u8 { return RFLC_E_NOT_INITED }
    if rp == 0u64 { return RFLC_E_NULL }
    if (out_proposal_id as u64) == 0u64 { return RFLC_E_NULL }
    if cap_verify_rights(vcap, cap_right_reflect()) == 0u8 { return RFLC_E_CAP_DENIED }
    let slot : u64 = rflc_free_slot()
    if slot == RFLC_PROPOSAL_SLOTS { return RFLC_E_QUEUE_FULL }
    let hp : *u8 = rp as *u8
    let mut tlen : u64 = 0u64
    let mut a : u64 = 0u64
    while a < 4u64 { tlen = tlen | ((hp[a] as u64) << (a * 8u64))  a = a + 1u64 }
    let mut llen : u64 = 0u64
    let mut e : u64 = 0u64
    while e < 4u64 { llen = llen | ((hp[4u64 + e] as u64) << (e * 8u64))  e = e + 1u64 }
    let mut plen : u64 = 0u64
    let mut g : u64 = 0u64
    while g < 4u64 { plen = plen | ((hp[8u64 + g] as u64) << (g * 8u64))  g = g + 1u64 }
    let mut total : u64 = tlen + llen + plen
    /* The body is written at offset 12 (after the 12-byte header), so 12+total
     * must fit the 4096-byte slot; clamping to CAP (not CAP-12) let a clause
     * with tlen+llen+plen>=4085 write up to 12 bytes past the slot (OOB BSS for
     * slot 1023).  [audit F-RFLC-1] */
    if total > RFLC_PROPOSAL_PAYLOAD_CAP - 12u64 { total = RFLC_PROPOSAL_PAYLOAD_CAP - 12u64 }
    rflc_build_clause_id(hp, total, slot)
    ident_copy(rflc_prop_id_ptr(slot), out_proposal_id)
    let dp : *u8 = rflc_prop_payload_ptr(slot)
    let mut h : u64 = 0u64
    while h < 12u64 { dp[h] = hp[h]  h = h + 1u64 }
    let mut c : u64 = 0u64
    while c < total { dp[12u64 + c] = hp[12u64 + c]  c = c + 1u64 }
    RFLC_PROPOSAL_LENS[slot] = (12u64 + total) as u32
    RFLC_PROPOSAL_KINDS[slot] = RFLC_KIND_CLAUSE
    RFLC_PROPOSAL_LIVE[slot] = 1u8
    RFLC_PROPOSAL_COUNT = RFLC_PROPOSAL_COUNT + 1u64
    rflc_emit(rflc_prop_id_ptr(slot) as u64, rflc_prop_id_ptr(slot) as u64, 0x11u8)
    return RFLC_OK
}

// Derive a deterministic clause-proposal id into slot from at_current() + the
// CONTIGUOUS clause body head (bounded, no modulo).  3 params (W2): t read
// internally.  Seed = enc_u64(t) || body[0..min(total,88)] -- captures the
// textual||ltl||predicate heads regardless of field layout, so two clauses
// differing only in the predicate (even past the textual+ltl region) get
// distinct ids (fixes the field-offset collision the per-field read had: it
// read the predicate at 12+tlen, ignoring llen, so a clause with an LTL field
// hashed the LTL region as the predicate).
fn rflc_build_clause_id(hp: u64, total: u64, slot: u64) -> i32 {
    let t : u64 = at_current()
    let sp : *u8 = (&RFLC_PROOF_SEED as u64) as *u8
    let mut z : u64 = 0u64
    while z < 96u64 { sp[z] = 0u8  z = z + 1u64 }
    let mut b : u64 = 0u64
    while b < 8u64 { sp[b] = ((t >> (b * 8u64)) & 0xFFu64) as u8  b = b + 1u64 }
    let hpp : *u8 = hp as *u8
    let mut bc : u64 = total
    if bc > 88u64 { bc = 88u64 }
    let mut i : u64 = 0u64
    while i < bc { sp[8u64 + i] = hpp[12u64 + i]  i = i + 1u64 }
    ident_from_bytes(sp, 96u64, rflc_prop_id_ptr(slot))
    return RFLC_OK
}

fn rc_propose_synthesis(spec_id: *u8, cap: u64, out_proposal_id: *u8) -> i32 @export {
    let vcap : u64 = cap
    if RFLC_INITED == 0u8 { return RFLC_E_NOT_INITED }
    if (spec_id as u64) == 0u64 { return RFLC_E_NULL }
    if (out_proposal_id as u64) == 0u64 { return RFLC_E_NULL }
    if cap_verify_rights(vcap, cap_right_reflect()) == 0u8 { return RFLC_E_CAP_DENIED }
    let slot : u64 = rflc_free_slot()
    if slot == RFLC_PROPOSAL_SLOTS { return RFLC_E_QUEUE_FULL }
    ident_copy(spec_id, rflc_prop_id_ptr(slot))
    ident_copy(spec_id, out_proposal_id)
    RFLC_PROPOSAL_KINDS[slot] = RFLC_KIND_SYNTHESIS
    RFLC_PROPOSAL_LENS[slot] = 32u32
    RFLC_PROPOSAL_LIVE[slot] = 1u8
    RFLC_PROPOSAL_COUNT = RFLC_PROPOSAL_COUNT + 1u64
    rflc_emit(rflc_prop_id_ptr(slot) as u64, rflc_prop_id_ptr(slot) as u64, 0x12u8)
    return RFLC_OK
}

fn rc_queue_size() -> u64 @export { return RFLC_PROPOSAL_COUNT }

fn rc_proposal_kind(slot: u64, out_kind: *u8) -> i32 @export {
    let vs : u64 = slot
    if (out_kind as u64) == 0u64 { return RFLC_E_NULL }
    if vs >= RFLC_PROPOSAL_SLOTS { return RFLC_E_BAD_SLOT }
    if RFLC_PROPOSAL_LIVE[vs] == 0u8 { return RFLC_E_BAD_SLOT }
    out_kind[0u64] = RFLC_PROPOSAL_KINDS[vs]
    return RFLC_OK
}

// Dequeue a live proposal's kind + payload for the governance review path (M71).
// W2-clean (4 params; out_payload must be >= RFLC_PROPOSAL_PAYLOAD_CAP=4096).
// out_len written byte-by-byte through *u8 (Trap 5: no *u32 element store).
fn rc_dequeue(slot: u64, out_kind: *u8, out_payload: *u8, out_len: *u32) -> i32 @export {
    let vs : u64 = slot
    if (out_kind as u64) == 0u64 { return RFLC_E_NULL }
    if (out_payload as u64) == 0u64 { return RFLC_E_NULL }
    if (out_len as u64) == 0u64 { return RFLC_E_NULL }
    if vs >= RFLC_PROPOSAL_SLOTS { return RFLC_E_BAD_SLOT }
    if RFLC_PROPOSAL_LIVE[vs] == 0u8 { return RFLC_E_BAD_SLOT }
    out_kind[0u64] = RFLC_PROPOSAL_KINDS[vs]
    let plen : u32 = RFLC_PROPOSAL_LENS[vs]
    let pl : u64 = (plen as u64) & 0xFFFFFFFFu64
    let src : *u8 = rflc_prop_payload_ptr(vs)
    let mut i : u64 = 0u64
    while i < pl { out_payload[i] = src[i]  i = i + 1u64 }
    let olp : *u8 = out_len as *u8
    olp[0u64] = (plen & 0xFFu32) as u8
    olp[1u64] = ((plen >> 8u32) & 0xFFu32) as u8
    olp[2u64] = ((plen >> 16u32) & 0xFFu32) as u8
    olp[3u64] = ((plen >> 24u32) & 0xFFu32) as u8
    return RFLC_OK
}

// =========================== self-test ===========================

fn rflc_st_fill(p: u64, len: u64, b: u8) -> i32 {
    let pp : *u8 = p as *u8
    let mut i : u64 = 0u64
    while i < len { pp[i] = b  i = i + 1u64 }
    return RFLC_OK
}

// KAT-1: forbidden-self-set EXACT + enforced (entry + defense-in-depth re-check).
fn rc_st_k1(cap_ok: u64) -> u64 {
    rflc_derive_id(RFLC_TAG_SELF, &RFLC_ST_SELF as u64)
    rflc_derive_id(RFLC_TAG_GOVERN, &RFLC_ST_GOV as u64)
    rflc_derive_id(RFLC_TAG_PRESERVER, &RFLC_ST_PRES as u64)
    rflc_derive_id(0x09u8, &RFLC_ST_OTHER as u64)
    if rc_forbidden_target((&RFLC_ST_SELF as u64) as *u8) != 1u8 { return 1u64 }
    if rc_forbidden_target((&RFLC_ST_GOV as u64) as *u8) != 1u8 { return 2u64 }
    if rc_forbidden_target((&RFLC_ST_PRES as u64) as *u8) != 1u8 { return 3u64 }
    if rc_forbidden_target((&RFLC_ST_OTHER as u64) as *u8) != 0u8 { return 4u64 }
    if rc_request_begin((&RFLC_ST_SELF as u64) as *u8, cap_ok) != RFLC_E_TARGET_FORBIDDEN { return 5u64 }
    // defense-in-depth: begin on other, overwrite REQ_TARGET to self, construct -> forbidden
    if rc_request_begin((&RFLC_ST_OTHER as u64) as *u8, cap_ok) != RFLC_OK { return 6u64 }
    ident_copy((&RFLC_ST_SELF as u64) as *u8, (&RFLC_REQ_TARGET as u64) as *u8)
    if rc_construct_proof((&RFLC_ST_TERM as u64) as *u8) != RFLC_E_TARGET_FORBIDDEN { return 7u64 }
    RFLC_REQ_OPEN = 0u8
    return 0u64
}

// KAT-2: capability gate fails closed.
fn rc_st_k2(cap_ok: u64, cap_bad: u64) -> u64 {
    if rc_request_begin((&RFLC_ST_OTHER as u64) as *u8, cap_bad) != RFLC_E_CAP_DENIED { return 10u64 }
    if rc_request_begin((&RFLC_ST_OTHER as u64) as *u8, cap_ok) != RFLC_OK { return 11u64 }
    RFLC_REQ_OPEN = 0u8
    return 0u64
}

// KAT-3: bounded property buffer rejects overflow (no wrap).
fn rc_st_k3(cap_ok: u64) -> u64 {
    if rc_request_begin((&RFLC_ST_OTHER as u64) as *u8, cap_ok) != RFLC_OK { return 20u64 }
    rflc_st_fill(&RFLC_ST_BIG as u64, 4096u64, 0x5Au8)
    if rc_request_push_property((&RFLC_ST_BIG as u64) as *u8, 4096u32) != RFLC_OK { return 21u64 }
    if rc_request_push_property((&RFLC_ST_BIG as u64) as *u8, 1u32) != RFLC_E_PROPERTY_OVERFLOW { return 22u64 }
    let dp : *u8 = (&RFLC_REQ_PROPERTY as u64) as *u8
    if dp[0u64] != 0x5Au8 { return 23u64 }
    if dp[4095u64] != 0x5Au8 { return 24u64 }
    RFLC_REQ_OPEN = 0u8
    return 0u64
}

// KAT-4: REAL proof construction (proof_term built) -- positive + budget negative.
fn rc_st_k4(cap_ok: u64) -> u64 {
    if rc_request_begin((&RFLC_ST_OTHER as u64) as *u8, cap_ok) != RFLC_OK { return 30u64 }
    rflc_st_fill(&RFLC_ST_PROP as u64, 64u64, 0x7Eu8)
    if rc_request_push_property((&RFLC_ST_PROP as u64) as *u8, 64u32) != RFLC_OK { return 31u64 }
    rflc_st_fill(&RFLC_ST_BUD as u64, 32u64, 0u8)
    let bp : *u8 = (&RFLC_ST_BUD as u64) as *u8
    bp[0u64] = 100u8                       // weight = 100 (<= ceiling)
    if rc_request_set_budget((&RFLC_ST_BUD as u64) as *u8) != RFLC_OK { return 32u64 }
    if rc_construct_proof((&RFLC_ST_TERM as u64) as *u8) != RFLC_OK { return 33u64 }   // pt_verify-passing term
    // budget negative: weight 2_000_000 > ceiling -> E_BUDGET_EXHAUSTED
    if rc_request_begin((&RFLC_ST_OTHER as u64) as *u8, cap_ok) != RFLC_OK { return 34u64 }
    rflc_st_fill(&RFLC_ST_BUD as u64, 32u64, 0u8)
    bp[0u64] = 0x80u8  bp[1u64] = 0x84u8  bp[2u64] = 0x1Eu8   // 0x1E8480 = 2_000_000 LE
    if rc_request_set_budget((&RFLC_ST_BUD as u64) as *u8) != RFLC_OK { return 35u64 }
    if rc_construct_proof((&RFLC_ST_TERM as u64) as *u8) != RFLC_E_BUDGET_EXHAUSTED { return 36u64 }
    RFLC_REQ_OPEN = 0u8
    return 0u64
}

// KAT-5: proposal queue -- synthesis + clause, kind tagging, id distinctness, count.
fn rc_st_k5(cap_ok: u64) -> u64 {
    rflc_st_fill(&RFLC_ST_SPEC as u64, 32u64, 0x33u8)
    if rc_propose_synthesis((&RFLC_ST_SPEC as u64) as *u8, cap_ok, (&RFLC_ST_PID as u64) as *u8) != RFLC_OK { return 40u64 }
    if rc_proposal_kind(0u64, (&RFLC_ST_KIND as u64) as *u8) != RFLC_OK { return 41u64 }
    if RFLC_ST_KIND[0u64] != RFLC_KIND_SYNTHESIS { return 42u64 }
    if rc_queue_size() != 1u64 { return 43u64 }
    // build a minimal clause req: header [tlen=4][llen=0][plen=4] then "TEXT" "PRED"
    let cr : *u8 = (&RFLC_ST_CLAUSEREQ as u64) as *u8
    let mut z : u64 = 0u64
    while z < 128u64 { cr[z] = 0u8  z = z + 1u64 }
    cr[0u64] = 4u8                          // textual_len = 4
    cr[8u64] = 4u8                          // predicate_len = 4
    cr[12u64] = 0x54u8  cr[13u64] = 0x45u8  cr[14u64] = 0x58u8  cr[15u64] = 0x54u8   // "TEXT"
    cr[16u64] = 0x50u8  cr[17u64] = 0x52u8  cr[18u64] = 0x45u8  cr[19u64] = 0x44u8   // "PRED"
    if rc_propose_clause((&RFLC_ST_CLAUSEREQ as u64) as *u8, cap_ok, (&RFLC_ST_PID2 as u64) as *u8) != RFLC_OK { return 44u64 }
    if rc_proposal_kind(1u64, (&RFLC_ST_KIND as u64) as *u8) != RFLC_OK { return 45u64 }
    if RFLC_ST_KIND[0u64] != RFLC_KIND_CLAUSE { return 46u64 }
    if rc_queue_size() != 2u64 { return 47u64 }
    if ident_eq((&RFLC_ST_PID as u64) as *u8, (&RFLC_ST_PID2 as u64) as *u8) != 0u8 { return 48u64 }
    return 0u64
}

// KAT-6: null + uninit + bad-slot negatives.
fn rc_st_k6(cap_ok: u64) -> u64 {
    let nullp : *u8 = 0u64 as *u8
    if rc_request_begin(nullp, cap_ok) != RFLC_E_NULL { return 50u64 }
    if rc_proposal_kind(0u64, nullp) != RFLC_E_NULL { return 51u64 }
    if rc_proposal_kind(5000u64, (&RFLC_ST_KIND as u64) as *u8) != RFLC_E_BAD_SLOT { return 52u64 }
    if rc_proposal_kind(900u64, (&RFLC_ST_KIND as u64) as *u8) != RFLC_E_BAD_SLOT { return 53u64 }  // live==0
    return 0u64
}

// KAT-7: clause-id captures the predicate even past an LTL field (exercises the
// field-offset bug the per-field read had).  Two clause bodies identical in
// textual+ltl but differing ONLY in the predicate must yield DISTINCT ids.
// rflc_build_clause_id is called directly (no intervening wh_publish) so both
// reads see the SAME at_current() -- isolating the body difference from the
// time prefix (a tautology guard).  Old code (predicate read at 12+tlen,
// ignoring llen) -> identical seeds -> collision -> returns 70.
fn rc_st_k7() -> u64 {
    let cr : *u8 = (&RFLC_ST_CLAUSEREQ as u64) as *u8
    let mut z : u64 = 0u64
    while z < 128u64 { cr[z] = 0u8  z = z + 1u64 }
    cr[0u64] = 4u8                          // textual_len = 4
    cr[4u64] = 4u8                          // ltl_len = 4
    cr[8u64] = 4u8                          // predicate_len = 4
    cr[12u64] = 0x54u8  cr[13u64] = 0x45u8  cr[14u64] = 0x58u8  cr[15u64] = 0x54u8   // "TEXT"
    cr[16u64] = 0x4Cu8  cr[17u64] = 0x54u8  cr[18u64] = 0x4Cu8  cr[19u64] = 0x5Fu8   // "LTL_"
    cr[20u64] = 0x50u8  cr[21u64] = 0x52u8  cr[22u64] = 0x44u8  cr[23u64] = 0x41u8   // "PRDA"
    rflc_build_clause_id(&RFLC_ST_CLAUSEREQ as u64, 12u64, 10u64)
    ident_copy(rflc_prop_id_ptr(10u64), (&RFLC_ST_PID as u64) as *u8)
    cr[23u64] = 0x42u8                       // predicate last byte A -> B (textual+ltl unchanged)
    rflc_build_clause_id(&RFLC_ST_CLAUSEREQ as u64, 12u64, 11u64)
    if ident_eq((&RFLC_ST_PID as u64) as *u8, rflc_prop_id_ptr(11u64)) != 0u8 { return 70u64 }
    return 0u64
}

fn rc_selftest() -> u64 @export {
    wh_init(0u64)
    pt_init()
    cap_env_init()
    // uninit negative (before rc_init): the INITED guard fires first, regardless of args.
    if rc_request_begin((&RFLC_ST_OTHER as u64) as *u8, 1u64) != RFLC_E_NOT_INITED { return 54u64 }
    rc_init()
    let cap_ok : u64 = 1u64                              // root has CAP_RIGHT_ATTEST
    let cap_bad : u64 = cap_attenuate(1u64, 0x1000u64, 0u64)   // CRYPTO_SIGN only, no ATTEST
    if cap_bad == 0u64 { return 60u64 }
    let r1 : u64 = rc_st_k1(cap_ok)
    if r1 != 0u64 { return r1 }
    let r2 : u64 = rc_st_k2(cap_ok, cap_bad)
    if r2 != 0u64 { return r2 }
    let r3 : u64 = rc_st_k3(cap_ok)
    if r3 != 0u64 { return r3 }
    let r4 : u64 = rc_st_k4(cap_ok)
    if r4 != 0u64 { return r4 }
    let r5 : u64 = rc_st_k5(cap_ok)
    if r5 != 0u64 { return r5 }
    let r6 : u64 = rc_st_k6(cap_ok)
    if r6 != 0u64 { return r6 }
    let r7 : u64 = rc_st_k7()
    if r7 != 0u64 { return r7 }
    return 99u64
}
