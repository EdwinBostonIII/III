/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\sat_arith.iii
 *
 * III STDLIB - numera::sat_arith
 *
 * Saturating fixed-width integer arithmetic.
 * On overflow, clamp to the maximum representable value.
 * On underflow, clamp to zero.
 *
 * Used by the resolver activation-score arithmetic (FROZEN SPEC §5.1).
 * All results are deterministic; no FP; no panic; no allocation.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00 (pure).
 *
 * Trap discipline (FROZEN SPEC §0.7, ADR-RES-016):
 *   - No signed-i64 ordering compares.
 *   - All u32->u64 widening masked.
 *   - All ordering compares on u64 are SAFE (the trap is signed-only).
 */

module numera_sat_arith

/* COMBINE-11: scalar's single-pass saturating ops (no double op-evaluation).
 * BOTH widths delegate here.  The did-overflow / did-underflow predicates that
 * the u32 paths formerly called are removed: predicate-then-recompute evaluates
 * the operation twice, which is the exact anti-pattern COMBINE-11 eliminates.
 * [audit W3.22: u32 sat ops now single-pass, matching the u64 ops.] */
extern @abi(c-msvc-x64) fn scalar_u64_add_sat(a: u64, b: u64) -> u64 from "scalar.iii"
extern @abi(c-msvc-x64) fn scalar_u64_sub_sat(a: u64, b: u64) -> u64 from "scalar.iii"
extern @abi(c-msvc-x64) fn scalar_u64_mul_sat(a: u64, b: u64) -> u64 from "scalar.iii"
extern @abi(c-msvc-x64) fn scalar_u32_add_sat(a: u32, b: u32) -> u32 from "scalar.iii"
extern @abi(c-msvc-x64) fn scalar_u32_sub_sat(a: u32, b: u32) -> u32 from "scalar.iii"
extern @abi(c-msvc-x64) fn scalar_u32_mul_sat(a: u32, b: u32) -> u32 from "scalar.iii"

/* --- u64 saturating --- */

fn sat_add_u64(a: u64, b: u64) -> u64 @export {
    return scalar_u64_add_sat(a, b)   /* COMBINE-11: single-pass (was check-then-recompute) */
}

fn sat_sub_u64(a: u64, b: u64) -> u64 @export {
    return scalar_u64_sub_sat(a, b)   /* COMBINE-11 */
}

fn sat_mul_u64(a: u64, b: u64) -> u64 @export {
    return scalar_u64_mul_sat(a, b)   /* COMBINE-11 */
}

fn sat_div_u64(a: u64, b: u64) -> u64 @export {
    if b == 0u64 {
        return 0xFFFFFFFFFFFFFFFFu64
    }
    return a / b
}

/* --- u32 saturating --- */

fn sat_add_u32(a: u32, b: u32) -> u32 @export {
    return scalar_u32_add_sat(a, b)   /* COMBINE-11: single-pass (was check-then-recompute) */
}

fn sat_sub_u32(a: u32, b: u32) -> u32 @export {
    return scalar_u32_sub_sat(a, b)   /* COMBINE-11 */
}

fn sat_mul_u32(a: u32, b: u32) -> u32 @export {
    return scalar_u32_mul_sat(a, b)   /* COMBINE-11 */
}

fn sat_div_u32(a: u32, b: u32) -> u32 @export {
    if b == 0u32 {
        return 0xFFFFFFFFu32
    }
    return a / b
}

/* --- popcount helper (used by resolver_score §5.1 partial-args bonus) --- */

fn popcount_u32(x: u32) -> u32 @export {
    let mut v : u32 = x
    let mut c : u32 = 0u32
    while v != 0u32 {
        c = c + (v & 1u32)
        v = (v >> 1u32) & 0x7FFFFFFFu32
    }
    return c
}

fn popcount_u64(x: u64) -> u32 @export {
    let mut v : u64 = x
    let mut c : u32 = 0u32
    while v != 0u64 {
        c = c + ((v & 1u64) as u32)
        v = v >> 1u64
    }
    return c
}

/* --- min/max helpers (u64-safe per ADR-RES-016) --- */

fn min_u64(a: u64, b: u64) -> u64 @export {
    if a == b { return a }
    if a < b { return a }
    return b
}

fn max_u64(a: u64, b: u64) -> u64 @export {
    if a == b { return a }
    if a < b { return b }
    return a
}

fn min_u32(a: u32, b: u32) -> u32 @export {
    if a == b { return a }
    if a < b { return a }
    return b
}

fn max_u32(a: u32, b: u32) -> u32 @export {
    if a == b { return a }
    if a < b { return b }
    return a
}
