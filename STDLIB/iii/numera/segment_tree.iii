/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\segment_tree.iii
 *
 * III STDLIB - numera::segment_tree  --  RANGE-MINIMUM SEGMENT TREE (verified).
 *
 * Where a Fenwick tree handles invertible prefix aggregates (sums), a segment tree handles ANY associative
 * range query -- here the range MINIMUM, which has no inverse and so cannot be done by prefix differences.
 * The array is laid out as a complete binary tree (leaves in the second half, each internal node the min of
 * its two children); a point update walks one leaf-to-root path and a range query stitches together O(log n)
 * canonical segments via the iterative bottom-up sweep.  The half-open index juggling is exactly where
 * segment trees are mis-implemented, so the III discipline VERIFIES every query against the naive O(n)
 * minimum over the same interval.
 *
 * Values [5,2,8,1,9,3,7,4]; range minima must match the naive scan; a point update is reflected immediately.
 *
 * Verified (segment_tree_kat): specific range minima are correct (global min 1, [4,5]->3, [6,7]->4); the tree
 * agrees with the naive minimum over EVERY interval; a point update (element 3 -> 0) changes the right minima
 * and the tree still agrees everywhere.  NIH/self-contained.
 *
 * Public API:
 *   seg_build() ; seg_min2(a,b) -> u32 ; seg_update(i,v) ; seg_query(l,r) -> u32 ; seg_naive(l,r) -> u32 ;
 *   seg_agree() -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_segment_tree

const SEG_N   : u32 = 8u32
const SEG_INF : u32 = 0xFFFFFFFFu32

var SEG_VAL  : [u32; 8]
var SEG_TREE : [u32; 16]            /* 1-indexed; leaves at [N, 2N) */

fn seg_min2(a: u32, b: u32) -> u32 @export {
    if a < b { return a }
    return b
}

fn seg_build() -> i32 @export {
    SEG_VAL[0u64]=5u32 ; SEG_VAL[1u64]=2u32 ; SEG_VAL[2u64]=8u32 ; SEG_VAL[3u64]=1u32
    SEG_VAL[4u64]=9u32 ; SEG_VAL[5u64]=3u32 ; SEG_VAL[6u64]=7u32 ; SEG_VAL[7u64]=4u32
    let mut i : u32 = 0u32
    while i < SEG_N { SEG_TREE[(SEG_N + i) as u64] = SEG_VAL[i as u64] ; i = i + 1u32 }
    let mut k : u32 = SEG_N - 1u32
    while k > 0u32 {
        SEG_TREE[k as u64] = seg_min2(SEG_TREE[(2u32 * k) as u64], SEG_TREE[((2u32 * k) + 1u32) as u64])
        k = k - 1u32
    }
    return 0i32
}

/* set element i to v; recompute the path to the root. */
fn seg_update(i: u32, v: u32) -> i32 @export {
    if i >= SEG_N { return -1i32 }       /* [OOB-W10] i writes SEG_VAL[i] (SEG_VAL[8]) + SEG_TREE[SEG_N+i] (SEG_TREE[16]) */
    SEG_VAL[i as u64] = v
    let mut p : u32 = SEG_N + i
    SEG_TREE[p as u64] = v
    p = p / 2u32
    while p > 0u32 {
        SEG_TREE[p as u64] = seg_min2(SEG_TREE[(2u32 * p) as u64], SEG_TREE[((2u32 * p) + 1u32) as u64])
        p = p / 2u32
    }
    return 0i32
}

/* range minimum over [l, r] (inclusive) by the iterative half-open sweep. */
fn seg_query(l: u32, r: u32) -> u32 @export {
    if l >= SEG_N { return SEG_INF }     /* [OOB-W10] l/r index SEG_TREE[SEG_N+l .. SEG_N+r]; out-of-range -> empty (INF) */
    if r >= SEG_N { return SEG_INF }
    let mut res : u32 = SEG_INF
    let mut lo : u32 = SEG_N + l
    let mut hi : u32 = (SEG_N + r) + 1u32
    while lo < hi {
        if (lo & 1u32) == 1u32 { res = seg_min2(res, SEG_TREE[lo as u64]) ; lo = lo + 1u32 }
        if (hi & 1u32) == 1u32 { hi = hi - 1u32 ; res = seg_min2(res, SEG_TREE[hi as u64]) }
        lo = lo / 2u32
        hi = hi / 2u32
    }
    return res
}

/* the naive O(n) reference minimum over [l, r]. */
fn seg_naive(l: u32, r: u32) -> u32 @export {
    let mut m : u32 = SEG_INF
    let mut k : u32 = l
    while k <= r {
        m = seg_min2(m, SEG_VAL[k as u64])
        k = k + 1u32
    }
    return m
}

/* the tree agrees with the naive minimum over EVERY interval. */
fn seg_agree() -> u32 @export {
    let mut l : u32 = 0u32
    while l < SEG_N {
        let mut r : u32 = l
        while r < SEG_N {
            if seg_query(l, r) != seg_naive(l, r) { return 0u32 }
            r = r + 1u32
        }
        l = l + 1u32
    }
    return 1u32
}

/* =====================================================================================
 * segment_tree_kat -- 99 = the range-minimum segment tree is correct, verified against naive:
 *   (1) specific minima: global [0,7]->1, [4,5]->3, [6,7]->4, [0,0]->5;
 *   (2) the tree agrees with the naive minimum over every interval;
 *   (3) a point update (element 3 -> 0) changes the right minima and the tree still agrees everywhere;
 *   (4) min2 is correct.
 * ===================================================================================== */
fn segment_tree_kat() -> u64 @export {
    seg_build()

    /* (1) specific range minima */
    if seg_query(0u32, 7u32) != 1u32 { return 1u64 }
    if seg_query(4u32, 5u32) != 3u32 { return 2u64 }
    if seg_query(6u32, 7u32) != 4u32 { return 3u64 }
    if seg_query(0u32, 0u32) != 5u32 { return 4u64 }
    if seg_query(1u32, 3u32) != 1u32 { return 5u64 }

    /* (2) agreement over every interval */
    if seg_agree() != 1u32 { return 6u64 }

    /* (3) a point update */
    seg_update(3u32, 0u32)                                /* element 3: 1 -> 0 */
    if seg_query(1u32, 3u32) != 0u32 { return 7u64 }
    if seg_query(0u32, 7u32) != 0u32 { return 8u64 }
    if seg_query(4u32, 7u32) != 3u32 { return 9u64 }      /* untouched half */
    if seg_agree() != 1u32 { return 10u64 }

    /* (4) min2 */
    if seg_min2(7u32, 3u32) != 3u32 { return 11u64 }
    if seg_min2(2u32, 9u32) != 2u32 { return 12u64 }

    return 99u64
}
