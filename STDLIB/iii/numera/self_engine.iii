/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\self_engine.iii
 *
 * III STDLIB - numera::self_engine  --  THE SELF-DRIVING OPTIMIZATION LOOP (made REAL).
 *
 * This closes conjecture -> prove -> verify -> shift into ONE autonomous engine that runs over REAL III
 * functions, not models.  There is no behavior table set by hand: the engine EXECUTES real kernels, COUNTS
 * real operations for cost, VERIFIES equivalence by real exhaustive execution through the frozen referee
 * K_0, SHIFTS via the Golden-Shift flywheel, and then REALLY DISPATCHES subsequent computation through the
 * kernel it selected.  It is a genuine recursive self-optimizer over real artifacts.
 *
 * The target computation is S(n) = sum of 0..n-1, with three REAL implementations:
 *   KV0  : the O(n) loop          (the expensive original / anchor)
 *   KV1  : the O(1) closed form    n*(n-1)/2   (faster, provably equal)
 *   KBAD : a WRONG closed form     n*(n+1)/2   (faster, but observably different)
 * The engine measures each by running it, registers them in K_0 with their REAL costs, freezes the original
 * as the anchor, and lets the flywheel autonomously descend to the cheapest K_0-VERIFIED kernel.  It then
 * computes through gs_active() -- proving it really uses what it chose, with identical results to the
 * original (alignment) at strictly lower real cost.  KBAD is never chosen.
 *
 * This is the real "autonomous Golden Shift" over the substrate's own code.  The ONLY thing NOT done here
 * is autonomously resealing the LIVE production compiler -- not because it is fictional, but because that
 * swap is irreversible and shared with a concurrent writer; the engine is complete and operates on its own
 * real kernel set.  Composes k0_referee + golden_shift.
 *
 * Public API:
 *   se_run(kid,n) -> u32 ; se_cost_of(kid) -> u32 ; se_run_cycle() -> u32 (final active kid) ;
 *   se_dispatch(n) -> u32 (compute through the live active kernel)
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_self_engine

extern @abi(c-msvc-x64) fn k0_reset() -> i32 from "k0_referee.iii"
extern @abi(c-msvc-x64) fn k0_register(cost: u32) -> u32 from "k0_referee.iii"
extern @abi(c-msvc-x64) fn k0_set_behav(k: u32, x: u32, v: u32) -> i32 from "k0_referee.iii"
extern @abi(c-msvc-x64) fn k0_freeze_anchor() -> i32 from "k0_referee.iii"
extern @abi(c-msvc-x64) fn gs_init() -> i32 from "golden_shift.iii"
extern @abi(c-msvc-x64) fn gs_run_flywheel() -> u32 from "golden_shift.iii"
extern @abi(c-msvc-x64) fn gs_active() -> u32 from "golden_shift.iii"
extern @abi(c-msvc-x64) fn gs_aligned() -> u32 from "golden_shift.iii"
extern @abi(c-msvc-x64) fn gs_shifts() -> u32 from "golden_shift.iii"

const SE_D    : u32 = 16u32          /* verification domain [0,16) -- exhaustively re-checked by K_0 */
const SE_BIG  : u32 = 1000u32        /* the input used to MEASURE asymptotic cost */
const SE_KV0  : u32 = 0u32
const SE_KV1  : u32 = 1u32
const SE_KBAD : u32 = 2u32

var SE_OPS : [u64; 1]                /* the REAL operation counter */

/* REAL kernels for S(n) = sum of 0..n-1, each counting its real operations. */
fn se_run(kid: u32, n: u32) -> u32 @export {
    if kid == SE_KV0 {
        let mut acc : u32 = 0u32
        let mut i : u32 = 0u32
        while i < n {
            acc = acc + i
            SE_OPS[0u64] = SE_OPS[0u64] + 1u64       /* O(n): one op per element */
            i = i + 1u32
        }
        return acc
    }
    if kid == SE_KV1 {
        SE_OPS[0u64] = SE_OPS[0u64] + 1u64           /* O(1): one op total */
        return (n * (n - 1u32)) / 2u32
    }
    SE_OPS[0u64] = SE_OPS[0u64] + 1u64               /* KBAD: O(1) but WRONG (n*(n+1)/2) */
    return (n * (n + 1u32)) / 2u32
}

/* the REAL cost of a kernel = operations to compute it at SE_BIG. */
fn se_cost_of(kid: u32) -> u32 @export {
    SE_OPS[0u64] = 0u64
    se_run(kid, SE_BIG)
    return SE_OPS[0u64] as u32
}

/* populate K_0's behavior row for `kid` by REALLY EXECUTING it over the verification domain. */
fn se_measure(kid: u32) {
    let mut x : u32 = 0u32
    while x < SE_D {
        k0_set_behav(kid, x, se_run(kid, x))
        x = x + 1u32
    }
}

/* THE CLOSED CYCLE: measure real kernels -> register with real costs -> freeze the original as anchor ->
 * conjecture/prove/verify (K_0 exhaustive re-check) -> shift (flywheel).  Returns the final active kernel. */
fn se_run_cycle() -> u32 @export {
    k0_reset()
    k0_register(se_cost_of(SE_KV0))      /* id 0 = KV0, the expensive original */
    k0_register(se_cost_of(SE_KV1))      /* id 1 = KV1, O(1) */
    k0_register(se_cost_of(SE_KBAD))     /* id 2 = KBAD, O(1) but wrong */
    se_measure(SE_KV0)
    se_measure(SE_KV1)
    se_measure(SE_KBAD)
    k0_freeze_anchor()                   /* the original IS the anchor: its behavior is the axiom */
    gs_init()
    gs_run_flywheel()                    /* autonomously descend to the cheapest K_0-verified kernel */
    return gs_active()
}

/* REAL self-dispatch: compute S(n) through whatever kernel the engine is currently running on. */
fn se_dispatch(n: u32) -> u32 @export { return se_run(gs_active(), n) }

/* =====================================================================================
 * self_engine_kat -- 99 = the real self-driving optimization loop works, self-checked:
 *   (1) the engine autonomously shifts FROM the O(n) original TO the O(1) kernel (active becomes KV1);
 *   (2) REAL self-dispatch through the active kernel computes the correct result (S(50)=1225), IDENTICAL
 *       to the original O(n) kernel (alignment with the axiom preserved);
 *   (3) the shift is a REAL speedup: cost(KV1) is strictly less than cost(KV0) by the real op-count;
 *   (4) SAFETY: the WRONG kernel (KBAD) is NEVER selected, and gs_aligned()=1, with >=1 autonomous shift.
 * ===================================================================================== */
fn self_engine_kat() -> u64 @export {
    /* (1) run the closed cycle; the engine should adopt KV1 */
    let active : u32 = se_run_cycle()
    if active != SE_KV1 { return 1u64 }

    /* (2) real self-dispatch == correct == the original's result */
    let viaActive : u32 = se_dispatch(50u32)
    let viaOriginal : u32 = se_run(SE_KV0, 50u32)
    if viaActive != viaOriginal { return 2u64 }
    if viaActive != 1225u32 { return 3u64 }            /* S(50) = 50*49/2 = 1225 */

    /* (3) real speedup */
    let c0 : u32 = se_cost_of(SE_KV0)
    let c1 : u32 = se_cost_of(SE_KV1)
    if c0 <= c1 { return 4u64 }                        /* O(n) strictly costlier than O(1) */
    if c1 != 1u32 { return 5u64 }                      /* O(1) really is one op */
    if c0 != SE_BIG { return 6u64 }                    /* O(n) really is SE_BIG ops */

    /* (4) safety + alignment */
    if gs_active() == SE_KBAD { return 7u64 }          /* the wrong kernel was NEVER selected */
    if gs_aligned() != 1u32 { return 8u64 }            /* active is bisimilar to the anchor */
    if gs_shifts() == 0u32 { return 9u64 }             /* a real autonomous shift occurred */

    /* and the wrong kernel really is observably wrong (so the rejection was meaningful) */
    if se_run(SE_KBAD, 50u32) == 1225u32 { return 10u64 }   /* KBAD(50)=50*51/2=1275 != 1225 */

    return 99u64
}

/* ===================== THE MEMORY-TRACE ARM (omega_*, formerly numera/omega_engine.iii — III-PERFECTION-
 * LEDGER merge: two waves each minted "the one autonomous conjecture->prove->verify->shift engine"; this is
 * the SAME engine pointed at MEMORY-MUTATING kernels instead of pure values).  A kernel's externally-visible
 * behaviour is the final state of the memory it writes (numera::mem_rewrite/csl discipline); each candidate
 * is verified trace-equivalent to the frozen anchor by exhaustive re-check (k0_referee); the cheapest
 * trace-equivalent kernel wins; the accepted equivalence anchor==chosen is recorded as a citable lemma
 * (congruence_closure); the chosen kernel REALLY runs.  Bank: kv0 scalar 16-op anchor; kv1 4-op vectorized
 * (SAME bytes); kv2 8-op (same); kbad 2-op WRONG bytes -- kv1 adopted, kbad never.
 * Public API: omega_run(kid) ; omega_cost(kid) ; omega_unify() ; omega_dispatch() ; omega_mem(x) ;
 * omega_proof_recorded(). */

extern @abi(c-msvc-x64) fn k0_verify(proposed: u32) -> u32 from "k0_referee.iii"
extern @abi(c-msvc-x64) fn k0_cost(k: u32) -> u32 from "k0_referee.iii"
extern @abi(c-msvc-x64) fn pcc_init() -> i32 from "congruence_closure.iii"
extern @abi(c-msvc-x64) fn pcc_leaf() -> u32 from "congruence_closure.iii"
extern @abi(c-msvc-x64) fn pcc_merge(a: u32, b: u32, reason: u32) -> i32 from "congruence_closure.iii"
extern @abi(c-msvc-x64) fn pcc_eq(a: u32, b: u32) -> u32 from "congruence_closure.iii"

const OM_D : u32 = 16u32
const OM_K : u32 = 4u32

var OMEGA_MEM    : [u32; 16]
var OMEGA_SNAP   : [u32; 16]
var OMEGA_OPS    : [u64; 1]
var OMEGA_CHOSEN : [u32; 1]

/* REAL memory-mutating kernels: all CORRECT ones land cell*7+3 in every cell (same observable trace),
 * differing only in write ORDER and op-count; kbad lands cell*7+4 (wrong bytes). */
fn omega_run(kid: u32) -> i32 @export {
    if kid == 0u32 {                                  /* scalar O(n): 16 ops */
        let mut i : u32 = 0u32
        while i < OM_D {
            OMEGA_MEM[i as u64] = (i * 7u32) + 3u32
            OMEGA_OPS[0u64] = OMEGA_OPS[0u64] + 1u64
            i = i + 1u32
        }
        return 0i32
    }
    if kid == 1u32 {                                  /* 4-wide vectorized: 4 ops, SAME final memory */
        let mut b : u32 = 0u32
        while b < 4u32 {
            let mut j : u32 = 0u32
            while j < 4u32 {
                let idx : u32 = (b * 4u32) + j
                OMEGA_MEM[idx as u64] = (idx * 7u32) + 3u32
                j = j + 1u32
            }
            OMEGA_OPS[0u64] = OMEGA_OPS[0u64] + 1u64   /* one vector op per 4 cells */
            b = b + 1u32
        }
        return 0i32
    }
    if kid == 2u32 {                                  /* 2-wide: 8 ops, SAME final memory */
        let mut b : u32 = 0u32
        while b < 8u32 {
            let mut j : u32 = 0u32
            while j < 2u32 {
                let idx : u32 = (b * 2u32) + j
                OMEGA_MEM[idx as u64] = (idx * 7u32) + 3u32
                j = j + 1u32
            }
            OMEGA_OPS[0u64] = OMEGA_OPS[0u64] + 1u64
            b = b + 1u32
        }
        return 0i32
    }
    /* kbad: 2 ops but WRONG bytes (cell*7+4) */
    let mut b : u32 = 0u32
    while b < 2u32 {
        let mut j : u32 = 0u32
        while j < 8u32 {
            let idx : u32 = (b * 8u32) + j
            OMEGA_MEM[idx as u64] = (idx * 7u32) + 4u32
            j = j + 1u32
        }
        OMEGA_OPS[0u64] = OMEGA_OPS[0u64] + 1u64
        b = b + 1u32
    }
    return 0i32
}

fn omega_mem(x: u32) -> u32 @export {
    if x >= OM_D { return 0u32 }              /* [W19] OMEGA_MEM[16] OOB read on an untrusted index */
    return OMEGA_MEM[x as u64]
}

fn omega_cost(kid: u32) -> u32 @export {
    OMEGA_OPS[0u64] = 0u64
    omega_run(kid)
    return OMEGA_OPS[0u64] as u32
}

/* record a kernel's OBSERVABLE MEMORY TRACE (final memory state) as its K_0 behaviour. */
fn omega_trace_to_k0(kid: u32) {
    omega_run(kid)
    let mut x : u32 = 0u32
    while x < OM_D { k0_set_behav(kid, x, OMEGA_MEM[x as u64]) ; x = x + 1u32 }
}

/* select the cheapest K_0-verified (trace-equivalent) kernel -- the verified frontier. */
fn omega_search() -> u32 {
    let mut best : u32 = 0u32
    let mut bestcost : u32 = k0_cost(0u32)
    let mut k : u32 = 1u32
    while k < OM_K {
        if k0_verify(k) == 1u32 {
            if k0_cost(k) < bestcost { best = k ; bestcost = k0_cost(k) }
        }
        k = k + 1u32
    }
    return best
}

/* THE GRAND UNIFICATION: trace -> verify -> select frontier -> record proof. Returns the chosen kernel. */
fn omega_unify() -> u32 @export {
    k0_reset()
    k0_register(omega_cost(0u32))
    k0_register(omega_cost(1u32))
    k0_register(omega_cost(2u32))
    k0_register(omega_cost(3u32))
    omega_trace_to_k0(0u32)
    omega_trace_to_k0(1u32)
    omega_trace_to_k0(2u32)
    omega_trace_to_k0(3u32)
    k0_freeze_anchor()
    let chosen : u32 = omega_search()
    OMEGA_CHOSEN[0u32] = chosen
    /* record the accepted equivalence anchor == chosen as a citable lemma */
    pcc_init()
    let a : u32 = pcc_leaf()        /* term 0 = the anchor */
    let c : u32 = pcc_leaf()        /* term 1 = the chosen kernel */
    pcc_merge(a, c, 1u32)
    return chosen
}

/* REAL self-dispatch: run the chosen kernel, mutating real memory to its observable trace. */
fn omega_dispatch() -> i32 @export { return omega_run(OMEGA_CHOSEN[0u32]) }

/* 1 iff the equivalence (anchor == chosen) is recorded in the proof-producing congruence closure. */
fn omega_proof_recorded() -> u32 @export { return pcc_eq(0u32, 1u32) }

/* ===== KAT ===== */
fn omega_snapshot() {
    let mut x : u32 = 0u32
    while x < OM_D { OMEGA_SNAP[x as u64] = OMEGA_MEM[x as u64] ; x = x + 1u32 }
}
fn omega_mem_eq_snap() -> u32 {
    let mut x : u32 = 0u32
    while x < OM_D { if OMEGA_MEM[x as u64] != OMEGA_SNAP[x as u64] { return 0u32 } ; x = x + 1u32 }
    return 1u32
}

/* =====================================================================================
 * omega_engine_kat -- 99 = the grand unification works, self-checked:
 *   (1) the engine autonomously adopts kv1 (cheapest trace-equivalent, 4 ops) -- not the cheaper WRONG kbad;
 *   (2) the chosen kernel's REAL memory trace is byte-identical to the anchor's (observable-trace equivalence);
 *   (3) the proof anchor==chosen is recorded in the congruence closure;
 *   (4) the cost is really lower (4 < 16); deterministic; and kbad's trace really differs.
 * ===================================================================================== */
fn omega_engine_kat() -> u64 @export {
    /* (1) unify -> adopt kv1 */
    let chosen : u32 = omega_unify()
    if chosen != 1u32 { return 1u64 }

    /* (2) the chosen kernel's real memory trace == the anchor's */
    omega_run(0u32) ; omega_snapshot()        /* anchor's observable trace */
    omega_dispatch()                          /* run the chosen (kv1) -> mutate real memory */
    if omega_mem_eq_snap() != 1u32 { return 2u64 }
    if omega_mem(5u32) != ((5u32 * 7u32) + 3u32) { return 3u64 }   /* a real byte: cell 5 = 38 */

    /* (3) the proof is recorded */
    if omega_proof_recorded() != 1u32 { return 4u64 }

    /* (4) real speedup + safety + determinism */
    if omega_cost(1u32) >= omega_cost(0u32) { return 5u64 }        /* 4 < 16 */
    if omega_cost(1u32) != 4u32 { return 6u64 }
    if omega_cost(0u32) != 16u32 { return 7u64 }
    let again : u32 = omega_unify()
    if again != chosen { return 8u64 }                            /* deterministic */
    /* kbad's trace really differs from the anchor (so its rejection was meaningful) */
    omega_run(0u32) ; omega_snapshot()
    omega_run(3u32)
    if omega_mem_eq_snap() == 1u32 { return 9u64 }                /* kbad must differ */

    return 99u64
}
