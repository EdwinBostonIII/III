/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\sep_logic.iii
 *
 * III STDLIB - numera::sep_logic  --  SEPARATION LOGIC + THE FRAME RULE.
 *
 * Assertions about heaplets (numera::heaplet) and the principle that makes formal verification SCALE:
 * the FRAME RULE.  An assertion is a predicate on heaps; the precise fragment is
 *     emp        (the heap is empty)
 *     a |-> v    (the heap is exactly the single cell a holding v)
 *     P * Q      (the heap splits into DISJOINT parts, one satisfying P, the other Q)
 *     <b>        (a pure fact b, on the empty heap)
 * For precise assertions the split of `P * Q` is UNIQUE (determined by footprints), so satisfaction is
 * decidable without an exponential search over splits -- `sl_sat` computes it directly.
 *
 * THE FRAME RULE, stated semantically here over commands-as-heap-transformers with a declared footprint:
 *     if command c only writes cells in fp(c), and R owns cells DISJOINT from fp(c), then
 *         c(hP ⊎ hR)  =  c(hP) ⊎ hR
 * i.e. running c on a bigger heap transforms c's own region exactly as on the small heap and leaves the
 * FRAME hR byte-for-byte untouched.  This is local reasoning: to verify a function you look only at the
 * memory it owns, and everything else is provably preserved.  Mainstream verifiers drown in the global
 * state space precisely because they lack this; III gets it from the heaplet separation algebra for free.
 *
 * Verified (sep_logic_kat): sl_sat correctness; * commutative / associative / emp-identity; the FRAME
 * THEOREM over 200 random (local, frame) splits for STORE and SWAP commands; and the NEGATIVE -- a command
 * whose footprint OVERLAPS the frame provably MODIFIES it (the disjointness side-condition is load-bearing).
 *
 * Public API:
 *   sl_emp() / sl_pt(a,v) / sl_star(p,q) / sl_pure(b) -> u32    build assertion nodes
 *   sl_footprint(node) -> u64                                   cells the assertion constrains
 *   sl_sat(node, h) -> u32                                      1 iff heap h satisfies the assertion
 *   sl_frame_holds(kind,a,v,b, hP, hR) -> u32                   1 iff the frame theorem holds for this split
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_sep_logic

extern @abi(c-msvc-x64) fn hl_init() -> i32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_empty() -> u32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_singleton(a: u32, v: u32) -> u32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_set(h: u32, a: u32, v: u32) -> i32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_has(h: u32, a: u32) -> u32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_get(h: u32, a: u32) -> u32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_union(h1: u32, h2: u32) -> u32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_equal(h1: u32, h2: u32) -> u32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_footprint(h: u32) -> u64 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_size(h: u32) -> u32 from "heaplet.iii"

const SL_EMP  : u32 = 0u32
const SL_PT   : u32 = 1u32
const SL_STAR : u32 = 2u32
const SL_PURE : u32 = 3u32
const SL_NONE : u32 = 0xFFFFFFFFu32
const SL_ALL  : u64 = 0xFFFFFFFFFFFFFFFFu64

const CMD_STORE : u32 = 0u32
const CMD_SWAP  : u32 = 1u32
const CMD_ADD   : u32 = 2u32

var SL_KIND : [u32; 512]
var SL_A    : [u32; 512]
var SL_B    : [u32; 512]
var SL_N    : [u32; 1]

fn sl_reset() -> i32 @export { SL_N[0u32] = 0u32 ; return 0i32 }

fn sl_node(kind: u32, a: u32, b: u32) -> u32 {
    let n : u32 = SL_N[0u32]
    if n >= 512u32 { return SL_NONE }
    SL_N[0u32] = n + 1u32
    SL_KIND[n as u64] = kind
    SL_A[n as u64] = a
    SL_B[n as u64] = b
    return n
}

fn sl_emp() -> u32 @export { return sl_node(SL_EMP, 0u32, 0u32) }
fn sl_pt(a: u32, v: u32) -> u32 @export { return sl_node(SL_PT, a, v) }
fn sl_star(p: u32, q: u32) -> u32 @export { return sl_node(SL_STAR, p, q) }
fn sl_pure(b: u32) -> u32 @export { return sl_node(SL_PURE, b, 0u32) }

fn sl_footprint(node: u32) -> u64 @export {
    let k : u32 = SL_KIND[node as u64]
    if k == SL_EMP { return 0u64 }
    if k == SL_PURE { return 0u64 }
    if k == SL_PT { return 1u64 << (SL_A[node as u64] as u64) }
    /* STAR: union of the two sides' footprints */
    return sl_footprint(SL_A[node as u64]) | sl_footprint(SL_B[node as u64])
}

/* a NEW heaplet = the cells of h whose bit is set in mask (uses only exported heaplet ops). */
fn hl_restrict(h: u32, mask: u64) -> u32 {
    let r : u32 = hl_empty()
    let mut a : u32 = 0u32
    while a < 64u32 {
        if hl_has(h, a) == 1u32 {
            if (mask & (1u64 << (a as u64))) != 0u64 { hl_set(r, a, hl_get(h, a)) }
        }
        a = a + 1u32
    }
    return r
}

fn hl_copy(h: u32) -> u32 { return hl_restrict(h, SL_ALL) }

fn sl_sat(node: u32, h: u32) -> u32 @export {
    let k : u32 = SL_KIND[node as u64]
    if k == SL_EMP {
        if hl_size(h) == 0u32 { return 1u32 }
        return 0u32
    }
    if k == SL_PURE {
        if hl_size(h) == 0u32 { if SL_A[node as u64] == 1u32 { return 1u32 } }
        return 0u32
    }
    if k == SL_PT {
        let a : u32 = SL_A[node as u64]
        let v : u32 = SL_B[node as u64]
        if hl_size(h) != 1u32 { return 0u32 }
        if hl_has(h, a) != 1u32 { return 0u32 }
        if hl_get(h, a) != v { return 0u32 }
        return 1u32
    }
    /* STAR: precise unique split by P's footprint */
    let p : u32 = SL_A[node as u64]
    let q : u32 = SL_B[node as u64]
    let fpP : u64 = sl_footprint(p)
    let fpQ : u64 = sl_footprint(q)
    if (fpP & fpQ) != 0u64 { return 0u32 }     /* precise & overlapping -> cannot separate */
    let h1 : u32 = hl_restrict(h, fpP)
    let h2 : u32 = hl_restrict(h, fpP ^ SL_ALL)
    if sl_sat(p, h1) != 1u32 { return 0u32 }
    if sl_sat(q, h2) != 1u32 { return 0u32 }
    return 1u32
}

/* ----- commands as heap transformers (footprint = cells written) ----- */
fn cmd_footprint(kind: u32, a: u32, b: u32) -> u64 {
    if kind == CMD_SWAP { return (1u64 << (a as u64)) | (1u64 << (b as u64)) }
    return 1u64 << (a as u64)
}

fn cmd_apply(kind: u32, a: u32, v: u32, b: u32, h: u32) -> u32 {
    let r : u32 = hl_copy(h)
    if kind == CMD_STORE { hl_set(r, a, v) }
    else {
        if kind == CMD_SWAP {
            let va : u32 = hl_get(r, a)
            let vb : u32 = hl_get(r, b)
            hl_set(r, a, vb)
            hl_set(r, b, va)
        } else {
            let cur : u32 = hl_get(r, a)
            hl_set(r, a, (cur + v) & 0xFFu32)
        }
    }
    return r
}

/* 1 iff the FRAME THEOREM holds for command (kind,a,v,b) over the split (hP, hR):
 *   requires fp(cmd) disjoint from dom(hR) -- then c(hP ⊎ hR) == c(hP) ⊎ hR. */
fn sl_frame_holds(kind: u32, a: u32, v: u32, b: u32, hP: u32, hR: u32) -> u32 @export {
    let h : u32 = hl_union(hP, hR)
    if h == 0xFFFFFFFFu32 { return 0u32 }
    let big : u32 = cmd_apply(kind, a, v, b, h)
    let small : u32 = cmd_apply(kind, a, v, b, hP)
    let framed : u32 = hl_union(small, hR)
    if framed == 0xFFFFFFFFu32 { return 0u32 }
    return hl_equal(big, framed)
}

/* ===== KAT ===== */
var SL_RNG : [u64; 1]
fn sl_rng() -> u64 {
    let mut z : u64 = SL_RNG[0u64]
    z = z ^ (z << 13u64)
    z = z ^ (z >> 7u64)
    z = z ^ (z << 17u64)
    SL_RNG[0u64] = z
    return z
}
fn sl_lowbit(mask: u64) -> u32 {
    let mut a : u32 = 0u32
    while a < 64u32 { if (mask & (1u64 << (a as u64))) != 0u64 { return a } ; a = a + 1u32 }
    return 0u32
}
fn hl_build(mask: u64) -> u32 {
    let h : u32 = hl_empty()
    let mut a : u32 = 0u32
    while a < 64u32 { if (mask & (1u64 << (a as u64))) != 0u64 { hl_set(h, a, (a * 3u32) + 7u32) } ; a = a + 1u32 }
    return h
}

/* =====================================================================================
 * sep_logic_kat -- 99 = separation logic + the frame rule, self-checked:
 *   PART A (assertions): emp/points-to satisfaction incl. wrong-value & wrong-cell negatives; P*Q on a
 *     2-cell heap; * COMMUTATIVE; overlapping-footprint * is UNSAT; emp IDENTITY; * ASSOCIATIVE.
 *   PART B (FRAME THEOREM): over 200 random disjoint (local hP, frame hR) splits, a STORE into the local
 *     region satisfies c(hP⊎hR)==c(hP)⊎hR AND leaves hR byte-identical; plus a SWAP (2-cell footprint).
 *   PART C (NEGATIVE): a STORE whose footprint OVERLAPS the frame provably MODIFIES the frame region.
 * ===================================================================================== */
fn sep_logic_kat() -> u64 @export {
    /* ---- PART A ---- */
    hl_init() ; sl_reset()
    let e : u32 = hl_empty()
    if sl_sat(sl_emp(), e) != 1u32 { return 1u64 }
    let h5 : u32 = hl_singleton(5u32, 99u32)
    if sl_sat(sl_pt(5u32, 99u32), h5) != 1u32 { return 2u64 }
    if sl_sat(sl_pt(5u32, 98u32), h5) != 0u32 { return 3u64 }
    if sl_sat(sl_pt(6u32, 99u32), h5) != 0u32 { return 4u64 }
    if sl_sat(sl_emp(), h5) != 0u32 { return 5u64 }

    hl_init() ; sl_reset()
    let h : u32 = hl_empty()
    hl_set(h, 3u32, 30u32)
    hl_set(h, 7u32, 70u32)
    if sl_sat(sl_star(sl_pt(3u32, 30u32), sl_pt(7u32, 70u32)), h) != 1u32 { return 6u64 }
    if sl_sat(sl_star(sl_pt(7u32, 70u32), sl_pt(3u32, 30u32)), h) != 1u32 { return 7u64 }   /* commutative */
    if sl_sat(sl_star(sl_pt(3u32, 99u32), sl_pt(7u32, 70u32)), h) != 0u32 { return 8u64 }   /* wrong value */
    if sl_sat(sl_star(sl_pt(3u32, 30u32), sl_pt(3u32, 30u32)), h) != 0u32 { return 9u64 }   /* overlap -> unsat */

    hl_init() ; sl_reset()
    let h3 : u32 = hl_singleton(3u32, 30u32)
    if sl_sat(sl_star(sl_pt(3u32, 30u32), sl_emp()), h3) != 1u32 { return 10u64 }            /* emp identity */

    hl_init() ; sl_reset()
    let h3c : u32 = hl_empty()
    hl_set(h3c, 1u32, 10u32)
    hl_set(h3c, 2u32, 20u32)
    hl_set(h3c, 4u32, 40u32)
    let p : u32 = sl_pt(1u32, 10u32)
    let q : u32 = sl_pt(2u32, 20u32)
    let rr : u32 = sl_pt(4u32, 40u32)
    let lassoc : u32 = sl_star(sl_star(p, q), rr)
    let rassoc : u32 = sl_star(p, sl_star(q, rr))
    if sl_sat(lassoc, h3c) != sl_sat(rassoc, h3c) { return 11u64 }                            /* associative */
    if sl_sat(lassoc, h3c) != 1u32 { return 12u64 }

    /* ---- PART B: THE FRAME THEOREM ---- */
    SL_RNG[0u64] = 0x2B7E151628AED2A6u64
    let mut t : u32 = 0u32
    while t < 200u32 {
        hl_init()
        let mut maskP : u64 = sl_rng() & 0x5555555555555555u64    /* even cells */
        let maskR : u64 = sl_rng() & 0xAAAAAAAAAAAAAAAAu64        /* odd cells (disjoint) */
        if maskP == 0u64 { maskP = 1u64 }                        /* ensure >=1 owned cell */
        let hP : u32 = hl_build(maskP)
        let hR : u32 = hl_build(maskR)
        let a : u32 = sl_lowbit(maskP)
        let newv : u32 = ((sl_rng() & 0x3Fu64) as u32) + 100u32
        /* STORE into the local region: frame theorem must hold */
        if sl_frame_holds(CMD_STORE, a, newv, 0u32, hP, hR) != 1u32 { return 8000u64 + (t as u64) }
        /* frame hR is byte-identical inside the big result */
        let big : u32 = cmd_apply(CMD_STORE, a, newv, 0u32, hl_union(hP, hR))
        let fr : u32 = hl_restrict(big, maskR)
        if hl_equal(fr, hR) != 1u32 { return 8500u64 + (t as u64) }
        t = t + 1u32
    }

    /* SWAP (2-cell footprint) frame preservation */
    hl_init()
    let sp : u32 = hl_empty()
    hl_set(sp, 0u32, 11u32)
    hl_set(sp, 2u32, 22u32)            /* local owns cells 0,2 */
    let sr : u32 = hl_singleton(9u32, 90u32)   /* frame owns cell 9 */
    if sl_frame_holds(CMD_SWAP, 0u32, 0u32, 2u32, sp, sr) != 1u32 { return 13u64 }
    /* and the swap actually happened locally */
    let sbig : u32 = cmd_apply(CMD_SWAP, 0u32, 0u32, 2u32, hl_union(sp, sr))
    if hl_get(sbig, 0u32) != 22u32 { return 14u64 }
    if hl_get(sbig, 2u32) != 11u32 { return 15u64 }
    if hl_get(sbig, 9u32) != 90u32 { return 16u64 }   /* frame untouched */

    /* ---- PART C: NEGATIVE -- command footprint OVERLAPS the frame ---- */
    hl_init()
    let nlP : u32 = hl_singleton(2u32, 20u32)         /* local owns cell 2 */
    let nfR : u32 = hl_singleton(8u32, 80u32)         /* frame owns cell 8, value 80 */
    let nh : u32 = hl_union(nlP, nfR)
    let nbig : u32 = cmd_apply(CMD_STORE, 8u32, 99u32, 0u32, nh)   /* writes the FRAME's cell */
    let nfr : u32 = hl_restrict(nbig, 1u64 << 8u64)
    if hl_equal(nfr, nfR) == 1u32 { return 90u64 }    /* frame MUST differ now */
    if hl_get(nfr, 8u32) != 99u32 { return 91u64 }    /* it holds the new value, not 80 */
    /* and the frame theorem predicate correctly reports failure here */
    if sl_frame_holds(CMD_STORE, 8u32, 99u32, 0u32, nlP, nfR) == 1u32 { return 92u64 }

    return 99u64
}
