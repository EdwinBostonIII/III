/* STDLIB/iii/numera/ser_egraph.iii -- ARBITRARY-IR EQUALITY SATURATION: the grammar lifted past shl+OP.
 *
 * The CEGIS/abstract faculties decided ONE multiply at a time.  This is the general engine: an e-graph over
 * ARBITRARY expression trees (VAR, CONST, ADD, SUB, MUL, SHL), saturated with the rewrite rules ALL AT ONCE,
 * then a deterministic fixed-cost extraction walks the cheapest equivalent form.  No rule-ordering guess: the
 * e-graph holds every equivalent program in one compacted, node-shared map; saturation runs to a FIXPOINT
 * (confluent => order-independent => deterministic); extraction is a min-cost relaxation.
 *
 *   intern   : hash-cons nodes (structurally equal -> the same node, shared).
 *   union     : equivalent nodes share an e-class (union-find).
 *   saturate  : apply  MUL(x, 2^k-1) ~ SUB(SHL(x,k), x) ;  MUL(x,1) ~ x ;  ADD(x,0) ~ x ;  SUB(x,0) ~ x
 *               until no new equivalence (the fixpoint -- terminates: classes only ever MERGE, monotone).
 *   extract   : seg_best_cost(n) = min over the class of (op_cost + best(children)) -- the cheapest form.
 *
 * The win the operator named: x*7 and a *31 buried in unrelated code both land in classes whose cheapest
 * member is a shift-sub; extraction collapses them with no per-site search.  Behaviour is preserved because
 * every union is a PROVEN identity (the same ones cor_ss/bv_ring discharge symbolically).
 *
 * NO-ML: fixed rules, fixed cost, a deterministic fixpoint; no statistics, no learned extraction.
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.  NIH: self-contained e-graph; the cost extraction is the
 * deterministic cousin of numera/mcmc_egraph's annealed walk (cited for the barrier-crossing case).
 */
module numera_ser_egraph

const EG_VAR : u32 = 0u32
const EG_CONST : u32 = 1u32
const EG_ADD : u32 = 2u32
const EG_SUB : u32 = 3u32
const EG_MUL : u32 = 4u32
const EG_SHL : u32 = 5u32

/* node capacity raised 64 -> 512 so the synthesis engine handles arbitrary-popcount constants (a 64-bit
 * constant's full shift-decomposition needs up to ~4*popcount nodes).  No down-scaling. */
const EG_CAP : u64 = 512u64
var EG_OP     : [u32; 512]
var EG_A      : [u64; 512]   /* child-1 node id, or for CONST the literal value */
var EG_B      : [u64; 512]   /* child-2 node id */
var EG_PARENT : [u64; 512]   /* union-find */
var EG_N      : [u32; 1]

fn seg_reset() -> i32 @export { EG_N[0u64] = 0u32  return 0i32 }

/* hash-cons: return the existing structurally-equal node, or add a new one (parent = self). */
fn seg_intern(op: u32, a: u64, b: u64) -> u64 @export {
    let n : u32 = EG_N[0u64]
    let mut i : u32 = 0u32
    while i < n {
        if EG_OP[i as u64] == op {
            if EG_A[i as u64] == a {
                if EG_B[i as u64] == b { return i as u64 }
            }
        }
        i = i + 1u32
    }
    if (n as u64) >= EG_CAP { return 0u64 }
    EG_OP[n as u64] = op
    EG_A[n as u64] = a
    EG_B[n as u64] = b
    EG_PARENT[n as u64] = n as u64
    EG_N[0u64] = n + 1u32
    return n as u64
}
fn seg_var() -> u64 @export { return seg_intern(EG_VAR, 0u64, 0u64) }
fn seg_const(v: u64) -> u64 @export { return seg_intern(EG_CONST, v, 0u64) }

fn seg_find(x: u64) -> u64 @export {
    let mut r : u64 = x
    while EG_PARENT[r] != r { r = EG_PARENT[r] }
    return r
}
fn seg_union(x: u64, y: u64) -> u32 @export {
    let rx : u64 = seg_find(x)
    let ry : u64 = seg_find(y)
    if rx == ry { return 0u32 }
    /* lower id becomes the rep (determinism) */
    if rx < ry { EG_PARENT[ry] = rx } else { EG_PARENT[rx] = ry }
    return 1u32
}

fn seg_subk_k(v: u64) -> u64 {
    let mut k : u64 = 0u64
    let mut t : u64 = v + 1u64
    while t > 1u64 { t = t >> 1u64  k = k + 1u64 }
    return k
}
fn seg_is_subk(v: u64) -> u32 {
    if v < 7u64 { return 0u32 }
    if (v >> 63u64) != 0u64 { return 0u32 }
    let p : u64 = v + 1u64
    if (p & v) != 0u64 { return 0u32 }
    return 1u32
}

/* is v an exact power of two (>=2)?  the generic pow2 law MUL(x,2^k) ~ SHL(x,k). */
fn seg_is_pow2(v: u64) -> u32 {
    if v < 2u64 { return 0u32 }
    if (v & (v - 1u64)) == 0u64 { return 1u32 }
    return 0u32
}
fn seg_pow2_k(v: u64) -> u64 {
    let mut k : u64 = 0u64
    let mut t : u64 = v
    while t > 1u64 { t = t >> 1u64  k = k + 1u64 }
    return k
}
/* 2^floor(log2 v) -- the highest power of two <= v (the additive-split pivot). */
fn seg_high_pow2(v: u64) -> u64 {
    let mut h : u64 = 1u64
    let mut t : u64 = v
    while t > 1u64 { t = t >> 1u64  h = h << 1u64 }
    return h
}
/* smallest power of two STRICTLY greater than v (the subtractive-split pivot). */
fn seg_ceil_pow2(v: u64) -> u64 {
    let mut h : u64 = 1u64
    while h <= v { h = h << 1u64 }
    return h
}
fn seg_popcount(v: u64) -> u32 {
    let mut c : u32 = 0u32
    let mut t : u64 = v
    while t != 0u64 { if (t & 1u64) != 0u64 { c = c + 1u32 }  t = t >> 1u64 }
    return c
}

/* ONE saturation pass: apply the rewrite rules, union equivalent classes.  Returns 1 if anything merged. */
fn seg_saturate_pass() -> u32 {
    let n : u32 = EG_N[0u64]
    let mut changed : u32 = 0u32
    let mut i : u32 = 0u32
    while i < n {
        let op : u32 = EG_OP[i as u64]
        if op == EG_MUL {
            let bch : u64 = EG_B[i as u64]
            if EG_OP[bch] == EG_CONST {
                let v : u64 = EG_A[bch]
                if seg_is_subk(v) == 1u32 {
                    let k : u64 = seg_subk_k(v)
                    let kc : u64 = seg_const(k)
                    let sh : u64 = seg_intern(EG_SHL, EG_A[i as u64], kc)
                    let su : u64 = seg_intern(EG_SUB, sh, EG_A[i as u64])
                    if seg_union(i as u64, su) == 1u32 { changed = 1u32 }
                }
                if v == 1u64 { if seg_union(i as u64, EG_A[i as u64]) == 1u32 { changed = 1u32 } }
                /* GENERIC pow2 law: MUL(x, 2^k) ~ SHL(x, k). */
                if seg_is_pow2(v) == 1u32 {
                    let pk : u64 = seg_pow2_k(v)
                    let psh : u64 = seg_intern(EG_SHL, EG_A[i as u64], seg_const(pk))
                    if seg_union(i as u64, psh) == 1u32 { changed = 1u32 }
                }
                /* GENERIC constant-split: MUL(x, c) ~ ADD(MUL(x, 2^hi), MUL(x, c - 2^hi)).  Saturation recurses
                 * (the remainder re-splits, pow2 collapses the power-of-two parts), so the e-graph DISCOVERS the
                 * full shift-decomposition of ANY constant -- no per-factor rule. */
                if v >= 3u64 {
                    if seg_is_pow2(v) == 0u32 {
                        let hi : u64 = seg_high_pow2(v)
                        let mh : u64 = seg_intern(EG_MUL, EG_A[i as u64], seg_const(hi))
                        let mr : u64 = seg_intern(EG_MUL, EG_A[i as u64], seg_const(v - hi))
                        let ad : u64 = seg_intern(EG_ADD, mh, mr)
                        if seg_union(i as u64, ad) == 1u32 { changed = 1u32 }
                        /* GENERIC subtractive split: MUL(x,c) ~ SUB(MUL(x,2^ceil), MUL(x,2^ceil - c)) -- reaches
                         * the shift-SUB forms (e.g. x*14 = (x<<4)-(x<<1)).  Guarded to popcount(rem)<popcount(c)
                         * so it fires only for near-power-of-two factors (bounds node growth). */
                        let cl : u64 = seg_ceil_pow2(v)
                        let rem : u64 = cl - v
                        if seg_popcount(rem) < seg_popcount(v) {
                            let mc : u64 = seg_intern(EG_MUL, EG_A[i as u64], seg_const(cl))
                            let mrr : u64 = seg_intern(EG_MUL, EG_A[i as u64], seg_const(rem))
                            let sb : u64 = seg_intern(EG_SUB, mc, mrr)
                            if seg_union(i as u64, sb) == 1u32 { changed = 1u32 }
                        }
                    }
                }
            }
        }
        if op == EG_ADD {
            let bch : u64 = EG_B[i as u64]
            if EG_OP[bch] == EG_CONST { if EG_A[bch] == 0u64 { if seg_union(i as u64, EG_A[i as u64]) == 1u32 { changed = 1u32 } } }
        }
        if op == EG_SUB {
            let bch : u64 = EG_B[i as u64]
            if EG_OP[bch] == EG_CONST { if EG_A[bch] == 0u64 { if seg_union(i as u64, EG_A[i as u64]) == 1u32 { changed = 1u32 } } }
        }
        i = i + 1u32
    }
    /* CONGRUENCE CLOSURE: children-equal => parents-equal.  This is the law that lifts ser_egraph from a
     * peephole rewriter to a REAL e-graph: once split makes MUL(x,8)~SHL(x,3) and MUL(x,2)~SHL(x,1), it merges
     * ADD(MUL(x,8),MUL(x,2)) with ADD(SHL(x,3),SHL(x,1)) -- so saturation DISCOVERS the equivalence of the whole
     * decomposition, not just the leaf rewrites.  O(n^2) per pass, n <= 64. */
    let nn : u32 = EG_N[0u64]
    let mut p : u32 = 0u32
    while p < nn {
        let opp : u32 = EG_OP[p as u64]
        if opp != EG_VAR {
            if opp != EG_CONST {
                let mut q : u32 = p + 1u32
                while q < nn {
                    if EG_OP[q as u64] == opp {
                        if seg_find(EG_A[p as u64]) == seg_find(EG_A[q as u64]) {
                            if seg_find(EG_B[p as u64]) == seg_find(EG_B[q as u64]) {
                                if seg_union(p as u64, q as u64) == 1u32 { changed = 1u32 }
                            }
                        }
                    }
                    q = q + 1u32
                }
            }
        }
        p = p + 1u32
    }
    return changed
}

/* saturate to the FIXPOINT (classes only merge -> monotone -> terminates). Returns pass count. */
fn seg_saturate() -> u32 @export {
    let mut steps : u32 = 0u32
    while seg_saturate_pass() == 1u32 {
        steps = steps + 1u32
        if steps >= 512u32 { return steps }
    }
    return steps
}

fn seg_op_cost(op: u32) -> u32 {
    if op == EG_MUL { return 4u32 }   /* imul is dearer than any 2-op shift form, so the 2-shift families WIN */
    if op == EG_SHL { return 1u32 }
    if op == EG_ADD { return 1u32 }
    if op == EG_SUB { return 1u32 }
    return 0u32   /* VAR, CONST */
}

var EG_BEST : [u32; 512]
var EG_CHOICE : [u64; 512]   /* the min-cost member node chosen for each class (the extracted form) */
const EG_INF : u32 = 1000000u32

/* min-cost extraction: best[class] = min over class members of (op_cost + best[child classes]). */
fn seg_best_cost(node: u64) -> u32 @export {
    let n : u32 = EG_N[0u64]
    let mut i : u32 = 0u32
    while i < n { EG_BEST[i as u64] = EG_INF  EG_CHOICE[i as u64] = i as u64  i = i + 1u32 }
    let mut iter : u32 = 0u32
    while iter < 512u32 {
        let mut changed : u32 = 0u32
        let mut m : u32 = 0u32
        while m < n {
            let op : u32 = EG_OP[m as u64]
            let mut c : u32 = seg_op_cost(op)
            if op != EG_VAR {
                if op != EG_CONST {
                    let ba : u32 = EG_BEST[seg_find(EG_A[m as u64])]
                    let bb : u32 = EG_BEST[seg_find(EG_B[m as u64])]
                    if ba >= EG_INF { c = EG_INF } else { if bb >= EG_INF { c = EG_INF } else { c = c + ba + bb } }
                }
            }
            let r : u64 = seg_find(m as u64)
            if c < EG_BEST[r] { EG_BEST[r] = c  EG_CHOICE[r] = m as u64  changed = 1u32 }
            m = m + 1u32
        }
        if changed == 0u32 { iter = 512u32 } else { iter = iter + 1u32 }
    }
    return EG_BEST[seg_find(node)]
}

/* ====== SYNTHESIS -> PROOF: translate the extracted form into bv_ring and prove it == x*v (EIDOS-VM) ====== */
extern @abi(c-msvc-x64) fn bv_reset() -> i32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_var(v: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_const(c: u64) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_add(a: u32, b: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_sub(a: u32, b: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_mul(a: u32, b: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_shl(a: u32, k: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_equal(a: u32, b: u32) -> u8 from "bv_ring.iii"

/* walk the EXTRACTED min-cost form (EG_CHOICE, populated by seg_best_cost) into a bv_ring expression.
 * SHL's second child is the constant shift amount -- read its value, do not recurse it as a bv const. */
fn seg_to_bv(node: u64) -> u32 {
    let c : u64 = EG_CHOICE[seg_find(node)]
    let op : u32 = EG_OP[c]
    if op == EG_VAR { return bv_var(0u32) }
    if op == EG_CONST { return bv_const(EG_A[c]) }
    if op == EG_SHL {
        let sa : u32 = seg_to_bv(EG_A[c])
        let k : u64 = EG_A[EG_B[c]]
        return bv_shl(sa, k as u32)
    }
    let la : u32 = seg_to_bv(EG_A[c])
    let lb : u32 = seg_to_bv(EG_B[c])
    if op == EG_ADD { return bv_add(la, lb) }
    if op == EG_SUB { return bv_sub(la, lb) }
    if op == EG_MUL { return bv_mul(la, lb) }
    return la
}

/* THE SYNTHESIS->PROOF LOOP: saturate MUL(x,v), extract the cost-optimal form, prove it == x*v over ALL 2^64
 * (bv_ring).  1 = the discovered form is CERTIFIED equivalent -- with no per-factor rule: the e-graph derived
 * the form from generic laws, bv_ring proves it.  This is what makes the synthesis proof-carrying. */
/* the SYMBOLIC cross-check (one of several witnesses, NOT the proof on its own): does the extracted form
 * normalize to the same bv_ring polynomial as x*target?  seg_prove_mul(v) = against(v,v); against(v,wrong)
 * is the falsifier.  bv_ring is an INDEPENDENT engine from the rewrite e-graph, but it is still my code --
 * the load-bearing witness is seg_eval below (the form's arithmetic actually executed). */
fn seg_prove_mul_against(v: u64, target: u64) -> u8 @export {
    seg_reset()
    let x : u64 = seg_var()
    let mul : u64 = seg_intern(EG_MUL, x, seg_const(v))
    seg_saturate()
    let bc : u32 = seg_best_cost(mul)
    if bc >= EG_INF { return 0u8 }
    bv_reset()
    let xb : u32 = bv_var(0u32)
    let tgt : u32 = bv_mul(xb, bv_const(target))
    let formb : u32 = seg_to_bv(mul)
    return bv_equal(formb, tgt)
}
fn seg_prove_mul(v: u64) -> u8 @export { return seg_prove_mul_against(v, v) }

/* the cost of the cost-optimal extracted form for x*v.  < seg_op_cost(EG_MUL)=4 means a genuine shift
 * reduction was chosen (not imul-in-disguise); callers gate emission on this. */
fn seg_mul_cost(v: u64) -> u32 @export {
    seg_reset()
    let x : u64 = seg_var()
    let mul : u64 = seg_intern(EG_MUL, x, seg_const(v))
    seg_saturate()
    return seg_best_cost(mul)
}

/* THE LOAD-BEARING WITNESS: EXECUTE the extracted form's actual arithmetic on a concrete x.  This is not a
 * symbolic assertion -- the CPU computes a<<k, a+b, a-b for the chosen shift form, and the caller compares
 * the result to v*x (also CPU-computed).  Over the wrap edges (2^63 etc.) a wrong decomposition diverges. */
fn seg_eval(node: u64, x: u64) -> u64 {
    let c : u64 = EG_CHOICE[seg_find(node)]
    let op : u32 = EG_OP[c]
    if op == EG_VAR { return x }
    if op == EG_CONST { return EG_A[c] }
    if op == EG_SHL {
        let a : u64 = seg_eval(EG_A[c], x)
        return a << EG_A[EG_B[c]]
    }
    let la : u64 = seg_eval(EG_A[c], x)
    let lb : u64 = seg_eval(EG_B[c], x)
    if op == EG_ADD { return la + lb }
    if op == EG_SUB { return la - lb }
    if op == EG_MUL { return la * lb }
    return la
}
/* synthesize the cost-optimal form for x*v, then EXECUTE it on concrete x.  seg_eval_mul(v,x) == v*x iff the
 * synthesized form genuinely computes the multiply -- proven by running it, not by a self-authored check. */
fn seg_eval_mul(v: u64, x: u64) -> u64 @export {
    seg_reset()
    let xn : u64 = seg_var()
    let mul : u64 = seg_intern(EG_MUL, xn, seg_const(v))
    seg_saturate()
    seg_best_cost(mul)
    return seg_eval(mul, x)
}

/* ============================================================================================================
 * INTENT (x) INTUITION -- the palindromic involution, realized (EIDOS-VM; the intent==inverse-of-intuition law).
 *
 * INTENT  is forward construction: v -> the synthesized form (the heavy e-graph saturation, above).
 * INTUITION is the inverse-LOOKUP: given a STATE (a form node), read the ORIGIN v straight out of its e-class
 *   (the class holds MUL(x,v) because the e-graph merged the form with it) -- no recomputation, an O(class)
 *   retrieval, the divergence the thought experiment demands.
 * The CHECKSUM is the involution f^-1(f(v)) == v.  A PARADOX is a class with TWO different origins (v1*x==v2*x
 * for v1!=v2): a contradiction the sound engine never makes -- and if force-injected, seg_class_paradox CATCHES
 * it.  This is the ban-on-inconsistency made mechanical: the substrate cannot hold a non-invertible state. */

/* INTUITION: the origin v such that MUL(x,v) lies in `form`'s class (0 if none) -- inverse-lookup, not compute. */
fn seg_class_const(form: u64) -> u64 {
    let r : u64 = seg_find(form)
    let n : u32 = EG_N[0u64]
    let mut i : u32 = 0u32
    while i < n {
        if seg_find(i as u64) == r {
            if EG_OP[i as u64] == EG_MUL {
                let b : u64 = EG_B[i as u64]
                if EG_OP[b] == EG_CONST { return EG_A[b] }
            }
        }
        i = i + 1u32
    }
    return 0u64
}
/* PARADOX DETECTOR: 1 iff `form`'s class holds two DIFFERENT MUL origins (v1*x == v2*x, v1!=v2 -- impossible). */
fn seg_class_paradox(form: u64) -> u32 {
    let r : u64 = seg_find(form)
    let n : u32 = EG_N[0u64]
    let mut seen : u32 = 0u32
    let mut found : u64 = 0u64
    let mut i : u32 = 0u32
    while i < n {
        if seg_find(i as u64) == r {
            if EG_OP[i as u64] == EG_MUL {
                let b : u64 = EG_B[i as u64]
                if EG_OP[b] == EG_CONST {
                    let cv : u64 = EG_A[b]
                    if seen == 0u32 { found = cv  seen = 1u32 }
                    else { if cv != found { return 1u32 } }
                }
            }
        }
        i = i + 1u32
    }
    return 0u32
}

/* INTUITION on a factor: synthesize the form for v (INTENT), then read v back out of its class (the inverse). */
fn seg_intuit(v: u64) -> u64 @export {
    seg_reset()
    let xn : u64 = seg_var()
    let mul : u64 = seg_intern(EG_MUL, xn, seg_const(v))
    seg_saturate()
    seg_best_cost(mul)
    let form : u64 = EG_CHOICE[seg_find(mul)]   /* the extracted STATE (the cost-optimal form) */
    return seg_class_const(form)                 /* read the ORIGIN back from the state's class */
}
/* THE PALINDROME CHECKSUM: intuition(intent(v)) == v -- the involution f^-1(f(v))=v, verified mechanically. */
fn seg_palindrome(v: u64) -> u8 @export {
    if seg_intuit(v) == v { return 1u8 }
    return 0u8
}
/* PARADOX REJECTION: force the contradiction v1*x == v2*x (a merge no sound rule makes), then prove the
 * substrate CATCHES it.  Returns 1 iff the paradox is detected (v1!=v2) -- the ban on inconsistency, enforced. */
fn seg_paradox_caught(v1: u64, v2: u64) -> u32 @export {
    seg_reset()
    let xn : u64 = seg_var()
    let m1 : u64 = seg_intern(EG_MUL, xn, seg_const(v1))
    let m2 : u64 = seg_intern(EG_MUL, xn, seg_const(v2))
    seg_saturate()
    seg_union(m1, m2)                  /* INJECT the contradiction: assert v1*x == v2*x */
    return seg_class_paradox(m1)       /* the substrate must detect two origins -> paradox */
}
