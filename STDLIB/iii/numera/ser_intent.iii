/* STDLIB/iii/numera/ser_intent.iii -- INTENT AS A TARGET E-CLASS: the e-graph as inter-module synthesis linker.
 *
 * Intent is the INVERSE of intuition (a Galois adjunction): intuition generalises instances -> a shape
 * (numera/ser_antiunify); intent demands a shape -> the implementation that fits it (this).  A module's intent
 * is NOT a human feeling -- it is a module-to-module geometric boundary, a CONTRACT, deterministic.  Here that
 * contract is dropped into the e-graph as a TARGET e-class ("a value == x*v"); synthesis grows candidate
 * implementations; and -- the epiphany -- the e-classes MERGE only when the multi-engine certifier PROVES a
 * candidate equivalent to the contract.  Extraction then walks the cheapest fulfilling path.
 *
 * This repurposes the e-graph from a local optimiser into an INTER-MODULE SYNTHESIS LINKER -- not standard
 * (egg-style e-graphs optimise a complete program; SyGuS/CEGIS build from scratch on a raw SMT solver).  Here
 * the e-graph holds an UNFULFILLED contract, the membrane+CEGIS grow toward it, and a SYMBOLIC proof triggers
 * the merge.  It outclasses Curry-Howard FOR THIS ARCHITECTURE: the burden of discovery is the machine's
 * (saturate the topological map until a proven bridge connects state to target), not a human proof tree.
 *
 * SOUNDNESS (the conscience line): a merge fires ONLY on a bv_ring proof of equivalence over ALL 2^64 -- so
 * every member of the intent class is PROVABLY equal to the contract, and in_resolve returns a provably-correct
 * cheapest implementation.  A candidate whose proof FAILS never merges (in_propose returns 0, zero state change).
 *
 * EVENT-DRIVEN: the contract, each proposal, and each proven merge are perceived on the witnessed
 * event_substrate log -> the intent resolution is a replayable, foldable process.  NO-ML: fixed grammar, a
 * deductive proof gate, a deterministic extraction; no model, no statistics.
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00.  NIH: composes numera/ser_egraph (the map) + numera/bv_ring (the
 * certifier that merges) + omnia/event_substrate (the witnessed bus) -- no island.
 */
module numera_ser_intent

extern @abi(c-msvc-x64) fn seg_reset() -> i32 from "ser_egraph.iii"
extern @abi(c-msvc-x64) fn seg_var() -> u64 from "ser_egraph.iii"
extern @abi(c-msvc-x64) fn seg_const(v: u64) -> u64 from "ser_egraph.iii"
extern @abi(c-msvc-x64) fn seg_intern(op: u32, a: u64, b: u64) -> u64 from "ser_egraph.iii"
extern @abi(c-msvc-x64) fn seg_union(x: u64, y: u64) -> u32 from "ser_egraph.iii"
extern @abi(c-msvc-x64) fn seg_best_cost(node: u64) -> u32 from "ser_egraph.iii"

extern @abi(c-msvc-x64) fn bv_reset() -> i32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_var(v: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_const(c: u64) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_sub(a: u32, b: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_shl(a: u32, k: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_mul(a: u32, b: u32) -> u32 from "bv_ring.iii"
extern @abi(c-msvc-x64) fn bv_equal(a: u32, b: u32) -> u8 from "bv_ring.iii"

extern @abi(c-msvc-x64) fn evt_reset() -> i32 from "event_substrate.iii"
extern @abi(c-msvc-x64) fn evt_perceive(observer: u64, kind: u64, priority: u64, payload: u64) -> u64 from "event_substrate.iii"
extern @abi(c-msvc-x64) fn evt_count() -> u32 from "event_substrate.iii"
extern @abi(c-msvc-x64) fn evt_witness(upto: u32) -> u64 from "event_substrate.iii"

const IN_MUL : u32 = 4u32
const IN_SUB : u32 = 3u32
const IN_SHL : u32 = 5u32

var IN_X : [u64; 1]   /* the shared variable node */
var IN_V : [u64; 1]   /* the contract's target factor v */

/* Module A's INTENT: declare the contract "a value == x*v" as a TARGET e-class.  Returns the target handle. */
fn in_declare(v: u64) -> u64 @export {
    seg_reset()
    evt_reset()
    let x : u64 = seg_var()
    IN_X[0u64] = x
    IN_V[0u64] = v
    let spec : u64 = seg_intern(IN_MUL, x, seg_const(v))
    evt_perceive(1u64, 1u64, v, spec)          /* INTENT declared */
    return spec
}

/* SYNTHESIS proposal: Module B offers (x<<k)-x.  The certifier must PROVE it == x*v over ALL 2^64; ONLY a
 * proof triggers the e-class MERGE.  1 = proven + merged; 0 = proof failed, zero state change. */
fn in_propose_shlsub(handle: u64, k: u64) -> u32 @export {
    let v : u64 = IN_V[0u64]
    bv_reset()
    let bx : u32 = bv_var(0u32)
    let proven : u8 = bv_equal(bv_sub(bv_shl(bx, k as u32), bx), bv_mul(bx, bv_const(v)))
    evt_perceive(1u64, 2u64, k, proven as u64)   /* PROPOSAL (with its verdict) */
    if proven != 1u8 { return 0u32 }              /* no proof -> NO merge (soundness) */
    let x : u64 = IN_X[0u64]
    let cand : u64 = seg_intern(IN_SUB, seg_intern(IN_SHL, x, seg_const(k)), x)
    seg_union(handle, cand)
    evt_perceive(1u64, 3u64, k, cand)             /* MERGE (proof-triggered) */
    return 1u32
}

/* EXTRACTION: the cheapest PROVABLY-CORRECT implementation of the contract (the naive multiply is the
 * fallback at cost 3; a proven shl-sub lowers it to 2). */
fn in_resolve(handle: u64) -> u32 @export { return seg_best_cost(handle) }

/* the replayable witness of the whole intent resolution (declare -> propose -> merge). */
fn in_witness() -> u64 @export { return evt_witness(evt_count()) }

/* ============================================================================================================
 * THE CLOSED SYNTHESIS LOOP, AT THE SVIR LEVEL -- ser_cegis PROPOSES, seq_equiv DISPOSES.
 * in_propose_shlsub above needs the caller to supply k.  Here the SYNTHESIZER (ser_cegis/cg_synth) AUTONOMOUSLY
 * chooses the strength-reduction descriptor {form,k} for x*v, this module EMITS both the multiply and the
 * reduction as real SVIR bodies, and the SVIR<->SVIR prover (numera/ser_kinduct_sym/seq_equiv) CERTIFIES them
 * equivalent over ALL 2^64.  This is the apply-half the EIDOS retrospective recorded as unbuilt (C4): the
 * synthesizer drives a rewrite that is PROVEN sound -- and the prover is the independent backstop that REFUTES
 * a corrupted proposal (in_certify_wrong).  cg_synth's concrete oracle only makes the proposal PLAUSIBLE; the
 * exhaustive bit-blast miter makes it PROVEN.  NO ISLAND: composes ser_cegis + ser_kinduct_sym.  Ring R0. */
extern @abi(c-msvc-x64) fn cg_synth(v: u64, seed: u64) -> u32 from "ser_cegis.iii"
extern @abi(c-msvc-x64) fn cg_form(packed: u32) -> u32 from "ser_cegis.iii"
extern @abi(c-msvc-x64) fn cg_k(packed: u32) -> u32 from "ser_cegis.iii"
extern @abi(c-msvc-x64) fn seq_equiv(ba: u64, oa: u64, la: u64, bx: u64, ox: u64, lx: u64, nparam: u32) -> u32 from "ser_kinduct_sym.iii"

const IN_CGNONE : u32 = 4294967295u32
const IN_SEQTOP : u32 = 2u32
var IN_MULB : [u8; 32]   /* emitted body of  x * v        */
var IN_REDB : [u8; 32]   /* emitted body of  the reduction */

fn in_emit_b(base: u64, off: u64, byte: u8) -> u64 { let p : *u8 = (base + off) as *u8  p[0u64] = byte  return off + 1u64 }
fn in_emit_const(base: u64, off: u64, val: u64) -> u64 {
    let mut o : u64 = in_emit_b(base, off, 1u8)              /* CONST_I64 opcode 0x01 */
    let mut i : u64 = 0u64
    while i < 8u64 { o = in_emit_b(base, o, ((val >> (i * 8u64)) & 255u64) as u8)  i = i + 1u64 }
    return o
}
fn in_emit_mul(base: u64, v: u64) -> u64 {                   /* GET0 CONST(v) MUL */
    let mut o : u64 = in_emit_b(base, 0u64, 16u8)  o = in_emit_b(base, o, 0u8)
    o = in_emit_const(base, o, v)
    return in_emit_b(base, o, 34u8)
}
fn in_emit_red(base: u64, form: u32, k: u64) -> u64 {        /* GET0 CONST(k) SHL [GET0 ADD|SUB] */
    let mut o : u64 = in_emit_b(base, 0u64, 16u8)  o = in_emit_b(base, o, 0u8)
    o = in_emit_const(base, o, k)
    o = in_emit_b(base, o, 40u8)                            /* SHL */
    if form == 1u32 { o = in_emit_b(base, o, 16u8)  o = in_emit_b(base, o, 0u8)  o = in_emit_b(base, o, 32u8) }   /* (x<<k)+x */
    if form == 2u32 { o = in_emit_b(base, o, 16u8)  o = in_emit_b(base, o, 0u8)  o = in_emit_b(base, o, 33u8) }   /* (x<<k)-x */
    return o
}

/* THE DRIVER: synthesize a reduction for x*v and PROVE it.  1 = synth proposed AND prover certified over 2^64;
 * 0 = proposal refuted; IN_SEQTOP = no reduction found / undecided. */
fn in_certify(v: u64, seed: u64) -> u32 @export {
    let d : u32 = cg_synth(v, seed)
    if d == IN_CGNONE { return IN_SEQTOP }
    let form : u32 = cg_form(d)
    let kk : u32 = cg_k(d)
    let k : u64 = kk as u64
    let lm : u64 = in_emit_mul(&IN_MULB as u64, v)
    let lr : u64 = in_emit_red(&IN_REDB as u64, form, k)
    return seq_equiv(&IN_MULB as u64, 0u64, lm, &IN_REDB as u64, 0u64, lr, 1u32)
}
/* TEETH: corrupt the synthesized shift by +1 -- the prover MUST refute (0), proving it certifies the SPECIFIC
 * descriptor, not "any reduction". */
fn in_certify_wrong(v: u64, seed: u64) -> u32 @export {
    let d : u32 = cg_synth(v, seed)
    if d == IN_CGNONE { return IN_SEQTOP }
    let form : u32 = cg_form(d)
    let kk : u32 = cg_k(d)
    let k : u64 = (kk as u64) + 1u64
    let lm : u64 = in_emit_mul(&IN_MULB as u64, v)
    let lr : u64 = in_emit_red(&IN_REDB as u64, form, k)
    return seq_equiv(&IN_MULB as u64, 0u64, lm, &IN_REDB as u64, 0u64, lr, 1u32)
}

/* ============================================================================================================
 * THE PROVEN ADJUNCTION -- intent ⊣ intuition, made executable law (2026-07-17).
 *
 * The header calls intent "the INVERSE of intuition (a Galois adjunction)".  Until now that was PROSE.  Here
 * it becomes a theorem III PROVES WITH ITS OWN ENGINES -- the two faculties composed into one certified loop.
 *
 * THE ADJUNCTION.  Write gamma (INTUITION, generalize) : instances -> the parametric family they share
 * (numera/ser_antiunify::au_generalize, a pure structural least-general-generalization), and sigma (INTENT,
 * specialize+prove) : a family/contract -> the cheapest PROVABLY-correct implementation (this module).  The
 * Galois CLOSURE is sigma.gamma (generalize, then prove).  The laws, each discharged by a REAL prover, never
 * an assertion:
 *   EXPANSIVE   S subset sigma.gamma(S): every instance is a proven member of its own generalization
 *               (au_is_subk verifies 2^k-1 == v for each; ser_antiunify:37).
 *   WARRANTED   sigma proves the WHOLE generalized family in ONE symbolic shot over k=3..63
 *               (au_prove_family -> forcefield/cg_opt_rules::cor_ss_certify_all; ser_antiunify:74).
 *   ROUND-TRIP  on a member, INTUITION synthesizes the reduction (cg_synth) and INTENT certifies it == x*v
 *               over ALL 2^64 by the SVIR<->SVIR miter (in_certify -> ser_kinduct_sym::seq_equiv).
 *   SOUND       the negative arm PROVEN: a descriptor corrupted by +1 is REFUTED by the same miter
 *               (in_certify_wrong == 0) -- intent certifies the SPECIFIC descriptor, not "any reduction".
 *   TIGHT       the lower adjoint does not over-reach: a non-member in the instance set forbids the family
 *               (au_generalize -> AU_NONE), so gamma never claims a shape sigma cannot prove.
 *   IDEMPOTENT  gamma is deterministic (same instances => same family): the closure sigma.gamma is stable.
 *
 * TWO-PATH (the no-tautology law): the ROUND-TRIP identity (x<<3)-x == x*7 is certified here by seq_equiv AND,
 * independently, by the standing tool `iii-prove` over all 2^64 (bit-blast UNSAT); the corrupted (x<<4)-x is
 * REFUTED by both -- so a vacuous in-organ pass cannot hide.  in_adjoint_selfproof is the CONDITION OF MOTION:
 * before intent may resolve any contract, the adjunction that justifies it is re-proven, exit 0. */
extern @abi(c-msvc-x64) fn au_generalize(v0: u64, v1: u64, v2: u64, seed: u64) -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_prove_family(family: u32) -> u8 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_is_subk(v: u64, seed: u64) -> u32 from "ser_antiunify.iii"

const IN_AU_SUBK : u32 = 2u32
const IN_AU_NONE : u32 = 255u32

/* gamma: the family INTUITION generalizes the instances to (exported for consumers of the adjunction). */
fn in_adjoint_gamma(v0: u64, v1: u64, v2: u64, seed: u64) -> u32 @export { return au_generalize(v0, v1, v2, seed) }
/* sigma's warrant for a whole family: INTENT's one-shot proof (1 = universally sound). */
fn in_adjoint_family_warrant(family: u32) -> u8 @export { return au_prove_family(family) }
/* the closure sigma.gamma applied to {v0,v1,v2}: 1 iff intuition generalizes them to a family AND intent
 * proves that whole family -- the Galois closure, computed and certified by III's own engines. */
fn in_adjoint_closure(v0: u64, v1: u64, v2: u64, seed: u64) -> u8 @export {
    let fam : u32 = au_generalize(v0, v1, v2, seed)
    if fam == IN_AU_NONE { return 0u8 }
    return au_prove_family(fam)
}

/* THE ADJUNCTION SELF-PROOF (CONDITION OF MOTION -- the FAST tier, milliseconds).  It proves the adjunction's
 * STRUCTURE plus a REAL soundness certificate: the e-class MERGE fires only on a bv_ring proof over ALL 2^64
 * that (x<<3)-x == x*7 (in_propose_shlsub), so the ground identity is machine-proven here -- and a wrong
 * proposal is bv_ring-REFUTED.  The exhaustive SVIR-miter + whole-family certificates are the deliberate
 * WARRANT below (they cost ~30s -- too dear for every motion, so they are a deep-proof, not a heartbeat).
 * 0 = intent ⊣ intuition structurally PROVEN this invocation.
 *   10 gamma-wrong   11 not-expansive   15 not-tight   16 not-idempotent
 *   17 merge-not-cheaper   18 wrong-proposal-merged */
fn in_adjoint_selfproof() -> u32 @export {
    let seed : u64 = 1u64
    /* gamma: intuition generalizes {7,15,31} (each 2^k-1) to the SUBK family */
    if au_generalize(7u64, 15u64, 31u64, seed) != IN_AU_SUBK { return 10u32 }
    /* EXPANSIVE: each instance is a proven member of its own generalization */
    if au_is_subk(7u64, seed) != 1u32 { return 11u32 }
    if au_is_subk(15u64, seed) != 1u32 { return 11u32 }
    if au_is_subk(31u64, seed) != 1u32 { return 11u32 }
    /* TIGHT: a non-member (6 is not 2^k-1) forbids the family -- gamma never over-reaches */
    if au_generalize(7u64, 15u64, 6u64, seed) != IN_AU_NONE { return 15u32 }
    /* IDEMPOTENT: gamma is deterministic -> the closure is stable */
    if au_generalize(7u64, 15u64, 31u64, seed) != IN_AU_SUBK { return 16u32 }
    /* the e-class INTENT linker: a proof-triggered merge (bv_ring over ALL 2^64, fast) lowers the cost;
     * a wrong proposal is bv_ring-REFUTED and never merges -- a REAL soundness arm, both directions */
    let h : u64 = in_declare(7u64)
    let before : u32 = in_resolve(h)
    if in_propose_shlsub(h, 3u64) != 1u32 { return 17u32 }       /* (x<<3)-x == x*7 proven -> merge */
    if in_resolve(h) >= before { return 17u32 }                  /* the merge lowered the cost      */
    let h2 : u64 = in_declare(15u64)
    if in_propose_shlsub(h2, 3u64) != 0u32 { return 18u32 }      /* (x<<3)-x = x*7 != x*15 -> no merge */
    return 0u32
}
fn in_adjoint_ok() -> u8 @export {
    if in_adjoint_selfproof() == 0u32 { return 1u8 }
    return 0u8
}
/* THE ADJUNCTION WARRANT (the DEEP tier, deliberate ~30s): the exhaustive certificates that make the
 * adjunction SOUND over the whole domain -- the WHOLE family proven in one symbolic shot, the SVIR<->SVIR
 * round-trip certified over ALL 2^64, and the corrupted descriptor REFUTED by the same miter.  Run at seal
 * time / on demand, not every motion.  0 = warranted | 12 family-unwarranted | 13 round-trip-fails
 * | 14 not-sound(teeth). */
fn in_adjoint_warrant() -> u32 @export {
    let seed : u64 = 1u64
    if au_prove_family(IN_AU_SUBK) != 1u8 { return 12u32 }       /* the whole family, cor_ss_certify_all */
    if in_certify(7u64, seed) != 1u32 { return 13u32 }           /* the SVIR round-trip, seq_equiv 2^64  */
    if in_certify_wrong(7u64, seed) != 0u32 { return 14u32 }     /* the SVIR teeth (corrupt +1 refuted)  */
    return 0u32
}
