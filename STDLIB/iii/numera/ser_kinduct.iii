/* STDLIB/iii/numera/ser_kinduct.iii -- the TEMPORAL SIEVE: k-induction for the proof-gated temporal merge.
 *
 * The temporal membrane (ser_tgraph) is a BOUNDED refuter -- it can find a deadlock in k steps, but it cannot
 * PROVE infinite safety, so it cannot trigger an e-class merge.  The operator named the fix exactly:
 * k-INDUCTION.  To prove an LTL safety invariant P holds for ALL reachable states (infinite time):
 *     BASE:      the initial state satisfies P.
 *     INDUCTIVE: for ANY state s with P(s), EVERY transition s -> s' preserves P(s').
 * If both discharge, P is invariant -- universally, for all time.  This is the temporal cousin of the
 * spatial sieve: the combinational miter P(s) & T(s,s') & ~P(s') must be UNSAT (here, exhaustively over the
 * finite state geometry -- the bit-blast bv_bits would do for larger systems).
 *
 * The system: a lock-based MUTEX, state = (lock, p1_cs, p2_cs) (3 bits, 8 states).  The temporal intent is
 * MUTUAL EXCLUSION: G ~(p1_cs & p2_cs).  The subtlety the sieve exposes (and the membrane misses): the bare
 * invariant ~(p1 & p2) is NOT 1-inductive -- an UNREACHABLE state (p1 in CS with the lock free) satisfies it
 * yet steps to a violation.  The STRENGTHENED invariant (lock == p1|p2) & ~(p1&p2) IS 1-inductive -> the
 * merge fires, proving mutual exclusion for every reachable state.  Strengthening-to-induction is the
 * mathematical handshake the operator described.
 *
 * NO-ML: a fixed transition relation + exhaustive induction; no statistics.  Hexad: kind_essence.  Ring: R0.
 * K: 1.00.  NIH: self-contained finite-state model checker (the bv_bits-backed lift is the unbounded path).
 */
module numera_ser_kinduct

fn ski_lock(s: u32) -> u32 { return s & 1u32 }
fn ski_p1(s: u32) -> u32 { return (s >> 1u32) & 1u32 }
fn ski_p2(s: u32) -> u32 { return (s >> 2u32) & 1u32 }

/* the transition relation: successor of s under move m (disabled move = stutter).
 * moves: 0 p1-enter, 1 p1-exit, 2 p2-enter, 3 p2-exit, 4 stutter. */
fn ski_succ(s: u32, m: u32) -> u32 @export {
    if m == 0u32 { if ski_lock(s) == 0u32 { return s | 3u32 }  return s }   /* enter: set lock + p1_cs */
    if m == 1u32 { if ski_p1(s) == 1u32 { return s & 4u32 }    return s }   /* exit: clear lock + p1_cs  */
    if m == 2u32 { if ski_lock(s) == 0u32 { return s | 5u32 }  return s }   /* enter: set lock + p2_cs */
    if m == 3u32 { if ski_p2(s) == 1u32 { return s & 2u32 }    return s }   /* exit: clear lock + p2_cs  */
    return s
}

/* the bare temporal intent: ~(p1_cs & p2_cs). */
fn ski_weak(s: u32) -> u32 { if ski_p1(s) == 1u32 { if ski_p2(s) == 1u32 { return 0u32 } }  return 1u32 }
/* the strengthened (inductive) invariant: (lock == p1|p2) & ~(p1&p2). */
fn ski_strong(s: u32) -> u32 {
    if ski_weak(s) == 0u32 { return 0u32 }
    let pv : u32 = ski_p1(s) | ski_p2(s)
    if ski_lock(s) == pv { return 1u32 }
    return 0u32
}
fn ski_inv(s: u32, strong: u32) -> u32 { if strong == 1u32 { return ski_strong(s) }  return ski_weak(s) }

/* BASE: the initial state (0 = lock=0,p1=0,p2=0) satisfies the invariant. */
fn ski_base(strong: u32) -> u32 { return ski_inv(0u32, strong) }

/* INDUCTIVE: every P-state's every successor is a P-state (the miter P(s)&T(s,s')&~P(s') is UNSAT). */
fn ski_inductive(strong: u32) -> u32 @export {
    let mut s : u32 = 0u32
    while s < 8u32 {
        if ski_inv(s, strong) == 1u32 {
            let mut m : u32 = 0u32
            while m < 5u32 {
                if ski_inv(ski_succ(s, m), strong) == 0u32 { return 0u32 }
                m = m + 1u32
            }
        }
        s = s + 1u32
    }
    return 1u32
}

/* the universal verdict: base & inductive => P holds for ALL reachable states, all time (the merge). */
fn ski_universal(strong: u32) -> u32 @export {
    if ski_base(strong) == 0u32 { return 0u32 }
    if ski_inductive(strong) == 0u32 { return 0u32 }
    return 1u32
}

/* independent ground truth: the reachable closure from init; 1 iff every reachable state is mutually-exclusive. */
var SKI_MARK : [u32; 8]
fn ski_reachable_safe() -> u32 @export {
    let mut i : u32 = 0u32
    while i < 8u32 { SKI_MARK[i as u64] = 0u32  i = i + 1u32 }
    SKI_MARK[0u64] = 1u32
    let mut changed : u32 = 1u32
    while changed == 1u32 {
        changed = 0u32
        let mut s : u32 = 0u32
        while s < 8u32 {
            if SKI_MARK[s as u64] == 1u32 {
                let mut m : u32 = 0u32
                while m < 5u32 {
                    let sp : u32 = ski_succ(s, m)
                    if SKI_MARK[sp as u64] == 0u32 { SKI_MARK[sp as u64] = 1u32  changed = 1u32 }
                    m = m + 1u32
                }
            }
            s = s + 1u32
        }
    }
    let mut k : u32 = 0u32
    while k < 8u32 {
        if SKI_MARK[k as u64] == 1u32 { if ski_weak(k) == 0u32 { return 0u32 } }
        k = k + 1u32
    }
    return 1u32
}

/* ====== GENERALIZED k-INDUCTION over ANY FSM registered in ser_fsm (EIDOS Verification Membrane Phase 1.1) ===
 * The mutex above is now ONE instance; ski_*_g verify the CALLER's registered transition system + invariant
 * (numera/ser_fsm), so k-induction is a reusable engine, not a demonstration of one example. */
extern @abi(c-msvc-x64) fn sfsm_reset() -> i32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_set_n(n: u32) -> i32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_add_trans(src: u32, to: u32) -> i32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_set_inv(s: u32, holds: u8) -> i32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_set_init(s: u32, is_init: u8) -> i32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_n() -> u32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_trans_n() -> u32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_trans_from(e: u32) -> u32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_trans_to(e: u32) -> u32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_inv(s: u32) -> u8 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_init(s: u32) -> u8 from "ser_fsm.iii"

/* BASE: every initial state of the registered FSM satisfies the registered invariant. */
fn ski_base_g() -> u32 @export {
    let n : u32 = sfsm_n()
    let mut s : u32 = 0u32
    while s < n {
        if sfsm_init(s) == 1u8 { if sfsm_inv(s) != 1u8 { return 0u32 } }
        s = s + 1u32
    }
    return 1u32
}
/* INDUCTIVE STEP: every transition out of an invariant-state lands in an invariant-state (the UNSAT miter). */
fn ski_inductive_g() -> u32 @export {
    let m : u32 = sfsm_trans_n()
    let mut e : u32 = 0u32
    while e < m {
        let f : u32 = sfsm_trans_from(e)
        if sfsm_inv(f) == 1u8 { if sfsm_inv(sfsm_trans_to(e)) != 1u8 { return 0u32 } }
        e = e + 1u32
    }
    return 1u32
}
fn ski_universal_g() -> u32 @export {
    if ski_base_g() != 1u32 { return 0u32 }
    if ski_inductive_g() != 1u32 { return 0u32 }
    return 1u32
}
/* SUBSUMPTION: register the hardcoded mutex INTO ser_fsm (strong invariant + all edges), so the GENERAL engine
 * reproduces the fixture -- proof the generalization is faithful (ski_universal_g here == ski_universal(1)). */
fn ski_register_mutex() -> i32 @export {
    sfsm_reset()
    sfsm_set_n(8u32)
    let mut s : u32 = 0u32
    while s < 8u32 {
        if ski_strong(s) == 1u32 { sfsm_set_inv(s, 1u8) }
        let mut m : u32 = 0u32
        while m < 5u32 { sfsm_add_trans(s, ski_succ(s, m))  m = m + 1u32 }
        s = s + 1u32
    }
    sfsm_set_init(0u32, 1u8)
    return 0i32
}

/* ============================================================================================================
 * EVENT-DRIVEN k-INDUCTION that CONSUMES the causal epoch partition (ser_causal) -- the real composition.
 * Confluence of N concurrent ripples (does every interleaving reach the same final state?) is a k-induction:
 * base = one ripple is trivially confluent; step = adding ripple N preserves confluence iff it commutes with
 * all of 1..N-1.  caus_collapse IS that induction folded over the event log -> n_epochs==1 iff confluent.  The
 * sieve CONSUMES the partition (it unrolls n_epochs, NOT N! interleavings) AND concretely VERIFIES it (forward
 * vs reverse final state must agree) -- so it can never be a wrapper that trusts a bad certificate. */
extern @abi(c-msvc-x64) fn caus_collapse(n: u32) -> u32 from "ser_causal.iii"
extern @abi(c-msvc-x64) fn caus_final_state(n: u32, reverse: u32) -> u64 from "ser_causal.iii"
extern @abi(c-msvc-x64) fn caus_orderings_to_check(n: u32) -> u64 from "ser_causal.iii"
extern @abi(c-msvc-x64) fn evt_count() -> u32 from "event_substrate.iii"
extern @abi(c-msvc-x64) fn evt_witness(upto: u32) -> u64 from "event_substrate.iii"

/* 1 = the N logged ripples are CONFLUENT (every interleaving reaches the same final state), proven by
 * consuming the causal epoch fold + a concrete forward/reverse witness.  0 = not confluent.  2 = the causal
 * certificate and the concrete states DISAGREE (a bad merge -- the sieve catches it, it never just trusts). */
fn ski_confluent_reduced(n: u32) -> u32 @export {
    let ep : u32 = caus_collapse(n)                  /* CONSUME the causal fold: the epoch partition */
    let fwd : u64 = caus_final_state(n, 0u32)
    let rev : u64 = caus_final_state(n, 1u32)
    if ep == 1u32 {
        if fwd != rev { return 2u32 }                /* certificate says confluent but states differ -> CAUGHT */
        return 1u32
    }
    return 0u32
}
/* the work the reduction saved: the orderings the naive sieve would unroll (n!) collapse to this (1 if confluent). */
fn ski_orderings_reduced(n: u32) -> u64 @export { return caus_orderings_to_check(n) }
/* the witnessed verdict of the reduced sieve (the fold over the ripples + the partition certificate). */
fn ski_reduced_witness() -> u64 @export { return evt_witness(evt_count()) }
