/* STDLIB/iii/numera/ser_petri.iii -- THE CONCRETE-FUZZING MEMBRANE of the DISCOVER-phase petri dish.
 *
 * The petri dish (the DISCOVER phase) is allowed to HALLUCINATE candidate rewrites non-deterministically --
 * but the multi-engine proof sieve (bv_ring + bv_bits + the CIC kernel) is COMPUTATIONALLY HEAVY.  Feeding
 * 10,000 hallucinated candidates straight to the sieve would halt the system.  This module is the cellular
 * MEMBRANE: a CHEAP, deterministic fast-fail filter that kills implausible candidates on CONCRETE integers
 * BEFORE any formal proof is attempted.  Only candidates that match the reference on EVERY probe survive to
 * the sieve.  This is "fuzzing as a filter" -- the architectural piece that makes the dish tractable.
 *
 * IT IS A REFUTER, NOT A PROVER (the honest scope): a single concrete divergence REFUTES a universal
 * identity (sound -- one counterexample kills it); surviving the battery is PLAUSIBLE, never PROVEN.  The
 * proof is still the sieve's job.  So the membrane can only ever ADMIT FEWER candidates to the proof; it
 * cannot make a false rule pass (that is the kernel's wall).
 *
 * NO-ML / determinism-of-method (the hard lock, honored): the membrane LEARNS NOTHING.  It accumulates no
 * cross-run statistics, trains no cost model, reinforces no pathway.  The battery is FIXED source; the
 * sample is SEEDED (egraph_stochastic/egs_next -- same seed => same verdict), the Grace-seed exception.
 * The proposer it gates (numera/mcmc_egraph) is likewise cost-DIRECTED by a FIXED cost landscape, never
 * cost-LEARNED -- "adaptive WITHOUT learning" (EIDOS).  The line: search direction is a function of the
 * CANDIDATE (its deterministic cost / concrete behaviour), never of accumulated success HISTORY.
 *
 * Hexad: kind_sensitivity.  Ring: R0.  K: 0.99.  NIH: composes egraph_stochastic/egs_next only (the seeded
 * RNG -- no island, no reinvented xorshift).  Determinism: integer-only; seeded; no proof-engine externs
 * (THAT is what makes it cheap -- it never touches bv_ring/bv_bits/tc_check).  Compiler-UNREFERENCED -> LIBNATIVE.
 */
module numera_ser_petri

extern @abi(c-msvc-x64) fn egs_next(state: u64) -> u64 from "egraph_stochastic.iii"

/* The candidate EMITTED form over a machine word, mod 2^64 (the shl+OP strength-reduction family + the
 * shift round-trip, the forms the sieve+emitter actually handle):
 *   form 0: x << k            (pure shift; claims x*2^k)
 *   form 1: (x << k) + x      (shladd;     claims x*(2^k+1))
 *   form 2: (x << k) - x      (shl-sub;    claims x*(2^k-1))
 *   form 3: (x << k) >> k     (round-trip; claims x -- FALSE for any x with a bit in the top k positions) */
fn sp_emit(form: u32, k: u32, t: u64) -> u64 @export {
    let kk : u64 = k as u64
    if form == 0u32 { return t << kk }
    if form == 1u32 { return (t << kk) + t }
    if form == 2u32 { return (t << kk) - t }
    if form == 3u32 { return (t << kk) >> kk }
    return 0u64
}

/* The reference RHS: x * v mod 2^64.  v is a RUNTIME word (a parameter), so this is the honest full
 * multiply -- the ground truth the candidate's emitted form must match. */
fn sp_ref(t: u64, v: u64) -> u64 @export { return t * v }

/* The fixed edge battery: small values + the OVERFLOW edges where a wrap-sensitive candidate diverges. */
const SP_NEDGE : u64 = 7u64
var SP_EDGE : [u64; 7]
var SP_INIT : u8 = 0u8
fn sp_init() -> i32 @export {
    if SP_INIT == 1u8 { return 0i32 }
    SP_EDGE[0u64] = 0u64
    SP_EDGE[1u64] = 1u64
    SP_EDGE[2u64] = 2u64
    SP_EDGE[3u64] = 3u64
    SP_EDGE[4u64] = 2305843009213693952u64    /* 2^61 */
    SP_EDGE[5u64] = 9223372036854775808u64    /* 2^63 -- the high-bit overflow edge */
    SP_EDGE[6u64] = 18446744073709551615u64   /* 2^64 - 1 */
    SP_INIT = 1u8
    return 0i32
}

/* THE MEMBRANE: 1 = PLAUSIBLE (emitted == reference on the WHOLE battery AND a seeded sample of nsample
 * values), 0 = DEAD (refuted at the first divergence -- cheap, no proof engine touched).  The candidate
 * claims  sp_emit(form,k,x) == x*v  for all x; the membrane tries to refute it concretely. */
fn sp_membrane(form: u32, k: u32, v: u64, seed: u64, nsample: u32) -> u32 @export {
    sp_init()
    let mut i : u64 = 0u64
    while i < SP_NEDGE {
        if sp_emit(form, k, SP_EDGE[i]) != sp_ref(SP_EDGE[i], v) { return 0u32 }
        i = i + 1u64
    }
    let mut s : u64 = seed
    let mut j : u32 = 0u32
    while j < nsample {
        s = egs_next(s)
        if sp_emit(form, k, s) != sp_ref(s, v) { return 0u32 }
        j = j + 1u32
    }
    return 1u32
}

/* A DELIBERATELY-WEAK membrane that probes ONLY small values (0..3) -- no overflow edges, no sample.  Its
 * sole purpose is to demonstrate (in the KAT) that the overflow vectors are LOAD-BEARING: a candidate
 * wrong ONLY in the high bits slips THIS but is killed by the full sp_membrane.  Never used in production. */
fn sp_membrane_smallonly(form: u32, k: u32, v: u64) -> u32 @export {
    let mut t : u64 = 0u64
    while t <= 3u64 {
        if sp_emit(form, k, t) != sp_ref(t, v) { return 0u32 }
        t = t + 1u64
    }
    return 1u32
}

/* battery accessors -- so the CEGIS oracle (numera/ser_cegis) composes the SAME fixed probe set (no island,
 * no duplicated battery): the membrane OWNS the edge vectors; the synthesizer borrows them. */
fn sp_edge_n() -> u64 @export { return SP_NEDGE }
fn sp_edge_at(i: u64) -> u64 @export { sp_init() if i >= SP_NEDGE { return 0u64 } return SP_EDGE[i] }

/* ============================================================================================================
 * GENERAL TRANSITION-SYSTEM FUZZING (the boundless-k-induction FRONT END).  sp_membrane above refutes a single
 * rewrite candidate; THIS is the general organ: it walks an ARBITRARY transition T (a bv_bits circuit over the
 * symbolic state) from a concrete init, recording every reached state as an OBSERVATION for ser_antiunify --
 * the finite empirical trace the generalizer abstracts into a candidate invariant, which ser_kinduct_sym then
 * proves over ALL 2^64.  "Fuzzing as the eyes of the synthesizer."  REFUTER -> OBSERVER: a finite trace can
 * never PROVE an infinite law -- it is the raw evidence the deterministic generalization folds.
 *
 * NO-ML: sp_fuzz_det is a concrete deterministic walk (same (T,init,nsteps) => same trace); sp_fuzz_seeded is
 * a SEEDED walk (egs_next -- the Grace-seed exception) for input-driven systems (same seed => same trace).  No
 * statistics, no learned policy -- exploration is a function of the SEED, never of accumulated success history. */
extern @abi(c-msvc-x64) fn bb_set_input(v: u32, val: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_eval(t: u32) -> u64 from "bv_bits.iii"

/* THE OBSERVATION TRACE BUFFER -- owned by the fuzzer (the PRODUCER).  Each fuzzed state is recorded here for
 * ser_antiunify to generalize.  Owning it here (not in the consumer) keeps the module graph ACYCLIC: the
 * generalizer READS the trace (ser_antiunify -> ser_petri); the fuzzer never depends on the generalizer. */
const SP_OCAP : u64 = 256u64
var SP_OBS : [u64; 256]
var SP_ON : u32 = 0u32
fn sp_obs_reset() -> i32 @export { SP_ON = 0u32  return 0i32 }
fn sp_obs_push(v: u64) -> i32 @export {
    if (SP_ON as u64) < SP_OCAP { SP_OBS[SP_ON as u64] = v  SP_ON = SP_ON + 1u32 }
    return 0i32
}
fn sp_obs_count() -> u32 @export { return SP_ON }
fn sp_obs_at(i: u32) -> u64 @export { if (i as u64) < SP_OCAP { return SP_OBS[i as u64] }  return 0u64 }

/* DETERMINISTIC FUZZ: walk T (a bv_bits circuit over statevar) from init for nsteps, recording each reached
 * state as an observation (s_{n+1} = T(s_n), evaluated concretely).  Returns the number of observations. */
fn sp_fuzz_det(t_root: u32, statevar: u32, init: u64, nsteps: u32) -> u32 @export {
    sp_obs_reset()
    let mut s : u64 = init
    let mut i : u32 = 0u32
    while i < nsteps {
        sp_obs_push(s)
        bb_set_input(statevar, s)
        s = bb_eval(t_root)
        i = i + 1u32
    }
    return sp_obs_count()
}

/* SEEDED FUZZ for input-driven systems: T is a circuit over (statevar, inputvar); each step draws a fresh
 * seeded input and steps s' = T(s, input), exploring a deterministic-by-seed reachable subset.  Returns the
 * number of observations.  Same seed => same trace (the Grace-seed exception -- a seeded RNG, not learning). */
fn sp_fuzz_seeded(t_root: u32, statevar: u32, inputvar: u32, init: u64, nsteps: u32, seed: u64) -> u32 @export {
    sp_obs_reset()
    let mut s   : u64 = init
    let mut rng : u64 = seed
    let mut i : u32 = 0u32
    while i < nsteps {
        sp_obs_push(s)
        rng = egs_next(rng)
        bb_set_input(statevar, s)
        bb_set_input(inputvar, rng)
        s = bb_eval(t_root)
        i = i + 1u32
    }
    return sp_obs_count()
}

/* ============================================================================================================
 * MULTI-COMPONENT OBSERVATION (the RELATIONAL front end).  sp_fuzz_det records ONE state variable's reached
 * values; a CONSERVATION invariant -- a quantity held CONSTANT across a COUPLED transition (the sound image of
 * "the fractional charges sum to exactly zero") -- is a RELATION between TWO components, so the generalizer
 * (ser_antiunify's relational lgg) needs BOTH streams.  This adds a parallel y-stream SHARING the obs count,
 * and a JOINT deterministic fuzz that walks (x,y) under coupled circuits (tx,ty) over (xvar,yvar) with a
 * SIMULTANEOUS update: BOTH successors are evaluated from the CURRENT pair before EITHER is assigned, so a
 * truly coupled system (x'=x+y, ...) is observed faithfully.  Same (tx,ty,x0,y0,nsteps) => same trace
 * (deterministic; no learning -- exploration is a function of the inputs, never of accumulated history). */
var SP_OBS_Y : [u64; 256]
fn sp_obs2_reset() -> i32 @export { SP_ON = 0u32  return 0i32 }
fn sp_obs2_push(vx: u64, vy: u64) -> i32 @export {
    if (SP_ON as u64) < SP_OCAP { SP_OBS[SP_ON as u64] = vx  SP_OBS_Y[SP_ON as u64] = vy  SP_ON = SP_ON + 1u32 }
    return 0i32
}
fn sp_obs_y_at(i: u32) -> u64 @export { if (i as u64) < SP_OCAP { return SP_OBS_Y[i as u64] }  return 0u64 }

/* DETERMINISTIC JOINT FUZZ: walk the coupled transition (tx,ty) -- each a bv_bits circuit over BOTH statevars --
 * from (x0,y0) for nsteps, recording each reached (x,y) pair.  Simultaneous: evaluate xn,yn from the current
 * (x,y) before assigning, so the step is s_{n+1} = T(s_n), not a sequential half-update.  Returns the count. */
fn sp_fuzz_det2(tx_root: u32, ty_root: u32, xvar: u32, yvar: u32, x0: u64, y0: u64, nsteps: u32) -> u32 @export {
    sp_obs2_reset()
    let mut x : u64 = x0
    let mut y : u64 = y0
    let mut i : u32 = 0u32
    while i < nsteps {
        sp_obs2_push(x, y)
        bb_set_input(xvar, x)
        bb_set_input(yvar, y)
        let xn : u64 = bb_eval(tx_root)
        let yn : u64 = bb_eval(ty_root)
        x = xn
        y = yn
        i = i + 1u32
    }
    return sp_obs_count()
}
