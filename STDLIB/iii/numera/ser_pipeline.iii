/* STDLIB/iii/numera/ser_pipeline.iii -- THE FULL SERAPHYTE PIPELINE: every organ load-bearing in ONE real fold.
 *
 * The cluster was 13 islands.  This is the production fold the reseal DRIVER consumes to make its real
 * self-modification decision -- so each organ GATES that decision (remove one and the verdict changes):
 *
 *   INTUITION (ser_cegis)  : the compiler SYNTHESIZES the descriptor {form,k} for a target factor -- it decides
 *                            WHAT to optimise (closing the human-picked-"subk" seam).  No human, no learning.
 *   INTENT    (ser_intent) : the contract x*v is a target e-class; ONLY a symbolic proof triggers the MERGE;
 *                            extraction yields the cheapest provably-correct implementation.
 *   PROVE     (cg_autocatalyst): the real CIC-kernel membrane admits the (k,k) identity (a proof, not a stub).
 *   COLLAPSE  (ser_cascade/cascade2/regalloc): ONE proof collapses an UNRELATED site (non-local); a deeper
 *                            multi-pass fixpoint folds the chain to DRY (behaviour-preserving); the freed
 *                            register eliminates a required spill.
 *   ALIGN     (ser_tdriver): the rewrite's temporal choreography is provably SAFE + LIVE (k-induction sieve +
 *                            causal-collapse + the LTL liveness membrane), unattended.
 *   WITNESS   (ser_eidos)  : every gate green -> the ACCEPT is field_record'd on the real eidos/field with a
 *                            content-addressed witness; a failing gate -> field_rewind (provenance retained).
 *
 * NIH: composes the existing organs only -- authors no proof, no optimisation, no crypto.  Ring R0.  K 1.00.
 * Determinism: integer; CEGIS is seeded (Grace-seed), the proofs are deductive.  CONSUMED BY the reseal driver.
 */
module numera_ser_pipeline

/* INTUITION -- the descriptor synthesizer (CEGIS): the compiler decides WHAT to optimise. */
extern @abi(c-msvc-x64) fn cg_synth(v: u64, seed: u64) -> u32 from "ser_cegis.iii"
extern @abi(c-msvc-x64) fn cg_form(packed: u32) -> u32 from "ser_cegis.iii"
extern @abi(c-msvc-x64) fn cg_k(packed: u32) -> u32 from "ser_cegis.iii"
extern @abi(c-msvc-x64) fn cg_cost(packed: u32) -> u32 from "ser_cegis.iii"

/* INTENT -- the e-class merges only on proof. */
extern @abi(c-msvc-x64) fn in_declare(v: u64) -> u64 from "ser_intent.iii"
extern @abi(c-msvc-x64) fn in_propose_shlsub(handle: u64, k: u64) -> u32 from "ser_intent.iii"
extern @abi(c-msvc-x64) fn in_resolve(handle: u64) -> u32 from "ser_intent.iii"

/* COLLAPSE -- non-local cascade + deeper fixpoint DCE + register reallocation. */
extern @abi(c-msvc-x64) fn casc_register_subk(seed: u64) -> u8 from "ser_cascade.iii"
extern @abi(c-msvc-x64) fn casc_site_covered(v: u64) -> u32 from "ser_cascade.iii"
extern @abi(c-msvc-x64) fn casc_cost(v: u64) -> u32 from "ser_cascade.iii"
extern @abi(c-msvc-x64) fn cf_reset() -> i32 from "ser_cascade2.iii"
extern @abi(c-msvc-x64) fn cf_push(kind: u32, arg: u64) -> i32 from "ser_cascade2.iii"
extern @abi(c-msvc-x64) fn cf_cost() -> u32 from "ser_cascade2.iii"
extern @abi(c-msvc-x64) fn cf_eval(x: u64) -> u64 from "ser_cascade2.iii"
extern @abi(c-msvc-x64) fn cf_cascade() -> u32 from "ser_cascade2.iii"
extern @abi(c-msvc-x64) fn sra_reset() -> i32 from "ser_regalloc.iii"
extern @abi(c-msvc-x64) fn sra_push(start: u64, end: u64) -> i32 from "ser_regalloc.iii"
extern @abi(c-msvc-x64) fn sra_kill(i: u32) -> i32 from "ser_regalloc.iii"
extern @abi(c-msvc-x64) fn sra_spills(k: u32) -> u32 from "ser_regalloc.iii"

/* ALIGN -- the temporal choreography is provably safe + live. */
extern @abi(c-msvc-x64) fn tdrv_compile() -> u8 from "ser_tdriver.iii"

/* WITNESS -- the eidos/field accept/rollback. */
extern @abi(c-msvc-x64) fn sev_begin() -> i32 from "ser_eidos.iii"
extern @abi(c-msvc-x64) fn sev_reseal_record(verdict: u64, rule_id: u64) -> u64 from "ser_eidos.iii"
extern @abi(c-msvc-x64) fn sev_frontier() -> u32 from "ser_eidos.iii"
extern @abi(c-msvc-x64) fn sev_provenance() -> u32 from "ser_eidos.iii"

/* PROVE -- the real CIC-kernel autocatalyst membrane. */
extern @abi(c-msvc-x64) fn cga_dispose(a: u32, b: u32, budget: u32) -> u8 from "cg_autocatalyst.iii"

const SVP_SEED : u64 = 11400714819323198485u64
const SVP_SUBK : u32 = 2u32    /* the cg_synth form code for shift-sub (2^k-1) */
const SVP_GATE : u64 = 99u64

/* INTUITION: synthesize the descriptor for factor v (the compiler decides WHAT).  Returns packed {form,k,cost}. */
fn svp_descriptor(v: u64) -> u32 @export { return cg_synth(v, SVP_SEED) }
fn svp_form(packed: u32) -> u32 @export { return cg_form(packed) }
fn svp_k(packed: u32) -> u32 @export { return cg_k(packed) }
fn svp_cost(packed: u32) -> u32 @export { return cg_cost(packed) }

/* INTENT: the contract x*v is fulfilled only by a proof (the e-class merge at cost 2).  1 = fulfilled. */
fn svp_intent_fulfilled(v: u64, k: u64) -> u8 @export {
    let h: u64 = in_declare(v)
    if in_propose_shlsub(h, k) != 1u32 { return 0u8 }    /* the proof must merge the e-classes */
    if in_resolve(h) != 2u32 { return 0u8 }              /* extraction now picks the cheap shift-sub */
    return 1u8
}

/* COLLAPSE 1 (non-local): the proven family collapses an UNRELATED site v, no re-proof.  1 = covered, cost 2. */
fn svp_cascade_covers(v: u64) -> u8 @export {
    casc_register_subk(SVP_SEED)
    if casc_site_covered(v) != 1u32 { return 0u8 }
    if casc_cost(v) != 2u32 { return 0u8 }
    return 1u8
}

/* COLLAPSE 2 (deeper fixpoint+DCE): x*v + 0, *1 collapses to cost 2, behaviour preserved.  1 = collapsed. */
fn svp_fixpoint_dce(v: u64) -> u8 @export {
    casc_register_subk(SVP_SEED)
    cf_reset()
    cf_push(1u32, v)        /* MUL v */
    cf_push(2u32, 0u64)     /* ADD 0 */
    cf_push(1u32, 1u64)     /* MUL 1 */
    let before: u64 = cf_eval(2u64)
    let steps: u32 = cf_cascade()
    if steps == 0u32 { return 0u8 }       /* it actually rewrote */
    if cf_cost() != 2u32 { return 0u8 }   /* 7 -> 2 through the dependent chain */
    if cf_eval(2u64) != before { return 0u8 }   /* behaviour preserved */
    return 1u8
}

/* COLLAPSE 3 (regalloc): the cascade's DCE frees a register -> a required spill is eliminated.  1 = spill gone. */
fn svp_regalloc_frees() -> u8 @export {
    sra_reset()
    sra_push(0u64, 5u64)
    sra_push(1u64, 5u64)
    sra_push(2u64, 5u64)
    if sra_spills(2u32) != 1u32 { return 0u8 }   /* before: a spill at K=2 */
    sra_kill(2u32)                               /* DCE kills the dead value */
    if sra_spills(2u32) != 0u32 { return 0u8 }   /* after: the spill is eliminated */
    return 1u8
}

/* ALIGN: the rewrite's temporal choreography is provably safe + live (k-induction + causal + liveness). */
fn svp_aligned() -> u8 @export { return tdrv_compile() }

/* ABSTRACT PRE-DECIDE (ser_absint -- the Astrée O(1) abstract, no solver): the shift-linear abstract decides
 * x*v's shift-sub form VALID and the wrong (shladd) form REFUTED in closed form, BEFORE the kernel proof --
 * the prune that keeps the solver viable.  1 = the O(1) verdicts hold (and agree with the kernel). */
extern @abi(c-msvc-x64) fn ai_decide(kind: u32, j: u32, m: u32, v: u64) -> u32 from "ser_absint.iii"
fn svp_absint_predecide(k: u32, v: u64) -> u8 @export {
    if ai_decide(4u32, k, 0u32, v) != 1u32 { return 0u8 }   /* (x<<k)-x == v*x  : O(1) VALID   */
    if ai_decide(3u32, k, 0u32, v) != 0u32 { return 0u8 }   /* (x<<k)+x (=2^k+1, wrong) : O(1) REFUTED */
    return 1u8
}

/* SYMBOLIC k-INDUCTION (ser_kinduct_sym -- complements tdrv's concrete k-induction in ALIGN): a symbolic
 * invariant -- x+2 preserves evenness (proven), x+1 breaks it (refuted).  1 = both hold. */
extern @abi(c-msvc-x64) fn sks_pres_even(inc: u64) -> u8 from "ser_kinduct_sym.iii"
fn svp_kinduct_sym() -> u8 @export {
    if sks_pres_even(2u64) != 1u8 { return 0u8 }
    if sks_pres_even(1u64) != 0u8 { return 0u8 }
    return 1u8
}

/* CONSERVATION (the RELATIONAL invariant -- ser_petri fuzz -> ser_antiunify generalize -> ser_kinduct_sym prove,
 * the full loop on a class the single-scalar templates cannot express).  A COUPLED counter x'=x+1, y'=y-1
 * conserves x+y; the relational lgg DISCOVERS the kernel from the fuzzed pairs and BOTH prover engines (closed
 * form + 2-var bit-blast) certify it over all 2^128, while a non-conserving candidate is REFUSED.  1 = the true
 * law is proven by both engines AND the false one refused -- the sound, in-domain image of "the charges sum to
 * zero".  STRUCTURALLY gated in svp_autopoietic_wave (remove it and the wave's verdict changes); the wave
 * binary is un-runnable here (pre-existing ~1.25GB BSS), so its RUNTIME load-bearingness is UNVERIFIED --
 * the conservation ENGINE itself is runtime-proven (corpus 2073=99), the wave wiring is structural. */
extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_add(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_sub(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn sp_fuzz_det2(tx: u32, ty: u32, xv: u32, yv: u32, x0: u64, y0: u64, n: u32) -> u32 from "ser_petri.iii"
extern @abi(c-msvc-x64) fn au_consv_found() -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_consv_w0() -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_consv_w1() -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_consv_c() -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn sks_consv_prove(w0: u64, w1: u64, c: u64, a: u64, b: u64, x0: u64, y0: u64) -> u8 from "ser_kinduct_sym.iii"
extern @abi(c-msvc-x64) fn sks_consv_step_sym(w0: u64, w1: u64, a: u64, b: u64) -> u8 from "ser_kinduct_sym.iii"
fn svp_conservation() -> u8 @export {
    let bneg1 : u64 = 0u64 - 1u64
    let bneg2 : u64 = 0u64 - 2u64
    /* FUZZ the coupled counter x'=x+1, y'=y-1 from (5,5) -> observe (x,y) pairs (x+y == 10 conserved). */
    bb_reset(64u64)
    let xv : u32 = bb_var(0u32)
    let yv : u32 = bb_var(1u32)
    let tx : u32 = bb_add(xv, bb_const(1u64))
    let ty : u32 = bb_sub(yv, bb_const(1u64))
    if sp_fuzz_det2(tx, ty, 0u32, 1u32, 5u64, 5u64, 12u32) != 12u32 { return 0u8 }
    /* GENERALIZE: the relational lgg fits a linear conservation law to every observed pair. */
    if au_consv_found() != 1u32 { return 0u8 }
    let w0 : u64 = au_consv_w0()
    let w1 : u64 = au_consv_w1()
    let c  : u64 = au_consv_c()
    /* PROVE: the DISCOVERED kernel is conserved over ALL 2^128 under (a,b)=(+1,-1). */
    if sks_consv_prove(w0, w1, c, 1u64, bneg1, 5u64, 5u64) != 1u8 { return 0u8 }
    /* CROSS-CHECK + CONSCIENCE: the clean (1,1) sum is conserved under (+1,-1) [independent bit-blast engine],
     * and the same candidate under (+1,-2) is REFUSED -- two engines, two verdicts. */
    if sks_consv_step_sym(1u64, 1u64, 1u64, bneg1) != 1u8 { return 0u8 }
    if sks_consv_step_sym(1u64, 1u64, 1u64, bneg2) != 0u8 { return 0u8 }
    return 1u8
}

/* ============================================================================================================
 * CAPACITY-CONSERVATION SEAL (the relational invariant, applied to MEMORY -- conservation wired into the EXISTING
 * separation-algebra membrane).  An allocator partitions `cap` cells into a FREE heaplet and a USED heaplet.  The
 * seal composes THREE existing organs, none authored here:
 *   QUANTITATIVE (conservation): hl_size(free)+hl_size(used)==cap, and the alloc/free transition PROVEN to
 *                                conserve the sum over all 2^128 (sks_consv_step) -- the count bookkeeping never
 *                                drifts (catches an UNCOMPENSATED leak/double-count -- count DRIFT; NOT a
 *                                count-preserving identity swap, which is the disjointness half's job).
 *   SPATIAL-DISJOINT (heaplet) : hl_disjoint(free,used)==1 -- no cell is BOTH free and used.
 *   SPATIAL-FRAME (sep_logic)  : sl_frame_holds(STORE into a used cell over (used,free))==1 -- allocating a used
 *                                cell provably leaves the FREE region byte-identical (the frame rule).
 * SCOPE (locked): proves bookkeeping consistency + separation, NOT temporal use-after-free -- COMPLEMENTARY to an
 * aliasing borrow-checker, discovered+proven with zero annotations, never a replacement. */
extern @abi(c-msvc-x64) fn hl_init() -> i32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_empty() -> u32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_set(h: u32, a: u32, v: u32) -> i32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_disjoint(h1: u32, h2: u32) -> u32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn hl_size(h: u32) -> u32 from "heaplet.iii"
extern @abi(c-msvc-x64) fn sl_frame_holds(kind: u32, a: u32, v: u32, b: u32, hP: u32, hR: u32) -> u32 from "sep_logic.iii"
extern @abi(c-msvc-x64) fn sks_consv_step(w0: u64, w1: u64, a: u64, b: u64) -> u8 from "ser_kinduct_sym.iii"

fn svp_mem_build(mask: u64) -> u32 {            /* a heaplet over exactly the cells set in `mask` (0..63) */
    let h : u32 = hl_empty()
    let mut a : u32 = 0u32
    while a < 64u32 {
        if (mask & (1u64 << (a as u64))) != 0u64 { hl_set(h, a, 1u32) }
        a = a + 1u32
    }
    return h
}
/* the CONCRETE-STATE seal: 1 iff (free,used) over `cap` cells is conservatively sealed RIGHT NOW.  `used_cell`
 * must be a cell in `used` (the frame demonstration: storing it leaves `free` byte-identical). */
fn svp_mem_state_sealed(free_mask: u64, used_mask: u64, cap: u32, used_cell: u32) -> u8 @export {
    hl_init()
    let free_h : u32 = svp_mem_build(free_mask)
    let used_h : u32 = svp_mem_build(used_mask)
    if hl_disjoint(free_h, used_h) != 1u32 { return 0u8 }                  /* SPATIAL: no double-owned cell */
    let nf : u32 = hl_size(free_h)
    let nu : u32 = hl_size(used_h)
    if (nf + nu) != cap { return 0u8 }                                     /* QUANTITATIVE: capacity accounted */
    if sl_frame_holds(0u32, used_cell, 200u32, 0u32, used_h, free_h) != 1u32 { return 0u8 }  /* FRAME: write framed off free */
    return 1u8
}
/* THE SEAL (wave gate): the ABSTRACT laws (alloc/free conserve capacity over all 2^128; a leak is REFUSED) tied
 * to a CONCRETE heap whose real free->used move keeps the sizes summing to cap; overlap and leak FAIL the seal. */
fn svp_mem_seal() -> u8 @export {
    let bneg1 : u64 = 0u64 - 1u64
    /* ABSTRACT: alloc (free-1,used+1) and free (free+1,used-1) conserve free+used; a LEAK (free-1,used+0) drifts. */
    if sks_consv_step(1u64, 1u64, bneg1, 1u64) != 1u8 { return 0u8 }
    if sks_consv_step(1u64, 1u64, 1u64, bneg1) != 1u8 { return 0u8 }
    if sks_consv_step(1u64, 1u64, bneg1, 0u64) != 0u8 { return 0u8 }       /* LEAK refused (drift = -1) */
    /* CONCRETE TIE: free={0,1,2,3}, used={4,5,6,7}, cap=8 -> sealed.  Move cell 3 free->used -> STILL sealed
     * (sizes still sum to 8 -- the real heaplet move MATCHES the conserved prediction). */
    if svp_mem_state_sealed(0x0Fu64, 0xF0u64, 8u32, 4u32) != 1u8 { return 0u8 }
    if svp_mem_state_sealed(0x07u64, 0xF8u64, 8u32, 3u32) != 1u8 { return 0u8 }   /* after moving cell 3 free->used */
    /* CONSCIENCE: overlap (cell 3 in BOTH) -> not disjoint -> seal FAILS; size-mismatch (sum 6 != 8) -> FAILS. */
    if svp_mem_state_sealed(0x0Fu64, 0xF8u64, 8u32, 3u32) != 0u8 { return 0u8 }   /* cell 3 in both -> overlap */
    if svp_mem_state_sealed(0x07u64, 0x70u64, 8u32, 4u32) != 0u8 { return 0u8 }   /* sizes 3+3=6 != 8 -> leak */
    return 1u8
}

/* THE FULL PIPELINE for a real family factor v: intuition -> prove -> intent -> collapse x3 -> align ->
 * witness(eidos ACCEPT).  Returns 99 iff EVERY organ's real output succeeds.  The eidos frontier commits only
 * when all gates are green -- so each organ is load-bearing in the accept decision. */
fn svp_pipeline(v: u64) -> u64 @export {
    /* INTUITION: the compiler synthesizes the descriptor (no human picks "subk"). */
    let d: u32 = svp_descriptor(v)
    if svp_form(d) != SVP_SUBK { return 1u64 }          /* must be shift-sub for a 2^k-1 factor */
    if svp_cost(d) != 2u32 { return 2u64 }              /* a real shift-sub (cheaper than imul) */
    let k: u32 = svp_k(d)
    /* PROVE: the real CIC-kernel admits the (k,k) identity. */
    let mut verdict: u64 = 0u64
    if cga_dispose(k, k, 64u32) == 1u8 { verdict = SVP_GATE }
    if verdict != SVP_GATE { return 3u64 }
    /* ABSTRACT (ser_absint, Astrée O(1), no solver): pre-decide the shift-sub VALID before the heavy work. */
    if svp_absint_predecide(k, v) != 1u8 { return 11u64 }
    /* INTENT: the contract is fulfilled by the proof (the e-class merge). */
    if svp_intent_fulfilled(v, k as u64) != 1u8 { return 4u64 }
    /* COLLAPSE: non-local cascade, deeper fixpoint+DCE, regalloc spill elimination. */
    if svp_cascade_covers(v) != 1u8 { return 5u64 }
    if svp_fixpoint_dce(v) != 1u8 { return 6u64 }
    if svp_regalloc_frees() != 1u8 { return 7u64 }
    /* ALIGN: temporal safe + live. */
    if svp_aligned() != 1u8 { return 8u64 }
    /* SYMBOLIC k-induction (ser_kinduct_sym -- complements the concrete ALIGN above). */
    if svp_kinduct_sym() != 1u8 { return 12u64 }
    /* WITNESS: reset the field clean (the align/collapse organs share the event_substrate), then record the
     * ACCEPT in isolation so the committed frontier reflects exactly this pipeline's decision. */
    sev_begin()
    if sev_reseal_record(verdict, v) != 1u64 { return 9u64 }
    if sev_frontier() != 1u32 { return 10u64 }
    return 99u64
}

/* THE NEGATIVE: a non-family factor (no cheaper rewrite) -- intuition synthesizes NO shift-sub -> the pipeline
 * REJECTS and the eidos witness ROLLS BACK (provenance retained).  1 = correctly rejected + rolled back. */
fn svp_pipeline_rejects(v: u64) -> u8 @export {
    sev_begin()
    let d: u32 = svp_descriptor(v)
    if svp_cost(d) != 3u32 { return 0u8 }       /* a non-member must have NO cheaper rewrite (imul, cost 3) */
    sev_reseal_record(0u64, v)                  /* verdict 0 -> field_rewind */
    if sev_provenance() == 0u32 { return 0u8 }  /* the refused rule retained as provenance */
    return 1u8
}

/* UNIT PROOF: the full pipeline ACCEPTS the real family factor 7 (every organ green) and REJECTS the
 * non-member 11 (no cheaper rewrite, rolled back).  99 = both -- every organ load-bearing in one fold. */
fn svp_selftest() -> u64 @export {
    if svp_pipeline(7u64) != 99u64 { return 1u64 }
    if svp_pipeline_rejects(11u64) != 1u8 { return 2u64 }
    return 99u64
}

/* === FIRST WAVE (corpus 2004-2015): the autonomous DISCOVER -> PROVE -> COMMIT loop + the proving
 * infrastructure (immune vaccine / memoised proving / cross-prover diff / isub witnessed bus) + the
 * autopoietic ECONOMY (kvalue ledger / energy / reality / membrane / the living loop).  Wired HERE so the
 * reseal driver's consumer DEPENDS on every one -- the APPLY half (this pipeline) gating on the DISCOVER/
 * COMMIT half.  Remove any organ and svp_autopoietic_wave changes => each is load-bearing, not archived. === */
extern @abi(c-msvc-x64) fn sd_selftest() -> u64 from "ser_discover.iii"
extern @abi(c-msvc-x64) fn so_selftest() -> u64 from "ser_optimize.iii"
extern @abi(c-msvc-x64) fn sc_selftest() -> u64 from "ser_commit.iii"
extern @abi(c-msvc-x64) fn im_selftest() -> u64 from "ser_immune.iii"
extern @abi(c-msvc-x64) fn smemo_selftest() -> u64 from "ser_memo.iii"
extern @abi(c-msvc-x64) fn sdiff_selftest() -> u64 from "ser_diff.iii"
extern @abi(c-msvc-x64) fn si_selftest() -> u64 from "ser_isub.iii"
extern @abi(c-msvc-x64) fn sk_selftest() -> u64 from "ser_kvalue.iii"
extern @abi(c-msvc-x64) fn se_selftest() -> u64 from "ser_energy.iii"
extern @abi(c-msvc-x64) fn sr_selftest() -> u64 from "ser_real.iii"
extern @abi(c-msvc-x64) fn sm_selftest() -> u64 from "ser_membrane.iii"
extern @abi(c-msvc-x64) fn sa_selftest() -> u64 from "ser_autopoiesis.iii"

/* THE AUTOPOIETIC WAVE: the first-wave loop, made load-bearing in the reseal consumer.  99 = every first-wave
 * organ discharges (discover/optimize/commit + immune/memo/diff/isub + kvalue/energy/real/membrane/autopoiesis). */
fn svp_autopoietic_wave() -> u64 @export {
    if sd_selftest() != 99u64 { return 1u64 }     /* DISCOVER: seeded search, kernel proof, cg_opt_rules match */
    if so_selftest() != 99u64 { return 2u64 }     /* OPTIMIZE: SAT-prove the mixed/shift laws cg_r3 lacks */
    if sc_selftest() != 99u64 { return 3u64 }     /* COMMIT: seal kernel-proven, refuse the false */
    if im_selftest() != 99u64 { return 4u64 }     /* IMMUNE: proven-bad becomes a vaccine (never retried) */
    if smemo_selftest() != 99u64 { return 5u64 }  /* MEMO: never prove twice (the witnessed-substrate saving) */
    if sdiff_selftest() != 99u64 { return 6u64 }  /* DIFF: bv_ring vs bv_bits cross-prover soundness monitor */
    if si_selftest() != 99u64 { return 7u64 }     /* ISUB: the Seraphyte as a witnessed, foldable process */
    if sk_selftest() != 99u64 { return 8u64 }     /* KVALUE: the K-value ledger */
    if se_selftest() != 99u64 { return 9u64 }     /* ENERGY: catabolism returns positive energy */
    if sr_selftest() != 99u64 { return 10u64 }    /* REAL: the membrane-observed reality substrate */
    if sm_selftest() != 99u64 { return 11u64 }    /* MEMBRANE: the unified admission boundary */
    if sa_selftest() != 99u64 { return 12u64 }    /* AUTOPOIESIS: the living loop (K-ratchet, immortality) */
    if svp_conservation() != 1u8 { return 13u64 } /* CONSERVATION: the relational invariant, fuzz->generalize->prove (two engines) */
    if svp_mem_seal() != 1u8 { return 14u64 }     /* MEMORY SEAL: capacity conservation + separation (heaplet/sep_logic), leak/overlap refused */
    return 99u64
}
