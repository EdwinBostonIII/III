/* STDLIB/iii/numera/ser_real.iii -- THE SERAPHYTE ON A REAL III TARGET (Phase-4 liveness, no synthetic).
 *
 * The earlier organs (ser_kvalue/membrane/autopoiesis) proved the loop LOGIC over a synthetic 3-node
 * fixture.  This organ runs the SAME loop on III's REAL structure: the six-state-typed proof-web of III's
 * actual crypto primitives (numera/weave_graph -- SHA-2 Ch/Maj, the ChaCha/SHA rotations as bv circuits).
 * Every check here is a REAL fact, not a model:
 *
 *   - The MEMBRANE is LIVE: sr_membrane admits a circuit replacement iff ws_edge_proven == TRUE, i.e. the
 *     two circuits are SAT-PROVEN EQUIVALENT at the crypto width (bb_equal over the real bitvector circuits)
 *     -- a real behaviour-preservation proof, not a hardcoded input.  It REFUSES a non-equivalent swap.
 *   - The K-GAIN is the real COST-TRUTH: ws_node_cost_at is the actual AND-gate count of the circuit; the
 *     SHA-2 Ch optform (1 AND) is cheaper than the spec mux (2 ANDs), so adopting the proven-equivalent
 *     cheaper form RAISES the structure's efficiency (lowers waste) -- the spec's KLIMAX ascent, real.
 *   - The MOVE is a real OBSOLESCENCE: ws_strand_retires == proven-equivalent AND different-cost, so the
 *     costlier form is retired WITHOUT changing behaviour -- the weave's actual cost-truth optimisation.
 *
 * So the organism optimises a real III primitive: it retires the SHA-2 Ch spec mux in favour of the
 * proven-equal optform, and refuses to "replace" Ch with Maj (proven DISTINCT).  Real target, real proof,
 * real cost reduction, both arms.
 *
 * Hexad: kind_act (the optimising act on real structure).  Ring: R0.  K: 1.00.  NIH: composes
 * numera/weave_graph only (which is the typed index OF primweb's SAT universe -- bv_bits + primweb, all
 * in-tree).  Determinism: integer ==/!= and UNSIGNED < ; no allocator of its own (weave uses bb's).
 * Compiler-UNREFERENCED -> LIBNATIVE.  See DOCS/III-SERAPHYTE-INTEGRATION-PLAN.md (Part III liveness).
 */
module numera_ser_real

extern @abi(c-msvc-x64) fn ws_edge_proven(i: u32, j: u32) -> u32 from "weave_graph.iii"
extern @abi(c-msvc-x64) fn ws_node_cost_at(idx: u32) -> u64 from "weave_graph.iii"
extern @abi(c-msvc-x64) fn ws_strand_cheaper(i: u32, j: u32) -> u32 from "weave_graph.iii"
extern @abi(c-msvc-x64) fn ws_strand_retires(i: u32, j: u32) -> u8 from "weave_graph.iii"
extern @abi(c-msvc-x64) fn ws_strand_agrees_primweb() -> u8 from "weave_graph.iii"
extern @abi(c-msvc-x64) fn ws_weave_universal_count() -> u32 from "weave_graph.iii"

const SR_WG_TRUE  : u32 = 1u32    /* weave_graph WG_TRUE -- proven-equivalent at crypto width */
const SR_ADMIT    : u32 = 99u32
const SR_REJ_EQ   : u32 = 1u32    /* not SAT-proven equivalent -> membrane refuses */

/* THE LIVE MEMBRANE on real circuits: admit replacing `old` with `new` iff they are SAT-proven
 * behaviour-equivalent (ws_edge_proven == TRUE).  Real proof, not a modelled input. */
fn sr_membrane(old: u32, new: u32) -> u32 @export {
    if ws_edge_proven(old, new) != SR_WG_TRUE { return SR_REJ_EQ }
    return SR_ADMIT
}

/* The real-target liveness KAT.  99 = the organism climbs K on III's REAL crypto-primitive web:
 *   ARM 1  REAL TARGET: the (Ch spec, Ch optform) strand IS a primweb theorem (the weave indexes primweb).
 *   ARM 2  LIVE MEMBRANE (positive): Ch spec(0) <-> optform(1) is SAT-proven equivalent -> ADMIT.
 *   ARM 3  REAL K-GAIN: optform(1) AND-gate cost < spec(0) cost; the cheaper proven form is node 1.
 *   ARM 4  REAL OBSOLESCENCE: ws_strand_retires(0,1) -- proven-equal AND cheaper -> costlier retired, behaviour kept.
 *   ARM 5  LIVE MEMBRANE (negative): Ch(0) vs Maj(2) is proven-DISTINCT -> REFUSE (no false equivalence).
 *   ARM 6  a SECOND real strand: Maj spec(2) <-> carry-save(3) is also retirable; the web has real communion.
 */
fn sr_selftest() -> u64 @export {
    /* ARM 1 -- real target, real theorems */
    if ws_strand_agrees_primweb() != 1u8 { return 1u64 }
    if ws_weave_universal_count() == 0u32 { return 2u64 }

    /* ARM 2 -- live membrane admits a real proven-equivalent replacement */
    if sr_membrane(0u32, 1u32) != SR_ADMIT { return 3u64 }

    /* ARM 3 -- real cost-truth K-gain */
    let cost_spec : u64 = ws_node_cost_at(0u32)
    let cost_opt  : u64 = ws_node_cost_at(1u32)
    if cost_opt >= cost_spec { return 4u64 }
    if ws_strand_cheaper(0u32, 1u32) != 1u32 { return 5u64 }

    /* ARM 4 -- real obsolescence (proof- AND cost-backed) */
    if ws_strand_retires(0u32, 1u32) != 1u8 { return 6u64 }

    /* ARM 5 -- live membrane REFUSES a non-equivalent swap (Ch != Maj, proven distinct) */
    if sr_membrane(0u32, 2u32) != SR_REJ_EQ { return 7u64 }

    /* ARM 6 -- a second real retirable strand (Maj spec -> carry-save) */
    if ws_strand_retires(2u32, 3u32) != 1u8 { return 8u64 }

    return 99u64
}
