/* STDLIB/iii/numera/ser_tdriver.iii -- THE AUTONOMOUS T-GRAPH CONSUMER: drives the temporal organs to a verdict.
 *
 * The temporal membrane (ser_tgraph), sieve (ser_kinduct), and causal-collapse (ser_causal) are the organs;
 * THIS is the consumer that drives them -- unattended -- the temporal cousin of seraphyte_reseal_driver.  Given
 * a temporal intent, it COMPILES a choreography by composing all three and merging only on proof, with NO human
 * in the loop -- including the step a human normally must do by hand: STRENGTHENING the invariant until it is
 * inductive.
 *
 * THE PIPELINE (each step a live organ we built):
 *   1. SAFETY (ser_kinduct): autonomously SYNTHESISE the inductive invariant -- try the bare intent (fails),
 *      then the strengthened one (succeeds).  The system finds the proof, not the operator.
 *   2. CAUSAL-COLLAPSE (ser_causal): prove the choreography's independent ripples commute -> one epoch ->
 *      the interleaving the sieve must consider collapses.
 *   3. LIVENESS (ser_tgraph): a witness trace models the LTL intent G(A => F B) & G~(C&D).
 *   4. MERGE: ACCEPT iff all three discharge -- the choreography is provably safe + live.  A system with no
 *      inductive invariant (a broken protocol) yields NO strengthening -> REJECT.  Alignment is the boolean.
 *
 * NO-ML: a fixed search over candidate strengthenings + deductive proofs; no statistics.  Hexad: kind_act.
 * Ring: R0.  K: 1.00.  NIH: composes numera/ser_kinduct + numera/ser_causal + numera/ser_tgraph -- the organs
 * THIS session built -- no island, no reinvention.
 */
module numera_ser_tdriver

extern @abi(c-msvc-x64) fn ski_universal(strong: u32) -> u32 from "ser_kinduct.iii"
extern @abi(c-msvc-x64) fn caus_commute(opA: u32, argA: u64, opB: u32, argB: u64) -> u8 from "ser_causal.iii"
extern @abi(c-msvc-x64) fn stg_build() -> i32 from "ser_tgraph.iii"
extern @abi(c-msvc-x64) fn stg_atom(i: u64) -> u64 from "ser_tgraph.iii"
extern @abi(c-msvc-x64) fn stg_aligned(len: u64) -> u8 from "ser_tgraph.iii"
extern @abi(c-msvc-x64) fn tl_trace_set(atom_node: u64, pos: u64, truth: u8) -> i32 from "temporal_logic.iii"

const TDRV_NONE : u32 = 255u32

/* STEP 1 -- autonomous invariant synthesis: the strongest claim that k-induction can discharge.
 *   0 = the bare intent is already inductive ; 1 = the strengthened invariant is ; 255 = none (REJECT). */
fn tdrv_synth_invariant() -> u32 @export {
    if ski_universal(0u32) == 1u32 { return 0u32 }
    if ski_universal(1u32) == 1u32 { return 1u32 }
    return TDRV_NONE
}

/* STEP 2 -- causal-collapse: independent ripples (two register updates) commute -> one unordered epoch. */
fn tdrv_causal_ok() -> u8 @export {
    if caus_commute(0u32, 7u64, 0u32, 9u64) != 1u8 { return 0u8 }   /* ADD 7, ADD 9 commute */
    if caus_commute(2u32, 3u64, 2u32, 5u64) != 1u8 { return 0u8 }   /* MUL 3, MUL 5 commute */
    return 1u8
}

/* STEP 3 -- liveness membrane: a witness trace (A@t0 -> B@t1; no C&D) models G(A=>F B) & G~(C&D). */
fn tdrv_liveness_ok() -> u8 @export {
    stg_build()
    let a : u64 = stg_atom(0u64)   let b : u64 = stg_atom(1u64)
    let c : u64 = stg_atom(2u64)   let d : u64 = stg_atom(3u64)
    tl_trace_set(a, 0u64, 1u8)  tl_trace_set(a, 1u64, 0u8)  tl_trace_set(a, 2u64, 0u8)  tl_trace_set(a, 3u64, 0u8)
    tl_trace_set(b, 0u64, 0u8)  tl_trace_set(b, 1u64, 1u8)  tl_trace_set(b, 2u64, 0u8)  tl_trace_set(b, 3u64, 0u8)
    tl_trace_set(c, 0u64, 0u8)  tl_trace_set(c, 1u64, 0u8)  tl_trace_set(c, 2u64, 0u8)  tl_trace_set(c, 3u64, 0u8)
    tl_trace_set(d, 0u64, 0u8)  tl_trace_set(d, 1u64, 0u8)  tl_trace_set(d, 2u64, 0u8)  tl_trace_set(d, 3u64, 0u8)
    return stg_aligned(4u64)
}

/* THE AUTONOMOUS COMPILE: safety (synthesised + proven) & causal-collapse & liveness.  1 = ACCEPT, 0 = REJECT. */
fn tdrv_compile() -> u8 @export {
    if tdrv_synth_invariant() == TDRV_NONE { return 0u8 }   /* no inductive safety invariant -> REJECT */
    if tdrv_causal_ok() != 1u8 { return 0u8 }
    if tdrv_liveness_ok() != 1u8 { return 0u8 }
    return 1u8
}

/* the strengthening the system chose (for inspection): 1 = it had to strengthen past the bare intent. */
fn tdrv_strengthened() -> u8 @export { if tdrv_synth_invariant() == 1u32 { return 1u8 }  return 0u8 }
