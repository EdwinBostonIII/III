/* STDLIB/iii/numera/ser_tgraph.iii -- TEMPORAL E-GRAPH: the intent-linker rotated 90 degrees into TIME.
 *
 * ser_intent (corpus 2026) makes a SPATIAL contract a target e-class -- "a value == x*v" -- and merges a
 * candidate only on a proof.  This is the TEMPORAL rotation the operator named: the target is no longer a
 * value but the MATHEMATICAL INVARIANT OF A GLOBAL STATE OVER TIME, written in Linear Temporal Logic.  The
 * "alignment metric" (the e-class handshake) becomes: a candidate event TRACE merges with the temporal intent
 * iff the certifier proves the trace SATISFIES the LTL invariant -- emergent choreography, deadlock made
 * mathematically impossible at compile time.
 *
 * This is NOT a new engine: III already verifies LTL (numera/temporal_logic: G/F/U) and uses it in production
 * (aether/hotstuff proves G(quorum => F advance), the BFT liveness theorem).  This organ COMPOSES it as the
 * temporal target.  The intent here, the canonical safety+liveness pair:
 *     G(A => F B)   -- liveness: whenever ripple A fires, state B must EVENTUALLY follow
 *     G ~(C & D)    -- safety:   states C and D must NEVER hold simultaneously
 * A candidate trace is ALIGNED iff it models both.  The bounded check (tl_trace_eval over a length-len trace)
 * is the temporal cousin of bv_bits' combinational miter -- the event_substrate log IS the trace.
 *
 * NO-ML: fixed LTL semantics, a deterministic trace evaluator; no statistics.  Hexad: kind_essence.  Ring: R0.
 * K: 1.00.  NIH: composes numera/temporal_logic (tl_*) -- no island, no reinvented model checker.
 */
module numera_ser_tgraph

extern @abi(c-msvc-x64) fn tl_init() -> i32 from "temporal_logic.iii"
extern @abi(c-msvc-x64) fn tl_alloc_formula() -> u32 from "temporal_logic.iii"
extern @abi(c-msvc-x64) fn tl_append_atom(slot: u32, pred_slot: u32) -> u32 from "temporal_logic.iii"
extern @abi(c-msvc-x64) fn tl_append_not(slot: u32, child: u32) -> u32 from "temporal_logic.iii"
extern @abi(c-msvc-x64) fn tl_append_bin(slot: u32, tag: u8, l: u32, r: u32) -> u32 from "temporal_logic.iii"
extern @abi(c-msvc-x64) fn tl_append_unary_temp(slot: u32, tag: u8, child: u32) -> u32 from "temporal_logic.iii"
extern @abi(c-msvc-x64) fn tl_set_root(slot: u32, root: u32) -> i32 from "temporal_logic.iii"
extern @abi(c-msvc-x64) fn tl_trace_eval(formula_slot: u32, len: u64) -> i32 from "temporal_logic.iii"
extern @abi(c-msvc-x64) fn tl_trace_holds(node: u64, pos: u64) -> u8 from "temporal_logic.iii"
extern @abi(c-msvc-x64) fn tl_trace_set(atom_node: u64, pos: u64, truth: u8) -> i32 from "temporal_logic.iii"
extern @abi(c-msvc-x64) fn evt_count() -> u32 from "event_substrate.iii"
extern @abi(c-msvc-x64) fn evt_kind_at(i: u32) -> u64 from "event_substrate.iii"
extern @abi(c-msvc-x64) fn sfsm_n() -> u32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_trans_n() -> u32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_trans_from(e: u32) -> u32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_trans_to(e: u32) -> u32 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_inv(s: u32) -> u8 from "ser_fsm.iii"
extern @abi(c-msvc-x64) fn sfsm_init(s: u32) -> u8 from "ser_fsm.iii"

const STG_NOT : u8 = 1u8
const STG_AND : u8 = 2u8
const STG_IMPL : u8 = 4u8
const STG_ALWAYS : u8 = 6u8   /* G */
const STG_EVENT : u8 = 7u8    /* F */

var STG_F    : [u32; 1]
var STG_ATOM : [u64; 4]   /* A, B, C, D atom nodes */
var STG_ROOT : [u64; 1]

/* build the GLOBAL TEMPORAL INTENT: G(A => F B) & G ~(C & D). */
fn stg_build() -> i32 @export {
    tl_init()
    let f : u32 = tl_alloc_formula()
    STG_F[0u64] = f
    let a : u32 = tl_append_atom(f, 0u32)
    let b : u32 = tl_append_atom(f, 1u32)
    let c : u32 = tl_append_atom(f, 2u32)
    let d : u32 = tl_append_atom(f, 3u32)
    STG_ATOM[0u64] = a as u64   STG_ATOM[1u64] = b as u64
    STG_ATOM[2u64] = c as u64   STG_ATOM[3u64] = d as u64
    let fb   : u32 = tl_append_unary_temp(f, STG_EVENT, b)        /* F B          */
    let im   : u32 = tl_append_bin(f, STG_IMPL, a, fb)           /* A => F B     */
    let live : u32 = tl_append_unary_temp(f, STG_ALWAYS, im)      /* G(A => F B)  */
    let cd   : u32 = tl_append_bin(f, STG_AND, c, d)             /* C & D        */
    let ncd  : u32 = tl_append_not(f, cd)                         /* ~(C & D)     */
    let safe : u32 = tl_append_unary_temp(f, STG_ALWAYS, ncd)     /* G ~(C & D)   */
    let root : u32 = tl_append_bin(f, STG_AND, live, safe)        /* live & safe  */
    STG_ROOT[0u64] = root as u64
    tl_set_root(f, root)
    return 0i32
}

/* the atom-node handle for atom i (0=A,1=B,2=C,3=D) -- used by the caller to set the candidate trace. */
fn stg_atom(i: u64) -> u64 @export { if i >= 4u64 { return 0u64 }  return STG_ATOM[i] }

/* THE TEMPORAL ALIGNMENT VERDICT: 1 iff the current length-len candidate trace MODELS the temporal intent
 * (the temporal e-class merge).  A trace that violates liveness or safety does NOT align. */
fn stg_aligned(len: u64) -> u8 @export {
    tl_trace_eval(STG_F[0u64], len)
    return tl_trace_holds(STG_ROOT[0u64], 0u64)
}

/* ====== PARAMETRIC BMC: evaluate ANY caller-built LTL formula against the caller's trace (EIDOS-VM Phase 1.2) ==
 * The fixture above (G(A=>FB) & G~(C&D)) is now ONE instance; stg_check evaluates the formula the CALLER built
 * via temporal_logic (tl_alloc_formula + tl_append_* + tl_set_root, passing the root node it created) over the
 * trace the caller set (tl_trace_set) -- so the bounded model checker is a reusable engine over ANY property. */
fn stg_check(formula: u32, root: u64, len: u64) -> u8 @export {
    tl_trace_eval(formula, len)
    return tl_trace_holds(root, 0u64)
}

/* ============================================================================================================
 * EVENT-DRIVEN BMC (the architectural fix): the LTL trace IS the EVENT LOG, not a synthetic tl_trace.  Atom a
 * holds at position i iff event i has KIND a -- so the membrane model-checks the REAL choreography on the
 * substrate (event_substrate.evt_perceive).  atom_nodes[a] = the atom node bound to kind a; n = #atoms;
 * the trace length = evt_count().  This is ser_tgraph CONSUMING the event log, the read half it was missing. */
fn stg_check_events(formula: u32, root: u64, atom_nodes: *u64, n: u32) -> u8 @export {
    let len : u64 = evt_count() as u64
    let mut i : u64 = 0u64
    while i < len {
        let k : u64 = evt_kind_at(i as u32)
        let mut a : u32 = 0u32
        while a < n {
            let mut truth : u8 = 0u8
            if (a as u64) == k { truth = 1u8 }
            tl_trace_set(atom_nodes[a as u64], i, truth)
            a = a + 1u32
        }
        i = i + 1u64
    }
    return stg_check(formula, root, len)
}

/* ============================================================================================================
 * REAL BOUNDED MODEL CHECKING (the fullest form -- it GENERATES the counterexample, it does not consume a trace).
 * Over the shared transition relation (ser_fsm: states, guarded transitions, init set, safety invariant), unroll
 * by breadth-first reachability to depth max_depth, checking the invariant at EVERY reachable state.  If a state
 * with inv==0 is reachable, the safety property is VIOLATED; stg_bmc records it and the shortest path to it, so
 * the witness trace is RECONSTRUCTED from the search -- never supplied.  Returns the depth of the violation, or
 * STG_BMC_SAFE if the invariant holds on all states reachable within max_depth. */
const STG_BMC_SAFE : u32 = 0xFFFFFFFFu32

var BMC_SEEN   : [u8;  256]
var BMC_DEPTH  : [u32; 256]
var BMC_PARENT : [u32; 256]
var BMC_QUEUE  : [u32; 256]
var BMC_VIOL   : [u32; 1]
var BMC_EXPL   : [u32; 1]   /* how many states the search actually expanded (the work it did) */

fn stg_bmc(max_depth: u32) -> u32 @export {
    let n : u32 = sfsm_n()
    let mut i : u32 = 0u32
    while i < n { BMC_SEEN[i as u64] = 0u8  i = i + 1u32 }
    let mut qh : u32 = 0u32
    let mut qt : u32 = 0u32
    i = 0u32
    while i < n {                                            /* seed the frontier with every init state */
        if sfsm_init(i) == 1u8 {
            BMC_SEEN[i as u64] = 1u8  BMC_DEPTH[i as u64] = 0u32  BMC_PARENT[i as u64] = i
            BMC_QUEUE[qt as u64] = i  qt = qt + 1u32
        }
        i = i + 1u32
    }
    let mut expl : u32 = 0u32
    while qh < qt {
        let cur : u32 = BMC_QUEUE[qh as u64]  qh = qh + 1u32
        expl = expl + 1u32
        let d : u32 = BMC_DEPTH[cur as u64]
        if sfsm_inv(cur) == 0u8 {                            /* a REACHABLE violating state -> counterexample */
            BMC_VIOL[0u64] = cur  BMC_EXPL[0u64] = expl
            return d
        }
        if d < max_depth {
            let tn : u32 = sfsm_trans_n()
            let mut t : u32 = 0u32
            while t < tn {                                   /* expand: every enabled transition out of cur */
                if sfsm_trans_from(t) == cur {
                    let nx : u32 = sfsm_trans_to(t)
                    if nx < n { if BMC_SEEN[nx as u64] == 0u8 {
                        BMC_SEEN[nx as u64] = 1u8  BMC_DEPTH[nx as u64] = d + 1u32  BMC_PARENT[nx as u64] = cur
                        BMC_QUEUE[qt as u64] = nx  qt = qt + 1u32
                    } }
                }
                t = t + 1u32
            }
        }
    }
    BMC_VIOL[0u64] = STG_BMC_SAFE  BMC_EXPL[0u64] = expl
    return STG_BMC_SAFE
}
fn stg_bmc_violation() -> u32 @export { return BMC_VIOL[0u64] }     /* the violating state, or STG_BMC_SAFE */
fn stg_bmc_explored() -> u32 @export { return BMC_EXPL[0u64] }      /* states expanded (the search's real work) */
/* the counterexample path: number of states from an init state to the violation, inclusive. */
fn stg_bmc_path_len() -> u32 @export {
    if BMC_VIOL[0u64] == STG_BMC_SAFE { return 0u32 }
    let mut s : u32 = BMC_VIOL[0u64]
    let mut len : u32 = 1u32
    while BMC_PARENT[s as u64] != s { s = BMC_PARENT[s as u64]  len = len + 1u32 }
    return len
}
/* path_state(i): the i-th state on the reconstructed counterexample (0 = init, path_len-1 = the violation). */
fn stg_bmc_path_state(i: u32) -> u32 @export {
    if BMC_VIOL[0u64] == STG_BMC_SAFE { return STG_BMC_SAFE }
    let len : u32 = stg_bmc_path_len()
    if i >= len { return STG_BMC_SAFE }
    let mut back : u32 = len - 1u32 - i
    let mut s : u32 = BMC_VIOL[0u64]
    while back > 0u32 { s = BMC_PARENT[s as u64]  back = back - 1u32 }
    return s
}
/* was state s reached by the last BMC run? (1 = reachable from init).  k-induction restricts its inductive
 * step to reachable states -- the bare invariant is often not inductive on UNREACHABLE states (the classic
 * k-induction trap), and reachability is exactly the strengthening that closes it. */
fn stg_bmc_reachable(s: u32) -> u8 @export { if s >= 256u32 { return 0u8 }  return BMC_SEEN[s as u64] }
