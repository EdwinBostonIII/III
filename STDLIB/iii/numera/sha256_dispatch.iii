/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\sha256_dispatch.iii
 *
 * III STDLIB - numera::sha256_dispatch
 *
 * Runtime dispatch of the HIGHEST-AVAILABLE SHA-256 implementation.  Two
 * implementations now exist and are proven bit-identical:
 *   - software   numera/sha256.iii      (the FIPS-verified scalar core)
 *   - hardware   numera/sha256_ni.iii    (Intel SHA-NI: sha256rnds2/msg1/msg2)
 * The exhaustive differential KAT corpus/1020 proves them byte-for-byte equal
 * over lengths 0..135 (every block count + the 55/56/63/64 padding edges) PLUS
 * the FIPS 180-4 "abc"/"" vectors.  C.14 staged accelerator -- now ACTIVATED.
 *
 * Selection (cpufeat-gated -- never emits an unsupported instruction):
 *   - AUTO (default)        : cpufeat_has_sha()==1 -> SHA-NI, else software.
 *   - force_path(SOFTWARE)  : pin the software path (overrides AUTO).
 *   - force_path(SHA_NI)    : request SHA-NI; honored iff cpufeat_has_sha()==1,
 *                             else falls back to software.
 * SHA-NI being bit-identical means EVERY consumer (e.g. omnia/prespec.iii) gets
 * the SAME digest on either path -- only the cycle count changes.  The
 * @dynamic_impact(perf, ux) provenance is now REAL: on a SHA-capable CPU the
 * dispatcher auto-selects the fast path with no consumer source change.
 *
 * GOLDEN-SAFE: the compiler does NOT link sha256_dispatch (verified by objdump
 * of COMPILED/iiis-2.exe -- no sha256_dispatch / sha256_ni symbol), so wiring
 * the hardware path cannot drift the determinism golden.  A non-SHA CPU runs
 * the proven software path bit-for-bit (cpufeat-gated fallback).
 *
 * Public surface (stable across the activation):
 *   sha256_dispatch_oneshot(input, len, out_32) -> u32   compute SHA-256
 *   sha256_dispatch_path() -> u32                        0 = software, 1 = SHA-NI
 *   sha256_dispatch_force_path(p) -> u32                 returns the resulting path
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00.
 */

module numera_sha256_dispatch

extern @abi(c-msvc-x64) fn sha256_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn sha256_ni_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 from "sha256_ni.iii"
extern @abi(c-msvc-x64) fn cpufeat_has_sha() -> u8 from "cpufeat.iii"

const SHA_PATH_SOFTWARE : u32 = 0u32
const SHA_PATH_SHA_NI   : u32 = 1u32

/* dispatch override: AUTO selects the highest-available path; the two forced
 * states let tests + tooling pin a specific path.  Default = AUTO. */
const SHA_OV_AUTO     : u32 = 0u32
const SHA_OV_SOFTWARE : u32 = 1u32
const SHA_OV_SHA_NI   : u32 = 2u32

var SHA_DISPATCH_OV : u32 = 0u32

/* The active path.  AUTO and requested-SHA-NI both honor cpufeat (so a non-SHA
 * CPU never reaches sha256rnds2); forced-software pins the scalar core. */
fn sha256_dispatch_select() -> u32 {
    let ov : u32 = SHA_DISPATCH_OV
    if ov == SHA_OV_SOFTWARE { return SHA_PATH_SOFTWARE }
    if cpufeat_has_sha() == 1u8 { return SHA_PATH_SHA_NI }
    return SHA_PATH_SOFTWARE
}

/* Pin a path for tests/benchmarking.  Returns the RESULTING active path:
 *   force(SOFTWARE) -> 0 ; force(SHA_NI) -> cpufeat_has_sha() ; bogus -> unchanged. */
fn sha256_dispatch_force_path(p: u32) -> u32 @export {
    let p_l : u32 = p & 0xFFFFFFFFu32
    if p_l == SHA_PATH_SOFTWARE { SHA_DISPATCH_OV = SHA_OV_SOFTWARE ; return sha256_dispatch_select() }
    if p_l == SHA_PATH_SHA_NI   { SHA_DISPATCH_OV = SHA_OV_SHA_NI   ; return sha256_dispatch_select() }
    return sha256_dispatch_select()   /* bogus -> override unchanged */
}

fn sha256_dispatch_path() -> u32 @export {
    return sha256_dispatch_select()
}

fn sha256_dispatch_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 @export {
    if sha256_dispatch_select() == SHA_PATH_SHA_NI { return sha256_ni_oneshot(input, len, out_32) }
    return sha256_oneshot(input, len, out_32)
}
