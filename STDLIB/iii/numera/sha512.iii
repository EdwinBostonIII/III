/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\sha512.iii
 *
 * III STDLIB - numera::sha512
 *
 * Hand-rolled FIPS 180-4 SHA-512.  Same module-singleton pattern as
 * sha256.iii: one inline state machine, sha512_init/update/final, plus
 * the W3-bypassing finalize_internal + digest_byte readback for
 * cross-file consumers that cannot pass a pointer-to-global.
 *
 * Differences from SHA-256:
 *   - 64-bit words (vs 32-bit)
 *   - 80 rounds (vs 64)
 *   - 80 K-constants (vs 64)
 *   - 128-byte block (vs 64)
 *   - 128-bit length field (vs 64) -- we model it via two u64 counters
 *   - 64-byte digest (vs 32)
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00.
 *
 * Used by: Ed25519 verify (next session) and any future SHA-512-based
 * crypto primitive.
 *
 * NIH: zero externs.  Hand-rolled FIPS 180-4 inner loop.
 */

module numera_sha512

const SHA512_BLOCK_BYTES : u32 = 128u32

var SHA512_K       : [u64; 80]
var SHA512_K_INIT  : u8 = 0u8
var SHA512_H       : [u64; 8]
var SHA512_W       : [u64; 80]
var SHA512_BUF     : [u8; 128]
var SHA512_BUFLEN  : u32 = 0u32
var SHA512_BITS_LO : u64 = 0u64
var SHA512_BITS_HI : u64 = 0u64       /* high 64 bits of the 128-bit count */
var SHA512_INIT    : u8  = 0u8

/* --- §3.5 AVX-512 message-schedule sigma0 (4-wide, prior-word part) --- */
extern @abi(c-msvc-x64) fn cpufeat_has_avx512f() -> u8 from "cpufeat.iii"
var SHA512_PART    : [u64; 4]      /* partial[j] = W[t+j-16] + sigma0(W[t+j-15]) + W[t+j-7] */
var SHA512_SCHED_T : u32 = 0u32    /* current 4-group start index t */
var SHA512_FORCE   : u32 = 0u32    /* 0=auto, 1=scalar, 2=avx512 (bit-identity override) */

/* --- ROTR for 64-bit words --- */

fn sha512_rotr(x: u64, n: u64) -> u64 {
    return (x >> n) | (x << (64u64 - n))
}

/* --- K-table init (FIPS 180-4 §4.2.3) --- */

fn sha512_init_k() -> u32 {
    if SHA512_K_INIT == 1u8 { return 0u32 }
    SHA512_K[0]  = 0x428a2f98d728ae22u64
    SHA512_K[1]  = 0x7137449123ef65cdu64
    SHA512_K[2]  = 0xb5c0fbcfec4d3b2fu64
    SHA512_K[3]  = 0xe9b5dba58189dbbcu64
    SHA512_K[4]  = 0x3956c25bf348b538u64
    SHA512_K[5]  = 0x59f111f1b605d019u64
    SHA512_K[6]  = 0x923f82a4af194f9bu64
    SHA512_K[7]  = 0xab1c5ed5da6d8118u64
    SHA512_K[8]  = 0xd807aa98a3030242u64
    SHA512_K[9]  = 0x12835b0145706fbeu64
    SHA512_K[10] = 0x243185be4ee4b28cu64
    SHA512_K[11] = 0x550c7dc3d5ffb4e2u64
    SHA512_K[12] = 0x72be5d74f27b896fu64
    SHA512_K[13] = 0x80deb1fe3b1696b1u64
