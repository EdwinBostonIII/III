/* ISA op tags (a symbol id is 32 bytes: tag byte + zeros). */
const SI_X    : u8 = 12u8     /* the variable x       (arity 0) */
const SI_C0   : u8 = 20u8     /* constant 0           (arity 0) */
const SI_C1   : u8 = 21u8     /* constant 1           (arity 0) */
const SI_C2   : u8 = 22u8     /* constant 2           (arity 0) */
const SI_ADD  : u8 = 30u8     /* add(_, _)            (arity 2) */
const SI_MUL  : u8 = 31u8     /* mul(_, _)            (arity 2) */
const SI_SHL  : u8 = 32u8     /* shl(_, _)            (arity 2) */
const SI_DIV  : u8 = 33u8     /* udiv(_, _)           (arity 2; wave-4 M12) */
const SI_SHR  : u8 = 34u8     /* lshr(_, _)           (arity 2; wave-4 M12) */

const SI_SENT     : u32 = 0xFFFFFFFFu32
const CL_BALANCED : u32 = 3u32     /* cost_lattice seeds order 3 = balanced (2,2,1,1,1,1) */

var SI_SYM   : [u8;  32]
var SI_CHILD : [u32; 8]
var SI_REQ   : [u32; 256]
var SI_RULE  : [u32; 64]
var SI_CVEC  : [u64; 6]
var SI_DOT   : [u64; 1]
var SI_OUT   : [u32; 256]
var SI_OUTN  : [u32; 1]
var SOV_LP    : [u32; 1]    /* sov_lower preorder cursor over the egraph output */
var SOV_SUCCF : [u32; 1]    /* the kernel succ-function node (lam n:Nat. succ n) */

/* contingent-evolution-driver buffers (the ripple store + cell-graph; static, no malloc) */
var EV_META    : [u8; 32]
var EV_SLOTS   : [u8; 512]    /* 8 slots * 64 bytes */
var EV_ARENA   : [u8; 2048]
var EV_CK      : [u8; 4]      /* cell_kind (ncells <= 4) */
var EV_CA      : [u8; 128]    /* cell_addr (4 * 32) */
var EV_IOFF    : [u8; 32]     /* in_off (4 * 8) */
var EV_ICNT    : [u8; 32]     /* in_cnt (4 * 8) */
var EV_ILIST   : [u8; 32]     /* in_list (4 * 8) */
var EV_SCR     : [u8; 64]     /* recompute scratch (2 * 32) */
var EV_NEW     : [u8; 32]     /* recompute newaddr */
var EV_ADDRX   : [u8; 32]     /* address of expr A's optimum (x) */
var EV_ADDRSHL : [u8; 32]     /* address of expr D's optimum (x<<1) */
var EV_C1SNAP  : [u8; 32]     /* cell1's address snapshot */
var EV_RESOLVE : [u8; 256]    /* resolve output */
var EV_VBUF    : [u8; 32]     /* resolve tamper-check scratch */

var SI_CC_SEEDED : u8 = 0u8     /* W3.8 one-time microarch cost-table seed flag */
var SI_REQ32     : [u8; 32]     /* cc_evaluate request aggregate (ops_ptr,n,deps_ptr,dep_n) */
var SI_OPS1      : [u32; 1]     /* single-op opcode array for the per-tag cost query */
var SI_GA        : [u64; 6]     /* gradient KAT: ADD cost-vector capture */
var SI_GM        : [u64; 6]     /* gradient KAT: MUL cost-vector capture */
var SI_GS        : [u64; 6]     /* gradient KAT: SHL cost-vector capture */

fn si_symset(tag: u8) -> i32 {
    let mut i : u64 = 0u64
    while i < 32u64 { SI_SYM[i] = 0u8 ; i = i + 1u64 }
    SI_SYM[0u64] = tag
    return 0i32
}
fn si_symp() -> *u8  { return (&SI_SYM) as u64 as *u8 }
fn si_chp()  -> *u32 { return (&SI_CHILD) as u64 as *u32 }

/* build an arity-0 leaf node; returns its eclass id. */
fn si_leaf(tag: u8) -> u32 @export {
    si_symset(tag)
    return eg_add(si_symp(), si_chp(), 0u32)
}
/* build an arity-2 node over child eclasses a, b; returns its eclass id. */
fn si_node2(tag: u8, a: u32, b: u32) -> u32 @export {
    si_symset(tag)
    SI_CHILD[0u32] = a
    SI_CHILD[1u32] = b
    return eg_add(si_symp(), si_chp(), 2u32)
}
/* the (idempotent) symbol slot for a tag. */
fn si_slot(tag: u8) -> u32 @export {
    si_symset(tag)
    return eg_intern_symbol(si_symp())
}

/* preorder-skeleton encoders (the egraph's rule/extract format). */
fn si_enc_sym(slot: u32, arity: u32) -> u32 {
    return (slot << 1u32) | (arity << 16u32)
}
fn si_enc_var(idx: u32) -> u32 {
    return (idx << 1u32) | 1u32
}

const SI_TP_SCALE : u64 = 1000u64    /* cc_evaluate's throughput full-scale */

/* store a little-endian u64 at byte offset off of the request aggregate p. */
fn si_st_u64(p: *u8, off: u64, v: u64) -> i32 {
    p[off + 0u64] = (v & 0xFFu64) as u8
    p[off + 1u64] = ((v >> 8u64) & 0xFFu64) as u8
    p[off + 2u64] = ((v >> 16u64) & 0xFFu64) as u8
    p[off + 3u64] = ((v >> 24u64) & 0xFFu64) as u8
    p[off + 4u64] = ((v >> 32u64) & 0xFFu64) as u8
    p[off + 5u64] = ((v >> 40u64) & 0xFFu64) as u8
    p[off + 6u64] = ((v >> 48u64) & 0xFFu64) as u8
    p[off + 7u64] = ((v >> 56u64) & 0xFFu64) as u8
    return 0i32
}

/* pack a cc_evaluate request aggregate: {ops_ptr, n, deps_ptr, dep_n} (32 bytes LE). */
fn si_pack_req(req: *u8, ops_ptr: u64, n: u64, deps_ptr: u64, dep_n: u64) -> i32 {
    si_st_u64(req, 0u64, ops_ptr)
    si_st_u64(req, 8u64, n)
    si_st_u64(req, 16u64, deps_ptr)
    si_st_u64(req, 24u64, dep_n)
    return 0i32
}

/* Seed the per-opcode microarch cost table ONCE (idempotent; deterministic -- a
 * fixed table, NOT observational/counting).  The cost-calculus/microarch opcode IS
 * the SI_* tag value.  A multiply costs 3x latency + 2x energy; the cheap ops keep
 * the cc/ma defaults (latency 1, size 4, dcache 0, energy 1). */
fn sov_isa_cost_seed() -> i32 {
    cc_init()
    ma_init()
    ma_set_latency((SI_MUL as u32), 3u32)
    cc_set_energy((SI_MUL as u32), 2u32)
    /* wave-4 M12: division is the DEAREST scalar op (divq-class latency; a fixed deterministic
     * table value, not observation).  SHR keeps the cheap defaults (latency 1, energy 1). */
    ma_set_latency((SI_DIV as u32), 26u32)
    cc_set_energy((SI_DIV as u32), 8u32)
    return 0i32
}

/* THE COST-FIELD (W3.8 / ENHANCE-4 / SEPARATE-3): an ISA op's scalar cost is the
 * balanced-order dot of its REAL 6-dim microarch cost vector, now produced by
 * numera/cost_calculus.cc_evaluate (latency from the microarch_model simulator;
 * register pressure, icache=size, dcache, energy from cc's per-opcode tables) --
 * no longer a hand-stubbed all-ones vector.  The throughput dimension is converted
 * to a DEFICIT (TP_SCALE - throughput): a stalling (high-latency) op must be DEARER,
 * but cc reports throughput as (1000*n)/cycles which DROPS with latency -- fed raw
 * into a positive-weight dot it would rank a multiply CHEAPER and invert the
 * optimizer.  The deficit makes it a true cost.  Requires cl_init() for the orders. */
fn sov_isa_op_cost(tag: u8) -> u64 @export {
    if SI_CC_SEEDED == 0u8 {
        sov_isa_cost_seed()
        SI_CC_SEEDED = 1u8
    }
    SI_OPS1[0u32] = tag as u32
    let reqp : *u8 = (&SI_REQ32) as u64 as *u8
    si_pack_req(reqp, (&SI_OPS1) as u64, 1u64, 0u64, 0u64)
    let cvp : *u64 = (&SI_CVEC) as u64 as *u64
    cc_evaluate(reqp, cvp)
    let tp : u64 = SI_CVEC[1u32]
    if tp < SI_TP_SCALE { SI_CVEC[1u32] = SI_TP_SCALE - tp } else { SI_CVEC[1u32] = 0u64 }
    let dtp : *u64 = (&SI_DOT) as u64 as *u64
    cl_dot_slot(CL_BALANCED, cvp, dtp)
    return SI_DOT[0u32]
}

/* W3.8 helper: snapshot the live SI_CVEC into a 6-u64 buffer (gradient capture). */
fn si_cap6(dst: u64) -> i32 {
    let d : *u64 = dst as *u64
    let mut i : u64 = 0u64
    while i < 6u64 {
        d[i] = SI_CVEC[i]
        i = i + 1u64
    }
    return 0i32
}

/* W3.8 / ENHANCE-4 gradient falsifier: the cost field is REAL (sourced from
 * cost_calculus), not a flat stub.  Positives: MUL's 6-vec differs from ADD's in
 * latency / throughput-deficit / energy, and MUL's scalar cost strictly exceeds
 * ADD's and SHL's (the gradient that drives strength-reduction extraction); the
 * cheap ops share a cost (shl == add).  Negative: a FLAT re-seed (mul == add)
 * collapses the gradient so the costs become EQUAL -- proving it is data-driven, not
 * hardcoded.  99 = pass. */
fn sov_isa_cost_gradient_kat() -> u64 @export {
    cl_init()                                       /* seed the cost_lattice orders */
    let ca : u64 = sov_isa_op_cost(SI_ADD)
    si_cap6((&SI_GA) as u64)
    let cm : u64 = sov_isa_op_cost(SI_MUL)
    si_cap6((&SI_GM) as u64)
    let cs : u64 = sov_isa_op_cost(SI_SHL)
    si_cap6((&SI_GS) as u64)
    if SI_GM[0u32] == SI_GA[0u32] { return 1u64 }   /* latency differs (3 vs 1) */
    if SI_GM[1u32] == SI_GA[1u32] { return 2u64 }   /* throughput deficit differs */
    if SI_GM[5u32] == SI_GA[5u32] { return 3u64 }   /* energy differs (2 vs 1) */
    if SI_GS[0u32] != SI_GA[0u32] { return 4u64 }   /* shl latency == add (cheap) */
    if SI_GS[5u32] != SI_GA[5u32] { return 5u64 }   /* shl energy == add (cheap) */
    if cm <= ca { return 6u64 }                     /* MUL strictly dearer than ADD */
    if cm <= cs { return 7u64 }                     /* MUL strictly dearer than SHL */
    if ca != cs { return 8u64 }                     /* ADD == SHL (both cheap) */
    /* NEGATIVE: a flat re-seed (mul == add) collapses the gradient. */
    ma_set_latency((SI_MUL as u32), 1u32)
    cc_set_energy((SI_MUL as u32), 1u32)
    let cm_flat : u64 = sov_isa_op_cost(SI_MUL)
    let ca2     : u64 = sov_isa_op_cost(SI_ADD)
    if cm_flat != ca2 { return 9u64 }               /* flat field -> mul == add */
    /* restore the real gradient. */
    ma_set_latency((SI_MUL as u32), 3u32)
    cc_set_energy((SI_MUL as u32), 2u32)
    if sov_isa_op_cost(SI_MUL) <= sov_isa_op_cost(SI_ADD) { return 10u64 }
    return 99u64
}

/* register the two SOUND algebraic rules into the (already eg_init'd) egraph:
 *   A. mul(?0, c2) -> shl(?0, c1)   [x*2 = x<<1]
 *   B. add(?0, c0) -> ?0            [x+0 = x]
 * returns 0 on success, else a small nonzero code. */
fn sov_isa_rules() -> u32 @export {
    let s_mul : u32 = si_slot(SI_MUL)
    let s_shl : u32 = si_slot(SI_SHL)
    let s_add : u32 = si_slot(SI_ADD)
    let s_c0  : u32 = si_slot(SI_C0)
    let s_c1  : u32 = si_slot(SI_C1)
    let s_c2  : u32 = si_slot(SI_C2)
    if s_mul == SI_SENT { return 1u32 }
    if s_shl == SI_SENT { return 2u32 }
    if s_add == SI_SENT { return 3u32 }

    /* ===== wave-4 M13: RULE REGISTRATION IS KERNEL CITATION ======================================
     * Every core rule was 'kernel-certified' in COMMENTS (corpus 875/1207) while only Rule I
     * consulted the kernel live.  Unified: each rule's exact law is re-proven by the CIC kernel
     * AT REGISTRATION, every boot.  The core six are FOUNDATIONAL -- a refused citation fails
     * rules() LOUDLY (codes 20-25): an optimizer whose ground rules the kernel won't certify
     * must not come up at all.  (The optional-symbol rules H/I keep their skip-on-refusal
     * contract -- absence is sound; a broken foundation is not.)  Clobbers the tc arena. */
    tc_reset()
    let cit_x : u32 = tc_var(0u32)
    let cit_0 : u32 = tc_bvlit_u64(0u64)
    let cit_1 : u32 = tc_bvlit_u64(1u64)
    let cit_2 : u32 = tc_bvlit_u64(2u64)
    if tc_conv(tc_bvmul(cit_x, cit_2), tc_bvshl(cit_x, cit_1)) != 1u8 { return 20u32 }  /* A: x*2 == x<<1 */
    if tc_conv(tc_bvadd(cit_x, cit_0), cit_x) != 1u8 { return 21u32 }                   /* B: x+0 == x */
    if tc_conv(tc_bvmul(cit_x, cit_1), cit_x) != 1u8 { return 22u32 }                   /* C: x*1 == x */
    if tc_conv(tc_bvmul(cit_x, cit_0), cit_0) != 1u8 { return 23u32 }                   /* D: x*0 == 0 */
    if tc_conv(tc_bvadd(cit_1, cit_1), cit_2) != 1u8 { return 24u32 }                   /* F: 1+1 == 2 */
    if tc_conv(tc_bvmul(cit_1, cit_2), cit_2) != 1u8 { return 25u32 }                   /* G: 1*2 == 2 */

    /* Rule A: LHS [mul/2, ?0, c2/0]  ->  RHS [shl/2, ?0, c1/0] */
    SI_RULE[0u32] = 3u32
    SI_RULE[1u32] = 3u32
    SI_RULE[2u32] = si_enc_sym(s_mul, 2u32)
    SI_RULE[3u32] = si_enc_var(0u32)
    SI_RULE[4u32] = si_enc_sym(s_c2, 0u32)
    SI_RULE[5u32] = si_enc_sym(s_shl, 2u32)
    SI_RULE[6u32] = si_enc_var(0u32)
    SI_RULE[7u32] = si_enc_sym(s_c1, 0u32)
    let rulep : *u32 = (&SI_RULE) as u64 as *u32
    if eg_register_rule(rulep) == SI_SENT { return 4u32 }

    /* Rule B: LHS [add/2, ?0, c0/0]  ->  RHS [?0] */
    SI_RULE[0u32] = 3u32
    SI_RULE[1u32] = 1u32
    SI_RULE[2u32] = si_enc_sym(s_add, 2u32)
    SI_RULE[3u32] = si_enc_var(0u32)
    SI_RULE[4u32] = si_enc_sym(s_c0, 0u32)
    SI_RULE[5u32] = si_enc_var(0u32)
    if eg_register_rule(rulep) == SI_SENT { return 5u32 }

    /* Rule C: LHS [mul/2, ?0, c1/0]  ->  RHS [?0]   [x*1 = x] (kernel-certified, 875) */
    SI_RULE[0u32] = 3u32
    SI_RULE[1u32] = 1u32
    SI_RULE[2u32] = si_enc_sym(s_mul, 2u32)
    SI_RULE[3u32] = si_enc_var(0u32)
    SI_RULE[4u32] = si_enc_sym(s_c1, 0u32)
    SI_RULE[5u32] = si_enc_var(0u32)
    if eg_register_rule(rulep) == SI_SENT { return 6u32 }

    /* Rule D: LHS [mul/2, ?0, c0/0]  ->  RHS [c0/0]   [x*0 = 0] (kernel-certified, 875) */
    SI_RULE[0u32] = 3u32
    SI_RULE[1u32] = 1u32
    SI_RULE[2u32] = si_enc_sym(s_mul, 2u32)
    SI_RULE[3u32] = si_enc_var(0u32)
    SI_RULE[4u32] = si_enc_sym(s_c0, 0u32)
    SI_RULE[5u32] = si_enc_sym(s_c0, 0u32)
    if eg_register_rule(rulep) == SI_SENT { return 7u32 }

    /* Rule F: add(c1, c1) -> c2  [constant fold 1+1=2] (a GROUND rule; kernel-certified) */
    SI_RULE[0u32] = 3u32
    SI_RULE[1u32] = 1u32
    SI_RULE[2u32] = si_enc_sym(s_add, 2u32)
    SI_RULE[3u32] = si_enc_sym(s_c1, 0u32)
    SI_RULE[4u32] = si_enc_sym(s_c1, 0u32)
    SI_RULE[5u32] = si_enc_sym(s_c2, 0u32)
    if eg_register_rule(rulep) == SI_SENT { return 8u32 }

    /* Rule G [SELF-EXTENSION via the self-improvement loop, 2026-06-04]: mul(c1, c2) -> c2  [1*2 = 2,
     * a GROUND constant fold the optimizer LACKED -- mul(1,2) descended only to shl(1,1), 3 nodes].
     * KERNEL-CERTIFIED + KERNEL-GOVERNED by sov_isa_selfext_kat (the CIC kernel proves 1*2 == 2 and
     * REJECTS the meaning-changing 1*2 == 1).  Additive: fires ONLY on the ground term mul(1,2). */
    SI_RULE[0u32] = 3u32
    SI_RULE[1u32] = 1u32
    SI_RULE[2u32] = si_enc_sym(s_mul, 2u32)
    SI_RULE[3u32] = si_enc_sym(s_c1, 0u32)
    SI_RULE[4u32] = si_enc_sym(s_c2, 0u32)
    SI_RULE[5u32] = si_enc_sym(s_c2, 0u32)
    if eg_register_rule(rulep) == SI_SENT { return 9u32 }

    /* Rule H [LATTICE-CITED, wave-4 M10]: shl(shl(?0,c1),c1) -> shl(?0,c2)  [(x<<1)<<1 = x<<2,
     * the (a=1,b=1) instance of the 0xB7 shift-combining family].  The rule is registered ONLY
     * when the autocatalyst lattice CERTIFIES the pair AT USE-SITE -- cga_dispose_shift(2,1,1):
     * UNSAT at four probe widths behind the count-mask wall -- so the optimizer can only do what
     * the lattice proves.  A lattice refusal SKIPS the rule: the optimizer stays sound, merely
     * weaker, and the shift-combine KAT reddens (observable, never silent).  The nested depth-2
     * LHS is preorder [shl/2, shl/2, ?0, c1, c1] (matcher support proven during bring-up). */
    if cga_dispose_shift(2u32, 1u32, 1u32, 1u32) == 1u8 {
        SI_RULE[0u32] = 5u32
        SI_RULE[1u32] = 3u32
        SI_RULE[2u32] = si_enc_sym(s_shl, 2u32)
        SI_RULE[3u32] = si_enc_sym(s_shl, 2u32)
        SI_RULE[4u32] = si_enc_var(0u32)
        SI_RULE[5u32] = si_enc_sym(s_c1, 0u32)
        SI_RULE[6u32] = si_enc_sym(s_c1, 0u32)
        SI_RULE[7u32] = si_enc_sym(s_shl, 2u32)
        SI_RULE[8u32] = si_enc_var(0u32)
        SI_RULE[9u32] = si_enc_sym(s_c2, 0u32)
        if eg_register_rule(rulep) == SI_SENT { return 10u32 }
    }

    /* Rule I [KERNEL-CITED, wave-4 M12]: div(?0, c2) -> shr(?0, c1)  [x/2 = x>>1 -- THE
     * DIV-STRENGTH IOTA, ledger 8.29].  OPTIONAL symbols: registered only when the div/shr
     * slots exist (a caller that never builds division terms is untouched) AND the CIC KERNEL
     * certifies the law AT REGISTRATION -- tc_conv(bvudiv(x,2), bvlshr(x,1)) consulted live
     * (clobbers the tc arena; rules() callers hold no kernel state).  A kernel refusal SKIPS
     * the rule: sound-but-weaker, and the div-strength KAT reddens (observable, never silent). */
    let s_div : u32 = si_slot(SI_DIV)
    let s_shr : u32 = si_slot(SI_SHR)
    if s_div != SI_SENT {
        if s_shr != SI_SENT {
            tc_reset()
            let kx : u32 = tc_var(0u32)
            let lhs_k : u32 = tc_bvudiv(kx, tc_bvlit_u64(2u64))
            let rhs_k : u32 = tc_bvlshr(kx, tc_bvlit_u64(1u64))
            if tc_conv(lhs_k, rhs_k) == 1u8 {
                SI_RULE[0u32] = 3u32
                SI_RULE[1u32] = 3u32
                SI_RULE[2u32] = si_enc_sym(s_div, 2u32)
                SI_RULE[3u32] = si_enc_var(0u32)
                SI_RULE[4u32] = si_enc_sym(s_c2, 0u32)
                SI_RULE[5u32] = si_enc_sym(s_shr, 2u32)
                SI_RULE[6u32] = si_enc_var(0u32)
                SI_RULE[7u32] = si_enc_sym(s_c1, 0u32)
                if eg_register_rule(rulep) == SI_SENT { return 11u32 }
            }
        }
    }

    return 0u32
}

/* set the extraction cost of one op (by tag) into SI_REQ[slot+2]. */
fn si_setcost(tag: u8) -> i32 {
    let slot : u32 = si_slot(tag)
    if slot == SI_SENT { return -1i32 }
    let sb : u64 = (slot as u64) + 2u64
    SI_REQ[sb] = sov_isa_op_cost(tag) as u32
    return 0i32
}

/* THE SOVEREIGN ISA DESCENT.  Given a built term root (rules already registered),
 * saturate the proven-equal class, attach the cost-field, and extract the min-cost
 * realization into (out_term, out_n).  Returns the egraph status (0 = ok). */
fn sov_isa_descend(root: u32, out_term: *u32, out_n: *u32) -> i32 @export {
    eg_saturate(16u32)
    let mut i : u32 = 0u32
    while i < 256u32 { SI_REQ[i] = 0u32 ; i = i + 1u32 }
    SI_REQ[0u32] = eg_find(root)
    si_setcost(SI_X)
    si_setcost(SI_C0)
    si_setcost(SI_C1)
    si_setcost(SI_C2)
    si_setcost(SI_ADD)
    si_setcost(SI_MUL)
    si_setcost(SI_SHL)
    /* wave-4 M12: the division pair joins the cost field -- an unset cost is COST ZERO to the
     * extractor, which would make divq look FREE and the strength reduction never taken.  The
     * sym-count read moves AFTER the cost attaches (si_setcost interns idempotently; symbols
     * never used by a term do not appear in any e-node, so old extractions are untouched). */
    si_setcost(SI_DIV)
    si_setcost(SI_SHR)
    SI_REQ[1u32] = eg_sym_count()
    let reqp : *u32 = (&SI_REQ) as u64 as *u32
    return eg_extract(reqp, out_term, out_n)
}

/* KAT (99 = all pass).  Proves the descent end-to-end, BOTH arms:
 *   - a TWO-RULE compose descends add(mul(x,2),0) to the cheapest proven-equal
 *     realization shl(x,1) (strict cost drop, head = shl);
 *   - the cost-field ranks mul dearer than shl (cost_lattice);
 *   - the FAITHFULNESS falsifier: with NO rules registered, the SAME term does NOT
 *     descend (head stays add) -- the optimizer never fabricates an equality. */
fn sov_isa_kat() -> u64 @export {
    /* ---------- positive: add(mul(x, c2), c0) --rules--> shl(x, c1) ---------- */
    eg_init()
    cl_init()
    let cx   : u32 = si_leaf(SI_X)
    let cc2  : u32 = si_leaf(SI_C2)
    let cc0  : u32 = si_leaf(SI_C0)
    let cmul : u32 = si_node2(SI_MUL, cx, cc2)
    let cadd : u32 = si_node2(SI_ADD, cmul, cc0)
    if cadd == SI_SENT { return 1u64 }
    /* seed shl(x, c1) so the shl/c1 slots exist for the rule RHS + cost table */
    let cc1  : u32 = si_leaf(SI_C1)
    let cseed : u32 = si_node2(SI_SHL, cx, cc1)
    if cseed == SI_SENT { return 2u64 }
    if sov_isa_rules() != 0u32 { return 3u64 }

    let otp : *u32 = (&SI_OUT) as u64 as *u32
    let onp : *u32 = (&SI_OUTN) as u64 as *u32
    let rc : i32 = sov_isa_descend(cadd, otp, onp)
    if rc != 0i32 { return 4u64 }
    let s_shl : u32 = si_slot(SI_SHL)
    if SI_OUTN[0u32] != 3u32 { return 5u64 }       /* shl(x,c1): 3 preorder entries */
    if SI_OUT[0u32] != s_shl { return 6u64 }       /* head symbol is shl (the cheap form) */

    /* ---------- the cost-field ranks mul dearer than shl ---------- */
    if sov_isa_op_cost(SI_MUL) <= sov_isa_op_cost(SI_SHL) { return 7u64 }

    /* ---------- FAITHFULNESS falsifier: NO rules => NO descent ---------- */
    eg_init()
    cl_init()
    let dx   : u32 = si_leaf(SI_X)
    let dc2  : u32 = si_leaf(SI_C2)
    let dc0  : u32 = si_leaf(SI_C0)
    let dmul : u32 = si_node2(SI_MUL, dx, dc2)
    let dadd : u32 = si_node2(SI_ADD, dmul, dc0)
    let dc1  : u32 = si_leaf(SI_C1)
    let dseed : u32 = si_node2(SI_SHL, dx, dc1)
    if dseed == SI_SENT { return 8u64 }
    /* NO sov_isa_rules() here -- the e-class is the singleton {add(mul(x,c2),c0)}. */
    let rc2 : i32 = sov_isa_descend(dadd, otp, onp)
    if rc2 != 0i32 { return 9u64 }
    let s_add : u32 = si_slot(SI_ADD)
    if SI_OUT[0u32] != s_add { return 10u64 }      /* head still add: no fabricated equality */

    return 99u64
}

/* KAT [wave-4 M13]: RULE REGISTRATION IS KERNEL CITATION -- the uniform contract.  Every core
 * rule (A/B/C/D/F/G) is re-proven by the CIC kernel at registration, every boot; a refused
 * citation fails rules() LOUDLY.  Teeth: (1) the citations PASS (rules() == 0 on a seeded
 * graph); (2) the citations DISCRIMINATE -- the kernel REFUSES each family's wrong-shape twin
 * (x*2 vs x<<2; x+0 vs 0; x*1 vs 1; 1+1 vs 1), so a corrupted rule could never come up.
 * 99 = the optimizer's whole foundation is live-proven, not comment-trusted. */
fn sov_isa_citation_kat() -> u64 @export {
    eg_init()
    cl_init()
    let cx : u32 = si_leaf(SI_X)
    let cc2 : u32 = si_leaf(SI_C2)
    let cc0 : u32 = si_leaf(SI_C0)
    let cc1 : u32 = si_leaf(SI_C1)
    let seed1 : u32 = si_node2(SI_MUL, cx, cc2)
    let seed2 : u32 = si_node2(SI_ADD, cx, cc0)
    let seed3 : u32 = si_node2(SI_SHL, cx, cc1)
    if seed1 == SI_SENT { return 1u64 }
    if seed2 == SI_SENT { return 2u64 }
    if seed3 == SI_SENT { return 3u64 }
    if sov_isa_rules() != 0u32 { return 4u64 }      /* (1) every core citation passed */
    /* (2) the wrong-shape twins are REFUSED by the kernel */
    tc_reset()
    let kx : u32 = tc_var(0u32)
    let k0 : u32 = tc_bvlit_u64(0u64)
    let k1 : u32 = tc_bvlit_u64(1u64)
    let k2 : u32 = tc_bvlit_u64(2u64)
    if tc_conv(tc_bvmul(kx, k2), tc_bvshl(kx, k2)) != 0u8 { return 5u64 }   /* x*2 != x<<2 */
    if tc_conv(tc_bvadd(kx, k0), k0) != 0u8 { return 6u64 }                  /* x+0 != 0 */
    if tc_conv(tc_bvmul(kx, k1), k1) != 0u8 { return 7u64 }                  /* x*1 != 1 */
    if tc_conv(tc_bvadd(k1, k1), k1) != 0u8 { return 8u64 }                  /* 1+1 != 1 */
    return 99u64
}

/* KAT [wave-4 M12]: KERNEL-CITED DIVISION STRENGTH REDUCTION.  div(x,2) descends to shr(x,1)
 * -- Rule I, admitted only because the CIC kernel certifies THE DIV-STRENGTH IOTA (x/2 == x>>1,
 * ledger 8.29) at registration.  Teeth: (a) the reduction fires (head shr, count c1); (b) the
 * kernel citation is POSITIVE in-module AND the kernel REFUSES the false law (x/3 vs x>>1) --
 * a wrong rule could never register; (c) the cost field ranks div DEARER than shr (the gradient
 * that makes the reduction worth taking); (d) faithfulness (no rules => head stays div).
 * 99 = never hard-coded. */
fn sov_isa_divstrength_kat() -> u64 @export {
    eg_init()
    cl_init()
    let cx : u32 = si_leaf(SI_X)
    let cc2 : u32 = si_leaf(SI_C2)
    let root : u32 = si_node2(SI_DIV, cx, cc2)
    if root == SI_SENT { return 1u64 }
    let cc1 : u32 = si_leaf(SI_C1)
    let cseed : u32 = si_node2(SI_SHR, cx, cc1)     /* seed shr(x,c1) slots for the RHS */
    if cseed == SI_SENT { return 2u64 }
    if sov_isa_rules() != 0u32 { return 3u64 }
    let otp : *u32 = (&SI_OUT) as u64 as *u32
    let onp : *u32 = (&SI_OUTN) as u64 as *u32
    if sov_isa_descend(root, otp, onp) != 0i32 { return 4u64 }
    let s_shr : u32 = si_slot(SI_SHR)
    let s_c1 : u32 = si_slot(SI_C1)
    if SI_OUTN[0u32] != 3u32 { return 5u64 }
    if SI_OUT[0u32] != s_shr { return 6u64 }         /* head is shr: strength-reduced */
    if SI_OUT[2u32] != s_c1 { return 7u64 }
    /* (b) the kernel citation, both arms, in-module */
    tc_reset()
    let kx : u32 = tc_var(0u32)
    if tc_conv(tc_bvudiv(kx, tc_bvlit_u64(2u64)), tc_bvlshr(kx, tc_bvlit_u64(1u64))) != 1u8 { return 8u64 }
    if tc_conv(tc_bvudiv(kx, tc_bvlit_u64(3u64)), tc_bvlshr(kx, tc_bvlit_u64(1u64))) != 0u8 { return 9u64 }
    /* (c) the cost gradient: division is dearer than the shift */
    if sov_isa_op_cost(SI_DIV) <= sov_isa_op_cost(SI_SHR) { return 10u64 }
    /* (d) faithfulness: no rules => no reduction */
    eg_init()
    cl_init()
    let dx : u32 = si_leaf(SI_X)
    let dc2 : u32 = si_leaf(SI_C2)
    let droot : u32 = si_node2(SI_DIV, dx, dc2)
    if sov_isa_descend(droot, otp, onp) != 0i32 { return 11u64 }
    let s_div : u32 = si_slot(SI_DIV)
    if SI_OUT[0u32] != s_div { return 12u64 }
    return 99u64
}

/* KAT [wave-4 M10]: THE LATTICE-CITED SHIFT COMBINE.  shl(shl(x,1),1) descends to shl(x,2) --
 * Rule H, admitted only because the 0xB7 registry certifies (a=1,b=1) by UNSAT at four widths.
 * Teeth: (a) the combine fires (5 preorder entries -> 3, head shl, count c2); (b) THE WALL is
 * cited in-module (the lattice REFUSES (40,40) -- the false silicon law can never become a
 * rule); (c) faithfulness (no rules => no combine).  99 = the optimizer does exactly what the
 * lattice proves, nothing more. */
fn sov_isa_shiftcombine_kat() -> u64 @export {
    eg_init()
    cl_init()
    let cx : u32 = si_leaf(SI_X)
    let cc1 : u32 = si_leaf(SI_C1)
    let inner : u32 = si_node2(SI_SHL, cx, cc1)
    let root : u32 = si_node2(SI_SHL, inner, cc1)
    if root == SI_SENT { return 1u64 }
    let cc2 : u32 = si_leaf(SI_C2)
    let cseed : u32 = si_node2(SI_SHL, cx, cc2)     /* seed shl(x,c2) slots for the RHS */
    if cseed == SI_SENT { return 2u64 }
    if sov_isa_rules() != 0u32 { return 3u64 }
    let otp : *u32 = (&SI_OUT) as u64 as *u32
    let onp : *u32 = (&SI_OUTN) as u64 as *u32
    if sov_isa_descend(root, otp, onp) != 0i32 { return 4u64 }
    let s_shl : u32 = si_slot(SI_SHL)
    let s_c2 : u32 = si_slot(SI_C2)
    if SI_OUTN[0u32] != 3u32 { return 5u64 }        /* combined: shl(x,c2) = 3 preorder entries */
    if SI_OUT[0u32] != s_shl { return 6u64 }
    if SI_OUT[2u32] != s_c2 { return 7u64 }          /* the count is c2: genuinely combined */
    /* (b) THE WALL, cited in-module: the false silicon law is REFUSED by the lattice */
    if cga_dispose_shift(2u32, 40u32, 40u32, 1u32) != 0u8 { return 8u64 }
    /* (c) faithfulness: no rules => no combine (the 5-entry original stays) */
    eg_init()
    cl_init()
    let dx : u32 = si_leaf(SI_X)
    let dc1 : u32 = si_leaf(SI_C1)
    let dinner : u32 = si_node2(SI_SHL, dx, dc1)
    let droot : u32 = si_node2(SI_SHL, dinner, dc1)
    if sov_isa_descend(droot, otp, onp) != 0i32 { return 9u64 }
    if SI_OUTN[0u32] != 5u32 { return 10u64 }
    return 99u64
}

/* KAT: the enriched optimizer collapses (x*1) + (x*0) to a single leaf x via THREE
 * composing rules -- C (x*1->x), D (x*0->0), B (x+0->x) -- a 7-node expression to 1
 * node.  Every rule kernel-certified sound (corpus 875).  + the faithfulness
 * falsifier: with NO rules the same term does NOT collapse (head stays add).
 * 99 = the collapse + the falsifier pass. */
fn sov_isa_kat2() -> u64 @export {
    eg_init()
    cl_init()
    let ex   : u32 = si_leaf(SI_X)
    let ec1  : u32 = si_leaf(SI_C1)
    let ec0  : u32 = si_leaf(SI_C0)
    let em1  : u32 = si_node2(SI_MUL, ex, ec1)     /* x*1 */
    let em0  : u32 = si_node2(SI_MUL, ex, ec0)     /* x*0 */
    let esum : u32 = si_node2(SI_ADD, em1, em0)    /* (x*1) + (x*0) */
    if esum == SI_SENT { return 1u64 }
    /* seed shl + c2 so every op slot exists for the rule set + cost table */
    let ec2  : u32 = si_leaf(SI_C2)
    let eshl : u32 = si_node2(SI_SHL, ex, ec1)
    if eshl == SI_SENT { return 2u64 }
    if sov_isa_rules() != 0u32 { return 3u64 }

    let otp : *u32 = (&SI_OUT) as u64 as *u32
    let onp : *u32 = (&SI_OUTN) as u64 as *u32
    let rc : i32 = sov_isa_descend(esum, otp, onp)
    if rc != 0i32 { return 4u64 }
    let s_x : u32 = si_slot(SI_X)
    if SI_OUTN[0u32] != 1u32 { return 5u64 }       /* collapsed to a SINGLE leaf */
    if SI_OUT[0u32] != s_x { return 6u64 }         /* the leaf is x */

    /* FAITHFULNESS falsifier: NO rules => NO collapse (head stays add). */
    eg_init()
    cl_init()
    let dx   : u32 = si_leaf(SI_X)
    let dc1  : u32 = si_leaf(SI_C1)
    let dc0  : u32 = si_leaf(SI_C0)
    let dm1  : u32 = si_node2(SI_MUL, dx, dc1)
    let dm0  : u32 = si_node2(SI_MUL, dx, dc0)
    let dsum : u32 = si_node2(SI_ADD, dm1, dm0)
    let dc2  : u32 = si_leaf(SI_C2)
    let dshl : u32 = si_node2(SI_SHL, dx, dc1)
    if dshl == SI_SENT { return 7u64 }
    let rc2 : i32 = sov_isa_descend(dsum, otp, onp)
    if rc2 != 0i32 { return 8u64 }
    let s_add : u32 = si_slot(SI_ADD)
    if SI_OUT[0u32] != s_add { return 9u64 }       /* unchanged: head still add */

    /* CONSTANT FOLDING: add(c1,c1) folds to the literal c2 (ground rule F). */
    eg_init()
    cl_init()
    let fx  : u32 = si_leaf(SI_X)
    let fc1 : u32 = si_leaf(SI_C1)
    let fc2 : u32 = si_leaf(SI_C2)
    let fc0 : u32 = si_leaf(SI_C0)
    let fadd : u32 = si_node2(SI_ADD, fc1, fc1)    /* 1 + 1 */
    let fm : u32 = si_node2(SI_MUL, fx, fc1)       /* seed mul slot */
    let fs : u32 = si_node2(SI_SHL, fx, fc1)       /* seed shl slot */
    if fs == SI_SENT { return 10u64 }
    if sov_isa_rules() != 0u32 { return 11u64 }
    let rc3 : i32 = sov_isa_descend(fadd, otp, onp)
    if rc3 != 0i32 { return 12u64 }
    let s_c2 : u32 = si_slot(SI_C2)
    if SI_OUTN[0u32] != 1u32 { return 13u64 }      /* folds to a single literal */
    if SI_OUT[0u32] != s_c2 { return 14u64 }       /* the literal is c2 (= 2) */

    return 99u64
}

/* ============================================================
 *  PROOF-CARRYING OPTIMIZATION (DOCS/III-SOVEREIGN-CALCULUS-DESIGN.md §11).
 *  The egraph (untrusted "nous") PROPOSES an optimization; III's kernel (the TRUSTED
 *  core) DISPOSES -- it independently re-derives input == output as a theorem and
 *  accepts the optimization only if it can PROVE it.  Translation validation:
 *  soundness never depends on the egraph being correct.  Nous gets full liberty
 *  precisely because the kernel leashes it. */

/* the kernel succ-function (lam n:Nat. succ n), closed. */
fn sov_succf() -> u32 {
    return tc_lam(tc_nat(), tc_succ(tc_var(0u32)))
}
/* Nat model: add(a,b) = iter(a, succ, b). */
fn sov_m_add(a: u32, b: u32) -> u32 {
    return tc_iter(a, SOV_SUCCF[0u32], b)
}
/* Nat model: mul(a,b) = iter(0, (lam acc. add(a^1, acc)), b); a^1 shifts a past acc. */
fn sov_m_mul(a: u32, b: u32) -> u32 {
    let step : u32 = tc_lam(tc_nat(), tc_iter(tc_shift_k(a, 1u32), SOV_SUCCF[0u32], tc_var(0u32)))
    return tc_iter(tc_zero(), step, b)
}

/* lower the egraph output preorder (symbol slots) to a kernel Nat-model.  Uses the
 * module cursor SOV_LP; SOV_SUCCF must be set.  x -> #0, cK -> numeral, add/mul ->
 * the Nat models, shl1(a) -> add(a,a) (the descent only emits shift-by-1). */
fn sov_lower(out_term: *u32) -> u32 {
    let pos : u32 = SOV_LP[0u32]
    SOV_LP[0u32] = pos + 1u32
    let pb : u64 = pos as u64
    let slot : u32 = out_term[pb]
    if slot == si_slot(SI_X)  { return tc_var(0u32) }
    if slot == si_slot(SI_C0) { return tc_zero() }
    if slot == si_slot(SI_C1) { return tc_succ(tc_zero()) }
    if slot == si_slot(SI_C2) { return tc_succ(tc_succ(tc_zero())) }
    if slot == si_slot(SI_ADD) {
        let aa : u32 = sov_lower(out_term)
        let bb : u32 = sov_lower(out_term)
        return sov_m_add(aa, bb)
    }
    if slot == si_slot(SI_MUL) {
        let ma : u32 = sov_lower(out_term)
        let mb : u32 = sov_lower(out_term)
        return sov_m_mul(ma, mb)
    }
    if slot == si_slot(SI_SHL) {
        let sa      : u32 = sov_lower(out_term)   /* the value being shifted */
        let s_shift : u32 = sov_lower(out_term)   /* shift-amount child: lowered ONLY to advance the
                                                   * preorder cursor (stream integrity).  Intentionally
                                                   * UNUSED -- shl(a,1) is modeled as add(a,a) in the Nat
                                                   * model regardless of the shift constant.  (iii permits
                                                   * the unused binding; the call's SIDE EFFECT is required.) */
        return sov_m_add(sa, sa)
    }
    return 0u32
}

/* Integration C trit pre-filter: per-position rigid-head compatibility.
 * both rigid + equal -> TRUE(+1); both rigid + different -> FALSE(-1);
 * either DEFER(0) -> UNKNOWN(0). */
fn shape_pos(x: u32, y: u32) -> i32 {
    if x == 0u32 { return 0i32 }
    if y == 0u32 { return 0i32 }
    if x == y { return 1i32 }
    return -1i32
}

/* shape_compatible: Kleene-AND fold (iii_trit_and) of the head + two sub-head
 * positions of the two terms' shape signatures.  -1 = SOUNDLY incompatible (a
 * position carries two DIFFERENT rigid heads => the terms cannot be convertible
 * => safe fast reject); 0 = unknown (defer to the kernel); +1 = shallow-
 * compatible (STILL defer -- the kernel alone decides convertibility). */
fn shape_compatible(a_term: u32, b_term: u32) -> i32 {
    let sa : u32 = tc_shape_sig(a_term)
    let sb : u32 = tc_shape_sig(b_term)
    if sa == 0u32 { return 0i32 }
    if sb == 0u32 { return 0i32 }
    let mut acc : i32 = shape_pos((sa >> 16u32) & 0xFFu32, (sb >> 16u32) & 0xFFu32)
    acc = iii_trit_and(acc, shape_pos((sa >> 8u32) & 0xFFu32, (sb >> 8u32) & 0xFFu32))
    acc = iii_trit_and(acc, shape_pos(sa & 0xFFu32, sb & 0xFFu32))
    return acc
}

/* THE KERNEL VERIFIER (translation validation), unfiltered core: an optimization
 * in_model -> out_model is sound iff the kernel proves in == out, i.e.
 * (lam x:Nat. refl in) checks against Pi(x:Nat). Id Nat in out.  The kernel is
 * the SOLE arbiter.  1 = certified sound; 0 = REJECTED. */
fn sov_pcc_verify_core(in_model: u32, out_model: u32) -> u8 @export {
    let cert : u32 = tc_lam(tc_nat(), tc_refl(in_model))
    let goal : u32 = tc_pi(tc_nat(), tc_id(tc_nat(), in_model, out_model))
    return tc_check(cert, goal)
}

/* Guarded verifier: a SOUND shape pre-filter short-circuits to REJECT when the
 * two models have rigidly-incompatible WHNF heads (shape_compatible == FALSE),
 * sparing the kernel a doomed conversion.  The filter NEVER accepts -- every
 * acceptance is still the kernel core's verdict, so translation validation is
 * unchanged; only provably-doomed checks are skipped. */
fn sov_pcc_verify(in_model: u32, out_model: u32) -> u8 @export {
    if shape_compatible(in_model, out_model) == -1i32 { return 0u8 }
    return sov_pcc_verify_core(in_model, out_model)
}

/* PROOF-CARRYING DESCENT: descend input (egraph), lower the output to a kernel model,
 * and KERNEL-VERIFY it equals the caller's input model.  1 = accept (output in
 * out_term/out_n, kernel-certified sound); 0 = reject. */
fn sov_pcc(input_egraph: u32, input_model: u32, out_term: *u32, out_n: *u32) -> u8 @export {
    let rc : i32 = sov_isa_descend(input_egraph, out_term, out_n)
    if rc != 0i32 { return 0u8 }
    SOV_SUCCF[0u32] = sov_succf()
    SOV_LP[0u32] = 0u32
    let out_model : u32 = sov_lower(out_term)
    if out_model == 0u32 { return 0u8 }
    return sov_pcc_verify(input_model, out_model)
}

/* KAT: the proof-carrying descent.  Positive: (x*1)+(x*0) descends to x and the kernel
 * CERTIFIES the optimization sound.  Falsifier: a tampered "optimization" (x -> x*2)
 * is REJECTED -- the leash holds even if nous lies.  99 = all pass. */
fn sov_pcc_kat() -> u64 @export {
    eg_init()
    cl_init()
    tc_reset()
    let ex  : u32 = si_leaf(SI_X)
    let ec1 : u32 = si_leaf(SI_C1)
    let ec0 : u32 = si_leaf(SI_C0)
    let em1 : u32 = si_node2(SI_MUL, ex, ec1)
    let em0 : u32 = si_node2(SI_MUL, ex, ec0)
    let esum : u32 = si_node2(SI_ADD, em1, em0)
    let ec2 : u32 = si_leaf(SI_C2)
    let eshl : u32 = si_node2(SI_SHL, ex, ec1)
    if eshl == SI_SENT { return 1u64 }
    if sov_isa_rules() != 0u32 { return 2u64 }

    /* the input's kernel Nat-model: add(mul(x,1), mul(x,0)) */
    SOV_SUCCF[0u32] = sov_succf()
    let imodel : u32 = sov_m_add(sov_m_mul(tc_var(0u32), tc_succ(tc_zero())), sov_m_mul(tc_var(0u32), tc_zero()))

    let otp : *u32 = (&SI_OUT) as u64 as *u32
    let onp : *u32 = (&SI_OUTN) as u64 as *u32
    /* (1-2) PROOF-CARRYING: descend + kernel-verify -> ACCEPT, and it optimized to x */
    if sov_pcc(esum, imodel, otp, onp) != 1u8 { return 3u64 }
    if SI_OUT[0u32] != si_slot(SI_X) { return 4u64 }

    /* (3) FALSIFIER: a tampered output (x -> x*2) is REJECTED (kernel disproves x==2x) */
    let x2model : u32 = sov_m_mul(tc_var(0u32), tc_succ(tc_succ(tc_zero())))
    if sov_pcc_verify(imodel, x2model) != 0u8 { return 5u64 }

    /* (4) control: the verifier ACCEPTS a true equality (x == x) */
    if sov_pcc_verify(tc_var(0u32), tc_var(0u32)) != 1u8 { return 6u64 }

    return 99u64
}

/* THE SELF-IMPROVEMENT LOOP, REALIZED on the freshly-added Rule G (mul(c1,c2) -> c2).  III improves +
 * extends its OWN optimizer via its OWN reasoning, kernel-governed -- no rigging:
 *   (1) IMPROVEMENT: with the rules registered, mul(c1,c2) now descends to the literal c2 (a SINGLE
 *       node) -- a fold the optimizer GAINED (pre-G it reached only shl(c1,c1), 3 nodes).
 *   (2) KERNEL DISPOSES: the CIC kernel CERTIFIES the rule sound -- sov_m_mul(1,2) is convertible to 2.
 *   (3) KERNEL GOVERNS: the kernel REJECTS the meaning-changing variant 1*2 == 1 (un-riggable).
 * The optimization is the e-graph's (untrusted); every soundness verdict is the kernel's.  99 = pass. */
fn sov_isa_selfext_kat() -> u64 @export {
    eg_init()
    cl_init()
    tc_reset()
    let gx  : u32 = si_leaf(SI_X)
    let gc1 : u32 = si_leaf(SI_C1)
    let gc2 : u32 = si_leaf(SI_C2)
    let gc0 : u32 = si_leaf(SI_C0)
    let gprod : u32 = si_node2(SI_MUL, gc1, gc2)         /* the ground term 1 * 2 */
    let gseed : u32 = si_node2(SI_SHL, gx, gc1)          /* seed shl/c1 slots (Rule A RHS + cost table) */
    if gseed == SI_SENT { return 1u64 }
    if sov_isa_rules() != 0u32 { return 2u64 }

    /* (1) IMPROVEMENT: mul(1,2) now folds to the literal c2 (single node), not shl(1,1) */
    let otp : *u32 = (&SI_OUT) as u64 as *u32
    let onp : *u32 = (&SI_OUTN) as u64 as *u32
    if sov_isa_descend(gprod, otp, onp) != 0i32 { return 3u64 }
    if SI_OUTN[0u32] != 1u32 { return 4u64 }             /* folded to a SINGLE node */
    if SI_OUT[0u32] != si_slot(SI_C2) { return 5u64 }    /* and it is the literal 2 */

    /* (2) KERNEL DISPOSES: the kernel CERTIFIES 1*2 == 2 (the rule is sound) */
    SOV_SUCCF[0u32] = sov_succf()
    let m_1x2 : u32 = sov_m_mul(tc_succ(tc_zero()), tc_succ(tc_succ(tc_zero())))
    let m_2   : u32 = tc_succ(tc_succ(tc_zero()))
    if sov_pcc_verify(m_1x2, m_2) != 1u8 { return 6u64 }

    /* (3) KERNEL GOVERNS: the kernel REJECTS 1*2 == 1 (meaning-changing -> un-riggable) */
    let m_1   : u32 = tc_succ(tc_zero())
    if sov_pcc_verify(m_1x2, m_1) != 0u8 { return 7u64 }

    return 99u64
}

/* ============================================================
 *  PATH C: the kernel-GOVERNED codegen optimizer (DOCS/III-OPTIMIZER-PATH-C.md).
 *  The compiler's codegen rewrite rules are admitted ONLY IF III itself certifies them:
 *  (a) the WIDTH-INVARIANCE GUARD admits a rule only when its equivalence holds at EVERY bit width,
 *      and (b) the CIC kernel PROVES the (unbounded) equivalence.  The guard is load-bearing: the
 *      kernel's Nat model is unary/UNBOUNDED, so it would FALSELY "prove" a width-SENSITIVE rule
 *      (const-fold under overflow) -- the guard, not the kernel, keeps those out of codegen. */
const OPT_EMIT_SHIFTMASK : u32 = 1u32   /* emit transforms the LIVE operand by a width-commuting op (shl/shr/and) */
const OPT_EMIT_LITERAL   : u32 = 2u32   /* emit is a pure literal (a const-fold result) -- the UNBOUNDED value */

/* WIDTH-INVARIANCE GUARD: a rule is admissible iff its equivalence is width-invariant -- i.e. it
 * commutes with truncation mod 2^w, so the idealized (unbounded) kernel proof transfers to every
 * width.  Shift/mask of the live operand: YES.  A pure-literal emit (const-fold): NO -- its value is
 * the unbounded computation, which diverges from the width-w runtime under overflow.  REJECT the
 * literal class until a fixed-width (mod-2^w) kernel theory exists. */
fn opt_rule_width_invariant(emit_kind: u32) -> u8 {
    if emit_kind == OPT_EMIT_SHIFTMASK { return 1u8 }
    return 0u8
}

/* THE PATH-C CERTIFIER: III governs its own codegen optimizer.  99 = the optimizer rule the compiler
 * applies is (kernel-PROVEN sound for the base case) AND (admitted only by the width-invariance guard),
 * and a width-sensitive rule is REFUSED even though the unary kernel would accept its equivalence. */
fn sov_opt_certify_kat() -> u64 @export {
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    let x : u32 = tc_var(0u32)
    /* (1) KERNEL PROOF: III CERTIFIES the base strength-reduction rule  mul(x,2) == shl(x,1)  (modeled add(x,x)). */
    let mul_x_2 : u32 = sov_m_mul(x, tc_succ(tc_succ(tc_zero())))
    let add_x_x : u32 = sov_m_add(x, x)
    if sov_pcc_verify(mul_x_2, add_x_x) != 1u8 { return 1u64 }
    /* (2) GOVERNANCE: the kernel REJECTS the meaning-changing mul(x,2) == mul(x,1) -- un-riggable. */
    let mul_x_1 : u32 = sov_m_mul(x, tc_succ(tc_zero()))
    if sov_pcc_verify(mul_x_2, mul_x_1) != 0u8 { return 2u64 }
    /* (3) GUARD admits the strength-reduction family (shift/mask of the live operand). */
    if opt_rule_width_invariant(OPT_EMIT_SHIFTMASK) != 1u8 { return 3u64 }
    /* (4) THE SOUNDNESS CONTRIBUTION: the kernel ACCEPTS the unbounded fold 2*2 == 4, yet the guard
     * still REFUSES the const-fold class -- catching exactly what the unary kernel cannot (overflow). */
    let mul_2_2 : u32 = sov_m_mul(tc_succ(tc_succ(tc_zero())), tc_succ(tc_succ(tc_zero())))
    let nat_4   : u32 = tc_succ(tc_succ(tc_succ(tc_succ(tc_zero()))))
    if sov_pcc_verify(mul_2_2, nat_4) != 1u8 { return 4u64 }
    if opt_rule_width_invariant(OPT_EMIT_LITERAL) != 0u8 { return 5u64 }
    return 99u64
}

/* ============================================================
 *  PSI -- DETERMINISTIC SUPERPOSITION (DOCS/III-SOVEREIGN-CALCULUS-DESIGN.md §12).
 *  The no-downsides quantum-like invocation: an e-class is a SUPERPOSITION (all
 *  proven-equal realizations of a value held at once); saturation explores them
 *  simultaneously; psi_collapse is DETERMINISTIC measurement (cost-optimal, no
 *  probability); psi_interfere is a kernel-gated coherent merge; the kernel's proof
 *  of equivalence is COHERENCE (no decoherence).  No floats, no probability, no ML. */

/* psi_of: the superposition of an arithmetic term's equivalence class -- register the
 * kernel-certified rules + saturate.  Returns the e-class root (the psi handle). */
fn psi_of(root: u32) -> u32 @export {
    sov_isa_rules()
    eg_saturate(16u32)
    return eg_find(root)
}

/* psi_card: the superposition's cardinality -- how many distinct realizations are held
 * at once.  > 1 == a genuine superposition. */
fn psi_card(psi: u32) -> u32 @export {
    return eg_class_size(psi)
}

/* psi_collapse: DETERMINISTIC measurement -- extract the cost-optimal realization (the
 * cost-field is the observable).  No probability; reproducible (bit-identical replay). */
fn psi_collapse(psi: u32, out_term: *u32, out_n: *u32) -> i32 @export {
    let mut i : u32 = 0u32
    while i < 256u32 { SI_REQ[i] = 0u32 ; i = i + 1u32 }
    SI_REQ[0u32] = eg_find(psi)
    SI_REQ[1u32] = eg_sym_count()
    si_setcost(SI_X)
    si_setcost(SI_C0)
    si_setcost(SI_C1)
    si_setcost(SI_C2)
    si_setcost(SI_ADD)
    si_setcost(SI_MUL)
    si_setcost(SI_SHL)
    let reqp : *u32 = (&SI_REQ) as u64 as *u32
    return eg_extract(reqp, out_term, out_n)
}

/* psi_interfere: coherent merge of two superpositions -- ONLY if the kernel proves
 * their values equal (sov_pcc_verify on the Nat-models m1,m2).  Constructive
 * interference: the e-classes union.  A non-equal merge is REJECTED (no decoherence
 * into contradiction).  1 = merged; 0 = rejected. */
fn psi_interfere(r1: u32, r2: u32, m1: u32, m2: u32) -> u8 @export {
    if sov_pcc_verify(m1, m2) != 1u8 { return 0u8 }
    eg_union(r1, r2)
    eg_rebuild()
    return 1u8
}

/* KAT: deterministic superposition.  (a) a term's superposition holds MULTIPLE
 * realizations at once (card>1); (b) it COLLAPSES deterministically to the optimum;
 * (c) re-collapse is identical (no probability); (d) two equal superpositions
 * INTERFERE (kernel-gated coherent merge); (e) FALSIFIER: a non-equal merge is
 * REJECTED.  99 = all pass. */
fn psi_kat() -> u64 @export {
    eg_init()
    cl_init()
    tc_reset()
    let ex  : u32 = si_leaf(SI_X)
    let ec1 : u32 = si_leaf(SI_C1)
    let ec0 : u32 = si_leaf(SI_C0)
    let em1 : u32 = si_node2(SI_MUL, ex, ec1)
    let em0 : u32 = si_node2(SI_MUL, ex, ec0)
    let esum : u32 = si_node2(SI_ADD, em1, em0)
    let ec2 : u32 = si_leaf(SI_C2)
    let eshl : u32 = si_node2(SI_SHL, ex, ec1)
    if eshl == SI_SENT { return 1u64 }

    let psi : u32 = psi_of(esum)
    /* (a) SUPERPOSITION: holds > 1 realization at once */
    if psi_card(psi) < 2u32 { return 2u64 }
    /* (b) MEASUREMENT: deterministic collapse to the optimum (x) */
    let otp : *u32 = (&SI_OUT) as u64 as *u32
    let onp : *u32 = (&SI_OUTN) as u64 as *u32
    if psi_collapse(psi, otp, onp) != 0i32 { return 3u64 }
    if SI_OUT[0u32] != si_slot(SI_X) { return 4u64 }
    let first : u32 = SI_OUT[0u32]
    /* (c) DETERMINISM: re-collapse identical (no probability) */
    if psi_collapse(psi, otp, onp) != 0i32 { return 5u64 }
    if SI_OUT[0u32] != first { return 6u64 }

    /* (d-e) INTERFERENCE -- fresh nodes (no rules => separate classes); the KERNEL gates the merge. */
    eg_init()
    cl_init()
    tc_reset()
    let ix  : u32 = si_leaf(SI_X)
    let ic1 : u32 = si_leaf(SI_C1)
    let im1 : u32 = si_node2(SI_MUL, ix, ic1)      /* x*1 (its own class) */
    SOV_SUCCF[0u32] = sov_succf()
    let mm1 : u32 = sov_m_mul(tc_var(0u32), tc_succ(tc_zero()))   /* model x*1 (== x) */
    let mx  : u32 = tc_var(0u32)                                  /* model x */
    /* (d) coherent merge: x*1 == x -> union */
    if psi_interfere(im1, ix, mm1, mx) != 1u8 { return 7u64 }
    if eg_find(im1) != eg_find(ix) { return 8u64 }   /* interfered (merged) */
    /* (e) FALSIFIER: x*1 vs x*2 (not equal) -> REJECTED */
    let ic2 : u32 = si_leaf(SI_C2)
    let im2 : u32 = si_node2(SI_MUL, ix, ic2)
    let mm2 : u32 = sov_m_mul(tc_var(0u32), tc_succ(tc_succ(tc_zero())))  /* model x*2 (== 2x) */
    if psi_interfere(im1, im2, mm1, mm2) != 0u8 { return 9u64 }   /* non-equal: not merged */

    return 99u64
}

/* ============================================================
 *  THE CONTINGENT EVOLUTION DRIVER (DOCS/III-SOVEREIGN-CALCULUS-DESIGN.md §13).
 *  Files self-optimize and changes propagate -- DETERMINISTICALLY + COHERENTLY:
 *    self-optimize : psi_collapse -> the optimized form (deterministic measurement);
 *    content-address: rn_publish the optimized form -> its address (equal optima
 *                     CONVERGE to one address; a different optimum -> a new address);
 *    propagate     : a computed cell = H(input addresses); rn_ripple recomputes to a
 *                    fixpoint -- a changed source propagates; an unchanged (re-optimized,
 *                    deterministic) source does NOT (no spurious evolution, no drift).
 *  Reuses psi (numera/sov_isa) + the ripple network (forcefield/ripple).  No floats,
 *  no observation, no ML -- the files learn by deterministic re-descent. */

fn ev_eq32(a: *u8, ao: u64, b: *u8, bo: u64) -> u8 {
    let mut k : u64 = 0u64
    let mut eq : u8 = 1u8
    while k < 32u64 {
        if a[ao + k] != b[bo + k] { eq = 0u8 }
        k = k + 1u64
    }
    return eq
}
fn ev_stu64(p: *u8, off: u64, v: u64) -> u64 {
    let mut i : u64 = 0u64
    let mut x : u64 = v
    while i < 8u64 {
        p[off + i] = (x & 0xFFu64) as u8
        x = x >> 8u64
        i = i + 1u64
    }
    return 0u64
}
fn ev_copy32(dst: *u8, doff: u64, src: *u8, soff: u64) -> u64 {
    let mut k : u64 = 0u64
    while k < 32u64 {
        dst[doff + k] = src[soff + k]
        k = k + 1u64
    }
    return 0u64
}

fn sov_evolve_kat() -> u64 @export {
    let metap : *u8 = (&EV_META) as u64 as *u8
    let slotp : *u8 = (&EV_SLOTS) as u64 as *u8
    let arenp : *u8 = (&EV_ARENA) as u64 as *u8
    let outp  : *u32 = (&SI_OUT) as u64 as *u32
    let onp   : *u32 = (&SI_OUTN) as u64 as *u32
    let outb  : *u8  = (&SI_OUT) as u64 as *u8
    let axp   : *u8  = (&EV_ADDRX) as u64 as *u8
    let shlp  : *u8  = (&EV_ADDRSHL) as u64 as *u8
    let newp  : *u8  = (&EV_NEW) as u64 as *u8
    let cap   : *u8  = (&EV_CA) as u64 as *u8
    let ckp   : *u8  = (&EV_CK) as u64 as *u8
    let ioffp : *u8  = (&EV_IOFF) as u64 as *u8
    let icntp : *u8  = (&EV_ICNT) as u64 as *u8
    let ilstp : *u8  = (&EV_ILIST) as u64 as *u8
    let scrp  : *u8  = (&EV_SCR) as u64 as *u8
    let snapp : *u8  = (&EV_C1SNAP) as u64 as *u8
    let rvp   : *u8  = (&EV_RESOLVE) as u64 as *u8
    let vbp   : *u8  = (&EV_VBUF) as u64 as *u8

    rn_store_init(metap, slotp, 8u64, 2048u64)

    /* --- optimize expr A = (x*1)+(x*0) -> x; content-address its optimum --- */
    eg_init()
    cl_init()
    let ax  : u32 = si_leaf(SI_X)                  /* x interned FIRST -> deterministic slot */
    let ac1 : u32 = si_leaf(SI_C1)
    let ac0 : u32 = si_leaf(SI_C0)
    let ac2 : u32 = si_leaf(SI_C2)
    let am1 : u32 = si_node2(SI_MUL, ax, ac1)
    let am0 : u32 = si_node2(SI_MUL, ax, ac0)
    let aA  : u32 = si_node2(SI_ADD, am1, am0)
    let ash : u32 = si_node2(SI_SHL, ax, ac1)
    if ash == SI_SENT { return 1u64 }
    let psiA : u32 = psi_of(aA)
    if psi_collapse(psiA, outp, onp) != 0i32 { return 2u64 }
    let alen : u64 = (SI_OUTN[0u32] as u64) * 4u64
    if rn_publish(metap, slotp, arenp, outb, 0u64, alen, axp, 0u64) != 0u64 { return 3u64 }

    /* (1) RESOLUTION: the optimum is retrievable by its address (tamper-checked) */
    if rn_resolve(metap, slotp, arenp, axp, 0u64, rvp, 0u64, 256u64, vbp) != alen { return 4u64 }

    /* (2) cell-graph: cell0 = source (= A's optimum); cell1 = computed (depends on cell0) */
    EV_CK[0u32] = 0u8
    EV_CK[1u32] = 1u8
    ev_copy32(cap, 0u64, axp, 0u64)                /* cell0.addr = addr(x) */
    ev_stu64(icntp, 0u64, 0u64)
    ev_stu64(icntp, 8u64, 1u64)
    ev_stu64(ioffp, 0u64, 0u64)
    ev_stu64(ioffp, 8u64, 0u64)
    ev_stu64(ilstp, 0u64, 0u64)                    /* cell1's input = cell0 */
    rn_ripple(metap, slotp, arenp, 2u64, ckp, cap, ioffp, icntp, ilstp, scrp, newp)
    ev_copy32(snapp, 0u64, cap, 32u64)             /* snapshot cell1's address */

    /* (3) DETERMINISM: re-optimize A -> same optimum -> same address -> no spurious ripple */
    eg_init()
    cl_init()
    let bx  : u32 = si_leaf(SI_X)
    let bc1 : u32 = si_leaf(SI_C1)
    let bc0 : u32 = si_leaf(SI_C0)
    let bc2 : u32 = si_leaf(SI_C2)
    let bm1 : u32 = si_node2(SI_MUL, bx, bc1)
    let bm0 : u32 = si_node2(SI_MUL, bx, bc0)
    let aB  : u32 = si_node2(SI_ADD, bm1, bm0)
    let bsh : u32 = si_node2(SI_SHL, bx, bc1)
    if bsh == SI_SENT { return 5u64 }
    let psiB : u32 = psi_of(aB)
    if psi_collapse(psiB, outp, onp) != 0i32 { return 6u64 }
    if rn_publish(metap, slotp, arenp, outb, 0u64, (SI_OUTN[0u32] as u64) * 4u64, newp, 0u64) != 0u64 { return 7u64 }
    if ev_eq32(newp, 0u64, axp, 0u64) == 0u8 { return 8u64 }    /* DETERMINISM: identical address */
    rn_ripple(metap, slotp, arenp, 2u64, ckp, cap, ioffp, icntp, ilstp, scrp, newp)
    if ev_eq32(cap, 32u64, snapp, 0u64) == 0u8 { return 9u64 }  /* no spurious change */

    /* (4) PROPAGATION: optimize D = x*2 -> x<<1 (different optimum) -> cell0 -> ripple changes cell1 */
    eg_init()
    cl_init()
    let dx  : u32 = si_leaf(SI_X)
    let dc1 : u32 = si_leaf(SI_C1)
    let dc0 : u32 = si_leaf(SI_C0)
    let dc2 : u32 = si_leaf(SI_C2)
    let dm  : u32 = si_node2(SI_MUL, dx, dc2)      /* x*2 */
    let dad : u32 = si_node2(SI_ADD, dx, dc0)      /* seed add slot */
    let dsh : u32 = si_node2(SI_SHL, dx, dc1)      /* seed shl slot */
    if dsh == SI_SENT { return 10u64 }
    let psiD : u32 = psi_of(dm)
    if psi_collapse(psiD, outp, onp) != 0i32 { return 11u64 }
    if rn_publish(metap, slotp, arenp, outb, 0u64, (SI_OUTN[0u32] as u64) * 4u64, shlp, 0u64) != 0u64 { return 12u64 }
    if ev_eq32(shlp, 0u64, axp, 0u64) == 1u8 { return 13u64 }   /* different optimum -> different address */
    ev_copy32(cap, 0u64, shlp, 0u64)               /* cell0 := D's optimum */
    rn_ripple(metap, slotp, arenp, 2u64, ckp, cap, ioffp, icntp, ilstp, scrp, newp)
    if ev_eq32(cap, 32u64, snapp, 0u64) == 1u8 { return 14u64 } /* cell1 CHANGED (propagation) */

    return 99u64
}

/* ============================================================
 *  KERNEL-GOVERNED RULE ADMISSION -- the system subject to itself.  A rewrite rule joins
 *  III's engine only if it passes BOTH gates, composed from EXISTING organs (no reinvention):
 *    - OPERATIONAL admissibility -- root-confluent AND terminating -- the decision
 *      omnia/xii_admission::xad_decide (the Knuth-Bendix-style admission gate);
 *    - SEMANTIC soundness -- the rule's two sides are KERNEL-PROVEN equal -- sov_pcc_verify
 *      (the §11 mechanism, numera/typecheck the trusted core).
 *  xii_admission alone admits ANY confluent+terminating rule -- even a MEANING-CHANGING one,
 *  because it gates OPERATION, not MEANING.  III's own proof kernel supplies precisely the
 *  missing gate, so III's rule admission is made SUBJECT TO III's kernel: the engine can never
 *  adopt a rule the kernel cannot prove meaning-preserving.  1 = admit; 0 = reject. */
fn sov_admit_rule(lhs_model: u32, rhs_model: u32, root_confluent: u32, terminating: u32) -> u8 @export {
    if sov_pcc_verify(lhs_model, rhs_model) != 1u8 { return 0u8 }       /* KERNEL: not meaning-preserving -> reject */
    if xad_decide(root_confluent, terminating) != 1u32 { return 0u8 }   /* XII: not operationally admissible -> reject */
    return 1u8
}

/* KAT: kernel-governed admission -- BOTH gates load-bearing, the kernel closing the semantic
 * gap xii_admission alone leaves open.  (1) a sound + admissible rule add(x,0)->x is ADMITTED;
 * (2) THE GAP -- add(x,0)->succ(x) is MEANING-CHANGING: xii_admission ALONE (xad_decide(1,1))
 * ADMITS it, the kernel-governed gate REJECTS it (same operational flags, opposite verdict by
 * MEANING -- the kernel caught what XII cannot see); (3) the operational gate still bites a
 * kernel-sound rule that is non-confluent / non-terminating.  Each gate rejects what the other
 * admits -> non-vacuous composition.  No ML, no observation.  99 = all pass. */
fn sov_admit_kat() -> u64 @export {
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    let x : u32 = tc_var(0u32)
    let z : u32 = tc_zero()
    let m_addx0 : u32 = sov_m_add(x, z)        /* add(x,0) -- LHS model (reduces to x) */
    let m_succx : u32 = tc_succ(x)             /* succ(x) -- a meaning-CHANGING RHS */

    /* (1) sound + operationally admissible -> ADMIT */
    if sov_admit_rule(m_addx0, x, 1u32, 1u32) != 1u8 { return 1u64 }

    /* (2) THE SEMANTIC GAP, closed: xii_admission alone ADMITS the meaning-changing rule... */
    if xad_decide(1u32, 1u32) != 1u32 { return 2u64 }                       /* XII operational: ADMIT */
    if sov_admit_rule(m_addx0, m_succx, 1u32, 1u32) != 0u8 { return 3u64 }   /* ...kernel-governed: REJECT */

    /* (3) the operational gate still bites a kernel-sound rule */
    if sov_admit_rule(m_addx0, x, 0u32, 1u32) != 0u8 { return 4u64 }   /* non-confluent  -> reject */
    if sov_admit_rule(m_addx0, x, 1u32, 0u32) != 0u8 { return 5u64 }   /* non-terminating -> reject */

    /* (4) controls: the kernel genuinely distinguishes meaning */
    if sov_pcc_verify(m_addx0, m_succx) != 0u8 { return 6u64 }         /* add(x,0) != succ(x) */
    if sov_pcc_verify(m_addx0, x) != 1u8 { return 7u64 }              /* add(x,0) == x */

    return 99u64
}

/* Integration C KAT: the SOUND conversion shape pre-filter.  Proves:
 *  (A) the filter FIRES a sound FALSE on rigidly-incompatible heads (zero vs
 *      succ) AND through the sub-head fold (succ 0 vs succ(succ 0) = 1 vs 2);
 *  (B) it never spuriously rejects equal / same-shaped terms;
 *  (C) it DEFERS (Kleene UNKNOWN) on a neutral (non-rigid var) head;
 *  (D) the SOUNDNESS DIFFERENTIAL -- the guarded verifier returns EXACTLY the
 *      unfiltered kernel verdict on every pair, so the filter changes no result;
 *  (E) those verdicts are the correct ones (0==0, 1==1 accepted; 0!=1, 1!=2
 *      rejected).  The kernel stays the sole arbiter of acceptance.  99 = pass. */
fn shape_filter_selftest() -> u64 @export {
    tc_reset()
    let z  : u32 = tc_zero()
    let s0 : u32 = tc_succ(z)
    let s1 : u32 = tc_succ(s0)
    let v0 : u32 = tc_var(0u32)
    let v1 : u32 = tc_var(1u32)
    /* (A) sound FALSE: head mismatch, then sub-head fold */
    if shape_compatible(z, s0)  != -1i32 { return 1u64 }
    if shape_compatible(s0, s1) != -1i32 { return 2u64 }
    /* (B) no spurious reject of equal / same-deferred-shape terms */
    if shape_compatible(z, z)   == -1i32 { return 3u64 }
    if shape_compatible(s0, s0) == -1i32 { return 4u64 }
    /* (C) defer (UNKNOWN = 0) on a neutral head */
    if shape_compatible(v0, z) != 0i32 { return 5u64 }
    if shape_compatible(z, v0) != 0i32 { return 6u64 }
    /* (D) soundness differential: guarded == unfiltered kernel on every pair */
    if sov_pcc_verify(z, z)   != sov_pcc_verify_core(z, z)   { return 7u64 }
    if sov_pcc_verify(z, s0)  != sov_pcc_verify_core(z, s0)  { return 8u64 }
    if sov_pcc_verify(s0, s0) != sov_pcc_verify_core(s0, s0) { return 9u64 }
    if sov_pcc_verify(s0, s1) != sov_pcc_verify_core(s0, s1) { return 10u64 }
    if sov_pcc_verify(v0, v0) != sov_pcc_verify_core(v0, v0) { return 11u64 }
    if sov_pcc_verify(v0, v1) != sov_pcc_verify_core(v0, v1) { return 12u64 }
    /* (E) the verdicts are the correct ones */
    if sov_pcc_verify(z, z)   != 1u8 { return 13u64 }
    if sov_pcc_verify(s0, s0) != 1u8 { return 14u64 }
    if sov_pcc_verify(z, s0)  != 0u8 { return 15u64 }
    if sov_pcc_verify(s0, s1) != 0u8 { return 16u64 }
    return 99u64
}

/* ============================================================
 *  THE SR-SCHEMA INDUCTION TOWER -- FOUNDATION RUNG.
 *
 *  The schema  Pi(x).Pi(k). Id(Nat, mul(x, pow2 k), iter(x, double, k))  (the symbolic
 *  shift-as-repeated-doubling identity) is UNREACHABLE through the existing refl path:
 *  with SYMBOLIC k the iterators are STUCK NEUTRALS, so refl cannot close it -- it forces
 *  tc_natrec INDUCTION over k, which in turn forces a propositional-congruence helper
 *  (ap under succ, built with the Id eliminator tc_j) and the additive Peano sub-tower.
 *
 *  This is the FOUNDATION: the base rung that every later rung stands on.
 *    (a) BASE_MUL_ONE : mul(x, 1) == x        -- refl-definitional (the iter on a CONCRETE
 *        numeral fully unrolls: mul(x,1) -> add(x,0) -> x); the kernel closes it by refl.
 *        KERNEL-VERIFIED (sov_pcc_verify_core == 1; neg control mul(x,2) == 0).
 *    (b) AP_SUCC      : Pi(a).Pi(b).Pi(p:Id(Nat,a,b)). Id(Nat, succ a, succ b)
 *        -- congruence of succ over a PROPOSITIONAL Id; NOT definitional, so tc_j is
 *        mandatory.  Every nat-induction STEP needs this.  Built CLOSED + applied.
 *        == the recipe's lemma_tower[0] (L0_helpers_cong_ap).  KERNEL-VERIFIED
 *        (tc_check(aps, goal) == 1; neg control wrong-congruence goal == 0).
 *
 *  PROVEN -- (c) ADD_LEFT_ZERO (L1) : Pi(b:Nat). Id(Nat, add(zero,b), b).  The FIRST tc_natrec rung.
 *  Over a symbolic b, add(zero,b) = iter(zero, succf, b) is a STUCK NEUTRAL, so refl cannot close it
 *  -- tc_natrec induction is mandatory, and the kernel's TC_NATREC rule shifts the IH type via
 *  tc_shift_k(stored_type, k+1).  That IH type carries the CLOSED step succf = (lam n. succ n).
 *  The kernel reducer used to MANGLE that shift (ccl_eta_contract eta-collapsed succf to a bare Succ
 *  that ccl_to_tc misreified as #0); that block is now FIXED (ccl_eta_contract refuses to eta-contract
 *  a head data-constructor / eliminator), so the shifted succf survives, the IH-lookup type matches the
 *  reconstructed step type, and the natrec STEP tc_checks.  KERNEL-VERIFIED: sov_l1_proven_witness
 *  asserts tc_check(L1_term, L1_goal) == 1 with biting negatives (wrong codomain succ b == 0; refl
 *  shortcut == 0) and the reducer-fix controls as a regression tripwire.
 *
 *  PROPOSE/DISPOSE: a lemma is sound ONLY because tc_check ACCEPTS it (returns 1).  The KAT
 *  exercises NEGATIVE controls (each must REJECT) so no 99 is vacuous. */

/* The CLOSED congruence helper  ap_succ : Pi(a:Nat).Pi(b:Nat).Pi(p:Id(Nat,a,b)). Id(Nat, succ a, succ b).
 * Proof: lam(a).lam(b).lam(p). J(C, refl(succ a), p), motive
 *   C := lam(y:Nat). lam(h:Id(Nat,a,y)). Id(Nat, succ a, succ y).
 * De-Bruijn (verified): in [a,b,p] a=#2,b=#1,p=#0 ; inside C's lam-y [a,b,p,y] a=#3,y=#0 ;
 * inside C's lam-h [a,b,p,y,h] a=#4,y=#1.  app(C,a) beta-reduces (y:=a) to Id(Nat,succ a,succ a)
 * = the type of refl(succ a); app(app(C,b),p) to Id(Nat,succ a,succ b) = the goal codomain. */
fn sov_ap_succ_term() -> u32 {
    let c_hdom : u32 = tc_id(tc_nat(), tc_var(3u32), tc_var(0u32))               /* h : Id(Nat, a@#3, y@#0)   in [a,b,p,y] */
    let c_body : u32 = tc_id(tc_nat(), tc_succ(tc_var(4u32)), tc_succ(tc_var(1u32))) /* Id(Nat, succ a@#4, succ y@#1) in [a,b,p,y,h] */
    let c_inner : u32 = tc_lam(c_hdom, c_body)                                    /* lam h. ... */
    let mtv : u32 = tc_lam(tc_nat(), c_inner)                                     /* lam y. lam h. ... */
    let base : u32 = tc_refl(tc_succ(tc_var(2u32)))                               /* refl(succ a@#2) : C a (refl a) */
    let jterm : u32 = tc_j(mtv, base, tc_var(0u32))                               /* J(C, base, p@#0) : C b p */
    let p_dom : u32 = tc_id(tc_nat(), tc_var(1u32), tc_var(0u32))                 /* p : Id(Nat, a@#1, b@#0)   in [a,b] */
    let lp : u32 = tc_lam(p_dom, jterm)                                           /* lam p. ... */
    let lb : u32 = tc_lam(tc_nat(), lp)                                           /* lam b. ... */
    return tc_lam(tc_nat(), lb)                                                   /* lam a. ... */
}
/* The goal type of ap_succ. */
fn sov_ap_succ_goal() -> u32 {
    let body : u32 = tc_id(tc_nat(), tc_succ(tc_var(2u32)), tc_succ(tc_var(1u32))) /* Id(Nat, succ a@#2, succ b@#1) in [a,b,p] */
    let p_dom : u32 = tc_id(tc_nat(), tc_var(1u32), tc_var(0u32))                 /* Id(Nat, a@#1, b@#0) in [a,b] */
    let pp : u32 = tc_pi(p_dom, body)
    let pb : u32 = tc_pi(tc_nat(), pp)
    return tc_pi(tc_nat(), pb)
}

/* The closed motive for L1: P := lam(j:Nat). Id(Nat, add(zero,j), j) = lam j. Id(Nat, iter(zero,succf,j), j).
 * SOV_SUCCF must be set.  CLOSED -> shift(P,1)=shift(P,2)=P. */
fn sov_l1_motive() -> u32 {
    let addzj : u32 = sov_m_add(tc_zero(), tc_var(0u32))   /* add(zero, j@#0) = iter(zero,succf,#0) */
    let body : u32 = tc_id(tc_nat(), addzj, tc_var(0u32))  /* Id(Nat, add(zero,j), j) */
    return tc_lam(tc_nat(), body)
}

/* L1 proof term: natrec(P, base, step, b) wrapped in lam(b:Nat).  CONSTRUCTION IS CORRECT
 * (each sub-piece infers; de-Bruijn verified piecewise) but the WHOLE FAILS tc_check on the
 * current kernel -- see the OPEN-GAP note at the top of this section (tc_shift_k corrupts the
 * succf step inside the IH type during the kernel's tc_ctx_lookup).  KEPT (not deleted) as the
 * exact term that becomes provable the moment the CCL reducer is fixed; sov_l1_blocked_witness
 * holds the tripwire.  DO NOT assert this proves L1 until that witness flips.
 * base : P zero = Id(Nat, add(zero,zero), zero); add(zero,zero) ->iota zero, so refl(zero).
 * step : Pi(k:Nat). P k -> P(succ k); built so the inner-lam domain is IDENTICAL to the
 *   kernel's nr_ih = app(shift(P,1), #0), and the BODY applies the CLOSED ap_succ to the IH:
 *   in [k,ih] k=#1, ih=#0 ; ap_succ (add(zero,k)) k ih : Id(Nat, succ(add(zero,k)), succ k),
 *   which WOULD be conv to the kernel's nr_conc = app(shift(P,2), succ #1) but for the shift defect. */
fn sov_l1_term() -> u32 {
    let p : u32 = sov_l1_motive()
    let aps : u32 = sov_ap_succ_term()
    let base : u32 = tc_refl(tc_zero())                                  /* P zero ~ Id(Nat,zero,zero) -> refl(zero) */
    /* step inner-lam (ih) domain, IDENTICAL to the kernel's nr_ih: app(shift(P,1), #0) in [k] */
    let ih_dom : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let addzk : u32 = sov_m_add(tc_zero(), tc_var(1u32))                  /* add(zero, k@#1) in [k,ih] */
    /* BODY = ap_succ (add(zero,k)) k ih : Id(Nat, succ(add(zero,k)), succ k) */
    let ap1 : u32 = tc_app(aps, addzk)
    let ap2 : u32 = tc_app(ap1, tc_var(1u32))                            /* second arg b := k@#1 */
    let body : u32 = tc_app(ap2, tc_var(0u32))                           /* proof arg p := ih@#0 */
    let step_inner : u32 = tc_lam(ih_dom, body)                          /* lam ih. BODY  in [k] */
    let step : u32 = tc_lam(tc_nat(), step_inner)                        /* lam k. lam ih. BODY */
    let rec : u32 = tc_natrec(p, base, step, tc_var(0u32))               /* natrec(P,base,step, b@#0) in [b] */
    return tc_lam(tc_nat(), rec)                                         /* lam b. natrec(...) */
}
/* The goal type of L1: Pi(b:Nat). Id(Nat, add(zero,b), b). */
fn sov_l1_goal() -> u32 {
    let addzb : u32 = sov_m_add(tc_zero(), tc_var(0u32))   /* add(zero, b@#0) in [b] */
    let body : u32 = tc_id(tc_nat(), addzb, tc_var(0u32))
    return tc_pi(tc_nat(), body)
}

/* L1 PROVEN WITNESS (positive).  The kernel reducer block is REMOVED (ccl_eta_contract no longer
 * eta-collapses the closed succ-step), so add_left_zero now CLOSES by tc_natrec induction.  Returns
 * 99 IFF the kernel ACCEPTS the genuine L1 term against its true goal AND rejects biting negatives --
 * non-vacuous, un-rigged, and a tripwire for the exact reducer fix (controls A/B flip if it regresses). */
fn sov_l1_proven_witness() -> u64 @export {
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    let succf : u32 = sov_succf()
    /* TRIPWIRE A: shift no longer corrupts the closed succ-lambda (the fixed reducer step). */
    if tc_check(tc_shift_k(succf, 1u32), tc_pi(tc_nat(), tc_nat())) != 1u8 { return 1u64 }
    /* TRIPWIRE B: hence shifted succf IS conv to a fresh succf (the IH-lookup no longer diverges). */
    if tc_conv(tc_shift_k(succf, 1u32), sov_succf()) != 1u8 { return 2u64 }
    /* THE PROOF: the GENUINE L1 natrec term checks against its true goal Pi(b).Id(Nat,add(zero,b),b). */
    let l1 : u32 = sov_l1_term()
    let l1_goal : u32 = sov_l1_goal()
    if tc_check(l1, l1_goal) != 1u8 { return 3u64 }
    /* NEG 1: the WRONG codomain Pi(b).Id(Nat,add(zero,b),succ b) is well-formed but NOT proven by l1. */
    let wrong_body : u32 = tc_id(tc_nat(), sov_m_add(tc_zero(), tc_var(0u32)), tc_succ(tc_var(0u32)))
    let wrong_goal : u32 = tc_pi(tc_nat(), wrong_body)
    if tc_infer(wrong_goal) == 0u32 { return 4u64 }
    if tc_check(l1, wrong_goal) != 0u8 { return 5u64 }
    /* NEG 2: a refl shortcut does NOT prove L1 -- add(zero,b) is a STUCK neutral (symbolic b), not
     * definitionally b; only the induction closes it.  Catches a reducer that wrongly reduces stuck iters. */
    let bogus : u32 = tc_lam(tc_nat(), tc_refl(tc_var(0u32)))
    if tc_check(bogus, l1_goal) != 0u8 { return 6u64 }
    return 99u64
}

/* THE FOUNDATION-RUNG KAT.  99 = the kernel ACCEPTED the two FOUNDATION lemmas (a)+(b),
 * REJECTED their negative controls (so each acceptance is non-vacuous + un-rigged), AND the
 * L1 block is a PROVEN FACT (not a silent omission): the next rung up, add_left_zero, is
 * blocked by a pinned kernel-primitive defect that this KAT witnesses (see
 * sov_l1_blocked_witness + the open-gap note above).  PROPOSE/DISPOSE honored throughout:
 * every positive is a tc_check==1, every negative a tc_check==0, the gap is disclosed, and
 * nothing is weakened or hard-coded to 99. */
fn sov_sr_foundation_kat() -> u64 @export {
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    let x : u32 = tc_var(0u32)

    /* ---- (a) BASE_MUL_ONE : mul(x,1) == x  (refl-definitional; the SOLE arbiter is the kernel) ---- */
    let mul_x_1 : u32 = sov_m_mul(x, tc_succ(tc_zero()))
    if sov_pcc_verify_core(mul_x_1, x) != 1u8 { return 1u64 }
    /* (a)-NEG: mul(x,2) is a STUCK neutral (iter on symbolic x), NOT conv to x -> REJECT. */
    let mul_x_2 : u32 = sov_m_mul(x, tc_succ(tc_succ(tc_zero())))
    if sov_pcc_verify_core(mul_x_2, x) != 0u8 { return 2u64 }

    /* ---- (b) AP_SUCC : Pi(a).Pi(b).Pi(p:Id(Nat,a,b)). Id(Nat,succ a,succ b)  (tc_j congruence)
     *      == the recipe's lemma_tower[0] L0_helpers_cong_ap -- the mandatory ingredient of
     *         every nat-induction step, here proven CLOSED. ---- */
    let aps : u32 = sov_ap_succ_term()
    let aps_goal : u32 = sov_ap_succ_goal()
    if tc_check(aps, aps_goal) != 1u8 { return 3u64 }
    /* (b)-NEG: the SAME proof term does NOT prove the WRONG congruence Id(Nat, succ a, succ(succ b)). */
    let aps_body_bad : u32 = tc_id(tc_nat(), tc_succ(tc_var(2u32)), tc_succ(tc_succ(tc_var(1u32))))
    let aps_pdom : u32 = tc_id(tc_nat(), tc_var(1u32), tc_var(0u32))
    let aps_goal_bad : u32 = tc_pi(tc_nat(), tc_pi(tc_nat(), tc_pi(aps_pdom, aps_body_bad)))
    if tc_check(aps, aps_goal_bad) != 0u8 { return 4u64 }

    /* ---- (c) L1 add_left_zero is PROVEN -- the kernel reducer block is REMOVED ----
     * ccl_eta_contract no longer eta-collapses the closed succ-step succf=(lam n. succ n), so
     * tc_shift_k preserves it and the tc_natrec IH-lookup no longer diverges -- the FIRST induction
     * rung now CLOSES.  sov_l1_proven_witness returns 99 IFF the kernel ACCEPTS the genuine natrec
     * term against Pi(b).Id(Nat,add(zero,b),b) AND rejects biting negatives (wrong codomain succ b +
     * refl shortcut), with the reducer fix asserted as a regression tripwire. */
    if sov_l1_proven_witness() != 99u64 { return 5u64 }

    return 99u64
}

/* ============================================================
 *  THE DISTRIBUTIVITY RUNG -- L6 mul-over-double : Pi(x).Pi(m). Id(Nat, mul(x, double m), double(mul(x,m))).
 *
 *  TASK: construct + kernel-verify  mul(x, 2m) == 2*mul(x,m)  by Nat induction (natrec) over m.
 *
 *  VERDICT (kernel-disposed, on OUR OWN constructions): PROVEN.  L6 over a SYMBOLIC m is a STUCK
 *  NEUTRAL (iter/mul do not iota-reduce), so refl cannot close it -- Nat induction (tc_natrec) over m
 *  is MANDATORY.  The kernel's TC_NATREC rule shifts the supplied motive via tc_shift_k(P,1)/(P,2) to
 *  build the step type, and that motive carries the closed step succf = (lam n. succ n).  The kernel
 *  reducer used to MANGLE that shift (ccl_eta_contract eta-collapsed succf to a bare Succ that ccl_to_tc
 *  misreified as #0); that block is now FIXED (ccl_eta_contract refuses to eta-contract a head
 *  data-constructor / eliminator), so the shifted motive is well-typed, the natrec STEP tc_checks, and
 *  the whole induction closes.
 *
 *  PROOF (the additive Peano tower, each rung kernel-accepted; one tc_check(L6) transitively verifies
 *  all of them):  ap_succ + add_succ_left + add_assoc + add_comm (via L1 add_left_zero) + the add
 *  congruences ap_add_l/r + add_left_comm + mul_left_distributivity (MLD), and finally
 *  L6 == MLD(x, m, m) because double(v) == add(v,v) definitionally.  Built as a SHARED-NODE DAG
 *  (sov_tw_* below + sov_l6_build_tower) so the composed term stays within TC_CAP.
 *
 *  PROPOSE/DISPOSE / KERNEL-VERIFIED: sov_l6_proven_witness builds the GENUINE, UNWEAKENED L6 term +
 *  goal and asserts tc_check(L6_term, L6_goal) == 1 (ACCEPT), bracketed by a biting negative control
 *  (the off-by-succ codomain == 0).  Nothing is weakened, no refl substitutes for the symbolic-m
 *  schema, and the 99 is never hard-coded. */

/* double(v) = iter(v, succf, v) == add(v,v).  CLOSED; Nat->Nat. */
fn sov_m_double(v: u32) -> u32 {
    return tc_iter(v, SOV_SUCCF[0u32], v)
}

/* ============================================================================
 *  THE SR-SCHEMA INDUCTION TOWER -- VERIFIED (kernel-accepted, reducer block REMOVED).
 *  Each lemma proof term is built ONCE into a shared SOV_G_* node and referenced as a DAG by the
 *  higher rungs (the definitional layer the raw tc_* kernel lacks), so the composed L6 term stays
 *  within TC_CAP.  Index conventions are de-Bruijn-exact; the SOLE arbiter is tc_check.
 *  L6 mul-over-double reduces to MLD(x,m,m) because double(v) == add(v,v) definitionally.
 * ============================================================================ */
var SOV_G_APS   : [u32; 1]
var SOV_G_ASL   : [u32; 1]
var SOV_G_L1    : [u32; 1]
var SOV_G_SYM   : [u32; 1]
var SOV_G_TRANS : [u32; 1]
var SOV_G_ASSOC : [u32; 1]
var SOV_G_APR   : [u32; 1]
var SOV_G_APL   : [u32; 1]
var SOV_G_COMM  : [u32; 1]
var SOV_G_ALC   : [u32; 1]
var SOV_G_MLD   : [u32; 1]
var SOV_G_APDBL : [u32; 1]   /* ap_double congruence: Id(u,v) -> Id(double u, double v) */
var SOV_G_L6    : [u32; 1]   /* the L6 proof term itself (callable: L6(x)(m)) */
var SOV_DBLF    : [u32; 1]   /* doublef = lam v. iter(v, succf, v) = lam v. double(v) (closed) */
/* commutative-semiring lemmas (the full optimization-class set) */
var SOV_G_AMR   : [u32; 1]   /* ap_mul_r */
var SOV_G_AML   : [u32; 1]   /* ap_mul_l */
var SOV_G_A1L   : [u32; 1]   /* add_one_left: add(1,w)=succ w */
var SOV_G_MLZ   : [u32; 1]   /* mul_left_zero: mul(0,b)=0 */
var SOV_G_ML1   : [u32; 1]   /* mul_left_one: mul(1,b)=b */
var SOV_G_MSL   : [u32; 1]   /* mul_succ_left: mul(succ a,b)=add(b,mul(a,b)) */
var SOV_G_MCM   : [u32; 1]   /* mul_comm */
var SOV_G_MAS   : [u32; 1]   /* mul_assoc */

/* ap_succ : Pi(a).Pi(b).Pi(Id(a,b)). Id(succ a,succ b). */
fn sov_tw_aps() -> u32 {
    let c_hdom : u32 = tc_id(tc_nat(), tc_var(3u32), tc_var(0u32))
    let c_body : u32 = tc_id(tc_nat(), tc_succ(tc_var(4u32)), tc_succ(tc_var(1u32)))
    let mtv : u32 = tc_lam(tc_nat(), tc_lam(c_hdom, c_body))
    let base : u32 = tc_refl(tc_succ(tc_var(2u32)))
    let jterm : u32 = tc_j(mtv, base, tc_var(0u32))
    let p_dom : u32 = tc_id(tc_nat(), tc_var(1u32), tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(p_dom, jterm)))
}
/* add_succ_left : Pi(a).Pi(b). Id(add(succ a,b), succ(add(a,b))). */
fn sov_tw_asl() -> u32 {
    let lhs : u32 = sov_m_add(tc_succ(tc_var(2u32)), tc_var(0u32))
    let rhs : u32 = tc_succ(sov_m_add(tc_var(2u32), tc_var(0u32)))
    let p : u32 = tc_lam(tc_nat(), tc_id(tc_nat(), lhs, rhs))
    let base : u32 = tc_refl(tc_succ(tc_var(1u32)))
    let ih_dom : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let a1 : u32 = sov_m_add(tc_succ(tc_var(3u32)), tc_var(1u32))
    let b1 : u32 = tc_succ(sov_m_add(tc_var(3u32), tc_var(1u32)))
    let body : u32 = tc_app(tc_app(tc_app(SOV_G_APS[0u32], a1), b1), tc_var(0u32))
    let step : u32 = tc_lam(tc_nat(), tc_lam(ih_dom, body))
    let rec : u32 = tc_natrec(p, base, step, tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), rec))
}
/* L1 add_left_zero : Pi(b). Id(add(0,b), b). */
fn sov_tw_l1() -> u32 {
    let p : u32 = tc_lam(tc_nat(), tc_id(tc_nat(), sov_m_add(tc_zero(), tc_var(0u32)), tc_var(0u32)))
    let base : u32 = tc_refl(tc_zero())
    let ih_dom : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let a1 : u32 = sov_m_add(tc_zero(), tc_var(1u32))
    let ap2 : u32 = tc_app(tc_app(SOV_G_APS[0u32], a1), tc_var(1u32))
    let body : u32 = tc_app(ap2, tc_var(0u32))
    let step : u32 = tc_lam(tc_nat(), tc_lam(ih_dom, body))
    let rec : u32 = tc_natrec(p, base, step, tc_var(0u32))
    return tc_lam(tc_nat(), rec)
}
/* sym : Pi(a).Pi(b).Pi(Id(a,b)). Id(b,a). */
fn sov_tw_sym() -> u32 {
    let c_hdom : u32 = tc_id(tc_nat(), tc_var(3u32), tc_var(0u32))
    let c_body : u32 = tc_id(tc_nat(), tc_var(1u32), tc_var(4u32))
    let mtv : u32 = tc_lam(tc_nat(), tc_lam(c_hdom, c_body))
    let base : u32 = tc_refl(tc_var(2u32))
    let jterm : u32 = tc_j(mtv, base, tc_var(0u32))
    let p_dom : u32 = tc_id(tc_nat(), tc_var(1u32), tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(p_dom, jterm)))
}
/* trans : Pi(a).Pi(b).Pi(c).Pi(Id(a,b)).Pi(Id(b,c)). Id(a,c). */
fn sov_tw_trans() -> u32 {
    let c_hdom : u32 = tc_id(tc_nat(), tc_var(4u32), tc_var(0u32))
    let c_body : u32 = tc_id(tc_nat(), tc_var(6u32), tc_var(1u32))
    let mtv : u32 = tc_lam(tc_nat(), tc_lam(c_hdom, c_body))
    let base : u32 = tc_var(1u32)
    let jterm : u32 = tc_j(mtv, base, tc_var(0u32))
    let p_dom : u32 = tc_id(tc_nat(), tc_var(2u32), tc_var(1u32))
    let q_dom : u32 = tc_id(tc_nat(), tc_var(2u32), tc_var(1u32))
    let lp : u32 = tc_lam(p_dom, tc_lam(q_dom, jterm))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(tc_nat(), lp)))
}
/* add_assoc : Pi(a).Pi(b).Pi(c). Id(add(add(a,b),c), add(a,add(b,c))). */
fn sov_tw_assoc() -> u32 {
    let mlhs : u32 = sov_m_add(sov_m_add(tc_var(3u32), tc_var(2u32)), tc_var(0u32))
    let mrhs : u32 = sov_m_add(tc_var(3u32), sov_m_add(tc_var(2u32), tc_var(0u32)))
    let p : u32 = tc_lam(tc_nat(), tc_id(tc_nat(), mlhs, mrhs))
    let base : u32 = tc_refl(sov_m_add(tc_var(2u32), tc_var(1u32)))
    let ih_dom : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let arg1 : u32 = sov_m_add(sov_m_add(tc_var(4u32), tc_var(3u32)), tc_var(1u32))
    let arg2 : u32 = sov_m_add(tc_var(4u32), sov_m_add(tc_var(3u32), tc_var(1u32)))
    let body : u32 = tc_app(tc_app(tc_app(SOV_G_APS[0u32], arg1), arg2), tc_var(0u32))
    let step : u32 = tc_lam(tc_nat(), tc_lam(ih_dom, body))
    let rec : u32 = tc_natrec(p, base, step, tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(tc_nat(), rec)))
}
/* ap_add_r : Pi(c).Pi(a).Pi(b).Pi(Id(a,b)). Id(add(c,a), add(c,b)). */
fn sov_tw_apr() -> u32 {
    let h_dom : u32 = tc_id(tc_nat(), tc_var(3u32), tc_var(0u32))
    let c_body : u32 = tc_id(tc_nat(), sov_m_add(tc_var(5u32), tc_var(4u32)), sov_m_add(tc_var(5u32), tc_var(1u32)))
    let mtv : u32 = tc_lam(tc_nat(), tc_lam(h_dom, c_body))
    let base : u32 = tc_refl(sov_m_add(tc_var(3u32), tc_var(2u32)))
    let jterm : u32 = tc_j(mtv, base, tc_var(0u32))
    let p_dom : u32 = tc_id(tc_nat(), tc_var(1u32), tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(p_dom, jterm))))
}
/* ap_add_l : Pi(c).Pi(a).Pi(b).Pi(Id(a,b)). Id(add(a,c), add(b,c)). */
fn sov_tw_apl() -> u32 {
    let h_dom : u32 = tc_id(tc_nat(), tc_var(3u32), tc_var(0u32))
    let c_body : u32 = tc_id(tc_nat(), sov_m_add(tc_var(4u32), tc_var(5u32)), sov_m_add(tc_var(1u32), tc_var(5u32)))
    let mtv : u32 = tc_lam(tc_nat(), tc_lam(h_dom, c_body))
    let base : u32 = tc_refl(sov_m_add(tc_var(2u32), tc_var(3u32)))
    let jterm : u32 = tc_j(mtv, base, tc_var(0u32))
    let p_dom : u32 = tc_id(tc_nat(), tc_var(1u32), tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(p_dom, jterm))))
}
/* add_comm : Pi(a).Pi(b). Id(add(a,b), add(b,a)).  base=sym(L1 a); step=trans(ap_succ ih)(sym(asl k a)). */
fn sov_tw_comm() -> u32 {
    let p : u32 = tc_lam(tc_nat(), tc_id(tc_nat(), sov_m_add(tc_var(2u32), tc_var(0u32)), sov_m_add(tc_var(0u32), tc_var(2u32))))
    let a0 : u32 = sov_m_add(tc_zero(), tc_var(1u32))
    let l1a : u32 = tc_app(SOV_G_L1[0u32], tc_var(1u32))
    let base : u32 = tc_app(tc_app(tc_app(SOV_G_SYM[0u32], a0), tc_var(1u32)), l1a)
    let ih_dom : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let addak : u32 = sov_m_add(tc_var(3u32), tc_var(1u32))
    let addka : u32 = sov_m_add(tc_var(1u32), tc_var(3u32))
    let ska : u32 = sov_m_add(tc_succ(tc_var(1u32)), tc_var(3u32))
    let xx : u32 = tc_succ(addak)
    let yy : u32 = tc_succ(addka)
    let apih : u32 = tc_app(tc_app(tc_app(SOV_G_APS[0u32], addak), addka), tc_var(0u32))
    let aslka : u32 = tc_app(tc_app(SOV_G_ASL[0u32], tc_var(1u32)), tc_var(3u32))
    let symq : u32 = tc_app(tc_app(tc_app(SOV_G_SYM[0u32], ska), yy), aslka)
    let body : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], xx), yy), ska), apih), symq)
    let step : u32 = tc_lam(tc_nat(), tc_lam(ih_dom, body))
    let rec : u32 = tc_natrec(p, base, step, tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), rec))
}
/* add_left_comm : Pi(x).Pi(a).Pi(b). Id(add(x,add(a,b)), add(a,add(x,b))). */
fn sov_tw_alc() -> u32 {
    let xv : u32 = tc_var(2u32)
    let av : u32 = tc_var(1u32)
    let bv : u32 = tc_var(0u32)
    let xa : u32 = sov_m_add(xv, av)
    let ax : u32 = sov_m_add(av, xv)
    let A1 : u32 = sov_m_add(xa, bv)
    let B1 : u32 = sov_m_add(xv, sov_m_add(av, bv))
    let A2 : u32 = sov_m_add(ax, bv)
    let B2 : u32 = sov_m_add(av, sov_m_add(xv, bv))
    let assoc_xab : u32 = tc_app(tc_app(tc_app(SOV_G_ASSOC[0u32], xv), av), bv)
    let step1 : u32 = tc_app(tc_app(tc_app(SOV_G_SYM[0u32], A1), B1), assoc_xab)
    let comm_xa : u32 = tc_app(tc_app(SOV_G_COMM[0u32], xv), av)
    let step2 : u32 = tc_app(tc_app(tc_app(tc_app(SOV_G_APL[0u32], bv), xa), ax), comm_xa)
    let assoc_axb : u32 = tc_app(tc_app(tc_app(SOV_G_ASSOC[0u32], av), xv), bv)
    let t12 : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], B1), A1), A2), step1), step2)
    let res : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], B1), A2), B2), t12), assoc_axb)
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(tc_nat(), res)))
}
/* MLD mul_left_distrib : Pi(x).Pi(a).Pi(b). Id(mul(x,add(a,b)), add(mul(x,a),mul(x,b))). */
fn sov_tw_mld() -> u32 {
    let mlhs : u32 = sov_m_mul(tc_var(3u32), sov_m_add(tc_var(2u32), tc_var(0u32)))
    let mrhs : u32 = sov_m_add(sov_m_mul(tc_var(3u32), tc_var(2u32)), sov_m_mul(tc_var(3u32), tc_var(0u32)))
    let p : u32 = tc_lam(tc_nat(), tc_id(tc_nat(), mlhs, mrhs))
    let base : u32 = tc_refl(sov_m_mul(tc_var(2u32), tc_var(1u32)))
    let ih_dom : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let xv : u32 = tc_var(4u32)
    let uu : u32 = sov_m_mul(xv, sov_m_add(tc_var(3u32), tc_var(1u32)))
    let va : u32 = sov_m_mul(xv, tc_var(3u32))
    let vk : u32 = sov_m_mul(xv, tc_var(1u32))
    let addvavk : u32 = sov_m_add(va, vk)
    let s1 : u32 = tc_app(tc_app(tc_app(tc_app(SOV_G_APR[0u32], xv), uu), addvavk), tc_var(0u32))
    let s2 : u32 = tc_app(tc_app(tc_app(SOV_G_ALC[0u32], xv), va), vk)
    let xu : u32 = sov_m_add(xv, uu)
    let xvavk : u32 = sov_m_add(xv, addvavk)
    let vaxvk : u32 = sov_m_add(va, sov_m_add(xv, vk))
    let body : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], xu), xvavk), vaxvk), s1), s2)
    let step : u32 = tc_lam(tc_nat(), tc_lam(ih_dom, body))
    let rec : u32 = tc_natrec(p, base, step, tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(tc_nat(), rec)))
}
/* Build the shared tower into the SOV_G_* nodes (call after tc_reset + SOV_SUCCF set). */
/* ap_double congruence: Pi(u).Pi(v).Pi(Id(u,v)). Id(double u, double v) == Id(add(u,u), add(v,v)).
 * One tc_j with the motive substituting y into BOTH positions of add. */
fn sov_tw_apdbl() -> u32 {
    let c_hdom : u32 = tc_id(tc_nat(), tc_var(3u32), tc_var(0u32))                          /* h:Id(u@#3,y@#0) [u,v,p,y] */
    let c_body : u32 = tc_id(tc_nat(), sov_m_add(tc_var(4u32), tc_var(4u32)), sov_m_add(tc_var(1u32), tc_var(1u32)))  /* Id(add(u@#4,u),add(y@#1,y)) [u,v,p,y,h] */
    let mtv : u32 = tc_lam(tc_nat(), tc_lam(c_hdom, c_body))
    let base : u32 = tc_refl(sov_m_add(tc_var(2u32), tc_var(2u32)))                          /* refl(add(u@#2,u@#2)) */
    let jterm : u32 = tc_j(mtv, base, tc_var(0u32))
    let p_dom : u32 = tc_id(tc_nat(), tc_var(1u32), tc_var(0u32))                            /* Id(u@#1,v@#0) [u,v] */
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(p_dom, jterm)))
}
/* ============================ commutative-semiring optimization classes ============================ */
/* ap_mul_r : Pi(c).Pi(a).Pi(b).Pi(Id(a,b)). Id(mul(c,a), mul(c,b)). */
fn sov_tw_amr() -> u32 {
    let h : u32 = tc_id(tc_nat(), tc_var(3u32), tc_var(0u32))
    let b : u32 = tc_id(tc_nat(), sov_m_mul(tc_var(5u32), tc_var(4u32)), sov_m_mul(tc_var(5u32), tc_var(1u32)))
    let m : u32 = tc_lam(tc_nat(), tc_lam(h, b))
    let bs : u32 = tc_refl(sov_m_mul(tc_var(3u32), tc_var(2u32)))
    let j : u32 = tc_j(m, bs, tc_var(0u32))
    let pd : u32 = tc_id(tc_nat(), tc_var(1u32), tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(pd, j))))
}
/* ap_mul_l : Pi(c).Pi(a).Pi(b).Pi(Id(a,b)). Id(mul(a,c), mul(b,c)). */
fn sov_tw_aml() -> u32 {
    let h : u32 = tc_id(tc_nat(), tc_var(3u32), tc_var(0u32))
    let b : u32 = tc_id(tc_nat(), sov_m_mul(tc_var(4u32), tc_var(5u32)), sov_m_mul(tc_var(1u32), tc_var(5u32)))
    let m : u32 = tc_lam(tc_nat(), tc_lam(h, b))
    let bs : u32 = tc_refl(sov_m_mul(tc_var(2u32), tc_var(3u32)))
    let j : u32 = tc_j(m, bs, tc_var(0u32))
    let pd : u32 = tc_id(tc_nat(), tc_var(1u32), tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(pd, j))))
}
/* add_one_left : Pi(w). Id(add(1,w), succ w). */
fn sov_tw_a1l() -> u32 {
    let aslw : u32 = tc_app(tc_app(SOV_G_ASL[0u32], tc_zero()), tc_var(0u32))
    let l1w : u32 = tc_app(SOV_G_L1[0u32], tc_var(0u32))
    let ap : u32 = tc_app(tc_app(tc_app(SOV_G_APS[0u32], sov_m_add(tc_zero(), tc_var(0u32))), tc_var(0u32)), l1w)
    let a1w : u32 = sov_m_add(tc_succ(tc_zero()), tc_var(0u32))
    let sa0w : u32 = tc_succ(sov_m_add(tc_zero(), tc_var(0u32)))
    let sw : u32 = tc_succ(tc_var(0u32))
    let bo : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], a1w), sa0w), sw), aslw), ap)
    return tc_lam(tc_nat(), bo)
}
/* mul_left_zero : Pi(b). Id(mul(0,b), 0). */
fn sov_tw_mlz() -> u32 {
    let p : u32 = tc_lam(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_zero(), tc_var(0u32)), tc_zero()))
    let bs : u32 = tc_refl(tc_zero())
    let id : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let m0k : u32 = sov_m_mul(tc_zero(), tc_var(1u32))
    let bo : u32 = tc_app(tc_app(tc_app(tc_app(SOV_G_APR[0u32], tc_zero()), m0k), tc_zero()), tc_var(0u32))
    let st : u32 = tc_lam(tc_nat(), tc_lam(id, bo))
    let rc : u32 = tc_natrec(p, bs, st, tc_var(0u32))
    return tc_lam(tc_nat(), rc)
}
/* mul_left_one : Pi(b). Id(mul(1,b), b). */
fn sov_tw_ml1() -> u32 {
    let p : u32 = tc_lam(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_succ(tc_zero()), tc_var(0u32)), tc_var(0u32)))
    let bs : u32 = tc_refl(tc_zero())
    let id : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let m1k : u32 = sov_m_mul(tc_succ(tc_zero()), tc_var(1u32))
    let a1 : u32 = tc_app(SOV_G_A1L[0u32], m1k)
    let ap : u32 = tc_app(tc_app(tc_app(SOV_G_APS[0u32], m1k), tc_var(1u32)), tc_var(0u32))
    let add1 : u32 = sov_m_add(tc_succ(tc_zero()), m1k)
    let sm1k : u32 = tc_succ(m1k)
    let sk : u32 = tc_succ(tc_var(1u32))
    let bo : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], add1), sm1k), sk), a1), ap)
    let st : u32 = tc_lam(tc_nat(), tc_lam(id, bo))
    let rc : u32 = tc_natrec(p, bs, st, tc_var(0u32))
    return tc_lam(tc_nat(), rc)
}
/* mul_succ_left : Pi(a).Pi(b). Id(mul(succ a,b), add(b, mul(a,b))). */
fn sov_tw_msl() -> u32 {
    let pb : u32 = tc_id(tc_nat(), sov_m_mul(tc_succ(tc_var(2u32)), tc_var(0u32)), sov_m_add(tc_var(0u32), sov_m_mul(tc_var(2u32), tc_var(0u32))))
    let p : u32 = tc_lam(tc_nat(), pb)
    let bs : u32 = tc_refl(tc_zero())
    let id : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let av : u32 = tc_var(3u32)
    let kv : u32 = tc_var(1u32)
    let sav : u32 = tc_succ(av)
    let mm : u32 = sov_m_mul(av, kv)
    let msak : u32 = sov_m_mul(sav, kv)
    let addkM : u32 = sov_m_add(kv, mm)
    let step1 : u32 = tc_app(tc_app(tc_app(tc_app(SOV_G_APR[0u32], sav), msak), addkM), tc_var(0u32))
    let addsa_msak : u32 = sov_m_add(sav, msak)
    let addsa_addkM : u32 = sov_m_add(sav, addkM)
    let a_addkM : u32 = sov_m_add(av, addkM)
    let sa : u32 = tc_app(tc_app(SOV_G_ASL[0u32], av), addkM)
    let addaM : u32 = sov_m_add(av, mm)
    let k_addaM : u32 = sov_m_add(kv, addaM)
    let alc_akM : u32 = tc_app(tc_app(tc_app(SOV_G_ALC[0u32], av), kv), mm)
    let s_a_addkM : u32 = tc_succ(a_addkM)
    let s_k_addaM : u32 = tc_succ(k_addaM)
    let mid : u32 = tc_app(tc_app(tc_app(SOV_G_APS[0u32], a_addkM), k_addaM), alc_akM)
    let sk_addaM : u32 = sov_m_add(tc_succ(kv), addaM)
    let sb : u32 = tc_app(tc_app(SOV_G_ASL[0u32], kv), addaM)
    let sb_sym : u32 = tc_app(tc_app(tc_app(SOV_G_SYM[0u32], sk_addaM), s_k_addaM), sb)
    let t1 : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], addsa_addkM), s_a_addkM), s_k_addaM), sa), mid)
    let t2 : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], addsa_addkM), s_k_addaM), sk_addaM), t1), sb_sym)
    let bo : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], addsa_msak), addsa_addkM), sk_addaM), step1), t2)
    let st : u32 = tc_lam(tc_nat(), tc_lam(id, bo))
    let rc : u32 = tc_natrec(p, bs, st, tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), rc))
}
/* mul_comm : Pi(a).Pi(b). Id(mul(a,b), mul(b,a)). */
fn sov_tw_mcm() -> u32 {
    let p : u32 = tc_lam(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_var(2u32), tc_var(0u32)), sov_m_mul(tc_var(0u32), tc_var(2u32))))
    let m0a : u32 = sov_m_mul(tc_zero(), tc_var(1u32))
    let mlza : u32 = tc_app(SOV_G_MLZ[0u32], tc_var(1u32))
    let bs : u32 = tc_app(tc_app(tc_app(SOV_G_SYM[0u32], m0a), tc_zero()), mlza)
    let id : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let av : u32 = tc_var(3u32)
    let kv : u32 = tc_var(1u32)
    let mak : u32 = sov_m_mul(av, kv)
    let mka : u32 = sov_m_mul(kv, av)
    let addak : u32 = sov_m_add(av, mak)
    let addaka : u32 = sov_m_add(av, mka)
    let mska : u32 = sov_m_mul(tc_succ(kv), av)
    let step1 : u32 = tc_app(tc_app(tc_app(tc_app(SOV_G_APR[0u32], av), mak), mka), tc_var(0u32))
    let mslka : u32 = tc_app(tc_app(SOV_G_MSL[0u32], kv), av)
    let msl_sym : u32 = tc_app(tc_app(tc_app(SOV_G_SYM[0u32], mska), addaka), mslka)
    let bo : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], addak), addaka), mska), step1), msl_sym)
    let st : u32 = tc_lam(tc_nat(), tc_lam(id, bo))
    let rc : u32 = tc_natrec(p, bs, st, tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), rc))
}
/* mul_assoc : Pi(a).Pi(b).Pi(c). Id(mul(mul(a,b),c), mul(a,mul(b,c))). */
fn sov_tw_mas() -> u32 {
    let pAB : u32 = sov_m_mul(tc_var(3u32), tc_var(2u32))
    let pb : u32 = tc_id(tc_nat(), sov_m_mul(pAB, tc_var(0u32)), sov_m_mul(tc_var(3u32), sov_m_mul(tc_var(2u32), tc_var(0u32))))
    let p : u32 = tc_lam(tc_nat(), pb)
    let bs : u32 = tc_refl(tc_zero())
    let id : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let av : u32 = tc_var(4u32)
    let bv : u32 = tc_var(3u32)
    let kv : u32 = tc_var(1u32)
    let AB : u32 = sov_m_mul(av, bv)
    let mABk : u32 = sov_m_mul(AB, kv)
    let mbk : u32 = sov_m_mul(bv, kv)
    let mambk : u32 = sov_m_mul(av, mbk)
    let step1 : u32 = tc_app(tc_app(tc_app(tc_app(SOV_G_APR[0u32], AB), mABk), mambk), tc_var(0u32))
    let addABmABk : u32 = sov_m_add(AB, mABk)
    let addABmambk : u32 = sov_m_add(AB, mambk)
    let bplusmbk : u32 = sov_m_add(bv, mbk)
    let ma_bm : u32 = sov_m_mul(av, bplusmbk)
    let mld_ab : u32 = tc_app(tc_app(tc_app(SOV_G_MLD[0u32], av), bv), mbk)
    let mld_sym : u32 = tc_app(tc_app(tc_app(SOV_G_SYM[0u32], ma_bm), addABmambk), mld_ab)
    let bo : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], addABmABk), addABmambk), ma_bm), step1), mld_sym)
    let st : u32 = tc_lam(tc_nat(), tc_lam(id, bo))
    let rc : u32 = tc_natrec(p, bs, st, tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(tc_nat(), rc)))
}
fn sov_l6_build_tower() -> u64 {
    SOV_DBLF[0u32]    = tc_lam(tc_nat(), tc_iter(tc_var(0u32), SOV_SUCCF[0u32], tc_var(0u32)))
    SOV_G_APS[0u32]   = sov_tw_aps()
    SOV_G_ASL[0u32]   = sov_tw_asl()
    SOV_G_L1[0u32]    = sov_tw_l1()
    SOV_G_SYM[0u32]   = sov_tw_sym()
    SOV_G_TRANS[0u32] = sov_tw_trans()
    SOV_G_ASSOC[0u32] = sov_tw_assoc()
    SOV_G_APR[0u32]   = sov_tw_apr()
    SOV_G_APL[0u32]   = sov_tw_apl()
    SOV_G_COMM[0u32]  = sov_tw_comm()
    SOV_G_ALC[0u32]   = sov_tw_alc()
    SOV_G_MLD[0u32]   = sov_tw_mld()
    SOV_G_APDBL[0u32] = sov_tw_apdbl()
    SOV_G_AMR[0u32]   = sov_tw_amr()
    SOV_G_AML[0u32]   = sov_tw_aml()
    SOV_G_A1L[0u32]   = sov_tw_a1l()
    SOV_G_MLZ[0u32]   = sov_tw_mlz()
    SOV_G_ML1[0u32]   = sov_tw_ml1()
    SOV_G_MSL[0u32]   = sov_tw_msl()
    SOV_G_MCM[0u32]   = sov_tw_mcm()
    SOV_G_MAS[0u32]   = sov_tw_mas()
    return 0u64
}


/* The GENUINE L6 goal: Pi(x:Nat). Pi(m:Nat). Id(Nat, mul(x, double m), double(mul(x,m))). */
fn sov_l6_goal() -> u32 {
    let xin : u32 = tc_var(1u32)                          /* x, in [x,m] */
    let min : u32 = tc_var(0u32)                          /* m, in [x,m] */
    let lhs : u32 = sov_m_mul(xin, sov_m_double(min))
    let rhs : u32 = sov_m_double(sov_m_mul(xin, min))
    let body : u32 = tc_id(tc_nat(), lhs, rhs)            /* Id(...) in [x,m] */
    let perM : u32 = tc_pi(tc_nat(), body)                /* Pi(m:Nat). Id(...) */
    return tc_pi(tc_nat(), perM)                          /* Pi(x:Nat). Pi(m:Nat). Id(...) */
}

/* The GENUINE L6 proof term: lam(x). lam(m). MLD(x)(m)(m).  double(v) == add(v,v) definitionally,
 * so L6's goal Id(mul(x,double m), double(mul(x,m))) == Id(mul(x,add(m,m)), add(mul(x,m),mul(x,m)))
 * which is exactly MLD instantiated at a:=m, b:=m.  Requires sov_l6_build_tower() to have populated
 * SOV_G_MLD.  tc_check of this term transitively verifies the ENTIRE additive tower (asl, L1, sym,
 * trans, assoc, ap_add_l/r, comm, add_left_comm, MLD). */
fn sov_l6_term() -> u32 {
    let app : u32 = tc_app(tc_app(tc_app(SOV_G_MLD[0u32], tc_var(1u32)), tc_var(0u32)), tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), app))
}

/* L6 PROVEN WITNESS (positive).  The reducer block is REMOVED, so the mandatory tc_natrec induction
 * over a symbolic m now closes: L6 mul-over-double is PROVED via the additive Peano tower + MLD.
 * Returns 99 IFF the kernel ACCEPTS the genuine L6 term against its true goal AND rejects a biting
 * negative (the off-by-succ codomain) -- non-vacuous, un-rigged.  A single tc_check(L6) validates the
 * whole tower transitively; the negative control proves it is not vacuously accepting. */
fn sov_l6_proven_witness() -> u64 @export {
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    sov_l6_build_tower()
    /* construction sanity: the apex lemma node is non-ERR (0 = arena overflow during build). */
    if SOV_G_MLD[0u32] == 0u32 { return 1u64 }
    let l6 : u32 = sov_l6_term()
    let l6_goal : u32 = sov_l6_goal()
    /* THE PROOF: the kernel accepts L6 mul-over-double. */
    if tc_check(l6, l6_goal) != 1u8 { return 2u64 }
    /* NEG: the SAME term must NOT prove the off-by-succ codomain Id(mul(x,double m), succ(double(mul(x,m)))). */
    let wrhs : u32 = tc_succ(sov_m_double(sov_m_mul(tc_var(1u32), tc_var(0u32))))
    let wbody : u32 = tc_id(tc_nat(), sov_m_mul(tc_var(1u32), sov_m_double(tc_var(0u32))), wrhs)
    let wgoal : u32 = tc_pi(tc_nat(), tc_pi(tc_nat(), wbody))
    if tc_infer(wgoal) == 0u32 { return 3u64 }
    if tc_check(l6, wgoal) != 0u8 { return 4u64 }
    return 99u64
}

/* THE DISTRIBUTIVITY-RUNG KAT.  99 = the kernel PROVED L6 mul-over-double (the symbolic-m schema, by
 * mandatory tc_natrec induction over the additive Peano tower), and rejected the off-by-succ negative
 * control.  PROPOSE/DISPOSE honored: the positive is tc_check==1, the negative tc_check==0, nothing is
 * weakened, no refl substitutes for the symbolic-m schema, and 99 is never hard-coded. */
fn sov_sr_distrib_kat() -> u64 @export {
    if sov_l6_proven_witness() != 99u64 { return 5u64 }
    return 99u64
}

/* ============================================================================
 *  THE STRENGTH-REDUCTION SCHEMA (the headline, uniquely-III result):
 *     Pi(x).Pi(k). Id(Nat, mul(x, pow2 k), itd(x, k))      where  pow2 k = 2^k,  itd(x,k) = double^k(x).
 *  i.e. "multiplying by a power of two equals k repeated doublings" -- the canonical strength reduction
 *  the sov_isa "Path C" optimizer wants to apply -- PROVED CORRECT for a SYMBOLIC k by III's own CIC
 *  kernel (proof-carrying optimization: the egraph PROPOSES the rewrite, the kernel DISPOSES by proving
 *  the equality for all k).  Induction on k:  base mul(x,2^0)=mul(x,1)=x=double^0(x) (refl);  step uses
 *  L6 (mul-over-double) at m=pow2 k + ap_double(IH), since pow2(succ k)=double(pow2 k) and
 *  itd(x,succ k)=double(itd(x,k)) definitionally.  Built on the SAME shared tower.
 * ============================================================================ */
/* pow2(k) = iter(1, doublef, k) = double^k(1) = 2^k. */
fn sov_m_pow2(k: u32) -> u32 { return tc_iter(tc_succ(tc_zero()), SOV_DBLF[0u32], k) }
/* itd(x,k) = iter(x, doublef, k) = double^k(x). */
fn sov_m_itd(x: u32, k: u32) -> u32 { return tc_iter(x, SOV_DBLF[0u32], k) }

/* The schema proof term: lam x. lam k. natrec(P, refl(x), step, k). */
fn sov_sr_term() -> u32 {
    /* P = lam j. Id(mul(x, pow2 j), itd(x, j)) ; in [x,k,j] x=#2, j=#0 */
    let mlhs : u32 = sov_m_mul(tc_var(2u32), sov_m_pow2(tc_var(0u32)))
    let mrhs : u32 = sov_m_itd(tc_var(2u32), tc_var(0u32))
    let p : u32 = tc_lam(tc_nat(), tc_id(tc_nat(), mlhs, mrhs))
    /* base : P 0 ~ Id(mul(x,1), x) -- both conv x ; in [x,k] x=#1 */
    let base : u32 = tc_refl(tc_var(1u32))
    /* step in [x,k,kstep,ih]: x=#3, kstep=#1, ih=#0 */
    let ih_dom : u32 = tc_app(tc_shift_k(p, 1u32), tc_var(0u32))
    let p2k : u32 = sov_m_pow2(tc_var(1u32))                 /* pow2(kstep) */
    let mxp : u32 = sov_m_mul(tc_var(3u32), p2k)             /* mul(x, pow2 kstep) */
    let itdxk : u32 = sov_m_itd(tc_var(3u32), tc_var(1u32))  /* itd(x, kstep) */
    let l6app : u32 = tc_app(tc_app(SOV_G_L6[0u32], tc_var(3u32)), p2k)             /* L6(x)(p2k) : Id(mul(x,double p2k), double(mul(x,p2k))) */
    let apdbl : u32 = tc_app(tc_app(tc_app(SOV_G_APDBL[0u32], mxp), itdxk), tc_var(0u32))  /* Id(double mxp, double itdxk) */
    let x_ : u32 = sov_m_mul(tc_var(3u32), sov_m_double(p2k))   /* mul(x, double p2k) == mul(x, pow2(succ kstep)) */
    let y_ : u32 = sov_m_double(mxp)                            /* double(mul(x,p2k)) */
    let z_ : u32 = sov_m_double(itdxk)                          /* double(itd(x,kstep)) == itd(x, succ kstep) */
    let body : u32 = tc_app(tc_app(tc_app(tc_app(tc_app(SOV_G_TRANS[0u32], x_), y_), z_), l6app), apdbl)
    let step : u32 = tc_lam(tc_nat(), tc_lam(ih_dom, body))
    let rec : u32 = tc_natrec(p, base, step, tc_var(0u32))
    return tc_lam(tc_nat(), tc_lam(tc_nat(), rec))
}
/* The schema goal: Pi(x).Pi(k). Id(Nat, mul(x, pow2 k), itd(x, k)). */
fn sov_sr_goal() -> u32 {
    let mlhs : u32 = sov_m_mul(tc_var(1u32), sov_m_pow2(tc_var(0u32)))   /* in [x,k] x=#1,k=#0 */
    let mrhs : u32 = sov_m_itd(tc_var(1u32), tc_var(0u32))
    return tc_pi(tc_nat(), tc_pi(tc_nat(), tc_id(tc_nat(), mlhs, mrhs)))
}

/* STRENGTH-REDUCTION PROVEN WITNESS.  99 IFF the kernel ACCEPTS the schema mul(x,2^k)==double^k(x) for
 * symbolic k AND rejects a biting negative (the off-by-double codomain).  A single tc_check(schema)
 * transitively verifies the whole tower + L6 + ap_double + the k-induction. */
fn sov_sr_strength_witness() -> u64 @export {
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    sov_l6_build_tower()
    SOV_G_L6[0u32] = sov_l6_term()
    if SOV_G_L6[0u32] == 0u32 { return 1u64 }
    let s : u32 = sov_sr_term()
    let g : u32 = sov_sr_goal()
    /* THE PROOF: a SINGLE tc_check -- mul(x, 2^k) == double^k(x) for all k (transitively verifies the
     * whole tower + L6 + ap_double + the k-induction).  Minimal arena pressure (no accumulated checks). */
    if tc_check(s, g) != 1u8 { return 2u64 }
    /* NEG: the schema term must NOT prove the off-by-double codomain Id(mul(x,pow2 k), double(itd(x,k))). */
    let wbody : u32 = tc_id(tc_nat(), sov_m_mul(tc_var(1u32), sov_m_pow2(tc_var(0u32))), sov_m_double(sov_m_itd(tc_var(1u32), tc_var(0u32))))
    let wgoal : u32 = tc_pi(tc_nat(), tc_pi(tc_nat(), wbody))
    if tc_check(s, wgoal) != 0u8 { return 4u64 }
    return 99u64
}

/* THE LOOP -> COMMONS FEED (T9): admit III's kernel-certified strength-reduction schema into the Theorem
 * Commons so the optimizer can later CITE it by content-address instead of re-proving. Reuses the EXACT
 * (proof s, goal g) the strength witness verifies; tcom_admit re-runs tc_check, so only a kernel-accepted
 * theorem is registered (nothing trusted). The autocatalytic loop's discoveries thereby become a persistent,
 * content-addressed, citable lemma library -- the harmony unique to III (cad x CIC kernel x the loop).
 * 99 = the schema is admitted (and, by tcom_admit's gate, kernel-re-verified at registration). */
var SOV_THM_STRENGTH : [u8; 20] = [116u8, 104u8, 109u8, 58u8, 115u8, 116u8, 114u8, 101u8, 110u8, 103u8, 116u8, 104u8, 95u8, 115u8, 99u8, 104u8, 101u8, 109u8, 97u8, 10u8]   /* "thm:strength_schema\n" */
const SOV_THM_STRENGTH_LEN : u64 = 20u64
var SOV_THM_FOLD : [u8; 15] = [116u8, 104u8, 109u8, 58u8, 115u8, 104u8, 105u8, 102u8, 116u8, 95u8, 102u8, 111u8, 108u8, 100u8, 10u8]   /* "thm:shift_fold\n" */
const SOV_THM_FOLD_LEN : u64 = 15u64
/* helper: rebuild the additive Peano tower into a FRESH arena (each certified theorem is admitted in its own
 * arena; the Commons key is the cad of the statement BYTES, so the reset between theorems is sound). */
fn sov_feed_setup() -> u64 {
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    sov_l6_build_tower()
    SOV_G_L6[0u32] = sov_l6_term()
    return SOV_G_L6[0u32] as u64
}
fn sov_feed_commons() -> u64 @export {
    /* theorem 1: the strength-reduction schema  mul(x,2^k) == double^k(x)  (symbolic k) */
    if sov_feed_setup() == 0u64 { return 1u64 }
    if tcom_admit((&SOV_THM_STRENGTH as u64), SOV_THM_STRENGTH_LEN, sov_sr_term(), sov_sr_goal()) != 0i32 { return 2u64 }
    /* theorem 2: the const-shift codegen fold  x<<k == x*2^k  (fresh arena) */
    if sov_feed_setup() == 0u64 { return 3u64 }
    if tcom_admit((&SOV_THM_FOLD as u64), SOV_THM_FOLD_LEN, sov_shift_fold_term(), sov_shift_fold_goal()) != 0i32 { return 4u64 }
    return 99u64
}

/* CITE-OR-PROVE (T9, closes the loop propose->prove->persist->CITE): the proof-carrying optimizer's REUSE
 * path. Check the Theorem Commons FIRST; if the strength schema is already kernel-certified there, CITE it
 * (77) and SKIP the expensive proof (the L6 tower build + tc_check). Only on a miss does it pay to prove +
 * admit (88). No other compiler reuses KERNEL PROOFS by content-address -- this is proof-carrying
 * optimization that gets cheaper as the system's certified repertoire grows. */
fn sov_cite_or_prove_strength() -> u64 @export {
    if tcom_cite((&SOV_THM_STRENGTH as u64), SOV_THM_STRENGTH_LEN) == 0i32 { return 77u64 }
    if sov_feed_setup() == 0u64 { return 1u64 }
    if tcom_admit((&SOV_THM_STRENGTH as u64), SOV_THM_STRENGTH_LEN, sov_sr_term(), sov_sr_goal()) != 0i32 { return 2u64 }
    return 88u64
}

/* THE STRENGTH-REDUCTION KAT.  99 = III's CIC kernel PROVED its own strength-reduction schema
 * mul(x, 2^k) == double^k(x) for a SYMBOLIC k (the proof-carrying-optimization headline), with the
 * off-by-double negative control rejected.  Nothing weakened; 99 never hard-coded. */
fn sov_sr_strength_kat() -> u64 @export {
    if sov_sr_strength_witness() != 99u64 { return 5u64 }
    return 99u64
}

/* ============================================================================
 *  HARMONY: the inductive schema UNLOCKS optimizations the refl-only disposer cannot certify.
 *  The live proof-carrying disposer sov_pcc_verify certifies an optimization by REFL (definitional
 *  equality).  But a strength reduction mul(x, 2^k) -> double^k(x) is NOT definitional even at a
 *  CONCRETE k for a SYMBOLIC x: mul(x,4) normalizes to x+(x+(x+x)) while double^2(x) normalizes to
 *  (x+x)+(x+x) -- equal only up to add-ASSOCIATIVITY, which is propositional (proven, not definitional).
 *  So refl FAILS.  The inductive strength schema (sov_sr_term), instantiated at the concrete k, SUPPLIES
 *  the missing associativity proof and CERTIFIES the rewrite.  This is the disposer made strictly more
 *  powerful by the proof tower: a kernel that certifies INDUCTIVE optimization schemas, not just
 *  definitional ones -- uniquely-III proof-carrying optimization. 99 = refl REJECTS the (sound) rewrite
 *  AND the schema certificate ACCEPTS it. */
fn sov_sr_apply_witness() -> u64 @export {
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    sov_l6_build_tower()
    SOV_G_L6[0u32] = sov_l6_term()
    let n2 : u32 = tc_succ(tc_succ(tc_zero()))                          /* k = 2 (concrete) */
    /* the strength reduction at k=2, x SYMBOLIC: Pi(x). Id(mul(x, pow2 2), itd(x, 2)). */
    let in_m : u32 = sov_m_mul(tc_var(0u32), sov_m_pow2(n2))            /* mul(x, 4)  in [x] x=#0 */
    let out_m : u32 = sov_m_itd(tc_var(0u32), n2)                       /* double^2(x) */
    /* (a) the LIVE refl disposer CANNOT certify it (add-associativity is not definitional). */
    if sov_pcc_verify(in_m, out_m) != 0u8 { return 1u64 }
    /* (b) the inductive schema certificate (lam x. schema(x)(2)) DOES certify it. */
    let goal : u32 = tc_pi(tc_nat(), tc_id(tc_nat(), in_m, out_m))
    let cert : u32 = tc_lam(tc_nat(), tc_app(tc_app(sov_sr_term(), tc_var(0u32)), n2))
    if tc_check(cert, goal) != 1u8 { return 2u64 }
    return 99u64
}

/* KAT: the schema-certified strength reduction (proof-carrying optimization beyond definitional equality). */
fn sov_sr_apply_kat() -> u64 @export {
    if sov_sr_apply_witness() != 99u64 { return 5u64 }
    return 99u64
}

/* GENERALITY: proof-carrying optimization is a FRAMEWORK, not a one-off.  A SECOND class -- left
 * distributivity mul(x, a+b) -> add(mul(x,a), mul(x,b)) -- is, like strength reduction, NOT definitional
 * for symbolic operands (mul over a symbolic sum is a stuck neutral), so the refl-only disposer REJECTS
 * it; the MLD lemma already in the tower CERTIFIES it.  99 = refl REJECTS the sound rewrite AND the MLD
 * certificate ACCEPTS it -- the same egraph-PROPOSES / kernel-DISPOSES discipline, a different rule. */
fn sov_distrib_apply_witness() -> u64 @export {
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    sov_l6_build_tower()
    /* goal: Pi(x).Pi(a).Pi(b). Id(mul(x, add(a,b)), add(mul(x,a), mul(x,b)))  in [x,a,b] x=#2,a=#1,b=#0 */
    let gbody : u32 = tc_id(tc_nat(), sov_m_mul(tc_var(2u32), sov_m_add(tc_var(1u32), tc_var(0u32))), sov_m_add(sov_m_mul(tc_var(2u32), tc_var(1u32)), sov_m_mul(tc_var(2u32), tc_var(0u32))))
    let goal : u32 = tc_pi(tc_nat(), tc_pi(tc_nat(), tc_pi(tc_nat(), gbody)))
    /* (a) refl CANNOT certify left distributivity for symbolic a,b. */
    let refl_cert : u32 = tc_lam(tc_nat(), tc_lam(tc_nat(), tc_lam(tc_nat(), tc_refl(sov_m_mul(tc_var(2u32), sov_m_add(tc_var(1u32), tc_var(0u32)))))))
    if tc_check(refl_cert, goal) != 0u8 { return 1u64 }
    /* (b) the MLD lemma (already in the shared tower) IS a certificate for it. */
    if tc_check(SOV_G_MLD[0u32], goal) != 1u8 { return 2u64 }
    return 99u64
}
fn sov_distrib_apply_kat() -> u64 @export {
    if sov_distrib_apply_witness() != 99u64 { return 5u64 }
    return 99u64
}

/* THE COMPLETE COMMUTATIVE-SEMIRING OPTIMIZATION-CLASS SET, kernel-proven.  Beyond the strength schema
 * and left-distributivity (1115/1116/1117), III's CIC kernel proves the full algebraic-optimization
 * theory of Nat: the multiplicative annihilator, identity, commutativity, and associativity -- the
 * remaining canonical integer-optimization classes (right distributivity is the corollary MLD o mul_comm).
 * Each lemma is checked in its own arena epoch (tc_check==1); the harmony control shows mul_comm is NOT
 * refl-certifiable for symbolic operands (commutativity is propositional, not definitional).  99 = the
 * complete commutative semiring is kernel-certified, refl rejects the (sound) commutativity rewrite. */
fn sov_opt_classes_kat() -> u64 @export {
    /* mul_left_zero (annihilator): mul(0,b)=0 */
    tc_reset(); SOV_SUCCF[0u32] = sov_succf(); sov_l6_build_tower()
    let mlzg : u32 = tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_zero(), tc_var(0u32)), tc_zero()))
    if tc_check(SOV_G_MLZ[0u32], mlzg) != 1u8 { return 1u64 }
    /* mul_left_one (identity): mul(1,b)=b */
    tc_reset(); SOV_SUCCF[0u32] = sov_succf(); sov_l6_build_tower()
    let ml1g : u32 = tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_succ(tc_zero()), tc_var(0u32)), tc_var(0u32)))
    if tc_check(SOV_G_ML1[0u32], ml1g) != 1u8 { return 2u64 }
    /* mul_succ_left (the inductive engine of mul_comm): mul(succ a,b)=add(b,mul(a,b)) */
    tc_reset(); SOV_SUCCF[0u32] = sov_succf(); sov_l6_build_tower()
    let mslg : u32 = tc_pi(tc_nat(), tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_succ(tc_var(1u32)), tc_var(0u32)), sov_m_add(tc_var(0u32), sov_m_mul(tc_var(1u32), tc_var(0u32))))))
    if tc_check(SOV_G_MSL[0u32], mslg) != 1u8 { return 3u64 }
    /* mul_comm: mul(a,b)=mul(b,a) */
    tc_reset(); SOV_SUCCF[0u32] = sov_succf(); sov_l6_build_tower()
    let mcmg : u32 = tc_pi(tc_nat(), tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_var(1u32), tc_var(0u32)), sov_m_mul(tc_var(0u32), tc_var(1u32)))))
    if tc_check(SOV_G_MCM[0u32], mcmg) != 1u8 { return 4u64 }
    /* mul_assoc: mul(mul(a,b),c)=mul(a,mul(b,c)) */
    tc_reset(); SOV_SUCCF[0u32] = sov_succf(); sov_l6_build_tower()
    let masg : u32 = tc_pi(tc_nat(), tc_pi(tc_nat(), tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(sov_m_mul(tc_var(2u32), tc_var(1u32)), tc_var(0u32)), sov_m_mul(tc_var(2u32), sov_m_mul(tc_var(1u32), tc_var(0u32)))))))
    if tc_check(SOV_G_MAS[0u32], masg) != 1u8 { return 5u64 }
    /* HARMONY: refl CANNOT certify mul_comm for symbolic a,b (commutativity is propositional). */
    tc_reset(); SOV_SUCCF[0u32] = sov_succf()
    let mcmg2 : u32 = tc_pi(tc_nat(), tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_var(1u32), tc_var(0u32)), sov_m_mul(tc_var(0u32), tc_var(1u32)))))
    let refl_cert : u32 = tc_lam(tc_nat(), tc_lam(tc_nat(), tc_refl(sov_m_mul(tc_var(1u32), tc_var(0u32)))))
    if tc_check(refl_cert, mcmg2) != 0u8 { return 6u64 }
    return 99u64
}

/* ============================================================================
 *  THE AUTOCATALYTIC SYNTHESIZER -- the proof-carrying tower extended into an AUTOMATED
 *  auto-prover.  sov_sr_apply_witness certified ONE hand-written strength reduction (k=2).
 *  Here the certificate is SYNTHESIZED for an ARBITRARY k: the synthesizer extracts the
 *  exponent, builds the numeral, and INSTANTIATES the proven inductive schema sov_sr_term
 *  at that k -- a NON-refl proof term the definitional-equality disposer cannot produce.
 *  The kernel (tc_check) stays the SOLE arbiter; the synthesizer only PROPOSES the
 *  certificate.  Caller must set up the shared tower (sov_l6_build_tower + SOV_G_L6) in the
 *  live arena (the sov_sr_apply_witness ritual).  This is the "constrained decoding of CIC
 *  proof terms" that nous_synth explicitly defers to the full kernel -- realized for the
 *  commutative-semiring strength/distribution optimization classes.
 * ============================================================================ */

/* The Nat numeral succ^d(zero) (d in 0..~64; the proof term for large d exceeds TC_CAP). */
fn sov_num(d: u32) -> u32 {
    let mut n : u32 = tc_zero()
    let mut i : u32 = 0u32
    while i < d { n = tc_succ(n)  i = i + 1u32 }
    return n
}

/* The strength-reduction goal at depth k, x symbolic: Pi(x). Id(Nat, mul(x, 2^k), double^k(x)). */
fn sov_synth_strength_goal(k: u32) -> u32 @export {
    let kn : u32 = sov_num(k)
    return tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_var(0u32), sov_m_pow2(kn)), sov_m_itd(tc_var(0u32), kn)))
}

/* THE SYNTHESIZER (strength class): instantiate the proven inductive schema at depth k.
 * Returns the candidate proof term (lam x. schema(x)(k)) -- UNTRUSTED until tc_check disposes it.
 * (The schema body references the shared-tower globals SOV_G_*; the caller must have built them.) */
fn sov_synth_strength_at(k: u32) -> u32 @export {
    let kn : u32 = sov_num(k)
    return tc_lam(tc_nat(), tc_app(tc_app(sov_sr_term(), tc_var(0u32)), kn))
}

/* THE NON-VACUITY GATE (make-or-break): the synthesizer is a GENUINE auto-prover, not a k=2
 * lookup.  For k = 3 AND k = 4 (NEITHER hard-coded in any prior KAT):
 *   (a) the refl disposer sov_pcc_verify REJECTS the strength reduction (add-assoc is propositional);
 *   (b,c) the synthesizer instantiates the inductive schema at the EXTRACTED k -> a non-refl
 *         certificate the kernel ACCEPTS (tc_check == 1);
 *   (d) NEGATIVE CONTROL: the certificate synthesized for k=3 does NOT prove the k=4 goal -- the
 *       kernel is not fooled by a near-miss (the 99.9%-fail discipline, in miniature).
 * 99 = the synthesizer auto-proves what refl cannot, and the kernel rejects the mismatch. */
fn sov_synth_nonvacuity_witness() -> u64 @export {
    /* --- k = 3 --- */
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    sov_l6_build_tower()
    SOV_G_L6[0u32] = sov_l6_term()
    let k3 : u32 = sov_num(3u32)
    let in3 : u32 = sov_m_mul(tc_var(0u32), sov_m_pow2(k3))
    let out3 : u32 = sov_m_itd(tc_var(0u32), k3)
    if sov_pcc_verify(in3, out3) != 0u8 { return 1u64 }                     /* (a) refl REJECTS */
    if tc_check(sov_synth_strength_at(3u32), sov_synth_strength_goal(3u32)) != 1u8 { return 2u64 }  /* (b,c) schema CERTIFIES */

    /* --- k = 4 --- */
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    sov_l6_build_tower()
    SOV_G_L6[0u32] = sov_l6_term()
    let k4 : u32 = sov_num(4u32)
    let in4 : u32 = sov_m_mul(tc_var(0u32), sov_m_pow2(k4))
    let out4 : u32 = sov_m_itd(tc_var(0u32), k4)
    if sov_pcc_verify(in4, out4) != 0u8 { return 3u64 }
    if tc_check(sov_synth_strength_at(4u32), sov_synth_strength_goal(4u32)) != 1u8 { return 4u64 }

    /* --- (d) NEGATIVE CONTROL: k=3 certificate does NOT prove the k=4 goal --- */
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    sov_l6_build_tower()
    SOV_G_L6[0u32] = sov_l6_term()
    if tc_check(sov_synth_strength_at(3u32), sov_synth_strength_goal(4u32)) != 0u8 { return 5u64 }

    return 99u64
}

fn sov_synth_nonvacuity_kat() -> u64 @export {
    return sov_synth_nonvacuity_witness()   /* propagate the precise witness code (1..5 = which arm; 99 = pass) */
}

/* --- the multi-class synthesizer API (consumed by the autocatalytic loop) --- */
const SOV_CLASS_STRENGTH : u32 = 0u32   /* mul(x, 2^param) -> double^param(x)            */
const SOV_CLASS_DISTRIB  : u32 = 1u32   /* mul(x, a+b)     -> add(mul x a, mul x b)  (param ignored) */

/* Set up the shared arena + proven tower for a synthesis attempt (the sov_sr_apply ritual, exported so
 * the outer autocatalyst modules need NO access to the private tower internals (the SOV_G tower). */
fn sov_ac_setup() -> u64 @export {
    tc_reset()
    SOV_SUCCF[0u32] = sov_succf()
    sov_l6_build_tower()
    SOV_G_L6[0u32] = sov_l6_term()
    return 0u64
}

/* The goal TYPE for an optimization (class, param) -- what the kernel must verify the cert against. */
fn sov_synth_goal(class: u32, param: u32) -> u32 @export {
    if class == SOV_CLASS_STRENGTH { return sov_synth_strength_goal(param) }
    if class == SOV_CLASS_DISTRIB {
        /* Pi(x).Pi(a).Pi(b). Id(mul(x, a+b), add(mul x a, mul x b))  in [x,a,b] x=#2,a=#1,b=#0 */
        let gbody : u32 = tc_id(tc_nat(), sov_m_mul(tc_var(2u32), sov_m_add(tc_var(1u32), tc_var(0u32))), sov_m_add(sov_m_mul(tc_var(2u32), tc_var(1u32)), sov_m_mul(tc_var(2u32), tc_var(0u32))))
        return tc_pi(tc_nat(), tc_pi(tc_nat(), tc_pi(tc_nat(), gbody)))
    }
    return 0u32
}

/* The HALLUCINATED strength identity Pi(x). Id(mul(x, 2^a), double^b(x)) -- a candidate equation that is
 * TRUE iff a == b.  The mutagen proposes (a,b) pairs (mostly a != b -> FALSE); the synthesizer's best
 * cert (the schema at a) tc_checks this goal iff a == b, so the kernel disposes of every false dream. */
fn sov_hall_goal(a: u32, b: u32) -> u32 @export {
    let na : u32 = sov_num(a)
    let nb : u32 = sov_num(b)
    return tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_var(0u32), sov_m_pow2(na)), sov_m_itd(tc_var(0u32), nb)))
}

/* THE SYNTHESIZER: propose a candidate proof term for optimization (class, param) within a step budget.
 * budget==0 -> ABORT (sov_synth_timeout: 99.9% of hallucinations die here, returns 0).  Unknown class
 * -> 0.  The returned term is UNTRUSTED until the sieve disposes it through tc_check.  (Caller must
 * sov_ac_setup() first so the tower globals are live.) */
fn sov_synth_attempt(class: u32, param: u32, budget: u32) -> u32 @export {
    if budget == 0u32 { return 0u32 }
    if class == SOV_CLASS_STRENGTH { return sov_synth_strength_at(param) }
    if class == SOV_CLASS_DISTRIB  { return SOV_G_MLD[0u32] }   /* the proven left-distribution lemma */
    return 0u32
}

/* MULTI-CLASS SYNTHESIS + BUDGET + KERNEL DISPOSAL.  99 = the synthesizer serves two distinct
 * optimization classes, honors its step budget, and every soundness verdict is the kernel's:
 *   (1) STRENGTH at k=4: the synthesized cert tc_checks its goal;
 *   (2) DISTRIB:         the synthesized cert (MLD) tc_checks its goal -- a DIFFERENT class;
 *   (3) BUDGET=0:        attempt returns 0 (timeout -> the sieve discards);
 *   (4) FALSE candidate: the k=4 cert does NOT prove the k=3 goal (the kernel rejects a near-miss).
 * (k is held <=4 so the conversion check stays within TC_CAP; a larger k normalizes mul(x,2^k) to a
 *  2^k-deep add-tree that overflows the arena -> the kernel returns 0, the capacity fail-safe -- a real
 *  honest bound on the synthesizer's reach, never a false accept.) */
fn sov_synth_attempt_kat() -> u64 @export {
    sov_ac_setup()
    let c4 : u32 = sov_synth_attempt(SOV_CLASS_STRENGTH, 4u32, 64u32)
    if c4 == 0u32 { return 1u64 }
    if tc_check(c4, sov_synth_goal(SOV_CLASS_STRENGTH, 4u32)) != 1u8 { return 2u64 }
    sov_ac_setup()
    let cd : u32 = sov_synth_attempt(SOV_CLASS_DISTRIB, 0u32, 64u32)
    if cd == 0u32 { return 3u64 }
    if tc_check(cd, sov_synth_goal(SOV_CLASS_DISTRIB, 0u32)) != 1u8 { return 4u64 }
    if sov_synth_attempt(SOV_CLASS_STRENGTH, 4u32, 0u32) != 0u32 { return 5u64 }   /* budget timeout */
    sov_ac_setup()
    if tc_check(sov_synth_attempt(SOV_CLASS_STRENGTH, 4u32, 64u32), sov_synth_goal(SOV_CLASS_STRENGTH, 3u32)) != 0u8 { return 6u64 }
    return 99u64
}

/* --- THE ISOMORPHIC SCYTHE's kernel primitives (consumed by ast_hunter / proof_bisimulation) --- */

/* The cost verdict: the optimal shift-based double^k is STRICTLY cheaper than the legacy multiply
 * mul(x,2^k).  Data-driven via sov_isa_op_cost (cost_calculus-sourced), never hardcoded -- a flat
 * re-seed collapses it (sov_isa_cost_gradient_kat proves that).  1 = optimal strictly cheaper. */
fn sov_strength_cheaper() -> u8 @export {
    cl_init()                                       /* seed the cost_lattice orders (cl_dot_slot needs it) */
    if sov_isa_op_cost(SI_MUL) > sov_isa_op_cost(SI_SHL) { return 1u8 }
    return 0u8
}

/* (The hunter's concrete pre-filter evaluates the two integer functions in plain host arithmetic --
 * see numera/ast_hunter.iii; the CIC kernel is reserved for the UNIVERSAL equivalence proof.) */

/* ============================================================================
 *  THE CERTIFIED OPTIMIZATION CENSUS -- the complete, kernel-proven optimization theory of III's own
 *  arithmetic algebra (the commutative semiring of Nat).  Every class below is a UNIVERSAL rewrite the
 *  CIC kernel proves sound; the census enumerates them, certifies each unrigged, and quantifies the
 *  cost it removes.  This is the honest "negative-tech-debt" inventory: not a magic understanding of
 *  arbitrary code, but the EXHAUSTIVE provable optimization surface of the substrate's own primitives.
 *    classes 0..3 = strength reduction  mul(x, 2^k) -> double^k(x)   for k=1,2,3,4
 *    class  4     = mul identity         mul(1, b) -> b
 *    class  5     = mul annihilator      mul(0, b) -> 0
 *    class  6     = mul commutativity    mul(a,b) -> mul(b,a)
 *    class  7     = mul associativity    mul(mul(a,b),c) -> mul(a,mul(b,c))
 *    class  8     = left distributivity  mul(x, a+b) -> add(mul x a, mul x b)
 * ============================================================================ */
const SOV_CENSUS_N : u32 = 9u32

/* Kernel-certify optimization class `c` (its own arena epoch + proven tower).  1 = the CIC kernel
 * PROVES the rewrite sound for ALL inputs; 0 = not certified.  The kernel is the SOLE arbiter. */
fn sov_census_certify(c: u32) -> u8 @export {
    sov_ac_setup()
    if c <= 3u32 {
        let k : u32 = c + 1u32
        return tc_check(sov_synth_strength_at(k), sov_synth_strength_goal(k))
    }
    if c == 4u32 {
        let g4 : u32 = tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_succ(tc_zero()), tc_var(0u32)), tc_var(0u32)))
        return tc_check(SOV_G_ML1[0u32], g4)
    }
    if c == 5u32 {
        let g5 : u32 = tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_zero(), tc_var(0u32)), tc_zero()))
        return tc_check(SOV_G_MLZ[0u32], g5)
    }
    if c == 6u32 {
        let g6 : u32 = tc_pi(tc_nat(), tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_var(1u32), tc_var(0u32)), sov_m_mul(tc_var(0u32), tc_var(1u32)))))
        return tc_check(SOV_G_MCM[0u32], g6)
    }
    if c == 7u32 {
        let g7 : u32 = tc_pi(tc_nat(), tc_pi(tc_nat(), tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(sov_m_mul(tc_var(2u32), tc_var(1u32)), tc_var(0u32)), sov_m_mul(tc_var(2u32), sov_m_mul(tc_var(1u32), tc_var(0u32)))))))
        return tc_check(SOV_G_MAS[0u32], g7)
    }
    if c == 8u32 {
        let g8 : u32 = tc_pi(tc_nat(), tc_pi(tc_nat(), tc_pi(tc_nat(), tc_id(tc_nat(), sov_m_mul(tc_var(2u32), sov_m_add(tc_var(1u32), tc_var(0u32))), sov_m_add(sov_m_mul(tc_var(2u32), tc_var(1u32)), sov_m_mul(tc_var(2u32), tc_var(0u32)))))))
        return tc_check(SOV_G_MLD[0u32], g8)
    }
    return 0u8
}

/* The cost (in cost-lattice units) a certified class REMOVES per application: strength replaces a MUL
 * with a SHL (delta = cost MUL - cost SHL); identity / annihilator ELIMINATE the MUL entirely (delta =
 * cost MUL); commutativity / associativity / distributivity are structural enablers (direct delta 0). */
fn sov_census_cost_delta(c: u32) -> u64 @export {
    cl_init()
    let m : u64 = sov_isa_op_cost(SI_MUL)
    if c <= 3u32 {
        let s : u64 = sov_isa_op_cost(SI_SHL)
        if m > s { return m - s }
        return 0u64
    }
    if c == 4u32 { return m }
    if c == 5u32 { return m }
    return 0u64
}

fn sov_census_n() -> u32 @export { return SOV_CENSUS_N }

/* How many of the SOV_CENSUS_N classes the kernel certifies (the size of the provable catalog). */
fn sov_census_count() -> u32 @export {
    let mut c : u32 = 0u32
    let mut n : u32 = 0u32
    while c < SOV_CENSUS_N {
        if sov_census_certify(c) == 1u8 { n = n + 1u32 }
        c = c + 1u32
    }
    return n
}

/* Total per-application cost removed across all CERTIFIED classes (the proven optimization yield). */
fn sov_census_cost_saved() -> u64 @export {
    let mut c : u32 = 0u32
    let mut t : u64 = 0u64
    while c < SOV_CENSUS_N {
        if sov_census_certify(c) == 1u8 { t = t + sov_census_cost_delta(c) }
        c = c + 1u32
    }
    return t
}

/* The census is SOUND iff (a) every cataloged class kernel-certifies AND (b) a NON-theorem is rejected
 * (a strength cert at k=2 does NOT prove the k=3 goal -- the kernel refuses an unsound "optimization"). */
fn sov_census_all_sound() -> u8 @export {
    if sov_census_count() != SOV_CENSUS_N { return 0u8 }
    sov_ac_setup()
    if tc_check(sov_synth_strength_at(2u32), sov_synth_strength_goal(3u32)) != 0u8 { return 0u8 }
    return 1u8
}

/* ============================================================================
 *  THE CONSTANT-SHIFT CODEGEN FOLD, KERNEL-CERTIFIED WIDTH-FAITHFULLY (BV64, 2026-06-06).
 *  cg_r3/cg_r3.c fold  x<<k -> shl $k  (and x*2^k -> shl $k) for a COMPILE-TIME-CONSTANT k.
 *  Correctness is the HARDWARE fact  x<<k == x*2^k (mod 2^64), with the x86-64 count mask k&63.
 *
 *  Previously this was proven over unbounded Peano Nat (x<<k = x doubled k times == x*2^k as
 *  ideal integers) and the mod-2^width truncation was waved through "by congruence" -- a deep
 *  k-induction tower (the reason TC_CAP was raised to 131072) that NEVER modelled wraparound.
 *  Now it is proven DIRECTLY in the kernel's native 64-bit machine-int model: bvshl(x, lit k)
 *  iota-reduces in ONE step to bvmul(x, lit 2^(k&63)), so the certificate is a bare `refl` and
 *  the equality is the TRUE width-sensitive machine fact -- not an ideal-integer approximation.
 *  The deep Peano tower is no longer load-bearing for the width fact; the inductive strength
 *  SCHEMA (sov_sr_term) remains as a separate ideal-integer capability.  Untrusted proposer:
 *  numera/bv_ring (full symbolic ring decision); trusted disposer: the CIC kernel's BV iota.
 * ============================================================================ */
/* The fold's certificate: lam x:BV. refl(x<<1) : Pi(x:BV). Id(BV, x<<1, x*2). */
fn sov_shift_fold_term() -> u32 {
    let lhs : u32 = tc_bvshl(tc_var(0u32), tc_bvlit_u64(1u64))    /* x << 1 */
    return tc_lam(tc_bv(), tc_refl(lhs))                          /* lam x:BV. refl(x<<1) */
}
/* The fold's goal: Pi(x:BV). Id(BV, x<<1, x*2)  -- the canonical width-faithful strength reduction. */
fn sov_shift_fold_goal() -> u32 {
    let lhs : u32 = tc_bvshl(tc_var(0u32), tc_bvlit_u64(1u64))
    let rhs : u32 = tc_bvmul(tc_var(0u32), tc_bvlit_u64(2u64))
    return tc_pi(tc_bv(), tc_id(tc_bv(), lhs, rhs))
}
/* Kernel-check  Pi(x:BV). Id(BV, x<<k, x*factor)  via a bare-refl certificate; 1 iff accepted. */
fn sov_bv_fold_check(k: u64, factor: u64) -> u8 {
    let lhs : u32 = tc_bvshl(tc_var(0u32), tc_bvlit_u64(k))
    let rhs : u32 = tc_bvmul(tc_var(0u32), tc_bvlit_u64(factor))
    let goal : u32 = tc_pi(tc_bv(), tc_id(tc_bv(), lhs, rhs))
    let cert : u32 = tc_lam(tc_bv(), tc_refl(lhs))
    return tc_check(cert, goal)
}

/* 99 = the CIC kernel CERTIFIES the constant-shift fold WIDTH-FAITHFULLY (x<<k == x*2^k mod 2^64)
 * across the codegen-relevant family k in {1,5,31,63}, honours the x86-64 count mask (x<<64 == x),
 * computes the fold's OVERFLOW flag by iota, AND rejects the off-by-one (x<<1 != x*4) -- every fact
 * a bare-refl kernel proof over BV64, no Peano tower.  Upgrades the cg_r3 fold from runtime-validated
 * (and ideal-integer kernel-approximated) to kernel-certified width-faithfully. */
fn sov_shift_fold_witness() -> u64 @export {
    tc_reset()
    if tc_check(sov_shift_fold_term(), sov_shift_fold_goal()) != 1u8 { return 1u64 }
    if sov_bv_fold_check(1u64,  2u64) != 1u8 { return 4u64 }
    if sov_bv_fold_check(5u64,  32u64) != 1u8 { return 5u64 }
    if sov_bv_fold_check(31u64, 0x80000000u64) != 1u8 { return 6u64 }
    if sov_bv_fold_check(63u64, 0x8000000000000000u64) != 1u8 { return 7u64 }
    if sov_bv_fold_check(64u64, 1u64) != 1u8 { return 8u64 }   /* x86-64 count mask: x<<64 == x*1 == x */
    /* NEG: off-by-one rejected -- the x<<1 certificate does NOT prove x*4 (= x*2^2). */
    let lhs1 : u32 = tc_bvshl(tc_var(0u32), tc_bvlit_u64(1u64))
    let ng : u32 = tc_pi(tc_bv(), tc_id(tc_bv(), lhs1, tc_bvmul(tc_var(0u32), tc_bvlit_u64(4u64))))
    if tc_check(sov_shift_fold_term(), ng) != 0u8 { return 2u64 }
    /* OVERFLOW-CHECKED folding: the kernel computes the fold's overflow flag by iota. */
    if tc_conv(tc_bvaddovf(tc_bvlit_u64(0xFFFFFFFFFFFFFFFFu64), tc_bvlit_u64(1u64)), tc_true()) != 1u8 { return 9u64 }
    if tc_conv(tc_bvmulovf(tc_bvlit_u64(2u64), tc_bvlit_u64(3u64)), tc_false()) != 1u8 { return 10u64 }
    return 99u64
}
fn sov_shift_fold_kat() -> u64 @export {
    if sov_shift_fold_witness() != 99u64 { return 3u64 }
    return 99u64
}

