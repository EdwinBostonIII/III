/* STDLIB/iii/numera/tense.iii -- TENSE: data-lifetime typing (Aorist / Perfect / Present).  (FINAL / evergreen.)
 *
 * A lifetime/linearity discipline (affine + immutability), as a state machine over a value's lifecycle:
 *   AORIST  = ephemeral, USE-ONCE (a CF8h read folded into the crystal then discarded): consume once, then dead.
 *   PERFECT = completed-with-ongoing-effect, IMMUTABLE after bind (the hardware crystal): writable until bound,
 *             then read-only forever.
 *   PRESENT = live, mutable: all operations always allowed.
 * The state tracks BOUND (bit0) and USED (bit1); tense_step validates one operation and returns the new state, or
 * T_REJECT if the operation violates the tense's discipline.  tense_can_write/tense_can_reuse are the convenience
 * predicates.  Pure, NIH.  Ring R0.  KAT: corpus 1822. */
module numera_tense

const TENSE_AORIST  : u32 = 0u32
const TENSE_PERFECT : u32 = 1u32
const TENSE_PRESENT : u32 = 2u32

const TST_FRESH : u32 = 0u32
const TST_BOUND : u32 = 1u32     /* bit 0 */
const TST_USED  : u32 = 2u32     /* bit 1 */

const TOP_WRITE   : u32 = 0u32
const TOP_READ    : u32 = 1u32
const TOP_BIND    : u32 = 2u32
const TOP_CONSUME : u32 = 3u32

const T_REJECT : u32 = 0xFFFFFFFFu32

/* validate one operation on a value of the given tense in the given state; return the new state or T_REJECT. */
fn tense_step(tense: u32, state: u32, op: u32) -> u32 @export {
    if tense == TENSE_PRESENT { return state }                         /* live: everything allowed, state unchanged */

    if tense == TENSE_PERFECT {
        if op == TOP_READ { return state }                            /* read always */
        if op == TOP_BIND { return state | TST_BOUND }                /* bind freezes it */
        if op == TOP_WRITE {
            if (state & TST_BOUND) != 0u32 { return T_REJECT }        /* immutable after bind */
            return state
        }
        return T_REJECT                                               /* consume is not a Perfect operation */
    }

    if tense == TENSE_AORIST {
        if (state & TST_USED) != 0u32 { return T_REJECT }             /* use-once: nothing after consume */
        if op == TOP_CONSUME { return state | TST_USED }              /* the single use */
        if op == TOP_READ { return state }
        if op == TOP_WRITE { return state }                          /* writable before the single use */
        return T_REJECT
    }
    return T_REJECT
}

/* convenience predicates. */
fn tense_can_write(tense: u32, already_bound: u8) -> u8 @export {
    let st : u32 = (already_bound as u32) & 1u32
    if tense_step(tense, st, TOP_WRITE) == T_REJECT { return 0u8 }
    return 1u8
}
fn tense_can_reuse(tense: u32, already_used: u8) -> u8 @export {
    let mut st : u32 = 0u32
    if already_used == 1u8 { st = TST_USED }
    if tense_step(tense, st, TOP_READ) == T_REJECT { return 0u8 }
    return 1u8
}
