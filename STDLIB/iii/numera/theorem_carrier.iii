/* III/STDLIB/iii/numera/theorem_carrier.iii
 *
 * III STDLIB - numera::theorem_carrier  (Layer 5, Module 62)
 *
 * Theorems as first-class substrate artifacts. A carrier bundles a
 * statement, a VERIFIED proof-term id, a content-addressed carrier id,
 * and the dependency closure (carrier ids this proof cites via
 * PT_RULE_LIBRARY_CITE). M18 binds: no op cites a theorem without its
 * carrier. W35 binds: no theorem without a witnessed proof term --
 * tc_alloc refuses admission unless pt_verify == 0 and every declared
 * dependency is already resident.
 *
 * Reconciliations vs gospel body (spec Gap list items 1-11):
 *   -- keccak256_oneshot from "keccak256.iii" (param-spill-safe oneshot)
 *   -- at_advance() -> u64 from "algebraic_time.iii" (no at_now)
 *   -- wh_publish from "witness_hook.iii" (ws_emit_fragment does not exist)
 *   -- tc_alloc collapsed to req:*u8 aggregate (W2, was 6 params)
 *   -- all function-local [u8;N] arrays hoisted to module scope (Trap 7)
 *   -- Placeholder id-compute line deleted; oneshot over THMC_IDBUF is real
 *   -- statement_len > 1024 guard added (was missing -- buffer overrun)
 *   -- THMC_E_DUP guard for idempotent admission (M5/M17)
 *   -- stable THMC_OP_PROPOSED / THMC_OP_VERIFIED op-ids (M6/M10)
 *   -- pt_verify hoisted before slot lookup (fail-fast, W35/M18)
 *   -- large buffers declared [u64; bytes/8], accessed byte-wise (Trap 19)
 *   -- THMC_TIMESTAMPS : [u64; 16384] (gospel mis-sized as [u8; 524288])
 *
 * Hexad: kind_essence + kind_witness + kind_cognition. Ring: R0. K: 1.00.
 * NIH: identifier, keccak256, proof_term, witness_hook, algebraic_time only.
 * Not reentrant (serialized admission ceremony -- acceptable for substrate).
 *
 * Public API: tc_init, tc_alloc, tc_verify, tc_emit_proposed,
 * tc_emit_verified, tc_get_statement, tc_get_proof_term,
 * tc_get_dependencies, tc_pack_alloc_req, tc_kat.
 */
module numera_theorem_carrier

extern @abi(c-msvc-x64) fn ident_zero(out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_eq(a: *u8, b: *u8) -> u8 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_copy(src: *u8, dst: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_from_bytes(input: *u8, in_len: u64, out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn keccak256_oneshot(msg_ptr: u64, msg_len: u64, out_ptr: u64) -> i32 from "keccak256.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn pt_verify(term_id: *u8) -> i32 from "proof_term.iii"
extern @abi(c-msvc-x64) fn wh_publish(producer: *u8, opid: *u8, in_commit: *u8, out_commit: *u8, revtag: u8, phase: u8, pillar: u16, antecedents: *u8, n_ante: u32, payload: *u8, payload_len: u32, out_frag_id: *u8) -> u64 from "witness_hook.iii"
extern @abi(c-msvc-x64) fn at_advance() -> u64 from "algebraic_time.iii"

/* --- Status codes (THMC_ prefix, Trap 2) --- */
const THMC_OK              : i32 =  0i32
const THMC_E_NULL          : i32 = -1i32
const THMC_E_FULL          : i32 = -2i32
const THMC_E_ABSENT        : i32 = -3i32
const THMC_E_VERIFY_FAIL   : i32 = -4i32
const THMC_E_DEP_ABSENT    : i32 = -5i32
const THMC_E_BUF_TOO_SMALL : i32 = -6i32
const THMC_E_NOT_INITED    : i32 = -7i32
const THMC_E_DUP           : i32 = -8i32

/* --- Capacity constants --- */
const THMC_SLOTS           : u64 = 16384u64
const THMC_STATEMENT_BYTES : u64 = 1024u64
const THMC_MAX_DEPS        : u64 = 64u64
const THMC_ID_BYTES        : u64 = 32u64
const THMC_DEP_STRIDE      : u64 = 2048u64
const THMC_FRAG_TAG0       : u8  = 0xE3u8
const THMC_FRAG_PROPOSED   : u8  = 0x0Au8
const THMC_FRAG_VERIFIED   : u8  = 0x0Bu8

/* --- Scalars --- */
var THMC_INITED            : u8  = 0u8
var THMC_COUNT             : u64 = 0u64

/* --- Slot tables (frugal [u64; bytes/8] for large buffers -- Trap 19) ---
 *
 * THMC_CARRIER_IDS: 16384 * 32 = 524288 bytes -> [u64; 65536]
 * THMC_PROOF_TERM_IDS: same
 * THMC_STATEMENTS: 16384 * 1024 = 16777216 bytes -> [u64; 2097152]
 * THMC_DEPENDENCIES: 16384 * 64 * 32 = 33554432 bytes -> [u64; 4194304]
 * All accessed byte-wise via ((&ARR as u64) + offset) as *u8.
 */
var THMC_CARRIER_IDS       : [u64; 65536]
var THMC_PROOF_TERM_IDS    : [u64; 65536]
var THMC_STATEMENT_LENS    : [u32; 16384]
var THMC_STATEMENTS        : [u64; 2097152]
var THMC_DEPENDENCY_COUNTS : [u32; 16384]
var THMC_DEPENDENCIES      : [u64; 4194304]
var THMC_TIMESTAMPS        : [u64; 16384]
var THMC_LIVE              : [u8;  16384]
var THMC_VERIFIED_FLAG     : [u8;  16384]

/* [W3.1 / COMBINE-3] caller-owned content-address index: carrier_id -> slot, for O(1) tc_find_slot
 * (was an O(THMC_SLOTS)=16384 linear scan, called per dependency -> O((D+1)*16384)).  Sized 32768
 * (>= 16384 slots, <=50% load).  The table is ADD-ONLY (LIVE cleared only on tc_init). */
extern @abi(c-msvc-x64) fn cai_clear(vals: u64, slots: u64) -> i32 from "caindex.iii"
extern @abi(c-msvc-x64) fn cai_get(keys: u64, vals: u64, mask: u64, id: *u8) -> u32 from "caindex.iii"
extern @abi(c-msvc-x64) fn cai_put(keys: u64, vals: u64, mask: u64, id: *u8, payload: u32) -> i32 from "caindex.iii"
const THMC_CAI_SLOTS : u64 = 32768u64
const THMC_CAI_MASK  : u64 = 32767u64
var THMC_CAI_KEYS : [u8;  1048576]   /* 32768 * 32 */
var THMC_CAI_VALS : [u32; 32768]

/* --- Module-scope scratch (Trap 7 -- no local var arrays) --- */
var THMC_HASH_OUT           : [u8; 32]
var THMC_IDBUF              : [u64; 388]      /* 3104 bytes / 8 = 388 words: holds statement(1024) + ptid(32) + deps(2048) */
var THMC_PAYLOAD            : [u64; 266]      /* 64 hdr + 64*32 dep ids, +2 words headroom [audit C-TC-2] */
var THMC_PRODUCER           : [u8; 32]
var THMC_OP_PROPOSED        : [u8; 32]
var THMC_OP_VERIFIED        : [u8; 32]
var THMC_INC                : [u8; 32]
var THMC_OUTC               : [u8; 32]

/* --- KAT scratch --- */
var THMC_KAT_STMT           : [u8; 16]
var THMC_KAT_PTID           : [u8; 32]
var THMC_KAT_DEP            : [u8; 32]
var THMC_KAT_ID             : [u8; 32]
var THMC_KAT_REF            : [u8; 32]
var THMC_KAT_FRAG           : [u8; 32]
var THMC_KAT_OUT            : [u64; 128]      /* 1024 bytes output scratch */
var THMC_KAT_REQBUF         : [u8; 64]
var THMC_KAT_PADS_AND_DEPS  : [u8; 24]       /* ptid ptr(8) + dep ptr(8) + dep_count(8) */
var THMC_KAT_DEPID2         : [u8; 32]
var THMC_KAT_CNTBUF         : [u64; 1]       /* out_count / out_len storage via *u32 */

/* ============================================================
 * Internal helpers
 * ============================================================ */

/* Byte address of slot s's canonical 32-byte carrier id. */
fn tc_cid_addr(s: u64) -> u64 {
    return (&THMC_CARRIER_IDS as u64) + s * 32u64
}

/* Byte address of slot s's proof-term id. */
fn tc_ptid_addr(s: u64) -> u64 {
    return (&THMC_PROOF_TERM_IDS as u64) + s * 32u64
}

/* Byte address of slot s's statement region (stride 1024). */
fn tc_stmt_addr(s: u64) -> u64 {
    return (&THMC_STATEMENTS as u64) + s * 1024u64
}

/* Byte address of slot s's dependency region (stride THMC_DEP_STRIDE=2048). */
fn tc_dep_addr(s: u64) -> u64 {
    return (&THMC_DEPENDENCIES as u64) + s * 2048u64
}

/* Read a u64 little-endian from byte span base at offset off (8 bytes, Trap 4/5 safe). */
fn tc_load_u64_le(base: u64, off: u64) -> u64 {
    let p : *u8 = base as *u8
    let b0 : u64 = p[off + 0u64] as u64
    let b1 : u64 = p[off + 1u64] as u64
    let b2 : u64 = p[off + 2u64] as u64
    let b3 : u64 = p[off + 3u64] as u64
    let b4 : u64 = p[off + 4u64] as u64
    let b5 : u64 = p[off + 5u64] as u64
    let b6 : u64 = p[off + 6u64] as u64
    let b7 : u64 = p[off + 7u64] as u64
    let lo : u64 = b0 | (b1 << 8u64) | (b2 << 16u64) | (b3 << 24u64)
    let hi : u64 = b4 | (b5 << 8u64) | (b6 << 16u64) | (b7 << 24u64)
    return lo | (hi << 32u64)
}

/* Sentinel-scan live slots for carrier_id; return slot as i64, -1i64 if absent.
 * All callers test == / != against -1i64 only (Trap 3). */
fn tc_find_slot(carrier_id: *u8) -> i64 {
    /* [W3.1 / COMBINE-3] O(1) content-address lookup (was an O(THMC_SLOTS)=16384 scan, called per
     * dependency).  Add-only table -> a caindex hit is always a live, full-id-verified match,
     * byte-identical to the old (LIVE && ident_eq) scan's first-match result. */
    let s : u32 = cai_get((&THMC_CAI_KEYS) as u64, (&THMC_CAI_VALS) as u64, THMC_CAI_MASK, carrier_id)
    if s == 0xFFFFFFFFu32 { return -1i64 }
    return s as i64
}

/* Sentinel-scan for a free slot; return index as i64, -1i64 if full. */
fn tc_free_slot() -> i64 {
    let mut found : i64 = -1i64
    let mut sentinel : u8 = 0u8
    let mut i : u64 = 0u64
    while i < THMC_SLOTS {
        if sentinel == 0u8 {
            if THMC_LIVE[i] == 0u8 { found = i as i64  sentinel = 1u8 }
        }
        i = i + 1u64
    }
    return found
}

/* Copy len bytes from src_addr to dst_addr (byte-by-byte, Trap 5). */
fn tc_copy_bytes(dst_addr: u64, src_addr: u64, len: u64) -> i32 {
    let dst : *u8 = dst_addr as *u8
    let src : *u8 = src_addr as *u8
    let mut i : u64 = 0u64
    while i < len {
        dst[i] = src[i]
        i = i + 1u64
    }
    return THMC_OK
}

/* Zero len bytes at dst_addr. */
fn tc_zero_bytes(dst_addr: u64, len: u64) -> i32 {
    let dst : *u8 = dst_addr as *u8
    let mut i : u64 = 0u64
    while i < len {
        dst[i] = 0u8
        i = i + 1u64
    }
    return THMC_OK
}

/* Store a u32 value as 4 LE bytes at (base+off) through *u8 (Trap 5). */
fn tc_store_u32_le(base: u64, off: u64, v: u32) -> i32 {
    let p : *u8 = base as *u8
    p[off + 0u64] = (v & 0xFFu32) as u8
    p[off + 1u64] = ((v >> 8u32) & 0xFFu32) as u8
    p[off + 2u64] = ((v >> 16u32) & 0xFFu32) as u8
    p[off + 3u64] = ((v >> 24u32) & 0xFFu32) as u8
    return THMC_OK
}

/* ============================================================
 * Public API
 * ============================================================ */

/* tc_init -- idempotent; zeros occupancy, sets stable op-ids + producer. */
fn tc_init() -> i32 @export {
    if THMC_INITED == 1u8 { return THMC_OK }
    let mut i : u64 = 0u64
    while i < THMC_SLOTS {
        THMC_LIVE[i] = 0u8
        THMC_VERIFIED_FLAG[i] = 0u8
        i = i + 1u64
    }
    THMC_COUNT = 0u64
    cai_clear((&THMC_CAI_VALS) as u64, THMC_CAI_SLOTS)
    /* Stable op-ids for M6/M10: hash of ASCII op name. */
    let prop_name : *u8 = (&THMC_OP_PROPOSED as u64) as *u8
    THMC_OP_PROPOSED[0]  = 0x74u8   THMC_OP_PROPOSED[1]  = 0x63u8
    THMC_OP_PROPOSED[2]  = 0x5Fu8   THMC_OP_PROPOSED[3]  = 0x65u8
    THMC_OP_PROPOSED[4]  = 0x6Du8   THMC_OP_PROPOSED[5]  = 0x69u8
    THMC_OP_PROPOSED[6]  = 0x74u8   THMC_OP_PROPOSED[7]  = 0x5Fu8
    THMC_OP_PROPOSED[8]  = 0x70u8   THMC_OP_PROPOSED[9]  = 0x72u8
    THMC_OP_PROPOSED[10] = 0x6Fu8   THMC_OP_PROPOSED[11] = 0x70u8
    THMC_OP_PROPOSED[12] = 0x6Fu8   THMC_OP_PROPOSED[13] = 0x73u8
    THMC_OP_PROPOSED[14] = 0x65u8   THMC_OP_PROPOSED[15] = 0x64u8
    let mut k : u64 = 16u64
    while k < 32u64 { THMC_OP_PROPOSED[k] = 0u8  k = k + 1u64 }
    /* Compute ident_from_bytes("tc_emit_proposed", 16) -> THMC_OP_PROPOSED */
    ident_from_bytes(prop_name, 16u64, prop_name)
    let veri_name : *u8 = (&THMC_OP_VERIFIED as u64) as *u8
    THMC_OP_VERIFIED[0]  = 0x74u8   THMC_OP_VERIFIED[1]  = 0x63u8
    THMC_OP_VERIFIED[2]  = 0x5Fu8   THMC_OP_VERIFIED[3]  = 0x65u8
    THMC_OP_VERIFIED[4]  = 0x6Du8   THMC_OP_VERIFIED[5]  = 0x69u8
    THMC_OP_VERIFIED[6]  = 0x74u8   THMC_OP_VERIFIED[7]  = 0x5Fu8
    THMC_OP_VERIFIED[8]  = 0x76u8   THMC_OP_VERIFIED[9]  = 0x65u8
    THMC_OP_VERIFIED[10] = 0x72u8   THMC_OP_VERIFIED[11] = 0x69u8
    THMC_OP_VERIFIED[12] = 0x66u8   THMC_OP_VERIFIED[13] = 0x69u8
    THMC_OP_VERIFIED[14] = 0x65u8   THMC_OP_VERIFIED[15] = 0x64u8
    let mut m : u64 = 16u64
    while m < 32u64 { THMC_OP_VERIFIED[m] = 0u8  m = m + 1u64 }
    ident_from_bytes(veri_name, 16u64, veri_name)
    /* Zero producer (stable null-producer for now -- M6 note). */
    ident_zero((&THMC_PRODUCER as u64) as *u8)
    THMC_INITED = 1u8
    return THMC_OK
}

/* tc_alloc -- W2-clean aggregate input; see TC_ALLOC_REQ layout in spec.
 * req[0..7]   = statement_len (u64 LE)
 * req[8..15]  = absolute ptr to statement bytes (u64 LE)
 * req[16..23] = absolute ptr to proof_term_id (32B) (u64 LE)
 * req[24..31] = absolute ptr to dependency_carriers (dep_count*32B) (u64 LE)
 * req[32..39] = dependency_count (u64 LE)
 */
fn tc_alloc(req: *u8, out_carrier_id: *u8) -> i32 @export {
    if THMC_INITED == 0u8 { return THMC_E_NOT_INITED }
    if (req as u64) == 0u64 { return THMC_E_NULL }
    if (out_carrier_id as u64) == 0u64 { return THMC_E_NULL }
    /* Read the 5 aggregate fields byte-by-byte (Trap 4/5 safe). */
    let req_base : u64 = req as u64
    let statement_len : u64 = tc_load_u64_le(req_base, 0u64)
    let stmt_ptr      : u64 = tc_load_u64_le(req_base, 8u64)
    let ptid_ptr      : u64 = tc_load_u64_le(req_base, 16u64)
    let dep_ptr       : u64 = tc_load_u64_le(req_base, 24u64)
    let dep_count     : u64 = tc_load_u64_le(req_base, 32u64)
    if dep_count > THMC_MAX_DEPS { return THMC_E_FULL }   /* unbounded dep_count overruns THMC_PAYLOAD/dep arrays [audit C-TC-1] */
    /* Null checks. */
    if stmt_ptr == 0u64 { return THMC_E_NULL }
    if ptid_ptr == 0u64 { return THMC_E_NULL }
    /* Statement-length cap guard (new -- spec Gap item 6). */
    if statement_len > THMC_STATEMENT_BYTES { return THMC_E_BUF_TOO_SMALL }
    /* Step 1: Verify proof term FIRST (fail-fast, W35/M18). */
    let ptid_p : *u8 = ptid_ptr as *u8
    if pt_verify(ptid_p) != 0i32 { return THMC_E_VERIFY_FAIL }
    /* Step 2: Verify dependency closure present (sentinel loop, W14). */
    let mut deps_ok : u8 = 1u8
    let mut d : u64 = 0u64
    while d < dep_count {
        if deps_ok == 1u8 {
            let dep_id_p : *u8 = (dep_ptr + d * 32u64) as *u8
            if tc_find_slot(dep_id_p) == -1i64 { deps_ok = 0u8 }
        }
        d = d + 1u64
    }
    if deps_ok == 0u8 { return THMC_E_DEP_ABSENT }
    /* Step 3: Compute carrier id = Keccak256(statement || ptid || dep_ids).
     * Stage contiguously into THMC_IDBUF (3104 bytes, fits statement(1024)+ptid(32)+deps(<=2048)).
     * One oneshot call -- param-spill-safe (Trap 11 / keccak spill fix). */
    let idbuf_base : u64 = &THMC_IDBUF as u64
    tc_copy_bytes(idbuf_base, stmt_ptr, statement_len)
    tc_copy_bytes(idbuf_base + statement_len, ptid_ptr, 32u64)
    let deps_bytes : u64 = dep_count * 32u64
    tc_copy_bytes(idbuf_base + statement_len + 32u64, dep_ptr, deps_bytes)
    let total_len : u64 = statement_len + 32u64 + deps_bytes
    cad_oneshot(1u32, idbuf_base as *u8, total_len, (&THMC_HASH_OUT as u64) as *u8)   /* H2: theorem id via cad (byte-identical) */
    /* Step 4: Idempotent-admit guard (new -- spec Gap item 7, M5/M17). */
    let dup_check : i64 = tc_find_slot((&THMC_HASH_OUT as u64) as *u8)
    if dup_check != -1i64 { return THMC_E_DUP }
    /* Step 5: Find a free slot. */
    let free : i64 = tc_free_slot()
    if free == -1i64 { return THMC_E_FULL }
    let s : u64 = free as u64
    /* Step 6: Commit slot. */
    let cid_dst : *u8 = tc_cid_addr(s) as *u8
    ident_copy((&THMC_HASH_OUT as u64) as *u8, cid_dst)
    ident_copy(cid_dst, out_carrier_id)
    let ptid_dst : *u8 = tc_ptid_addr(s) as *u8
    ident_copy(ptid_ptr as *u8, ptid_dst)
    /* Store statement length (u32 width, masked). */
    let stmt_len_u32 : u32 = (statement_len & 0xFFFFFFFFu64) as u32
    THMC_STATEMENT_LENS[s] = stmt_len_u32
    /* Copy statement bytes into slot's statement region. */
    tc_copy_bytes(tc_stmt_addr(s), stmt_ptr, statement_len)
    /* Store dep count (u32 width, masked). */
    let dep_cnt_u32 : u32 = (dep_count & 0xFFFFFFFFu64) as u32
    THMC_DEPENDENCY_COUNTS[s] = dep_cnt_u32
    /* Copy dependency ids into slot's dep region. */
    tc_copy_bytes(tc_dep_addr(s), dep_ptr, deps_bytes)
    /* Timestamp: algebraic time advance (W17 monotonic). */
    THMC_TIMESTAMPS[s] = at_advance()
    THMC_LIVE[s] = 1u8
    THMC_VERIFIED_FLAG[s] = 1u8
    THMC_COUNT = THMC_COUNT + 1u64
    cai_put((&THMC_CAI_KEYS) as u64, (&THMC_CAI_VALS) as u64, THMC_CAI_MASK, tc_cid_addr(s) as *u8, s as u32)   /* [W3.1] index carrier_id -> slot */
    return THMC_OK
}

/* tc_verify -- re-attest an already-resident carrier; idempotent/reversible (M9). */
fn tc_verify(carrier_id: *u8) -> i32 @export {
    if THMC_INITED == 0u8 { return THMC_E_NOT_INITED }
    if (carrier_id as u64) == 0u64 { return THMC_E_NULL }
    let found : i64 = tc_find_slot(carrier_id)
    if found == -1i64 { return THMC_E_ABSENT }
    let s : u64 = found as u64
    /* Re-verify stored proof term. */
    let ptid_p : *u8 = tc_ptid_addr(s) as *u8
    if pt_verify(ptid_p) != 0i32 { return THMC_E_VERIFY_FAIL }
    /* Re-check dep closure present (sentinel loop, W14). */
    let dc : u64 = (THMC_DEPENDENCY_COUNTS[s] as u64) & 0xFFFFFFFFu64
    let dep_base : u64 = tc_dep_addr(s)
    let mut deps_ok : u8 = 1u8
    let mut d : u64 = 0u64
    while d < dc {
        if deps_ok == 1u8 {
            let dep_id_p : *u8 = (dep_base + d * 32u64) as *u8
            if tc_find_slot(dep_id_p) == -1i64 { deps_ok = 0u8 }
        }
        d = d + 1u64
    }
    if deps_ok == 0u8 { return THMC_E_DEP_ABSENT }
    THMC_VERIFIED_FLAG[s] = 1u8
    return THMC_OK
}

/* tc_emit_proposed -- emit a THEOREM_PROPOSED fragment via wh_publish.
 * Payload (72 bytes): [0]=THMC_FRAG_TAG0, [1]=THMC_FRAG_PROPOSED, [2..7]=0,
 * [8..39]=carrier_id, [40..71]=proof_term_id. M6/M10: distinct op-id. */
fn tc_emit_proposed(carrier_id: *u8, out_frag_id: *u8) -> i32 @export {
    if THMC_INITED == 0u8 { return THMC_E_NOT_INITED }
    if (carrier_id as u64) == 0u64 { return THMC_E_NULL }
    if (out_frag_id as u64) == 0u64 { return THMC_E_NULL }
    let found : i64 = tc_find_slot(carrier_id)
    if found == -1i64 { return THMC_E_ABSENT }
    let s : u64 = found as u64
    let pay_base : u64 = &THMC_PAYLOAD as u64
    let pay : *u8 = pay_base as *u8
    pay[0u64] = THMC_FRAG_TAG0
    pay[1u64] = THMC_FRAG_PROPOSED
    let mut z : u64 = 2u64
    while z < 8u64 { pay[z] = 0u8  z = z + 1u64 }
    /* Copy carrier_id into payload[8..39]. */
    let mut k : u64 = 0u64
    while k < 32u64 { pay[8u64 + k] = carrier_id[k]  k = k + 1u64 }
    /* Copy proof_term_id into payload[40..71]. */
    let ptid_p : *u8 = tc_ptid_addr(s) as *u8
    let mut m : u64 = 0u64
    while m < 32u64 { pay[40u64 + m] = ptid_p[m]  m = m + 1u64 }
    /* in-commit = carrier_id; out-commit = proof_term_id. */
    ident_copy(carrier_id, (&THMC_INC as u64) as *u8)
    ident_copy(ptid_p, (&THMC_OUTC as u64) as *u8)
    let nullp : *u8 = 0u64 as *u8
    let fr : u64 = wh_publish((&THMC_PRODUCER as u64) as *u8, (&THMC_OP_PROPOSED as u64) as *u8, (&THMC_INC as u64) as *u8, (&THMC_OUTC as u64) as *u8, 0u8, 0u8, 0u16, nullp, 0u32, pay, 72u32, out_frag_id)
    if fr == 0xFFFFFFFFFFFFFFFFu64 { return THMC_E_FULL }
    return THMC_OK
}

/* tc_emit_verified -- emit a THEOREM_VERIFIED fragment.
 * Requires THMC_VERIFIED_FLAG[slot]==1. Payload: [0]=E3, [1]=0B, [2..7]=0,
 * [8..39]=carrier_id, [40..71]=proof_term_id, [72..75]=dc LE-u32,
 * [76..79]=0 pad, [80..80+dc*32)=dep ids. plen=80+dc*32. */
fn tc_emit_verified(carrier_id: *u8, out_frag_id: *u8) -> i32 @export {
    if THMC_INITED == 0u8 { return THMC_E_NOT_INITED }
    if (carrier_id as u64) == 0u64 { return THMC_E_NULL }
    if (out_frag_id as u64) == 0u64 { return THMC_E_NULL }
    let found : i64 = tc_find_slot(carrier_id)
    if found == -1i64 { return THMC_E_ABSENT }
    let s : u64 = found as u64
    if THMC_VERIFIED_FLAG[s] == 0u8 { return THMC_E_VERIFY_FAIL }
    let dc : u64 = (THMC_DEPENDENCY_COUNTS[s] as u64) & 0xFFFFFFFFu64
    let dc_u32 : u32 = (dc & 0xFFFFFFFFu64) as u32
    let pay_base : u64 = &THMC_PAYLOAD as u64
    let pay : *u8 = pay_base as *u8
    pay[0u64] = THMC_FRAG_TAG0
    pay[1u64] = THMC_FRAG_VERIFIED
    let mut z : u64 = 2u64
    while z < 8u64 { pay[z] = 0u8  z = z + 1u64 }
    /* carrier_id -> payload[8..39]. */
    let mut k : u64 = 0u64
    while k < 32u64 { pay[8u64 + k] = carrier_id[k]  k = k + 1u64 }
    /* proof_term_id -> payload[40..71]. */
    let ptid_p : *u8 = tc_ptid_addr(s) as *u8
    let mut m : u64 = 0u64
    while m < 32u64 { pay[40u64 + m] = ptid_p[m]  m = m + 1u64 }
    /* dep_count as 4 LE bytes at [72..75] (Trap 5: byte-by-byte). */
    pay[72u64] = (dc_u32 & 0xFFu32) as u8
    pay[73u64] = ((dc_u32 >> 8u32) & 0xFFu32) as u8
    pay[74u64] = ((dc_u32 >> 16u32) & 0xFFu32) as u8
    pay[75u64] = ((dc_u32 >> 24u32) & 0xFFu32) as u8
    /* 4 bytes pad at [76..79]. */
    pay[76u64] = 0u8   pay[77u64] = 0u8   pay[78u64] = 0u8   pay[79u64] = 0u8
    /* dep ids at [80..80+dc*32). Nested sentinel loops (keep shallow -- Trap 13). */
    let dep_base : u64 = tc_dep_addr(s)
    let mut dep_i : u64 = 0u64
    while dep_i < dc {
        let dep_src_base : u64 = dep_base + dep_i * 32u64
        let dep_dst_base : u64 = 80u64 + dep_i * 32u64
        let dep_src : *u8 = dep_src_base as *u8
        let mut q : u64 = 0u64
        while q < 32u64 { pay[dep_dst_base + q] = dep_src[q]  q = q + 1u64 }
        dep_i = dep_i + 1u64
    }
    let plen : u64 = 80u64 + dc * 32u64
    let plen_u32 : u32 = (plen & 0xFFFFFFFFu64) as u32
    ident_copy(carrier_id, (&THMC_INC as u64) as *u8)
    ident_copy(ptid_p, (&THMC_OUTC as u64) as *u8)
    let nullp : *u8 = 0u64 as *u8
    let fr : u64 = wh_publish((&THMC_PRODUCER as u64) as *u8, (&THMC_OP_VERIFIED as u64) as *u8, (&THMC_INC as u64) as *u8, (&THMC_OUTC as u64) as *u8, 0u8, 0u8, 0u16, nullp, 0u32, pay, plen_u32, out_frag_id)
    if fr == 0xFFFFFFFFFFFFFFFFu64 { return THMC_E_FULL }
    return THMC_OK
}

/* tc_get_statement -- copy stored statement bytes to out_buf; set *out_len. */
fn tc_get_statement(carrier_id: *u8, out_buf: *u8, out_cap: u32, out_len: *u32) -> i32 @export {
    if THMC_INITED == 0u8 { return THMC_E_NOT_INITED }
    if (carrier_id as u64) == 0u64 { return THMC_E_NULL }
    if (out_buf as u64) == 0u64 { return THMC_E_NULL }
    if (out_len as u64) == 0u64 { return THMC_E_NULL }
    let found : i64 = tc_find_slot(carrier_id)
    if found == -1i64 { return THMC_E_ABSENT }
    let s : u64 = found as u64
    let len_u32 : u32 = THMC_STATEMENT_LENS[s]
    let len : u64 = (len_u32 as u64) & 0xFFFFFFFFu64
    if (out_cap as u64) < len { return THMC_E_BUF_TOO_SMALL }
    tc_copy_bytes(out_buf as u64, tc_stmt_addr(s), len)
    out_len[0u64] = len_u32
    return THMC_OK
}

/* tc_get_proof_term -- copy stored proof-term id to out_term_id (32 bytes). */
fn tc_get_proof_term(carrier_id: *u8, out_term_id: *u8) -> i32 @export {
    if THMC_INITED == 0u8 { return THMC_E_NOT_INITED }
    if (carrier_id as u64) == 0u64 { return THMC_E_NULL }
    if (out_term_id as u64) == 0u64 { return THMC_E_NULL }
    let found : i64 = tc_find_slot(carrier_id)
    if found == -1i64 { return THMC_E_ABSENT }
    let s : u64 = found as u64
    ident_copy(tc_ptid_addr(s) as *u8, out_term_id)
    return THMC_OK
}

/* tc_get_dependencies -- copy dep ids to out_buf; set *out_count. */
fn tc_get_dependencies(carrier_id: *u8, out_buf: *u8, out_cap: u32, out_count: *u32) -> i32 @export {
    if THMC_INITED == 0u8 { return THMC_E_NOT_INITED }
    if (carrier_id as u64) == 0u64 { return THMC_E_NULL }
    if (out_buf as u64) == 0u64 { return THMC_E_NULL }
    if (out_count as u64) == 0u64 { return THMC_E_NULL }
    let found : i64 = tc_find_slot(carrier_id)
    if found == -1i64 { return THMC_E_ABSENT }
    let s : u64 = found as u64
    let dc_u32 : u32 = THMC_DEPENDENCY_COUNTS[s]
    let dc : u64 = (dc_u32 as u64) & 0xFFFFFFFFu64
    let need : u64 = dc * 32u64
    if (out_cap as u64) < need { return THMC_E_BUF_TOO_SMALL }
    tc_copy_bytes(out_buf as u64, tc_dep_addr(s), need)
    out_count[0u64] = dc_u32
    return THMC_OK
}

/* tc_pack_alloc_req -- convenience packer: writes the 40-byte aggregate header.
 * ptids_and_deps layout (caller provides):
 *   [0..7]   = u64 absolute ptr to proof_term_id (32B)
 *   [8..15]  = u64 absolute ptr to dep ids (dep_count * 32B)
 *   [16..23] = u64 dep_count
 * W2: 4 params. */
fn tc_pack_alloc_req(req_out: *u8, statement: *u8, statement_len: u32, ptids_and_deps: *u8) -> i32 @export {
    if (req_out as u64) == 0u64 { return THMC_E_NULL }
    if (ptids_and_deps as u64) == 0u64 { return THMC_E_NULL }
    let ro : u64 = req_out as u64
    let pd : u64 = ptids_and_deps as u64
    /* statement_len as u64 LE at [0..7]. */
    let slen64 : u64 = (statement_len as u64) & 0xFFFFFFFFu64
    let sr : *u8 = ro as *u8
    sr[0u64] = (slen64 & 0xFFu64) as u8
    sr[1u64] = ((slen64 >> 8u64) & 0xFFu64) as u8
    sr[2u64] = ((slen64 >> 16u64) & 0xFFu64) as u8
    sr[3u64] = ((slen64 >> 24u64) & 0xFFu64) as u8
    sr[4u64] = 0u8   sr[5u64] = 0u8   sr[6u64] = 0u8   sr[7u64] = 0u8
    /* statement ptr as u64 LE at [8..15]. */
    let sp64 : u64 = statement as u64
    sr[8u64]  = (sp64 & 0xFFu64) as u8
    sr[9u64]  = ((sp64 >> 8u64) & 0xFFu64) as u8
    sr[10u64] = ((sp64 >> 16u64) & 0xFFu64) as u8
    sr[11u64] = ((sp64 >> 24u64) & 0xFFu64) as u8
    sr[12u64] = ((sp64 >> 32u64) & 0xFFu64) as u8
    sr[13u64] = ((sp64 >> 40u64) & 0xFFu64) as u8
    sr[14u64] = ((sp64 >> 48u64) & 0xFFu64) as u8
    sr[15u64] = ((sp64 >> 56u64) & 0xFFu64) as u8
    /* proof_term_id ptr at [16..23], dep ptr at [24..31], dep_count at [32..39]:
     * read from ptids_and_deps (24 bytes) byte-by-byte. */
    let pp : *u8 = pd as *u8
    let mut i : u64 = 0u64
    while i < 24u64 {
        sr[16u64 + i] = pp[i]
        i = i + 1u64
    }
    return THMC_OK
}

/* ============================================================
 * tc_kat -- Tier-A self-test; returns 99u64 on full pass.
 * Tier A: standalone (no real pt_verify / wh_publish needed for core KATs).
 * We call tc_alloc / tc_verify / getters directly; pt_verify will return
 * non-zero on a made-up proof-term id (absent from proof_term table) which is
 * exactly the failure path we test in the negative case.
 *
 * Because tc_alloc calls pt_verify internally which needs proof_term.iii to
 * be live, and because this is a compile-only-checked module (integration runs
 * the full KAT after linking), the KAT is structured around the interface
 * contracts that are locally verifiable:
 *
 * KAT 1: not-inited guard (before tc_init).
 * KAT 2: dep-absent negative case.
 * KAT 3: statement > 1024 rejected.
 * KAT 4: buf-too-small on getters.
 * KAT 5: id determinism (same preimage -> same Keccak result in IDBUF).
 * KAT 6: tc_init idempotence (double-call ok).
 * ============================================================ */
fn tc_kat() -> u64 @export {
    /* KAT 1: not-inited guard -- all public APIs must return THMC_E_NOT_INITED
     * before tc_init is called. We save and restore THMC_INITED. */
    let saved_inited : u8 = THMC_INITED
    THMC_INITED = 0u8
    let zerop : *u8 = (&THMC_KAT_PTID as u64) as *u8
    if tc_verify(zerop) != THMC_E_NOT_INITED { THMC_INITED = saved_inited  return 1u64 }
    if tc_emit_proposed(zerop, (&THMC_KAT_FRAG as u64) as *u8) != THMC_E_NOT_INITED { THMC_INITED = saved_inited  return 2u64 }
    if tc_emit_verified(zerop, (&THMC_KAT_FRAG as u64) as *u8) != THMC_E_NOT_INITED { THMC_INITED = saved_inited  return 3u64 }
    if tc_get_proof_term(zerop, (&THMC_KAT_PTID as u64) as *u8) != THMC_E_NOT_INITED { THMC_INITED = saved_inited  return 4u64 }
    THMC_INITED = saved_inited
    /* Initialize for remaining KATs. */
    tc_init()
    /* KAT 2: dep-absent rejection (negative case -- proves guard rejects bad input).
     * Build a request with dep_count=1 and a dep id of all-0xAA that was never admitted.
     * tc_alloc must return THMC_E_DEP_ABSENT and leave THMC_COUNT unchanged. */
    let count_before : u64 = THMC_COUNT
    /* Zero the dep id pattern: 32 bytes of 0xAA. */
    let mut di : u64 = 0u64
    while di < 32u64 { THMC_KAT_DEP[di] = 0xAAu8  di = di + 1u64 }
    /* Zero the proof-term id. */
    let mut pi : u64 = 0u64
    while pi < 32u64 { THMC_KAT_PTID[pi] = 0u8  pi = pi + 1u64 }
    /* Zero the statement. */
    let mut si : u64 = 0u64
    while si < 3u64 { THMC_KAT_STMT[si] = 0u8  si = si + 1u64 }
    /* Pack alloc req using tc_pack_alloc_req. */
    let pab : u64 = &THMC_KAT_PADS_AND_DEPS as u64
    let pabp : *u8 = pab as *u8
    /* pab[0..7] = ptr to ptid (THMC_KAT_PTID). */
    let ptid_addr_val : u64 = &THMC_KAT_PTID as u64
    pabp[0u64]  = (ptid_addr_val & 0xFFu64) as u8
    pabp[1u64]  = ((ptid_addr_val >> 8u64) & 0xFFu64) as u8
    pabp[2u64]  = ((ptid_addr_val >> 16u64) & 0xFFu64) as u8
    pabp[3u64]  = ((ptid_addr_val >> 24u64) & 0xFFu64) as u8
    pabp[4u64]  = ((ptid_addr_val >> 32u64) & 0xFFu64) as u8
    pabp[5u64]  = ((ptid_addr_val >> 40u64) & 0xFFu64) as u8
    pabp[6u64]  = ((ptid_addr_val >> 48u64) & 0xFFu64) as u8
    pabp[7u64]  = ((ptid_addr_val >> 56u64) & 0xFFu64) as u8
    /* pab[8..15] = ptr to dep id (THMC_KAT_DEP). */
    let dep_addr_val : u64 = &THMC_KAT_DEP as u64
    pabp[8u64]  = (dep_addr_val & 0xFFu64) as u8
    pabp[9u64]  = ((dep_addr_val >> 8u64) & 0xFFu64) as u8
    pabp[10u64] = ((dep_addr_val >> 16u64) & 0xFFu64) as u8
    pabp[11u64] = ((dep_addr_val >> 24u64) & 0xFFu64) as u8
    pabp[12u64] = ((dep_addr_val >> 32u64) & 0xFFu64) as u8
    pabp[13u64] = ((dep_addr_val >> 40u64) & 0xFFu64) as u8
    pabp[14u64] = ((dep_addr_val >> 48u64) & 0xFFu64) as u8
    pabp[15u64] = ((dep_addr_val >> 56u64) & 0xFFu64) as u8
    /* pab[16..23] = dep_count = 1. */
    pabp[16u64] = 1u8   pabp[17u64] = 0u8   pabp[18u64] = 0u8   pabp[19u64] = 0u8
    pabp[20u64] = 0u8   pabp[21u64] = 0u8   pabp[22u64] = 0u8   pabp[23u64] = 0u8
    let req_ptr : *u8 = (&THMC_KAT_REQBUF as u64) as *u8
    let stmt_ptr_kat : *u8 = (&THMC_KAT_STMT as u64) as *u8
    tc_pack_alloc_req(req_ptr, stmt_ptr_kat, 3u32, pabp)
    let dep_absent_rc : i32 = tc_alloc(req_ptr, (&THMC_KAT_ID as u64) as *u8)
    /* tc_alloc calls pt_verify first; pt_verify on a zero-id will return non-zero
     * (absent from proof_term table), so we get THMC_E_VERIFY_FAIL here in the
     * standalone (non-linked) scenario. Both THMC_E_VERIFY_FAIL and THMC_E_DEP_ABSENT
     * prove the guard rejects bad input and leaves THMC_COUNT unchanged -- that is
     * the KAT-2 contract. */
    if dep_absent_rc == THMC_OK { return 10u64 }
    if THMC_COUNT != count_before { return 11u64 }
    /* KAT 3: statement > 1024 rejected. */
    /* Build req with statement_len = 1025 (beyond cap). */
    let req3 : *u8 = (&THMC_KAT_REQBUF as u64) as *u8
    let r3b : u64 = &THMC_KAT_REQBUF as u64
    let r3p : *u8 = r3b as *u8
    r3p[0u64] = 0x01u8   r3p[1u64] = 0x04u8   r3p[2u64] = 0u8   r3p[3u64] = 0u8
    r3p[4u64] = 0u8   r3p[5u64] = 0u8   r3p[6u64] = 0u8   r3p[7u64] = 0u8
    let stmt_val64 : u64 = (&THMC_KAT_STMT as u64)
    r3p[8u64]  = (stmt_val64 & 0xFFu64) as u8
    r3p[9u64]  = ((stmt_val64 >> 8u64) & 0xFFu64) as u8
    r3p[10u64] = ((stmt_val64 >> 16u64) & 0xFFu64) as u8
    r3p[11u64] = ((stmt_val64 >> 24u64) & 0xFFu64) as u8
    r3p[12u64] = ((stmt_val64 >> 32u64) & 0xFFu64) as u8
    r3p[13u64] = ((stmt_val64 >> 40u64) & 0xFFu64) as u8
    r3p[14u64] = ((stmt_val64 >> 48u64) & 0xFFu64) as u8
    r3p[15u64] = ((stmt_val64 >> 56u64) & 0xFFu64) as u8
    /* ptid ptr and dep ptr and count zeros. */
    let ptid_v64 : u64 = &THMC_KAT_PTID as u64
    r3p[16u64] = (ptid_v64 & 0xFFu64) as u8
    r3p[17u64] = ((ptid_v64 >> 8u64) & 0xFFu64) as u8
    r3p[18u64] = ((ptid_v64 >> 16u64) & 0xFFu64) as u8
    r3p[19u64] = ((ptid_v64 >> 24u64) & 0xFFu64) as u8
    r3p[20u64] = ((ptid_v64 >> 32u64) & 0xFFu64) as u8
    r3p[21u64] = ((ptid_v64 >> 40u64) & 0xFFu64) as u8
    r3p[22u64] = ((ptid_v64 >> 48u64) & 0xFFu64) as u8
    r3p[23u64] = ((ptid_v64 >> 56u64) & 0xFFu64) as u8
    r3p[24u64] = 0u8   r3p[25u64] = 0u8   r3p[26u64] = 0u8   r3p[27u64] = 0u8
    r3p[28u64] = 0u8   r3p[29u64] = 0u8   r3p[30u64] = 0u8   r3p[31u64] = 0u8
    r3p[32u64] = 0u8   r3p[33u64] = 0u8   r3p[34u64] = 0u8   r3p[35u64] = 0u8
    r3p[36u64] = 0u8   r3p[37u64] = 0u8   r3p[38u64] = 0u8   r3p[39u64] = 0u8
    let rc3 : i32 = tc_alloc(req3, (&THMC_KAT_ID as u64) as *u8)
    if rc3 != THMC_E_BUF_TOO_SMALL { return 20u64 }
    /* KAT 4: buf-too-small on tc_get_statement.
     * Synthesize a fake-resident slot so the getter has something to return.
     * We directly write into the tables (bypassing alloc -- this is a white-box KAT). */
    let fake_s : u64 = 0u64
    /* Set carrier id to known bytes (0x55 * 32). */
    let fake_cid : *u8 = tc_cid_addr(fake_s) as *u8
    let mut fi : u64 = 0u64
    while fi < 32u64 { fake_cid[fi] = 0x55u8  fi = fi + 1u64 }
    THMC_STATEMENT_LENS[fake_s] = 3u32
    THMC_LIVE[fake_s] = 1u8
    cai_put((&THMC_CAI_KEYS) as u64, (&THMC_CAI_VALS) as u64, THMC_CAI_MASK, fake_cid, fake_s as u32)   /* [W3.1] mirror the white-box slot write into the index */
    /* Copy "abc" into statement. */
    let fake_stmt : *u8 = tc_stmt_addr(fake_s) as *u8
    fake_stmt[0u64] = 0x61u8   fake_stmt[1u64] = 0x62u8   fake_stmt[2u64] = 0x63u8
    /* Set ptid to known bytes. */
    let fake_ptid : *u8 = tc_ptid_addr(fake_s) as *u8
    let mut fpi : u64 = 0u64
    while fpi < 32u64 { fake_ptid[fpi] = 0u8  fpi = fpi + 1u64 }
    THMC_DEPENDENCY_COUNTS[fake_s] = 0u32
    THMC_VERIFIED_FLAG[fake_s] = 1u8
    /* out_cap=2 < statement_len=3 -> THMC_E_BUF_TOO_SMALL. */
    let out_buf4 : *u8 = (&THMC_KAT_OUT as u64) as *u8
    let cntbuf : *u32 = (&THMC_KAT_CNTBUF as u64) as *u32
    let rc4 : i32 = tc_get_statement(fake_cid, out_buf4, 2u32, cntbuf)
    if rc4 != THMC_E_BUF_TOO_SMALL { return 30u64 }
    /* KAT 4b: buf-too-small on tc_get_dependencies (fake 0 deps, cap 0 -- always ok). */
    /* KAT 5: successful tc_get_statement on the fake slot. */
    let rc5 : i32 = tc_get_statement(fake_cid, out_buf4, 10u32, cntbuf)
    if rc5 != THMC_OK { return 40u64 }
    if cntbuf[0u64] != 3u32 { return 41u64 }
    if out_buf4[0u64] != 0x61u8 { return 42u64 }
    if out_buf4[1u64] != 0x62u8 { return 43u64 }
    if out_buf4[2u64] != 0x63u8 { return 44u64 }
    /* KAT 5b: tc_get_proof_term returns 32 zero bytes. */
    let rc5b : i32 = tc_get_proof_term(fake_cid, (&THMC_KAT_REF as u64) as *u8)
    if rc5b != THMC_OK { return 45u64 }
    let mut pacc : u32 = 0u32
    let ref_p : *u8 = (&THMC_KAT_REF as u64) as *u8
    let mut ri : u64 = 0u64
    while ri < 32u64 { pacc = pacc | (ref_p[ri] as u32)  ri = ri + 1u64 }
    if pacc != 0u32 { return 46u64 }
    /* KAT 6: tc_init is idempotent (double-call ok, THMC_INITED stays 1). */
    let rc6 : i32 = tc_init()
    if rc6 != THMC_OK { return 50u64 }
    if THMC_INITED != 1u8 { return 51u64 }
    /* KAT 7: id-determinism check -- compute Keccak256 of "abc" + 32 zeros
     * directly and verify the result is a non-trivial 32-byte hash. */
    THMC_KAT_STMT[0u64] = 0x61u8   THMC_KAT_STMT[1u64] = 0x62u8   THMC_KAT_STMT[2u64] = 0x63u8
    let mut zi : u64 = 0u64
    while zi < 32u64 { THMC_KAT_PTID[zi] = 0u8  zi = zi + 1u64 }
    let idbuf7 : u64 = &THMC_IDBUF as u64
    let ibp7 : *u8 = idbuf7 as *u8
    ibp7[0u64] = 0x61u8   ibp7[1u64] = 0x62u8   ibp7[2u64] = 0x63u8
    let mut zi2 : u64 = 0u64
    while zi2 < 32u64 { ibp7[3u64 + zi2] = 0u8  zi2 = zi2 + 1u64 }
    keccak256_oneshot(idbuf7, 35u64, (&THMC_KAT_REF as u64))
    /* Verify the result has at least some nonzero byte (non-trivial hash). */
    let ref7 : *u8 = (&THMC_KAT_REF as u64) as *u8
    let mut hacc : u32 = 0u32
    let mut hi7 : u64 = 0u64
    while hi7 < 32u64 { hacc = hacc | (ref7[hi7] as u32)  hi7 = hi7 + 1u64 }
    if hacc == 0u32 { return 60u64 }
    /* Run again; result must be bit-identical (M2 determinism). */
    keccak256_oneshot(idbuf7, 35u64, (&THMC_HASH_OUT as u64))
    let ho7 : *u8 = (&THMC_HASH_OUT as u64) as *u8
    if ident_eq(ref7, ho7) != 1u8 { return 61u64 }
    /* KAT 8: absent carrier -> THMC_E_ABSENT from tc_verify and getters. */
    let mut ai : u64 = 0u64
    while ai < 32u64 { THMC_KAT_ID[ai] = 0xBBu8  ai = ai + 1u64 }
    let absent_id : *u8 = (&THMC_KAT_ID as u64) as *u8
    if tc_verify(absent_id) != THMC_E_ABSENT { return 70u64 }
    if tc_get_proof_term(absent_id, (&THMC_KAT_REF as u64) as *u8) != THMC_E_ABSENT { return 71u64 }
    if tc_get_dependencies(absent_id, out_buf4, 1024u32, cntbuf) != THMC_E_ABSENT { return 72u64 }
    return 99u64
}

/* Ontological footer: theorem_carrier IS the substrate's theorem-admission
 * ceremony. It embodies M18 (Theorem Carrier Discipline): every theorem
 * in the math library is a carrier with a VERIFIED proof term and a complete
 * dependency closure. It knows HOW to be a theorem -- carrying statement,
 * proof, dependencies, witness fragments, and algebraic timestamps -- not
 * merely how to store one. */
