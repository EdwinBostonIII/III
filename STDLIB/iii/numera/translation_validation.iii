/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\translation_validation.iii
 *
 * III STDLIB - numera::translation_validation  --  TRUST THE CHECKER, NOT THE OPTIMIZER.
 *
 * III's defining philosophy made a tool: rather than trust an optimizer to be correct, VALIDATE its output.
 * A transformation is admitted only if an independent check proves the optimized computation produces the
 * same result as the source for EVERY input -- so a bug anywhere in the (large, untrusted) optimizer is
 * caught by the (small, trusted) checker, no matter how the rewrite was produced.  This is translation
 * validation, the practical road to a trustworthy compiler.
 *
 * Source: f(a) = a*2.  Candidate rewrites: a<<1 (correct), a+a (correct), a<<2 (WRONG: a*4), a*2 (identity).
 * The checker accepts the three equivalent forms and rejects the wrong one, witnessing the first input where
 * it diverges.
 *
 * Verified (translation_validation_kat): the strength-reduced a<<1, the doubling a+a, and the identity a*2
 * are all validated equivalent to a*2 over the input domain; the wrong a<<2 is rejected with a witnessing
 * input (a=1, where a*2=2 but a<<2=4); equivalence is checked over every input, not sampled.  NIH/self-contained.
 *
 * Public API:
 *   tv_source(a) -> u32 ; tv_cand(kind,a) -> u32 ; tv_check(kind) -> u32 ; tv_witness(kind) -> u32
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_translation_validation

const TV_DOM : u32 = 256u32       /* the input domain [0,256) over which equivalence is proven */

var TV_WIT : [u32; 1]             /* first input at which a rejected candidate diverges */

/* the trusted source semantics: f(a) = a*2. */
fn tv_source(a: u32) -> u32 @export { return a * 2u32 }

/* the candidate rewrite forms the (untrusted) optimizer might have emitted. */
fn tv_cand(kind: u32, a: u32) -> u32 @export {
    if kind == 0u32 { return a << 1u32 }          /* strength-reduced: a*2 */
    if kind == 1u32 { return a + a }              /* doubling: a*2 */
    if kind == 2u32 { return a << 2u32 }          /* WRONG: a*4 */
    return a * 2u32                               /* kind 3: identity */
}

/* validate: the candidate equals the source for EVERY input; else record the first divergence. */
fn tv_check(kind: u32) -> u32 @export {
    let mut a : u32 = 0u32
    while a < TV_DOM {
        if tv_source(a) != tv_cand(kind, a) {
            TV_WIT[0u64] = a
            return 0u32
        }
        a = a + 1u32
    }
    return 1u32
}

fn tv_witness(kind: u32) -> u32 @export { return TV_WIT[0u64] }

/* =====================================================================================
 * translation_validation_kat -- 99 = output validation is correct, self-checked:
 *   (1) the strength-reduced a<<1 is validated equivalent to a*2;
 *   (2) the doubling a+a and the identity a*2 are validated equivalent;
 *   (3) the WRONG a<<2 is rejected, witnessed at a=1 (a*2=2 but a<<2=4);
 *   (4) the checker covers the whole domain (a concrete late input agrees for the accepted forms).
 * ===================================================================================== */
fn translation_validation_kat() -> u64 @export {
    /* (1) strength reduction validated */
    if tv_check(0u32) != 1u32 { return 1u64 }

    /* (2) doubling and identity validated */
    if tv_check(1u32) != 1u32 { return 2u64 }
    if tv_check(3u32) != 1u32 { return 3u64 }

    /* (3) the wrong rewrite is rejected, witnessed at a=1 */
    if tv_check(2u32) != 0u32 { return 4u64 }
    if tv_witness(2u32) != 1u32 { return 5u64 }
    if tv_source(1u32) != 2u32 { return 6u64 }
    if tv_cand(2u32, 1u32) != 4u32 { return 7u64 }

    /* (4) whole-domain coverage: a large input still agrees for the accepted forms */
    if tv_cand(0u32, 200u32) != tv_source(200u32) { return 8u64 }
    if tv_cand(1u32, 200u32) != tv_source(200u32) { return 9u64 }

    return 99u64
}
