/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\typecheck.iii
 *
 * III STDLIB - numera::typecheck  (P5 brick 1: the type-theoretic spine)
 *
 * A tiny TOTAL dependent type-checker for lambda-Pi with a predicative universe
 * ladder U0 : U1 : U2 : ...  The de Bruijn criterion: a small trusted kernel
 * that CHECKS (never searches).  Design: DOCS/III-P5-DEPENDENT-CORE-DESIGN.md.
 *
 * Terms live in a flat module-global node arena (function-local arrays indexed
 * by a runtime var SEGFAULT in iii; the arena is the same shape egraph/XII use).
 * De Bruijn indices => no alpha-renaming; binders are nameless.  Conversion is
 * by normalization (NbE): beta-normalize both sides, compare structurally
 * (under de Bruijn, structural identity == alpha-equivalence).
 *
 * The keystone NEGATIVE the KAT witnesses is that the kernel REJECTS  U0 : U0
 * (Girard's paradox; a system with Type : Type proves False).
 *
 * Hexad: kind_essence + kind_cognition.  Ring: R0.  K: 1.00.
 * NIH: the trusted core depends on NOTHING but its own arena -- the smaller the
 * trusted base, the stronger the de Bruijn criterion.  No libc, no OS, no hash.
 */

module numera_typecheck

/* --- Path C: the combinator backend (numera/combinator) as conversion oracle ---
 * tc_to_cb compiles TC terms to variable-free combinators; cb_conv reduces (pure
 * first-order rewrite, NO substitution) + structurally compares.  The differential
 * KAT p5_kat_cbconv proves cb_conv == tc_conv (NbE) on the computational fragment
 * -- the gate that licenses retiring NbE for XII (design 19, toward B16). */
extern @abi(c-msvc-x64) fn cb_reset() -> u64 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_var(k: u32) -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_app(f: u32, a: u32) -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_lam(body: u32) -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_atom(id: u32) -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_true() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_false() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_if_c() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_zero() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_succ_c() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_iter_c() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_natrec_c() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_inl_c() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_inr_c() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_case_c() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_j_c() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_refl_c() -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_compile(m: u32) -> u32 from "combinator.iii"
extern @abi(c-msvc-x64) fn cb_conv(x: u32, y: u32) -> u8 from "combinator.iii"

/* --- Path C: the directed CCL reducer (numera/ccl) -- the beta-eta+iota oracle.
 * tc_to_ccl compiles TC -> categorical combinators; ccl_conv reduces both to CCL
 * normal form (directed, O(reduction-length), NO substitution) + compares.  The
 * differential proves ccl_conv == tc_conv (NbE) on the FULL beta-eta+iota theory. */
extern @abi(c-msvc-x64) fn ccl_reset() -> u64 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_conv(x: u32, y: u32) -> u8 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_snd() -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_fst() -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_comp(a: u32, b: u32) -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_cur(x: u32) -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_cur_d(domain: u32, body: u32) -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_reduce(t: u32) -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_reach_c(h: u32) -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn iii_hexad_reachable(h: u16) -> u8 from "hexad_reach.iii"
extern @abi(c-msvc-x64) fn clek_register(c: u64) -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_lek_c(cs: u32, bs: u32) -> u32 from "ccl.iii"
/* BV64 morphism constructors -- tc_to_ccl compiles TC BV nodes into these CCL primitives. */
extern @abi(c-msvc-x64) fn ccl_bvlit_c(lo: u32, hi: u32) -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_bvadd_c(a: u32, b: u32) -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_bvsub_c(a: u32, b: u32) -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_bvmul_c(a: u32, b: u32) -> u32 from "ccl.iii"
extern @abi(c-msvc-x64) fn ccl_bvand_c(a: u32, b: u32) -> u32 from "ccl.iii"
