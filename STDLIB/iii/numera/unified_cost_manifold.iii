/* STDLIB/iii/numera/unified_cost_manifold.iii -- APOTHEOSIS C.8: the closed-form COST MANIFOLD.
 *
 * `cost_calculus.iii` already maps an op/dep graph to the 6-D cost vector, but its LATENCY dim runs
 * the event-loop micro-arch simulator (`ma_simulate`) -- which can only price a FINISHED design at
 * extraction time. This organ prices the latency in CLOSED FORM: the critical path (longest
 * weighted chain through the dependency DAG), computed by a topological-relaxation DP. That makes
 * cost queryable DURING e-graph saturation, so the optimizer is cost-AWARE (it can compare
 * candidate rewrites mid-search), not merely cost-measuring at the end -- a strictly more powerful
 * synthesis. The result is the same 6-D vector (latency, throughput, regpressure, icache, dcache,
 * energy), all LOWER-IS-BETTER, which the §C.8 `pareto_extraction` frontier and the §C.7 ripple `J`
 * consult. Honestly a MODEL (analytic critical-path + analytic per-op sums), not a cycle-accurate
 * sim -- but a deterministic, integer-exact one.
 *
 * The /math-olympiad guarantee: the critical path is the analytic latency LOWER BOUND -- on a DAG
 * the longest weighted path is exactly the earliest completion time under unbounded parallelism, so
 * `uc_formula_latency` is a sound floor no schedule can beat.
 *
 * Compiler-UNREFERENCED -> LIBNATIVE.  Hexad: kind_essence.  Ring: R0.  NIH: integer DP only; no
 * float, no observed state.  K: 1.00. */
module numera_unified_cost_manifold

const UCM_MAXN : u64 = 512u64
const UCM_MAXE : u64 = 2048u64

var UCM_LAT    : [u64; 512]    /* per-op latency */
var UCM_ENERGY : [u64; 512]    /* per-op energy */
var UCM_REGS   : [u64; 512]    /* per-op register demand */
var UCM_DCACHE : [u64; 512]    /* per-op memory-traffic weight */
var UCM_ESRC   : [u32; 2048]   /* dependency edge: ESRC[k] must finish before EDST[k] */
var UCM_EDST   : [u32; 2048]
var UCM_CP     : [u64; 512]    /* critical-path-to-node DP scratch */
var UCM_N      : [u64; 1]
var UCM_NE     : [u64; 1]

fn uc_reset() -> i32 @export { UCM_N[0u64] = 0u64  UCM_NE[0u64] = 0u64  return 0i32 }

/* declare op i's per-dimension costs (i must be the next index). */
fn uc_set_op(latency: u64, energy: u64, regs: u64, dcache: u64) -> i64 @export {
    let la : u64 = latency  let en : u64 = energy  let rg : u64 = regs  let dc : u64 = dcache
    let i : u64 = UCM_N[0u64]
    if i >= UCM_MAXN { return 0i64 - 1i64 }
    UCM_LAT[i] = la  UCM_ENERGY[i] = en  UCM_REGS[i] = rg  UCM_DCACHE[i] = dc
    UCM_N[0u64] = i + 1u64
    return i as i64
}

/* add a dependency a -> b (a must finish before b starts).  Both endpoints must be DECLARED ops
 * (index < the current op count): an out-of-range index would later index UCM_CP/UCM_LAT past the
 * declared set (reading uninitialized/adjacent scratch) in uc_formula_latency -- refuse it here. */
fn uc_add_dep(a: u32, b: u32) -> i32 @export {
    let k : u64 = UCM_NE[0u64]
    if k >= UCM_MAXE { return 0i32 - 1i32 }
    let n : u64 = UCM_N[0u64]
    if (a as u64) >= n { return 0i32 - 1i32 }
    if (b as u64) >= n { return 0i32 - 1i32 }
    UCM_ESRC[k] = a  UCM_EDST[k] = b
    UCM_NE[0u64] = k + 1u64
    return 0i32
}

/* closed-form latency = the critical path (longest weighted chain).  cp[v] = lat[v] + max over
 * preds a of cp[a]; computed by N rounds of edge relaxation (a longest path has <= N-1 edges, so
 * N rounds converge on a DAG).  Returns max_v cp[v]. */
fn uc_formula_latency() -> u64 @export {
    let n  : u64 = UCM_N[0u64]
    let ne : u64 = UCM_NE[0u64]
    let mut i : u64 = 0u64
    while i < n { UCM_CP[i] = UCM_LAT[i]  i = i + 1u64 }   /* a source's cp is its own latency */
    let mut round : u64 = 0u64
    while round < n {
        let mut k : u64 = 0u64
        while k < ne {
            let a : u64 = UCM_ESRC[k] as u64
            let b : u64 = UCM_EDST[k] as u64
            let cand : u64 = UCM_CP[a] + UCM_LAT[b]   /* path ending at b via a */
            if cand > UCM_CP[b] { UCM_CP[b] = cand }
            k = k + 1u64
        }
        round = round + 1u64
    }
    let mut best : u64 = 0u64
    i = 0u64
    while i < n { if UCM_CP[i] > best { best = UCM_CP[i] }  i = i + 1u64 }
    return best
}

/* the remaining five dims are O(n) analytic sums/maxima (all lower-is-better). */
fn uc_sum_energy() -> u64 @export {
    let n : u64 = UCM_N[0u64]  let mut s : u64 = 0u64  let mut i : u64 = 0u64
    while i < n { s = s + UCM_ENERGY[i]  i = i + 1u64 }
    return s
}
fn uc_max_regpressure() -> u64 @export {
    let n : u64 = UCM_N[0u64]  let mut m : u64 = 0u64  let mut i : u64 = 0u64
    while i < n { if UCM_REGS[i] > m { m = UCM_REGS[i] }  i = i + 1u64 }
    return m
}
fn uc_sum_dcache() -> u64 @export {
    let n : u64 = UCM_N[0u64]  let mut s : u64 = 0u64  let mut i : u64 = 0u64
    while i < n { s = s + UCM_DCACHE[i]  i = i + 1u64 }
    return s
}

/* assemble the 6-D cost vector into out6 (six u64, the cost_calculus/cost_lattice/pareto contract):
 *   [0] critical-path latency  [1] total work (throughput proxy)  [2] max reg pressure
 *   [3] op count (icache)      [4] dcache traffic                 [5] energy */
fn uc_cost(out6: u64) -> i32 @export {
    let p : *u64 = out6 as *u64
    let n : u64 = UCM_N[0u64]
    let mut work : u64 = 0u64  let mut i : u64 = 0u64
    while i < n { work = work + UCM_LAT[i]  i = i + 1u64 }   /* total work = sum of op latencies */
    p[0u64] = uc_formula_latency()
    p[1u64] = work
    p[2u64] = uc_max_regpressure()
    p[3u64] = n
    p[4u64] = uc_sum_dcache()
    p[5u64] = uc_sum_energy()
    return 0i32
}

var UCM_OUT : [u64; 6]

/* Self-test: critical path of a chain = sum; of a parallel split = the longest branch (NOT the
 * sum); the 6-D assembly is exact; and latency is a sound LOWER BOUND (work >= span >= each op).
 * 99 = pass. */
fn ucm_selftest() -> u64 @export {
    /* (1) a CHAIN 0->1->2 with latencies 3,5,7 -> critical path = 3+5+7 = 15. */
    uc_reset()
    uc_set_op(3u64, 1u64, 2u64, 0u64)   /* op 0 */
    uc_set_op(5u64, 1u64, 2u64, 0u64)   /* op 1 */
    uc_set_op(7u64, 1u64, 2u64, 0u64)   /* op 2 */
    uc_add_dep(0u32, 1u32)
    uc_add_dep(1u32, 2u32)
    if uc_formula_latency() != 15u64 { return 1u64 }

    /* (1b) the RELAXATION ROUNDS are LOAD-BEARING: the same chain 0->1->2, but edges inserted OUT of
     * topological order (1->2 BEFORE 0->1) forces a 2nd relaxation round to converge -- a 1-round
     * (or 0-round) impl returns 12, only the full N-round loop returns 15. */
    uc_reset()
    uc_set_op(3u64, 1u64, 1u64, 0u64)
    uc_set_op(5u64, 1u64, 1u64, 0u64)
    uc_set_op(7u64, 1u64, 1u64, 0u64)
    uc_add_dep(1u32, 2u32)
    uc_add_dep(0u32, 1u32)
    if uc_formula_latency() != 15u64 { return 10u64 }   /* a single-pass impl returns 12 here */

    /* (2) a PARALLEL split with NONZERO dcache weights 4,5,6,7 (so the dcache dim is exercised);
     * latencies 2,10,3,1.  paths 0-1-3=13, 0-2-3=6 -> critical path = 13 (longest branch, NOT 16). */
    uc_reset()
    uc_set_op(2u64, 1u64, 1u64, 4u64)   /* 0 */
    uc_set_op(10u64,1u64, 1u64, 5u64)   /* 1 */
    uc_set_op(3u64, 1u64, 1u64, 6u64)   /* 2 */
    uc_set_op(1u64, 1u64, 1u64, 7u64)   /* 3 */
    uc_add_dep(0u32,1u32)  uc_add_dep(0u32,2u32)  uc_add_dep(1u32,3u32)  uc_add_dep(2u32,3u32)
    let span : u64 = uc_formula_latency()
    if span != 13u64 { return 2u64 }

    /* (3) the lower-bound property tested against INDEPENDENTLY-computed bounds (not pinned literals):
     * maxop <= span <= work, where work = sum of op latencies and maxop = the largest single op. A
     * relaxation bug that over- or under-counted the span would now trip arm 3 or 4. */
    let mut work : u64 = 0u64  let mut maxop : u64 = 0u64  let mut z : u64 = 0u64
    while z < 4u64 {
        let lz : u64 = UCM_LAT[z]
        work = work + lz
        if lz > maxop { maxop = lz }
        z = z + 1u64
    }
    if span > work { return 3u64 }     /* span never exceeds total work */
    if span < maxop { return 4u64 }    /* span is at least the largest single op */

    /* (4) the 6-D assembly is exact, INCLUDING the dcache dim (now nonzero). */
    uc_cost(&UCM_OUT as u64)
    if UCM_OUT[0u64] != 13u64 { return 5u64 }    /* latency = critical path */
    if UCM_OUT[1u64] != 16u64 { return 6u64 }    /* work = 2+10+3+1 */
    if UCM_OUT[2u64] != 1u64  { return 7u64 }    /* max regs */
    if UCM_OUT[3u64] != 4u64  { return 8u64 }    /* op count */
    if UCM_OUT[4u64] != 22u64 { return 11u64 }   /* dcache = 4+5+6+7 (a constant-0 stub fails here) */
    if UCM_OUT[5u64] != 4u64  { return 9u64 }    /* energy = 4*1 */

    /* (5) NEGATIVE arm: uc_add_dep REJECTS an out-of-range node index (>= the declared op count).
     * (sentinel spilled to a local -- a parenthesised expr before `{` trips the iiis paren-hexad parse.) */
    let neg1 : i32 = 0i32 - 1i32
    if uc_add_dep(0u32, 600u32) != neg1 { return 12u64 }   /* 600 >= n=4 -> refused */
    if uc_add_dep(0u32, 4u32)   != neg1 { return 13u64 }   /* 4 >= n=4 (off-by-one) -> refused */
    return 99u64
}
