/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\vectorizer.iii
 *
 * III STDLIB - numera::vectorizer  --  VERIFIED VECTORIZATION (four modules compose into one rewrite).
 *
 * The deepest harmony in the analysis stack: turning a scalar loop into a SIMD loop requires THREE proofs
 * at once, each from a different module, and this composes them:
 *   - numera::loop_optimizer (transitively numera::interval_lattice + numera::affine_check) proves the loop
 *     stays in bounds for every iteration;
 *   - numera::align_domain certifies the largest power-of-two width W to which every access is aligned;
 *   - and the W-wide grouping is proven here to COVER exactly the scalar iteration space (no element dropped
 *     or double-processed), legal only when W divides the trip count.
 * Only when safety, alignment, clean coverage, and equivalence ALL hold is a width W>=2 emitted; otherwise
 * the loop falls back to scalar (width 1) or is refused outright (unsafe).  No single module could license
 * this rewrite; their composition does.
 *
 * Verified (vectorizer_kat): an in-bounds 8-strided loop vectorizes at width 8; a base-misaligned variant
 * drops to width 4; an odd-stride loop stays scalar (width 1); an out-of-bounds loop is refused (0); and the
 * width-W grouping is proven to cover exactly the scalar iteration space.  NIH; composes loop_optimizer and
 * align_domain.
 *
 * Public API:
 *   vz_covers(n,W) -> u32 ; vz_simd_safe(a,b,W) -> u32 ; vz_equivalent(a,b,n,W) -> u32 ;
 *   vz_vectorize(a,b,n,size) -> u32   (0 unsafe, 1 scalar, >=2 vector width)
 *
 * Hexad: kind_essence.  Ring: R0.  K: 0.99.
 */
module numera_vectorizer

extern @abi(c-msvc-x64) fn lo_optimize(a: u32, b: u32, n: u32, size: u32) -> u32 from "loop_optimizer.iii"
extern @abi(c-msvc-x64) fn ad_max_vector_width(base: u32, stride: u32) -> u32 from "align_domain.iii"
extern @abi(c-msvc-x64) fn ad_loop_aligned(base: u32, stride: u32, w: u32) -> u32 from "align_domain.iii"

/* clean coverage: the trip count n is a multiple of the width W (W is a power of two). */
fn vz_covers(n: u32, w: u32) -> u32 @export {
    if (n & (w - 1u32)) == 0u32 { return 1u32 }
    return 0u32
}

/* every access a*i+b is W-aligned (so the SIMD load/store is an aligned access). */
fn vz_simd_safe(a: u32, b: u32, w: u32) -> u32 @export {
    return ad_loop_aligned(b, a, w)            /* access = b + i*a ; aligned iff w|b and w|a */
}

/* the W-wide grouping covers EXACTLY the scalar iteration space [0,n): each i hit once, none beyond n. */
fn vz_equivalent(a: u32, b: u32, n: u32, w: u32) -> u32 @export {
    let mut seen : u32 = 0u32
    let mut g : u32 = 0u32
    while g < n {
        let mut l : u32 = 0u32
        while l < w {
            let i : u32 = g + l
            if i < n { seen = seen | (1u32 << i) }
            l = l + 1u32
        }
        g = g + w
    }
    let full : u32 = (1u32 << n) - 1u32
    if seen == full { return 1u32 }
    return 0u32
}

/* the vectorization verdict: 0 = unsafe (cannot run), 1 = scalar only, W>=2 = legal SIMD width. */
fn vz_vectorize(a: u32, b: u32, n: u32, size: u32) -> u32 @export {
    if lo_optimize(a, b, n, size) == 0u32 { return 0u32 }   /* not even safe to run */
    let w : u32 = ad_max_vector_width(a, b)                  /* largest aligned width */
    if w < 2u32 { return 1u32 }                              /* not alignable beyond scalar */
    if vz_covers(n, w) == 0u32 { return 1u32 }               /* trip count not a multiple of W */
    if vz_simd_safe(a, b, w) == 0u32 { return 1u32 }         /* some access not W-aligned */
    if vz_equivalent(a, b, n, w) == 0u32 { return 1u32 }     /* grouping would drop/repeat an element */
    return w                                                 /* fully certified at width W */
}

/* =====================================================================================
 * vectorizer_kat -- 99 = verified vectorization composes four modules correctly, self-checked:
 *   (1) an in-bounds 8-strided loop (a=8,b=0,n=16,size=256) vectorizes at width 8;
 *   (2) a base-misaligned variant (a=8,b=4) drops to width 4 (gcd alignment);
 *   (3) an odd-stride loop (a=3,b=1) stays SCALAR (width 1);
 *   (4) an out-of-bounds loop (n=256,size=16) is REFUSED (0); and the width-8 grouping covers exactly [0,16).
 * ===================================================================================== */
fn vectorizer_kat() -> u64 @export {
    /* (1) clean SIMD width 8 */
    if vz_vectorize(8u32, 0u32, 16u32, 256u32) != 8u32 { return 1u64 }

    /* (2) base misaligned -> width 4 */
    if vz_vectorize(8u32, 4u32, 16u32, 256u32) != 4u32 { return 2u64 }

    /* (3) odd stride -> scalar only */
    if vz_vectorize(3u32, 1u32, 16u32, 256u32) != 1u32 { return 3u64 }

    /* (4) out of bounds -> refused */
    if vz_vectorize(8u32, 0u32, 256u32, 16u32) != 0u32 { return 4u64 }

    /* the grouping covers exactly the scalar space; a non-dividing width does not */
    if vz_equivalent(8u32, 0u32, 16u32, 8u32) != 1u32 { return 5u64 }
    if vz_covers(16u32, 8u32) != 1u32 { return 6u64 }
    if vz_covers(20u32, 8u32) != 0u32 { return 7u64 }            /* 20 not a multiple of 8 */
    if vz_simd_safe(8u32, 0u32, 8u32) != 1u32 { return 8u64 }
    if vz_simd_safe(8u32, 4u32, 8u32) != 0u32 { return 9u64 }    /* base 4 not 8-aligned */

    return 99u64
}
