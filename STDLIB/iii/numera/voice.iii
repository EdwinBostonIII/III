/* STDLIB/iii/numera/voice.iii -- VOICE AS A THREE-EFFECT SYSTEM (Active / Middle / Passive).
 *
 * POC for safety-as-grammar: every metal operation carries a VOICE that determines its proof obligation, so the
 * synthesis engine knows the safety implication from the op's type -- no separate checker.
 *   PASSIVE (read; the universal latch -- CPUID/PCI): always realizes.  No obligation.
 *   MIDDLE  (reversible self-probe -- the throwaway-guest): realizes ONLY inside a rollback envelope, else EVAPORATES.
 *   ACTIVE  (external write -- bare-metal assert): realizes ONLY with a crystal-minted capability, else EVAPORATES.
 * "Evaporates" = VK_NULL: the op becomes unrepresentable and contributes nothing (the EK_NULL / logic6 don't-care
 * principle applied to safety -- unsafe code does not error, it VANISHES).  Pure, NIH.  Ring R0.  KAT: corpus 1816. */
module numera_voice

const VOICE_PASSIVE : u32 = 0u32
const VOICE_MIDDLE  : u32 = 1u32
const VOICE_ACTIVE  : u32 = 2u32
const VK_NULL : u32 = 0xFFFFFFFFu32   /* evaporated / unrepresentable */

/* admit one op: returns its realized token, or VK_NULL if it evaporates (the safety obligation unmet). */
fn voice_admit(voice: u32, op_token: u32, has_cap: u8, has_env: u8) -> u32 @export {
    if voice == VOICE_PASSIVE { return op_token }
    if voice == VOICE_MIDDLE  { if has_env == 1u8 { return op_token }  return VK_NULL }
    if voice == VOICE_ACTIVE  { if has_cap == 1u8 { return op_token }  return VK_NULL }
    return VK_NULL
}

/* 1 iff the op realizes (did not evaporate). */
fn voice_realizes(voice: u32, has_cap: u8, has_env: u8) -> u8 @export {
    if voice_admit(voice, 1u32, has_cap, has_env) == VK_NULL { return 0u8 }
    return 1u8
}

/* THE EVAPORATION PASS: over a program of parallel arrays (voices[i], caps[i], envs[i]), count the ops that
 * REALIZE -- unsafe Active/Middle ops evaporate and are not counted (they emit nothing).  The realized count is the
 * size of the safe residual program. */
fn voice_residual_count(voices_ptr: u64, caps_ptr: u64, envs_ptr: u64, n: u32) -> u32 @export {
    let mut realized : u32 = 0u32
    let mut i : u32 = 0u32
    while i < n {
        let vp : *u8 = (voices_ptr + (i as u64)) as *u8
        let cp : *u8 = (caps_ptr + (i as u64)) as *u8
        let ep : *u8 = (envs_ptr + (i as u64)) as *u8
        if voice_realizes(vp[0u64] as u32, cp[0u64], ep[0u64]) == 1u8 { realized = realized + 1u32 }
        i = i + 1u32
    }
    return realized
}
