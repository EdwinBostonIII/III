/* STDLIB/iii/numera/weave_graph.iii -- THE WEAVE ITSELF: the six-state-typed proof-graph of III's REAL primitives.
 *
 * The structure the founding chat specified (verbatim): "one mathematical woven structure that serves as the
 * common denominator of every former III primitive ... such that III understands itself through the lens of this
 * perfect math", with six-state's exact role "nodes = primitive building-blocks as bitvector circuits; edges =
 * SAT-proven relations; logic6 types the PROOF STATUS of the web's strands."
 *
 * The nodes here are the ACTUAL III crypto primitives as bv_bits circuits -- the SHA-2 choice/majority functions
 * and the ChaCha/SHA/Blake2 rotation -- the SAME circuits numera/primweb proves and numera/weave_blocks executes.
 * The names are dissolved: a node is the MATH (a rotation, a mux), not "ChaCha's" or "Blake2's".  The edges are
 * SAT-proven (bb_equal) relations, and they INDEX primweb's existing theorems (ws_strand_agrees_primweb checks
 * the weave's typed edges against pw_sha_ch_optform / pw_sha_maj_optform / pw_rot_duality) -- not reinvented.
 *
 * SIX-STATE types each strand's PROOF STATUS (the meta-level, not the bits):
 *   ALL  (5)  proven-equivalent for ALL tested widths -- a UNIVERSAL theorem (the SHA-2 Ch/Maj structural laws,
 *             which are bitwise and hold at every width).
 *   BOTH (3)  equivalent ONLY UNDER A CONDITION -- the ROTATION DUALITY rotl(x,k) == rotr(x,w-k) is real but
 *             WIDTH-TIED: with the 32-bit crypto constants (rotl 7 vs rotr 25 = 32-7), it holds at width 32 and
 *             is proven-distinct at width 64.  This is the genuine conditional strand -- six-state's paraconsistent
 *             middle on a REAL primitive relation, not a manufactured example.
 *   TRUE (1)  proven-equivalent at the canonical 32-bit crypto width.
 *   FALSE(2)  proven-distinct (Ch is not Maj; one rotation is not another).
 *   NEITHER/NULL (0/4)  an open strand not yet proven.
 *
 * This is the cross-primitive index: the (rotl 7, rotr 25) strand IS the ChaCha-rotl <-> SHA/Blake2-rotr
 * connection (the duality every primitive's rotation factors through).  III FILLS this web (numera/present's
 * present_weave_graph enumerates + admits the proven strands); the commons PERSISTS it.  Composes numera/bv_bits
 * + numera/primweb (no island; it is the typed index OF primweb's universe).  Ring: R0.  K: 1.00.  Deterministic. */
module numera_weave_graph

extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_and(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_or(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_xor(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_not(a: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shl(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shr(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_add(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_equal(a: u32, b: u32) -> u8 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_count_and() -> u64 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_count_kind(kind: u32) -> u64 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_has_coupling() -> u8 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_sig_equal(a: u32, b: u32, nvars: u32) -> u8 from "bv_bits.iii"
/* the proven theorems this graph INDEXES (numera/primweb), to confirm the typed edges are the real strands: */
extern @abi(c-msvc-x64) fn pw_sha_ch_optform() -> u8 from "primweb.iii"
extern @abi(c-msvc-x64) fn pw_sha_maj_optform() -> u8 from "primweb.iii"
extern @abi(c-msvc-x64) fn pw_rot_duality(k: u64) -> u8 from "primweb.iii"
extern @abi(c-msvc-x64) fn pw_arx_atom_invertible() -> u8 from "primweb.iii"
extern @abi(c-msvc-x64) fn pw_toffoli_self_inverse() -> u8 from "primweb.iii"
extern @abi(c-msvc-x64) fn pw_toffoli_is_nand() -> u8 from "primweb.iii"

const WG_NEITHER : u32 = 0u32
const WG_TRUE    : u32 = 1u32
const WG_FALSE   : u32 = 2u32
const WG_BOTH    : u32 = 3u32
const WG_NULL    : u32 = 4u32
const WG_ALL     : u32 = 5u32

const WG_NODES : u32 = 8u32

/* width-parametric rotation (the rotate the crypto primitives use): rotl/rotr by k over a w-bit word. */
fn ws_rotl(x: u32, k: u64, w: u64) -> u32 { return bb_or(bb_shl(x, k), bb_shr(x, w - k)) }
fn ws_rotr(x: u32, k: u64, w: u64) -> u32 { return bb_or(bb_shr(x, k), bb_shl(x, w - k)) }

/* the primitive NODES -- the REAL III crypto building-blocks as bv circuits (a,b,c are inputs; w the width). */
fn ws_node(idx: u32, w: u64, a: u32, b: u32, c: u32) -> u32 {
    if idx == 0u32 { return bb_xor(bb_and(a, b), bb_and(bb_not(a), c)) }                 /* SHA-2 Ch: spec mux */
    if idx == 1u32 { return bb_xor(c, bb_and(a, bb_xor(b, c))) }                         /* SHA-2 Ch: optform */
    if idx == 2u32 { return bb_xor(bb_xor(bb_and(a, b), bb_and(a, c)), bb_and(b, c)) }   /* SHA-2 Maj: spec */
    if idx == 3u32 { return bb_xor(bb_and(a, b), bb_and(c, bb_xor(a, b))) }              /* SHA-2 Maj: carry-save */
    if idx == 4u32 { return ws_rotl(a, 7u64, w) }                                        /* rotl 7  (ChaCha/SHA) */
    if idx == 5u32 { return ws_rotr(a, 25u64, w) }                                       /* rotr 25 = rotl 7 @ w=32 */
    if idx == 6u32 { return ws_rotl(a, 16u64, w) }                                       /* rotl 16 */
    return ws_rotr(a, 16u64, w)                                                           /* rotr 16 = rotl 16 @ w=32 */
}

fn ws_node_count() -> u32 @export { return WG_NODES }

fn ws_edge_eq_at(i: u32, j: u32, w: u64) -> u8 {
    bb_reset(w)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    let c : u32 = bb_var(2u32)
    return bb_equal(ws_node(i, w, a, b, c), ws_node(j, w, a, b, c))
}

/* the six-state PROOF STATUS of the strand between nodes i and j.  Tested at the 32-bit crypto width and at 64:
 * equivalent at BOTH -> universal (ALL); at exactly one -> width-conditional (BOTH); at NEITHER -> refuted (FALSE). */
fn ws_edge_status(i: u32, j: u32) -> u32 @export {
    if i >= WG_NODES { return WG_NULL }
    if j >= WG_NODES { return WG_NULL }
    let e32 : u8 = ws_edge_eq_at(i, j, 32u64)
    let e64 : u8 = ws_edge_eq_at(i, j, 64u64)
    if e32 == 1u8 { if e64 == 1u8 { return WG_ALL } }       /* universal -- holds at every width */
    if e32 == 1u8 { return WG_BOTH }                        /* conditional -- the 32-bit-tied rotation duality */
    if e64 == 1u8 { return WG_BOTH }
    return WG_FALSE                                         /* proven-distinct */
}

/* proven-equivalent at the canonical 32-bit crypto width (TRUE) or proven-distinct (FALSE). */
fn ws_edge_proven(i: u32, j: u32) -> u32 @export {
    if i >= WG_NODES { return WG_NULL }
    if j >= WG_NODES { return WG_NULL }
    if ws_edge_eq_at(i, j, 32u64) == 1u8 { return WG_TRUE }
    return WG_FALSE
}

/* THE WOVEN CENSUS: tally every undirected strand by its six-state proof-status.  out -> three u32 (LE):
 * [ALL (universal theorems), BOTH (width-conditional strands), FALSE (refuted)]. */
fn ws_weave_census(out: u64) -> i32 @export {
    let mut n_all   : u32 = 0u32
    let mut n_both  : u32 = 0u32
    let mut n_false : u32 = 0u32
    let mut i : u32 = 0u32
    while i < WG_NODES {
        let mut j : u32 = i + 1u32
        while j < WG_NODES {
            let s : u32 = ws_edge_status(i, j)
            if s == WG_ALL { n_all = n_all + 1u32 }
            if s == WG_BOTH { n_both = n_both + 1u32 }
            if s == WG_FALSE { n_false = n_false + 1u32 }
            j = j + 1u32
        }
        i = i + 1u32
    }
    ws_put_u32le(out, 0u64, n_all)
    ws_put_u32le(out, 4u64, n_both)
    ws_put_u32le(out, 8u64, n_false)
    return 0i32
}

fn ws_weave_universal_count() -> u32 @export {
    let mut n_all : u32 = 0u32
    let mut i : u32 = 0u32
    while i < WG_NODES {
        let mut j : u32 = i + 1u32
        while j < WG_NODES {
            if ws_edge_status(i, j) == WG_ALL { n_all = n_all + 1u32 }
            j = j + 1u32
        }
        i = i + 1u32
    }
    return n_all
}

/* INDEX primweb: confirm the weave's typed edges ARE primweb's named theorems -- the Ch optform strand (0,1)
 * matches pw_sha_ch_optform, the Maj optform strand (2,3) matches pw_sha_maj_optform, and the rotation-duality
 * strand (4,5) -- rotl(x,7) == rotr(x,25) -- matches pw_rot_duality(7).  Returns 1 iff the weave and primweb
 * agree on all three (the graph is the typed index OF primweb's universe, not a parallel reinvention). */
fn ws_strand_agrees_primweb() -> u8 @export {
    if ws_edge_proven(0u32, 1u32) != WG_TRUE { return 0u8 }
    if pw_sha_ch_optform() != 1u8 { return 0u8 }
    if ws_edge_proven(2u32, 3u32) != WG_TRUE { return 0u8 }
    if pw_sha_maj_optform() != 1u8 { return 0u8 }
    if ws_edge_proven(4u32, 5u32) != WG_TRUE { return 0u8 }     /* rotl 7 == rotr 25 at w=32 */
    if pw_rot_duality(7u64) != 1u8 { return 0u8 }               /* primweb's same theorem */
    return 1u8
}

/* ============================================================================================================
 * THE COST-TRUTH SELECT (the second face of the common denominator): when two nodes are PROVEN EQUIVALENT, the
 * weave does not keep both -- it SELECTS the cheaper by gate cost (AND-gate count, the bb_bits cost-truth) and
 * the costlier is OBSOLETE.  This is "select the cheapest by the cost-truth, which makes the loser obsolete"
 * (the founding chat): the Ch spec mux costs 2 ANDs, the optform 1 -- so the spec is retired; the Maj spec costs
 * 3 ANDs, the carry-save 2 -- the spec is retired.  Borrowed names dissolved AND the redundant form eliminated. */

/* the AND-gate cost of a node's circuit at width w (the cost-truth's measure). */
fn ws_node_cost(idx: u32, w: u64) -> u64 {
    bb_reset(w)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    let c : u32 = bb_var(2u32)
    ws_node(idx, w, a, b, c)
    return bb_count_and()
}
fn ws_node_cost_at(idx: u32) -> u64 @export { return ws_node_cost(idx, 32u64) }

/* for a strand, the CHEAPER node (fewer AND-gates) -- the one the weave keeps canonical; the other is obsolete.
 * Returns the index of the cheaper node (i on a tie). */
fn ws_strand_cheaper(i: u32, j: u32) -> u32 @export {
    let ci : u64 = ws_node_cost(i, 32u64)
    let cj : u64 = ws_node_cost(j, 32u64)
    if cj < ci { return j }
    return i
}

/* 1 iff the strand (i,j) is PROVEN-EQUIVALENT at the crypto width AND the two forms have DIFFERENT cost -- i.e.
 * the weave can retire the costlier without changing behavior (a genuine obsolescence, proof- and cost-backed). */
fn ws_strand_retires(i: u32, j: u32) -> u8 @export {
    if ws_edge_proven(i, j) != WG_TRUE { return 0u8 }
    if ws_node_cost(i, 32u64) == ws_node_cost(j, 32u64) { return 0u8 }
    return 1u8
}

/* ============================================================================================================
 * THE SECOND KIND OF COMMON DENOMINATOR (the founding chat, D05 ~24517): where two primitives share not an
 * operation-sequence but a RESULT computed by DIFFERENT ALGORITHMS, the weave proves them equivalent and selects
 * the cheapest by the cost-truth, "which makes the loser obsolete."  This is the mechanism that genuinely RETIRES
 * a primitive (Montgomery vanishes wherever a cheaper fold provably wins).
 *
 * Concrete strand (the strength-reduction instance, tractable in the SAT judge): 5*x by the naive algorithm
 * (x+x+x+x+x, four adds) vs the strength-reduced algorithm ((x<<2)+x, one shift + one add).  SAME RESULT,
 * DIFFERENT ALGORITHM.  Proven equal for all x; the naive form costs far more gates, so it is retired. */
fn ws_mul5_naive(x: u32) -> u32 { return bb_add(bb_add(bb_add(bb_add(x, x), x), x), x) }   /* x+x+x+x+x */
fn ws_mul5_fold(x: u32) -> u32 { return bb_add(bb_shl(x, 2u64), x) }                        /* (x<<2)+x */

/* 1 iff the two algorithms compute the same result for all x at width w (the equivalence that licenses retirement). */
fn ws_secondkind_proven(w: u64) -> u8 @export {
    bb_reset(w)
    let x : u32 = bb_var(0u32)
    return bb_equal(ws_mul5_naive(x), ws_mul5_fold(x))
}
/* ============================================================================================================
 * THE TOPOLOGICAL BIFURCATOR (the melt, made honest): decide whether two circuits are equal by ROUTING on their
 * data-flow topology, not by one fixed method.  A bit-INDEPENDENT circuit (only AND/OR/XOR/NOT -- bit n depends
 * only on bit n of its inputs) is decided by the MELTED SIGNATURE JUDGE (bb_sig_equal): a truth-table byte
 * compare, no SAT, no clauses, and WIDTH-AGNOSTIC -- the result holds at every width because the truth table is
 * the same at every width.  A bit-COUPLING circuit (ADD/SUB/MUL/SHL/SHR -- bit n crosses into other bits) cannot
 * be a truth-table; it routes to the SAT judge (bb_equal), bound to a physical width, where a width-conditional
 * verdict (the rotation-duality BOTH) is a REAL mathematical limitation of diagonal data-flow, not an artifact.
 * One mechanism, the right tool per topology -- the four clumps melted where they CAN melt, the judge kept where
 * the math genuinely forbids it. */

fn ws_is_bit_independent() -> u8 @export { if bb_has_coupling() == 0u8 { return 1u8 }  return 0u8 }

/* the bifurcated verdict: ALL (signature-proven, width-agnostic universal) for the bit-independent fragment;
 * TRUE (SAT-proven at the built width) for the bit-coupling fragment; FALSE if distinct.  a,b are built in the
 * current bb session; nvars is the input count for the signature route. */
fn ws_decide(a: u32, b: u32, nvars: u32) -> u32 @export {
    if bb_has_coupling() == 0u8 {
        if bb_sig_equal(a, b, nvars) == 1u8 { return WG_ALL }       /* signature: universal, no SAT */
        return WG_FALSE
    }
    if bb_equal(a, b) == 1u8 { return WG_TRUE }                     /* SAT: proven at this physical width */
    return WG_FALSE
}

/* the cost-truth for arithmetic strands is the ADD-operation count (EK_ADD=8) -- the adder is the dominant cost
 * of a multiply-by-constant, and bb_add is one structural node, so this counts algorithm steps faithfully. */
fn ws_secondkind_naive_cost(w: u64) -> u64 @export {
    bb_reset(w)
    let x : u32 = bb_var(0u32)
    ws_mul5_naive(x)
    return bb_count_kind(8u32)
}
fn ws_secondkind_fold_cost(w: u64) -> u64 @export {
    bb_reset(w)
    let x : u32 = bb_var(0u32)
    ws_mul5_fold(x)
    return bb_count_kind(8u32)
}
/* 1 iff the second-kind strand RETIRES the naive algorithm: proven-equivalent AND the fold is strictly cheaper.
 * The general/naive primitive is then obsolete for this result -- the common-denominator dissolution. */
fn ws_secondkind_retires(w: u64) -> u8 @export {
    if ws_secondkind_proven(w) != 1u8 { return 0u8 }
    if ws_secondkind_fold_cost(w) < ws_secondkind_naive_cost(w) { return 1u8 }
    return 0u8
}

/* BROADER PRIMITIVE COVERAGE: the weave also holds families beyond SHA-2/rotation, typed honestly.
 *
 * Keccak's chi (one lane): out = a XOR ((NOT b) AND c) -- a REAL 3-input primitive.  It is NOT SHA-2's Ch
 * (a&b)^(~a&c): the weave types the strand FALSE, correctly SEPARATING related-but-distinct primitives (the
 * melt-plan's note that chi shares the bv substrate but is a different Boolean function).  Returns the status. */
fn ws_chi_vs_ch_status() -> u32 @export {
    bb_reset(32u64)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    let c : u32 = bb_var(2u32)
    let chi : u32 = bb_xor(a, bb_and(bb_not(b), c))                      /* Keccak chi lane */
    let ch  : u32 = bb_xor(bb_and(a, b), bb_and(bb_not(a), c))           /* SHA-2 Ch */
    if bb_equal(chi, ch) == 1u8 { return WG_ALL }
    return WG_FALSE                                                       /* distinct -- the weave separates them */
}
/* but chi IS a genuine member of the web: it is its own thing, and it is invertible-structured (a permutation in
 * Keccak).  1 iff chi is non-trivially distinct from the identity on its first input (it does real mixing). */
fn ws_chi_nontrivial() -> u8 @export {
    bb_reset(32u64)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    let c : u32 = bb_var(2u32)
    let chi : u32 = bb_xor(a, bb_and(bb_not(b), c))
    if bb_equal(chi, a) == 1u8 { return 0u8 }                            /* chi == a everywhere?  no -> it mixes */
    return 1u8
}

/* THE CROSS-PRIMITIVE ARX CORE: the shared atom of ChaCha's quarter-round and Blake2's G-function -- d' =
 * rotl(d ^ (a+b), 16) -- is a single proven bijection (numera/primweb's pw_arx_atom_invertible).  The weave
 * INDEXES that theorem: 1 iff the ARX core every ChaCha/Blake2 mix factors through is the proven reversible atom.
 * This is the deepest cross-primitive strand: two borrowed names, one proven core. */
fn ws_arx_core_proven() -> u8 @export { return pw_arx_atom_invertible() }

/* ============================================================================================================
 * THE UNIVERSAL REVERSIBLE PRIMITIVE, MELTED: the Toffoli / CCNOT gate (a,b,c) -> (a, b, c ^ (a&b)).  Its third
 * output is c ^ (a&b) -- a BIT-INDEPENDENT 3-input function, so the melt handles it WITHOUT SAT: its defining
 * properties are truth-table SIGNATURE facts.  This is the gate that makes III's logic isomorphic to reversible
 * computation (Landauer ~zero-heat), and the weave now holds it as a node typed by the melted judge, indexing
 * primweb's existing SAT proofs (anti-island). */
fn ws_toffoli(a: u32, b: u32, c: u32) -> u32 { return bb_xor(c, bb_and(a, b)) }      /* the third output */

/* REVERSIBILITY, by signature: applying the Toffoli third-output twice returns c -- a SELF-INVERSE permutation.
 * (c ^ (a&b)) ^ (a&b) == c.  Proven by SIGNATURE IDENTITY over 3 inputs (no SAT): the universal reversible gate's
 * reversibility is a truth-table fact, melted.  Returns 1 iff self-inverse. */
fn ws_toffoli_selfinverse() -> u8 @export {
    bb_reset(8u64)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    let c : u32 = bb_var(2u32)
    let once  : u32 = ws_toffoli(a, b, c)
    let twice : u32 = ws_toffoli(a, b, once)
    return bb_sig_equal(twice, c, 3u32)                 /* twice == c  ->  self-inverse */
}

/* UNIVERSALITY, by signature: with c = 1 (all ones), the Toffoli third output is 1 ^ (a&b) = NOT(a&b) = NAND,
 * which is functionally complete -- so reversible computation expresses ANY Boolean function.  Proven by signature
 * identity over the 2 free inputs (no SAT).  Returns 1 iff Toffoli(a,b,1) == NAND(a,b). */
fn ws_toffoli_is_nand() -> u8 @export {
    bb_reset(8u64)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    let ones : u32 = bb_const(0xFFu64)                  /* c = 1 on every signature row */
    let toff : u32 = ws_toffoli(a, b, ones)             /* 1 ^ (a&b) */
    let nand : u32 = bb_not(bb_and(a, b))
    return bb_sig_equal(toff, nand, 2u32)
}

/* the Toffoli is bit-independent (only AND/XOR) -> the melt's signature route applies (no bit-coupling). */
fn ws_toffoli_bit_independent() -> u8 @export {
    bb_reset(8u64)
    let a : u32 = bb_var(0u32)
    let b : u32 = bb_var(1u32)
    let c : u32 = bb_var(2u32)
    ws_toffoli(a, b, c)
    return ws_is_bit_independent()
}

/* INDEX primweb: confirm the weave's signature-melted Toffoli facts AGREE with primweb's SAT proofs
 * (pw_toffoli_self_inverse, pw_toffoli_is_nand) -- the melt and the judge reach the same truth, the melt for free. */
fn ws_toffoli_agrees_primweb() -> u8 @export {
    if ws_toffoli_selfinverse() != 1u8 { return 0u8 }
    if pw_toffoli_self_inverse() != 1u8 { return 0u8 }
    if ws_toffoli_is_nand() != 1u8 { return 0u8 }
    if pw_toffoli_is_nand() != 1u8 { return 0u8 }
    return 1u8
}

fn ws_put_u32le(base: u64, off: u64, v: u32) -> i32 {
    let p : *u8 = (base + off) as *u8
    p[0u64] = (v & 0xFFu32) as u8
    p[1u64] = ((v >> 8u32) & 0xFFu32) as u8
    p[2u64] = ((v >> 16u32) & 0xFFu32) as u8
    p[3u64] = ((v >> 24u32) & 0xFFu32) as u8
    return 0i32
}
