/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\x25519.iii
 *
 * III STDLIB - numera::x25519
 *
 * RFC 7748 X25519 ECDH (Curve25519 scalar multiplication).
 *
 * Public API:
 *   x25519(out:*u8, scalar:*u8, u:*u8) -> i32 @export
 *      out, scalar, u are each 32 bytes little-endian.  Returns 0 on success.
 *
 * W0.5 (x25519->fe25519): the Montgomery ladder now runs on numera/fe25519's
 * fixed 8-limb (radix 2^32) GF(2^255-19) field -- the SAME allocation-free,
 * ~1000x-faster field the Ed25519 group law uses -- instead of the per-call
 * 256 MB arena + arbitrary-precision bigint path.  Field elements are 8 u64
 * limbs in module-scope buffers; every ladder op is one fz_add/fz_sub/fz_mul.
 *
 * Algorithm (RFC 7748 section 5): clamp scalar; decode u (mask bit 255);
 * Montgomery ladder bits 254..0 with a CONSTANT-TIME branchless cswap; final
 * x_2 / z_2 = x_2 * z_2^(p-2); encode as 32 LE bytes.  Constant-time posture is
 * preserved: fixed 255 iterations, branchless masked cswap, fz_invert exponent
 * is the PUBLIC p-2 (no secret-dependent control flow).
 *
 * Hexad: kind_essence.  Ring: R0.  K: 1.00.
 */

module numera_x25519

extern @abi(c-msvc-x64) fn fe25519_init() -> i32 from "fe25519.iii"
extern @abi(c-msvc-x64) fn fz_mul(a: u64, b: u64, r: u64) -> i32 from "fe25519.iii"
extern @abi(c-msvc-x64) fn fz_add(a: u64, b: u64, r: u64) -> i32 from "fe25519.iii"
extern @abi(c-msvc-x64) fn fz_sub(a: u64, b: u64, r: u64) -> i32 from "fe25519.iii"
extern @abi(c-msvc-x64) fn fz_copy(src: u64, dst: u64) -> i32 from "fe25519.iii"
extern @abi(c-msvc-x64) fn fz_decode(src: u64, dst: u64) -> i32 from "fe25519.iii"
extern @abi(c-msvc-x64) fn fz_encode(src: u64, dst: u64) -> i32 from "fe25519.iii"
extern @abi(c-msvc-x64) fn fz_freeze(r: u64) -> i32 from "fe25519.iii"
extern @abi(c-msvc-x64) fn fz_invert(a: u64, r: u64) -> i32 from "fe25519.iii"

const X25519_OK : i32 = 0i32

/* Ladder state + scratch (each an 8-limb GF(2^255-19) element). */
var XF_X1 : [u64; 8]
var XF_X2 : [u64; 8]  var XF_Z2 : [u64; 8]
var XF_X3 : [u64; 8]  var XF_Z3 : [u64; 8]
var XF_A  : [u64; 8]  var XF_AA : [u64; 8]
var XF_B  : [u64; 8]  var XF_BB : [u64; 8]
var XF_E  : [u64; 8]
var XF_C  : [u64; 8]  var XF_D  : [u64; 8]
var XF_DA : [u64; 8]  var XF_CB : [u64; 8]
var XF_T1 : [u64; 8]  var XF_T2 : [u64; 8]
var XF_ONE  : [u64; 8]  var XF_ZERO : [u64; 8]  var XF_A24 : [u64; 8]
var XF_ZINV : [u64; 8]  var XF_RES  : [u64; 8]

/* Clamped 32-byte scalar (RFC 7748 section 5); wiped before return. */
var X_SCALAR : [u8; 32]

/* Set an 8-limb element to the small constant v0 (v0 < 2^32). */
fn xf_set_small(buf: u64, v0: u64) -> i32 {
    let p : *u64 = buf as *u64
    p[0u64] = v0
    let mut i : u64 = 1u64
    while i < 8u64 { p[i] = 0u64  i = i + 1u64 }
    return 0i32
}

/* Wipe an 8-limb element. */
fn xf_wipe(buf: u64) -> i32 {
    let p : *u64 = buf as *u64
    let mut i : u64 = 0u64
    while i < 8u64 { p[i] = 0u64  i = i + 1u64 }
    return 0i32
}

/* Test bit `idx` of the clamped scalar. */
fn x_scalar_bit(idx: u32) -> u32 {
    let byte_idx : u32 = idx >> 3u32
    let bit_in_byte : u32 = idx & 7u32
    let b : u32 = X_SCALAR[byte_idx] as u32
    return (b >> bit_in_byte) & 1u32
}

/* CONSTANT-TIME conditional swap: if cond==1 swap (XF_X2,XF_X3) and (XF_Z2,XF_Z3)
 * limb-by-limb; else no-op.  Branchless masked XOR-swap (mask = 0-cond). */
fn x_cswap(cond: u32) -> i32 {
    let mask : u64 = 0u64 - (cond as u64)
    let p2 : *u64 = (&XF_X2 as u64) as *u64
    let p3 : *u64 = (&XF_X3 as u64) as *u64
    let q2 : *u64 = (&XF_Z2 as u64) as *u64
    let q3 : *u64 = (&XF_Z3 as u64) as *u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        let tx : u64 = mask & (p2[k] ^ p3[k])
        p2[k] = p2[k] ^ tx
        p3[k] = p3[k] ^ tx
        let tz : u64 = mask & (q2[k] ^ q3[k])
        q2[k] = q2[k] ^ tz
        q3[k] = q3[k] ^ tz
        k = k + 1u64
    }
    return 0i32
}

/* One Montgomery ladder step (RFC 7748 section 5), all on 8-limb buffers.
 * Every fz_* output buffer is distinct from its inputs (no aliasing); the
 * in-place overwrites of x2,z2,x3,z3 all happen after their old values are
 * consumed (DA,CB computed before x3/z3 overwrite; A,B before x2/z2). */
fn x_ladder_step() -> i32 {
    let x1 : u64 = &XF_X1 as u64
    let x2 : u64 = &XF_X2 as u64  let z2 : u64 = &XF_Z2 as u64
    let x3 : u64 = &XF_X3 as u64  let z3 : u64 = &XF_Z3 as u64
    let aa : u64 = &XF_AA as u64  let bb : u64 = &XF_BB as u64
    let a : u64 = &XF_A as u64    let b : u64 = &XF_B as u64    let e : u64 = &XF_E as u64
    let c : u64 = &XF_C as u64    let d : u64 = &XF_D as u64
    let da : u64 = &XF_DA as u64  let cb : u64 = &XF_CB as u64
    let t1 : u64 = &XF_T1 as u64  let t2 : u64 = &XF_T2 as u64
    let a24 : u64 = &XF_A24 as u64
    fz_add(x2, z2, a)        /* A  = x2 + z2 */
    fz_mul(a, a, aa)         /* AA = A^2 */
    fz_sub(x2, z2, b)        /* B  = x2 - z2 */
    fz_mul(b, b, bb)         /* BB = B^2 */
    fz_sub(aa, bb, e)        /* E  = AA - BB */
    fz_add(x3, z3, c)        /* C  = x3 + z3 */
    fz_sub(x3, z3, d)        /* D  = x3 - z3 */
    fz_mul(d, a, da)         /* DA = D*A */
    fz_mul(c, b, cb)         /* CB = C*B */
    fz_add(da, cb, t1)       /* T1 = DA + CB */
    fz_mul(t1, t1, x3)       /* x3'= (DA+CB)^2 */
    fz_sub(da, cb, t2)       /* T2 = DA - CB */
    fz_mul(t2, t2, t1)       /* T1 = (DA-CB)^2 */
    fz_mul(x1, t1, z3)       /* z3'= x1 * (DA-CB)^2 */
    fz_mul(aa, bb, x2)       /* x2'= AA * BB */
    fz_mul(a24, e, t1)       /* T1 = a24 * E */
    fz_add(aa, t1, t2)       /* T2 = AA + a24*E */
    fz_mul(e, t2, z2)        /* z2'= E * (AA + a24*E) */
    return 0i32
}

fn x25519(out: *u8, scalar: *u8, u_in: *u8) -> i32 @crystal @side_channel_resistant @constant_time @export {
    fe25519_init()
    /* Constants. */
    xf_set_small(&XF_ONE as u64, 1u64)
    xf_set_small(&XF_ZERO as u64, 0u64)
    xf_set_small(&XF_A24 as u64, 121665u64)
    /* Clamp the scalar (RFC 7748 section 5). */
    let mut i : u32 = 0u32
    while i < 32u32 {
        X_SCALAR[i] = scalar[i]
        i = i + 1u32
    }
    X_SCALAR[0]  = (X_SCALAR[0] as u32 & 248u32) as u8
    X_SCALAR[31] = (X_SCALAR[31] as u32 & 127u32) as u8
    X_SCALAR[31] = (X_SCALAR[31] as u32 | 64u32) as u8
    /* Decode u into x_1, masking bit 255 (limb[7] high bit). */
    fz_decode(u_in as u64, &XF_X1 as u64)
    let x1p : *u64 = (&XF_X1 as u64) as *u64
    x1p[7u64] = x1p[7u64] & 0x7FFFFFFFu64
    /* Initialise ladder: x_2 = 1, z_2 = 0, x_3 = u, z_3 = 1. */
    fz_copy(&XF_ONE as u64, &XF_X2 as u64)
    fz_copy(&XF_ZERO as u64, &XF_Z2 as u64)
    fz_copy(&XF_X1 as u64, &XF_X3 as u64)
    fz_copy(&XF_ONE as u64, &XF_Z3 as u64)
    /* Ladder, bits 254..0. */
    let mut swap : u32 = 0u32
    let mut t : u32 = 255u32
    while t > 0u32 {
        t = t - 1u32
        let k_t : u32 = x_scalar_bit(t)
        swap = swap ^ k_t
        x_cswap(swap)
        swap = k_t
        x_ladder_step()
    }
    x_cswap(swap)
    /* result = x_2 * z_2^(p-2), canonicalize, encode. */
    fz_invert(&XF_Z2 as u64, &XF_ZINV as u64)
    fz_mul(&XF_X2 as u64, &XF_ZINV as u64, &XF_RES as u64)
    fz_freeze(&XF_RES as u64)
    fz_encode(&XF_RES as u64, out as u64)
    /* Side-channel hygiene: wipe the secret scalar + all ladder state. */
    let mut wz : u32 = 0u32
    while wz < 32u32 { X_SCALAR[wz] = 0u8  wz = wz + 1u32 }
    xf_wipe(&XF_X1 as u64)  xf_wipe(&XF_X2 as u64)  xf_wipe(&XF_Z2 as u64)
    xf_wipe(&XF_X3 as u64)  xf_wipe(&XF_Z3 as u64)  xf_wipe(&XF_ZINV as u64)
    xf_wipe(&XF_RES as u64)
    return X25519_OK
}
