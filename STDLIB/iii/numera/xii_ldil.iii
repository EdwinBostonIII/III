/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\numera\xii_ldil.iii
 *
 * III STDLIB - numera::xii_ldil
 *
 * Layered Deterministic Intermediate Language (LDIL). Pruned SSA over a
 * struct-of-arrays slab. Typed values (width + signedness + optional
 * refinement predicate slot), explicit phi nodes with predecessor blocks,
 * dual block-instr representation (indexed array + O(1) linked cursor).
 * Shared base of the self-hosted codegen pipeline (cg_pure #39, cg_superopt #40).
 *
 * Builder is single-IR / non-reentrant; ldil_init() is the reset boundary
 * between compilation units. Refinement IMPLICATION (SMT discharge) is out of
 * scope here -- it lives in cg_superopt #40; this module only records slots and
 * checks local anchoring (every refined value has a defining instr whose OUT is
 * that value). Deterministic, integer-only, no float in any output-bearing path.
 *
 * 29 opcodes; each operation total over its bit width, no implementation-defined
 * behavior. Slot ids are monotone-counter assigned, so identical builder call
 * sequences produce byte-identical arenas and identical ids across runs/CPUs.
 *
 * Hexad: kind_essence + kind_form.  Ring: R0.  K: 1.00.
 * Discipline: W2 (<=4 params), W8 (fixed arenas), W13 (<=20 locals),
 *             W14 (sentinel-flag loops, no break), W15 (no recursion).
 */

module numera_xii_ldil

extern @abi(c-msvc-x64) fn ident_from_bytes(input: *u8, in_len: u64, out: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_copy(src: *u8, dst: *u8) -> i32 from "identifier.iii"
extern @abi(c-msvc-x64) fn ident_eq(a: *u8, b: *u8) -> u8 from "identifier.iii"

const LDIL_OK    : i32 =  0i32
const LDIL_E_BAD : i32 = -1i32
const LDIL_E_FULL : i32 = -2i32
const LDIL_SENT  : u32 = 0xFFFFFFFFu32

const LDIL_OP_NOP     : u8 =  0u8
const LDIL_OP_CONST   : u8 =  1u8
const LDIL_OP_ADD     : u8 =  2u8
const LDIL_OP_SUB     : u8 =  3u8
const LDIL_OP_MUL     : u8 =  4u8
const LDIL_OP_DIV     : u8 =  5u8
const LDIL_OP_MOD     : u8 =  6u8
const LDIL_OP_UDIV    : u8 =  7u8
const LDIL_OP_UMOD    : u8 =  8u8
const LDIL_OP_NEG     : u8 =  9u8
const LDIL_OP_AND     : u8 = 10u8
const LDIL_OP_OR      : u8 = 11u8
const LDIL_OP_XOR     : u8 = 12u8
const LDIL_OP_NOT     : u8 = 13u8
const LDIL_OP_SHL     : u8 = 14u8
const LDIL_OP_SHR     : u8 = 15u8
const LDIL_OP_SAR     : u8 = 16u8
const LDIL_OP_EQ      : u8 = 17u8
const LDIL_OP_NE      : u8 = 18u8
const LDIL_OP_SLT     : u8 = 19u8
const LDIL_OP_SLE     : u8 = 20u8
const LDIL_OP_ULT     : u8 = 21u8
const LDIL_OP_ULE     : u8 = 22u8
const LDIL_OP_LOAD    : u8 = 23u8
const LDIL_OP_STORE   : u8 = 24u8
const LDIL_OP_PHI     : u8 = 25u8
const LDIL_OP_BR      : u8 = 26u8
const LDIL_OP_BR_COND : u8 = 27u8
const LDIL_OP_RET     : u8 = 28u8
const LDIL_OP_CALL    : u8 = 29u8

const LDIL_W_8  : u8 = 0u8
const LDIL_W_16 : u8 = 1u8
const LDIL_W_32 : u8 = 2u8
const LDIL_W_64 : u8 = 3u8

const LDIL_MAX_VALS       : u32 = 65536u32
const LDIL_MAX_INSTRS      : u32 = 65536u32
const LDIL_MAX_BLOCKS      : u32 = 4096u32
const LDIL_MAX_FUNCS       : u32 = 1024u32
const LDIL_MAX_INPUTS      : u32 = 8u32
const LDIL_MAX_PHI_ENTRIES : u32 = 8u32
const LDIL_MAX_PRED        : u32 = 8u32
const LDIL_MAX_PARAMS      : u32 = 16u32
const LDIL_MAX_FN_BLOCKS   : u32 = 256u32
const LDIL_MAX_BLK_INSTRS  : u32 = 256u32
const LDIL_NAME_BYTES      : u32 = 32u32

/* Functions */
var LDIL_F_LIVE     : [u8;  1024]
var LDIL_F_NAME     : [u8;  32768]
var LDIL_F_N_PARAMS : [u32; 1024]
var LDIL_F_PARAMS   : [u32; 16384]
var LDIL_F_ENTRY    : [u32; 1024]
var LDIL_F_RET_WIDTH : [u8;  1024]
var LDIL_F_N_BLOCKS : [u32; 1024]
var LDIL_F_BLOCKS   : [u32; 262144]
var LDIL_F_USED     : u32 = 0u32

/* Blocks */
var LDIL_B_LIVE     : [u8;  4096]
var LDIL_B_N_INSTRS : [u32; 4096]
var LDIL_B_INSTRS   : [u32; 1048576]
var LDIL_B_TERM     : [u32; 4096]
var LDIL_B_N_PRED   : [u32; 4096]
var LDIL_B_PRED     : [u32; 32768]
var LDIL_B_PARENT   : [u32; 4096]
var LDIL_B_FIRST    : [u32; 4096]
var LDIL_B_LAST     : [u32; 4096]
var LDIL_B_USED     : u32 = 0u32

/* Instructions */
var LDIL_I_LIVE    : [u8;  65536]
var LDIL_I_OP      : [u8;  65536]
var LDIL_I_OUT     : [u32; 65536]
var LDIL_I_N_IN    : [u32; 65536]
var LDIL_I_IN      : [u32; 524288]
var LDIL_I_PHI_BLK : [u32; 524288]
var LDIL_I_IMM     : [i64; 65536]
var LDIL_I_BLOCK   : [u32; 65536]
var LDIL_I_NEXT    : [u32; 65536]
var LDIL_I_USED    : u32 = 0u32

/* Values */
var LDIL_V_LIVE    : [u8;  65536]
var LDIL_V_WIDTH   : [u8;  65536]
var LDIL_V_SIGNED  : [u8;  65536]
var LDIL_V_REFINE  : [u32; 65536]
var LDIL_V_DEFINSTR : [u32; 65536]
var LDIL_V_USED    : u32 = 0u32

/* Typecheck per-call shared context (flat-helper state; no recursion, W15).
 * The structural checker decomposes its per-block/per-instr/per-input passes
 * into private helpers that read these instead of deep nesting (Trap 13). */
var LDIL_TC_FUNC : u32 = 0u32
var LDIL_TC_OK   : u8  = 1u8

/* ============================ internal helpers ============================ */

/* Byte address of function `slot`'s 32-byte name field. u32->u64 masked
 * before the *32 multiply (Trap 4). */
fn ldil_f_name_ptr(slot: u32) -> *u8 {
    let off : u64 = ((slot as u64) & 0xFFFFFFFFu64) * 32u64
    let base : u64 = (&LDIL_F_NAME) as u64
    return (base + off) as *u8
}

/* Counter-bump instruction allocator. Returns slot id or LDIL_SENT when full. */
fn ldil_alloc_instr() -> u32 {
    if LDIL_I_USED >= LDIL_MAX_INSTRS { return LDIL_SENT }
    let i : u32 = LDIL_I_USED
    LDIL_I_LIVE[i]  = 1u8
    LDIL_I_OP[i]    = LDIL_OP_NOP
    LDIL_I_OUT[i]   = LDIL_SENT
    LDIL_I_N_IN[i]  = 0u32
    LDIL_I_IMM[i]   = 0i64
    LDIL_I_BLOCK[i] = LDIL_SENT
    LDIL_I_NEXT[i]  = LDIL_SENT
    LDIL_I_USED     = i + 1u32
    return i
}

/* True iff block id is in range and live. */
fn ldil_block_ok(block: u32) -> u8 {
    if block >= LDIL_B_USED { return 0u8 }
    if LDIL_B_LIVE[block] == 0u8 { return 0u8 }
    return 1u8
}

/* True iff value id is in range and live. */
fn ldil_value_ok(value: u32) -> u8 {
    if value >= LDIL_V_USED { return 0u8 }
    if LDIL_V_LIVE[value] == 0u8 { return 0u8 }
    return 1u8
}

/* True iff func id is in range and live. */
fn ldil_func_ok(func: u32) -> u8 {
    if func >= LDIL_F_USED { return 0u8 }
    if LDIL_F_LIVE[func] == 0u8 { return 0u8 }
    return 1u8
}

/* True iff instr id is in range and live. */
fn ldil_instr_ok(insn: u32) -> u8 {
    if insn >= LDIL_I_USED { return 0u8 }
    if LDIL_I_LIVE[insn] == 0u8 { return 0u8 }
    return 1u8
}

/* Append `instr` to `block`: indexed array slot AND the O(1) linked cursor.
 * Maintains FIRST/LAST/NEXT and stamps I_BLOCK. Both representations are kept
 * in sync so cg_pure (indexed walk) and cg_superopt (cursor walk) agree. */
fn ldil_block_append(block: u32, instr: u32) -> i32 {
    if ldil_block_ok(block) == 0u8 { return LDIL_E_BAD }
    if ldil_instr_ok(instr) == 0u8 { return LDIL_E_BAD }
    let n : u32 = LDIL_B_N_INSTRS[block]
    if n >= LDIL_MAX_BLK_INSTRS { return LDIL_E_FULL }
    let idx : u64 = (((block as u64) & 0xFFFFFFFFu64) * 256u64) + ((n as u64) & 0xFFFFFFFFu64)
    LDIL_B_INSTRS[idx] = instr
    LDIL_B_N_INSTRS[block] = n + 1u32
    if LDIL_B_FIRST[block] == LDIL_SENT {
        LDIL_B_FIRST[block] = instr
    } else {
        let last : u32 = LDIL_B_LAST[block]
        LDIL_I_NEXT[last] = instr
    }
    LDIL_B_LAST[block] = instr
    LDIL_I_BLOCK[instr] = block
    return LDIL_OK
}

/* ================================ lifecycle =============================== */

fn ldil_init() -> i32 @export {
    let mut i : u32 = 0u32
    while i < LDIL_MAX_VALS {
        LDIL_V_LIVE[i] = 0u8
        i = i + 1u32
    }
    let mut j : u32 = 0u32
    while j < LDIL_MAX_INSTRS {
        LDIL_I_LIVE[j] = 0u8
        j = j + 1u32
    }
    let mut b : u32 = 0u32
    while b < LDIL_MAX_BLOCKS {
        LDIL_B_LIVE[b] = 0u8
        b = b + 1u32
    }
    let mut f : u32 = 0u32
    while f < LDIL_MAX_FUNCS {
        LDIL_F_LIVE[f] = 0u8
        f = f + 1u32
    }
    LDIL_V_USED = 0u32
    LDIL_I_USED = 0u32
    LDIL_B_USED = 0u32
    LDIL_F_USED = 0u32
    return LDIL_OK
}

/* ================================ functions =============================== */

fn ldil_new_function(name_id: *u8, ret_width: u8) -> u32 @export {
    if LDIL_F_USED >= LDIL_MAX_FUNCS { return LDIL_SENT }
    let f : u32 = LDIL_F_USED
    let dst : *u8 = ldil_f_name_ptr(f)
    ident_copy(name_id, dst)
    LDIL_F_LIVE[f]      = 1u8
    LDIL_F_N_PARAMS[f]  = 0u32
    LDIL_F_ENTRY[f]     = LDIL_SENT
    LDIL_F_RET_WIDTH[f] = ret_width
    LDIL_F_N_BLOCKS[f]  = 0u32
    LDIL_F_USED         = f + 1u32
    return f
}

fn ldil_fn_add_param(func: u32, width: u8, signed: u8) -> u32 @export {
    if ldil_func_ok(func) == 0u8 { return LDIL_SENT }
    let n : u32 = LDIL_F_N_PARAMS[func]
    if n >= LDIL_MAX_PARAMS { return LDIL_SENT }
    let v : u32 = ldil_new_value(width, signed)
    if v == LDIL_SENT { return LDIL_SENT }
    let idx : u64 = (((func as u64) & 0xFFFFFFFFu64) * 16u64) + ((n as u64) & 0xFFFFFFFFu64)
    LDIL_F_PARAMS[idx] = v
    LDIL_F_N_PARAMS[func] = n + 1u32
    return v
}

fn ldil_fn_set_entry(func: u32, block: u32) -> i32 @export {
    if ldil_func_ok(func) == 0u8 { return LDIL_E_BAD }
    if ldil_block_ok(block) == 0u8 { return LDIL_E_BAD }
    LDIL_F_ENTRY[func] = block
    return LDIL_OK
}

fn ldil_fn_add_block(func: u32, block: u32) -> i32 @export {
    if ldil_func_ok(func) == 0u8 { return LDIL_E_BAD }
    if ldil_block_ok(block) == 0u8 { return LDIL_E_BAD }
    let n : u32 = LDIL_F_N_BLOCKS[func]
    if n >= LDIL_MAX_FN_BLOCKS { return LDIL_E_FULL }
    let idx : u64 = (((func as u64) & 0xFFFFFFFFu64) * 256u64) + ((n as u64) & 0xFFFFFFFFu64)
    LDIL_F_BLOCKS[idx] = block
    LDIL_F_N_BLOCKS[func] = n + 1u32
    return LDIL_OK
}

fn ldil_fn_n_params(func: u32) -> u32 @export {
    if ldil_func_ok(func) == 0u8 { return 0u32 }
    return LDIL_F_N_PARAMS[func]
}

fn ldil_fn_param_at(func: u32, idx: u32) -> u32 @export {
    if ldil_func_ok(func) == 0u8 { return LDIL_SENT }
    if idx >= LDIL_F_N_PARAMS[func] { return LDIL_SENT }
    let off : u64 = (((func as u64) & 0xFFFFFFFFu64) * 16u64) + ((idx as u64) & 0xFFFFFFFFu64)
    return LDIL_F_PARAMS[off]
}

fn ldil_fn_n_blocks(func: u32) -> u32 @export {
    if ldil_func_ok(func) == 0u8 { return 0u32 }
    return LDIL_F_N_BLOCKS[func]
}

fn ldil_fn_block_at(func: u32, idx: u32) -> u32 @export {
    if ldil_func_ok(func) == 0u8 { return LDIL_SENT }
    if idx >= LDIL_F_N_BLOCKS[func] { return LDIL_SENT }
    let off : u64 = (((func as u64) & 0xFFFFFFFFu64) * 256u64) + ((idx as u64) & 0xFFFFFFFFu64)
    return LDIL_F_BLOCKS[off]
}

fn ldil_fn_entry(func: u32) -> u32 @export {
    if ldil_func_ok(func) == 0u8 { return LDIL_SENT }
    return LDIL_F_ENTRY[func]
}

fn ldil_fn_ret_width(func: u32) -> u8 @export {
    if ldil_func_ok(func) == 0u8 { return 0u8 }
    return LDIL_F_RET_WIDTH[func]
}

fn ldil_fn_name_eq(func: u32, name_id: *u8) -> u8 @export {
    if ldil_func_ok(func) == 0u8 { return 0u8 }
    let p : *u8 = ldil_f_name_ptr(func)
    return ident_eq(p, name_id)
}

/* ================================= values ================================= */

fn ldil_new_value(width: u8, signed: u8) -> u32 @export {
    if LDIL_V_USED >= LDIL_MAX_VALS { return LDIL_SENT }
    let v : u32 = LDIL_V_USED
    LDIL_V_LIVE[v]     = 1u8
    LDIL_V_WIDTH[v]    = width
    LDIL_V_SIGNED[v]   = signed
    LDIL_V_REFINE[v]   = LDIL_SENT
    LDIL_V_DEFINSTR[v] = LDIL_SENT
    LDIL_V_USED        = v + 1u32
    return v
}

fn ldil_set_refinement(value: u32, pred_slot: u32) -> i32 @export {
    if ldil_value_ok(value) == 0u8 { return LDIL_E_BAD }
    LDIL_V_REFINE[value] = pred_slot
    return LDIL_OK
}

fn ldil_v_width(value: u32) -> u8 @export {
    if ldil_value_ok(value) == 0u8 { return 0u8 }
    return LDIL_V_WIDTH[value]
}

fn ldil_v_signed(value: u32) -> u8 @export {
    if ldil_value_ok(value) == 0u8 { return 0u8 }
    return LDIL_V_SIGNED[value]
}

fn ldil_v_refinement(value: u32) -> u32 @export {
    if ldil_value_ok(value) == 0u8 { return LDIL_SENT }
    return LDIL_V_REFINE[value]
}

fn ldil_v_definstr(value: u32) -> u32 @export {
    if ldil_value_ok(value) == 0u8 { return LDIL_SENT }
    return LDIL_V_DEFINSTR[value]
}

/* ================================= blocks ================================= */

fn ldil_new_block(parent_func: u32) -> u32 @export {
    if LDIL_B_USED >= LDIL_MAX_BLOCKS { return LDIL_SENT }
    let b : u32 = LDIL_B_USED
    LDIL_B_LIVE[b]     = 1u8
    LDIL_B_N_INSTRS[b] = 0u32
    LDIL_B_TERM[b]     = LDIL_SENT
    LDIL_B_N_PRED[b]   = 0u32
    LDIL_B_PARENT[b]   = parent_func
    LDIL_B_FIRST[b]    = LDIL_SENT
    LDIL_B_LAST[b]     = LDIL_SENT
    LDIL_B_USED        = b + 1u32
    return b
}

fn ldil_block_add_pred(block: u32, pred: u32) -> i32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_E_BAD }
    let n : u32 = LDIL_B_N_PRED[block]
    if n >= LDIL_MAX_PRED { return LDIL_E_FULL }
    let idx : u64 = (((block as u64) & 0xFFFFFFFFu64) * 8u64) + ((n as u64) & 0xFFFFFFFFu64)
    LDIL_B_PRED[idx] = pred
    LDIL_B_N_PRED[block] = n + 1u32
    return LDIL_OK
}

fn ldil_block_n_pred(block: u32) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return 0u32 }
    return LDIL_B_N_PRED[block]
}

fn ldil_block_pred_at(block: u32, idx: u32) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_SENT }
    if idx >= LDIL_B_N_PRED[block] { return LDIL_SENT }
    let off : u64 = (((block as u64) & 0xFFFFFFFFu64) * 8u64) + ((idx as u64) & 0xFFFFFFFFu64)
    return LDIL_B_PRED[off]
}

fn ldil_block_parent(block: u32) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_SENT }
    return LDIL_B_PARENT[block]
}

fn ldil_block_count(func: u32) -> u32 @export {
    let mut i : u32 = 0u32
    let mut n : u32 = 0u32
    while i < LDIL_B_USED {
        if LDIL_B_LIVE[i] == 1u8 {
            if LDIL_B_PARENT[i] == func { n = n + 1u32 }
        }
        i = i + 1u32
    }
    return n
}

fn ldil_block_n_instrs(block: u32) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return 0u32 }
    return LDIL_B_N_INSTRS[block]
}

fn ldil_block_instr_at(block: u32, idx: u32) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_SENT }
    if idx >= LDIL_B_N_INSTRS[block] { return LDIL_SENT }
    let off : u64 = (((block as u64) & 0xFFFFFFFFu64) * 256u64) + ((idx as u64) & 0xFFFFFFFFu64)
    return LDIL_B_INSTRS[off]
}

fn ldil_block_term(block: u32) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_SENT }
    return LDIL_B_TERM[block]
}

fn ldil_first_insn(block: u32) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_SENT }
    return LDIL_B_FIRST[block]
}

fn ldil_next_insn(insn: u32) -> u32 @export {
    if ldil_instr_ok(insn) == 0u8 { return LDIL_SENT }
    return LDIL_I_NEXT[insn]
}

/* =========================== instruction emitters ========================= */

fn ldil_emit_const(block: u32, width: u8, signed: u8, imm: u64) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_SENT }
    let out : u32 = ldil_new_value(width, signed)
    if out == LDIL_SENT { return LDIL_SENT }
    let i : u32 = ldil_alloc_instr()
    if i == LDIL_SENT { return LDIL_SENT }
    LDIL_I_OP[i]   = LDIL_OP_CONST
    LDIL_I_OUT[i]  = out
    LDIL_I_N_IN[i] = 0u32
    LDIL_I_IMM[i]  = imm as i64
    LDIL_V_DEFINSTR[out] = i
    ldil_block_append(block, i)
    return out
}

/* Binop result width via equality cascade (no ordering compare, Trap 3). */
fn ldil_binop_width(a: u32, b: u32) -> u8 {
    let wa : u8 = LDIL_V_WIDTH[a]
    let wb : u8 = LDIL_V_WIDTH[b]
    if wa == LDIL_W_64 { return LDIL_W_64 }
    if wb == LDIL_W_64 { return LDIL_W_64 }
    if wa == LDIL_W_32 { return LDIL_W_32 }
    if wb == LDIL_W_32 { return LDIL_W_32 }
    if wa == LDIL_W_16 { return LDIL_W_16 }
    if wb == LDIL_W_16 { return LDIL_W_16 }
    return LDIL_W_8
}

/* True iff op is one of the six comparison opcodes (result is W_8/unsigned). */
fn ldil_op_is_cmp(op: u8) -> u8 {
    if op == LDIL_OP_EQ  { return 1u8 }
    if op == LDIL_OP_NE  { return 1u8 }
    if op == LDIL_OP_SLT { return 1u8 }
    if op == LDIL_OP_SLE { return 1u8 }
    if op == LDIL_OP_ULT { return 1u8 }
    if op == LDIL_OP_ULE { return 1u8 }
    return 0u8
}

fn ldil_emit_binop(block: u32, op: u8, a: u32, b: u32) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_SENT }
    if ldil_value_ok(a) == 0u8 { return LDIL_SENT }
    if ldil_value_ok(b) == 0u8 { return LDIL_SENT }
    let mut w : u8 = ldil_binop_width(a, b)
    let mut sgn : u8 = LDIL_V_SIGNED[a]
    if ldil_op_is_cmp(op) == 1u8 {
        w = LDIL_W_8
        sgn = 0u8
    }
    let out : u32 = ldil_new_value(w, sgn)
    if out == LDIL_SENT { return LDIL_SENT }
    let i : u32 = ldil_alloc_instr()
    if i == LDIL_SENT { return LDIL_SENT }
    LDIL_I_OP[i]   = op
    LDIL_I_OUT[i]  = out
    LDIL_I_N_IN[i] = 2u32
    let base : u64 = ((i as u64) & 0xFFFFFFFFu64) * 8u64
    LDIL_I_IN[base + 0u64] = a
    LDIL_I_IN[base + 1u64] = b
    LDIL_V_DEFINSTR[out] = i
    ldil_block_append(block, i)
    return out
}

fn ldil_emit_unop(block: u32, op: u8, a: u32) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_SENT }
    if ldil_value_ok(a) == 0u8 { return LDIL_SENT }
    let w : u8 = LDIL_V_WIDTH[a]
    let sgn : u8 = LDIL_V_SIGNED[a]
    let out : u32 = ldil_new_value(w, sgn)
    if out == LDIL_SENT { return LDIL_SENT }
    let i : u32 = ldil_alloc_instr()
    if i == LDIL_SENT { return LDIL_SENT }
    LDIL_I_OP[i]   = op
    LDIL_I_OUT[i]  = out
    LDIL_I_N_IN[i] = 1u32
    let base : u64 = ((i as u64) & 0xFFFFFFFFu64) * 8u64
    LDIL_I_IN[base + 0u64] = a
    LDIL_V_DEFINSTR[out] = i
    ldil_block_append(block, i)
    return out
}

fn ldil_emit_load(block: u32, addr: u32, width: u8, signed: u8) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_SENT }
    if ldil_value_ok(addr) == 0u8 { return LDIL_SENT }
    let out : u32 = ldil_new_value(width, signed)
    if out == LDIL_SENT { return LDIL_SENT }
    let i : u32 = ldil_alloc_instr()
    if i == LDIL_SENT { return LDIL_SENT }
    LDIL_I_OP[i]   = LDIL_OP_LOAD
    LDIL_I_OUT[i]  = out
    LDIL_I_N_IN[i] = 1u32
    let base : u64 = ((i as u64) & 0xFFFFFFFFu64) * 8u64
    LDIL_I_IN[base + 0u64] = addr
    LDIL_V_DEFINSTR[out] = i
    ldil_block_append(block, i)
    return out
}

fn ldil_emit_store(block: u32, addr: u32, value: u32) -> i32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_E_BAD }
    if ldil_value_ok(addr) == 0u8 { return LDIL_E_BAD }
    if ldil_value_ok(value) == 0u8 { return LDIL_E_BAD }
    let i : u32 = ldil_alloc_instr()
    if i == LDIL_SENT { return LDIL_E_FULL }
    LDIL_I_OP[i]   = LDIL_OP_STORE
    LDIL_I_OUT[i]  = LDIL_SENT
    LDIL_I_N_IN[i] = 2u32
    let base : u64 = ((i as u64) & 0xFFFFFFFFu64) * 8u64
    LDIL_I_IN[base + 0u64] = addr
    LDIL_I_IN[base + 1u64] = value
    return ldil_block_append(block, i)
}

fn ldil_emit_phi(block: u32, width: u8, signed: u8) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_SENT }
    let out : u32 = ldil_new_value(width, signed)
    if out == LDIL_SENT { return LDIL_SENT }
    let i : u32 = ldil_alloc_instr()
    if i == LDIL_SENT { return LDIL_SENT }
    LDIL_I_OP[i]   = LDIL_OP_PHI
    LDIL_I_OUT[i]  = out
    LDIL_I_N_IN[i] = 0u32
    LDIL_V_DEFINSTR[out] = i
    ldil_block_append(block, i)
    return out
}

fn ldil_phi_add(phi_value: u32, pred_block: u32, value: u32) -> i32 @export {
    if ldil_value_ok(phi_value) == 0u8 { return LDIL_E_BAD }
    let i : u32 = LDIL_V_DEFINSTR[phi_value]
    if i == LDIL_SENT { return LDIL_E_BAD }
    if ldil_instr_ok(i) == 0u8 { return LDIL_E_BAD }
    let n : u32 = LDIL_I_N_IN[i]
    if n >= LDIL_MAX_PHI_ENTRIES { return LDIL_E_FULL }
    let off : u64 = (((i as u64) & 0xFFFFFFFFu64) * 8u64) + ((n as u64) & 0xFFFFFFFFu64)
    LDIL_I_IN[off] = value
    LDIL_I_PHI_BLK[off] = pred_block
    LDIL_I_N_IN[i] = n + 1u32
    return LDIL_OK
}

fn ldil_emit_br(block: u32, target: u32) -> i32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_E_BAD }
    let i : u32 = ldil_alloc_instr()
    if i == LDIL_SENT { return LDIL_E_FULL }
    LDIL_I_OP[i]   = LDIL_OP_BR
    LDIL_I_OUT[i]  = LDIL_SENT
    LDIL_I_N_IN[i] = 0u32
    LDIL_I_IMM[i]  = (target as u64) as i64
    LDIL_B_TERM[block] = i
    return ldil_block_append(block, i)
}

fn ldil_emit_br_cond(block: u32, cond: u32, t_block: u32, f_block: u32) -> i32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_E_BAD }
    if ldil_value_ok(cond) == 0u8 { return LDIL_E_BAD }
    let i : u32 = ldil_alloc_instr()
    if i == LDIL_SENT { return LDIL_E_FULL }
    let packed : u64 = (((f_block as u64) & 0xFFFFFFFFu64) << 32u64) | ((t_block as u64) & 0xFFFFFFFFu64)
    LDIL_I_OP[i]   = LDIL_OP_BR_COND
    LDIL_I_OUT[i]  = LDIL_SENT
    LDIL_I_N_IN[i] = 1u32
    let base : u64 = ((i as u64) & 0xFFFFFFFFu64) * 8u64
    LDIL_I_IN[base + 0u64] = cond
    LDIL_I_IMM[i]  = packed as i64
    LDIL_B_TERM[block] = i
    return ldil_block_append(block, i)
}

fn ldil_emit_ret(block: u32, value_or_sent: u32) -> i32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_E_BAD }
    let i : u32 = ldil_alloc_instr()
    if i == LDIL_SENT { return LDIL_E_FULL }
    LDIL_I_OP[i]   = LDIL_OP_RET
    LDIL_I_OUT[i]  = LDIL_SENT
    LDIL_I_N_IN[i] = 0u32
    if value_or_sent != LDIL_SENT {
        LDIL_I_N_IN[i] = 1u32
        let base : u64 = ((i as u64) & 0xFFFFFFFFu64) * 8u64
        LDIL_I_IN[base + 0u64] = value_or_sent
    }
    LDIL_B_TERM[block] = i
    return ldil_block_append(block, i)
}

fn ldil_emit_call(block: u32, callee: u32, args: *u32, n_args: u32) -> u32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_SENT }
    if n_args > LDIL_MAX_INPUTS { return LDIL_SENT }
    let out : u32 = ldil_new_value(LDIL_W_64, 0u8)
    if out == LDIL_SENT { return LDIL_SENT }
    let i : u32 = ldil_alloc_instr()
    if i == LDIL_SENT { return LDIL_SENT }
    LDIL_I_OP[i]   = LDIL_OP_CALL
    LDIL_I_OUT[i]  = out
    LDIL_I_IMM[i]  = (callee as u64) as i64
    let base : u64 = ((i as u64) & 0xFFFFFFFFu64) * 8u64
    let mut k : u32 = 0u32
    while k < n_args {
        let v : u32 = args[(k as u64) & 0xFFFFFFFFu64]
        LDIL_I_IN[base + ((k as u64) & 0xFFFFFFFFu64)] = v
        k = k + 1u32
    }
    LDIL_I_N_IN[i] = n_args
    LDIL_V_DEFINSTR[out] = i
    ldil_block_append(block, i)
    return out
}

/* ============================ instruction queries ========================= */

fn ldil_insn_opc(insn: u32) -> u8 @export {
    if ldil_instr_ok(insn) == 0u8 { return LDIL_OP_NOP }
    return LDIL_I_OP[insn]
}

fn ldil_insn_out(insn: u32) -> u32 @export {
    if ldil_instr_ok(insn) == 0u8 { return LDIL_SENT }
    return LDIL_I_OUT[insn]
}

fn ldil_insn_dst(insn: u32) -> u32 @export {
    if ldil_instr_ok(insn) == 0u8 { return LDIL_SENT }
    return LDIL_I_OUT[insn]
}

fn ldil_insn_n_in(insn: u32) -> u32 @export {
    if ldil_instr_ok(insn) == 0u8 { return 0u32 }
    return LDIL_I_N_IN[insn]
}

fn ldil_insn_in(insn: u32, idx: u32) -> u32 @export {
    if ldil_instr_ok(insn) == 0u8 { return LDIL_SENT }
    if idx >= LDIL_I_N_IN[insn] { return LDIL_SENT }
    let off : u64 = (((insn as u64) & 0xFFFFFFFFu64) * 8u64) + ((idx as u64) & 0xFFFFFFFFu64)
    return LDIL_I_IN[off]
}

fn ldil_insn_src(insn: u32, idx: u32) -> u32 @export {
    if ldil_instr_ok(insn) == 0u8 { return LDIL_SENT }
    if idx >= LDIL_I_N_IN[insn] { return LDIL_SENT }
    let off : u64 = (((insn as u64) & 0xFFFFFFFFu64) * 8u64) + ((idx as u64) & 0xFFFFFFFFu64)
    return LDIL_I_IN[off]
}

fn ldil_insn_imm(insn: u32) -> i64 @export {
    if ldil_instr_ok(insn) == 0u8 { return 0i64 }
    return LDIL_I_IMM[insn]
}

fn ldil_insn_phi_pred(insn: u32, idx: u32) -> u32 @export {
    if ldil_instr_ok(insn) == 0u8 { return LDIL_SENT }
    if idx >= LDIL_I_N_IN[insn] { return LDIL_SENT }
    let off : u64 = (((insn as u64) & 0xFFFFFFFFu64) * 8u64) + ((idx as u64) & 0xFFFFFFFFu64)
    return LDIL_I_PHI_BLK[off]
}

fn ldil_insn_block(insn: u32) -> u32 @export {
    if ldil_instr_ok(insn) == 0u8 { return LDIL_SENT }
    return LDIL_I_BLOCK[insn]
}

/* ===================== refinement alias (shorter-draft compat) ============ */

/* In pruned SSA a value's refinement is block-invariant (single definition
 * site), so the `block` arg is validated then ignored; kept for source-compat
 * with the shorter consumer's (vreg, block, pred_slot) triple. */
fn ldil_attach_refinement(value: u32, block: u32, pred_slot: u32) -> i32 @export {
    if ldil_block_ok(block) == 0u8 { return LDIL_E_BAD }
    return ldil_set_refinement(value, pred_slot)
}

/* ================================= checkers =============================== */

/* Per-input liveness check for one instruction. Clears LDIL_TC_OK on the first
 * dead/out-of-range input. Flat (depth 2) -- decomposed out of typecheck to
 * keep the parser block-nesting shallow (Trap 13). */
fn ldil_tc_check_inputs(insn: u32) -> i32 {
    let n : u32 = LDIL_I_N_IN[insn]
    let base : u64 = ((insn as u64) & 0xFFFFFFFFu64) * 8u64
    let mut k : u32 = 0u32
    while k < n {
        let v : u32 = LDIL_I_IN[base + ((k as u64) & 0xFFFFFFFFu64)]
        if ldil_value_ok(v) == 0u8 { LDIL_TC_OK = 0u8 }
        k = k + 1u32
    }
    return LDIL_OK
}

/* Operand-width / signedness compatibility for arithmetic and bitwise binops.
 * Both operands must share the instruction's recorded result width family;
 * signed-specific ops (DIV/MOD/SLT/SLE/SAR) require both operands signed.
 * Comparisons are exempt (they yield W_8). All compares are u8/u32 == (Trap 3).
 */
fn ldil_tc_binop_types(insn: u32) -> i32 {
    let op : u8 = LDIL_I_OP[insn]
    if ldil_op_is_cmp(op) == 1u8 { return LDIL_OK }
    let base : u64 = ((insn as u64) & 0xFFFFFFFFu64) * 8u64
    let a : u32 = LDIL_I_IN[base + 0u64]
    let b : u32 = LDIL_I_IN[base + 1u64]
    let wa : u8 = LDIL_V_WIDTH[a]
    let wb : u8 = LDIL_V_WIDTH[b]
    let out : u32 = LDIL_I_OUT[insn]
    let wo : u8 = LDIL_V_WIDTH[out]
    if wa != wb { LDIL_TC_OK = 0u8 }
    if wa != wo { LDIL_TC_OK = 0u8 }
    if op == LDIL_OP_DIV { ldil_tc_require_signed(a, b) }
    if op == LDIL_OP_MOD { ldil_tc_require_signed(a, b) }
    if op == LDIL_OP_SAR { ldil_tc_require_signed(a, b) }
    return LDIL_OK
}

/* Both operands must be signed; clears LDIL_TC_OK otherwise. */
fn ldil_tc_require_signed(a: u32, b: u32) -> i32 {
    if LDIL_V_SIGNED[a] == 0u8 { LDIL_TC_OK = 0u8 }
    if LDIL_V_SIGNED[b] == 0u8 { LDIL_TC_OK = 0u8 }
    return LDIL_OK
}

/* PHI arity check: phi n_in must equal the owning block's predecessor count. */
fn ldil_tc_check_phi(insn: u32, block: u32) -> i32 {
    let n_in : u32 = LDIL_I_N_IN[insn]
    let n_pred : u32 = LDIL_B_N_PRED[block]
    if n_in != n_pred { LDIL_TC_OK = 0u8 }
    return LDIL_OK
}

/* Walk one block: every input live; binops well-typed; PHIs precede non-PHIs
 * (the seen_non_phi sentinel) and have n_in == n_pred; block terminates.
 * Depth-3 loop body; helpers keep it shallow (Trap 13). Reads/writes
 * LDIL_TC_OK; no break (W14). */
fn ldil_tc_walk_block(block: u32) -> i32 {
    if ldil_block_ok(block) == 0u8 { LDIL_TC_OK = 0u8 }
    if LDIL_B_TERM[block] == LDIL_SENT { LDIL_TC_OK = 0u8 }
    let n : u32 = LDIL_B_N_INSTRS[block]
    let bbase : u64 = ((block as u64) & 0xFFFFFFFFu64) * 256u64
    let mut k : u32 = 0u32
    let mut seen_non_phi : u8 = 0u8
    while k < n {
        let insn : u32 = LDIL_B_INSTRS[bbase + ((k as u64) & 0xFFFFFFFFu64)]
        let op : u8 = LDIL_I_OP[insn]
        ldil_tc_check_inputs(insn)
        if op == LDIL_OP_PHI {
            if seen_non_phi == 1u8 { LDIL_TC_OK = 0u8 }
            ldil_tc_check_phi(insn, block)
        } else {
            seen_non_phi = 1u8
        }
        if LDIL_I_N_IN[insn] == 2u32 { ldil_tc_binop_types(insn) }
        k = k + 1u32
    }
    return LDIL_OK
}

/* Structural type check (W10, returns 0/1). Verifies: entry exists and its
 * parent is `func`; every block terminates; all instruction inputs live;
 * operand width compatibility + no mixed signedness on signed-specific ops;
 * each PHI's n_in == owning block n_pred; PHIs precede non-PHIs. Sentinel-flag
 * (LDIL_TC_OK), no break (W14), no recursion (W15), all == / != (Trap 3). */
fn ldil_typecheck_function(func: u32) -> u8 @export {
    if ldil_func_ok(func) == 0u8 { return 0u8 }
    LDIL_TC_FUNC = func
    LDIL_TC_OK = 1u8
    let entry : u32 = LDIL_F_ENTRY[func]
    if entry == LDIL_SENT { return 0u8 }
    if ldil_block_ok(entry) == 0u8 { return 0u8 }
    if LDIL_B_PARENT[entry] != func { return 0u8 }
    let nb : u32 = LDIL_F_N_BLOCKS[func]
    let fbase : u64 = ((func as u64) & 0xFFFFFFFFu64) * 256u64
    let mut bi : u32 = 0u32
    while bi < nb {
        let block : u32 = LDIL_F_BLOCKS[fbase + ((bi as u64) & 0xFFFFFFFFu64)]
        ldil_tc_walk_block(block)
        bi = bi + 1u32
    }
    return LDIL_TC_OK
}

/* Local refinement anchor check (M13-bounded; SMT implication deferred to #40).
 * Every live value that carries a refinement slot must be anchored: it must
 * have a live defining instruction whose OUT is that value, and that defining
 * instruction must belong to a block parented by `func`. A refined value with
 * no defining instruction (an orphan) fails. Pure structural; scans the value
 * arena (not the block-instr lists) so orphans -- which appear in no block --
 * are still caught. The arena is reset per compilation unit by ldil_init. */

/* True iff instr `di` is live and sits in a block whose parent func is `func`. */
fn ldil_refine_instr_in_func(di: u32, func: u32) -> u8 {
    if ldil_instr_ok(di) == 0u8 { return 0u8 }
    let blk : u32 = LDIL_I_BLOCK[di]
    if ldil_block_ok(blk) == 0u8 { return 0u8 }
    if LDIL_B_PARENT[blk] != func { return 0u8 }
    return 1u8
}

/* For a live value `value` carrying a refinement: its DEFINSTR must be a live
 * instr in `func` whose OUT is `value`. Clears LDIL_TC_OK on any violation.
 * Values with no refinement (or dead/out-of-range) are vacuously fine. */
fn ldil_refine_check_value(value: u32, func: u32) -> i32 {
    if ldil_value_ok(value) == 0u8 { return LDIL_OK }
    if LDIL_V_REFINE[value] == LDIL_SENT { return LDIL_OK }
    let di : u32 = LDIL_V_DEFINSTR[value]
    if di == LDIL_SENT { LDIL_TC_OK = 0u8 }
    if di != LDIL_SENT {
        if ldil_refine_instr_in_func(di, func) == 0u8 { LDIL_TC_OK = 0u8 }
        if LDIL_I_OUT[di] != value { LDIL_TC_OK = 0u8 }
    }
    return LDIL_OK
}

fn ldil_refine_check_function(func: u32) -> u8 @export {
    if ldil_func_ok(func) == 0u8 { return 0u8 }
    LDIL_TC_OK = 1u8
    let nv : u32 = LDIL_V_USED
    let mut vi : u32 = 0u32
    while vi < nv {
        ldil_refine_check_value(vi, func)
        vi = vi + 1u32
    }
    return LDIL_TC_OK
}

/* ================================= selftest =============================== */

/* KAT scratch (module-scope; the builder is non-reentrant by contract). */
var LDIL_T_NAME_F : [u8; 32]
var LDIL_T_NAME_G : [u8; 32]
var LDIL_T_CALLARGS : [u32; 4]

/* Build the canonical 32-byte identifier for the one-byte name `c` into `dst`. */
fn ldil_t_make_name(c: u8, dst: *u8) -> i32 {
    let scratch : *u8 = dst
    scratch[0u64] = c
    ident_from_bytes(scratch, 1u64, dst)
    return LDIL_OK
}

/* KAT-1: identity function f(x)->x. Returns 0 on pass, else a distinct code. */
fn ldil_selftest_k1() -> u64 {
    ldil_init()
    let np : *u8 = (&LDIL_T_NAME_F) as *u8
    ldil_t_make_name(70u8, np)
    let f : u32 = ldil_new_function(np, LDIL_W_64)
    if f != 0u32 { return 1u64 }
    let p : u32 = ldil_fn_add_param(f, LDIL_W_64, 1u8)
    if p != 0u32 { return 2u64 }
    let b : u32 = ldil_new_block(f)
    if b != 0u32 { return 3u64 }
    ldil_fn_add_block(f, b)
    ldil_fn_set_entry(f, b)
    ldil_emit_ret(b, p)
    if ldil_fn_n_params(0u32) != 1u32 { return 4u64 }
    if ldil_fn_param_at(0u32, 0u32) != 0u32 { return 5u64 }
    if ldil_fn_entry(0u32) != 0u32 { return 6u64 }
    if ldil_block_term(0u32) != 0u32 { return 7u64 }
    if ldil_insn_opc(0u32) != LDIL_OP_RET { return 8u64 }
    if ldil_insn_n_in(0u32) != 1u32 { return 9u64 }
    if ldil_insn_in(0u32, 0u32) != 0u32 { return 10u64 }
    if ldil_v_width(0u32) != LDIL_W_64 { return 11u64 }
    if ldil_v_signed(0u32) != 1u8 { return 12u64 }
    if ldil_typecheck_function(0u32) != 1u8 { return 13u64 }
    if ldil_block_count(0u32) != 1u32 { return 14u64 }
    if ldil_fn_ret_width(0u32) != LDIL_W_64 { return 15u64 }
    if ldil_fn_name_eq(0u32, np) != 1u8 { return 16u64 }
    return 0u64
}

/* KAT-2: r = (5 + 3); ret r. Checks const/binop wiring + the cursor + that the
 * terminator was appended to the instr list (the gospel bug fix). */
fn ldil_selftest_k2() -> u64 {
    ldil_init()
    let ng : *u8 = (&LDIL_T_NAME_G) as *u8
    ldil_t_make_name(71u8, ng)
    let f : u32 = ldil_new_function(ng, LDIL_W_64)
    if f != 0u32 { return 20u64 }
    let b : u32 = ldil_new_block(f)
    ldil_fn_add_block(f, b)
    ldil_fn_set_entry(f, b)
    let c5 : u32 = ldil_emit_const(b, LDIL_W_64, 1u8, 5u64)
    if c5 != 0u32 { return 21u64 }
    let c3 : u32 = ldil_emit_const(b, LDIL_W_64, 1u8, 3u64)
    if c3 != 1u32 { return 22u64 }
    let s : u32 = ldil_emit_binop(b, LDIL_OP_ADD, c5, c3)
    if s != 2u32 { return 23u64 }
    ldil_emit_ret(b, s)
    if ldil_insn_opc(0u32) != LDIL_OP_CONST { return 24u64 }
    if ldil_insn_imm(0u32) != 5i64 { return 25u64 }
    if ldil_insn_imm(1u32) != 3i64 { return 26u64 }
    if ldil_insn_opc(2u32) != LDIL_OP_ADD { return 27u64 }
    if ldil_insn_in(2u32, 0u32) != 0u32 { return 28u64 }
    if ldil_insn_in(2u32, 1u32) != 1u32 { return 29u64 }
    if ldil_insn_out(2u32) != 2u32 { return 30u64 }
    if ldil_insn_dst(2u32) != 2u32 { return 31u64 }
    if ldil_v_definstr(2u32) != 2u32 { return 32u64 }
    if ldil_block_n_instrs(0u32) != 4u32 { return 33u64 }
    if ldil_first_insn(0u32) != 0u32 { return 34u64 }
    if ldil_next_insn(0u32) != 1u32 { return 35u64 }
    if ldil_next_insn(2u32) != 3u32 { return 36u64 }
    if ldil_next_insn(3u32) != LDIL_SENT { return 37u64 }
    if ldil_insn_block(3u32) != 0u32 { return 38u64 }
    if ldil_insn_src(2u32, 1u32) != 1u32 { return 39u64 }
    if ldil_typecheck_function(0u32) != 1u8 { return 40u64 }
    return 0u64
}

/* KAT-3: diamond CFG with a phi. Positive case typechecks; negative sub-case
 * (one phi entry missing -> n_in != n_pred) MUST fail (proves the guard fires).
 */
fn ldil_selftest_k3() -> u64 {
    ldil_init()
    let ng : *u8 = (&LDIL_T_NAME_G) as *u8
    ldil_t_make_name(72u8, ng)
    let f : u32 = ldil_new_function(ng, LDIL_W_64)
    let b0 : u32 = ldil_new_block(f)
    let b1 : u32 = ldil_new_block(f)
    let b2 : u32 = ldil_new_block(f)
    let b3 : u32 = ldil_new_block(f)
    ldil_fn_add_block(f, b0)
    ldil_fn_add_block(f, b1)
    ldil_fn_add_block(f, b2)
    ldil_fn_add_block(f, b3)
    ldil_fn_set_entry(f, b0)
    let cond : u32 = ldil_emit_const(b0, LDIL_W_8, 0u8, 1u64)
    ldil_emit_br_cond(b0, cond, b1, b2)
    let va : u32 = ldil_emit_const(b1, LDIL_W_64, 1u8, 10u64)
    ldil_emit_br(b1, b3)
    let vb : u32 = ldil_emit_const(b2, LDIL_W_64, 1u8, 20u64)
    ldil_emit_br(b2, b3)
    ldil_block_add_pred(b3, b1)
    ldil_block_add_pred(b3, b2)
    let phi : u32 = ldil_emit_phi(b3, LDIL_W_64, 1u8)
    /* Emit the b3 terminator NOW so the ONLY structural violation in the
     * negative sub-case is the phi arity -- this isolates the n_in==n_pred
     * guard (a missing terminator would otherwise also fail typecheck, making
     * the negative result a tautology). */
    ldil_emit_ret(b3, phi)
    ldil_phi_add(phi, b1, va)
    if ldil_block_n_pred(3u32) != 2u32 { return 50u64 }
    if ldil_block_pred_at(3u32, 0u32) != 1u32 { return 51u64 }
    if ldil_block_pred_at(3u32, 1u32) != 2u32 { return 52u64 }
    let phi_instr : u32 = ldil_v_definstr(phi)
    if ldil_insn_opc(phi_instr) != LDIL_OP_PHI { return 53u64 }
    /* Negative sub-case: b3 IS terminated, but only ONE phi entry was added
     * (n_in=1 != n_pred=2) -> typecheck MUST fail solely on phi arity. */
    if ldil_typecheck_function(f) != 0u8 { return 54u64 }
    /* Now complete the phi -> positive case must typecheck. */
    ldil_phi_add(phi, b2, vb)
    if ldil_insn_n_in(phi_instr) != 2u32 { return 55u64 }
    if ldil_insn_phi_pred(phi_instr, 0u32) != 1u32 { return 56u64 }
    if ldil_insn_phi_pred(phi_instr, 1u32) != 2u32 { return 57u64 }
    if ldil_insn_in(phi_instr, 0u32) != va { return 58u64 }
    if ldil_insn_in(phi_instr, 1u32) != vb { return 59u64 }
    if ldil_typecheck_function(f) != 1u8 { return 60u64 }
    return 0u64
}

/* KAT-4: refinement round-trip + negative orphan case. */
fn ldil_selftest_k4() -> u64 {
    ldil_init()
    let ng : *u8 = (&LDIL_T_NAME_G) as *u8
    ldil_t_make_name(73u8, ng)
    let f : u32 = ldil_new_function(ng, LDIL_W_64)
    let b : u32 = ldil_new_block(f)
    ldil_fn_add_block(f, b)
    ldil_fn_set_entry(f, b)
    let v : u32 = ldil_new_value(LDIL_W_32, 0u8)
    if ldil_v_refinement(v) != LDIL_SENT { return 70u64 }
    ldil_set_refinement(v, 7u32)
    if ldil_v_refinement(v) != 7u32 { return 71u64 }
    /* Orphan: v has a refine slot but no defining instr -> refine check fails. */
    if ldil_refine_check_function(f) != 0u8 { return 72u64 }
    /* Anchor v to a real defining const instr in b, then it must pass. */
    let c : u32 = ldil_emit_const(b, LDIL_W_64, 1u8, 99u64)
    ldil_set_refinement(c, 3u32)
    ldil_emit_ret(b, c)
    /* Drop v's refinement so only the well-anchored c remains refined. */
    LDIL_V_REFINE[v] = LDIL_SENT
    if ldil_refine_check_function(f) != 1u8 { return 73u64 }
    /* attach_refinement alias must also anchor cleanly. */
    if ldil_attach_refinement(c, b, 5u32) != LDIL_OK { return 74u64 }
    if ldil_v_refinement(c) != 5u32 { return 75u64 }
    if ldil_refine_check_function(f) != 1u8 { return 76u64 }
    return 0u64
}

/* Negative-emitter checks: a binop over a dead/out-of-range value must refuse
 * with LDIL_SENT (proves the input guard rejects bad input, not just accepts
 * good input -- M-discipline: prove the negative case). */
fn ldil_selftest_k5() -> u64 {
    ldil_init()
    let ng : *u8 = (&LDIL_T_NAME_G) as *u8
    ldil_t_make_name(74u8, ng)
    let f : u32 = ldil_new_function(ng, LDIL_W_64)
    let b : u32 = ldil_new_block(f)
    ldil_fn_add_block(f, b)
    ldil_fn_set_entry(f, b)
    let c0 : u32 = ldil_emit_const(b, LDIL_W_64, 1u8, 1u64)
    /* value 5000 was never allocated -> binop must refuse. */
    if ldil_emit_binop(b, LDIL_OP_ADD, c0, 5000u32) != LDIL_SENT { return 80u64 }
    /* call with > 8 args must refuse exactly (no marshaling fiction). */
    let ap : *u32 = (&LDIL_T_CALLARGS) as *u32
    if ldil_emit_call(b, 0u32, ap, 9u32) != LDIL_SENT { return 81u64 }
    /* a 2-arg call with valid args succeeds and records n_in=2. */
    LDIL_T_CALLARGS[0u64] = c0
    LDIL_T_CALLARGS[1u64] = c0
    let cl : u32 = ldil_emit_call(b, 0u32, ap, 2u32)
    if cl == LDIL_SENT { return 82u64 }
    let ci : u32 = ldil_v_definstr(cl)
    if ldil_insn_n_in(ci) != 2u32 { return 83u64 }
    if ldil_insn_opc(ci) != LDIL_OP_CALL { return 84u64 }
    /* unop inherits width/signedness of its operand. */
    let u : u32 = ldil_emit_unop(b, LDIL_OP_NEG, c0)
    if ldil_v_width(u) != LDIL_W_64 { return 85u64 }
    /* store returns a status, not a value reg. */
    if ldil_emit_store(b, c0, c0) != LDIL_OK { return 86u64 }
    /* comparison binop forces W_8 / unsigned result. */
    let cm : u32 = ldil_emit_binop(b, LDIL_OP_ULT, c0, c0)
    if ldil_v_width(cm) != LDIL_W_8 { return 87u64 }
    if ldil_v_signed(cm) != 0u8 { return 88u64 }
    return 0u64
}

fn ldil_selftest() -> u64 @export {
    let r1 : u64 = ldil_selftest_k1()
    if r1 != 0u64 { return r1 }
    let r2 : u64 = ldil_selftest_k2()
    if r2 != 0u64 { return r2 }
    let r3 : u64 = ldil_selftest_k3()
    if r3 != 0u64 { return r3 }
    let r4 : u64 = ldil_selftest_k4()
    if r4 != 0u64 { return r4 }
    let r5 : u64 = ldil_selftest_k5()
    if r5 != 0u64 { return r5 }
    return 99u64
}
