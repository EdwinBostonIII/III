/* numera/zk_snark.iii — NIH Groth16 over BLS12-381 (gospel §4.12 / forward-ref #4).
 *
 * Ports ZK-PRUNING/src/snark.c from the toy field to the real BLS12-381 curve:
 * R1CS -> QAP via Lagrange over D = {1..m}, trusted setup, prove, pairing-verify
 *
 *   e(A,B) = e(alpha*G1, beta*G2) . e(IC_acc, gamma*G2) . e(C, delta*G2).
 *
 * Field/curve/pairing primitives come from zk_field.iii (the proven BLS12-381
 * substrate).  Fr polynomials live in zk_field's ZKFR slot pool (Montgomery
 * Fr) driven through the exported frq_* ops; this module is pure Groth16
 * orchestration with no field state of its own.
 *
 * ZKFR slot map (this module): poly work 10..179, divmod remainder 180..199,
 * Lagrange buffer 200..219, scalar scratch 240..251.  (zk_field reserves
 * 0..9 self-test, 252..255 frq scratch.)
 *
 * Layer 1 (this file, validated first): the Fr polynomial / QAP engine.
 */
module numera_zk_snark

extern @abi(c-msvc-x64) fn frq_boot() -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn frq_set_u32(slot: u64, v: u32) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn frq_get_limb(slot: u64, idx: u64) -> u32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn frq_to_mont_x(r: u64, a: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn frq_add_x(r: u64, a: u64, b: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn frq_sub_x(r: u64, a: u64, b: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn frq_mul_x(r: u64, a: u64, b: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn frq_inv_x(r: u64, a: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn frq_copy_x(dst: u64, src: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkf_boot() -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkg1_gen_x(g: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkg1_add_x(rg: u64, ag: u64, bg: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkg1_copy_x(rg: u64, ag: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkg1_setinf_x(g: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkg1_mul_fr(rg: u64, ag: u64, fr_slot: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkg2_gen_x(g: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkg2_add_x(rg: u64, ag: u64, bg: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkg2_copy_x(rg: u64, ag: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkg2_mul_fr(rg: u64, ag: u64, fr_slot: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkf_pairing_x(g1slot: u64, g2slot: u64, outB: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkf12_mul_x(rB: u64, aB: u64, bB: u64) -> i32 from "zk_field.iii"
extern @abi(c-msvc-x64) fn zkf12_eq_x(aB: u64, bB: u64) -> u64 from "zk_field.iii"

/* mont(v) into slot dst (v small). */
fn sn_set_mont(dst: u64, v: u32) -> i32 {
    frq_set_u32(251u64, v)
    frq_to_mont_x(dst, 251u64)
    return 0i32
}
/* Fr slot equality (compare 8 limbs). */
fn sn_fr_eq(a: u64, b: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < 8u64 { if frq_get_limb(a, i) != frq_get_limb(b, i) { return 0u64 } i = i + 1u64 }
    return 1u64
}
/* out_slot = P(x_slot), P = coeffs[baseB .. baseB+ncoef-1] (Horner). */
fn sn_poly_eval(baseB: u64, ncoef: u64, x_slot: u64, out_slot: u64) -> i32 {
    frq_copy_x(out_slot, baseB + ncoef - 1u64)
    let mut i : u64 = ncoef - 1u64
    while i > 0u64 {
        i = i - 1u64
        frq_mul_x(out_slot, out_slot, x_slot)
        frq_add_x(out_slot, out_slot, baseB + i)
    }
    return 0i32
}
/* t(X) = prod_{k=1..m} (X - k), coeffs into outB[0..m] (m+1 coeffs). */
fn sn_target_poly(m: u64, outB: u64) -> i32 {
    sn_set_mont(outB, 1u32)
    let mut i : u64 = 1u64
    while i <= m { frq_set_u32(outB + i, 0u32) ; i = i + 1u64 }
    let mut deg : u64 = 0u64
    let mut k : u64 = 1u64
    while k <= m {
        sn_set_mont(241u64, k as u32)                    /* mont(k) */
        let mut ii : u64 = deg + 1u64
        while ii > 0u64 {
            frq_mul_x(242u64, outB + ii, 241u64)         /* t[ii]*k */
            frq_sub_x(outB + ii, outB + ii - 1u64, 242u64)
            ii = ii - 1u64
        }
        frq_mul_x(242u64, outB, 241u64)
        frq_set_u32(243u64, 0u32)
        frq_sub_x(outB, 243u64, 242u64)                  /* t[0] = -t[0]*k */
        deg = deg + 1u64
        k = k + 1u64
    }
    return 0i32
}
/* outB[0..la+lb-2] = A * B  (schoolbook). */
fn sn_poly_mul(aB: u64, la: u64, bB: u64, lb: u64, outB: u64) -> i32 {
    let lo : u64 = la + lb - 1u64
    let mut i : u64 = 0u64
    while i < lo { frq_set_u32(outB + i, 0u32) ; i = i + 1u64 }
    i = 0u64
    while i < la {
        let mut j : u64 = 0u64
        while j < lb {
            frq_mul_x(240u64, aB + i, bB + j)
            frq_add_x(outB + i + j, outB + i + j, 240u64)
            j = j + 1u64
        }
        i = i + 1u64
    }
    return 0i32
}
/* qB[0..lq-1] = numB[0..ln-1] / denB[0..ld-1] (remainder discarded). rem @180. */
fn sn_poly_divmod(numB: u64, ln: u64, denB: u64, ld: u64, qB: u64, lq: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < ln { frq_copy_x(180u64 + i, numB + i) ; i = i + 1u64 }
    frq_inv_x(244u64, denB + ld - 1u64)                  /* lead_inv */
    i = 0u64
    while i < lq { frq_set_u32(qB + i, 0u32) ; i = i + 1u64 }
    let nsteps : u64 = ln - (ld - 1u64)
    let mut step : u64 = 0u64
    while step < nsteps {
        let idx : u64 = ln - 1u64 - step                 /* ln-1 downto ld-1 */
        frq_mul_x(245u64, 180u64 + idx, 244u64)          /* coef = rem[idx]*lead_inv */
        let qi : u64 = idx - (ld - 1u64)
        if qi < lq { frq_copy_x(qB + qi, 245u64) }
        let mut j : u64 = 0u64
        while j < ld {
            frq_mul_x(246u64, 245u64, denB + j)
            frq_sub_x(180u64 + qi + j, 180u64 + qi + j, 246u64)
            j = j + 1u64
        }
        step = step + 1u64
    }
    return 0i32
}
/* barycentric weights w[k] = 1 / prod_{j!=k} ((k+1)-(j+1)), into outB[0..m-1]. */
fn sn_bary_weights(m: u64, outB: u64) -> i32 {
    let mut k : u64 = 0u64
    while k < m {
        sn_set_mont(247u64, 1u32)                        /* prod = 1 */
        let mut j : u64 = 0u64
        while j < m {
            if j != k {
                sn_set_mont(248u64, (k + 1u64) as u32)
                sn_set_mont(249u64, (j + 1u64) as u32)
                frq_sub_x(250u64, 248u64, 249u64)
                frq_mul_x(247u64, 247u64, 250u64)
            }
            j = j + 1u64
        }
        frq_inv_x(outB + k, 247u64)
        k = k + 1u64
    }
    return 0i32
}
/* coefficient-form interpolant of vals[0..m-1] on D={1..m} into outB[0..m-1].
 * buffer poly @200. */
fn sn_lagrange_coeffs(valsB: u64, bwB: u64, m: u64, outB: u64) -> i32 {
    let mut i : u64 = 0u64
    while i < m { frq_set_u32(outB + i, 0u32) ; i = i + 1u64 }
    let mut k : u64 = 0u64
    while k < m {
        sn_set_mont(200u64, 1u32)                        /* buf[0]=1 */
        i = 1u64
        while i < m { frq_set_u32(200u64 + i, 0u32) ; i = i + 1u64 }
        let mut deg : u64 = 0u64
        let mut j : u64 = 0u64
        while j < m {
            if j != k {
                sn_set_mont(241u64, (j + 1u64) as u32)   /* tau_j */
                let mut ii : u64 = deg + 1u64
                while ii > 0u64 {
                    frq_mul_x(242u64, 200u64 + ii, 241u64)
                    frq_sub_x(200u64 + ii, 200u64 + ii - 1u64, 242u64)
                    ii = ii - 1u64
                }
                frq_mul_x(242u64, 200u64, 241u64)
                frq_set_u32(243u64, 0u32)
                frq_sub_x(200u64, 243u64, 242u64)
                deg = deg + 1u64
            }
            j = j + 1u64
        }
        frq_mul_x(244u64, valsB + k, bwB + k)            /* scale = vals[k]*bw[k] */
        i = 0u64
        while i < m {
            frq_mul_x(245u64, 244u64, 200u64 + i)
            frq_add_x(outB + i, outB + i, 245u64)
            i = i + 1u64
        }
        k = k + 1u64
    }
    return 0i32
}

/* Fr polynomial / QAP engine self-test.  99 = pass. */
fn zk_snark_poly_selftest() -> u64 @export {
    frq_boot()
    /* a = 1 + 2X + 3X^2 (slots 10..12), b = 4 + 5X (slots 13..14) */
    sn_set_mont(10u64, 1u32) sn_set_mont(11u64, 2u32) sn_set_mont(12u64, 3u32)
    sn_set_mont(13u64, 4u32) sn_set_mont(14u64, 5u32)
    /* (1) eval a at x=2 == 1+4+12 = 17 */
    sn_set_mont(15u64, 2u32)
    sn_poly_eval(10u64, 3u64, 15u64, 16u64)
    sn_set_mont(17u64, 17u32)
    if sn_fr_eq(16u64, 17u64) == 0u64 { return 1u64 }
    /* (2) c = a*b (degree 3, slots 20..23); divmod c/b == a */
    sn_poly_mul(10u64, 3u64, 13u64, 2u64, 20u64)
    sn_poly_divmod(20u64, 4u64, 13u64, 2u64, 30u64, 3u64)     /* q @30..32 */
    if sn_fr_eq(30u64, 10u64) == 0u64 { return 2u64 }
    if sn_fr_eq(31u64, 11u64) == 0u64 { return 3u64 }
    if sn_fr_eq(32u64, 12u64) == 0u64 { return 4u64 }
    /* (3) target_poly m=2: t(X)=(X-1)(X-2)=2-3X+X^2 -> [mont2, -mont3, mont1] */
    sn_target_poly(2u64, 40u64)
    sn_set_mont(43u64, 2u32)
    if sn_fr_eq(40u64, 43u64) == 0u64 { return 5u64 }         /* t[0]=2 */
    sn_set_mont(44u64, 1u32)
    if sn_fr_eq(42u64, 44u64) == 0u64 { return 6u64 }         /* t[2]=1 */
    /* (4) Lagrange: vals=[10,20] on D={1,2} -> interpolant; eval at 1,2 recovers */
    sn_bary_weights(2u64, 50u64)
    sn_set_mont(52u64, 10u32) sn_set_mont(53u64, 20u32)
    sn_lagrange_coeffs(52u64, 50u64, 2u64, 60u64)            /* coeffs @60..61 */
    sn_set_mont(62u64, 1u32)
    sn_poly_eval(60u64, 2u64, 62u64, 63u64)
    if sn_fr_eq(63u64, 52u64) == 0u64 { return 7u64 }        /* P(1)==10 */
    sn_set_mont(64u64, 2u32)
    sn_poly_eval(60u64, 2u64, 64u64, 65u64)
    if sn_fr_eq(65u64, 53u64) == 0u64 { return 8u64 }        /* P(2)==20 */
    return 99u64
}

/* ================= Groth16 setup / prove / verify =================
 * Fr slots (256+): alpha 256 beta 257 gamma 258 delta 259 x 260 invD 261
 *   invG 262 tx 263 r 264 s 265 ; z 266..273 ; A_mat 274 B_mat 306 C_mat 338
 *   (m*n dense) ; u_x 370 v_x 378 w_x 386 ; valU 394 valV 398 valW 402 ;
 *   Uc 406 Vc 410 Wc 414 ; bw 418 ; vals 422 ; coeffs 426 ; UV 430 ; tcoef 437 ;
 *   hcoef 442 ; snum 445 pw 446 tmp 447 zero 448 ; public 450.
 * G1 slots: A_g1 0 B_g1 8 IC 16 L 21 H 28 alpha_g1 31 beta_g1 32 delta_g1 33
 *   gen 40 A 41 Bp 42 C 43 acc 44 work 45.
 * G2 slots: B_g2 0 beta_g2 8 gamma_g2 9 delta_g2 10 work 11 gen 15 B 16.
 * GT Fp12 slots: lhs 990 r1 996 r2 1002 r3 1008 rhs 1014. */
fn sn_setup(m: u64, n: u64, l: u64) -> i32 {
    frq_boot() zkf_boot()
    sn_bary_weights(m, 418u64)
    let mut i : u64 = 0u64
    while i < n {
        let mut k : u64 = 0u64
        while k < m { frq_copy_x(422u64 + k, 274u64 + k*n + i) ; k = k + 1u64 }
        sn_lagrange_coeffs(422u64, 418u64, m, 426u64)
        sn_poly_eval(426u64, m, 260u64, 370u64 + i)               /* u_x[i] */
        k = 0u64
        while k < m { frq_copy_x(422u64 + k, 306u64 + k*n + i) ; k = k + 1u64 }
        sn_lagrange_coeffs(422u64, 418u64, m, 426u64)
        sn_poly_eval(426u64, m, 260u64, 378u64 + i)               /* v_x[i] */
        k = 0u64
        while k < m { frq_copy_x(422u64 + k, 338u64 + k*n + i) ; k = k + 1u64 }
        sn_lagrange_coeffs(422u64, 418u64, m, 426u64)
        sn_poly_eval(426u64, m, 260u64, 386u64 + i)               /* w_x[i] */
        i = i + 1u64
    }
    sn_target_poly(m, 437u64)
    sn_poly_eval(437u64, m + 1u64, 260u64, 263u64)               /* tx */
    frq_inv_x(261u64, 259u64)                                    /* invD */
    frq_inv_x(262u64, 258u64)                                    /* invG */
    zkg1_gen_x(40u64)
    zkg2_gen_x(15u64)
    i = 0u64
    while i < n {
        zkg1_mul_fr(0u64 + i, 40u64, 370u64 + i)                 /* A_g1[i] = u_x[i]*G */
        zkg2_mul_fr(0u64 + i, 15u64, 378u64 + i)                 /* B_g2[i] = v_x[i]*H */
        zkg1_mul_fr(8u64 + i, 40u64, 378u64 + i)                 /* B_g1[i] = v_x[i]*G */
        i = i + 1u64
    }
    i = 0u64
    while i <= l {
        frq_mul_x(445u64, 257u64, 370u64 + i)                    /* beta*u_i */
        frq_mul_x(447u64, 256u64, 378u64 + i)                    /* alpha*v_i */
        frq_add_x(445u64, 445u64, 447u64)
        frq_add_x(445u64, 445u64, 386u64 + i)                    /* + w_i */
        frq_mul_x(445u64, 445u64, 262u64)                        /* * invG */
        zkg1_mul_fr(16u64 + i, 40u64, 445u64)                    /* IC[i] */
        i = i + 1u64
    }
    i = l + 1u64
    while i < n {
        frq_mul_x(445u64, 257u64, 370u64 + i)
        frq_mul_x(447u64, 256u64, 378u64 + i)
        frq_add_x(445u64, 445u64, 447u64)
        frq_add_x(445u64, 445u64, 386u64 + i)
        frq_mul_x(445u64, 445u64, 261u64)                        /* * invD */
        zkg1_mul_fr(21u64 + (i - l - 1u64), 40u64, 445u64)       /* L[i-l-1] */
        i = i + 1u64
    }
    sn_set_mont(446u64, 1u32)                                    /* pw = 1 */
    let mut k2 : u64 = 0u64
    while k2 + 1u64 < m {
        frq_mul_x(445u64, 446u64, 263u64)                        /* pw * tx */
        frq_mul_x(445u64, 445u64, 261u64)                        /* * invD */
        zkg1_mul_fr(28u64 + k2, 40u64, 445u64)                   /* H_g1[k] */
        frq_mul_x(446u64, 446u64, 260u64)                        /* pw *= x */
        k2 = k2 + 1u64
    }
    zkg1_mul_fr(31u64, 40u64, 256u64)                            /* alpha_g1 */
    zkg1_mul_fr(32u64, 40u64, 257u64)                            /* beta_g1 */
    zkg2_mul_fr(8u64, 15u64, 257u64)                             /* beta_g2 */
    zkg2_mul_fr(9u64, 15u64, 258u64)                             /* gamma_g2 */
    zkg1_mul_fr(33u64, 40u64, 259u64)                            /* delta_g1 */
    zkg2_mul_fr(10u64, 15u64, 259u64)                            /* delta_g2 */
    return 0i32
}
fn sn_prove(m: u64, n: u64, l: u64) -> i32 {
    let mut k : u64 = 0u64
    while k < m {
        frq_set_u32(394u64 + k, 0u32)
        frq_set_u32(398u64 + k, 0u32)
        frq_set_u32(402u64 + k, 0u32)
        let mut i : u64 = 0u64
        while i < n {
            frq_mul_x(447u64, 274u64 + k*n + i, 266u64 + i) frq_add_x(394u64 + k, 394u64 + k, 447u64)
            frq_mul_x(447u64, 306u64 + k*n + i, 266u64 + i) frq_add_x(398u64 + k, 398u64 + k, 447u64)
            frq_mul_x(447u64, 338u64 + k*n + i, 266u64 + i) frq_add_x(402u64 + k, 402u64 + k, 447u64)
            i = i + 1u64
        }
        k = k + 1u64
    }
    sn_bary_weights(m, 418u64)
    sn_lagrange_coeffs(394u64, 418u64, m, 406u64)                /* Uc */
    sn_lagrange_coeffs(398u64, 418u64, m, 410u64)                /* Vc */
    sn_lagrange_coeffs(402u64, 418u64, m, 414u64)                /* Wc */
    sn_poly_mul(406u64, m, 410u64, m, 430u64)                    /* UV */
    k = 0u64
    while k < m { frq_sub_x(430u64 + k, 430u64 + k, 414u64 + k) ; k = k + 1u64 }   /* UV -= W */
    sn_target_poly(m, 437u64)
    sn_poly_divmod(430u64, 2u64*m - 1u64, 437u64, m + 1u64, 442u64, m - 1u64)      /* h = (UV-W)/t */
    /* A = alpha_g1 + sum z_i A_g1[i] + r*delta_g1 */
    zkg1_copy_x(41u64, 31u64)
    let mut i2 : u64 = 0u64
    while i2 < n { zkg1_mul_fr(45u64, 0u64 + i2, 266u64 + i2) zkg1_add_x(41u64, 41u64, 45u64) i2 = i2 + 1u64 }
    zkg1_mul_fr(45u64, 33u64, 264u64) zkg1_add_x(41u64, 41u64, 45u64)
    /* B = beta_g2 + sum z_i B_g2[i] + s*delta_g2 */
    zkg2_copy_x(16u64, 8u64)
    i2 = 0u64
    while i2 < n { zkg2_mul_fr(11u64, 0u64 + i2, 266u64 + i2) zkg2_add_x(16u64, 16u64, 11u64) i2 = i2 + 1u64 }
    zkg2_mul_fr(11u64, 10u64, 265u64) zkg2_add_x(16u64, 16u64, 11u64)
    /* Bp = beta_g1 + sum z_i B_g1[i] + s*delta_g1  (B_g1[i]=v_i*G; the G1 mirror of
     * B must use v_i, not u_i -- fixes the toy snark.c copy-paste bug that left the
     * verification residual r*delta*(V-U) != 0). */
    zkg1_copy_x(42u64, 32u64)
    i2 = 0u64
    while i2 < n { zkg1_mul_fr(45u64, 8u64 + i2, 266u64 + i2) zkg1_add_x(42u64, 42u64, 45u64) i2 = i2 + 1u64 }
    zkg1_mul_fr(45u64, 33u64, 265u64) zkg1_add_x(42u64, 42u64, 45u64)
    /* C = sum_{i>l} z_i L_i + sum_k h_k H_g1[k] + s*A + r*Bp - r*s*delta_g1 */
    zkg1_setinf_x(43u64)
    i2 = l + 1u64
    while i2 < n { zkg1_mul_fr(45u64, 21u64 + (i2 - l - 1u64), 266u64 + i2) zkg1_add_x(43u64, 43u64, 45u64) i2 = i2 + 1u64 }
    k = 0u64
    while k + 1u64 < m { zkg1_mul_fr(45u64, 28u64 + k, 442u64 + k) zkg1_add_x(43u64, 43u64, 45u64) k = k + 1u64 }
    zkg1_mul_fr(45u64, 41u64, 265u64) zkg1_add_x(43u64, 43u64, 45u64)        /* + s*A */
    zkg1_mul_fr(45u64, 42u64, 264u64) zkg1_add_x(43u64, 43u64, 45u64)        /* + r*Bp */
    frq_mul_x(447u64, 264u64, 265u64)                                        /* r*s */
    frq_set_u32(448u64, 0u32) frq_sub_x(447u64, 448u64, 447u64)              /* -rs mod r */
    zkg1_mul_fr(45u64, 33u64, 447u64) zkg1_add_x(43u64, 43u64, 45u64)        /* + (-rs)*delta_g1 */
    return 0i32
}
fn sn_verify(l: u64) -> u64 {
    zkg1_copy_x(44u64, 16u64)                                    /* acc = IC[0] */
    let mut i : u64 = 0u64
    while i < l { zkg1_mul_fr(45u64, 17u64 + i, 450u64 + i) zkg1_add_x(44u64, 44u64, 45u64) i = i + 1u64 }
    zkf_pairing_x(41u64, 16u64, 990u64)                          /* e(A,B) */
    zkf_pairing_x(31u64, 8u64, 996u64)                           /* e(alpha_g1, beta_g2) */
    zkf_pairing_x(44u64, 9u64, 1002u64)                          /* e(acc, gamma_g2) */
    zkf_pairing_x(43u64, 10u64, 1008u64)                         /* e(C, delta_g2) */
    zkf12_mul_x(1014u64, 996u64, 1002u64)
    zkf12_mul_x(1014u64, 1014u64, 1008u64)                       /* rhs */
    return zkf12_eq_x(990u64, 1014u64)
}

/* Groth16 KAT: x^3 = out circuit (m=2, n=4, l=1).  99 = pass. */
fn zk_snark_kat() -> u64 @export {
    frq_boot() zkf_boot()
    /* zero matrices (m*n = 8) */
    let mut k : u64 = 0u64
    while k < 8u64 { frq_set_u32(274u64 + k, 0u32) frq_set_u32(306u64 + k, 0u32) frq_set_u32(338u64 + k, 0u32) k = k + 1u64 }
    /* constraint 0: x*x = sym1  (a={v2}, b={v2}, c={v3}) */
    sn_set_mont(274u64 + 2u64, 1u32)        /* A[0][2] */
    sn_set_mont(306u64 + 2u64, 1u32)        /* B[0][2] */
    sn_set_mont(338u64 + 3u64, 1u32)        /* C[0][3] */
    /* constraint 1: sym1*x = out  (a={v3}, b={v2}, c={v1}) */
    sn_set_mont(274u64 + 4u64 + 3u64, 1u32) /* A[1][3] */
    sn_set_mont(306u64 + 4u64 + 2u64, 1u32) /* B[1][2] */
    sn_set_mont(338u64 + 4u64 + 1u64, 1u32) /* C[1][1] */
    /* witness x=3: z = [1, 27, 3, 9] */
    sn_set_mont(266u64, 1u32) sn_set_mont(267u64, 27u32) sn_set_mont(268u64, 3u32) sn_set_mont(269u64, 9u32)
    /* trapdoor + prover randomness (deterministic) */
    sn_set_mont(256u64, 7u32) sn_set_mont(257u64, 11u32) sn_set_mont(258u64, 13u32) sn_set_mont(259u64, 17u32) sn_set_mont(260u64, 5u32)
    sn_set_mont(264u64, 19u32) sn_set_mont(265u64, 23u32)
    sn_setup(2u64, 4u64, 1u64)
    sn_prove(2u64, 4u64, 1u64)
    sn_set_mont(450u64, 27u32)                                   /* public input out = 27 */
    if sn_verify(1u64) == 0u64 { return 1u64 }                   /* must accept */
    sn_set_mont(450u64, 28u32)                                   /* tamper */
    if sn_verify(1u64) == 1u64 { return 2u64 }                   /* must reject */
    return 99u64
}

