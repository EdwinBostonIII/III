/* STDLIB/iii/omnia/anamnesis.iii -- ANAMNESIS (the recollection): the fold re-founded in TIME.
 *
 * The fold is not a function called on a static graph.  It is what an append-only history RECOLLECTS: the one
 * nameless form drawn out of the flux of perceived events.  A set of order-constraints is not encoded as rival
 * vectors -- each [a<b] is PERCEIVED as an event on the isub logos bus (isub_emit V_BELOW, a, b).  From that ONE
 * event-log three readings are FOLDED, never stored:
 *
 *   IDENTITY   = isub_canon  -- the EXACT canonical form of the laid geometry up to renaming (brute-verified,
 *                              refuse-on-budget; sha256 only SEALS the exact bytes).  ONE identity, not a race.
 *   PROVENANCE = isub_witness -- the merkle root of the emitted CAVs (order- AND label-sensitive).  This is the
 *                              REAL witness that replaces the old 20-bit bounded handle (the "zk substitution").
 *   ORDER      = isub_below  -- the belief-order oracle (the Logos reading); the minimal basis is its transitive
 *                              reduction (the covering relations), folded from the log.
 *
 * WHY THIS IS PURE (no ontology/math contradiction -- the flaw SYMPLOKE held).  The old faculty laid an
 * UNDIRECTED graphic matroid across a DIRECTED order; on the diamond a<b,a<c,b<d,c<d the undirected rank (3)
 * DISAGREED with the order's basis (4), and that divergence was reported as "honesty."  It was a category error.
 * Here the numerical invariant is the DIRECTED transitive reduction (covering count), computed on the bus; an
 * INDEPENDENT engine (EIDOLOS eol_reduce, a separate entailment closure) agrees on BOTH the total order (3=3) AND
 * the diamond (4=4).  The contradiction is gone because the wrong ruler is gone.  ONE structure, ONE exact
 * identity, cross-certified without a lie.
 *
 * TWO BAROMETERS attest, never grade themselves: the LOGOS (the belief-order oracle + the independent eidolos
 * agreement) and the ELECTRON (bfp_compute48 -- the substrate's behavioral fingerprint, deterministic under our
 * folds).  Honest scope: the electron attests the SUBSTRATE's confluence, not any single claim.
 *
 * TEETH (the cross-checks are NOT vacuous): matched inputs AGREE and mismatched inputs DIVERGE (arm 7); the
 * identity is INVARIANT under relabeling and reordering (arms 10,13) yet the provenance DISTINGUISHES them (arms
 * 11,14) and the identity DISCRIMINATES distinct structures (arm 16).  Composes omnia/isub + omnia/eidolos +
 * katabasis/behavioral_fp.  Ring R0. */
module anamnesis

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn isub_reset() -> i32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_emit(verb: u32, a: u32, b: u32) -> u64 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_count() -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_verb(i: u32) -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_a(i: u32) -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_b(i: u32) -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_below(a: u32, b: u32) -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_canon_into(out32: *u8) -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_witness_into(out32: *u8) -> i32 from "isub.iii"
extern @abi(c-msvc-x64) fn isub_agree(root_a: *u8, root_b: *u8) -> u32 from "isub.iii"
extern @abi(c-msvc-x64) fn eol_reset() -> i32 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_read(addr: u64, len: u64) -> i64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_keep() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_reduce() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn bfp_compute48() -> u64 from "behavioral_fp.iii"

/* the perceived order, as (from,to) events -- laid onto the bus, never stored as a graph object */
var AN_FA : [u32; 16]   var AN_TB : [u32; 16]
var AN_NODE : [u32; 64]   var AN_NN : u64 = 0u64
/* the four 32-byte readings under test (canon = identity, wit = provenance) */
var AN_C1 : [u8; 32]   var AN_C2 : [u8; 32]   var AN_C3 : [u8; 32]   var AN_CD : [u8; 32]
var AN_W1 : [u8; 32]   var AN_W2 : [u8; 32]   var AN_W3 : [u8; 32]   var AN_TMP : [u8; 32]
/* the overhauled delivery store: keyed by the EXACT 32-byte canon (not a 20-bit handle) */
const AN_NSLOT : u64 = 64u64
var AN_SUSED : [u64; 64]   var AN_SKEY : [u8; 2048]   var AN_SN : [u64; 64]
var AN_SFA : [u32; 1024]   var AN_STB : [u32; 1024]

fn an_slen(s: u64) -> u64 { let p : *u8 = s as *u8   let mut i : u64 = 0u64   while p[i] != 0u8 { i = i + 1u64 }   return i }
fn an_pu(v: u64) -> u32 { if v >= 10u64 { an_pu(v / 10u64) }   putchar((48u64 + (v % 10u64)) as i32)   return 1u32 }
fn an_ps(s: u64) -> u32 { let p : *u8 = s as *u8   let mut i : u64 = 0u64   while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }   return 1u32 }

/* ===== lay the perceived order as EVENTS on the logos bus (event-primary) ===== */
fn an_lay(n: u64) -> i32 {
    isub_reset()
    let mut i : u64 = 0u64
    while i < n { isub_emit(0u32, AN_FA[i], AN_TB[i])   i = i + 1u64 }   /* verb 0 = V_BELOW */
    return 0i32
}
fn an_set_chain() -> u64 { AN_FA[0]=1u32 AN_TB[0]=2u32  AN_FA[1]=2u32 AN_TB[1]=3u32  AN_FA[2]=3u32 AN_TB[2]=4u32  return 3u64 }
fn an_set_chain_full() -> u64 {
    AN_FA[0]=1u32 AN_TB[0]=2u32  AN_FA[1]=2u32 AN_TB[1]=3u32  AN_FA[2]=3u32 AN_TB[2]=4u32
    AN_FA[3]=1u32 AN_TB[3]=3u32  AN_FA[4]=1u32 AN_TB[4]=4u32  AN_FA[5]=2u32 AN_TB[5]=4u32   return 6u64
}
fn an_set_diamond() -> u64 { AN_FA[0]=1u32 AN_TB[0]=2u32  AN_FA[1]=1u32 AN_TB[1]=3u32  AN_FA[2]=2u32 AN_TB[2]=4u32  AN_FA[3]=3u32 AN_TB[3]=4u32  return 4u64 }
fn an_set_chain_relabel() -> u64 { AN_FA[0]=11u32 AN_TB[0]=12u32  AN_FA[1]=12u32 AN_TB[1]=13u32  AN_FA[2]=13u32 AN_TB[2]=14u32  return 3u64 }
fn an_set_chain_reorder() -> u64 { AN_FA[0]=3u32 AN_TB[0]=4u32  AN_FA[1]=1u32 AN_TB[1]=2u32  AN_FA[2]=2u32 AN_TB[2]=3u32  return 3u64 }

/* ===== the minimal basis = transitive reduction (covering relations), FOLDED from the log ===== */
fn an_add_node(x: u32) -> i32 {
    let mut i : u64 = 0u64
    while i < AN_NN { if AN_NODE[i] == x { return 0i32 }   i = i + 1u64 }
    AN_NODE[AN_NN] = x   AN_NN = AN_NN + 1u64   return 0i32
}
fn an_gather_nodes() -> i32 {
    AN_NN = 0u64
    let n : u32 = isub_count()
    let mut i : u32 = 0u32
    while i < n { an_add_node(isub_a(i))   an_add_node(isub_b(i))   i = i + 1u32 }
    return 0i32
}
/* covering(a,b): the edge is in the minimal basis iff NO node z lies strictly between a and b in the order */
fn an_is_covering(a: u32, b: u32) -> u32 {
    let mut j : u64 = 0u64
    while j < AN_NN {
        let z : u32 = AN_NODE[j]
        if z != a { if z != b {
            if isub_below(a, z) == 1u32 { if isub_below(z, b) == 1u32 { return 0u32 } }
        } }
        j = j + 1u64
    }
    return 1u32
}
fn an_reduction_count() -> u64 {
    an_gather_nodes()
    let n : u32 = isub_count()
    let mut cnt : u64 = 0u64
    let mut i : u32 = 0u32
    while i < n {
        if isub_verb(i) == 0u32 { if an_is_covering(isub_a(i), isub_b(i)) == 1u32 { cnt = cnt + 1u64 } }
        i = i + 1u32
    }
    return cnt
}
/* the INDEPENDENT engine: eidolos entailment-closure drop count (a separate codebase, no self-grading) */
fn an_eol_dropped(claims: u64) -> u64 {
    eol_reset()
    if eol_read(claims, an_slen(claims)) <= 0i64 { return 9999u64 }
    if eol_keep() == 0u64 { return 9999u64 }
    return eol_reduce()
}

/* ===== the overhauled delivery: content-addressed by the EXACT 32-byte canon ===== */
fn an_key8(p: *u8) -> u64 { let mut v : u64 = 0u64   let mut i : u64 = 0u64   while i < 8u64 { v = (v << 8u64) | (p[i] as u64)   i = i + 1u64 }   return v }
fn an_key_eq(p: *u8, q: *u8) -> u32 { let mut i : u64 = 0u64   while i < 32u64 { if p[i] != q[i] { return 0u32 }   i = i + 1u64 }   return 1u32 }
fn an_store_reset() -> i32 { let mut i : u64 = 0u64   while i < AN_NSLOT { AN_SUSED[i] = 0u64   i = i + 1u64 }   return 0i32 }
/* publish the current (reduced) edges keyed by their exact canon; idempotent by 32-byte compare, not truncation */
fn an_publish(key: u64, n: u64) -> u64 {
    let kp : *u8 = key as *u8
    let base : u64 = (&AN_SKEY) as u64
    let mut h : u64 = an_key8(kp) % AN_NSLOT
    let mut tries : u64 = 0u64
    while tries < AN_NSLOT {
        let slot : *u8 = (base + h * 32u64) as *u8
        if AN_SUSED[h] == 1u64 {
            if an_key_eq(kp, slot) == 1u32 { return h }                       /* exact dedup */
        } else {
            let mut k : u64 = 0u64
            while k < 32u64 { slot[k] = kp[k]   k = k + 1u64 }
            AN_SN[h] = n
            let mut e : u64 = 0u64
            while e < n { AN_SFA[h * 16u64 + e] = AN_FA[e]   AN_STB[h * 16u64 + e] = AN_TB[e]   e = e + 1u64 }
            AN_SUSED[h] = 1u64
            return h
        }
        h = (h + 1u64) % AN_NSLOT   tries = tries + 1u64
    }
    return AN_NSLOT
}
/* resolve: re-lay the stored edges, re-canon, and confirm it re-seals to the SAME exact key (faithful) */
fn an_resolve(h: u64) -> u64 {
    if h >= AN_NSLOT { return 0u64 }
    if AN_SUSED[h] == 0u64 { return 0u64 }
    let n : u64 = AN_SN[h]
    isub_reset()
    let mut e : u64 = 0u64
    while e < n { isub_emit(0u32, AN_SFA[h * 16u64 + e], AN_STB[h * 16u64 + e])   e = e + 1u64 }
    if isub_canon_into((&AN_TMP) as u64 as *u8) != 1u32 { return 0u64 }
    let slot : *u8 = (((&AN_SKEY) as u64) + h * 32u64) as *u8
    if an_key_eq((&AN_TMP) as u64 as *u8, slot) != 1u32 { return 0u64 }        /* faithful iff re-canon == key */
    return n
}

/* ======================= THE GATE: the recollection, proven ======================= */
fn anamnesis_selfprove() -> u64 @export {
    /* --- EVENT-PRIMARY REDUCTION on the logos bus: the minimal basis is the transitive reduction --- */
    an_set_chain_full()   an_lay(6u64)
    let rc_total : u64 = an_reduction_count()
    if rc_total != 3u64 { return 1u64 }                                        /* total order of 6 -> basis 3 */
    an_set_diamond()   an_lay(4u64)
    let rc_dia : u64 = an_reduction_count()
    if rc_dia != 4u64 { return 2u64 }                                          /* diamond -> basis 4 (all covering) */

    /* --- CROSS-CERTIFICATION (independent engine, NO contradiction where the matroid lied) --- */
    if an_eol_dropped("[a < b] [b < c] [c < d] [a < c] [a < d] [b < d]" as u64) != 3u64 { return 3u64 }
    if an_eol_dropped("[a < b] [a < c] [b < d] [c < d]" as u64) != 0u64 { return 4u64 }
    if rc_total != (6u64 - 3u64) { return 5u64 }                               /* isub basis == eidolos kept: total */
    if rc_dia != (4u64 - 0u64) { return 6u64 }                                 /* isub basis == eidolos kept: DIAMOND */

    /* --- TEETH (falsifier): mismatched inputs MUST diverge, or the agreement is vacuous --- */
    an_set_diamond()   an_lay(4u64)
    let rc_mix : u64 = an_reduction_count()
    let ke_mix : u64 = 6u64 - an_eol_dropped("[a < b] [b < c] [c < d] [a < c] [a < d] [b < d]" as u64)
    if rc_mix == ke_mix { return 7u64 }                                        /* 4 != 3: the check discriminates */

    /* --- EXACT IDENTITY (canon) + REAL PROVENANCE (witness): the minimal basis, recollected --- */
    an_set_chain()   an_lay(3u64)
    if isub_canon_into((&AN_C1) as u64 as *u8) != 1u32 { return 8u64 }
    isub_witness_into((&AN_W1) as u64 as *u8)
    /* RELABEL: identity invariant, provenance distinguishes */
    an_set_chain_relabel()   an_lay(3u64)
    if isub_canon_into((&AN_C2) as u64 as *u8) != 1u32 { return 9u64 }
    isub_witness_into((&AN_W2) as u64 as *u8)
    if isub_agree((&AN_C1) as u64 as *u8, (&AN_C2) as u64 as *u8) != 1u32 { return 10u64 }
    if isub_agree((&AN_W1) as u64 as *u8, (&AN_W2) as u64 as *u8) != 0u32 { return 11u64 }
    /* REORDER: identity invariant, provenance distinguishes (the temporal leak, witnessed) */
    an_set_chain_reorder()   an_lay(3u64)
    if isub_canon_into((&AN_C3) as u64 as *u8) != 1u32 { return 12u64 }
    isub_witness_into((&AN_W3) as u64 as *u8)
    if isub_agree((&AN_C1) as u64 as *u8, (&AN_C3) as u64 as *u8) != 1u32 { return 13u64 }
    if isub_agree((&AN_W1) as u64 as *u8, (&AN_W3) as u64 as *u8) != 0u32 { return 14u64 }
    /* DISCRIMINATE: a distinct structure has a distinct identity (canon is not a constant) */
    an_set_diamond()   an_lay(4u64)
    if isub_canon_into((&AN_CD) as u64 as *u8) != 1u32 { return 15u64 }
    if isub_agree((&AN_C1) as u64 as *u8, (&AN_CD) as u64 as *u8) != 0u32 { return 16u64 }

    /* --- OVERHAULED DELIVERY: exact 32-byte canon key (retires the 20-bit handle), faithful, idempotent --- */
    an_store_reset()
    an_set_chain()   an_lay(3u64)   isub_canon_into((&AN_C1) as u64 as *u8)
    let h1 : u64 = an_publish((&AN_C1) as u64 as *u8, 3u64)
    if h1 >= AN_NSLOT { return 17u64 }
    if an_resolve(h1) != 3u64 { return 18u64 }                                 /* faithful: re-canon == stored key */
    let h1b : u64 = an_publish((&AN_C1) as u64 as *u8, 3u64)
    if h1b != h1 { return 19u64 }                                              /* idempotent: exact-key dedup */
    an_set_diamond()   an_lay(4u64)   isub_canon_into((&AN_CD) as u64 as *u8)
    let h2 : u64 = an_publish((&AN_CD) as u64 as *u8, 4u64)
    if h2 == h1 { return 20u64 }                                               /* distinct structure -> distinct slot */

    /* --- THE ELECTRON BAROMETER: the substrate's confluence, deterministic under our folds --- */
    if bfp_compute48() != bfp_compute48() { return 21u64 }

    return 0u64
}

fn an_show() -> i32 @export {
    an_ps("ANAMNESIS -- the fold recollected in time: events -> one exact identity, witnessed, no contradiction.\n" as u64)
    an_set_chain_full()   an_lay(6u64)
    an_ps("  total order (6 events): transitive reduction (isub) = " as u64)   an_pu(an_reduction_count())
    an_ps("   eidolos keeps = " as u64)   an_pu(6u64 - an_eol_dropped("[a < b] [b < c] [c < d] [a < c] [a < d] [b < d]" as u64))   an_ps("  -> AGREE\n" as u64)
    an_set_diamond()   an_lay(4u64)
    an_ps("  diamond (4 events):    transitive reduction (isub) = " as u64)   an_pu(an_reduction_count())
    an_ps("   eidolos keeps = " as u64)   an_pu(4u64 - an_eol_dropped("[a < b] [a < c] [b < d] [c < d]" as u64))   an_ps("  -> AGREE (the matroid lied here; the directed invariant does not)\n" as u64)
    return 0i32
}

fn main(argc: i32, argv: u64) -> u64 {
    let _a : i32 = argc   let _v : u64 = argv
    an_show()
    let r : u64 = anamnesis_selfprove()
    an_ps("anamnesis_selfprove = " as u64)   an_pu(r)
    if r == 0u64 { an_ps("  GREEN: event-primary fold; one exact identity; real witness; cross-certified with no contradiction; two barometers.\n" as u64) } else { an_ps("  (arm failed)\n" as u64) }
    return r
}
