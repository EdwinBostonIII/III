/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\dome_society.iii
 *
 * III STDLIB - omnia::dome_society  --  the Dome, evolved: each twin holds its OWN append-only log, and
 * perception is a PHYSICAL event -- a ripple is DELIVERED into a subscriber's own log via an explicit
 * subscription topology.  "Their own logs and their own ripples", literally.
 *
 * Where dome.iii is one shared participant-tagged history, here EYE/WAVE/ECHO/TIDE each have a private
 * log (a flattened [TW*CAP] arena).  soc_subscribe(from,to) wires the society: when `from` emits, the
 * event is appended to its own log AND delivered as a RIPPLE into every subscriber's log (src = the
 * emitter).  So a twin's log = its own emissions + exactly the ripples it chose to perceive.  This makes
 * cross-perception MEASURABLE (soc_perceived_count) and the wiring an inspectable topology -- the basis
 * for a fair, instrumented comparison against a deterministic decider.
 *
 * Reversibility is preserved per-twin: soc_mark snapshots every twin's head; soc_rewind records the
 * abandoned span [mark,head) PER TWIN (nothing erased -- provenance) and stamps a REWIND in TIDE's log.
 * The active fold skips abandoned spans.  NOT observational learning: fixed pure folds; a re-choice
 * changes only because the lesson is a recorded event.  Ring R0.  K 1.00.  NIH: libc only, zero externs.
 */
module omnia_dome_society

const TW       : u32 = 4u32      /* EYE WAVE ECHO TIDE */
const CAP      : u32 = 128u32    /* per-twin log capacity */
const SOC_NULL : u32 = 0xFFFFFFFFu32
const SOC_MAXAB: u32 = 64u32

const S_EYE  : u64 = 0u64
const S_WAVE : u64 = 1u64
const S_ECHO : u64 = 2u64
const S_TIDE : u64 = 3u64

const SK_MOVE   : u64 = 0u64
const SK_RIPPLE : u64 = 1u64
const SK_REWIND : u64 = 2u64
const SK_LESSON : u64 = 3u64

/* per-twin logs (flattened: twin*CAP + i) */
var SL_TICK : [u64; 512]
var SL_SRC  : [u64; 512]   /* originator (self for own emissions, the emitter for a delivered ripple) */
var SL_KIND : [u64; 512]
var SL_VAL  : [u64; 512]
var SL_PAY  : [u64; 512]
var SL_CNT  : [u32; 4]     /* per-twin head */

var SL_SUB  : [u32; 16]    /* subscription matrix SUB[from*TW+to] */
var SL_MARK : [u32; 4]     /* per-twin head snapshot at the branch-point */

var SL_ABTW : [u32; 64]    /* abandoned spans: (twin, lo, hi) -- provenance */
var SL_ABLO : [u32; 64]
var SL_ABHI : [u32; 64]
var SL_NAB  : u32 = 0u32

var SL_CLOCK   : u64 = 0u64
var SL_REWINDS : u32 = 0u32

fn soc_reset() -> i32 @export {
    let mut t : u32 = 0u32
    while t < TW { SL_CNT[t] = 0u32  SL_MARK[t] = 0u32  t = t + 1u32 }
    let mut i : u32 = 0u32
    while i < 16u32 { SL_SUB[i] = 0u32  i = i + 1u32 }
    SL_NAB = 0u32
    SL_CLOCK = 0u64
    SL_REWINDS = 0u32
    return 0i32
}

fn soc_subscribe(frm: u64, to: u64) -> i32 @export {
    let f : u32 = frm as u32
    let tt : u32 = to as u32
    if f < TW { if tt < TW { SL_SUB[f * TW + tt] = 1u32 } }
    return 0i32
}

/* internal: append one event to a twin's own log (not @export -- not public API) */
fn soc_append(twin: u32, src: u64, kind: u64, value: u64, payload: u64) -> i32 {
    if twin >= TW { return -1i32 }
    if SL_CNT[twin] >= CAP { return -1i32 }
    let idx : u32 = twin * CAP + SL_CNT[twin]
    let t : u64 = SL_CLOCK + 1u64
    SL_TICK[idx] = t
    SL_SRC[idx]  = src
    SL_KIND[idx] = kind
    SL_VAL[idx]  = value
    SL_PAY[idx]  = payload
    SL_CNT[twin] = SL_CNT[twin] + 1u32
    SL_CLOCK = t
    return 0i32
}

/* emit: append to the twin's OWN log, then DELIVER as a ripple into each subscriber's log. */
fn soc_emit(twin: u64, kind: u64, value: u64, payload: u64) -> u64 @export {
    let tw : u32 = twin as u32
    if tw >= TW { return 0u64 }
    soc_append(tw, twin, kind, value, payload)
    let mut to : u32 = 0u32
    while to < TW {
        if SL_SUB[tw * TW + to] == 1u32 {
            soc_append(to, twin, SK_RIPPLE, value, payload)
        }
        to = to + 1u32
    }
    return SL_CLOCK
}

fn soc_count(twin: u64) -> u32 @export {
    let t : u32 = twin as u32
    if t >= TW { return 0u32 }
    return SL_CNT[t]
}

/* mark a branch-point: snapshot every twin's head (so a rewind knows what to abandon). */
fn soc_mark() -> i32 @export {
    let mut t : u32 = 0u32
    while t < TW { SL_MARK[t] = SL_CNT[t]  t = t + 1u32 }
    return 0i32
}

/* rewind: record [mark,head) per twin as abandoned provenance (erase nothing), stamp a REWIND in TIDE. */
fn soc_rewind() -> i32 @export {
    let mut t : u32 = 0u32
    while t < TW {
        if SL_CNT[t] > SL_MARK[t] {
            if SL_NAB < SOC_MAXAB {
                SL_ABTW[SL_NAB] = t
                SL_ABLO[SL_NAB] = SL_MARK[t]
                SL_ABHI[SL_NAB] = SL_CNT[t]
                SL_NAB = SL_NAB + 1u32
            }
        }
        t = t + 1u32
    }
    soc_append(S_TIDE as u32, S_TIDE, SK_REWIND, 0u64, 0u64)
    SL_REWINDS = SL_REWINDS + 1u32
    return 0i32
}

/* internal: is event i of `twin` inside an abandoned span? (not @export) */
fn soc_abandoned(twin: u32, i: u32) -> u32 {
    let mut s : u32 = 0u32
    while s < SL_NAB {
        if SL_ABTW[s] == twin {
            if i >= SL_ABLO[s] { if i < SL_ABHI[s] { return 1u32 } }
        }
        s = s + 1u32
    }
    return 0u32
}

/* the ACTIVE fold: max value over a twin's LIVE events (skips abandoned branches + REWIND marks). */
fn soc_active_max(twin: u64) -> u64 @export {
    let tw : u32 = twin as u32
    if tw >= TW { return 0u64 }
    let mut m : u64 = 0u64
    let mut i : u32 = 0u32
    while i < SL_CNT[tw] {
        if soc_abandoned(tw, i) == 0u32 {
            let idx : u32 = tw * CAP + i
            if SL_KIND[idx] != SK_REWIND {
                let v : u64 = SL_VAL[idx]
                if v > m { m = v }
            }
        }
        i = i + 1u32
    }
    return m
}

fn soc_active_parity(twin: u64) -> u64 @export {
    let m : u64 = soc_active_max(twin)
    return m & 1u64
}

/* recurrence over a twin's LIVE events: first live prior index with this payload. */
fn soc_recurred(twin: u64, payload: u64, upto: u32) -> u32 @export {
    let tw : u32 = twin as u32
    if tw >= TW { return SOC_NULL }
    let mut i : u32 = 0u32
    while i < upto {
        if i < SL_CNT[tw] {
            if soc_abandoned(tw, i) == 0u32 {
                let idx : u32 = tw * CAP + i
                if SL_PAY[idx] == payload { return i }
            }
        }
        i = i + 1u32
    }
    return SOC_NULL
}

/* total abandoned (provenance) events across all twins -- the debug trail a determinist erases. */
fn soc_provenance_count() -> u32 @export {
    let mut c : u32 = 0u32
    let mut t : u32 = 0u32
    while t < TW {
        let mut i : u32 = 0u32
        while i < SL_CNT[t] {
            if soc_abandoned(t, i) == 1u32 { c = c + 1u32 }
            i = i + 1u32
        }
        t = t + 1u32
    }
    return c
}

fn soc_rewind_count() -> u32 @export { return SL_REWINDS }

/* total events of a kind by a twin (live + abandoned) = attempts made (e.g. ECHO MOVEs = choices tried). */
fn soc_kind_total(twin: u64, kind: u64) -> u32 @export {
    let tw : u32 = twin as u32
    if tw >= TW { return 0u32 }
    let mut c : u32 = 0u32
    let mut i : u32 = 0u32
    while i < SL_CNT[tw] {
        let idx : u32 = tw * CAP + i
        if SL_KIND[idx] == kind { c = c + 1u32 }
        i = i + 1u32
    }
    return c
}

/* how many events in a twin's log originated ELSEWHERE (delivered ripples) = its perceived inflow. */
fn soc_perceived_count(twin: u64) -> u32 @export {
    let tw : u32 = twin as u32
    if tw >= TW { return 0u32 }
    let mut c : u32 = 0u32
    let mut i : u32 = 0u32
    while i < SL_CNT[tw] {
        let idx : u32 = tw * CAP + i
        if SL_SRC[idx] != twin { c = c + 1u32 }
        i = i + 1u32
    }
    return c
}

/* internal mix (not @export) */
fn soc_mix(h: u64, x: u64) -> u64 {
    let r : u64 = h * 1099511628211u64 + x
    return r
}

/* witness over ALL twins' full logs -- provenance INCLUDED (the abandoned branches are in the seal). */
fn soc_witness_global() -> u64 @export {
    let mut h : u64 = 14695981039346656037u64
    let mut t : u32 = 0u32
    while t < TW {
        let mut i : u32 = 0u32
        while i < SL_CNT[t] {
            let idx : u32 = t * CAP + i
            h = soc_mix(h, SL_TICK[idx])
            h = soc_mix(h, SL_SRC[idx])
            h = soc_mix(h, SL_KIND[idx])
            h = soc_mix(h, SL_VAL[idx])
            h = soc_mix(h, SL_PAY[idx])
            i = i + 1u32
        }
        t = t + 1u32
    }
    return h
}
