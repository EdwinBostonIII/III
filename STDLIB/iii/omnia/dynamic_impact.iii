/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\dynamic_impact.iii
 *
 * III STDLIB - omnia::dynamic_impact
 *
 * Lattice plan Step 0025 (user-mode counterpart to sema's planned
 * @dynamic_impact analysis pass).  Records per-crystal expected perf
 * and UX deltas in basis-points (signed; encoded as u32 two's-comp).
 *
 *   register(crystal_id, perf_bp, ux_bp) -> i32
 *   perf_bp(crystal_id) -> u32
 *   ux_bp(crystal_id) -> u32
 *   aggregate_perf() -> i64   (sum of all registered perf_bp, signed)
 *   aggregate_ux()   -> i64   (same for ux)
 *
 * Capacity: 256 records.
 *
 * Hexad: kind_form (recording).  Ring: R0.  K: 1.00.
 */

module omnia_dynamic_impact

const IMPACT_OK         : i32 =  0i32
const IMPACT_E_BADID    : i32 = -1i32
const IMPACT_E_FULL     : i32 = -2i32

const IMPACT_MAX : u32 = 256u32

var IMPACT_ID    : [u64; 256]
var IMPACT_PERF  : [u32; 256]
var IMPACT_UX    : [u32; 256]
var IMPACT_LIVE  : [u8;  256]
var IMPACT_COUNT : u32 = 0u32

fn impact_find(id: u64) -> u32 {
    if id == 0u64 { return 0xFFFFFFFFu32 }
    let mut i : u32 = 0u32
    let mut found : u32 = 0xFFFFFFFFu32
    while i < IMPACT_MAX {
        if IMPACT_LIVE[i] == 1u8 {
            if IMPACT_ID[i] == id {
                if found == 0xFFFFFFFFu32 { found = i }
            }
        }
        i = i + 1u32
    }
    return found
}

fn dynamic_impact_register(id: u64, perf_bp: u32, ux_bp: u32) -> i32 @export {
    if id == 0u64 { return IMPACT_E_BADID }
    let existing : u32 = impact_find(id)
    if existing != 0xFFFFFFFFu32 {
        IMPACT_PERF[existing] = perf_bp & 0xFFFFFFFFu32
        IMPACT_UX[existing]   = ux_bp   & 0xFFFFFFFFu32
        return IMPACT_OK
    }
    let mut i : u32 = 0u32
    let mut slot : u32 = 0xFFFFFFFFu32
    while i < IMPACT_MAX {
        if IMPACT_LIVE[i] == 0u8 {
            if slot == 0xFFFFFFFFu32 { slot = i }
        }
        i = i + 1u32
    }
    if slot == 0xFFFFFFFFu32 { return IMPACT_E_FULL }
    IMPACT_ID[slot]   = id
    IMPACT_PERF[slot] = perf_bp & 0xFFFFFFFFu32
    IMPACT_UX[slot]   = ux_bp   & 0xFFFFFFFFu32
    IMPACT_LIVE[slot] = 1u8
    IMPACT_COUNT = IMPACT_COUNT + 1u32
    return IMPACT_OK
}

fn dynamic_impact_perf_bp(id: u64) -> u32 @export {
    let s : u32 = impact_find(id)
    if s == 0xFFFFFFFFu32 { return 0u32 }
    return IMPACT_PERF[s]
}

fn dynamic_impact_ux_bp(id: u64) -> u32 @export {
    let s : u32 = impact_find(id)
    if s == 0xFFFFFFFFu32 { return 0u32 }
    return IMPACT_UX[s]
}

fn dynamic_impact_count() -> u32 @export {
    return IMPACT_COUNT
}

/* Sign-extend a u32 holding an i32 (signed basis points, two's-complement) to a 64-bit
 * two's-complement value in a u64.  W4.3 (II-DYNIMP-2): the prior aggregate cast `as u64`,
 * which ZERO-extends -- a stored -100 (0xFFFFFF9C) became +4294967196, corrupting any sum
 * with a negative term. */
fn _di_sext32(v: u32) -> u64 {
    let lo : u64 = (v as u64) & 0xFFFFFFFFu64
    if (v & 0x80000000u32) != 0u32 { return lo | 0xFFFFFFFF00000000u64 }
    return lo
}

/* Signed 64-bit sum of all live perf basis points.  Two's-complement add over sign-extended
 * terms yields the exact signed sum; with <=256 terms each |v| < 2^31 the magnitude < 2^39,
 * so it never overflows i64.  iii returns the full 64 bits via u64 (the i64 bit pattern). */
fn dynamic_impact_aggregate_perf() -> u64 @export {
    let mut sum : u64 = 0u64
    let mut i : u32 = 0u32
    while i < IMPACT_MAX {
        if IMPACT_LIVE[i] == 1u8 {
            sum = sum + _di_sext32(IMPACT_PERF[i])
        }
        i = i + 1u32
    }
    return sum
}

/* W4.3 (II-DYNIMP-1): aggregate_ux was entirely UNIMPLEMENTED.  Same signed sum over the UX
 * deltas -- the declared capability, now real. */
fn dynamic_impact_aggregate_ux() -> u64 @export {
    let mut sum : u64 = 0u64
    let mut i : u32 = 0u32
    while i < IMPACT_MAX {
        if IMPACT_LIVE[i] == 1u8 {
            sum = sum + _di_sext32(IMPACT_UX[i])
        }
        i = i + 1u32
    }
    return sum
}

/* Low / high 32-bit halves of the signed 64-bit aggregates (the "two u64 sentinels" the
 * header names).  Kept for the split-readout API; both are now sign-correct. */
fn dynamic_impact_aggregate_perf_lo() -> u64 @export {
    return dynamic_impact_aggregate_perf() & 0xFFFFFFFFu64
}
fn dynamic_impact_aggregate_perf_hi() -> u64 @export {
    return (dynamic_impact_aggregate_perf() >> 32u64) & 0xFFFFFFFFu64
}
fn dynamic_impact_aggregate_ux_lo() -> u64 @export {
    return dynamic_impact_aggregate_ux() & 0xFFFFFFFFu64
}
fn dynamic_impact_aggregate_ux_hi() -> u64 @export {
    return (dynamic_impact_aggregate_ux() >> 32u64) & 0xFFFFFFFFu64
}
