/* STDLIB/iii/omnia/elenchos.iii -- ELENCHOS (ἔλεγχος, the refutation): the ZK under-constraint engine at the
 * REAL field.  The #1 ZK-circuit vulnerability is UNDER-CONSTRAINT: the constraint system fails to uniquely
 * determine the witness, so a malicious prover forges an accepted proof (soundness broken).  Over the field this
 * IS the fold: constraint matrix A is under-constrained  <=>  rank(A) < #witness vars  <=>  ker(A) != 0  <=>  a
 * nullspace vector w0 with A*w0 = 0, so for ANY honest witness w, (w + t*w0) is ALSO accepted for all t.  ELENCHOS
 * produces that w0 -- the Socratic refutation: a counter-witness that cross-examines the circuit's claimed
 * soundness to destruction.
 *
 * Exact over the ACTUAL BN254 scalar field r = 0x30644E72E131A029B85045B68181585D2833E84879B9709143E1F593F0000001
 * (the field circom/snarkjs use), via III's arbitrary-precision modular arithmetic (bigint_mod / bigint_modpow
 * Fermat inverse).  Modular Gaussian elimination -> exact rank + a nullspace basis vector; the forgery is verified
 * against the UNTOUCHED original matrix (non-circular).  Fires on under-constrained circuits (emits the forgery),
 * stays silent on sound ones.  Composes numera/bigint(+div) + memoria/arena.  Ring R0.
 *
 * SCOPE (honest): the LINEAR under-constraint subclass, exact at 254 bits, small systems (bigint 64-slot handle
 * table).  Real-circuit SCALE (thousands of constraints) needs flat-limb linear algebra; general R1CS is quadratic
 * (Jacobian-linearization).  Those are the productionization axes; this is the verified real-field core. */
module elenchos

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn bigint_new(arena: u64, cap: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_from_u64(arena: u64, v: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_set_limb(id: u64, i: u64, v: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_set_len(id: u64, len: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_normalize(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_copy(arena: u64, src: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_drop(id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_is_zero(id: u64) -> u8 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_cmp(a: u64, b: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mul(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_add(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_sub(arena: u64, a: u64, b: u64) -> u64 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mod(arena: u64, a: u64, m: u64) -> u64 from "bigint_div.iii"
extern @abi(c-msvc-x64) fn bigint_modpow(arena: u64, base: u64, exp: u64, modulus: u64) -> u64 from "bigint_div.iii"
extern @abi(c-msvc-x64) fn bigint_drop_arena(arena_id: u64) -> i32 from "bigint.iii"
extern @abi(c-msvc-x64) fn bigint_mul_u64(arena: u64, a: u64, scalar: u64) -> u64 from "bigint.iii"
/* the INGESTER is composition, not a from-scratch parser: III's RFC-8259 JSON parser (verba/json) eats the
 * circuit's constraint system (snarkjs exports R1CS/witness as JSON), coefficients read as raw digit text so
 * 254-bit BN254 field elements survive past i64. */
extern @abi(c-msvc-x64) fn json_parse(arena: u64, input_base: u64, input_len: u64) -> u64 from "json.iii"
extern @abi(c-msvc-x64) fn json_object_get(id: u64, key_base: u64, key_len: u64) -> u64 from "json.iii"
extern @abi(c-msvc-x64) fn json_array_len(id: u64) -> u64 from "json.iii"
extern @abi(c-msvc-x64) fn json_array_at(id: u64, i: u64) -> u64 from "json.iii"
extern @abi(c-msvc-x64) fn json_int(id: u64) -> i64 from "json.iii"
extern @abi(c-msvc-x64) fn json_string_base(id: u64) -> u64 from "json.iii"
extern @abi(c-msvc-x64) fn json_string_len(id: u64) -> u64 from "json.iii"

var EL_M    : [u64; 64]     /* working matrix (flat, r*nc+c), bigint ids */
var EL_ORIG : [u64; 64]     /* untouched copy for non-circular verification */
var EL_PIV  : [u64; 16]     /* pivot column of each rank row */
var EL_ISP  : [u64; 16]     /* is-pivot flag per column */
var EL_W0   : [u64; 16]     /* the forged nullspace witness (one bigint id per column) */
var EL_NR : u64 = 0u64   var EL_NC : u64 = 0u64   var EL_RANK : u64 = 0u64   var EL_P : u64 = 0u64   var EL_AR : u64 = 0u64
/* ---- R1CS (quadratic) layer: constraint (A*w)(B*w) = (C*w); Jacobian-linearization ---- */
var EL_RA : [u64; 64]     var EL_RB : [u64; 64]     var EL_RC : [u64; 64]   /* R1CS coeffs (small ints), flat m*n */
var EL_WI : [u64; 16]                                                       /* the satisfying witness w* (small ints) */
var EL_RM : u64 = 0u64   var EL_RN : u64 = 0u64   var EL_RPIN : u64 = 0u64  /* #constraints, #vars, #pinned public cols */
var EL_JSONBUF : [u8; 1024]   /* writable copy of the circuit JSON (never parse from read-only rodata) */

fn ps(s: u64) -> u32 { let p : *u8 = s as *u8   let mut i : u64 = 0u64   while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }   return 1u32 }
fn pu(v: u64) -> u32 { if v >= 10u64 { pu(v / 10u64) }   putchar((48u64 + (v % 10u64)) as i32)   return 1u32 }

fn el_field(arena: u64) -> u64 {
    let id : u64 = bigint_new(arena, 4u64)
    bigint_set_limb(id, 0u64, 0x43E1F593F0000001u64)   bigint_set_limb(id, 1u64, 0x2833E84879B97091u64)
    bigint_set_limb(id, 2u64, 0xB85045B68181585Du64)   bigint_set_limb(id, 3u64, 0x30644E72E131A029u64)
    bigint_set_len(id, 4u64)   bigint_normalize(id)   return id
}
/* modular ops over EL_P, each dropping its own intermediates (64-slot discipline) */
fn el_mul(a: u64, b: u64) -> u64 { let m : u64 = bigint_mul(EL_AR, a, b)   let r : u64 = bigint_mod(EL_AR, m, EL_P)   bigint_drop(m)   return r }
fn el_add(a: u64, b: u64) -> u64 { let m : u64 = bigint_add(EL_AR, a, b)   let r : u64 = bigint_mod(EL_AR, m, EL_P)   bigint_drop(m)   return r }
fn el_sub(a: u64, b: u64) -> u64 {                                    /* (a-b) mod p, a,b in [0,p) */
    if bigint_cmp(a, b) >= 0i32 { return bigint_sub(EL_AR, a, b) }
    let apb : u64 = bigint_add(EL_AR, a, EL_P)   let r : u64 = bigint_sub(EL_AR, apb, b)   bigint_drop(apb)   return r
}
fn el_inv(a: u64) -> u64 {                                           /* Fermat: a^(p-2) mod p */
    let two : u64 = bigint_from_u64(EL_AR, 2u64)   let e : u64 = bigint_sub(EL_AR, EL_P, two)
    let r : u64 = bigint_modpow(EL_AR, a, e, EL_P)   bigint_drop(two)   bigint_drop(e)   return r
}
fn el_at(r: u64, c: u64) -> u64 { return EL_M[r * EL_NC + c] }
fn el_setm(r: u64, c: u64, id: u64) -> i32 { EL_M[r * EL_NC + c] = id   return 0i32 }
fn el_oat(r: u64, c: u64) -> u64 { return EL_ORIG[r * EL_NC + c] }

/* set entry (r,c) to the small integer v (mod p), replacing any prior id */
fn el_put(r: u64, c: u64, v: u64) -> i32 { el_setm(r, c, bigint_from_u64(EL_AR, v))   return 0i32 }

fn el_copy_orig() -> i32 {
    let mut k : u64 = 0u64
    while k < EL_NR * EL_NC { EL_ORIG[k] = bigint_copy(EL_AR, EL_M[k])   k = k + 1u64 }
    return 0i32
}
fn el_swap_rows(r1: u64, r2: u64) -> i32 {
    let mut c : u64 = 0u64
    while c < EL_NC { let t : u64 = el_at(r1, c)   el_setm(r1, c, el_at(r2, c))   el_setm(r2, c, t)   c = c + 1u64 }
    return 0i32
}
/* in-place RREF over GF(p); sets EL_RANK and EL_PIV[] */
fn el_gauss() -> u64 {
    let mut rank : u64 = 0u64   let mut col : u64 = 0u64
    while col < EL_NC {
        if rank < EL_NR {
            let mut piv : u64 = EL_NR   let mut r : u64 = rank
            while r < EL_NR { if bigint_is_zero(el_at(r, col)) == 0u8 { if piv == EL_NR { piv = r } }   r = r + 1u64 }
            if piv != EL_NR {
                el_swap_rows(rank, piv)
                let inv : u64 = el_inv(el_at(rank, col))
                let mut j : u64 = col
                while j < EL_NC { let nw : u64 = el_mul(el_at(rank, j), inv)   bigint_drop(el_at(rank, j))   el_setm(rank, j, nw)   j = j + 1u64 }
                bigint_drop(inv)
                let mut i : u64 = 0u64
                while i < EL_NR {
                    if i != rank { if bigint_is_zero(el_at(i, col)) == 0u8 {
                        let factor : u64 = bigint_copy(EL_AR, el_at(i, col))
                        let mut j2 : u64 = col
                        while j2 < EL_NC {
                            let prod : u64 = el_mul(factor, el_at(rank, j2))
                            let nw2 : u64 = el_sub(el_at(i, j2), prod)
                            bigint_drop(prod)   bigint_drop(el_at(i, j2))   el_setm(i, j2, nw2)
                            j2 = j2 + 1u64
                        }
                        bigint_drop(factor)
                    } }
                    i = i + 1u64
                }
                EL_PIV[rank] = col   rank = rank + 1u64
            }
        }
        col = col + 1u64
    }
    EL_RANK = rank   return rank
}
/* build the forged witness EL_W0 from the first free column; returns that column, or EL_NC if full rank (sound) */
fn el_nullspace() -> u64 {
    let mut c : u64 = 0u64
    while c < EL_NC { EL_ISP[c] = 0u64   c = c + 1u64 }
    let mut k : u64 = 0u64
    while k < EL_RANK { EL_ISP[EL_PIV[k]] = 1u64   k = k + 1u64 }
    let mut f : u64 = EL_NC   c = 0u64
    while c < EL_NC { if EL_ISP[c] == 0u64 { if f == EL_NC { f = c } }   c = c + 1u64 }
    if f == EL_NC { return EL_NC }                                    /* full rank -> sound */
    c = 0u64
    while c < EL_NC { EL_W0[c] = bigint_from_u64(EL_AR, 0u64)   c = c + 1u64 }
    bigint_drop(EL_W0[f])   EL_W0[f] = bigint_from_u64(EL_AR, 1u64)   /* free var = 1 */
    k = 0u64
    while k < EL_RANK {
        let val : u64 = el_at(k, f)                                   /* RREF[k][f] */
        if bigint_is_zero(val) == 0u8 {
            bigint_drop(EL_W0[EL_PIV[k]])
            EL_W0[EL_PIV[k]] = bigint_sub(EL_AR, EL_P, val)           /* pivot var = -RREF[k][f] = p - val */
        }
        k = k + 1u64
    }
    return f
}
/* verify ORIG * W0 == 0 (mod p), against the UNTOUCHED matrix (non-circular): 1 = valid forgery */
fn el_verify() -> u64 {
    let mut i : u64 = 0u64
    while i < EL_NR {
        let mut acc : u64 = bigint_from_u64(EL_AR, 0u64)
        let mut c : u64 = 0u64
        while c < EL_NC {
            let prod : u64 = el_mul(el_oat(i, c), EL_W0[c])
            let nacc : u64 = el_add(acc, prod)
            bigint_drop(prod)   bigint_drop(acc)   acc = nacc
            c = c + 1u64
        }
        if bigint_is_zero(acc) == 0u8 { bigint_drop(acc)   return 0u64 }
        bigint_drop(acc)
        i = i + 1u64
    }
    return 1u64
}

/* ---- JSON INGESTION (composes verba/json) -- the circuit's constraints, eaten end-to-end ---- */
fn el_load_json(src: u64) -> u64 {                                  /* copy rodata literal -> writable buffer */
    let s : *u8 = src as *u8   let d : *u8 = (&EL_JSONBUF) as u64 as *u8
    let mut i : u64 = 0u64
    while s[i] != 0u8 { d[i] = s[i]   i = i + 1u64 }
    d[i] = 0u8   return i
}
fn el_dec(base: u64, len: u64) -> u64 {                             /* decimal digit text -> bigint (any width) */
    let mut acc : u64 = bigint_from_u64(EL_AR, 0u64)
    let p : *u8 = base as *u8   let mut i : u64 = 0u64
    while i < len {
        let ch : u8 = p[i]
        if ch >= 48u8 { if ch <= 57u8 {
            let dd : u64 = bigint_from_u64(EL_AR, (ch - 48u8) as u64)
            let t1 : u64 = bigint_mul_u64(EL_AR, acc, 10u64)
            let t2 : u64 = bigint_add(EL_AR, t1, dd)
            bigint_drop(acc)   bigint_drop(t1)   bigint_drop(dd)   acc = t2
        } }
        i = i + 1u64
    }
    return acc
}
/* parse {"vars":N,"rows":[[c,..],..]} -> matrix over r -> refute.  returns el_refute (1/0), or -1 on parse error */
fn el_ingest_json(base: u64, len: u64) -> i64 {
    el_free()                                                       /* clear any prior case's matrix (slot table) */
    let root : u64 = json_parse(EL_AR, base, len)
    if root == 0u64 { return 0i64 - 1i64 }
    let vars : u64 = json_object_get(root, "vars" as u64, 4u64)
    let rows : u64 = json_object_get(root, "rows" as u64, 4u64)
    if vars == 0u64 { return 0i64 - 1i64 }
    if rows == 0u64 { return 0i64 - 1i64 }
    EL_NC = json_int(vars) as u64
    EL_NR = json_array_len(rows)
    let mut r : u64 = 0u64
    while r < EL_NR {
        let row : u64 = json_array_at(rows, r)
        let mut c : u64 = 0u64
        while c < EL_NC {
            let coef : u64 = json_array_at(row, c)
            let dec : u64 = el_dec(json_string_base(coef), json_string_len(coef))   /* field elements as decimal strings (snarkjs form) */
            el_setm(r, c, bigint_mod(EL_AR, dec, EL_P))
            bigint_drop(dec)
            c = c + 1u64
        }
        r = r + 1u64
    }
    return el_refute() as i64
}

/* free all live matrix/orig/forgery bigints between independent cases (bigint 64-slot handle table) */
fn el_free() -> i32 {
    let mut k : u64 = 0u64
    while k < 64u64 {
        if EL_M[k] != 0u64 { bigint_drop(EL_M[k])   EL_M[k] = 0u64 }
        if EL_ORIG[k] != 0u64 { bigint_drop(EL_ORIG[k])   EL_ORIG[k] = 0u64 }
        k = k + 1u64
    }
    let mut j : u64 = 0u64
    while j < 16u64 { if EL_W0[j] != 0u64 { bigint_drop(EL_W0[j])   EL_W0[j] = 0u64 }   j = j + 1u64 }
    return 0i32
}

/* ================= THE GATE ================= */
/* returns 1 if the current matrix is under-constrained AND a verified forgery was produced; 0 if sound */
fn el_refute() -> u64 {
    el_copy_orig()
    el_gauss()
    if EL_RANK >= EL_NC { return 0u64 }                              /* full column rank -> sound */
    let f : u64 = el_nullspace()
    if f == EL_NC { return 0u64 }
    return el_verify()                                               /* forgery must satisfy ORIG*w0=0 */
}

fn elenchos_selfprove() -> u64 @export {
    EL_AR = arena_new(1u64 << 24u64)
    EL_P = el_field(EL_AR)

    /* CASE 1 -- UNDER-CONSTRAINED circuit (2 constraints, 3 witness vars), genuine field arithmetic:
     *   row0: 2*w0 + 3*w1        = pub0
     *   row1:        w1 + 5*w2   = pub1
     * rank 2 < 3 => free var w2 => forgeable.  RREF uses 15/2, 5/2 mod r (exercises modular inverse at 254 bit). */
    EL_NR = 2u64   EL_NC = 3u64
    el_put(0u64,0u64,2u64)  el_put(0u64,1u64,3u64)  el_put(0u64,2u64,0u64)
    el_put(1u64,0u64,0u64)  el_put(1u64,1u64,1u64)  el_put(1u64,2u64,5u64)
    let vuln : u64 = el_refute()
    if vuln != 1u64 { return 1u64 }                                  /* must detect + verify the forgery */

    /* CASE 2 -- SOUND circuit: add an independent constraint w0 = pub2 -> rank 3 = 3 vars -> unique -> silent */
    el_free()
    EL_NR = 3u64   EL_NC = 3u64
    el_put(0u64,0u64,2u64)  el_put(0u64,1u64,3u64)  el_put(0u64,2u64,0u64)
    el_put(1u64,0u64,0u64)  el_put(1u64,1u64,1u64)  el_put(1u64,2u64,5u64)
    el_put(2u64,0u64,1u64)  el_put(2u64,1u64,0u64)  el_put(2u64,2u64,0u64)
    let sound : u64 = el_refute()
    if sound != 0u64 { return 2u64 }                                 /* must stay silent (no forgery) */

    /* CASE 3 -- TEETH: the same sound matrix but drop the binding row again -> must flip back to forgeable */
    el_free()
    EL_NR = 2u64   EL_NC = 3u64
    el_put(0u64,0u64,2u64)  el_put(0u64,1u64,3u64)  el_put(0u64,2u64,0u64)
    el_put(1u64,0u64,0u64)  el_put(1u64,1u64,1u64)  el_put(1u64,2u64,5u64)
    if el_refute() != 1u64 { return 3u64 }

    /* CASE 4 -- END-TO-END from JSON (composes verba/json): the SAME circuit as a JSON constraint spec, parsed by
     * III's own RFC-8259 parser, built into the BN254 matrix, refuted, forgery verified.  The ingester is real. */
    let jl : u64 = el_load_json("{\"vars\":3,\"rows\":[[\"2\",\"3\",\"0\"],[\"0\",\"1\",\"5\"]]}" as u64)
    if el_ingest_json((&EL_JSONBUF) as u64, jl) != 1i64 { return 4u64 }
    /* and the JSON SOUND circuit (extra binding row) must stay silent through the same path */
    let jl2 : u64 = el_load_json("{\"vars\":3,\"rows\":[[\"2\",\"3\",\"0\"],[\"0\",\"1\",\"5\"],[\"1\",\"0\",\"0\"]]}" as u64)
    if el_ingest_json((&EL_JSONBUF) as u64, jl2) != 0i64 { return 5u64 }

    /* CASE 6 -- a REAL 254-bit field element from JSON: r-1 (= -1 mod r), constraint [-w0 + w1 = pub], 2 vars ->
     * rank 1 < 2 -> under-constrained.  Proves the ingester + arithmetic handle full-width BN254 coefficients. */
    let jl3 : u64 = el_load_json("{\"vars\":2,\"rows\":[[\"21888242871839275222246405745257275088548364400416034343698204186575808495616\",\"1\"]]}" as u64)
    if el_ingest_json((&EL_JSONBUF) as u64, jl3) != 1i64 { return 6u64 }
    return 0u64
}

fn el_show() -> i32 @export {
    EL_AR = arena_new(1u64 << 24u64)   EL_P = el_field(EL_AR)
    ps("ELENCHOS -- ZK under-constraint refutation over the REAL BN254 field, from a JSON circuit spec.\n" as u64)
    let jl : u64 = el_load_json("{\"vars\":3,\"rows\":[[\"2\",\"3\",\"0\"],[\"0\",\"1\",\"5\"]]}" as u64)
    ps("  ingest (verba/json), field elements as decimal strings (snarkjs form):\n    {\"vars\":3,\"rows\":[[\"2\",\"3\",\"0\"],[\"0\",\"1\",\"5\"]]}\n" as u64)
    let v : i64 = el_ingest_json((&EL_JSONBUF) as u64, jl)
    ps("  parsed -> BN254 matrix -> rank = " as u64)   pu(EL_RANK)   ps(" < 3 witness vars\n" as u64)
    if v == 1i64 { ps("  >>> UNDER-CONSTRAINED: forged witness verified (ORIG*w0 = 0 mod r) -- soundness refuted end-to-end.\n" as u64) }
    return 0i32
}

fn main(argc: i32, argv: u64) -> u64 {
    let _a : i32 = argc   let _v : u64 = argv
    el_show()
    let r : u64 = elenchos_selfprove()
    ps("elenchos_selfprove = " as u64)   pu(r)
    if r == 0u64 { ps("  GREEN: under-constraint detected + forgery verified over real BN254; sound circuit refused.\n" as u64) } else { ps("  (arm failed)\n" as u64) }
    return r
}
