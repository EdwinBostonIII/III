fn gn_arm295() -> u64 {
    /* THE VERDICT LOOP: the organism meters its own gcd engines on the
     * canonical workload; the dispatcher's default MUST be the measured
     * winner.  If the substrate drifts, this arm reddens and demands a
     * new verdict -- self-optimization as a standing proof obligation. */
    rz_reset()
    /* the workload: gcd((x^2-1)(x^2-2)q(x), (x^2-1)(x^2-3)q(x)) with a
     * common heavy factor q = 91x^2 + 121x + 169 -- content and degree
     * both in play; the true gcd is (x^2-1) q, derived independently by
     * BOTH engines and compared */
    rz_in(0u64, 0i64 - 1i64)   rz_in(1u64, 0i64)   rz_in(2u64, 1i64)
    let p1 : u64 = rz_from_in(2i64)
    rz_in(0u64, 0i64 - 2i64)   rz_in(1u64, 0i64)   rz_in(2u64, 1i64)
    let p2 : u64 = rz_from_in(2i64)
    rz_in(0u64, 0i64 - 3i64)   rz_in(1u64, 0i64)   rz_in(2u64, 1i64)
    let p3 : u64 = rz_from_in(2i64)
    rz_in(0u64, 169i64)   rz_in(1u64, 121i64)   rz_in(2u64, 91i64)
    let q : u64 = rz_from_in(2i64)
    let A : u64 = rz_mul(rz_mul(p1, p2), q)
    let B : u64 = rz_mul(rz_mul(p1, p3), q)
    let want : u64 = rz_mul(p1, q)
    /* meter engine 1: the subresultant PRS */
    py_opc_reset()
    let g1 : u64 = rz_gcd_sres(A, B)
    let ops_sres : u64 = py_opc()
    /* meter engine 2: the primitive PRS */
    py_opc_reset()
    let g2 : u64 = rz_gcd_prim(A, B)
    let ops_prim : u64 = py_opc()
