            if bigint_cmp(mp, mB) != 0i32 { return 299u64 }
            let prod : u64 = bigint_mul(gar, mB, dB)
            if bigint_cmp(prod, big) <= 0i32 { return 299u64 }
            let psb : u64 = bigint_shl_bits(gar, one, s)
            let hi2 : u64 = bigint_add(gar, big, psb)
            if bigint_cmp(prod, hi2) > 0i32 { return 299u64 }
            bigint_drop(one)   bigint_drop(big)   bigint_drop(dB)
            bigint_drop(r)   bigint_drop(mp)   bigint_drop(mB)
            bigint_drop(prod)   bigint_drop(psb)   bigint_drop(hi2)
            xs2[0u64] = 0u64
            xs2[1u64] = 1u64
            xs2[2u64] = d2 - 1u64
            xs2[3u64] = d2
            xs2[4u64] = d2 + 1u64
            xs2[5u64] = 0u64 - 1u64
            xs2[6u64] = 0u64 - d2
            let mut j : u64 = 0u64
            while j < 7u64 {
                let xv : u64 = xs2[j]
                if (gn_mulhi64(xv, m) >> s) != (xv / d2) { return 299u64 }
                j = j + 1u64
            }
            j = 0u64
            while j < 8u64 {
                let xr : u64 = gn_rnd()
                if (gn_mulhi64(xr, m) >> s) != (xr / d2) { return 299u64 }
                j = j + 1u64
            }
        }
        if (plan & 255u64) == 1u64 {
            let k : u64 = (plan >> 8u64) & 255u64
            let xr2 : u64 = gn_rnd()
            if (xr2 >> k) != (xr2 / d2) { return 299u64 }
        }
        i = i + 1u64
    }
    if magics < 2u64 { return 299u64 }
    /* the pow2 lane through the planner */
    let p32 : u64 = seg_div_plan(32u64)
    if (p32 & 255u64) != 1u64 { return 299u64 }
    if ((p32 >> 8u64) & 255u64) != 5u64 { return 299u64 }
    /* (c) the Montgomery kernel on the Goldilocks prime and a random odd */
    let g : u64 = 18446744069414584321u64
    if (g * (0u64 - kl_inv2_u64(g))) != (0u64 - 1u64) { return 299u64 }
    let r : u64 = gn_rnd() | 1u64
    if (r * (0u64 - kl_inv2_u64(r))) != (0u64 - 1u64) { return 299u64 }
    if kl_err() != 0u64 { return 299u64 }
    return 0u64
}
