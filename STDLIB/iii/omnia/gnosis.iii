var GN_SCROLL : u64 = 0u64
fn gn_addr() -> u64 @export { return GN_SCROLL }
fn gn_strlen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { i = i + 1u64 }
    return i
}
fn gn_v2(x: u64) -> u64 {
    /* 2-adic valuation of a nonzero word (caller guards zero) */
    let mut v : u64 = 0u64
    let mut m : u64 = x
    while (m & 1u64) == 0u64 { m = m >> 1u64   v = v + 1u64 }
    return v
}
fn gn_mulhi64(a: u64, b: u64) -> u64 {
    /* high 64 bits of a*b (32-bit half products; the GM-bound re-derivation) */
    let alo : u64 = a & 4294967295u64
    let ahi : u64 = a >> 32u64
    let blo : u64 = b & 4294967295u64
    let bhi : u64 = b >> 32u64
    let p0 : u64 = alo * blo
    let p1 : u64 = alo * bhi
    let p2 : u64 = ahi * blo
    let p3 : u64 = ahi * bhi
    let mid : u64 = (p0 >> 32u64) + (p1 & 4294967295u64) + (p2 & 4294967295u64)
    return p3 + (p1 >> 32u64) + (p2 >> 32u64) + (mid >> 32u64)
}
fn gn_rat_u64(x: u64) -> u64 {
    /* a full u64 as an exact pyrgos rational (two 32-bit halves) */
    let hi : u64 = x >> 32u64
    let lo : u64 = x & 4294967295u64
    return py_rat_add(py_rat_mul(py_rat_i64(hi as i64), py_rat_i64(4294967296i64)), py_rat_i64(lo as i64))
}
/* load a u64 into the klisi KP=2 mode(0,64) ring: digits ARE bits */
fn gn_kd_of(x: u64) -> u64 {
    let h : u64 = kd_alloc()
    let mut i : u64 = 0u64
    while i < 64u64 {
        if ((x >> i) & 1u64) == 1u64 { kd_seti(h, i, 1u64) }
        i = i + 1u64
    }
    return h
}
fn gn_kd_val(h: u64) -> u64 {
    let mut x : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 64u64 {
        if kd_get(h, i) == 1u64 { x = x | (1u64 << i) }
        i = i + 1u64
    }
    return x
}
var GN_SEED : u64 = 2463534242u64
fn gn_rnd() -> u64 {
    /* xorshift64 -- the reversible organ's own proven-bijective family */
    let mut x : u64 = GN_SEED
    x = x ^ (x << 13u64)
    x = x ^ (x >> 7u64)
    x = x ^ (x << 17u64)
    GN_SEED = x
    return x
}
fn gn_arm290() -> u64 {
    /* THE SUBSTRATE IDENTITY: the native ALU IS the KP=2 digit ring.
     * add and mul cross-oracled on random words; the wrap witnessed. */
    kd_setp(2u64)
    kd_mode(0u64, 64u64)
    let mut t : u64 = 0u64
    while t < 8u64 {
        let a : u64 = gn_rnd()
        let b : u64 = gn_rnd()
        kd_mode(0u64, 64u64)
        let ka : u64 = gn_kd_of(a)
        let kb : u64 = gn_kd_of(b)
        /* two engines, one sum; two engines, one product */
        if gn_kd_val(kd_add(ka, kb)) != (a + b) { return 290u64 }
        if gn_kd_val(kd_mul(ka, kb)) != (a * b) { return 290u64 }
        t = t + 1u64
    }
    /* the truncation ideal: 0xFFFF...F + 1 = 0 on BOTH engines */
    kd_mode(0u64, 64u64)
    let full : u64 = gn_kd_of(18446744073709551615u64)
    let one : u64 = gn_kd_of(1u64)
    let s : u64 = kd_add(full, one)
    if gn_kd_val(s) != 0u64 { return 290u64 }
    if (18446744073709551615u64 + 1u64) != 0u64 { return 290u64 }
    if kl_err() != 0u64 { return 290u64 }
    return 0u64
}
fn gn_arm291() -> u64 {
    /* THE ORBIT ORACLE, counter loops: `while x != 0 { x += c }` on w-bit
     * words halts iff v_2(c) <= v_2(x0).  COMPLETE enumeration of Z/2^8:
     * all 65536 (c, x0) pairs, each orbit bounded by the group order 256;
     * the decision rule must agree on EVERY pair.  Then the theorem
     * carries to Z/2^64. */
    let mut c : u64 = 0u64
    while c < 256u64 {
        let mut x0 : u64 = 0u64
        while x0 < 256u64 {
            /* run the orbit exactly (bounded by 256 = the group order) */
            let mut x : u64 = x0
            let mut halted : u64 = 0u64
            let mut steps : u64 = 0u64
            while steps < 256u64 {
                if x == 0u64 { halted = 1u64   steps = 256u64 } else {
                    x = (x + c) & 255u64
                    steps = steps + 1u64
                }
            }
            if x == 0u64 { halted = 1u64 }
            /* the valuation decision */
            let mut dec : u64 = 0u64
            if x0 == 0u64 { dec = 1u64 } else {
                if c == 0u64 { dec = 0u64 } else {
                    /* v2 within the 8-bit ring: c = 0 handled; compare
                     * v2(c) <= v2(x0) with valuations capped at 8 */
                    let vc : u64 = gn_v2(c)
                    let vx : u64 = gn_v2(x0)
                    if vc <= vx { dec = 1u64 }
                }
            }
            if dec != halted { return 291u64 }
            x0 = x0 + 1u64
        }
        c = c + 1u64
    }
    /* Z/2^64, where simulation cannot reach: the decided instances.
     * HALTS: x0 = 2^64 - 3c (three exact steps witness the decision) */
    let c1 : u64 = 6148914691236517205u64          /* odd: v2 = 0 -> halts from ANY x0 */
    let x1 : u64 = 0u64 - (3u64 * c1)
    let mut y : u64 = x1
    let mut n : u64 = 0u64
    while y != 0u64 { y = y + c1   n = n + 1u64 }
    if n != 3u64 { return 291u64 }
    if gn_v2(c1) != 0u64 { return 291u64 }
    /* DIVERGES: v2(c) = 4 > v2(x0) = 0 -- the subgroup obstruction is the
     * PROOF (x0 not divisible by gcd(c, 2^64) = 16); a bounded probe
     * agrees (1000 steps never reach 0) */
    let c2 : u64 = 48u64                           /* v2 = 4 */
    let x2 : u64 = 7u64                            /* v2 = 0 */
    if gn_v2(c2) != 4u64 { return 291u64 }
    if (x2 % 16u64) == 0u64 { return 291u64 }
    let mut z : u64 = x2
    let mut k : u64 = 0u64
    while k < 1000u64 {
        z = z + c2
        if z == 0u64 { return 291u64 }
        k = k + 1u64
    }
    /* and the residue INVARIANT that proves it forever: x mod 16 is
     * constant along the orbit and never 0 */
    if (z % 16u64) != (x2 % 16u64) { return 291u64 }
    return 0u64
}
fn gn_arm292() -> u64 {
    /* THE ORBIT ORACLE, valuation growth and bijective nontermination */
    /* x <<= 1 halts in <= 64 steps: the loop bound IS 2-adic (each step
     * raises v_2 by exactly 1; the ring truncates at 64) */
    let mut x : u64 = 12297829382473034411u64      /* odd start: worst case */
    let mut n : u64 = 0u64
    while x != 0u64 { x = x << 1u64   n = n + 1u64 }
    if n != 64u64 { return 292u64 }
    /* xorshift8 (13,7,17 shrunk to 3,5,2 on 8 bits): PERMUTATION saturated
     * -- 256 slots, every image hit once -- so 0 has the unique preimage 0
     * and no nonzero orbit ever reaches 0: NONTERMINATION PROVEN.
     * (the tally lives in the module BFS scratch: local arrays of this
     * size would breach the 64-slot frame law) */
    let mut i : u64 = 0u64
    while i < 256u64 { GN_VIS[i] = 0u64   i = i + 1u64 }
    i = 0u64
    while i < 256u64 {
        let mut v : u64 = i
        v = (v ^ (v << 3u64)) & 255u64
        v = v ^ (v >> 5u64)
        v = (v ^ (v << 2u64)) & 255u64
        GN_VIS[v] = GN_VIS[v] + 1u64
        i = i + 1u64
    }
    i = 0u64
    while i < 256u64 {
        let sv : u64 = GN_VIS[i]
        if sv != 1u64 { return 292u64 }
        i = i + 1u64
    }
    /* 0 maps to 0; one full nonzero orbit closed without touching 0 */
    let mut w : u64 = 1u64
    let mut steps : u64 = 0u64
    let mut back : u64 = 0u64
    while steps < 300u64 {
        w = (w ^ (w << 3u64)) & 255u64
        w = w ^ (w >> 5u64)
        w = (w ^ (w << 2u64)) & 255u64
        if w == 0u64 { return 292u64 }
        steps = steps + 1u64
        if w == 1u64 { back = steps   steps = 300u64 }
    }
    if back == 0u64 { return 292u64 }
    return 0u64
}
/* Peterson state: flag0 | flag1<<1 | turn<<2 | pc0<<3 | pc1<<6 (pc 0..3);
 * decompose-mutate-repack -- no mask constants, no precedence traps */
var GN_VIS : [u64; 512]
var GN_Q : [u64; 512]
fn gn_pack(f0: u64, f1: u64, tn: u64, p0: u64, p1: u64) -> u64 {
    return f0 | (f1 << 1u64) | (tn << 2u64) | (p0 << 3u64) | (p1 << 6u64)
}
fn gn_pet_step(st: u64, who: u64) -> u64 {
    /* one state-CHANGING step of thread `who`; returns st itself if the
     * thread cannot move (busy-wait with false condition) */
    let mut f0 : u64 = st & 1u64
    let mut f1 : u64 = (st >> 1u64) & 1u64
    let mut tn : u64 = (st >> 2u64) & 1u64
    let mut p0 : u64 = (st >> 3u64) & 7u64
    let mut p1 : u64 = (st >> 6u64) & 7u64
    if who == 0u64 {
        if p0 == 0u64 { f0 = 1u64   p0 = 1u64   return gn_pack(f0, f1, tn, p0, p1) }
        if p0 == 1u64 { tn = 1u64   p0 = 2u64   return gn_pack(f0, f1, tn, p0, p1) }
        if p0 == 2u64 {
            if f1 == 0u64 { p0 = 3u64   return gn_pack(f0, f1, tn, p0, p1) }
            if tn == 0u64 { p0 = 3u64   return gn_pack(f0, f1, tn, p0, p1) }
            return st
        }
        f0 = 0u64
        p0 = 0u64
        return gn_pack(f0, f1, tn, p0, p1)
    }
    if p1 == 0u64 { f1 = 1u64   p1 = 1u64   return gn_pack(f0, f1, tn, p0, p1) }
    if p1 == 1u64 { tn = 0u64   p1 = 2u64   return gn_pack(f0, f1, tn, p0, p1) }
    if p1 == 2u64 {
        if f0 == 0u64 { p1 = 3u64   return gn_pack(f0, f1, tn, p0, p1) }
        if tn == 1u64 { p1 = 3u64   return gn_pack(f0, f1, tn, p0, p1) }
        return st
    }
    f1 = 0u64
    p1 = 0u64
    return gn_pack(f0, f1, tn, p0, p1)
}
fn gn_arm293() -> u64 {
    /* THE INTERLEAVING ORBIT, Peterson: saturate the FULL reachable state
     * space; mutual exclusion in EVERY state; no reachable state stuck.
     * Then the negative control: check-then-set reaches both-in-CS. */
    let mut i : u64 = 0u64
    while i < 512u64 { GN_VIS[i] = 0u64   i = i + 1u64 }
    let mut qh : u64 = 0u64
    let mut qt : u64 = 0u64
    GN_Q[0u64] = 0u64
    GN_VIS[0u64] = 1u64
    qt = 1u64
    let mut reach : u64 = 0u64
    while qh < qt {
        let st : u64 = GN_Q[qh]
        qh = qh + 1u64
        reach = reach + 1u64
        let p0 : u64 = (st >> 3u64) & 7u64
        let p1 : u64 = (st >> 6u64) & 7u64
        /* MUTUAL EXCLUSION: never both in the critical section */
        if p0 == 3u64 { if p1 == 3u64 { return 293u64 } }
        /* successors; count the state-CHANGING moves */
        let mut moved : u64 = 0u64
        let mut who : u64 = 0u64
        while who < 2u64 {
            let ns : u64 = gn_pet_step(st, who)
            if ns != st {
                moved = moved + 1u64
                if GN_VIS[ns] == 0u64 {
                    GN_VIS[ns] = 1u64
                    GN_Q[qt] = ns
