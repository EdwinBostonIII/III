     * primitive normalization both promise): compare coefficientwise
     * against pp(want) computed by... both must EQUAL each other, and
     * divide the truth exactly at degree 4 */
    let mut k : i64 = 0i64
    while k <= 4i64 {
        if py_rat_cmp(rz_c(g1, k), rz_c(g2, k)) != 0i64 { return 295u64 }
        k = k + 1i64
    }
    if rz_count(g1, 0i64, 1i64, 2i64, 1i64) != rz_count(want, 0i64, 1i64, 2i64, 1i64) { return 295u64 }
