     * dispatcher must BE it -- deterministic meter, so their costs are
     * IDENTICAL.  If the substrate ever drifts and sres wins, this arm
     * reddens and demands the dispatcher be re-crowned. */
    if ops_prim > ops_sres { return 295u64 }
    if ops_disp != ops_prim { return 295u64 }
