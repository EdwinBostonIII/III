/* STDLIB/iii/omnia/hermeneus.iii -- HERMENEUS: THE ONE ENGLISH DOOR.
 *
 * English becomes exact EIDOLOS claims, human-confirmed, and delivered across nodes -- under one
 * law: THE STATISTICAL PART MAY PROPOSE; ONLY THE EXACT LAW PLUS A HUMAN DECIDES.
 *
 * This is the MERGE (one door, three organs as its layers -- no reinvention):
 *   - anglos  = THE SENSORY ORGAN.  A deterministic, fully-proven English->EIDOLOS transducer
 *     (an_transduce: determiners, adjective predication, kind-vs-identity, "and"-composition,
 *     named refusal of modals/conditionals/or/imperatives).  Its an_say is the round-tripping
 *     English read-back.  HERMENEUS composes it -- it does NOT re-hand-roll a grammar.
 *   - xenos   = THE STRUCTURAL FILTER.  Both muses emit a JSON claim-array; xn_admit judges it by
 *     the house's own re-derivation (cycle/lying refused, by name) and stands the claims.
 *   - HERMENEUS = THE IMMUNE SYSTEM.  The quarantine no auto-admitting door has: the read-back a
 *     human confirms, the confirm-pin WALL (no unconfirmed proposal reaches the core), and the
 *     content-addressed DIADOSIS delivery that distributes the reduced minimal basis exactly.
 *
 * TWO MUSES, ONE CHOKEPOINT:
 *   in-house : English -> an_transduce -> JSON claim-array -\
 *   external : any LLM's JSON proposal ---------------------> xn_admit -> vet -> an_say (read-back)
 *                                                             -> human confirm-wall -> DIADOSIS
 *
 * A muse is never proven honest; the QUARANTINE that makes a dishonest muse harmless is, every
 * invocation.  anglos already proves its own grammar (an_selfprove 390..399); hermeneus_selfprove
 * proves ONLY the seam and the wall: the transduced claim-array admits; the an_say read-back is the
 * exact confirm key; an unconfirmed standing claim yields the WALL; the confirmed path reduces to
 * the same address the hand claims do and delivers faithfully.
 *
 * Ring R0.  Composes aether/anglos (+ verba/nl_lex + verba/nl_parse), aether/xenos, omnia/eidolos,
 * omnia/diadosis, verba/lexicon, numera/idfold.  NIH: no new inference, no island.  ASCII only. */
module omnia_hermeneus

extern @abi(c-msvc-x64) fn eol_reset() -> i32 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_read(addr: u64, len: u64) -> i64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_addr() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_write() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_out_len() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_out_byte(i: u64) -> u8 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_rcap() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn lx_check(addr: u64, len: u64) -> u64 from "lexicon.iii"
extern @abi(c-msvc-x64) fn dd_reduce_addr(claims: u64) -> u64 from "diadosis.iii"
extern @abi(c-msvc-x64) fn dd_publish(addr: u64) -> u64 from "diadosis.iii"
extern @abi(c-msvc-x64) fn dd_resolve(h: u64, out: u64) -> u64 from "diadosis.iii"
extern @abi(c-msvc-x64) fn dd_ripple(handle: u64, count: u64) -> u64 from "diadosis.iii"
extern @abi(c-msvc-x64) fn dd_consumer_entails(reduced: u64, q: u64) -> u64 from "diadosis.iii"
extern @abi(c-msvc-x64) fn idfold_basis() -> u64 from "idfold.iii"
extern @abi(c-msvc-x64) fn idfold_u64(h: u64, v: u64) -> u64 from "idfold.iii"
extern @abi(c-msvc-x64) fn idfold_seal(h: u64) -> u64 from "idfold.iii"
extern @abi(c-msvc-x64) fn xn_admit(base: u64, len: u64) -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_canon_len() -> u64 from "xenos.iii"
extern @abi(c-msvc-x64) fn xn_canon_byte(i: u64) -> u8 from "xenos.iii"
/* the SENSORY ORGAN: anglos's deterministic English transducer + its round-tripping say-back */
extern @abi(c-msvc-x64) fn an_transduce(base: u64, len: u64) -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_claims() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_reason() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_scroll_len() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_scroll_byte(i: u64) -> u8 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_say() -> u64 from "anglos.iii"
extern @abi(c-msvc-x64) fn an_say_byte(i: u64) -> u8 from "anglos.iii"

const AN_V_CARRIED : u64 = 4u64            /* an_transduce: transduced to the threshold */
const HM_WALL : u64 = 18446744073709551615u64   /* delivery denied sentinel */

/* refusal reasons (0 = clean) */
const HM_R_NONE : u64 = 0u64
const HM_R_REFUSED : u64 = 1u64            /* the sensory organ / external door refused */
const HM_R_CAP : u64 = 2u64                /* over an envelope */
const HM_R_LAW : u64 = 3u64                /* incoherent: cycle / self-under */
const HM_R_ALIEN : u64 = 4u64              /* alien vocabulary (a flag, not a wall) */
const HM_R_MUTE : u64 = 6u64               /* admitted but unsayable -> cannot be read back */

/* ==================== state ==================== */
var HM_CAND : [u8; 16384]                  /* the admitted claim text (for vet + delivery) */
var HM_CN : u64 = 0u64
var HM_RREFUSED : u64 = 0u64               /* utterances refused (by the sensory organ / door) */
var HM_LAST_REASON : u64 = 0u64            /* the last refusal's named reason (an_reason canon) */
var HM_TMP : [u8; 4096]                    /* read-back scratch */
var HM_CANON : [u8; 16384]                 /* the vetted canonical scroll */
var HM_CNN : u64 = 0u64
var HM_LAST_ADDR : u64 = 0u64              /* the standing scroll's (pre-reduction) address */
var HM_LAST_ALIEN : u64 = 0u64             /* alien words flagged (liberation law: warn, not wall) */
var HM_ENG : [u8; 4096]                    /* the read-back the human confirms (an_say output) */
var HM_ENGN : u64 = 0u64
var HM_CLAIMS : [u8; 16384]                /* the standing proposal's raw claims (for delivery) */
var HM_CLN : u64 = 0u64
var HM_ADDR : u64 = 0u64                   /* the standing proposal's REDUCED address */
var HM_CONFIRMED : u64 = 0u64              /* 1 iff a matching human confirm has crossed */
var HM_PIN : u64 = 0u64                    /* the confirm's content-address cad(readback||addr) */
var HM_RWALL : u64 = 0u64                  /* delivery denied (unconfirmed / mismatched) */
var HM_RECV : [u8; 16384]                  /* resolved reduced-scroll bytes + say scratch */
var HM_JBUF : [u8; 8192]                   /* the muse's JSON claim-array (in-house or external) */

/* ==================== small tools (defined before use; no forward refs) ==================== */
fn hm_slen(s: u64) -> u64 { let p : *u8 = s as *u8   let mut i : u64 = 0u64   while p[i] != 0u8 { i = i + 1u64 }   return i }
fn hm_cput(c: u8) -> u64 { if HM_CN >= 16384u64 { return 1u64 }   HM_CAND[HM_CN] = c   HM_CN = HM_CN + 1u64   return 0u64 }
/* the exact canonical address of a scroll's bytes (0 = incoherent / cycle) */
fn hm_addr_of(base: u64, len: u64) -> u64 {
    eol_reset()
    if eol_read(base, len) < 0i64 { return 0u64 }
    return eol_addr()
}

/* ==================== vetting (the exact law before the human looks) ==================== */
/* vet HM_CAND: a coherent scroll (no cycle) + the XENOS re-derivation + vocabulary audit.
 * 0 = clean (alien is FLAGGED in HM_LAST_ALIEN, never a wall -- the liberation law); else a
 * named reason (HM_R_LAW cycle | HM_R_CAP over-cap). */
fn hm_vet() -> u64 {
    let rcap0 : u64 = eol_rcap()
    eol_reset()
    if eol_read((&HM_CAND) as u64, HM_CN) < 0i64 {
        eol_reset()
        if eol_rcap() > rcap0 { return HM_R_CAP }
        return HM_R_LAW
    }
    let a : u64 = eol_addr()
    if a == 0u64 { eol_reset()   return HM_R_LAW }
    eol_write()
    HM_CNN = eol_out_len()
    if HM_CNN == 0u64 { eol_reset()   return HM_R_LAW }
    let mut i : u64 = 0u64
    while i < HM_CNN { HM_CANON[i] = eol_out_byte(i)   i = i + 1u64 }
    /* THE RE-DERIVATION: the canonical text, read from scratch, derives the same address */
    eol_reset()
    if eol_read((&HM_CANON) as u64, HM_CNN) < 0i64 { eol_reset()   return HM_R_LAW }
    if eol_addr() != a { eol_reset()   return HM_R_LAW }
    HM_LAST_ADDR = a
    HM_LAST_ALIEN = lx_check((&HM_CANON) as u64, HM_CNN)
    if HM_LAST_ALIEN == HM_WALL { HM_LAST_ALIEN = 0u64 }
    eol_reset()
    if eol_read((&HM_CANON) as u64, HM_CNN) < 0i64 { eol_reset()   return HM_R_LAW }
    return HM_R_NONE
}
/* stand a proposal already carrying its read-back English: vet HM_CAND, record read-back + raw
 * claims + REDUCED address, CONFIRMED := 0.  Returns the reduced address (a huge idfold, never
 * 1..6) on success, or the vet reason on refusal. */
fn hm_stand(readback: u64, rlen: u64) -> u64 {
    let v : u64 = hm_vet()
    if v != 0u64 { return v }
    let ep : *u8 = readback as *u8
    let mut i : u64 = 0u64
    while i < rlen { if i < 4096u64 { HM_ENG[i] = ep[i] }   i = i + 1u64 }
    HM_ENGN = rlen
    i = 0u64
    while i < HM_CN { HM_CLAIMS[i] = HM_CAND[i]   i = i + 1u64 }
    HM_CLN = HM_CN
    HM_CLAIMS[HM_CLN] = 0u8
    HM_ADDR = dd_reduce_addr((&HM_CLAIMS) as u64)
    HM_CONFIRMED = 0u64
    return HM_ADDR
}

/* ==================== the confirm-gate (the quarantine) ==================== */
/* the confirm's content-address: cad(read-back bytes || the 8 bytes of the reduced address) */
fn hm_pin_of(readback: u64, len: u64, addr: u64) -> u64 {
    let p : *u8 = readback as *u8
    let mut h : u64 = idfold_basis()
    let mut i : u64 = 0u64
    while i < len { h = idfold_u64(h, p[i] as u64)   i = i + 1u64 }
    let mut a : u64 = addr
    let mut k : u64 = 0u64
    while k < 8u64 { h = idfold_u64(h, a & 255u64)   a = a >> 8u64   k = k + 1u64 }
    let v : u64 = idfold_seal(h)
    if v == 0u64 { return 1u64 }
    return v
}
/* record a human confirm: matches the STANDING proposal's read-back English AND reduced address.
 * On match CONFIRMED := 1 and HM_PIN := the content-address; returns the pin.  0 = no match. */
fn hm_confirm(readback: u64, len: u64, addr: u64) -> u64 @export {
    if len != HM_ENGN { return 0u64 }
    if addr != HM_ADDR { return 0u64 }
    let p : *u8 = readback as *u8
    let mut i : u64 = 0u64
    let mut same : u64 = 1u64
    while i < len { if p[i] != HM_ENG[i] { same = 0u64   i = len } else { i = i + 1u64 } }
    if same == 0u64 { return 0u64 }
    HM_PIN = hm_pin_of(readback, len, addr)
    HM_CONFIRMED = 1u64
    return HM_PIN
}
/* the human says "yes, that reading is right": confirm the standing proposal's OWN read-back. */
fn hm_confirm_readback() -> u64 @export { return hm_confirm((&HM_ENG) as u64, HM_ENGN, HM_ADDR) }
/* deliver the confirmed proposal into DIADOSIS.  DENIED (HM_WALL) if unconfirmed/mismatched --
 * no path from an unconfirmed proposal to the exact core. */
fn hm_deliver() -> u64 @export {
    if HM_CONFIRMED == 0u64 { HM_RWALL = HM_RWALL + 1u64   return HM_WALL }
    let a : u64 = dd_reduce_addr((&HM_CLAIMS) as u64)
    let h : u64 = dd_publish(a)
    let _r : u64 = dd_ripple(h, 1u64)
    return h
}

/* ==================== the one admission chokepoint (both muses) ==================== */
/* admit a JSON claim-array (from EITHER muse) through XENOS, render III's read-back via an_say
 * (self-inits nl_lex), and STAND it PROVISIONAL.  Returns hm_stand's result or a refusal reason. */
fn hm_admit_ext(json: u64, len: u64) -> u64 @export {
    let v : u64 = xn_admit(json, len)
    if v != 1u64 { return HM_R_LAW }                 /* the structural filter refused it, by name */
    /* the admitted scroll is STANDING; render the read-back BEFORE any eol_reset */
    let sl : u64 = an_say()
    if sl == 0u64 { return HM_R_MUTE }               /* admitted but unsayable -> cannot quarantine */
    let mut i : u64 = 0u64
    while i < sl { if i < 4096u64 { HM_TMP[i] = an_say_byte(i) }   i = i + 1u64 }
    HM_TMP[sl] = 0u8
    /* copy the admitted canonical claims (xenos buffer -- eidolos untouched) */
    let cn : u64 = xn_canon_len()
    if cn == 0u64 { return HM_R_LAW }
    HM_CN = 0u64
    let mut j : u64 = 0u64
    while j < cn { if hm_cput(xn_canon_byte(j)) != 0u64 { return HM_R_CAP }   j = j + 1u64 }
    return hm_stand((&HM_TMP) as u64, sl)
}
/* THE IN-HOUSE MUSE: English -> anglos -> JSON claim-array -> the same chokepoint.
 * Returns the reduced address (huge) on success; 0 on refusal (HM_RREFUSED++, reason recorded). */
fn hm_hear(english: u64, len: u64) -> u64 @export {
    let t : u64 = an_transduce(english, len)
    if t != AN_V_CARRIED { HM_RREFUSED = HM_RREFUSED + 1u64   HM_LAST_REASON = an_reason()   return 0u64 }
    if an_claims() == 0u64 { HM_RREFUSED = HM_RREFUSED + 1u64   HM_LAST_REASON = an_reason()   return 0u64 }
    let sn : u64 = an_scroll_len()
    if sn == 0u64 { HM_RREFUSED = HM_RREFUSED + 1u64   return 0u64 }
    if sn >= 8192u64 { HM_RREFUSED = HM_RREFUSED + 1u64   return 0u64 }
    let mut i : u64 = 0u64
    while i < sn { HM_JBUF[i] = an_scroll_byte(i)   i = i + 1u64 }
    let r : u64 = hm_admit_ext((&HM_JBUF) as u64, sn)
    if r <= 6u64 { HM_RREFUSED = HM_RREFUSED + 1u64   HM_LAST_REASON = r }
    return r
}

/* ==================== accessors ==================== */
fn hm_last_addr() -> u64 @export { return HM_LAST_ADDR }
fn hm_last_alien() -> u64 @export { return HM_LAST_ALIEN }
fn hm_confirmed() -> u64 @export { return HM_CONFIRMED }
fn hm_addr() -> u64 @export { return HM_ADDR }
fn hm_pin() -> u64 @export { return HM_PIN }
fn hm_rwall() -> u64 @export { return HM_RWALL }
fn hm_refused() -> u64 @export { return HM_RREFUSED }
fn hm_reason() -> u64 @export { return HM_LAST_REASON }
fn hm_eng_len() -> u64 @export { return HM_ENGN }
fn hm_eng_byte(i: u64) -> u8 @export { if i < HM_ENGN { return HM_ENG[i] }   return 0u8 }
fn hm_cand_len() -> u64 @export { return HM_CN }
fn hm_cand_byte(i: u64) -> u8 @export { if i < HM_CN { return HM_CAND[i] }   return 0u8 }

/* build test JSON claim-arrays for the external-door arms (byte-built: no escapes) */
fn hm_wrap_unsigned(claim: u64, len: u64, out: u64) -> u64 {
    let o : *u8 = out as *u8
    let c : *u8 = claim as *u8
    let mut w : u64 = 0u64
    o[w] = 91u8   w = w + 1u64   o[w] = 34u8   w = w + 1u64
    let mut i : u64 = 0u64
    while i < len { o[w] = c[i]   w = w + 1u64   i = i + 1u64 }
    o[w] = 34u8   w = w + 1u64   o[w] = 93u8   w = w + 1u64   o[w] = 0u8
    return w
}
fn hm_wrap_two(c1: u64, l1: u64, c2: u64, l2: u64, out: u64) -> u64 {
    let o : *u8 = out as *u8
    let mut w : u64 = 0u64
    o[w] = 91u8   w = w + 1u64   o[w] = 34u8   w = w + 1u64
    let p1 : *u8 = c1 as *u8
    let mut i : u64 = 0u64
    while i < l1 { o[w] = p1[i]   w = w + 1u64   i = i + 1u64 }
    o[w] = 34u8   w = w + 1u64   o[w] = 44u8   w = w + 1u64   o[w] = 34u8   w = w + 1u64
    let p2 : *u8 = c2 as *u8
    i = 0u64
    while i < l2 { o[w] = p2[i]   w = w + 1u64   i = i + 1u64 }
    o[w] = 34u8   w = w + 1u64   o[w] = 93u8   w = w + 1u64   o[w] = 0u8
    return w
}

/* ==================== the self-proof: ONLY the seam and the wall ==================== */
fn hermeneus_selfprove() -> u64 @export {
    /* arm 1: THE SEAM (in) -- English through the sensory organ admits through the structural
     * filter and STANDS provisional, carrying exactly the claim anglos's surface law dictates */
    let e1 : u64 = "the dream is a proof" as u64
    if hm_hear(e1, hm_slen(e1)) <= 6u64 { return 1u64 }
    if hm_confirmed() != 0u64 { return 1u64 }
    let h1 : u64 = "[dream < proof]" as u64
    if hm_last_addr() != hm_addr_of(h1, hm_slen(h1)) { return 1u64 }

    /* arm 2: READ-BACK IS THE KEY -- an_say's output is the EXACT string that passes the pin
     * (re-rendered fresh from the standing scroll, not echoed) */
    let sl : u64 = an_say()
    let mut i : u64 = 0u64
    while i < sl { HM_RECV[i] = an_say_byte(i)   i = i + 1u64 }
    if hm_confirm((&HM_RECV) as u64, sl, hm_addr()) == 0u64 { return 2u64 }
    if hm_confirmed() != 1u64 { return 2u64 }

    /* arm 3: THE WALL -- a freshly stood (unconfirmed) proposal yields HM_WALL on delivery */
    if hm_hear(e1, hm_slen(e1)) <= 6u64 { return 3u64 }
    if hm_deliver() != HM_WALL { return 3u64 }
    if hm_confirmed() != 0u64 { return 3u64 }

    /* arm 4: RELEASE + SEAM-EXACTNESS -- a confirmed "and"-composed utterance delivers a handle,
     * and reduces to the SAME address as the hand claims fed straight to DIADOSIS */
    let de : u64 = "the dream is a proof and the proof equals the law" as u64
    if hm_hear(de, hm_slen(de)) <= 6u64 { return 4u64 }
    if hm_confirm_readback() == 0u64 { return 4u64 }
    let h : u64 = hm_deliver()
    if h >= 256u64 { return 4u64 }
    let dh : u64 = "[dream < proof] [proof = law]" as u64
    if hm_addr() != dd_reduce_addr(dh) { return 4u64 }

    /* arm 5: CLOSURE at the consumer -- resolve the handle; a component claim is entailed, and a
     * claim OUTSIDE the closure is not delivered-as-known */
    let rl : u64 = dd_resolve(h, (&HM_RECV) as u64)
    if rl == 0u64 { return 5u64 }
    if dd_consumer_entails((&HM_RECV) as u64, "[dream < proof]" as u64) != 1u64 { return 5u64 }
    if dd_consumer_entails((&HM_RECV) as u64, "[law < dream]" as u64) == 1u64 { return 5u64 }

    /* arm 6: THE EXTERNAL MUSE -- an LLM's JSON proposal rides the SAME chokepoint: a truthful
     * claim-array stands PROVISIONAL; a cyclic one is refused at the filter, never stood */
    let jn : u64 = hm_wrap_unsigned("[dream < proof]" as u64, hm_slen("[dream < proof]" as u64), (&HM_JBUF) as u64)
    if hm_admit_ext((&HM_JBUF) as u64, jn) <= 6u64 { return 6u64 }
    if hm_confirmed() != 0u64 { return 6u64 }
    let jn2 : u64 = hm_wrap_two("[a < b]" as u64, hm_slen("[a < b]" as u64), "[b < a]" as u64, hm_slen("[b < a]" as u64), (&HM_JBUF) as u64)
    if hm_admit_ext((&HM_JBUF) as u64, jn2) > 6u64 { return 6u64 }

    /* arm 7: THE PIN -- distinct proposals earn distinct confirm-pins (a confirm cannot be replayed) */
    if hm_hear(e1, hm_slen(e1)) <= 6u64 { return 7u64 }
    let p1 : u64 = hm_confirm_readback()
    let ev : u64 = "the proof is valid" as u64
    if hm_hear(ev, hm_slen(ev)) <= 6u64 { return 7u64 }
    let p2 : u64 = hm_confirm_readback()
    if p1 == 0u64 { return 7u64 }
    if p2 == 0u64 { return 7u64 }
    if p1 == p2 { return 7u64 }

    return 0u64
}
/* This is a pure LIBRARY organ: no main, no I/O.  The standing tool is
 * omnia/hermeneus_cli.iii (iii hermeneus prove | translate | the live REPL). */
