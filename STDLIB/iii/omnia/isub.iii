/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\isub.iii
 *
 * III STDLIB - omnia::isub  --  THE IMMUTABLE METAL BUS: the Ring-(-1) cryptographic bedrock of the
 * inverse substrate.  An append-only log of UNIFORM GEOMETRIC BLOCKS whose verbs are CONTENT-ADDRESSED:
 * a block's identity IS the sha256 of its geometric footprint -- computed and committed AT EMIT TIME,
 * never a name and never derived-on-the-side.
 *
 * THE UNIFORM BLOCK (the only matter the bus stores, every block identical in shape):
 *     < verb , a , b >        verb in { V_BELOW , V_REFLECT }     a,b = bare point ADDRESSES
 *   V_BELOW(a,b)   = "a sits under b"   (the order -- the shape of every logic; from omnia::logos)
 *   V_REFLECT(a,b) = "a mirrors to b"   (the order-reversing involution)
 * There is NO name/string field anywhere in the log.  The VERB is the operator slot -- the place a
 * "named primitive" (l6_and, ...) would live -- and it admits exactly {0,1}.  A name packed into the verb
 * slot is a large integer and is STRUCTURALLY REJECTED by isub_emit (the name-gate); operands are bare
 * addresses, bounded to a sane range.  "No named primitives", enforced at the metal, not by convention.
 *
 * CONTENT-ADDRESSED VERBS (CAV) -- CONSTITUTIVE, not decorative:
 *   - On every emit, the bus computes  CAV_i = sha256( footprint_i )  where footprint = [verb||a(LE32)||
 *     b(LE32)], and STORES it as the block's identity (isub_event_cav_into reads the stored bytes -- it
 *     does not recompute).  The identity of a verb IS that hash.
 *   - The witness is the HASH-CHAIN of those identities:  ROOT_0 = sha256( 0^32 || CAV_0 ),
 *     ROOT_i = sha256( ROOT_{i-1} || CAV_i ).  O(1)/event (two fixed-size sha256), O(32) memo (the frozen
 *     root).  The witness is a function OF the content-addresses -- delete the CAV and the root cannot be
 *     formed.  A transparency-log / Merkle chain over geometric content-addresses.
 * Identical geometry -> identical CAV (the recognise-and-merge basis); any geometry change -> different
 * CAV -> different ROOT.  Demonstrably != sha256(a label).
 *
 * THE WITNESS ENGINE is the already-sealed omnia::exec_cert streaming sha256 (xc_begin/xc_event_byte/
 * xc_seal) -- "the streaming cad SHA-256 witness, wired directly to the metal bus".  Authors NO new crypto.
 *
 * DISTINCT FROM omnia::event_substrate (no island): event_substrate keys events by a NAMED kind
 * (EVT_K_MOVE / EVT_K_OBSERVE -- a named enum) and stores raw fields.  isub forbids names and makes the
 * sha256 content-address the constitutive identity + witness.  isub is the CAV bedrock.
 *
 * Ring R(-1) (the metal bus).  K 1.00.  NIH: libc-free; consumes only the sealed exec_cert sha256.
 */
module omnia_isub

extern @abi(c-msvc-x64) fn xc_begin() -> i32 from "exec_cert.iii"
extern @abi(c-msvc-x64) fn xc_event_byte(b: u32) -> i32 from "exec_cert.iii"
extern @abi(c-msvc-x64) fn xc_seal(out_32: *u8) -> i32 from "exec_cert.iii"

const ISUB_CAP     : u32 = 512u32
const ISUB_NULL    : u32 = 0xFFFFFFFFu32
const ISUB_MAXADDR : u32 = 0x100000u32   /* operands are bare addresses < 2^20 -- not packed strings */

/* the ONLY legal verbs -- the uniform geometric vocabulary (omnia::logos). */
const V_BELOW   : u32 = 0u32
const V_REFLECT : u32 = 1u32
const V_MAX     : u32 = 1u32              /* anything > this in the verb slot is a NAME -> rejected */

/* the ONE append-only metal bus: uniform blocks <verb, a, b> + logical tick.  No name field exists. */
var IS_VERB  : [u32; 512]
var IS_A     : [u32; 512]
var IS_B     : [u32; 512]
var IS_TICK  : [u64; 512]
var IS_COUNT : u32 = 0u32
var IS_CLOCK : u64 = 0u64

/* the CONSTITUTIVE content-addresses, committed at emit: CAV_i = sha256(footprint_i), 32 bytes each. */
var IS_CAV   : [u8; 16384]                /* 512 * 32 */
/* the witness ROOT = hash-chain of the CAVs (the frozen, O(32) memo). */
var IS_ROOT  : [u8; 32]

/* scratch (module scope -- W4: no fn-local var arrays). */
var IS_FP    : [u8; 16]                   /* one block's 9-byte geometric footprint */
var IS_TMP   : [u8; 32]                   /* a freshly-sealed CAV before it is copied into IS_CAV */
var IS_VIS   : [u32; 512]                 /* the order-query's visited set (bounded by the block cap) */
var IS_FRT   : [u32; 512]                 /* the order-query's DFS frontier */

fn isub_reset() -> i32 @export {
    IS_COUNT = 0u32
    IS_CLOCK = 0u64
    let mut k : u64 = 0u64
    while k < 32u64 { IS_ROOT[k] = 0u8  k = k + 1u64 }   /* genesis root = 0^32 */
    return 0i32
}

/* THE NAME-GATE: a verb is legal iff it is one of the uniform geometric verbs {BELOW, REFLECT}.  A name
 * or string packed into the verb slot is a large integer (>= 2) and is structurally illegal. */
fn isub_legal_verb(v: u32) -> u32 @export {
    if v <= V_MAX { return 1u32 }
    return 0u32
}

/* serialise one block's GEOMETRIC FOOTPRINT into IS_FP: [verb(1) || a(LE32) || b(LE32)] = 9 bytes.
 * Bare addresses + the order/reflect code -- there is no label in here.  Returns the byte length. */
fn isub_footprint(verb: u32, a: u32, b: u32) -> u64 {
    IS_FP[0u64] = (verb & 0xFFu32) as u8
    IS_FP[1u64] = (a & 0xFFu32) as u8
    IS_FP[2u64] = ((a >> 8u32) & 0xFFu32) as u8
    IS_FP[3u64] = ((a >> 16u32) & 0xFFu32) as u8
    IS_FP[4u64] = ((a >> 24u32) & 0xFFu32) as u8
    IS_FP[5u64] = (b & 0xFFu32) as u8
    IS_FP[6u64] = ((b >> 8u32) & 0xFFu32) as u8
    IS_FP[7u64] = ((b >> 16u32) & 0xFFu32) as u8
    IS_FP[8u64] = ((b >> 24u32) & 0xFFu32) as u8
    return 9u64
}

/* the CONTENT-ADDRESS of a (hypothetical) block: sha256(geometric footprint) into out32.  Pure helper --
 * the same function the emit path uses to commit identities; lets a caller verify stored == computed. */
fn isub_cav_into(verb: u32, a: u32, b: u32, out32: *u8) -> i32 @export {
    let n : u64 = isub_footprint(verb, a, b)
    xc_begin()
    let mut k : u64 = 0u64
    while k < n { xc_event_byte(IS_FP[k] as u32)  k = k + 1u64 }
    xc_seal(out32)
    return 0i32
}

/* THE ONLY MUTATOR.  Name-gate + operand bound FIRST (a name in the verb slot is REJECTED -- returns 0,
 * the bus is unchanged).  On accept: append the uniform block, COMMIT its content-address
 * CAV_i = sha256(footprint_i), and fold it into the witness chain ROOT = sha256(ROOT_prev || CAV_i). */
fn isub_emit(verb: u32, a: u32, b: u32) -> u64 @export {
    if isub_legal_verb(verb) == 0u32 { return 0u64 }      /* NAME REJECTED -- structural */
    if a >= ISUB_MAXADDR { return 0u64 }                  /* operands are bare addresses, bounded */
    if b >= ISUB_MAXADDR { return 0u64 }
    if IS_COUNT >= ISUB_CAP { return 0u64 }
    let i : u32 = IS_COUNT
    let t : u64 = IS_CLOCK + 1u64
    IS_VERB[i] = verb
    IS_A[i]    = a
    IS_B[i]    = b
    IS_TICK[i] = t
    IS_COUNT = i + 1u32
    IS_CLOCK = t

    /* CAV_i = sha256(footprint_i) -- the constitutive identity, committed now. */
    let n : u64 = isub_footprint(verb, a, b)
    xc_begin()
    let mut p : u64 = 0u64
    while p < n { xc_event_byte(IS_FP[p] as u32)  p = p + 1u64 }
    xc_seal(IS_TMP)
    let base : u32 = i * 32u32
    let mut c : u32 = 0u32
    while c < 32u32 { IS_CAV[base + c] = IS_TMP[c]  c = c + 1u32 }

    /* ROOT = sha256( ROOT_prev || CAV_i ) -- fold the identity into the witness chain. */
    xc_begin()
    let mut r : u64 = 0u64
    while r < 32u64 { xc_event_byte(IS_ROOT[r] as u32)  r = r + 1u64 }
    let mut q : u32 = 0u32
    while q < 32u32 { xc_event_byte(IS_CAV[base + q] as u32)  q = q + 1u32 }
    xc_seal(IS_ROOT)                                      /* old ROOT already streamed; seal overwrites it */

    return t
}

fn isub_count() -> u32 @export { return IS_COUNT }
fn isub_verb(i: u32) -> u32 @export { if i < IS_COUNT { return IS_VERB[i] }  return ISUB_NULL }
fn isub_a(i: u32) -> u32 @export { if i < IS_COUNT { return IS_A[i] }  return ISUB_NULL }
fn isub_b(i: u32) -> u32 @export { if i < IS_COUNT { return IS_B[i] }  return ISUB_NULL }

/* the STORED content-address (identity) of event i -- read from the committed bytes, NOT recomputed. */
fn isub_event_cav_into(i: u32, out32: *u8) -> i32 @export {
    if i >= IS_COUNT { return -1i32 }
    let base : u32 = i * 32u32
    let mut k : u32 = 0u32
    while k < 32u32 { out32[k as u64] = IS_CAV[base + k]  k = k + 1u32 }
    return 0i32
}

/* the witness ROOT -- the hash-chain of all committed content-addresses. */
fn isub_witness_into(out32: *u8) -> i32 @export {
    let mut k : u64 = 0u64
    while k < 32u64 { out32[k] = IS_ROOT[k]  k = k + 1u64 }
    return 0i32
}

/* ==================== THE ORDER ORACLE (the belief kinship, 2026-07-17) ====================
 * V_BELOW records "a sits under b" -- the shape of every logic, and exactly the
 * shape of a belief's PREFERENCE (world a preferred under world b).  V_REFLECT
 * records "a mirrors to b" -- the involution, and exactly the shape of a mind's
 * reversible DREAM (a proportional-context mirror pair).  Until now the bus could
 * only WRITE and WITNESS these; a mind that emitted its belief-order could not
 * ASK the bus about it.  These verbs let the logos bus REASON over the order it
 * has witnessed -- so the belief organ (katabasis/doxa) emits its preference as
 * V_BELOW and its dream as V_REFLECT, and the bus FULFILS the belief-queries:
 *   isub_below   -- is world a preferred-under world b?  (transitive closure of
 *                   the strict V_BELOW relation, reflexive: a <= a)
 *   isub_reflect -- what does a mirror to?  (its V_REFLECT involution partner)
 *   isub_agree   -- do two minds hold the same belief-order?  (their witness
 *                   ROOTs are equal -- recognise-and-merge as one comparison)
 * Sovereign: pure integer reasoning over the bus's own uniform blocks; no import,
 * no crypto, Ring -1 intact.  The bedrock does not learn about beliefs -- it
 * learns to reason about ORDER, which belief is a case of.  The dependency still
 * flows mind -> metal; the metal simply became a queryable order, not a scroll.
 * ==================================================================== */

/* is `a` below `b` in the reflexive-transitive closure of the witnessed V_BELOW
 * order?  1 yes | 0 no.  A bounded DFS over the <= 512 emitted blocks (no
 * allocation, no recursion): the acyclic witness makes it terminate. */
fn isub_below(a: u32, b: u32) -> u32 @export {
    if a == b { return 1u32 }
    let mut nvis : u64 = 0u64
    let mut sp : u64 = 0u64
    IS_FRT[sp] = a   sp = sp + 1u64
    IS_VIS[nvis] = a   nvis = nvis + 1u64
    while sp > 0u64 {
        sp = sp - 1u64
        let cur : u32 = IS_FRT[sp]
        let mut i : u64 = 0u64
        while i < (IS_COUNT as u64) {
            if IS_VERB[i] == V_BELOW { if IS_A[i] == cur {
                let nb : u32 = IS_B[i]
                if nb == b { return 1u32 }
                let mut seen : u64 = 0u64
                let mut j : u64 = 0u64
                while j < nvis { if IS_VIS[j] == nb { seen = 1u64   j = nvis } else { j = j + 1u64 } }
                if seen == 0u64 { if nvis < 512u64 { if sp < 512u64 {
                    IS_VIS[nvis] = nb   nvis = nvis + 1u64
                    IS_FRT[sp] = nb     sp = sp + 1u64
                } } }
            } }
            i = i + 1u64
        }
    }
    return 0u32
}
/* the V_REFLECT involution partner of `a` (a mirrors to b, or b mirrors to a),
 * or ISUB_NULL if the bus witnessed no reflection touching a. */
fn isub_reflect(a: u32) -> u32 @export {
    let mut i : u64 = 0u64
    while i < (IS_COUNT as u64) {
        if IS_VERB[i] == V_REFLECT {
            if IS_A[i] == a { return IS_B[i] }
            if IS_B[i] == a { return IS_A[i] }
        }
        i = i + 1u64
    }
    return ISUB_NULL
}
/* do two witnessed belief-orders agree?  1 iff their 32-byte ROOTs are equal --
 * recognise-and-merge: two minds concur exactly when their orders hash the same. */
fn isub_agree(root_a: *u8, root_b: *u8) -> u32 @export {
    let mut k : u64 = 0u64
    while k < 32u64 { if root_a[k] != root_b[k] { return 0u32 }   k = k + 1u64 }
    return 1u32
}

/* ==================== THE CANON LAYER (the bedrock learns to SEE, 2026-07-18) ====================
 * The witness ROOT above is a hash-CHAIN over emission order, and its CAVs eat
 * the bare addresses raw -- so the root hears both the ORDER the blocks arrived
 * in and the ARRANGEMENT of the labels.  "There is no label in here" was true of
 * names-as-strings, not of the labels' arrangement: two isomorphic geometries
 * with permuted addresses witness DIFFERENTLY.  The canon layer completes the
 * promise: an EXACT canonical form of the laid geometry, invariant under every
 * relabeling and every emission order -- computed by color refinement with
 * individualization (minimal-encoding selection over all tie branches, so no
 * choice order can leak), sealed through the SAME exec_cert sha256.  With it the
 * bus becomes a DECISION organ for identity questions:
 *   isub_swap_invariant -- is exchanging two addresses an automorphism of the
 *                          laid geometry?  (the transposition test: Leibniz's
 *                          discernment at the metal)
 *   isub_canon_into     -- the TRUE nameless witness (the isomorphism class's
 *                          one name)
 *   isub_same_orbit     -- may ANY automorphism carry a to b?  (structural
 *                          interchangeability, by marked canonization)
 * JURISDICTION: geometries of up to 64 distinct addresses (the machine word --
 * the mneme law); beyond it the canon REFUSES, counted, never silent.  The
 * canon layer is ADDITIVE: every prior export, byte layout and consumer is
 * untouched; the chain ROOT keeps its role (the temporal witness) and the canon
 * stands beside it (the timeless one).  NIH intact: pure integer partitioning
 * plus the sealed sha256 -- no new crypto, no imports. */
const ISC_NCAP : u64 = 64u64
const ISC_LEAFCAP : u64 = 4096u64
var ISC_ID   : [u32; 64]                 /* compact node id -> address           */
var ISC_N    : u64 = 0u64
var ISC_OUT  : [u64; 64]                 /* BELOW adjacency, node bitmasks       */
var ISC_IN   : [u64; 64]
var ISC_RFL  : [u64; 64]                 /* REFLECT adjacency (symmetric)        */
var ISC_MARK : u64 = 0u64                /* marked node | SENT (orbit queries)   */
var ISC_COL  : [u64; 4160]               /* colors, 65 levels x 64 nodes         */
var ISC_SIG  : [u64; 64]                 /* refinement signatures                */
var ISC_SRT  : [u64; 64]                 /* sort scratch                         */
var ISC_ENC  : [u8; 1088]                /* candidate canonical encoding         */
var ISC_BEST : [u8; 1088]                /* minimal encoding so far              */
var ISC_BESTSET : u64 = 0u64
var ISC_PERM : [u64; 64]                 /* canonical position -> node           */
var ISC_LEAVES : u64 = 0u64
var ISC_REFUSED : u64 = 0u64             /* canon refusals, counted              */
var ISC_SENT64 : u64 = 18446744073709551615u64

fn isc_mix(h: u64, v: u64) -> u64 {
    /* pure-integer combine for PARTITIONING only (the witness itself is
     * sealed by sha256 below) */
    let mut x : u64 = h ^ (v * 1099511628211u64)
    x = x ^ (x >> 33u64)
    x = x * 14029467366897019727u64
    x = x ^ (x >> 29u64)
    return x
}
fn isc_node_of(a: u32) -> u64 {
    let mut i : u64 = 0u64
    while i < ISC_N { if ISC_ID[i] == a { return i }   i = i + 1u64 }
    return ISC_SENT64
}
/* build the compact node graph off the laid blocks; 0 ok | 1 refused (cap) */
fn isc_build() -> u64 {
    ISC_N = 0u64
    let mut i : u64 = 0u64
    while i < (IS_COUNT as u64) {
        let mut s : u64 = 0u64
        while s < 2u64 {
            let mut ad : u32 = IS_A[i]
            if s == 1u64 { ad = IS_B[i] }
            if isc_node_of(ad) == ISC_SENT64 {
                if ISC_N >= ISC_NCAP { ISC_REFUSED = ISC_REFUSED + 1u64   return 1u64 }
                ISC_ID[ISC_N] = ad
                ISC_N = ISC_N + 1u64
            }
            s = s + 1u64
        }
        i = i + 1u64
    }
    let mut k : u64 = 0u64
    while k < ISC_N { ISC_OUT[k] = 0u64   ISC_IN[k] = 0u64   ISC_RFL[k] = 0u64   k = k + 1u64 }
    i = 0u64
    while i < (IS_COUNT as u64) {
        let na : u64 = isc_node_of(IS_A[i])
        let nb : u64 = isc_node_of(IS_B[i])
        if IS_VERB[i] == V_BELOW {
            ISC_OUT[na] = ISC_OUT[na] | (1u64 << nb)
            ISC_IN[nb] = ISC_IN[nb] | (1u64 << na)
        } else {
            ISC_RFL[na] = ISC_RFL[na] | (1u64 << nb)
            ISC_RFL[nb] = ISC_RFL[nb] | (1u64 << na)
        }
        i = i + 1u64
    }
    return 0u64
}
fn isc_pc(m: u64) -> u64 {
    let mut c : u64 = 0u64
    let mut x : u64 = m
    while x != 0u64 { c = c + (x & 1u64)   x = x >> 1u64 }
    return c
}
/* one refinement round at color level lv: signature = mix of own color and the
 * SORTED colors of below-successors, below-predecessors and mirror partners */
fn isc_refine(lv: u64) -> u64 {
    let base : u64 = lv * 64u64
    let mut i : u64 = 0u64
    while i < ISC_N {
        let mut h : u64 = isc_mix(1469598103934665603u64, ISC_COL[base + i])
        let mut e : u64 = 0u64
        while e < 3u64 {
            let mut msk : u64 = ISC_OUT[i]
            if e == 1u64 { msk = ISC_IN[i] }
            if e == 2u64 { msk = ISC_RFL[i] }
            let mut ns : u64 = 0u64
            let mut j : u64 = 0u64
            while j < ISC_N {
                if ((msk >> j) & 1u64) == 1u64 { ISC_SRT[ns] = ISC_COL[base + j]   ns = ns + 1u64 }
                j = j + 1u64
            }
            let mut a : u64 = 0u64
            while a + 1u64 < ns {
                let mut b2 : u64 = a + 1u64
                let mut mn : u64 = a
                while b2 < ns { if ISC_SRT[b2] < ISC_SRT[mn] { mn = b2 }   b2 = b2 + 1u64 }
                if mn != a { let t : u64 = ISC_SRT[a]   ISC_SRT[a] = ISC_SRT[mn]   ISC_SRT[mn] = t }
                a = a + 1u64
            }
            h = isc_mix(h, 767865653u64 + e)
            j = 0u64
            while j < ns { h = isc_mix(h, ISC_SRT[j])   j = j + 1u64 }
            e = e + 1u64
        }
        ISC_SIG[i] = h
        i = i + 1u64
    }
    let mut changed : u64 = 0u64
    i = 0u64
    while i < ISC_N {
        if ISC_COL[base + i] != ISC_SIG[i] { changed = 1u64 }
        ISC_COL[base + i] = ISC_SIG[i]
        i = i + 1u64
    }
    return changed
}
fn isc_refine_fix(lv: u64) -> i32 {
    let mut r : u64 = 0u64
    while r < 66u64 {
        if isc_refine(lv) == 0u64 { return 0i32 }
        r = r + 1u64
    }
    return 0i32
}
/* all colors distinct at level lv? if so, fill ISC_PERM with nodes in color order */
fn isc_discrete(lv: u64) -> u64 {
    let base : u64 = lv * 64u64
    let mut i : u64 = 0u64
    while i < ISC_N {
        let mut j : u64 = 0u64
        while j < ISC_N {
            if i != j { if ISC_COL[base + i] == ISC_COL[base + j] { return 0u64 } }
            j = j + 1u64
        }
        i = i + 1u64
    }
    let mut used : u64 = 0u64
    let mut p : u64 = 0u64
    while p < ISC_N {
        let mut bi : u64 = ISC_SENT64
        i = 0u64
        while i < ISC_N {
            if ((used >> i) & 1u64) == 0u64 {
                if bi == ISC_SENT64 { bi = i } else {
                    if ISC_COL[base + i] < ISC_COL[base + bi] { bi = i }
                }
            }
            i = i + 1u64
        }
        ISC_PERM[p] = bi
        used = used | (1u64 << bi)
        p = p + 1u64
    }
    return 1u64
}
/* encode the graph under ISC_PERM: n, then BELOW rows, then REFLECT rows */
fn isc_encode() -> i32 {
    let mut w : u64 = 0u64
    ISC_ENC[w] = ISC_N as u8
    w = w + 1u64
    let mut e : u64 = 0u64
    while e < 2u64 {
        let mut i : u64 = 0u64
        while i < ISC_N {
            let ni : u64 = ISC_PERM[i]
            let mut msk : u64 = ISC_OUT[ni]
            if e == 1u64 { msk = ISC_RFL[ni] }
            let mut acc : u64 = 0u64
            let mut nb : u64 = 0u64
            let mut j : u64 = 0u64
            while j < ISC_N {
                let nj : u64 = ISC_PERM[j]
                acc = (acc << 1u64) | ((msk >> nj) & 1u64)
                nb = nb + 1u64
                if nb == 8u64 { ISC_ENC[w] = acc as u8   w = w + 1u64   acc = 0u64   nb = 0u64 }
                j = j + 1u64
            }
            if nb != 0u64 { ISC_ENC[w] = (acc << (8u64 - nb)) as u8   w = w + 1u64 }
            i = i + 1u64
        }
        e = e + 1u64
    }
    /* the mark rides the encoding so marked canonization is well-defined */
    if ISC_MARK == ISC_SENT64 { ISC_ENC[w] = 255u8 } else {
        let mut mp : u64 = 0u64
        let mut q : u64 = 0u64
        while q < ISC_N { if ISC_PERM[q] == ISC_MARK { mp = q }   q = q + 1u64 }
        ISC_ENC[w] = mp as u8
    }
    w = w + 1u64
    return 0i32
}
fn isc_enc_len() -> u64 {
    let rowb : u64 = (ISC_N + 7u64) / 8u64
    return 1u64 + (2u64 * ISC_N * rowb) + 1u64
}
fn isc_take_if_min() -> i32 {
    let n : u64 = isc_enc_len()
    if ISC_BESTSET == 0u64 {
        let mut k : u64 = 0u64
        while k < n { ISC_BEST[k] = ISC_ENC[k]   k = k + 1u64 }
        ISC_BESTSET = 1u64
        return 0i32
    }
    let mut k : u64 = 0u64
    while k < n {
        if ISC_ENC[k] < ISC_BEST[k] {
            let mut j : u64 = k
            while j < n { ISC_BEST[j] = ISC_ENC[j]   j = j + 1u64 }
            return 0i32
        }
        if ISC_ENC[k] > ISC_BEST[k] { return 0i32 }
        k = k + 1u64
    }
    return 0i32
}
/* the individualization search: refine; if discrete take the encoding; else
 * split the first ambiguous cell on every member, minimal encoding wins */
fn isc_search(lv: u64) -> u64 {
    if lv >= 63u64 { return 1u64 }
    isc_refine_fix(lv)
    if isc_discrete(lv) == 1u64 {
        ISC_LEAVES = ISC_LEAVES + 1u64
        if ISC_LEAVES > ISC_LEAFCAP { return 1u64 }
        isc_encode()
        isc_take_if_min()
        return 0u64
    }
    let base : u64 = lv * 64u64
    /* the first ambiguous cell = the smallest color value owned by >1 node */
    let mut cell : u64 = ISC_SENT64
    let mut i : u64 = 0u64
    while i < ISC_N {
        let mut cnt : u64 = 0u64
        let mut j : u64 = 0u64
        while j < ISC_N {
            if ISC_COL[base + j] == ISC_COL[base + i] { cnt = cnt + 1u64 }
            j = j + 1u64
        }
        if cnt > 1u64 {
            if cell == ISC_SENT64 { cell = i } else {
                if ISC_COL[base + i] < ISC_COL[base + cell] { cell = i }
            }
        }
        i = i + 1u64
    }
    if cell == ISC_SENT64 { return 1u64 }
    let cc : u64 = ISC_COL[base + cell]
    /* TWIN COLLAPSE (sound): if every member of the cell has IDENTICAL
     * adjacency masks and no self-loop, the members are interchangeable --
     * any transposition of two of them is an automorphism, so every branch
     * yields the same minimal encoding and ONE branch suffices.  (The brute
     * permutation engine in the self-proof revalidates this on symmetric
     * graphs.)  Non-twin ambiguity still branches in full: exactness kept. */
    let mut alltwin : u64 = 1u64
    let mut m0 : u64 = ISC_SENT64
    i = 0u64
    while i < ISC_N {
        if ISC_COL[base + i] == cc {
            if m0 == ISC_SENT64 { m0 = i } else {
                if ISC_OUT[i] != ISC_OUT[m0] { alltwin = 0u64 }
                if ISC_IN[i] != ISC_IN[m0] { alltwin = 0u64 }
                if ISC_RFL[i] != ISC_RFL[m0] { alltwin = 0u64 }
            }
            if ((ISC_OUT[i] >> i) & 1u64) == 1u64 { alltwin = 0u64 }
            if ((ISC_RFL[i] >> i) & 1u64) == 1u64 { alltwin = 0u64 }
        }
        i = i + 1u64
    }
    i = 0u64
    while i < ISC_N {
        if ISC_COL[base + i] == cc {
            let nb : u64 = (lv + 1u64) * 64u64
            let mut j : u64 = 0u64
            while j < ISC_N { ISC_COL[nb + j] = ISC_COL[base + j]   j = j + 1u64 }
            ISC_COL[nb + i] = isc_mix(ISC_COL[base + i], 88172645463325252u64)
            if isc_search(lv + 1u64) != 0u64 { return 1u64 }
            if alltwin == 1u64 { return 0u64 }
        }
        i = i + 1u64
    }
    return 0u64
}
/* canonize the laid geometry (mark = a node address to distinguish, or pass
 * mark_on=0 for none); the canonical encoding is sealed by sha256 into out32.
 * 1 ok | 0 REFUSED (cap or budget), counted. */
fn isc_canon(mark_on: u32, mark_addr: u32, out32: *u8) -> u32 {
    if isc_build() != 0u64 { return 0u32 }
    ISC_MARK = ISC_SENT64
    if mark_on == 1u32 {
        let mn : u64 = isc_node_of(mark_addr)
        if mn == ISC_SENT64 { ISC_REFUSED = ISC_REFUSED + 1u64   return 0u32 }
        ISC_MARK = mn
    }
    let mut i : u64 = 0u64
    while i < ISC_N {
        let mut c0 : u64 = isc_mix(isc_mix(isc_mix(2166136261u64, isc_pc(ISC_OUT[i])), isc_pc(ISC_IN[i])), isc_pc(ISC_RFL[i]))
        if ISC_MARK == i { c0 = isc_mix(c0, 555555555555u64) }
        ISC_COL[i] = c0
        i = i + 1u64
    }
    ISC_BESTSET = 0u64
    ISC_LEAVES = 0u64
    if isc_search(0u64) != 0u64 { ISC_REFUSED = ISC_REFUSED + 1u64   return 0u32 }
    if ISC_BESTSET == 0u64 { ISC_REFUSED = ISC_REFUSED + 1u64   return 0u32 }
    let n : u64 = isc_enc_len()
    xc_begin()
    let mut k : u64 = 0u64
    while k < n { xc_event_byte(ISC_BEST[k] as u32)   k = k + 1u64 }
    xc_seal(out32)
    return 1u32
}
/* THE TRUE NAMELESS WITNESS: the canonical form of the laid geometry, sealed.
 * Invariant under every relabeling and every emission order.  1 ok | 0 refused. */
fn isub_canon_into(out32: *u8) -> u32 @export {
    return isc_canon(0u32, 0u32, out32)
}
fn isub_canon_refusals() -> u64 @export { return ISC_REFUSED }
/* THE TRANSPOSITION TEST: is exchanging addresses a and b an automorphism of
 * the laid block multiset?  1 yes | 0 no.  Pure block arithmetic. */
fn isub_swap_invariant(a: u32, b: u32) -> u32 @export {
    let mut i : u64 = 0u64
    while i < (IS_COUNT as u64) {
        let mut sa : u32 = IS_A[i]
        if sa == a { sa = b } else { if sa == b { sa = a } }
        let mut sb : u32 = IS_B[i]
        if sb == a { sb = b } else { if sb == b { sb = a } }
        /* count occurrences of the image among the blocks (multiset) */
        let mut want : u64 = 0u64
        let mut have : u64 = 0u64
        let mut j : u64 = 0u64
        while j < (IS_COUNT as u64) {
            if IS_VERB[j] == IS_VERB[i] {
                let mut ja : u32 = IS_A[j]
                let mut jb : u32 = IS_B[j]
                if IS_VERB[j] == V_REFLECT {
                    /* reflect blocks are unordered pairs */
                    if ja == sa { if jb == sb { have = have + 1u64 } } else {
                        if ja == sb { if jb == sa { have = have + 1u64 } } }
                    if ja == IS_A[i] { if jb == IS_B[i] { want = want + 1u64 } } else {
                        if ja == IS_B[i] { if jb == IS_A[i] { want = want + 1u64 } } }
                } else {
                    if ja == sa { if jb == sb { have = have + 1u64 } }
                    if ja == IS_A[i] { if jb == IS_B[i] { want = want + 1u64 } }
                }
            }
            j = j + 1u64
        }
        if have != want { return 0u32 }
        i = i + 1u64
    }
    return 1u32
}
/* THE ORBIT TEST: may ANY automorphism of the laid geometry carry a to b?
 * Decided by marked canonization: canon(mark a) == canon(mark b).
 * 1 yes | 0 no | 2 refused (cap/budget, counted). */
var ISC_OA : [u8; 32]
var ISC_OB : [u8; 32]
fn isub_same_orbit(a: u32, b: u32) -> u32 @export {
    if a == b { return 1u32 }
    if isc_canon(1u32, a, (&ISC_OA) as u64 as *u8) == 0u32 { return 2u32 }
    if isc_canon(1u32, b, (&ISC_OB) as u64 as *u8) == 0u32 { return 2u32 }
    let mut k : u64 = 0u64
    while k < 32u64 { if ISC_OA[k] != ISC_OB[k] { return 0u32 }   k = k + 1u64 }
    return 1u32
}
/* ==================== the canon self-proof (arms 20..26) ====================
 * The brute second engine: on small graphs EVERY permutation is walked and the
 * canonizer must agree with brute force on isomorphism, orbits and swaps. */
var ISC_CA : [u8; 32]
var ISC_CB : [u8; 32]
var ISC_BP : [u64; 8]
fn isc_perm_of(idx: u64, n: u64) -> i32 {
    /* the idx-th permutation of 0..n-1 (factorial number system) */
    let mut avail : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n { avail = avail | (1u64 << i)   i = i + 1u64 }
    let mut f : u64 = 1u64
    i = 1u64
    while i < n { f = f * i   i = i + 1u64 }
    let mut r : u64 = idx
    let mut p : u64 = 0u64
    while p < n {
        let mut pick : u64 = r / f
        r = r % f
        let mut j : u64 = 0u64
        let mut cnt : u64 = 0u64
        while j < 64u64 {
            if ((avail >> j) & 1u64) == 1u64 {
                if cnt == pick { ISC_BP[p] = j   avail = avail ^ (1u64 << j)   j = 64u64 } else { cnt = cnt + 1u64 }
            }
            j = j + 1u64
        }
        if p + 2u64 <= n { f = f / ((n - 1u64) - p) }
        p = p + 1u64
    }
    return 0i32
}
/* brute: is the permutation ISC_BP an isomorphism from the CURRENT laid blocks
 * onto themselves?  (checked as multiset equality of mapped blocks) */
fn isc_brute_auto(n: u64) -> u32 {
    let mut i : u64 = 0u64
    while i < (IS_COUNT as u64) {
        let na : u64 = isc_node_of(IS_A[i])
        let nb : u64 = isc_node_of(IS_B[i])
        let ma : u32 = ISC_ID[ISC_BP[na]]
        let mb : u32 = ISC_ID[ISC_BP[nb]]
        let mut have : u64 = 0u64
        let mut j : u64 = 0u64
        while j < (IS_COUNT as u64) {
            if IS_VERB[j] == IS_VERB[i] {
                if IS_VERB[j] == V_REFLECT {
                    if IS_A[j] == ma { if IS_B[j] == mb { have = 1u64 } }
                    if IS_A[j] == mb { if IS_B[j] == ma { have = 1u64 } }
                } else {
                    if IS_A[j] == ma { if IS_B[j] == mb { have = 1u64 } }
                }
            }
            j = j + 1u64
        }
        if have == 0u64 { return 0u32 }
        i = i + 1u64
    }
    return 1u32
}
fn isub_canon_selfproof() -> u32 @export {
    /* arm 20: canon ignores emission ORDER; the chain root does not (the
     * temporal leak, witnessed) */
    isub_reset()
    isub_emit(V_BELOW, 1u32, 2u32)
    isub_emit(V_BELOW, 2u32, 3u32)
    if isub_canon_into((&ISC_CA) as u64 as *u8) != 1u32 { return 20u32 }
    isub_witness_into((&ISC_OA) as u64 as *u8)
    isub_reset()
    isub_emit(V_BELOW, 2u32, 3u32)
    isub_emit(V_BELOW, 1u32, 2u32)
    if isub_canon_into((&ISC_CB) as u64 as *u8) != 1u32 { return 20u32 }
    isub_witness_into((&ISC_OB) as u64 as *u8)
    if isub_agree((&ISC_CA) as u64 as *u8, (&ISC_CB) as u64 as *u8) != 1u32 { return 20u32 }
    if isub_agree((&ISC_OA) as u64 as *u8, (&ISC_OB) as u64 as *u8) != 0u32 { return 20u32 }
    /* arm 21: canon ignores RELABELING -- complete over all 24 permutations
     * of a rigid 4-chain; the chain root hears the labels (the label leak) */
    let mut pi : u64 = 0u64
    let mut rootleak : u64 = 0u64
    while pi < 24u64 {
        isc_perm_of(pi, 4u64)
        isub_reset()
        /* the chain p(1) < p(2) < p(3) < p(4) over addresses 10+p */
        let mut e : u64 = 0u64
        while e < 3u64 {
            isub_emit(V_BELOW, (10u64 + ISC_BP[e]) as u32, (10u64 + ISC_BP[e + 1u64]) as u32)
            e = e + 1u64
        }
        if isub_canon_into((&ISC_CB) as u64 as *u8) != 1u32 { return 21u32 }
        if pi == 0u64 {
            let mut k : u64 = 0u64
            while k < 32u64 { ISC_CA[k] = ISC_CB[k]   k = k + 1u64 }
            isub_witness_into((&ISC_OA) as u64 as *u8)
        } else {
            if isub_agree((&ISC_CA) as u64 as *u8, (&ISC_CB) as u64 as *u8) != 1u32 { return 21u32 }
            isub_witness_into((&ISC_OB) as u64 as *u8)
            if isub_agree((&ISC_OA) as u64 as *u8, (&ISC_OB) as u64 as *u8) == 0u32 { rootleak = 1u64 }
        }
        pi = pi + 1u64
    }
    if rootleak != 1u64 { return 21u32 }
    /* arm 22: canon SEPARATES non-isomorphic shapes (chain vs star vs cycle) */
    isub_reset()
    isub_emit(V_BELOW, 1u32, 2u32)
    isub_emit(V_BELOW, 2u32, 3u32)
    isub_emit(V_BELOW, 3u32, 4u32)
    if isub_canon_into((&ISC_CA) as u64 as *u8) != 1u32 { return 22u32 }
    isub_reset()
    isub_emit(V_BELOW, 1u32, 4u32)
    isub_emit(V_BELOW, 2u32, 4u32)
    isub_emit(V_BELOW, 3u32, 4u32)
    if isub_canon_into((&ISC_CB) as u64 as *u8) != 1u32 { return 22u32 }
    if isub_agree((&ISC_CA) as u64 as *u8, (&ISC_CB) as u64 as *u8) != 0u32 { return 22u32 }
    /* arm 23: THE BRUTE ENGINE -- on a 5-node shape with real symmetry
     * (two leaves under one root, plus a mirrored pair), every one of the
     * 120 permutations is walked; brute automorphism must equal the
     * canonizer's orbit and swap verdicts on EVERY node pair */
    isub_reset()
    isub_emit(V_BELOW, 20u32, 22u32)
    isub_emit(V_BELOW, 21u32, 22u32)
    isub_emit(V_REFLECT, 23u32, 24u32)
    if isc_build() != 0u64 { return 23u32 }
    let n5 : u64 = ISC_N
    if n5 != 5u64 { return 23u32 }
    let mut x : u64 = 0u64
    while x < n5 {
        let mut y : u64 = 0u64
        while y < n5 {
            /* brute: does ANY permutation fix the shape and carry x to y?
             * and is the specific transposition (x y) an automorphism? */
            let mut orb : u64 = 0u64
            let mut swp : u64 = 0u64
            let mut q : u64 = 0u64
            while q < 120u64 {
                isc_perm_of(q, n5)
                if isc_brute_auto(n5) == 1u32 {
                    if ISC_BP[x] == y { orb = 1u64 }
                    /* the transposition: p[x]=y, p[y]=x, all else fixed */
                    let mut istr : u64 = 1u64
                    let mut z : u64 = 0u64
                    while z < n5 {
                        let mut wantz : u64 = z
                        if z == x { wantz = y }
                        if z == y { wantz = x }
                        if ISC_BP[z] != wantz { istr = 0u64 }
                        z = z + 1u64
                    }
                    if istr == 1u64 { swp = 1u64 }
                }
                q = q + 1u64
            }
            let co : u32 = isub_same_orbit(ISC_ID[x], ISC_ID[y])
            if co == 2u32 { return 23u32 }
            let cs : u32 = isub_swap_invariant(ISC_ID[x], ISC_ID[y])
            if (co as u64) != orb { return 23u32 }
            if x != y {
                if (cs as u64) != swp { return 23u32 }
                /* the lattice: a swap automorphism implies same orbit */
                if swp == 1u64 { if orb != 1u64 { return 23u32 } }
            }
            y = y + 1u64
        }
        x = x + 1u64
    }
    /* arm 24: the separation -- on a 3-cycle, rotation carries a to b (same
     * orbit) while the bare transposition is NOT an automorphism */
    isub_reset()
    isub_emit(V_BELOW, 31u32, 32u32)
    isub_emit(V_BELOW, 32u32, 33u32)
    isub_emit(V_BELOW, 33u32, 31u32)
    if isub_same_orbit(31u32, 32u32) != 1u32 { return 24u32 }
    if isub_swap_invariant(31u32, 32u32) != 0u32 { return 24u32 }
    /* arm 25: the refusal boundary -- a 65-address geometry refuses, counted */
    isub_reset()
    let mut w : u64 = 0u64
    while w < 65u64 {
        isub_emit(V_BELOW, (100u64 + w) as u32, 200u32)
        w = w + 1u64
    }
    let r0 : u64 = ISC_REFUSED
    if isub_canon_into((&ISC_CA) as u64 as *u8) != 0u32 { return 25u32 }
    if ISC_REFUSED != r0 + 1u64 { return 25u32 }
    /* arm 26: the prior surface is untouched -- the order oracle still proves */
    if isub_order_selfproof() != 0u32 { return 26u32 }
    isub_reset()
    return 0u32
}

/* the order oracle's self-proof (condition of motion for the new verbs): the
 * closure is transitive + reflexive + acyclic; the reflection is symmetric; two
 * identical orders agree and two distinct orders do not; the name-gate still
 * holds.  0 = proven | the failed arm. */
var IS_RA : [u8; 32]
var IS_RB : [u8; 32]
fn isub_order_selfproof() -> u32 @export {
    isub_reset()
    /* 1 under 2 under 3 under 4 (a total order) */
    isub_emit(V_BELOW, 1u32, 2u32)
    isub_emit(V_BELOW, 2u32, 3u32)
    isub_emit(V_BELOW, 3u32, 4u32)
    if isub_below(1u32, 4u32) != 1u32 { return 10u32 }        /* transitive       */
    if isub_below(2u32, 3u32) != 1u32 { return 10u32 }        /* direct           */
    if isub_below(1u32, 1u32) != 1u32 { return 11u32 }        /* reflexive        */
    if isub_below(4u32, 1u32) != 0u32 { return 12u32 }        /* acyclic (no back)*/
    if isub_below(1u32, 5u32) != 0u32 { return 13u32 }        /* 5 not in order   */
    isub_witness_into((&IS_RA) as u64 as *u8)
    /* the reflection involution */
    isub_reset()
    isub_emit(V_REFLECT, 7u32, 9u32)
    if isub_reflect(7u32) != 9u32 { return 14u32 }            /* a mirrors to b   */
    if isub_reflect(9u32) != 7u32 { return 14u32 }            /* symmetric        */
    if isub_reflect(3u32) != ISUB_NULL { return 14u32 }       /* no mirror        */
    /* recognise-and-merge: the same order agrees with itself, a different one not */
    isub_reset()
    isub_emit(V_BELOW, 1u32, 2u32)
    isub_emit(V_BELOW, 2u32, 3u32)
    isub_emit(V_BELOW, 3u32, 4u32)
    isub_witness_into((&IS_RB) as u64 as *u8)
    if isub_agree((&IS_RA) as u64 as *u8, (&IS_RB) as u64 as *u8) != 1u32 { return 15u32 }
    isub_reset()
    isub_emit(V_BELOW, 4u32, 3u32)                            /* the reversed order */
    isub_witness_into((&IS_RB) as u64 as *u8)
    if isub_agree((&IS_RA) as u64 as *u8, (&IS_RB) as u64 as *u8) != 0u32 { return 15u32 }
    /* the name-gate still holds under the new surface */
    isub_reset()
    if isub_emit(2u32, 1u32, 1u32) != 0u64 { return 16u32 }
    if isub_count() != 0u32 { return 16u32 }
    isub_reset()
    return 0u32
}
