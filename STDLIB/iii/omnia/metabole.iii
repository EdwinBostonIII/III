/* STDLIB/iii/omnia/metabole.iii -- METABOLE (the METABOLISM): the organ that
 * EATS foreign minds.
 *
 * THE VECTOR COLLAPSE, stated honestly: a quantized GGUF network is NOT a
 * cloud of floating-point approximations.  Every stored weight is an integer
 * times an IEEE fp16 scale, and every finite fp16 is EXACTLY a dyadic
 * rational M * 2^-24.  The shipped artifact is therefore ALREADY a point in
 * a finite dyadic lattice -- a finite exact object.  The float appears only
 * when OTHER runtimes choose lossy evaluation.  METABOLE ingests the
 * artifact losslessly into the exact tower: linear algebra on real weights
 * becomes machine-integer arithmetic with tracked exponents (no bignum below
 * row scale, no rounding anywhere), and decisions (sign, comparison, argmax)
 * become CERTIFIED facts.  What is NOT claimed: no end-to-end cheapness, no
 * magic compression of 400GB of entropy -- the collapse is representational,
 * not compressive.  The transcendental boundary (exp inside softmax/SiLU
 * mixing) is a NAMED deficit, not a faked capability; the final-layer argmax
 * needs no exp at all (any strictly monotone map preserves the argmax -- the
 * order theorem is machine-checked, exp's monotonicity is the named premise).
 *
 * THE ARMS (360..371, driven by the summit rite -- no gate of their own):
 *   360 THE FLESH: fp16 <-> dyadic is a finite law, proven COMPLETE -- all
 *       65536 bit patterns classified (finite=63488, nonfinite=2048, both
 *       counts re-derived from the walk), every finite pattern decoded to
 *       its exact mantissa M (value = M * 2^-24) and re-encoded to the
 *       IDENTICAL bits (bijection), and the decoded magnitudes STRICTLY
 *       increase over consecutive positive finite patterns (an independent
 *       global order engine that any decode slip would break).
 *   361 THE TYPES: the ggml quantization type table (values-per-block,
 *       bytes-per-block) for every type this organ certifies; internal
 *       consistency checked.  A type outside the table is a NAMED refusal,
 *       never a guess -- the conservation theorem (362) is what puts the
 *       table on trial against 400GB of reality.
 *   362 THE ANATOMY + CONSERVATION: every shard of the Feast is walked --
 *       magic, version, the complete KV forest (token arrays skipped by a
 *       windowed 64-bit reader, never loaded), every tensor's name, shape,
 *       type and offset -- and then the EXACT BYTE-TILING THEOREM: sorted
 *       tensor spans, each padded to the artifact's own alignment, must
 *       tile the data segment to the byte, ending flush with the file (tail
 *       pad < alignment).  A single wrong size in the type table, one
 *       misparsed field, and the tiling REDS.  Cross-shard: the split
 *       indices must be coherent and the declared total tensor count must
 *       equal the sum the walk derives.  An absent Feast is a LAWFUL fast
 *       (the door is verified, the table is empty) -- the flesh, type and
 *       scroll laws stand regardless.
 *   363 THE DIGESTION: real blocks of real tensors (the first two quantized
 *       tensors of shard 1) are read at their exact 64-bit offsets and
 *       dequantized into exact dyadic mantissas by TWO INDEPENDENT ENGINES:
 *       value-by-value affine decode vs the DISTRIBUTIVE factorization
 *       (sum v = d*sum(sc*q) - dmin*sum(m*32); sum v^2 expanded through the
 *       cross terms in 192-bit integer arithmetic).  Different association
 *       orders, different intermediate widths, one exact answer -- or red.
 *   364 THE WITNESS: the digested block's exact sum of squares, put in
 *       canonical form (odd mantissa * 2^-k).  Its odd mantissa carries MORE
 *       than 24 significant bits -- so IEEE fp32 (the runtime lingua franca)
 *       CANNOT hold the number; the round-to-nearest-even neighbor is
 *       computed in integers and its nonzero gap EXHIBITED.  The float must
 *       round; the organ holds the number exactly.  Machine-checked on the
 *       actual R1 weights, not rhetoric.
 *   365 THE KRISIS: certified decisions on real flesh.  (a) the exact
 *       argmax over the digested block by two paths (linear scan vs full
 *       insertion order), ties counted, NO exp evaluated -- the monotone
 *       premise is named, the order fact is checked.  (b) the RMSNorm-shaped
 *       comparison a/sqrt(S1) vs b/sqrt(S2) on real sub-rows, decided by TWO
 *       ENGINES: the elementary square-compare in 192-bit integer arithmetic
 *       vs the standing surd kernel (ui_sign_bi_big, the exact-geometry
 *       organ already in this probe).  The engines must agree; the reflexive
 *       control (a*sqrt(S) - a*sqrt(S) = 0) must vanish by both.
 *   366 THE SCROLL: the metabolic law sealed in EIDOLOS -- the derived
 *       entailment (weight sits under exact number) present nowhere in the
 *       text, the reversal refused, the address deterministic.
 *   370 THE SYNAPSE: a full embedding-width exact dot product between a
 *       real output.weight row and a real token_embd.weight row -- both
 *       STREAMED block by block (rows are contiguous: the byte-tiling
 *       theorem's layout law), every streamed block still passing the
 *       two-engine distributive check, products accumulated in signed
 *       192-bit integers.  Three teeth no shared slip survives: the
 *       REVERSED REGROUP (per-block partials summed backwards must equal
 *       the forward stream), the DOUBLE STREAM (the whole synapse
 *       recomputed from a fresh file stream must match limb for limb),
 *       and CAUCHY-SCHWARZ EXACT: (u.v)^2 <= (u.u)(v.v) verified in
 *       384-bit integer arithmetic on the real rows -- strictness derived,
 *       never assumed.
 *   371 THE STOMACH: the streaming law made a number -- total bytes
 *       streamed vs the fixed resident stomach (the sum of this organ's
 *       buffers).  The whole feast passes through a stomach that never
 *       grows: blocks in, proofs out.
 *   372 THE LOOM: thread-level parallel pipelining WITHOUT compromise.
 *       The theorem that makes it free: exact integer accumulation is
 *       associative and commutative, so a reduction schedule need only fix
 *       the PARTITION (static, block-aligned, canonical) -- the TIMING
 *       stays entirely free, and every interleaving must land on the same
 *       limbs.  Four workers (CreateThread, each with its OWN file handle,
 *       block buffer, decoder scratch and 192-bit accumulators -- zero
 *       shared mutable state) weave the same real synapse in parallel;
 *       then the loom is put on trial: the canonical fold must equal the
 *       REVERSED fold (associativity witnessed at the fold), the parallel
 *       result must equal the sequential stream of arm 370 LIMB FOR LIMB,
 *       and a second full launch must reproduce the first exactly.  Where
 *       float runtimes must serialize or force reduction trees to stay
 *       reproducible, the dyadic lattice makes parallelism a THEOREM.
 *
 * THE NAMED DEFICIT (the autarkeia law): a certified-exp interval organ
 * (rational Taylor bounds with proven remainders) does not yet exist in the
 * organism, so softmax MIXING (not argmax) stays undecided.  Named in every
 * census, never papered.
 */

module omnia_metabole

extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fread(buf: u64, sz: u64, n: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(stream: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn _fseeki64(stream: u64, off: i64, origin: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn _ftelli64(stream: u64) -> i64 from "msvcrt"

extern @abi(c-msvc-x64) fn CreateThread(attr: u64, stack: u64, start: u64, param: u64, flags: u64, tid: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn WaitForSingleObject(h: u64, ms: u32) -> u32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> i32 from "kernel32"

extern @abi(c-msvc-x64) fn ui_sign_bi_big(an: i64, bn: i64, dD1: i64, cn: i64, dD2: i64) -> i32 from "sqrt_sum_sign.iii"

extern @abi(c-msvc-x64) fn eol_reset() -> i32 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_read(addr: u64, len: u64) -> i64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_addr() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_lawcheck() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_entails(a_addr: u64, a_len: u64, verb: u64, b_addr: u64, b_len: u64) -> u64 from "eidolos.iii"

/* ==================== module state ==================== */

const MB_ALIGN_DEF : u64 = 32u64
const MB_MAXT      : u64 = 512u64     /* per-shard tensor ceiling (R1: 152 max) */

/* windowed 64-bit reader */
var MB_F     : u64 = 0u64             /* FILE* */
var MB_WIN   : [u8; 65536]
var MB_WBASE : u64 = 0u64             /* file offset of window start */
var MB_WLEN  : u64 = 0u64             /* valid bytes in window */
var MB_WPOS  : u64 = 0u64             /* cursor within window */
var MB_IOERR : u8  = 0u8              /* sticky */

/* per-shard walk results */
var MB_OFF  : [u64; 512]
var MB_NB   : [u64; 512]
var MB_KEY  : [u8; 256]
var MB_HIST : [u64; 64]               /* feast-wide ggml type histogram */

/* KV extraction slots (per shard; arch/dims sticky across shards) */
var MB_ALIGN   : u64 = 32u64
var MB_SPLITNO : u64 = 0u64
var MB_SPLITNO_F : u8 = 0u8
var MB_SPLITCT : u64 = 0u64
var MB_SPLITCT_F : u8 = 0u8
var MB_SPLITTN : u64 = 0u64
var MB_SPLITTN_F : u8 = 0u8
var MB_ARCH    : [u8; 32]
var MB_ARCHN   : u64 = 0u64
var MB_EMBED   : u64 = 0u64
var MB_LAYERS  : u64 = 0u64

/* split coherence across shards */
var MB_SPNOS  : [u64; 16]
var MB_SPNOSF : [u8; 16]

/* feast aggregates */
var MB_SHARDS   : u64 = 0u64
var MB_TOT_TENS : u64 = 0u64
var MB_TOT_BYTES: u64 = 0u64
var MB_CONSERVED: u64 = 0u64
var MB_REFUSED  : u64 = 0u64
var MB_FEAST    : u8  = 0u8           /* 1 = feast present */

/* digestion candidates (shard 1): first two quantized tensors */
var MB_C1_TYPE : u64 = 0u64
var MB_C1_OFF  : u64 = 0u64           /* relative; absolute fixed after walk */
var MB_C1_NE   : u64 = 0u64
var MB_C1_NE0  : u64 = 0u64
var MB_C1_NAME : [u8; 64]
var MB_C1_NN   : u64 = 0u64
var MB_C1_F    : u8 = 0u8
var MB_C2_TYPE : u64 = 0u64
var MB_C2_OFF  : u64 = 0u64
var MB_C2_NE   : u64 = 0u64
var MB_C2_NE0  : u64 = 0u64
/* the router (first ffn_gate_inp anywhere in the feast) */
var MB_C3_TYPE : u64 = 0u64
var MB_C3_OFF  : u64 = 0u64
var MB_C3_NE   : u64 = 0u64
var MB_C3_NE0  : u64 = 0u64
var MB_C3_SHARD: u64 = 0u64
var MB_C3_DBASE: u64 = 0u64
var MB_C3_NAME : [u8; 48]
var MB_C3_NN   : u64 = 0u64
var MB_C3_F    : u8 = 0u8
var MB_C3_HERE : u8 = 0u8             /* found during the CURRENT shard walk */
/* the gaze's seven organs of blk.0 attention (slot order: attn_norm, q_a,
 * q_a_norm, q_b, kv_a_mqa, kv_a_norm, kv_b) */
var MB_G_TYPE : [u64; 8]
var MB_G_OFF  : [u64; 8]
var MB_G_NE   : [u64; 8]
var MB_G_NE0  : [u64; 8]
var MB_G_DB   : [u64; 8]
var MB_G_SH   : [u64; 8]
var MB_G_F    : [u8; 8]
var MB_G_HERE : [u8; 8]
var MB_NHEAD  : u64 = 0u64
var MB_NROPE  : u64 = 0u64
var MB_EPSB   : u64 = 0u64            /* rms epsilon, raw f32 bits */
var MB_EPSF   : u8 = 0u8
var MB_GAZE_OK : u64 = 0u64
var MB_C2_NAME : [u8; 64]
var MB_C2_NN   : u64 = 0u64
var MB_C2_F    : u8 = 0u8
var MB_DBASE1  : u64 = 0u64           /* shard 1 data_base (absolute) */
var MB_PATH1   : [u8; 64]             /* shard 1 path (kept for reopen) */

/* decoded blocks: exact mantissas, value = mant * 2^-24 */
var MB_BLK  : [u8; 256]               /* raw block bytes */
var MB_VA   : [i64; 256]              /* candidate 1 block values */
var MB_VB   : [i64; 256]              /* candidate 2 block values */
var MB_NVA  : u64 = 0u64
var MB_NVB  : u64 = 0u64
var MB_SUMA : i64 = 0i64              /* exact sums (mant * 2^-24) */
var MB_SUMB : i64 = 0i64
/* exact sums of squares (mant * 2^-48), 2-limb little-endian */
var MB_SSA0 : u64 = 0u64
var MB_SSA1 : u64 = 0u64
var MB_SSB0 : u64 = 0u64
var MB_SSB1 : u64 = 0u64

/* 128-bit multiply result */
var MB_MHI : u64 = 0u64
var MB_MLO : u64 = 0u64

/* 3-limb accumulators (little-endian limbs) */
var MB_X : [u64; 3]
var MB_Y : [u64; 3]
var MB_Z : [u64; 3]

/* the report the driver prints, and the sealed scroll */
var MB_REP  : [u8; 4096]
var MB_REPN : u64 = 0u64
var MB_SCROLL : u64 = 0u64

/* the stomach meter: actual bytes pulled through the window this census */
var MB_STREAMED : u64 = 0u64

/* ==================== tiny utils ==================== */

fn mb_slen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { i = i + 1u64 }
    return i
}

fn mb_rb(b: u8) -> i32 {
    if MB_REPN >= 4095u64 { return 0i32 }
    MB_REP[MB_REPN] = b
    MB_REPN = MB_REPN + 1u64
    return 0i32
}

fn mb_rs(s: u64) -> i32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 {
        mb_rb(p[i])
        i = i + 1u64
    }
    return 0i32
}

fn mb_ru(v: u64) -> i32 {
    if v >= 10u64 { mb_ru(v / 10u64) }
    mb_rb((48u64 + (v % 10u64)) as u8)
    return 0i32
}

fn mb_ri(v: i64) -> i32 {
    if v < 0i64 {
        mb_rb(45u8)
        let m : u64 = (0i64 - v) as u64
        mb_ru(m)
        return 0i32
    }
    mb_ru(v as u64)
    return 0i32
}

fn mb_bitlen(v: u64) -> u64 {
    let mut n : u64 = 0u64
    let mut x : u64 = v
    while x != 0u64 {
        x = x >> 1u64
        n = n + 1u64
    }
    return n
}

/* 64x64 -> 128 (classic 32-bit split; no intermediate overflow) */
fn mb_mul64(a: u64, b: u64) -> i32 {
    let a0 : u64 = a & 0xFFFFFFFFu64
    let a1 : u64 = a >> 32u64
    let b0 : u64 = b & 0xFFFFFFFFu64
    let b1 : u64 = b >> 32u64
    let p00 : u64 = a0 * b0
    let p01 : u64 = a0 * b1
    let p10 : u64 = a1 * b0
    let p11 : u64 = a1 * b1
    let mid1 : u64 = p01 + (p00 >> 32u64)
    let mid2 : u64 = p10 + (mid1 & 0xFFFFFFFFu64)
    MB_MHI = p11 + (mid1 >> 32u64) + (mid2 >> 32u64)
    MB_MLO = (mid2 << 32u64) | (p00 & 0xFFFFFFFFu64)
    return 0i32
}

/* MB_Z = |a| * b as 3 limbs, where (ahi,alo) is a 128-bit value, b 64-bit */
fn mb_mul128by64(ahi: u64, alo: u64, b: u64) -> i32 {
    mb_mul64(alo, b)
    let l0 : u64 = MB_MLO
    let l1a : u64 = MB_MHI
    mb_mul64(ahi, b)
    let l1b : u64 = MB_MLO
    let l2a : u64 = MB_MHI
    let s : u64 = l1a + l1b
    let mut c : u64 = 0u64
    if s < l1a { c = 1u64 }
    MB_Z[0] = l0
    MB_Z[1] = s
    MB_Z[2] = l2a + c
    return 0i32
}

/* MB_X += MB_Z (3-limb, carries) */
fn mb_x_add_z() -> i32 {
    let s0 : u64 = MB_X[0] + MB_Z[0]
    let mut c0 : u64 = 0u64
    if s0 < MB_Z[0] { c0 = 1u64 }
    let s1a : u64 = MB_X[1] + MB_Z[1]
    let mut c1 : u64 = 0u64
    if s1a < MB_Z[1] { c1 = 1u64 }
    let s1 : u64 = s1a + c0
    if s1 < c0 { c1 = c1 + 1u64 }
    MB_X[0] = s0
    MB_X[1] = s1
    MB_X[2] = MB_X[2] + MB_Z[2] + c1
    return 0i32
}

/* MB_X -= MB_Z (3-limb, borrows); caller guarantees X >= Z */
fn mb_x_sub_z() -> i32 {
    let mut b : u64 = 0u64
    let d0 : u64 = MB_X[0] - MB_Z[0]
    if MB_X[0] < MB_Z[0] { b = 1u64 }
    let mut b1 : u64 = 0u64
    let d1a : u64 = MB_X[1] - MB_Z[1]
    if MB_X[1] < MB_Z[1] { b1 = 1u64 }
    let d1 : u64 = d1a - b
    if d1a < b { b1 = b1 + 1u64 }
    MB_X[0] = d0
    MB_X[1] = d1
    MB_X[2] = MB_X[2] - MB_Z[2] - b1
    return 0i32
}

/* compare MB_X vs MB_Y: -1 / 0 / +1 */
fn mb_x_cmp_y() -> i64 {
    if MB_X[2] > MB_Y[2] { return 1i64 }
    if MB_X[2] < MB_Y[2] { return 0i64 - 1i64 }
    if MB_X[1] > MB_Y[1] { return 1i64 }
    if MB_X[1] < MB_Y[1] { return 0i64 - 1i64 }
    if MB_X[0] > MB_Y[0] { return 1i64 }
    if MB_X[0] < MB_Y[0] { return 0i64 - 1i64 }
    return 0i64
}

/* append 3-limb MB_X as decimal to the report (binary long division by 10) */
var MB_DDIG : [u8; 64]
fn mb_rx3() -> i32 {
    let mut h : u64 = MB_X[2]
    let mut m : u64 = MB_X[1]
    let mut l : u64 = MB_X[0]
    let mut nd : u64 = 0u64
    if h == 0u64 {
        if m == 0u64 {
            if l == 0u64 {
                mb_rb(48u8)
                return 0i32
            }
        }
    }
    while (h | m | l) != 0u64 {
        /* divide (h,m,l) by 10 via binary long division over 192 bits */
        let mut rem : u64 = 0u64
        let mut qh : u64 = 0u64
        let mut qm : u64 = 0u64
        let mut ql : u64 = 0u64
        let mut bit : u64 = 192u64
        while bit != 0u64 {
            bit = bit - 1u64
            let mut src : u64 = 0u64
            if bit >= 128u64 { src = (h >> (bit - 128u64)) & 1u64 }
            if bit < 128u64 {
                if bit >= 64u64 { src = (m >> (bit - 64u64)) & 1u64 }
            }
            if bit < 64u64 { src = (l >> bit) & 1u64 }
            rem = (rem << 1u64) | src
            if rem >= 10u64 {
                rem = rem - 10u64
                if bit >= 128u64 { qh = qh | (1u64 << (bit - 128u64)) }
                if bit < 128u64 {
                    if bit >= 64u64 { qm = qm | (1u64 << (bit - 64u64)) }
                }
                if bit < 64u64 { ql = ql | (1u64 << bit) }
            }
        }
        MB_DDIG[nd] = (48u64 + rem) as u8
        nd = nd + 1u64
        h = qh
        m = qm
        l = ql
    }
    while nd != 0u64 {
        nd = nd - 1u64
        mb_rb(MB_DDIG[nd])
    }
    return 0i32
}

/* ==================== arm 360: THE FLESH (fp16 complete) ==================== */

var MB_F16S : u64 = 0u64              /* sign of last decode */
var MB_F16A : u64 = 0u64              /* magnitude mantissa (value = A * 2^-24) */

/* classify pattern: 0 finite (sets MB_F16S / MB_F16A), 1 inf, 2 nan */
fn mb_f16_dec(p: u64) -> u64 {
    let s : u64 = (p >> 15u64) & 1u64
    let e : u64 = (p >> 10u64) & 31u64
    let m : u64 = p & 1023u64
    if e == 31u64 {
        if m == 0u64 { return 1u64 }
        return 2u64
    }
    MB_F16S = s
    if e == 0u64 {
        MB_F16A = m
        return 0u64
    }
    MB_F16A = (1024u64 + m) << (e - 1u64)
    return 0u64
}

/* signed mantissa of a finite fp16 (value = result * 2^-24); nonfinite -> sets MB_IOERR */
fn mb_f16_mant(p: u64) -> i64 {
    let c : u64 = mb_f16_dec(p)
    if c != 0u64 {
        MB_IOERR = 1u8
        return 0i64
    }
    let a : i64 = MB_F16A as i64
    if MB_F16S == 1u64 { return 0i64 - a }
    return a
}

/* re-encode (s, A) -> pattern; 0xFFFFFFFFFFFFFFFF = not a valid fp16 mantissa */
fn mb_f16_enc(s: u64, a: u64) -> u64 {
    if a == 0u64 { return s << 15u64 }
    let bl : u64 = mb_bitlen(a)
    if bl <= 10u64 { return (s << 15u64) | a }
    let e : u64 = bl - 10u64
    if e > 30u64 { return 0xFFFFFFFFFFFFFFFFu64 }
    let low : u64 = e - 1u64
    if ((a >> low) << low) != a { return 0xFFFFFFFFFFFFFFFFu64 }
    let mm : u64 = (a >> low) - 1024u64
    if mm > 1023u64 { return 0xFFFFFFFFFFFFFFFFu64 }
    return (s << 15u64) | (e << 10u64) | mm
}

fn mb_arm360() -> u64 {
    let mut fin : u64 = 0u64
    let mut nonfin : u64 = 0u64
    let mut p : u64 = 0u64
    while p < 65536u64 {
        let c : u64 = mb_f16_dec(p)
        if c == 0u64 {
            fin = fin + 1u64
            /* bijection: re-encode must reproduce the exact bits */
            if mb_f16_enc(MB_F16S, MB_F16A) != p { return 360u64 }
        }
        if c != 0u64 { nonfin = nonfin + 1u64 }
        p = p + 1u64
    }
    /* the closed forms the walk must re-derive: 2*31*1024 finite, 2*1024 not */
    if fin != 63488u64 { return 360u64 }
    if nonfin != 2048u64 { return 360u64 }
    /* the independent order engine: positive finite magnitudes strictly rise */
    let mut prev : u64 = 0u64
    p = 1u64
    while p < 31744u64 {
        if mb_f16_dec(p) != 0u64 { return 360u64 }
        if MB_F16A <= prev { return 360u64 }
        prev = MB_F16A
        p = p + 1u64
    }
    mb_rs("the flesh: fp16 finite=" as u64)
    mb_ru(fin)
    mb_rs(" nonfinite=" as u64)
    mb_ru(nonfin)
    mb_rs(" bijection=ok monotone=ok lattice=2^-24" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ==================== arm 361: THE TYPES ==================== */

/* values per block; 0 = outside this organ's certified table */
fn mb_tbv(t: u64) -> u64 {
    if t == 0u64 { return 1u64 }      /* F32 */
    if t == 1u64 { return 1u64 }      /* F16 */
    if t == 2u64 { return 32u64 }     /* Q4_0 */
    if t == 3u64 { return 32u64 }     /* Q4_1 */
    if t == 6u64 { return 32u64 }     /* Q5_0 */
    if t == 7u64 { return 32u64 }     /* Q5_1 */
    if t == 8u64 { return 32u64 }     /* Q8_0 */
    if t == 9u64 { return 32u64 }     /* Q8_1 */
    if t == 10u64 { return 256u64 }   /* Q2_K */
    if t == 11u64 { return 256u64 }   /* Q3_K */
    if t == 12u64 { return 256u64 }   /* Q4_K */
    if t == 13u64 { return 256u64 }   /* Q5_K */
    if t == 14u64 { return 256u64 }   /* Q6_K */
    if t == 15u64 { return 256u64 }   /* Q8_K */
    if t == 24u64 { return 1u64 }     /* I8 */
    if t == 25u64 { return 1u64 }     /* I16 */
    if t == 26u64 { return 1u64 }     /* I32 */
    if t == 27u64 { return 1u64 }     /* I64 */
    if t == 28u64 { return 1u64 }     /* F64 */
    if t == 30u64 { return 1u64 }     /* BF16 */
    return 0u64
}

fn mb_tbb(t: u64) -> u64 {
    if t == 0u64 { return 4u64 }
    if t == 1u64 { return 2u64 }
    if t == 2u64 { return 18u64 }
    if t == 3u64 { return 20u64 }
    if t == 6u64 { return 22u64 }
    if t == 7u64 { return 24u64 }
    if t == 8u64 { return 34u64 }
    if t == 9u64 { return 36u64 }
    if t == 10u64 { return 84u64 }
    if t == 11u64 { return 110u64 }
    if t == 12u64 { return 144u64 }
    if t == 13u64 { return 176u64 }
    if t == 14u64 { return 210u64 }
    if t == 15u64 { return 292u64 }
    if t == 24u64 { return 1u64 }
    if t == 25u64 { return 2u64 }
    if t == 26u64 { return 4u64 }
    if t == 27u64 { return 8u64 }
    if t == 28u64 { return 8u64 }
    if t == 30u64 { return 2u64 }
    return 0u64
}

fn mb_arm361() -> u64 {
    /* internal consistency: bv and bb tables agree on membership; k-quants
     * are exactly the 256-value blocks; unit types carry unit-value sizes */
    let mut known : u64 = 0u64
    let mut kq : u64 = 0u64
    let mut t : u64 = 0u64
    while t < 64u64 {
        let bv : u64 = mb_tbv(t)
        let bb : u64 = mb_tbb(t)
        if bv == 0u64 {
            if bb != 0u64 { return 361u64 }
        }
        if bv != 0u64 {
            if bb == 0u64 { return 361u64 }
            known = known + 1u64
            if bv == 256u64 { kq = kq + 1u64 }
            /* a block never holds fewer bytes than one value of its lattice:
             * every certified type packs at most 16 values per byte-pair */
            if bb * 16u64 < bv { return 361u64 }
        }
        t = t + 1u64
    }
    if known != 20u64 { return 361u64 }
    if kq != 6u64 { return 361u64 }
    mb_rs("the types: known=" as u64)
    mb_ru(known)
    mb_rs(" kquant=" as u64)
    mb_ru(kq)
    mb_rb(10u8)
    return 0u64
}

/* ==================== the windowed 64-bit reader ==================== */

fn mb_pos() -> u64 { return MB_WBASE + MB_WPOS }

fn mb_seek_abs(off: u64) -> i32 {
    if off >= MB_WBASE {
        if off < MB_WBASE + MB_WLEN {
            MB_WPOS = off - MB_WBASE
            return 0i32
        }
    }
    let rc : i32 = _fseeki64(MB_F, off as i64, 0i32)
    if rc != 0i32 { MB_IOERR = 1u8 }
    MB_WBASE = off
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    return rc
}

fn mb_refill() -> i32 {
    if MB_WPOS < MB_WLEN { return 0i32 }
    let base : u64 = MB_WBASE + MB_WLEN
    let rc : i32 = _fseeki64(MB_F, base as i64, 0i32)
    if rc != 0i32 {
        MB_IOERR = 1u8
        return 1i32
    }
    let got : u64 = fread((&MB_WIN) as u64, 1u64, 65536u64, MB_F)
    MB_STREAMED = MB_STREAMED + got
    MB_WBASE = base
    MB_WLEN = got
    MB_WPOS = 0u64
    if got == 0u64 {
        MB_IOERR = 1u8
        return 1i32
    }
    return 0i32
}

fn mb_u8() -> u64 {
    if mb_refill() != 0i32 { return 0u64 }
    let b : u64 = MB_WIN[MB_WPOS] as u64
    MB_WPOS = MB_WPOS + 1u64
    return b
}

fn mb_u16() -> u64 {
    let b0 : u64 = mb_u8()
    let b1 : u64 = mb_u8()
    return b0 | (b1 << 8u64)
}

fn mb_u32() -> u64 {
    let b0 : u64 = mb_u16()
    let b1 : u64 = mb_u16()
    return b0 | (b1 << 16u64)
}

fn mb_u64() -> u64 {
    let b0 : u64 = mb_u32()
    let b1 : u64 = mb_u32()
    return b0 | (b1 << 32u64)
}

fn mb_skip(n: u64) -> i32 {
    let target : u64 = mb_pos() + n
    return mb_seek_abs(target)
}

/* ==================== the GGUF walk (one shard) ==================== */

var MB_PATH : [u8; 64]

fn mb_mkpath(i: u64) -> i32 {
    /* "Feast/r1_shardNN.gguf" + NUL */
    let s : u64 = "Feast/r1_shard" as u64
    let p : *u8 = s as *u8
    let mut k : u64 = 0u64
    while p[k] != 0u8 {
        MB_PATH[k] = p[k]
        k = k + 1u64
    }
    MB_PATH[k] = (48u64 + (i / 10u64)) as u8
    MB_PATH[k + 1u64] = (48u64 + (i % 10u64)) as u8
    let t : u64 = ".gguf" as u64
    let q : *u8 = t as *u8
    let mut j : u64 = 0u64
    while q[j] != 0u8 {
        MB_PATH[k + 2u64 + j] = q[j]
        j = j + 1u64
    }
    MB_PATH[k + 2u64 + j] = 0u8
    return 0i32
}

fn mb_keyis(lit: u64, klen: u64) -> u64 {
    let p : *u8 = lit as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 {
        if i >= klen { return 0u64 }
        if p[i] != MB_KEY[i] { return 0u64 }
        i = i + 1u64
    }
    if i != klen { return 0u64 }
    return 1u64
}

fn mb_scalar_size(vt: u64) -> u64 {
    if vt == 0u64 { return 1u64 }
    if vt == 1u64 { return 1u64 }
    if vt == 2u64 { return 2u64 }
    if vt == 3u64 { return 2u64 }
    if vt == 4u64 { return 4u64 }
    if vt == 5u64 { return 4u64 }
    if vt == 6u64 { return 4u64 }
    if vt == 7u64 { return 1u64 }
    if vt == 10u64 { return 8u64 }
    if vt == 11u64 { return 8u64 }
    if vt == 12u64 { return 8u64 }
    return 0u64
}

/* read a scalar KV value as u64 (unsigned reading of the stored bytes) */
fn mb_scalar_read(vt: u64) -> u64 {
    let sz : u64 = mb_scalar_size(vt)
    if sz == 1u64 { return mb_u8() }
    if sz == 2u64 { return mb_u16() }
    if sz == 4u64 { return mb_u32() }
    return mb_u64()
}

/* walk one KV entry: extract the named facts, skip everything else.
 * returns 0 ok, 1 refuse (nested array / unknown vtype) */
fn mb_kv_one(shard: u64) -> u64 {
    let klen : u64 = mb_u64()
    if klen > 255u64 { return 1u64 }
    let mut i : u64 = 0u64
    while i < klen {
        MB_KEY[i] = mb_u8() as u8
        i = i + 1u64
    }
    let vt : u64 = mb_u32()
    if MB_IOERR != 0u8 { return 1u64 }
    if vt == 8u64 {
        /* string */
        let slen : u64 = mb_u64()
        if mb_keyis("general.architecture" as u64, klen) == 1u64 {
            let mut cap : u64 = slen
            if cap > 31u64 { cap = 31u64 }
            let mut a : u64 = 0u64
            while a < cap {
                MB_ARCH[a] = mb_u8() as u8
                a = a + 1u64
            }
            MB_ARCHN = cap
            mb_skip(slen - cap)
            return 0u64
        }
        mb_skip(slen)
        return 0u64
    }
    if vt == 9u64 {
        /* array: elem type + count */
        let et : u64 = mb_u32()
        let cnt : u64 = mb_u64()
        if et == 8u64 {
            let mut a : u64 = 0u64
            while a < cnt {
                let sl : u64 = mb_u64()
                mb_skip(sl)
                if MB_IOERR != 0u8 { return 1u64 }
                a = a + 1u64
            }
            return 0u64
        }
        if et == 9u64 { return 1u64 }
        let esz : u64 = mb_scalar_size(et)
        if esz == 0u64 { return 1u64 }
        mb_skip(esz * cnt)
        return 0u64
    }
    let ssz : u64 = mb_scalar_size(vt)
    if ssz == 0u64 { return 1u64 }
    /* scalar: extract the named facts */
    if mb_keyis("general.alignment" as u64, klen) == 1u64 {
        MB_ALIGN = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("split.no" as u64, klen) == 1u64 {
        MB_SPLITNO = mb_scalar_read(vt)
        MB_SPLITNO_F = 1u8
        return 0u64
    }
    if mb_keyis("split.count" as u64, klen) == 1u64 {
        let v : u64 = mb_scalar_read(vt)
        if MB_SPLITCT_F == 1u8 {
            if v != MB_SPLITCT { return 1u64 }
        }
        MB_SPLITCT = v
        MB_SPLITCT_F = 1u8
        return 0u64
    }
    if mb_keyis("split.tensors.count" as u64, klen) == 1u64 {
        MB_SPLITTN = mb_scalar_read(vt)
        MB_SPLITTN_F = 1u8
        return 0u64
    }
    if mb_keyis("deepseek2.embedding_length" as u64, klen) == 1u64 {
        MB_EMBED = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.block_count" as u64, klen) == 1u64 {
        MB_LAYERS = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.attention.head_count" as u64, klen) == 1u64 {
        MB_NHEAD = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.rope.dimension_count" as u64, klen) == 1u64 {
        MB_NROPE = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.attention.layer_norm_rms_epsilon" as u64, klen) == 1u64 {
        MB_EPSB = mb_scalar_read(vt)
        MB_EPSF = 1u8
        return 0u64
    }
    mb_skip(ssz)
    return 0u64
}

fn mb_align_up(x: u64, a: u64) -> u64 {
    return (x + a - 1u64) & (0u64 - a)
}

/* walk one tensor info; index t < MB_MAXT.  returns 0 ok, 1 refuse */
fn mb_tensor_one(shard: u64, t: u64) -> u64 {
    let nlen : u64 = mb_u64()
    if nlen > 255u64 { return 1u64 }
    /* keep the name only if this becomes a digestion candidate */
    let mut i : u64 = 0u64
    while i < nlen {
        if i < 255u64 { MB_KEY[i] = mb_u8() as u8 }
        if i >= 255u64 { mb_u8() }
        i = i + 1u64
    }
    let nd : u64 = mb_u32()
    if nd > 8u64 { return 1u64 }
    let mut ne : u64 = 1u64
    let mut ne0 : u64 = 0u64
    let mut d : u64 = 0u64
    while d < nd {
        let dim : u64 = mb_u64()
        if d == 0u64 { ne0 = dim }
        ne = ne * dim
        d = d + 1u64
    }
    let ty : u64 = mb_u32()
    let off : u64 = mb_u64()
    if MB_IOERR != 0u8 { return 1u64 }
    if ty < 64u64 { MB_HIST[ty] = MB_HIST[ty] + 1u64 }
    /* the router capture: first name containing "ffn_gate_inp" in ANY shard */
    if MB_C3_F == 0u8 {
        if nlen >= 12u64 {
            let ndl : u64 = "ffn_gate_inp" as u64
            let np : *u8 = ndl as *u8
            let mut si : u64 = 0u64
            let mut hit : u64 = 0u64
            while si + 12u64 <= nlen {
                let mut sj : u64 = 0u64
                let mut ok : u64 = 1u64
                while sj < 12u64 {
                    if MB_KEY[si + sj] != np[sj] { ok = 0u64   sj = 12u64 }
                    sj = sj + 1u64
                }
                if ok == 1u64 { hit = 1u64   si = nlen }
                si = si + 1u64
            }
            if hit == 1u64 {
                MB_C3_TYPE = ty
                MB_C3_OFF = off
                MB_C3_NE = ne
                MB_C3_NE0 = ne0
                MB_C3_SHARD = shard
                let mut cc : u64 = nlen
                if cc > 47u64 { cc = 47u64 }
                let mut ck : u64 = 0u64
                while ck < cc {
                    MB_C3_NAME[ck] = MB_KEY[ck]
                    ck = ck + 1u64
                }
                MB_C3_NN = cc
                MB_C3_F = 1u8
                MB_C3_HERE = 1u8
            }
        }
    }
    /* the gaze's captures: blk.0 attention, exact names */
    let mut gsl : u64 = 8u64
    if mb_keyis("blk.0.attn_norm.weight" as u64, nlen) == 1u64 { gsl = 0u64 }
    if mb_keyis("blk.0.attn_q_a.weight" as u64, nlen) == 1u64 { gsl = 1u64 }
    if mb_keyis("blk.0.attn_q_a_norm.weight" as u64, nlen) == 1u64 { gsl = 2u64 }
    if mb_keyis("blk.0.attn_q_b.weight" as u64, nlen) == 1u64 { gsl = 3u64 }
    if mb_keyis("blk.0.attn_kv_a_mqa.weight" as u64, nlen) == 1u64 { gsl = 4u64 }
    if mb_keyis("blk.0.attn_kv_a_norm.weight" as u64, nlen) == 1u64 { gsl = 5u64 }
    if mb_keyis("blk.0.attn_kv_b.weight" as u64, nlen) == 1u64 { gsl = 6u64 }
    if gsl < 8u64 {
        if MB_G_F[gsl] == 0u8 {
            MB_G_TYPE[gsl] = ty
            MB_G_OFF[gsl] = off
            MB_G_NE[gsl] = ne
            MB_G_NE0[gsl] = ne0
            MB_G_SH[gsl] = shard
            MB_G_F[gsl] = 1u8
            MB_G_HERE[gsl] = 1u8
        }
    }
    let bv : u64 = mb_tbv(ty)
    if bv == 0u64 { return 1u64 }
    if ne0 % bv != 0u64 { return 1u64 }
    let nb : u64 = (ne / bv) * mb_tbb(ty)
    MB_OFF[t] = off
    MB_NB[t] = nb
    /* digestion candidates: the first two quantized tensors of shard 1 */
    if shard == 1u64 {
        let mut isq : u64 = 0u64
        if ty == 8u64 { isq = 1u64 }
        if ty == 12u64 { isq = 1u64 }
        if ty == 14u64 { isq = 1u64 }
        if isq == 1u64 {
            if MB_C1_F == 0u8 {
                MB_C1_TYPE = ty
                MB_C1_OFF = off
                MB_C1_NE = ne
                MB_C1_NE0 = ne0
                let mut c : u64 = nlen
                if c > 63u64 { c = 63u64 }
                let mut k : u64 = 0u64
                while k < c {
                    MB_C1_NAME[k] = MB_KEY[k]
                    k = k + 1u64
                }
                MB_C1_NN = c
                MB_C1_F = 1u8
                return 0u64
            }
            if MB_C2_F == 0u8 {
                MB_C2_TYPE = ty
                MB_C2_OFF = off
                MB_C2_NE = ne
                MB_C2_NE0 = ne0
                let mut c2 : u64 = nlen
                if c2 > 63u64 { c2 = 63u64 }
                let mut k2 : u64 = 0u64
                while k2 < c2 {
                    MB_C2_NAME[k2] = MB_KEY[k2]
                    k2 = k2 + 1u64
                }
                MB_C2_NN = c2
                MB_C2_F = 1u8
            }
        }
    }
    return 0u64
}

/* full walk + conservation of one shard.  returns:
 * 0 conserved / 1 refused (named) / 2 io-broken / 3 not found */
fn mb_shard(i: u64) -> u64 {
    mb_mkpath(i)
    let f : u64 = fopen((&MB_PATH) as u64, "rb" as u64)
    if f == 0u64 { return 3u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    /* file size */
    _fseeki64(f, 0i64, 2i32)
    let fsz : u64 = _ftelli64(f) as u64
    mb_seek_abs(0u64)
    /* header */
    let magic : u64 = mb_u32()
    if magic != 0x46554747u64 {
        fclose(f)
        return 1u64
    }
    let ver : u64 = mb_u32()
    if ver != 3u64 {
        fclose(f)
        return 1u64
    }
    let ntens : u64 = mb_u64()
    let nkv : u64 = mb_u64()
    if ntens > MB_MAXT {
        fclose(f)
        return 1u64
    }
    /* per-shard extraction state */
    MB_ALIGN = MB_ALIGN_DEF
    MB_SPLITNO_F = 0u8
    /* the KV forest */
    let mut k : u64 = 0u64
    while k < nkv {
        if mb_kv_one(i) != 0u64 {
            fclose(f)
            return 1u64
        }
        k = k + 1u64
    }
    /* alignment must be a power of two */
    if MB_ALIGN == 0u64 {
        fclose(f)
        return 1u64
    }
    if (MB_ALIGN & (MB_ALIGN - 1u64)) != 0u64 {
        fclose(f)
        return 1u64
    }
    /* the tensor infos */
    let mut t : u64 = 0u64
    while t < ntens {
        if mb_tensor_one(i, t) != 0u64 {
            fclose(f)
            return 1u64
        }
        t = t + 1u64
    }
    if MB_IOERR != 0u8 {
        fclose(f)
        return 2u64
    }
    let data_base : u64 = mb_align_up(mb_pos(), MB_ALIGN)
    if MB_C3_HERE == 1u8 {
        MB_C3_DBASE = data_base
        MB_C3_HERE = 0u8
    }
    let mut gdb : u64 = 0u64
    while gdb < 8u64 {
        if MB_G_HERE[gdb] == 1u8 {
            MB_G_DB[gdb] = data_base
            MB_G_HERE[gdb] = 0u8
        }
        gdb = gdb + 1u64
    }
    if i == 1u64 {
        MB_DBASE1 = data_base
        let mut pc : u64 = 0u64
        while pc < 64u64 {
            MB_PATH1[pc] = MB_PATH[pc]
            pc = pc + 1u64
        }
    }
    /* sort spans by offset (insertion; ntens <= 512) */
    let mut a : u64 = 1u64
    while a < ntens {
        let ko : u64 = MB_OFF[a]
        let kn : u64 = MB_NB[a]
        let mut b : u64 = a
        let mut go : u8 = 1u8
        while go == 1u8 {
            go = 0u8
            if b > 0u64 {
                if MB_OFF[b - 1u64] > ko {
                    MB_OFF[b] = MB_OFF[b - 1u64]
                    MB_NB[b] = MB_NB[b - 1u64]
                    b = b - 1u64
                    go = 1u8
                }
            }
        }
        MB_OFF[b] = ko
        MB_NB[b] = kn
        a = a + 1u64
    }
    /* THE TILING: spans, each padded to the artifact's alignment, must fit
     * flush -- first at zero, each next exactly at the padded end of the
     * previous, the last ending within one pad of the file end */
    let mut expect : u64 = 0u64
    let mut last_end : u64 = 0u64
    t = 0u64
    while t < ntens {
        if MB_OFF[t] != expect {
            fclose(f)
            return 1u64
        }
        last_end = MB_OFF[t] + MB_NB[t]
        expect = mb_align_up(last_end, MB_ALIGN)
        t = t + 1u64
    }
    let end_abs : u64 = data_base + last_end
    if end_abs > fsz {
        fclose(f)
        return 1u64
    }
    let tail : u64 = fsz - end_abs
    if tail >= MB_ALIGN {
        fclose(f)
        return 1u64
    }
    /* split coherence bookkeeping */
    if i <= 16u64 {
        MB_SPNOSF[i - 1u64] = MB_SPLITNO_F
        MB_SPNOS[i - 1u64] = MB_SPLITNO
    }
    MB_TOT_TENS = MB_TOT_TENS + ntens
    MB_TOT_BYTES = MB_TOT_BYTES + fsz
    fclose(f)
    return 0u64
}

fn mb_arm362() -> u64 {
    MB_SHARDS = 0u64
    MB_TOT_TENS = 0u64
    MB_TOT_BYTES = 0u64
    MB_CONSERVED = 0u64
    MB_REFUSED = 0u64
    MB_FEAST = 0u8
    let mut i : u64 = 1u64
    let mut stop : u8 = 0u8
    while stop == 0u8 {
        let rc : u64 = mb_shard(i)
        if rc == 3u64 { stop = 1u8 }
        if rc == 0u64 { MB_CONSERVED = MB_CONSERVED + 1u64 }
        if rc == 1u64 { MB_REFUSED = MB_REFUSED + 1u64 }
        if rc == 2u64 {
            /* an unreadable shard is a broken door, not a lawful fast */
            return 362u64
        }
        if stop == 0u8 {
            MB_SHARDS = i
            i = i + 1u64
            if i > 99u64 { stop = 1u8 }
        }
    }
    if MB_SHARDS == 0u64 {
        mb_rs("the feast: absent (lawful) -- the door stands, the table waits" as u64)
        mb_rb(10u8)
        return 0u64
    }
    MB_FEAST = 1u8
    /* every found shard must have conserved (a refused shard is a red door) */
    if MB_CONSERVED != MB_SHARDS { return 362u64 }
    /* split coherence: if split KVs exist they must name this very feast --
     * indices all present and distinct, spanning 0..N-1 or 1..N; the declared
     * count equal to the number of files on the table */
    let mut split_ok : u64 = 0u64
    if MB_SPLITCT_F == 1u8 {
        if MB_SPLITCT != MB_SHARDS { return 362u64 }
        let mut allf : u64 = 1u64
        let mut mn : u64 = 0xFFFFFFFFFFFFFFFFu64
        let mut mx : u64 = 0u64
        let mut s : u64 = 0u64
        while s < MB_SHARDS {
            if MB_SPNOSF[s] == 0u8 { allf = 0u64 }
            if MB_SPNOSF[s] == 1u8 {
                if MB_SPNOS[s] < mn { mn = MB_SPNOS[s] }
                if MB_SPNOS[s] > mx { mx = MB_SPNOS[s] }
                let mut s2 : u64 = 0u64
                while s2 < s {
                    if MB_SPNOS[s2] == MB_SPNOS[s] { allf = 0u64 }
                    s2 = s2 + 1u64
                }
            }
            s = s + 1u64
        }
        if allf == 1u64 {
            /* distinct + contiguous: zero-based or one-based, both lawful */
            if mn == 0u64 {
                if mx == MB_SHARDS - 1u64 { split_ok = 1u64 }
            }
            if mn == 1u64 {
                if mx == MB_SHARDS { split_ok = 1u64 }
            }
        }
        if split_ok == 0u64 { return 362u64 }
    }
    /* the declared whole vs the derived whole */
    if MB_SPLITTN_F == 1u8 {
        if MB_SPLITTN != MB_TOT_TENS { return 362u64 }
    }
    mb_rs("the feast: shards=" as u64)
    mb_ru(MB_SHARDS)
    mb_rs(" split=" as u64)
    if MB_SPLITCT_F == 1u8 { mb_ru(MB_SPLITCT) }
    if MB_SPLITCT_F == 0u8 { mb_rs("none" as u64) }
    mb_rs(" arch=" as u64)
    let mut ai : u64 = 0u64
    while ai < MB_ARCHN {
        mb_rb(MB_ARCH[ai])
        ai = ai + 1u64
    }
    mb_rs(" tensors=" as u64)
    mb_ru(MB_TOT_TENS)
    mb_rs("/" as u64)
    if MB_SPLITTN_F == 1u8 { mb_ru(MB_SPLITTN) }
    if MB_SPLITTN_F == 0u8 { mb_ru(MB_TOT_TENS) }
    mb_rs(" bytes=" as u64)
    mb_ru(MB_TOT_BYTES)
    mb_rs(" conserved=" as u64)
    mb_ru(MB_CONSERVED)
    mb_rs("/" as u64)
    mb_ru(MB_SHARDS)
    mb_rs(" refused=" as u64)
    mb_ru(MB_REFUSED)
    mb_rb(10u8)
    if MB_EMBED != 0u64 {
        mb_rs("the anatomy: embed=" as u64)
        mb_ru(MB_EMBED)
        mb_rs(" layers=" as u64)
        mb_ru(MB_LAYERS)
        mb_rs(" align=" as u64)
        mb_ru(MB_ALIGN)
        mb_rb(10u8)
    }
    return 0u64
}

/* ==================== arm 363: THE DIGESTION ==================== */

/* read `n` raw bytes at absolute offset into MB_BLK (shard 1 must be open) */
fn mb_read_block(abs: u64, n: u64) -> u64 {
    mb_seek_abs(abs)
    let mut i : u64 = 0u64
    while i < n {
        MB_BLK[i] = mb_u8() as u8
        i = i + 1u64
    }
    if MB_IOERR != 0u8 { return 1u64 }
    return 0u64
}

/* q4_K sub-block scale/min unpack (the 6-bit law) */
var MB_SC : u64 = 0u64
var MB_SM : u64 = 0u64
fn mb_q4k_scale(j: u64) -> i32 {
    if j < 4u64 {
        MB_SC = (MB_BLK[4u64 + j] as u64) & 63u64
        MB_SM = (MB_BLK[8u64 + j] as u64) & 63u64
        return 0i32
    }
    /* llama.cpp: sc = (s[j+4] & 0xF) | ((s[j-4] >> 6) << 4)
     *            m  = (s[j+4] >> 4)  | ((s[j]   >> 6) << 4)
     * our BLK holds scales at bytes 4..15: s[k] = BLK[4+k] */
    let sj4 : u64 = MB_BLK[4u64 + j + 4u64] as u64
    let sjm4 : u64 = MB_BLK[4u64 + j - 4u64] as u64
    let sj : u64 = MB_BLK[4u64 + j] as u64
    MB_SC = (sj4 & 0xFu64) | ((sjm4 >> 6u64) << 4u64)
    MB_SM = (sj4 >> 4u64) | ((sj >> 6u64) << 4u64)
    return 0i32
}

/* decode one q4_K block from MB_BLK into out (256 mants, value = mant*2^-24).
 * two-engine: fills the factored accumulators for the distributive check.
 * returns 0 ok / arm code on nonfinite scale */
var MB_E2_SUM : i64 = 0i64            /* factored engine: sum */
var MB_D2P : u64 = 0u64               /* factored engine sumsq pieces */
var MB_D2R : u64 = 0u64
var MB_D2S : u64 = 0u64
var MB_MD : i64 = 0i64
var MB_MDM : i64 = 0i64

fn mb_dec_q4k(into_b: u64) -> u64 {
    let dbits : u64 = (MB_BLK[0] as u64) | ((MB_BLK[1] as u64) << 8u64)
    let mbits : u64 = (MB_BLK[2] as u64) | ((MB_BLK[3] as u64) << 8u64)
    MB_IOERR = 0u8
    let md : i64 = mb_f16_mant(dbits)
    let mdm : i64 = mb_f16_mant(mbits)
    if MB_IOERR != 0u8 { return 1u64 }
    MB_MD = md
    MB_MDM = mdm
    let mut sumsc : i64 = 0i64        /* sum over sub-blocks of sc*Q */
    let mut summ : i64 = 0i64         /* sum over sub-blocks of m*32 */
    MB_D2P = 0u64
    MB_D2R = 0u64
    MB_D2S = 0u64
    let mut t : u64 = 0u64
    while t < 4u64 {
        let mut half : u64 = 0u64
        while half < 2u64 {
            let j : u64 = t * 2u64 + half
            mb_q4k_scale(j)
            let sc : i64 = MB_SC as i64
            let mn : i64 = MB_SM as i64
            let mut q_acc : i64 = 0i64
            let mut l : u64 = 0u64
            while l < 32u64 {
                let raw : u64 = MB_BLK[16u64 + t * 32u64 + l] as u64
                let mut q : u64 = raw & 0xFu64
                if half == 1u64 { q = raw >> 4u64 }
                let x : i64 = sc * (q as i64)
                let vm : i64 = md * x - mdm * mn
                let idx : u64 = t * 64u64 + half * 32u64 + l
                if into_b == 0u64 { MB_VA[idx] = vm }
                if into_b == 1u64 { MB_VB[idx] = vm }
                q_acc = q_acc + (q as i64)
                /* factored sumsq pieces: P += x^2, R += x*m, S += m^2 */
                MB_D2P = MB_D2P + ((x * x) as u64)
                MB_D2R = MB_D2R + ((x * mn) as u64)
                MB_D2S = MB_D2S + ((mn * mn) as u64)
                l = l + 1u64
            }
            sumsc = sumsc + sc * q_acc
            summ = summ + mn * 32i64
            half = half + 1u64
        }
        t = t + 1u64
    }
    MB_E2_SUM = md * sumsc - mdm * summ
    return 0u64
}

/* decode one q6_K block; same contract as q4 */
fn mb_dec_q6k(into_b: u64) -> u64 {
    let dbits : u64 = (MB_BLK[208] as u64) | ((MB_BLK[209] as u64) << 8u64)
    MB_IOERR = 0u8
    let md : i64 = mb_f16_mant(dbits)
    if MB_IOERR != 0u8 { return 1u64 }
    MB_MD = md
    MB_MDM = 0i64
    let mut sumsc : i64 = 0i64
    MB_D2P = 0u64
    MB_D2R = 0u64
    MB_D2S = 0u64
    let mut n2 : u64 = 0u64
    while n2 < 2u64 {
        let vbase : u64 = n2 * 128u64
        let qlb : u64 = n2 * 64u64
        let qhb : u64 = 128u64 + n2 * 32u64
        let scb : u64 = 192u64 + n2 * 8u64
        let mut l : u64 = 0u64
        while l < 32u64 {
            let isx : u64 = l / 16u64
            let ql0 : u64 = MB_BLK[qlb + l] as u64
            let ql32 : u64 = MB_BLK[qlb + l + 32u64] as u64
            let qh : u64 = MB_BLK[qhb + l] as u64
            let q1 : i64 = (((ql0 & 0xFu64) | (((qh >> 0u64) & 3u64) << 4u64)) as i64) - 32i64
            let q2 : i64 = (((ql32 & 0xFu64) | (((qh >> 2u64) & 3u64) << 4u64)) as i64) - 32i64
            let q3 : i64 = (((ql0 >> 4u64) | (((qh >> 4u64) & 3u64) << 4u64)) as i64) - 32i64
            let q4 : i64 = (((ql32 >> 4u64) | (((qh >> 6u64) & 3u64) << 4u64)) as i64) - 32i64
            let mut w : u64 = 0u64
            while w < 4u64 {
                let mut qv : i64 = q1
                if w == 1u64 { qv = q2 }
                if w == 2u64 { qv = q3 }
                if w == 3u64 { qv = q4 }
                let sidx : u64 = scb + isx + w * 2u64
                let scraw : u64 = MB_BLK[sidx] as u64
                let mut sc : i64 = scraw as i64
                if scraw >= 128u64 { sc = (scraw as i64) - 256i64 }
                let x : i64 = sc * qv
                let vm : i64 = md * x
                let idx : u64 = vbase + w * 32u64 + l
                if into_b == 0u64 { MB_VA[idx] = vm }
                if into_b == 1u64 { MB_VB[idx] = vm }
                /* factored: P += x^2 (R,S stay zero: no min term) */
                MB_D2P = MB_D2P + ((x * x) as u64)
                sumsc = sumsc + x
                w = w + 1u64
            }
            l = l + 1u64
        }
        n2 = n2 + 1u64
    }
    MB_E2_SUM = md * sumsc
    return 0u64
}

/* decode one q8_0 block (32 values) */
fn mb_dec_q80(into_b: u64) -> u64 {
    let dbits : u64 = (MB_BLK[0] as u64) | ((MB_BLK[1] as u64) << 8u64)
    MB_IOERR = 0u8
    let md : i64 = mb_f16_mant(dbits)
    if MB_IOERR != 0u8 { return 1u64 }
    MB_MD = md
    MB_MDM = 0i64
    let mut sq : i64 = 0i64
    MB_D2P = 0u64
    MB_D2R = 0u64
    MB_D2S = 0u64
    let mut l : u64 = 0u64
    while l < 32u64 {
        let raw : u64 = MB_BLK[2u64 + l] as u64
        let mut q : i64 = raw as i64
        if raw >= 128u64 { q = (raw as i64) - 256i64 }
        let vm : i64 = md * q
        if into_b == 0u64 { MB_VA[l] = vm }
        if into_b == 1u64 { MB_VB[l] = vm }
        sq = sq + q
        MB_D2P = MB_D2P + ((q * q) as u64)
        l = l + 1u64
    }
    MB_E2_SUM = md * sq
    return 0u64
}

fn mb_type_bytes(ty: u64) -> u64 { return mb_tbb(ty) }
fn mb_type_vals(ty: u64) -> u64 { return mb_tbv(ty) }

fn mb_type_name_rep(ty: u64) -> i32 {
    if ty == 8u64 { mb_rs("q8_0" as u64)   return 0i32 }
    if ty == 12u64 { mb_rs("q4_K" as u64)   return 0i32 }
    if ty == 14u64 { mb_rs("q6_K" as u64)   return 0i32 }
    mb_rs("t" as u64)
    mb_ru(ty)
    return 0i32
}

/* digest block `blk` of candidate `c` (0/1) into VA/VB.  E1 per-value sums
 * vs E2 factored sums must agree EXACTLY (the distributive theorem).
 * On success stores sum/sumsq into the candidate slots.  returns 0 ok */
fn mb_digest(c: u64, blk: u64) -> u64 {
    let mut ty : u64 = MB_C1_TYPE
    let mut off : u64 = MB_C1_OFF
    if c == 1u64 {
        ty = MB_C2_TYPE
        off = MB_C2_OFF
    }
    let bb : u64 = mb_type_bytes(ty)
    let bv : u64 = mb_type_vals(ty)
    let abs : u64 = MB_DBASE1 + off + blk * bb
    if mb_read_block(abs, bb) != 0u64 { return 1u64 }
    let mut rc : u64 = 1u64
    if ty == 12u64 { rc = mb_dec_q4k(c) }
    if ty == 14u64 { rc = mb_dec_q6k(c) }
    if ty == 8u64 { rc = mb_dec_q80(c) }
    if rc != 0u64 { return 1u64 }
    /* E1: per-value walk (association order 1) */
    let mut s1 : i64 = 0i64
    MB_X[0] = 0u64
    MB_X[1] = 0u64
    MB_X[2] = 0u64
    let mut i : u64 = 0u64
    while i < bv {
        let mut vm : i64 = 0i64
        if c == 0u64 { vm = MB_VA[i] }
        if c == 1u64 { vm = MB_VB[i] }
        s1 = s1 + vm
        let mut mag : u64 = vm as u64
        if vm < 0i64 { mag = (0i64 - vm) as u64 }
        mb_mul64(mag, mag)
        MB_Z[0] = MB_MLO
        MB_Z[1] = MB_MHI
        MB_Z[2] = 0u64
        mb_x_add_z()
        i = i + 1u64
    }
    /* E2 sum: the factored form (association order 2) */
    if s1 != MB_E2_SUM { return 1u64 }
    /* E2 sumsq: Md^2*P - 2*Md*Mdm*R + Mdm^2*S in 3-limb arithmetic */
    let mut mdm_mag : u64 = MB_MD as u64
    if MB_MD < 0i64 { mdm_mag = (0i64 - MB_MD) as u64 }
    let mut mmm_mag : u64 = MB_MDM as u64
    if MB_MDM < 0i64 { mmm_mag = (0i64 - MB_MDM) as u64 }
    /* Y := Md^2 * P */
    mb_mul64(mdm_mag, mdm_mag)
    mb_mul128by64(MB_MHI, MB_MLO, MB_D2P)
    MB_Y[0] = MB_Z[0]
    MB_Y[1] = MB_Z[1]
    MB_Y[2] = MB_Z[2]
    /* Y += Mdm^2 * S */
    mb_mul64(mmm_mag, mmm_mag)
    mb_mul128by64(MB_MHI, MB_MLO, MB_D2S)
    let t0 : u64 = MB_Y[0] + MB_Z[0]
    let mut tc : u64 = 0u64
    if t0 < MB_Z[0] { tc = 1u64 }
    let t1a : u64 = MB_Y[1] + MB_Z[1]
    let mut tc1 : u64 = 0u64
    if t1a < MB_Z[1] { tc1 = 1u64 }
    let t1 : u64 = t1a + tc
    if t1 < tc { tc1 = tc1 + 1u64 }
    MB_Y[0] = t0
    MB_Y[1] = t1
    MB_Y[2] = MB_Y[2] + MB_Z[2] + tc1
    /* Y -= 2*Md*Mdm*R when Md*Mdm > 0; += when < 0 (the cross term) */
    mb_mul64(mdm_mag, mmm_mag)
    mb_mul128by64(MB_MHI, MB_MLO, 2u64 * MB_D2R)
    let mut same_sign : u64 = 0u64
    if MB_MD > 0i64 {
        if MB_MDM > 0i64 { same_sign = 1u64 }
    }
    if MB_MD < 0i64 {
        if MB_MDM < 0i64 { same_sign = 1u64 }
    }
    /* swap X into Y-slot temporarily: do the cross op on Y via X machinery */
    let sx0 : u64 = MB_X[0]
    let sx1 : u64 = MB_X[1]
    let sx2 : u64 = MB_X[2]
    MB_X[0] = MB_Y[0]
    MB_X[1] = MB_Y[1]
    MB_X[2] = MB_Y[2]
    if same_sign == 1u64 { mb_x_sub_z() }
    if same_sign == 0u64 {
        if MB_D2R != 0u64 { mb_x_add_z() }
    }
    MB_Y[0] = MB_X[0]
    MB_Y[1] = MB_X[1]
    MB_Y[2] = MB_X[2]
    MB_X[0] = sx0
    MB_X[1] = sx1
    MB_X[2] = sx2
    /* THE DISTRIBUTIVE THEOREM: the two engines must agree exactly */
    if mb_x_cmp_y() != 0i64 { return 1u64 }
    if c == 0u64 {
        MB_SUMA = s1
        MB_SSA0 = MB_X[0]
        MB_SSA1 = MB_X[1]
        MB_NVA = bv
    }
    if c == 1u64 {
        MB_SUMB = s1
        MB_SSB0 = MB_X[0]
        MB_SSB1 = MB_X[1]
        MB_NVB = bv
    }
    if MB_X[2] != 0u64 { return 1u64 }
    return 0u64
}

fn mb_arm363() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_C1_F == 0u8 { return 363u64 }
    if MB_C2_F == 0u8 { return 363u64 }
    /* reopen shard 1 for ranged reads */
    let f : u64 = fopen((&MB_PATH1) as u64, "rb" as u64)
    if f == 0u64 { return 363u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    if mb_digest(0u64, 0u64) != 0u64 {
        fclose(f)
        return 363u64
    }
    if mb_digest(1u64, 0u64) != 0u64 {
        fclose(f)
        return 363u64
    }
    fclose(f)
    mb_rs("the digestion: " as u64)
    mb_type_name_rep(MB_C1_TYPE)
    mb_rs(" " as u64)
    let mut i : u64 = 0u64
    while i < MB_C1_NN {
        mb_rb(MB_C1_NAME[i])
        i = i + 1u64
    }
    mb_rs(" + " as u64)
    mb_type_name_rep(MB_C2_TYPE)
    mb_rs(" " as u64)
    i = 0u64
    while i < MB_C2_NN {
        mb_rb(MB_C2_NAME[i])
        i = i + 1u64
    }
    mb_rs(" block0 sum1=" as u64)
    mb_ri(MB_SUMA)
    mb_rs("*2^-24 sum2=" as u64)
    mb_ri(MB_SUMB)
    mb_rs("*2^-24 distributive=ok" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ==================== arm 364: THE WITNESS ==================== */

var MB_W_BITS : u64 = 0u64
var MB_W_K : u64 = 0u64
var MB_W_G0 : u64 = 0u64
var MB_W_G1 : u64 = 0u64

/* try the standing sumsq (SSA1,SSA0): canonical odd mantissa must exceed
 * 24 bits; compute the round-to-nearest-even fp32 gap.  returns 1 = witness
 * found, 0 = representable (walk on) */
fn mb_witness_try() -> u64 {
    let mut h : u64 = MB_SSA1
    let mut l : u64 = MB_SSA0
    if (h | l) == 0u64 { return 0u64 }
    /* strip twos: the canonical exponent k = 48 - tz */
    let mut tz : u64 = 0u64
    let mut go : u8 = 1u8
    while go == 1u8 {
        go = 0u8
        if (l & 1u64) == 0u64 {
            l = (l >> 1u64) | (h << 63u64)
            h = h >> 1u64
            tz = tz + 1u64
            go = 1u8
        }
    }
    let mut bl : u64 = mb_bitlen(h)
    if bl != 0u64 { bl = bl + 64u64 }
    if bl == 0u64 { bl = mb_bitlen(l) }
    MB_W_BITS = bl
    MB_W_K = 48u64 - tz
    if bl <= 24u64 { return 0u64 }
    /* the low (bl-24) bits are the part fp32 must throw away; the mantissa
     * is ODD, so the lowest bit is set and the gap can never be zero */
    let sh : u64 = bl - 24u64
    let mut lo_h : u64 = 0u64
    let mut lo_l : u64 = 0u64
    if sh >= 64u64 {
        lo_l = l
        lo_h = h & ((1u64 << (sh - 64u64)) - 1u64)
    }
    if sh < 64u64 {
        lo_l = l & ((1u64 << sh) - 1u64)
        lo_h = 0u64
    }
    /* round to nearest even: gap = min(low, 2^sh - low) in exact integers */
    let mut g_h : u64 = lo_h
    let mut g_l : u64 = lo_l
    /* compute 2^sh - low into (c_h, c_l) */
    let mut c_h : u64 = 0u64
    let mut c_l : u64 = 0u64
    if sh < 64u64 {
        c_l = (1u64 << sh) - lo_l
        c_h = 0u64
    }
    if sh >= 64u64 {
        /* 2^sh = (1 << (sh-64)) : 0 ; subtract (lo_h, lo_l) */
        let top : u64 = 1u64 << (sh - 64u64)
        c_l = 0u64 - lo_l
        c_h = top - lo_h
        if lo_l != 0u64 { c_h = c_h - 1u64 }
    }
    /* choose the smaller distance (round-to-nearest; the tie cannot happen
     * with an odd mantissa when sh >= 1 and low has its lsb set unless low
     * is exactly half -- half has lsb 0 for sh >= 2, and sh > 24 here) */
    let mut use_c : u64 = 0u64
    if c_h < g_h { use_c = 1u64 }
    if c_h == g_h {
        if c_l < g_l { use_c = 1u64 }
    }
    if use_c == 1u64 {
        g_h = c_h
        g_l = c_l
    }
    MB_W_G0 = g_l
    MB_W_G1 = g_h
    return 1u64
}

fn mb_arm364() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    /* the standing block's sumsq; walk later blocks only if fp32 could
     * hold the first (bounded, deterministic first-hit) */
    let mut found : u64 = mb_witness_try()
    let mut blk : u64 = 1u64
    let nblocks : u64 = MB_C1_NE / mb_type_vals(MB_C1_TYPE)
    let mut bound : u64 = nblocks
    if bound > 64u64 { bound = 64u64 }
    let mut f : u64 = 0u64
    if found == 0u64 {
        f = fopen((&MB_PATH1) as u64, "rb" as u64)
        if f == 0u64 { return 364u64 }
        MB_F = f
        MB_IOERR = 0u8
        MB_WBASE = 0u64
        MB_WLEN = 0u64
        MB_WPOS = 0u64
    }
    while found == 0u64 {
        if blk >= bound {
            fclose(f)
            return 364u64
        }
        if mb_digest(0u64, blk) != 0u64 {
            fclose(f)
            return 364u64
        }
        found = mb_witness_try()
        blk = blk + 1u64
    }
    if f != 0u64 { fclose(f) }
    mb_rs("the witness: sumsq odd-mantissa bits=" as u64)
    mb_ru(MB_W_BITS)
    mb_rs(" > 24 at 2^-" as u64)
    mb_ru(MB_W_K)
    mb_rs(" gap=" as u64)
    MB_X[0] = MB_W_G0
    MB_X[1] = MB_W_G1
    MB_X[2] = 0u64
    mb_rx3()
    mb_rs(" -- fp32 must round, the organ holds it exact" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ==================== arm 365: THE KRISIS ==================== */

fn mb_arm365() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    /* (a) certified argmax over the digested block by two paths.
     * NOTE: the standing MB_VA may hold a later block (the witness walk);
     * that block is real flesh all the same -- the decision is certified
     * on whatever exact values stand. */
    let n : u64 = MB_NVA
    if n == 0u64 { return 365u64 }
    let mut best : u64 = 0u64
    let mut i : u64 = 1u64
    while i < n {
        if MB_VA[i] > MB_VA[best] { best = i }
        i = i + 1u64
    }
    /* path 2: count how many values strictly exceed each candidate; the
     * argmax is the value nothing exceeds, found without comparing to the
     * path-1 winner's index */
    let mut best2 : u64 = 0xFFFFFFFFFFFFFFFFu64
    let mut ties : u64 = 0u64
    i = 0u64
    while i < n {
        let mut above : u64 = 0u64
        let mut j : u64 = 0u64
        while j < n {
            if MB_VA[j] > MB_VA[i] { above = above + 1u64 }
            j = j + 1u64
        }
        if above == 0u64 {
            ties = ties + 1u64
            if best2 == 0xFFFFFFFFFFFFFFFFu64 { best2 = i }
        }
        i = i + 1u64
    }
    if best2 != best { return 365u64 }
    if ties == 0u64 { return 365u64 }
    /* (b) the RMSNorm-shaped comparison on real sub-rows: a/sqrt(S1) vs
     * b/sqrt(S2) decided as sign(a*sqrt(S2) - b*sqrt(S1)) by two engines.
     * Sub-rows: the first 16 values of each digested block, with a mantissa
     * guard so every intermediate stays in-lane. */
    let mut a : i64 = 0i64
    let mut s1 : u64 = 0u64
    let mut b : i64 = 0i64
    let mut s2 : u64 = 0u64
    let mut guard : u64 = 0u64
    i = 0u64
    while i < 16u64 {
        let va : i64 = MB_VA[i]
        let vb : i64 = MB_VB[i]
        let mut ma : u64 = va as u64
        if va < 0i64 { ma = (0i64 - va) as u64 }
        let mut mbv : u64 = vb as u64
        if vb < 0i64 { mbv = (0i64 - vb) as u64 }
        if ma >= 536870912u64 { guard = 1u64 }
        if mbv >= 536870912u64 { guard = 1u64 }
        a = a + va
        b = b + vb
        s1 = s1 + ((va * va) as u64)
        s2 = s2 + ((vb * vb) as u64)
        i = i + 1u64
    }
    if guard == 1u64 { return 365u64 }
    if s1 == 0u64 { return 365u64 }
    if s2 == 0u64 { return 365u64 }
    /* engine 1: elementary square-compare with sign analysis (192-bit) */
    let mut e1 : i64 = 0i64
    let mut sa : i64 = 0i64
    if a > 0i64 { sa = 1i64 }
    if a < 0i64 { sa = 0i64 - 1i64 }
    let mut sb : i64 = 0i64
    if b > 0i64 { sb = 1i64 }
    if b < 0i64 { sb = 0i64 - 1i64 }
    if sa > sb { e1 = 1i64 }
    if sa < sb { e1 = 0i64 - 1i64 }
    if sa == sb {
        if sa == 0i64 { e1 = 0i64 }
        if sa != 0i64 {
            let mut ma2 : u64 = a as u64
            if a < 0i64 { ma2 = (0i64 - a) as u64 }
            let mut mb2 : u64 = b as u64
            if b < 0i64 { mb2 = (0i64 - b) as u64 }
            /* X := a^2 * S2 ; Y := b^2 * S1 */
            mb_mul64(ma2, ma2)
            mb_mul128by64(MB_MHI, MB_MLO, s2)
            MB_X[0] = MB_Z[0]
            MB_X[1] = MB_Z[1]
            MB_X[2] = MB_Z[2]
            mb_mul64(mb2, mb2)
            mb_mul128by64(MB_MHI, MB_MLO, s1)
            MB_Y[0] = MB_Z[0]
            MB_Y[1] = MB_Z[1]
            MB_Y[2] = MB_Z[2]
            let cmp : i64 = mb_x_cmp_y()
            e1 = cmp
            if sa < 0i64 { e1 = 0i64 - cmp }
        }
    }
    /* engine 2: the standing surd kernel -- sign(0 + a*sqrt(S2) - b*sqrt(S1)) */
    let e2 : i32 = ui_sign_bi_big(0i64, a, s2 as i64, 0i64 - b, s1 as i64)
    if (e2 as i64) != e1 { return 365u64 }
    /* the reflexive control: a*sqrt(S1) - a*sqrt(S1) must vanish by the kernel */
    let ez : i32 = ui_sign_bi_big(0i64, a, s1 as i64, 0i64 - a, s1 as i64)
    if ez != 0i32 { return 365u64 }
    mb_rs("the krisis: argmax=" as u64)
    mb_ru(best)
    mb_rs("/" as u64)
    mb_ru(n)
    mb_rs(" ties=" as u64)
    mb_ru(ties)
    mb_rs(" no-exp (monotone premise named) sign1=" as u64)
    mb_ri(e1)
    mb_rs(" sign2=" as u64)
    mb_ri(e2 as i64)
    mb_rs(" agree=ok" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ============ arms 370/371: THE SYNAPSE + THE STOMACH ============ */

/* signed 192-bit accumulators: which 0 = the running total, 1 = the block
 * partial, 2 = the regroup checker */
var MB_TS : i64 = 0i64
var MB_T0 : u64 = 0u64
var MB_T1 : u64 = 0u64
var MB_T2 : u64 = 0u64
var MB_BS : i64 = 0i64
var MB_B0 : u64 = 0u64
var MB_B1 : u64 = 0u64
var MB_B2 : u64 = 0u64
var MB_GS : i64 = 0i64
var MB_G0 : u64 = 0u64
var MB_G1 : u64 = 0u64
var MB_G2 : u64 = 0u64

fn mb_sacc_clear(which: u64) -> i32 {
    if which == 0u64 { MB_TS = 0i64   MB_T0 = 0u64   MB_T1 = 0u64   MB_T2 = 0u64 }
    if which == 1u64 { MB_BS = 0i64   MB_B0 = 0u64   MB_B1 = 0u64   MB_B2 = 0u64 }
    if which == 2u64 { MB_GS = 0i64   MB_G0 = 0u64   MB_G1 = 0u64   MB_G2 = 0u64 }
    return 0i32
}

fn mb_sacc_add(which: u64, ss: i64, s0: u64, s1: u64, s2: u64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let mut ds : i64 = 0i64
    let mut d0 : u64 = 0u64
    let mut d1 : u64 = 0u64
    let mut d2 : u64 = 0u64
    if which == 0u64 { ds = MB_TS   d0 = MB_T0   d1 = MB_T1   d2 = MB_T2 }
    if which == 1u64 { ds = MB_BS   d0 = MB_B0   d1 = MB_B1   d2 = MB_B2 }
    if which == 2u64 { ds = MB_GS   d0 = MB_G0   d1 = MB_G1   d2 = MB_G2 }
    let mut r_s : i64 = ds
    let mut r0 : u64 = d0
    let mut r1 : u64 = d1
    let mut r2 : u64 = d2
    if ds == 0i64 {
        r_s = ss
        r0 = s0
        r1 = s1
        r2 = s2
    }
    if ds == ss {
        let a0 : u64 = d0 + s0
        let mut c0 : u64 = 0u64
        if a0 < s0 { c0 = 1u64 }
        let a1a : u64 = d1 + s1
        let mut c1 : u64 = 0u64
        if a1a < s1 { c1 = 1u64 }
        let a1 : u64 = a1a + c0
        if a1 < c0 { c1 = c1 + 1u64 }
        r0 = a0
        r1 = a1
        r2 = d2 + s2 + c1
        r_s = ds
    }
    if ds != 0i64 {
        if ds != ss {
            let mut cmp : i64 = 0i64
            if d2 > s2 { cmp = 1i64 }
            if d2 < s2 { cmp = 0i64 - 1i64 }
            if cmp == 0i64 {
                if d1 > s1 { cmp = 1i64 }
                if d1 < s1 { cmp = 0i64 - 1i64 }
            }
            if cmp == 0i64 {
                if d0 > s0 { cmp = 1i64 }
                if d0 < s0 { cmp = 0i64 - 1i64 }
            }
            if cmp == 0i64 {
                r_s = 0i64
                r0 = 0u64
                r1 = 0u64
                r2 = 0u64
            }
            if cmp > 0i64 {
                let mut b : u64 = 0u64
                let x0 : u64 = d0 - s0
                if d0 < s0 { b = 1u64 }
                let mut b1 : u64 = 0u64
                let x1a : u64 = d1 - s1
                if d1 < s1 { b1 = 1u64 }
                let x1 : u64 = x1a - b
                if x1a < b { b1 = b1 + 1u64 }
                r0 = x0
                r1 = x1
                r2 = d2 - s2 - b1
                r_s = ds
            }
            if cmp < 0i64 {
                let mut b2 : u64 = 0u64
                let y0 : u64 = s0 - d0
                if s0 < d0 { b2 = 1u64 }
                let mut b3 : u64 = 0u64
                let y1a : u64 = s1 - d1
                if s1 < d1 { b3 = 1u64 }
                let y1 : u64 = y1a - b2
                if y1a < b2 { b3 = b3 + 1u64 }
                r0 = y0
                r1 = y1
                r2 = s2 - d2 - b3
                r_s = ss
            }
        }
    }
    if which == 0u64 { MB_TS = r_s   MB_T0 = r0   MB_T1 = r1   MB_T2 = r2 }
    if which == 1u64 { MB_BS = r_s   MB_B0 = r0   MB_B1 = r1   MB_B2 = r2 }
    if which == 2u64 { MB_GS = r_s   MB_G0 = r0   MB_G1 = r1   MB_G2 = r2 }
    return 0i32
}

/* unsigned 192-bit norms: u.u and v.v */
var MB_UU0 : u64 = 0u64
var MB_UU1 : u64 = 0u64
var MB_UU2 : u64 = 0u64
var MB_VV0 : u64 = 0u64
var MB_VV1 : u64 = 0u64
var MB_VV2 : u64 = 0u64

fn mb_uu_add(hi: u64, lo: u64) -> i32 {
    let a0 : u64 = MB_UU0 + lo
    let mut c0 : u64 = 0u64
    if a0 < lo { c0 = 1u64 }
    let a1a : u64 = MB_UU1 + hi
    let mut c1 : u64 = 0u64
    if a1a < hi { c1 = 1u64 }
    let a1 : u64 = a1a + c0
    if a1 < c0 { c1 = c1 + 1u64 }
    MB_UU0 = a0
    MB_UU1 = a1
    MB_UU2 = MB_UU2 + c1
    return 0i32
}

fn mb_vv_add(hi: u64, lo: u64) -> i32 {
    let a0 : u64 = MB_VV0 + lo
    let mut c0 : u64 = 0u64
    if a0 < lo { c0 = 1u64 }
    let a1a : u64 = MB_VV1 + hi
    let mut c1 : u64 = 0u64
    if a1a < hi { c1 = 1u64 }
    let a1 : u64 = a1a + c0
    if a1 < c0 { c1 = c1 + 1u64 }
    MB_VV0 = a0
    MB_VV1 = a1
    MB_VV2 = MB_VV2 + c1
    return 0i32
}

/* per-block synapse partials (the regroup engine's evidence) */
var MB_PS : [i64; 64]
var MB_PP0 : [u64; 64]
var MB_PP1 : [u64; 64]
var MB_PP2 : [u64; 64]
var MB_NP : u64 = 0u64

/* 384-bit product for the exact Cauchy-Schwarz: MB_R6 = a * b (3x3 limbs) */
var MB_R6 : [u64; 6]
var MB_R6A : [u64; 6]

fn mb_r6_addat(k: u64, v: u64) -> i32 {
    if v == 0u64 { return 0i32 }
    let s : u64 = MB_R6[k] + v
    let mut carry : u64 = 0u64
    if s < v { carry = 1u64 }
    MB_R6[k] = s
    let mut kk : u64 = k + 1u64
    while carry == 1u64 {
        let s2 : u64 = MB_R6[kk] + 1u64
        carry = 0u64
        if s2 == 0u64 { carry = 1u64 }
        MB_R6[kk] = s2
        kk = kk + 1u64
    }
    return 0i32
}

fn mb_mul192(a0: u64, a1: u64, a2: u64, b0: u64, b1: u64, b2: u64) -> i32 {
    let mut k : u64 = 0u64
    while k < 6u64 {
        MB_R6[k] = 0u64
        k = k + 1u64
    }
    let mut i : u64 = 0u64
    while i < 3u64 {
        let mut ai : u64 = a0
        if i == 1u64 { ai = a1 }
        if i == 2u64 { ai = a2 }
        let mut j : u64 = 0u64
        while j < 3u64 {
            let mut bj : u64 = b0
            if j == 1u64 { bj = b1 }
            if j == 2u64 { bj = b2 }
            mb_mul64(ai, bj)
            mb_r6_addat(i + j, MB_MLO)
            mb_r6_addat(i + j + 1u64, MB_MHI)
            j = j + 1u64
        }
        i = i + 1u64
    }
    return 0i32
}

/* compare MB_R6A vs MB_R6: -1/0/+1 */
fn mb_cmp6() -> i64 {
    let mut k : u64 = 6u64
    while k != 0u64 {
        k = k - 1u64
        if MB_R6A[k] > MB_R6[k] { return 1i64 }
        if MB_R6A[k] < MB_R6[k] { return 0i64 - 1i64 }
    }
    return 0i64
}

/* stream one full row pair: candidate 0 row ru dotted with candidate 1 row
 * rv, bpr blocks per row.  Every block passes the two-engine digest; the
 * dot, both norms and per-block partials accumulate.  returns 0 ok */
fn mb_synapse_stream(ru: u64, rv: u64, bpr: u64) -> u64 {
    mb_sacc_clear(0u64)
    MB_UU0 = 0u64
    MB_UU1 = 0u64
    MB_UU2 = 0u64
    MB_VV0 = 0u64
    MB_VV1 = 0u64
    MB_VV2 = 0u64
    MB_NP = 0u64
    let mut b : u64 = 0u64
    while b < bpr {
        if mb_digest(0u64, ru * bpr + b) != 0u64 { return 1u64 }
        if mb_digest(1u64, rv * bpr + b) != 0u64 { return 1u64 }
        mb_sacc_clear(1u64)
        let mut e : u64 = 0u64
        while e < 256u64 {
            let va : i64 = MB_VA[e]
            let vb : i64 = MB_VB[e]
            let mut ma : u64 = va as u64
            if va < 0i64 { ma = (0i64 - va) as u64 }
            let mut mbv : u64 = vb as u64
            if vb < 0i64 { mbv = (0i64 - vb) as u64 }
            if va != 0i64 {
                if vb != 0i64 {
                    let mut sgn : i64 = 1i64
                    if va < 0i64 {
                        if vb > 0i64 { sgn = 0i64 - 1i64 }
                    }
                    if va > 0i64 {
                        if vb < 0i64 { sgn = 0i64 - 1i64 }
                    }
                    mb_mul64(ma, mbv)
                    mb_sacc_add(1u64, sgn, MB_MLO, MB_MHI, 0u64)
                }
                mb_mul64(ma, ma)
                mb_uu_add(MB_MHI, MB_MLO)
            }
            if va == 0i64 {
                if vb != 0i64 {
                    mb_mul64(mbv, mbv)
                    mb_vv_add(MB_MHI, MB_MLO)
                }
            }
            if va != 0i64 {
                if vb != 0i64 {
                    mb_mul64(mbv, mbv)
                    mb_vv_add(MB_MHI, MB_MLO)
                }
            }
            e = e + 1u64
        }
        MB_PS[b] = MB_BS
        MB_PP0[b] = MB_B0
        MB_PP1[b] = MB_B1
        MB_PP2[b] = MB_B2
        mb_sacc_add(0u64, MB_BS, MB_B0, MB_B1, MB_B2)
        b = b + 1u64
    }
    MB_NP = bpr
    return 0u64
}

/* does row r of candidate c carry any nonzero value?  2 = io/decode red */
fn mb_row_alive(c: u64, r: u64, bpr: u64) -> u64 {
    let mut b : u64 = 0u64
    while b < bpr {
        if mb_digest(c, r * bpr + b) != 0u64 { return 2u64 }
        let mut e : u64 = 0u64
        while e < 256u64 {
            let mut v : i64 = 0i64
            if c == 0u64 { v = MB_VA[e] }
            if c == 1u64 { v = MB_VB[e] }
            if v != 0i64 { return 1u64 }
            e = e + 1u64
        }
        b = b + 1u64
    }
    return 0u64
}

var MB_SYN_RU : u64 = 0u64
var MB_SYN_RV : u64 = 0u64
var MB_SYN_CS : u64 = 0u64            /* 1 = strict, 2 = proportional */
var MB_SYN_S : i64 = 0i64
var MB_SYN_0 : u64 = 0u64
var MB_SYN_1 : u64 = 0u64
var MB_SYN_2 : u64 = 0u64
var MB_SYN_U0 : u64 = 0u64
var MB_SYN_U1 : u64 = 0u64
var MB_SYN_U2 : u64 = 0u64
var MB_SYN_V0 : u64 = 0u64
var MB_SYN_V1 : u64 = 0u64
var MB_SYN_V2 : u64 = 0u64

fn mb_arm370() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_C1_F == 0u8 { return 370u64 }
    if MB_C2_F == 0u8 { return 370u64 }
    /* the synapse law: one shared embedding axis, k-quant lattice both sides */
    if MB_C1_NE0 != MB_C2_NE0 { return 370u64 }
    if mb_tbv(MB_C1_TYPE) != 256u64 { return 370u64 }
    if mb_tbv(MB_C2_TYPE) != 256u64 { return 370u64 }
    let bpr : u64 = MB_C1_NE0 / 256u64
    if bpr == 0u64 { return 370u64 }
    if bpr > 64u64 { return 370u64 }
    let rows_u : u64 = MB_C1_NE / MB_C1_NE0
    let rows_v : u64 = MB_C2_NE / MB_C2_NE0
    let f : u64 = fopen((&MB_PATH1) as u64, "rb" as u64)
    if f == 0u64 { return 370u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    /* deterministic row choice: the first living row of each side */
    let mut ru : u64 = 0u64
    let mut found : u64 = 0u64
    while found == 0u64 {
        if ru >= 8u64 {
            fclose(f)
            return 370u64
        }
        if ru >= rows_u {
            fclose(f)
            return 370u64
        }
        let al : u64 = mb_row_alive(0u64, ru, bpr)
        if al == 2u64 {
            fclose(f)
            return 370u64
        }
        if al == 1u64 { found = 1u64 }
        if found == 0u64 { ru = ru + 1u64 }
    }
    let mut rv : u64 = 0u64
    found = 0u64
    while found == 0u64 {
        if rv >= 8u64 {
            fclose(f)
            return 370u64
        }
        if rv >= rows_v {
            fclose(f)
            return 370u64
        }
        let al2 : u64 = mb_row_alive(1u64, rv, bpr)
        if al2 == 2u64 {
            fclose(f)
            return 370u64
        }
        if al2 == 1u64 { found = 1u64 }
        if found == 0u64 { rv = rv + 1u64 }
    }
    MB_SYN_RU = ru
    MB_SYN_RV = rv
    /* PASS ONE */
    if mb_synapse_stream(ru, rv, bpr) != 0u64 {
        fclose(f)
        return 370u64
    }
    let p1s : i64 = MB_TS
    let p10 : u64 = MB_T0
    let p11 : u64 = MB_T1
    let p12 : u64 = MB_T2
    let u10 : u64 = MB_UU0
    let u11 : u64 = MB_UU1
    let u12 : u64 = MB_UU2
    let v10 : u64 = MB_VV0
    let v11 : u64 = MB_VV1
    let v12 : u64 = MB_VV2
    /* THE REVERSED REGROUP: partials summed backwards must equal the stream */
    mb_sacc_clear(2u64)
    let mut b2 : u64 = MB_NP
    while b2 != 0u64 {
        b2 = b2 - 1u64
        mb_sacc_add(2u64, MB_PS[b2], MB_PP0[b2], MB_PP1[b2], MB_PP2[b2])
    }
    if MB_GS != p1s {
        fclose(f)
        return 370u64
    }
    if MB_G0 != p10 {
        fclose(f)
        return 370u64
    }
    if MB_G1 != p11 {
        fclose(f)
        return 370u64
    }
    if MB_G2 != p12 {
        fclose(f)
        return 370u64
    }
    fclose(f)
    /* PASS TWO: a fresh stream must reproduce every limb */
    let f2 : u64 = fopen((&MB_PATH1) as u64, "rb" as u64)
    if f2 == 0u64 { return 370u64 }
    MB_F = f2
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    if mb_synapse_stream(ru, rv, bpr) != 0u64 {
        fclose(f2)
        return 370u64
    }
    fclose(f2)
    if MB_TS != p1s { return 370u64 }
    if MB_T0 != p10 { return 370u64 }
    if MB_T1 != p11 { return 370u64 }
    if MB_T2 != p12 { return 370u64 }
    if MB_UU0 != u10 { return 370u64 }
    if MB_UU1 != u11 { return 370u64 }
    if MB_UU2 != u12 { return 370u64 }
    if MB_VV0 != v10 { return 370u64 }
    if MB_VV1 != v11 { return 370u64 }
    if MB_VV2 != v12 { return 370u64 }
    /* THE EXACT CAUCHY-SCHWARZ: (u.v)^2 <= (u.u)(v.v) in 384-bit integers */
    if (MB_UU0 | MB_UU1 | MB_UU2) == 0u64 { return 370u64 }
    if (MB_VV0 | MB_VV1 | MB_VV2) == 0u64 { return 370u64 }
    mb_mul192(p10, p11, p12, p10, p11, p12)
    let mut k6 : u64 = 0u64
    while k6 < 6u64 {
        MB_R6A[k6] = MB_R6[k6]
        k6 = k6 + 1u64
    }
    mb_mul192(u10, u11, u12, v10, v11, v12)
    /* R6A = (u.v)^2 must be <= R6 = (u.u)(v.v) */
    let cs : i64 = mb_cmp6()
    if cs > 0i64 { return 370u64 }
    MB_SYN_CS = 1u64
    if cs == 0i64 { MB_SYN_CS = 2u64 }
    MB_SYN_S = p1s
    MB_SYN_0 = p10
    MB_SYN_1 = p11
    MB_SYN_2 = p12
    MB_SYN_U0 = u10
    MB_SYN_U1 = u11
    MB_SYN_U2 = u12
    MB_SYN_V0 = v10
    MB_SYN_V1 = v11
    MB_SYN_V2 = v12
    mb_rs("the synapse: output[" as u64)
    mb_ru(MB_SYN_RU)
    mb_rs("] x token_embd[" as u64)
    mb_ru(MB_SYN_RV)
    mb_rs("] dot=" as u64)
    if MB_SYN_S < 0i64 { mb_rb(45u8) }
    MB_X[0] = MB_SYN_0
    MB_X[1] = MB_SYN_1
    MB_X[2] = MB_SYN_2
    mb_rx3()
    mb_rs("*2^-48 blocks=" as u64)
    mb_ru(bpr)
    mb_rs("+" as u64)
    mb_ru(bpr)
    mb_rs(" regroup=ok stream=identical cauchy-schwarz=" as u64)
    if MB_SYN_CS == 1u64 { mb_rs("strict" as u64) }
    if MB_SYN_CS == 2u64 { mb_rs("proportional" as u64) }
    mb_rb(10u8)
    return 0u64
}

/* ==================== arm 372: THE LOOM ==================== */

const MB_NW : u64 = 4u64              /* the weavers */

/* worker-private state: slice `w` of every array belongs to worker w alone */
var MB_LFILE : [u64; 4]
var MB_LBLK : [u8; 1024]              /* 256 bytes per worker */
var MB_LVA : [i64; 1024]              /* 256 values per worker */
var MB_LVB : [i64; 1024]
var MB_LMH : [u64; 4]                 /* per-worker multiply scratch */
var MB_LML : [u64; 4]
var MB_LDS : [i64; 4]                 /* per-worker signed 192-bit dot */
var MB_LD0 : [u64; 4]
var MB_LD1 : [u64; 4]
var MB_LD2 : [u64; 4]
var MB_LU0 : [u64; 4]                 /* per-worker norms */
var MB_LU1 : [u64; 4]
var MB_LU2 : [u64; 4]
var MB_LV0 : [u64; 4]
var MB_LV1 : [u64; 4]
var MB_LV2 : [u64; 4]
var MB_LRC : [u64; 4]                 /* per-worker verdict */
/* the loom's read-only warp (set by the main thread before launch) */
var MB_L_RU : u64 = 0u64
var MB_L_RV : u64 = 0u64
var MB_L_BPR : u64 = 0u64
var MB_L_CHUNK : u64 = 0u64

/* pure fp16 mantissa: value = result * 2^-24; the sentinel marks nonfinite */
fn mb_f16m(p: u64) -> i64 {
    let e : u64 = (p >> 10u64) & 31u64
    let m : u64 = p & 1023u64
    if e == 31u64 { return 4611686018427387904i64 }
    let mut a : u64 = m
    if e != 0u64 { a = (1024u64 + m) << (e - 1u64) }
    let s : u64 = (p >> 15u64) & 1u64
    let av : i64 = a as i64
    if s == 1u64 { return 0i64 - av }
    return av
}

fn mb_wmul64(w: u64, a: u64, b: u64) -> i32 {
    let a0 : u64 = a & 0xFFFFFFFFu64
    let a1 : u64 = a >> 32u64
    let b0 : u64 = b & 0xFFFFFFFFu64
    let b1 : u64 = b >> 32u64
    let p00 : u64 = a0 * b0
    let p01 : u64 = a0 * b1
    let p10 : u64 = a1 * b0
    let p11 : u64 = a1 * b1
    let mid1 : u64 = p01 + (p00 >> 32u64)
    let mid2 : u64 = p10 + (mid1 & 0xFFFFFFFFu64)
    MB_LMH[w] = p11 + (mid1 >> 32u64) + (mid2 >> 32u64)
    MB_LML[w] = (mid2 << 32u64) | (p00 & 0xFFFFFFFFu64)
    return 0i32
}

/* worker signed 192-bit accumulate of (ss, magnitude (lo, hi, 0)) */
fn mb_wsacc(w: u64, ss: i64, lo: u64, hi: u64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let ds : i64 = MB_LDS[w]
    let d0 : u64 = MB_LD0[w]
    let d1 : u64 = MB_LD1[w]
    let d2 : u64 = MB_LD2[w]
    if ds == 0i64 {
        MB_LDS[w] = ss
        MB_LD0[w] = lo
        MB_LD1[w] = hi
        MB_LD2[w] = 0u64
        return 0i32
    }
    if ds == ss {
        let a0 : u64 = d0 + lo
        let mut c0 : u64 = 0u64
        if a0 < lo { c0 = 1u64 }
        let a1a : u64 = d1 + hi
        let mut c1 : u64 = 0u64
        if a1a < hi { c1 = 1u64 }
        let a1 : u64 = a1a + c0
        if a1 < c0 { c1 = c1 + 1u64 }
        MB_LD0[w] = a0
        MB_LD1[w] = a1
        MB_LD2[w] = d2 + c1
        return 0i32
    }
    /* different signs: compare magnitudes (src has limb2 = 0) */
    let mut cmp : i64 = 0i64
    if d2 != 0u64 { cmp = 1i64 }
    if cmp == 0i64 {
        if d1 > hi { cmp = 1i64 }
        if d1 < hi { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        if d0 > lo { cmp = 1i64 }
        if d0 < lo { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        MB_LDS[w] = 0i64
        MB_LD0[w] = 0u64
        MB_LD1[w] = 0u64
        MB_LD2[w] = 0u64
        return 0i32
    }
    if cmp > 0i64 {
        let mut b : u64 = 0u64
        let x0 : u64 = d0 - lo
        if d0 < lo { b = 1u64 }
        let mut b1 : u64 = 0u64
        let x1a : u64 = d1 - hi
        if d1 < hi { b1 = 1u64 }
        let x1 : u64 = x1a - b
        if x1a < b { b1 = b1 + 1u64 }
        MB_LD0[w] = x0
        MB_LD1[w] = x1
        MB_LD2[w] = d2 - b1
        return 0i32
    }
    let mut b2 : u64 = 0u64
    let y0 : u64 = lo - d0
    if lo < d0 { b2 = 1u64 }
    let y1 : u64 = hi - d1 - b2
    MB_LD0[w] = y0
    MB_LD1[w] = y1
    MB_LD2[w] = 0u64
    MB_LDS[w] = ss
    return 0i32
}

fn mb_wuadd(w: u64, hi: u64, lo: u64) -> i32 {
    let a0 : u64 = MB_LU0[w] + lo
    let mut c0 : u64 = 0u64
    if a0 < lo { c0 = 1u64 }
    let a1a : u64 = MB_LU1[w] + hi
    let mut c1 : u64 = 0u64
    if a1a < hi { c1 = 1u64 }
    let a1 : u64 = a1a + c0
    if a1 < c0 { c1 = c1 + 1u64 }
    MB_LU0[w] = a0
    MB_LU1[w] = a1
    MB_LU2[w] = MB_LU2[w] + c1
    return 0i32
}

fn mb_wvadd(w: u64, hi: u64, lo: u64) -> i32 {
    let a0 : u64 = MB_LV0[w] + lo
    let mut c0 : u64 = 0u64
    if a0 < lo { c0 = 1u64 }
    let a1a : u64 = MB_LV1[w] + hi
    let mut c1 : u64 = 0u64
    if a1a < hi { c1 = 1u64 }
    let a1 : u64 = a1a + c0
    if a1 < c0 { c1 = c1 + 1u64 }
    MB_LV0[w] = a0
    MB_LV1[w] = a1
    MB_LV2[w] = MB_LV2[w] + c1
    return 0i32
}

/* read n bytes at abs into worker w's private block buffer */
fn mb_wread(w: u64, abs: u64, n: u64) -> u64 {
    let f : u64 = MB_LFILE[w]
    if _fseeki64(f, abs as i64, 0i32) != 0i32 { return 1u64 }
    let dst : u64 = ((&MB_LBLK) as u64) + w * 256u64
    let got : u64 = fread(dst, 1u64, n, f)
    if got != n { return 1u64 }
    return 0u64
}

/* worker q4_K sub-block scales, packed (sc << 8) | mn */
fn mb_wq4ks(w: u64, j: u64) -> u64 {
    let base : u64 = w * 256u64
    if j < 4u64 {
        let sc : u64 = (MB_LBLK[base + 4u64 + j] as u64) & 63u64
        let mn : u64 = (MB_LBLK[base + 8u64 + j] as u64) & 63u64
        return (sc << 8u64) | mn
    }
    let sj4 : u64 = MB_LBLK[base + 8u64 + j] as u64
    let sjm4 : u64 = MB_LBLK[base + j] as u64
    let sj : u64 = MB_LBLK[base + 4u64 + j] as u64
    let sc2 : u64 = (sj4 & 0xFu64) | ((sjm4 >> 6u64) << 4u64)
    let mn2 : u64 = (sj4 >> 4u64) | ((sj >> 6u64) << 4u64)
    return (sc2 << 8u64) | mn2
}

/* worker decoders: private buffer in, private values out.  1 = refuse */
fn mb_wdec_q4k(w: u64, into_b: u64) -> u64 {
    let base : u64 = w * 256u64
    let dbits : u64 = (MB_LBLK[base] as u64) | ((MB_LBLK[base + 1u64] as u64) << 8u64)
    let mbits : u64 = (MB_LBLK[base + 2u64] as u64) | ((MB_LBLK[base + 3u64] as u64) << 8u64)
    let md : i64 = mb_f16m(dbits)
    let mdm : i64 = mb_f16m(mbits)
    if md == 4611686018427387904i64 { return 1u64 }
    if mdm == 4611686018427387904i64 { return 1u64 }
    let mut t : u64 = 0u64
    while t < 4u64 {
        let mut half : u64 = 0u64
        while half < 2u64 {
            let pk : u64 = mb_wq4ks(w, t * 2u64 + half)
            let sc : i64 = (pk >> 8u64) as i64
            let mn : i64 = (pk & 0xFFu64) as i64
            let mut l : u64 = 0u64
            while l < 32u64 {
                let raw : u64 = MB_LBLK[base + 16u64 + t * 32u64 + l] as u64
                let mut q : u64 = raw & 0xFu64
                if half == 1u64 { q = raw >> 4u64 }
                let vm : i64 = md * sc * (q as i64) - mdm * mn
                let idx : u64 = base + t * 64u64 + half * 32u64 + l
                if into_b == 0u64 { MB_LVA[idx] = vm }
                if into_b == 1u64 { MB_LVB[idx] = vm }
                l = l + 1u64
            }
            half = half + 1u64
        }
        t = t + 1u64
    }
    return 0u64
}

fn mb_wdec_q6k(w: u64, into_b: u64) -> u64 {
    let base : u64 = w * 256u64
    let dbits : u64 = (MB_LBLK[base + 208u64] as u64) | ((MB_LBLK[base + 209u64] as u64) << 8u64)
    let md : i64 = mb_f16m(dbits)
    if md == 4611686018427387904i64 { return 1u64 }
    let mut n2 : u64 = 0u64
    while n2 < 2u64 {
        let vbase : u64 = base + n2 * 128u64
        let qlb : u64 = base + n2 * 64u64
        let qhb : u64 = base + 128u64 + n2 * 32u64
        let scb : u64 = base + 192u64 + n2 * 8u64
        let mut l : u64 = 0u64
        while l < 32u64 {
            let isx : u64 = l / 16u64
            let ql0 : u64 = MB_LBLK[qlb + l] as u64
            let ql32 : u64 = MB_LBLK[qlb + l + 32u64] as u64
            let qh : u64 = MB_LBLK[qhb + l] as u64
            let q1 : i64 = (((ql0 & 0xFu64) | (((qh >> 0u64) & 3u64) << 4u64)) as i64) - 32i64
            let q2 : i64 = (((ql32 & 0xFu64) | (((qh >> 2u64) & 3u64) << 4u64)) as i64) - 32i64
            let q3 : i64 = (((ql0 >> 4u64) | (((qh >> 4u64) & 3u64) << 4u64)) as i64) - 32i64
            let q4 : i64 = (((ql32 >> 4u64) | (((qh >> 6u64) & 3u64) << 4u64)) as i64) - 32i64
            let mut wv : u64 = 0u64
            while wv < 4u64 {
                let mut qv : i64 = q1
                if wv == 1u64 { qv = q2 }
                if wv == 2u64 { qv = q3 }
                if wv == 3u64 { qv = q4 }
                let scraw : u64 = MB_LBLK[scb + isx + wv * 2u64] as u64
                let mut sc : i64 = scraw as i64
                if scraw >= 128u64 { sc = (scraw as i64) - 256i64 }
                let vm : i64 = md * sc * qv
                let idx : u64 = vbase + wv * 32u64 + l
                if into_b == 0u64 { MB_LVA[idx] = vm }
                if into_b == 1u64 { MB_LVB[idx] = vm }
                wv = wv + 1u64
            }
            l = l + 1u64
        }
        n2 = n2 + 1u64
    }
    return 0u64
}

fn mb_wdec_q80(w: u64, into_b: u64) -> u64 {
    let base : u64 = w * 256u64
    let dbits : u64 = (MB_LBLK[base] as u64) | ((MB_LBLK[base + 1u64] as u64) << 8u64)
    let md : i64 = mb_f16m(dbits)
    if md == 4611686018427387904i64 { return 1u64 }
    let mut l : u64 = 0u64
    while l < 32u64 {
        let raw : u64 = MB_LBLK[base + 2u64 + l] as u64
        let mut q : i64 = raw as i64
        if raw >= 128u64 { q = (raw as i64) - 256i64 }
        let vm : i64 = md * q
        let idx : u64 = base + l
        if into_b == 0u64 { MB_LVA[idx] = vm }
        if into_b == 1u64 { MB_LVB[idx] = vm }
        l = l + 1u64
    }
    return 0u64
}

fn mb_wdec(w: u64, ty: u64, into_b: u64) -> u64 {
    if ty == 12u64 { return mb_wdec_q4k(w, into_b) }
    if ty == 14u64 { return mb_wdec_q6k(w, into_b) }
    if ty == 8u64 { return mb_wdec_q80(w, into_b) }
    return 1u64
}

/* the weaver: OS thread entry (win64: arg arrives in rcx).  Processes the
 * static block range [w*chunk, min((w+1)*chunk, bpr)) with PRIVATE state
 * only -- the timing of the weavers is entirely free. */
fn mb_loom_worker(arg: u64) -> u32 {
    let w : u64 = arg
    MB_LDS[w] = 0i64
    MB_LD0[w] = 0u64
    MB_LD1[w] = 0u64
    MB_LD2[w] = 0u64
    MB_LU0[w] = 0u64
    MB_LU1[w] = 0u64
    MB_LU2[w] = 0u64
    MB_LV0[w] = 0u64
    MB_LV1[w] = 0u64
    MB_LV2[w] = 0u64
    let bbu : u64 = mb_tbb(MB_C1_TYPE)
    let bbv : u64 = mb_tbb(MB_C2_TYPE)
    let start : u64 = w * MB_L_CHUNK
    let mut endb : u64 = start + MB_L_CHUNK
    if endb > MB_L_BPR { endb = MB_L_BPR }
    let mut b : u64 = start
    while b < endb {
        let ub : u64 = MB_DBASE1 + MB_C1_OFF + (MB_L_RU * MB_L_BPR + b) * bbu
        if mb_wread(w, ub, bbu) != 0u64 {
            MB_LRC[w] = 372u64
            return 0u32
        }
        if mb_wdec(w, MB_C1_TYPE, 0u64) != 0u64 {
            MB_LRC[w] = 372u64
            return 0u32
        }
        let vb2 : u64 = MB_DBASE1 + MB_C2_OFF + (MB_L_RV * MB_L_BPR + b) * bbv
        if mb_wread(w, vb2, bbv) != 0u64 {
            MB_LRC[w] = 372u64
            return 0u32
        }
        if mb_wdec(w, MB_C2_TYPE, 1u64) != 0u64 {
            MB_LRC[w] = 372u64
            return 0u32
        }
        let base : u64 = w * 256u64
        let mut e : u64 = 0u64
        while e < 256u64 {
            let va : i64 = MB_LVA[base + e]
            let vbv : i64 = MB_LVB[base + e]
            let mut ma : u64 = va as u64
            if va < 0i64 { ma = (0i64 - va) as u64 }
            let mut mbv : u64 = vbv as u64
            if vbv < 0i64 { mbv = (0i64 - vbv) as u64 }
            if va != 0i64 {
                if vbv != 0i64 {
                    let mut sgn : i64 = 1i64
                    if va < 0i64 {
                        if vbv > 0i64 { sgn = 0i64 - 1i64 }
                    }
                    if va > 0i64 {
                        if vbv < 0i64 { sgn = 0i64 - 1i64 }
                    }
                    mb_wmul64(w, ma, mbv)
                    mb_wsacc(w, sgn, MB_LML[w], MB_LMH[w])
                }
                mb_wmul64(w, ma, ma)
                mb_wuadd(w, MB_LMH[w], MB_LML[w])
            }
            if vbv != 0i64 {
                mb_wmul64(w, mbv, mbv)
                mb_wvadd(w, MB_LMH[w], MB_LML[w])
            }
            e = e + 1u64
        }
        b = b + 1u64
    }
    MB_LRC[w] = 0u64
    return 0u32
}

/* one full launch: open private files, weave, join, verdict.  0 = ok.
 * `entry` is the thread routine (a bare fn-as-u64 -- the verified lea). */
var MB_LH : [u64; 4]
fn mb_loom_launch(entry: u64) -> u64 {
    let mut w : u64 = 0u64
    while w < MB_NW {
        MB_LFILE[w] = fopen((&MB_PATH1) as u64, "rb" as u64)
        if MB_LFILE[w] == 0u64 {
            let mut c : u64 = 0u64
            while c < w {
                fclose(MB_LFILE[c])
                c = c + 1u64
            }
            return 1u64
        }
        w = w + 1u64
    }
    w = 0u64
    while w < MB_NW {
        MB_LRC[w] = 999u64
        MB_LH[w] = CreateThread(0u64, 0u64, entry, w, 0u64, 0u64)
        if MB_LH[w] == 0u64 {
            /* join what launched, close everything, refuse */
            let mut j : u64 = 0u64
            while j < w {
                WaitForSingleObject(MB_LH[j], 0xFFFFFFFFu32)
                CloseHandle(MB_LH[j])
                j = j + 1u64
            }
            let mut c2 : u64 = 0u64
            while c2 < MB_NW {
                fclose(MB_LFILE[c2])
                c2 = c2 + 1u64
            }
            return 1u64
        }
        w = w + 1u64
    }
    w = 0u64
    while w < MB_NW {
        WaitForSingleObject(MB_LH[w], 0xFFFFFFFFu32)
        CloseHandle(MB_LH[w])
        w = w + 1u64
    }
    w = 0u64
    while w < MB_NW {
        fclose(MB_LFILE[w])
        w = w + 1u64
    }
    w = 0u64
    while w < MB_NW {
        if MB_LRC[w] != 0u64 { return 1u64 }
        w = w + 1u64
    }
    return 0u64
}

fn mb_arm372() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_SYN_CS == 0u64 { return 372u64 }
    let bpr : u64 = MB_C1_NE0 / 256u64
    MB_L_RU = MB_SYN_RU
    MB_L_RV = MB_SYN_RV
    MB_L_BPR = bpr
    MB_L_CHUNK = (bpr + MB_NW - 1u64) / MB_NW
    /* FIRST LAUNCH */
    if mb_loom_launch(mb_loom_worker as u64) != 0u64 { return 372u64 }
    /* the canonical fold, w = 0..NW-1 */
    mb_sacc_clear(0u64)
    let mut w : u64 = 0u64
    while w < MB_NW {
        mb_sacc_add(0u64, MB_LDS[w], MB_LD0[w], MB_LD1[w], MB_LD2[w])
        w = w + 1u64
    }
    let f1s : i64 = MB_TS
    let f10 : u64 = MB_T0
    let f11 : u64 = MB_T1
    let f12 : u64 = MB_T2
    /* the REVERSED fold: associativity witnessed at the fold itself */
    mb_sacc_clear(0u64)
    w = MB_NW
    while w != 0u64 {
        w = w - 1u64
        mb_sacc_add(0u64, MB_LDS[w], MB_LD0[w], MB_LD1[w], MB_LD2[w])
    }
    if MB_TS != f1s { return 372u64 }
    if MB_T0 != f10 { return 372u64 }
    if MB_T1 != f11 { return 372u64 }
    if MB_T2 != f12 { return 372u64 }
    /* THE THEOREM: the parallel weave equals the sequential stream */
    if f1s != MB_SYN_S { return 372u64 }
    if f10 != MB_SYN_0 { return 372u64 }
    if f11 != MB_SYN_1 { return 372u64 }
    if f12 != MB_SYN_2 { return 372u64 }
    /* the norms agree too (positive folds) */
    mb_sacc_clear(0u64)
    w = 0u64
    while w < MB_NW {
        let mut us : i64 = 0i64
        if (MB_LU0[w] | MB_LU1[w] | MB_LU2[w]) != 0u64 { us = 1i64 }
        mb_sacc_add(0u64, us, MB_LU0[w], MB_LU1[w], MB_LU2[w])
        w = w + 1u64
    }
    if MB_T0 != MB_SYN_U0 { return 372u64 }
    if MB_T1 != MB_SYN_U1 { return 372u64 }
    if MB_T2 != MB_SYN_U2 { return 372u64 }
    mb_sacc_clear(0u64)
    w = 0u64
    while w < MB_NW {
        let mut vs : i64 = 0i64
        if (MB_LV0[w] | MB_LV1[w] | MB_LV2[w]) != 0u64 { vs = 1i64 }
        mb_sacc_add(0u64, vs, MB_LV0[w], MB_LV1[w], MB_LV2[w])
        w = w + 1u64
    }
    if MB_T0 != MB_SYN_V0 { return 372u64 }
    if MB_T1 != MB_SYN_V1 { return 372u64 }
    if MB_T2 != MB_SYN_V2 { return 372u64 }
    /* SECOND LAUNCH: a fresh weave under fresh timing must land identically */
    if mb_loom_launch(mb_loom_worker as u64) != 0u64 { return 372u64 }
    mb_sacc_clear(0u64)
    w = 0u64
    while w < MB_NW {
        mb_sacc_add(0u64, MB_LDS[w], MB_LD0[w], MB_LD1[w], MB_LD2[w])
        w = w + 1u64
    }
    if MB_TS != f1s { return 372u64 }
    if MB_T0 != f10 { return 372u64 }
    if MB_T1 != f11 { return 372u64 }
    if MB_T2 != f12 { return 372u64 }
    mb_rs("the loom: workers=" as u64)
    mb_ru(MB_NW)
    mb_rs(" chunk=" as u64)
    mb_ru(MB_L_CHUNK)
    mb_rs(" partition=static timing=free result=sequential-identical fold=order-invariant relaunch=identical" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ============ arm 373: THE ROW-FLEET (matvec across the vocabulary) ============ */

/* the shared activation x: the digested embedding row, decoded ONCE through
 * the two-engine path, then READ-ONLY for every weaver (read-only sharing
 * is determinism-safe) */
var MB_XV : [i64; 7168]
var MB_XBMAX : [u64; 32]
var MB_L_V : u64 = 0u64
var MB_L_CHR : u64 = 0u64
var MB_SSTRIDE : u64 = 0u64

/* per-worker fleet ledgers */
var MB_FBI : [u64; 4]                 /* best row index (sentinel = empty) */
var MB_FBS : [i64; 4]
var MB_FB0 : [u64; 4]
var MB_FB1 : [u64; 4]
var MB_FB2 : [u64; 4]
var MB_FTIE : [u64; 4]
var MB_FPOS : [u64; 4]
var MB_FNEG : [u64; 4]
var MB_FZR : [u64; 4]
var MB_FSS : [i64; 4]                 /* per-worker signed sum of all dots */
var MB_FS0 : [u64; 4]
var MB_FS1 : [u64; 4]
var MB_FS2 : [u64; 4]

/* the eight witness rows: workers deposit, the main thread re-derives */
var MB_SMS : [i64; 8]
var MB_SM0 : [u64; 8]
var MB_SM1 : [u64; 8]
var MB_SM2 : [u64; 8]
var MB_SMF : [u8; 8]

/* the fold verdict */
var MB_GBI : u64 = 0u64
var MB_GBS : i64 = 0i64
var MB_GB0 : u64 = 0u64
var MB_GB1 : u64 = 0u64
var MB_GB2 : u64 = 0u64
var MB_GTS : u64 = 0u64

fn mb_scmp192(sa: i64, a0: u64, a1: u64, a2: u64, sb: i64, b0: u64, b1: u64, b2: u64) -> i64 {
    if sa > sb { return 1i64 }
    if sa < sb { return 0i64 - 1i64 }
    if sa == 0i64 { return 0i64 }
    let mut cmp : i64 = 0i64
    if a2 > b2 { cmp = 1i64 }
    if a2 < b2 { cmp = 0i64 - 1i64 }
    if cmp == 0i64 {
        if a1 > b1 { cmp = 1i64 }
        if a1 < b1 { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        if a0 > b0 { cmp = 1i64 }
        if a0 < b0 { cmp = 0i64 - 1i64 }
    }
    if sa < 0i64 { return 0i64 - cmp }
    return cmp
}

/* per-worker signed 3-limb fold accumulator (the sum-of-dots ledger) */
fn mb_wfold(w: u64, ss: i64, s0: u64, s1: u64, s2: u64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let ds : i64 = MB_FSS[w]
    let d0 : u64 = MB_FS0[w]
    let d1 : u64 = MB_FS1[w]
    let d2 : u64 = MB_FS2[w]
    if ds == 0i64 {
        MB_FSS[w] = ss
        MB_FS0[w] = s0
        MB_FS1[w] = s1
        MB_FS2[w] = s2
        return 0i32
    }
    if ds == ss {
        let a0 : u64 = d0 + s0
        let mut c0 : u64 = 0u64
        if a0 < s0 { c0 = 1u64 }
        let a1a : u64 = d1 + s1
        let mut c1 : u64 = 0u64
        if a1a < s1 { c1 = 1u64 }
        let a1 : u64 = a1a + c0
        if a1 < c0 { c1 = c1 + 1u64 }
        MB_FS0[w] = a0
        MB_FS1[w] = a1
        MB_FS2[w] = d2 + s2 + c1
        return 0i32
    }
    let mut cmp : i64 = 0i64
    if d2 > s2 { cmp = 1i64 }
    if d2 < s2 { cmp = 0i64 - 1i64 }
    if cmp == 0i64 {
        if d1 > s1 { cmp = 1i64 }
        if d1 < s1 { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        if d0 > s0 { cmp = 1i64 }
        if d0 < s0 { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        MB_FSS[w] = 0i64
        MB_FS0[w] = 0u64
        MB_FS1[w] = 0u64
        MB_FS2[w] = 0u64
        return 0i32
    }
    if cmp > 0i64 {
        let mut b : u64 = 0u64
        let x0 : u64 = d0 - s0
        if d0 < s0 { b = 1u64 }
        let mut b1 : u64 = 0u64
        let x1a : u64 = d1 - s1
        if d1 < s1 { b1 = 1u64 }
        let x1 : u64 = x1a - b
        if x1a < b { b1 = b1 + 1u64 }
        MB_FS0[w] = x0
        MB_FS1[w] = x1
        MB_FS2[w] = d2 - s2 - b1
        return 0i32
    }
    let mut b2 : u64 = 0u64
    let y0 : u64 = s0 - d0
    if s0 < d0 { b2 = 1u64 }
    let mut b3 : u64 = 0u64
    let y1a : u64 = s1 - d1
    if s1 < d1 { b3 = 1u64 }
    let y1 : u64 = y1a - b2
    if y1a < b2 { b3 = b3 + 1u64 }
    MB_FS0[w] = y0
    MB_FS1[w] = y1
    MB_FS2[w] = s2 - d2 - b3
    MB_FSS[w] = ss
    return 0i32
}

/* one row's exact dot against MB_XV, into worker w's LDS slot.
 * THE FAST PATH: when every mantissa in the block and in x's block sits
 * below 2^27, each product is below 2^54 and 256 of them stay below 2^62 --
 * plain i64/u64 block accumulation is EXACT (the guard is checked, never
 * assumed).  Guard-tripped blocks take the per-element 128-bit path. */
fn mb_fleet_row_dot(w: u64, t: u64) -> u64 {
    MB_LDS[w] = 0i64
    MB_LD0[w] = 0u64
    MB_LD1[w] = 0u64
    MB_LD2[w] = 0u64
    let bbu : u64 = mb_tbb(MB_C1_TYPE)
    let bpr : u64 = MB_L_BPR
    let base : u64 = w * 256u64
    let mut b : u64 = 0u64
    while b < bpr {
        let abs : u64 = MB_DBASE1 + MB_C1_OFF + (t * bpr + b) * bbu
        if mb_wread(w, abs, bbu) != 0u64 { return 1u64 }
        if mb_wdec(w, MB_C1_TYPE, 0u64) != 0u64 { return 1u64 }
        let boff : u64 = b * 256u64
        let mut vmax : u64 = 0u64
        let mut e : u64 = 0u64
        while e < 256u64 {
            let v : i64 = MB_LVA[base + e]
            let mut a : u64 = v as u64
            if v < 0i64 { a = (0i64 - v) as u64 }
            if a > vmax { vmax = a }
            e = e + 1u64
        }
        let mut fast : u64 = 0u64
        if vmax < 134217728u64 {
            if MB_XBMAX[b] < 134217728u64 { fast = 1u64 }
        }
        if fast == 1u64 {
            let mut pos : u64 = 0u64
            let mut neg : u64 = 0u64
            e = 0u64
            while e < 256u64 {
                let p : i64 = MB_LVA[base + e] * MB_XV[boff + e]
                if p > 0i64 { pos = pos + (p as u64) }
                if p < 0i64 { neg = neg + ((0i64 - p) as u64) }
                e = e + 1u64
            }
            if pos > neg { mb_wsacc(w, 1i64, pos - neg, 0u64) }
            if neg > pos { mb_wsacc(w, 0i64 - 1i64, neg - pos, 0u64) }
        }
        if fast == 0u64 {
            e = 0u64
            while e < 256u64 {
                let va : i64 = MB_LVA[base + e]
                let xv : i64 = MB_XV[boff + e]
                if va != 0i64 {
                    if xv != 0i64 {
                        let mut ma : u64 = va as u64
                        if va < 0i64 { ma = (0i64 - va) as u64 }
                        let mut mx : u64 = xv as u64
                        if xv < 0i64 { mx = (0i64 - xv) as u64 }
                        let mut sgn : i64 = 1i64
                        if va < 0i64 {
                            if xv > 0i64 { sgn = 0i64 - 1i64 }
                        }
                        if va > 0i64 {
                            if xv < 0i64 { sgn = 0i64 - 1i64 }
                        }
                        mb_wmul64(w, ma, mx)
                        mb_wsacc(w, sgn, MB_LML[w], MB_LMH[w])
                    }
                }
                e = e + 1u64
            }
        }
        b = b + 1u64
    }
    return 0u64
}

/* the fleet weaver: a static slice of the vocabulary, rows never split */
fn mb_fleet_worker(arg: u64) -> u32 {
    let w : u64 = arg
    MB_FBI[w] = 0xFFFFFFFFFFFFFFFFu64
    MB_FTIE[w] = 0u64
    MB_FPOS[w] = 0u64
    MB_FNEG[w] = 0u64
    MB_FZR[w] = 0u64
    MB_FSS[w] = 0i64
    MB_FS0[w] = 0u64
    MB_FS1[w] = 0u64
    MB_FS2[w] = 0u64
    let start : u64 = w * MB_L_CHR
    let mut endr : u64 = start + MB_L_CHR
    if endr > MB_L_V { endr = MB_L_V }
    let mut t : u64 = start
    while t < endr {
        if mb_fleet_row_dot(w, t) != 0u64 {
            MB_LRC[w] = 373u64
            return 0u32
        }
        let rs : i64 = MB_LDS[w]
        let r0 : u64 = MB_LD0[w]
        let r1 : u64 = MB_LD1[w]
        let r2 : u64 = MB_LD2[w]
        if rs > 0i64 { MB_FPOS[w] = MB_FPOS[w] + 1u64 }
        if rs < 0i64 { MB_FNEG[w] = MB_FNEG[w] + 1u64 }
        if rs == 0i64 { MB_FZR[w] = MB_FZR[w] + 1u64 }
        mb_wfold(w, rs, r0, r1, r2)
        if t % MB_SSTRIDE == 0u64 {
            let k : u64 = t / MB_SSTRIDE
            if k < 8u64 {
                MB_SMS[k] = rs
                MB_SM0[k] = r0
                MB_SM1[k] = r1
                MB_SM2[k] = r2
                MB_SMF[k] = 1u8
            }
        }
        if MB_FBI[w] == 0xFFFFFFFFFFFFFFFFu64 {
            MB_FBI[w] = t
            MB_FBS[w] = rs
            MB_FB0[w] = r0
            MB_FB1[w] = r1
            MB_FB2[w] = r2
            MB_FTIE[w] = 1u64
        }
        if MB_FBI[w] != t {
            let c : i64 = mb_scmp192(rs, r0, r1, r2, MB_FBS[w], MB_FB0[w], MB_FB1[w], MB_FB2[w])
            if c > 0i64 {
                MB_FBI[w] = t
                MB_FBS[w] = rs
                MB_FB0[w] = r0
                MB_FB1[w] = r1
                MB_FB2[w] = r2
                MB_FTIE[w] = 1u64
            }
            if c == 0i64 { MB_FTIE[w] = MB_FTIE[w] + 1u64 }
        }
        t = t + 1u64
    }
    MB_LRC[w] = 0u64
    return 0u32
}

/* fold the worker bests; dir 0 = canonical (w ascending), 1 = reversed.
 * The one law both directions must land on: highest value wins; on equal
 * values the LOWEST row index is the name; attained = ties summed over
 * every worker standing at the winning value. */
fn mb_fleet_fold(dir: u64) -> i32 {
    MB_GBI = 0xFFFFFFFFFFFFFFFFu64
    MB_GBS = 0i64
    MB_GB0 = 0u64
    MB_GB1 = 0u64
    MB_GB2 = 0u64
    MB_GTS = 0u64
    let mut k : u64 = 0u64
    while k < MB_NW {
        let mut w : u64 = k
        if dir == 1u64 { w = MB_NW - 1u64 - k }
        if MB_FBI[w] != 0xFFFFFFFFFFFFFFFFu64 {
            if MB_GBI == 0xFFFFFFFFFFFFFFFFu64 {
                MB_GBI = MB_FBI[w]
                MB_GBS = MB_FBS[w]
                MB_GB0 = MB_FB0[w]
                MB_GB1 = MB_FB1[w]
                MB_GB2 = MB_FB2[w]
                MB_GTS = MB_FTIE[w]
            }
            if MB_GBI != MB_FBI[w] {
                let c : i64 = mb_scmp192(MB_FBS[w], MB_FB0[w], MB_FB1[w], MB_FB2[w], MB_GBS, MB_GB0, MB_GB1, MB_GB2)
                if c > 0i64 {
                    MB_GBI = MB_FBI[w]
                    MB_GBS = MB_FBS[w]
                    MB_GB0 = MB_FB0[w]
                    MB_GB1 = MB_FB1[w]
                    MB_GB2 = MB_FB2[w]
                    MB_GTS = MB_FTIE[w]
                }
                if c == 0i64 {
                    MB_GTS = MB_GTS + MB_FTIE[w]
                    if MB_FBI[w] < MB_GBI { MB_GBI = MB_FBI[w] }
                }
            }
        }
        k = k + 1u64
    }
    return 0i32
}

/* decode the winner row and take its exact norm (into MB_LU slot 0) */
fn mb_fleet_row_norm(w: u64, t: u64) -> u64 {
    MB_LU0[w] = 0u64
    MB_LU1[w] = 0u64
    MB_LU2[w] = 0u64
    let bbu : u64 = mb_tbb(MB_C1_TYPE)
    let base : u64 = w * 256u64
    let mut b : u64 = 0u64
    while b < MB_L_BPR {
        let abs : u64 = MB_DBASE1 + MB_C1_OFF + (t * MB_L_BPR + b) * bbu
        if mb_wread(w, abs, bbu) != 0u64 { return 1u64 }
        if mb_wdec(w, MB_C1_TYPE, 0u64) != 0u64 { return 1u64 }
        let mut e : u64 = 0u64
        while e < 256u64 {
            let v : i64 = MB_LVA[base + e]
            if v != 0i64 {
                let mut a : u64 = v as u64
                if v < 0i64 { a = (0i64 - v) as u64 }
                mb_wmul64(w, a, a)
                mb_wuadd(w, MB_LMH[w], MB_LML[w])
            }
            e = e + 1u64
        }
        b = b + 1u64
    }
    return 0u64
}

/* build the shared activation from the digested embedding row */
fn mb_fleet_load_x() -> u64 {
    let f : u64 = fopen((&MB_PATH1) as u64, "rb" as u64)
    if f == 0u64 { return 1u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    let mut b : u64 = 0u64
    while b < MB_L_BPR {
        if mb_digest(1u64, MB_SYN_RV * MB_L_BPR + b) != 0u64 {
            fclose(f)
            return 1u64
        }
        let mut mx : u64 = 0u64
        let mut e : u64 = 0u64
        while e < 256u64 {
            let v : i64 = MB_VB[e]
            MB_XV[b * 256u64 + e] = v
            let mut a : u64 = v as u64
            if v < 0i64 { a = (0i64 - v) as u64 }
            if a > mx { mx = a }
            e = e + 1u64
        }
        MB_XBMAX[b] = mx
        b = b + 1u64
    }
    fclose(f)
    return 0u64
}

fn mb_arm373() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_SYN_CS == 0u64 { return 373u64 }
    let v_all : u64 = MB_C1_NE / MB_C1_NE0
    if v_all < 16u64 { return 373u64 }
    MB_L_BPR = MB_C1_NE0 / 256u64
    MB_L_V = v_all
    MB_L_CHR = (v_all + MB_NW - 1u64) / MB_NW
    MB_SSTRIDE = v_all / 8u64
    if MB_SSTRIDE == 0u64 { return 373u64 }
    let mut k : u64 = 0u64
    while k < 8u64 {
        MB_SMF[k] = 0u8
        k = k + 1u64
    }
    if mb_fleet_load_x() != 0u64 { return 373u64 }
    /* THE FLEET SAILS */
    if mb_loom_launch(mb_fleet_worker as u64) != 0u64 { return 373u64 }
    /* the histogram must partition the vocabulary exactly */
    let mut hp : u64 = 0u64
    let mut hn : u64 = 0u64
    let mut hz : u64 = 0u64
    let mut w : u64 = 0u64
    while w < MB_NW {
        hp = hp + MB_FPOS[w]
        hn = hn + MB_FNEG[w]
        hz = hz + MB_FZR[w]
        w = w + 1u64
    }
    if hp + hn + hz != v_all { return 373u64 }
    /* canonical fold, then the reversed fold must land identically */
    mb_fleet_fold(0u64)
    let g_i : u64 = MB_GBI
    let g_s : i64 = MB_GBS
    let g_0 : u64 = MB_GB0
    let g_1 : u64 = MB_GB1
    let g_2 : u64 = MB_GB2
    let g_t : u64 = MB_GTS
    mb_fleet_fold(1u64)
    if MB_GBI != g_i { return 373u64 }
    if MB_GBS != g_s { return 373u64 }
    if MB_GB0 != g_0 { return 373u64 }
    if MB_GB1 != g_1 { return 373u64 }
    if MB_GB2 != g_2 { return 373u64 }
    if MB_GTS != g_t { return 373u64 }
    if g_i == 0xFFFFFFFFFFFFFFFFu64 { return 373u64 }
    /* the sum-of-dots fold: canonical vs reversed (order-invariance) */
    mb_sacc_clear(0u64)
    w = 0u64
    while w < MB_NW {
        mb_sacc_add(0u64, MB_FSS[w], MB_FS0[w], MB_FS1[w], MB_FS2[w])
        w = w + 1u64
    }
    let ts_s : i64 = MB_TS
    let ts_0 : u64 = MB_T0
    let ts_1 : u64 = MB_T1
    let ts_2 : u64 = MB_T2
    mb_sacc_clear(0u64)
    w = MB_NW
    while w != 0u64 {
        w = w - 1u64
        mb_sacc_add(0u64, MB_FSS[w], MB_FS0[w], MB_FS1[w], MB_FS2[w])
    }
    if MB_TS != ts_s { return 373u64 }
    if MB_T0 != ts_0 { return 373u64 }
    if MB_T1 != ts_1 { return 373u64 }
    if MB_T2 != ts_2 { return 373u64 }
    /* the main thread reopens the flesh and re-derives: the anchor row
     * (must equal the twice-proven synapse) and all eight witness rows */
    MB_LFILE[0] = fopen((&MB_PATH1) as u64, "rb" as u64)
    if MB_LFILE[0] == 0u64 { return 373u64 }
    if mb_fleet_row_dot(0u64, MB_SYN_RU) != 0u64 {
        fclose(MB_LFILE[0])
        return 373u64
    }
    let mut anchor_ok : u64 = 1u64
    if MB_LDS[0] != MB_SYN_S { anchor_ok = 0u64 }
    if MB_LD0[0] != MB_SYN_0 { anchor_ok = 0u64 }
    if MB_LD1[0] != MB_SYN_1 { anchor_ok = 0u64 }
    if MB_LD2[0] != MB_SYN_2 { anchor_ok = 0u64 }
    if anchor_ok == 0u64 {
        fclose(MB_LFILE[0])
        return 373u64
    }
    let mut samples_ok : u64 = 0u64
    k = 0u64
    while k < 8u64 {
        if MB_SMF[k] != 1u8 {
            fclose(MB_LFILE[0])
            return 373u64
        }
        if mb_fleet_row_dot(0u64, k * MB_SSTRIDE) != 0u64 {
            fclose(MB_LFILE[0])
            return 373u64
        }
        let mut same : u64 = 1u64
        if MB_LDS[0] != MB_SMS[k] { same = 0u64 }
        if MB_LD0[0] != MB_SM0[k] { same = 0u64 }
        if MB_LD1[0] != MB_SM1[k] { same = 0u64 }
        if MB_LD2[0] != MB_SM2[k] { same = 0u64 }
        if same == 0u64 {
            fclose(MB_LFILE[0])
            return 373u64
        }
        samples_ok = samples_ok + 1u64
        k = k + 1u64
    }
    /* the winner's Cauchy-Schwarz: (dot)^2 <= (row.row)(x.x), exact */
    if mb_fleet_row_norm(0u64, g_i) != 0u64 {
        fclose(MB_LFILE[0])
        return 373u64
    }
    fclose(MB_LFILE[0])
    mb_mul192(g_0, g_1, g_2, g_0, g_1, g_2)
    let mut k6 : u64 = 0u64
    while k6 < 6u64 {
        MB_R6A[k6] = MB_R6[k6]
        k6 = k6 + 1u64
    }
    mb_mul192(MB_LU0[0], MB_LU1[0], MB_LU2[0], MB_SYN_V0, MB_SYN_V1, MB_SYN_V2)
    let cs : i64 = mb_cmp6()
    if cs > 0i64 { return 373u64 }
    mb_rs("the fleet: vocab=" as u64)
    mb_ru(v_all)
    mb_rs(" argmax=" as u64)
    mb_ru(g_i)
    mb_rs(" value=" as u64)
    if g_s < 0i64 { mb_rb(45u8) }
    MB_X[0] = g_0
    MB_X[1] = g_1
    MB_X[2] = g_2
    mb_rx3()
    mb_rs("*2^-48 attained=" as u64)
    mb_ru(g_t)
    mb_rs(" pos=" as u64)
    mb_ru(hp)
    mb_rs(" neg=" as u64)
    mb_ru(hn)
    mb_rs(" zero=" as u64)
    mb_ru(hz)
    mb_rs(" anchor=synapse-exact samples=" as u64)
    mb_ru(samples_ok)
    mb_rs("/8 winner-cs=" as u64)
    if cs < 0i64 { mb_rs("strict" as u64) }
    if cs == 0i64 { mb_rs("proportional" as u64) }
    mb_rs(" fold=order-invariant" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ============ arm 374: THE EXPERT WALK (the router, certified) ============ */

/* exact f32: value = mant * 2^exp with mant signed, exp in MB_F32E.
 * The sentinel marks nonfinite. */
var MB_F32E : i64 = 0i64
fn mb_f32m(bits: u64) -> i64 {
    let e : u64 = (bits >> 23u64) & 255u64
    let m : u64 = bits & 0x7FFFFFu64
    if e == 255u64 { return 4611686018427387904i64 }
    let mut mm : u64 = m
    MB_F32E = 0i64 - 149i64
    if e != 0u64 {
        mm = 8388608u64 + m
        MB_F32E = (e as i64) - 150i64
    }
    let mv : i64 = mm as i64
    if (bits >> 31u64) == 1u64 { return 0i64 - mv }
    return mv
}

/* the router's 256 logits, exact: sign, 3 limbs, exponent */
var MB_RLS : [i64; 256]
var MB_RL0 : [u64; 256]
var MB_RL1 : [u64; 256]
var MB_RL2 : [u64; 256]
var MB_RLE : [i64; 256]
/* per-64-element chunk partials for the reversed-fold teeth */
var MB_CPS : [i64; 112]
var MB_CP0 : [u64; 112]
var MB_CP1 : [u64; 112]
var MB_CP2 : [u64; 112]
var MB_TOP : [u64; 8]

/* signed accumulate (ss, l0,l1,l2) into slot arrays A (0 = row acc via
 * globals below); the walk is single-threaded so plain globals serve */
var MB_WAS : i64 = 0i64
var MB_WA0 : u64 = 0u64
var MB_WA1 : u64 = 0u64
var MB_WA2 : u64 = 0u64
fn mb_wacc3(ss: i64, s0: u64, s1: u64, s2: u64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let ds : i64 = MB_WAS
    let d0 : u64 = MB_WA0
    let d1 : u64 = MB_WA1
    let d2 : u64 = MB_WA2
    if ds == 0i64 {
        MB_WAS = ss
        MB_WA0 = s0
        MB_WA1 = s1
        MB_WA2 = s2
        return 0i32
    }
    if ds == ss {
        let a0 : u64 = d0 + s0
        let mut c0 : u64 = 0u64
        if a0 < s0 { c0 = 1u64 }
        let a1a : u64 = d1 + s1
        let mut c1 : u64 = 0u64
        if a1a < s1 { c1 = 1u64 }
        let a1 : u64 = a1a + c0
        if a1 < c0 { c1 = c1 + 1u64 }
        MB_WA0 = a0
        MB_WA1 = a1
        MB_WA2 = d2 + s2 + c1
        return 0i32
    }
    let mut cmp : i64 = 0i64
    if d2 > s2 { cmp = 1i64 }
    if d2 < s2 { cmp = 0i64 - 1i64 }
    if cmp == 0i64 {
        if d1 > s1 { cmp = 1i64 }
        if d1 < s1 { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        if d0 > s0 { cmp = 1i64 }
        if d0 < s0 { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        MB_WAS = 0i64
        MB_WA0 = 0u64
        MB_WA1 = 0u64
        MB_WA2 = 0u64
        return 0i32
    }
    if cmp > 0i64 {
        let mut b : u64 = 0u64
        let x0 : u64 = d0 - s0
        if d0 < s0 { b = 1u64 }
        let mut b1 : u64 = 0u64
        let x1a : u64 = d1 - s1
        if d1 < s1 { b1 = 1u64 }
        let x1 : u64 = x1a - b
        if x1a < b { b1 = b1 + 1u64 }
        MB_WA0 = x0
        MB_WA1 = x1
        MB_WA2 = d2 - s2 - b1
        return 0i32
    }
    let mut b2 : u64 = 0u64
    let y0 : u64 = s0 - d0
    if s0 < d0 { b2 = 1u64 }
    let mut b3 : u64 = 0u64
    let y1a : u64 = s1 - d1
    if s1 < d1 { b3 = 1u64 }
    let y1 : u64 = y1a - b2
    if y1a < b2 { b3 = b3 + 1u64 }
    MB_WA0 = y0
    MB_WA1 = y1
    MB_WA2 = s2 - d2 - b3
    MB_WAS = ss
    return 0i32
}

/* one router row, two window passes: exponent scan, then accumulation at
 * the row's own minimal exponent with per-chunk partials.
 * returns 0 ok / 1 io / 2 nonfinite / 3 spread-guard */
fn mb_walk_row(r: u64) -> u64 {
    let ne0 : u64 = MB_C3_NE0
    let row_abs : u64 = MB_C3_DBASE + MB_C3_OFF + r * ne0 * 4u64
    /* pass A: the exponent window of the row */
    mb_seek_abs(row_abs)
    let mut emin : i64 = 1000i64
    let mut emax : i64 = 0i64 - 1000i64
    let mut e : u64 = 0u64
    while e < ne0 {
        let bits : u64 = mb_u32()
        let mf : i64 = mb_f32m(bits)
        if mf == 4611686018427387904i64 { return 2u64 }
        if mf != 0i64 {
            if MB_XV[e] != 0i64 {
                if MB_F32E < emin { emin = MB_F32E }
                if MB_F32E > emax { emax = MB_F32E }
            }
        }
        e = e + 1u64
    }
    if MB_IOERR != 0u8 { return 1u64 }
    if emin == 1000i64 {
        /* an all-orthogonal row: the logit is exactly zero */
        MB_RLS[r] = 0i64
        MB_RL0[r] = 0u64
        MB_RL1[r] = 0u64
        MB_RL2[r] = 0u64
        MB_RLE[r] = 0i64
        return 0u64
    }
    if emax - emin > 32i64 { return 3u64 }
    /* pass B: exact accumulation at 2^(emin-24), chunk partials kept */
    mb_seek_abs(row_abs)
    MB_WAS = 0i64
    MB_WA0 = 0u64
    MB_WA1 = 0u64
    MB_WA2 = 0u64
    let nchunk : u64 = ne0 / 64u64
    let mut ch : u64 = 0u64
    while ch < nchunk {
        let mut ce : u64 = 0u64
        while ce < 64u64 {
            let bits : u64 = mb_u32()
            let mf : i64 = mb_f32m(bits)
            let xe : u64 = ch * 64u64 + ce
            let xv : i64 = MB_XV[xe]
            if mf != 0i64 {
                if xv != 0i64 {
                    let mut mfa : u64 = mf as u64
                    if mf < 0i64 { mfa = (0i64 - mf) as u64 }
                    let mut mxa : u64 = xv as u64
                    if xv < 0i64 { mxa = (0i64 - xv) as u64 }
                    let mut sgn : i64 = 1i64
                    if mf < 0i64 {
                        if xv > 0i64 { sgn = 0i64 - 1i64 }
                    }
                    if mf > 0i64 {
                        if xv < 0i64 { sgn = 0i64 - 1i64 }
                    }
                    mb_mul64(mfa, mxa)
                    let sh : u64 = (MB_F32E - emin) as u64
                    let mut l0 : u64 = MB_MLO
                    let mut l1 : u64 = MB_MHI
                    let mut l2 : u64 = 0u64
                    if sh != 0u64 {
                        l2 = l1 >> (64u64 - sh)
                        l1 = (l1 << sh) | (l0 >> (64u64 - sh))
                        l0 = l0 << sh
                    }
                    mb_wacc3(sgn, l0, l1, l2)
                }
            }
            ce = ce + 1u64
        }
        /* running prefix totals; the reversed teeth below derive the
         * per-chunk deltas and re-fold them backwards */
        MB_CPS[ch] = MB_WAS
        MB_CP0[ch] = MB_WA0
        MB_CP1[ch] = MB_WA1
        MB_CP2[ch] = MB_WA2
        ch = ch + 1u64
    }
    if MB_IOERR != 0u8 { return 1u64 }
    /* THE PREFIX LAW: the running totals must be reproducible by folding
     * the per-chunk deltas backwards -- derive each delta as total_k minus
     * total_{k-1} and re-fold in reverse; the result must equal the row */
    MB_WAS = 0i64
    MB_WA0 = 0u64
    MB_WA1 = 0u64
    MB_WA2 = 0u64
    let mut ck : u64 = nchunk
    while ck != 0u64 {
        ck = ck - 1u64
        let mut ps : i64 = 0i64
        let mut p0 : u64 = 0u64
        let mut p1 : u64 = 0u64
        let mut p2 : u64 = 0u64
        if ck == 0u64 {
            ps = MB_CPS[0]
            p0 = MB_CP0[0]
            p1 = MB_CP1[0]
            p2 = MB_CP2[0]
        }
        if ck != 0u64 {
            /* delta_k = total_k + (-total_{k-1}) via the signed acc */
            let sv2s : i64 = MB_WAS
            let sv20 : u64 = MB_WA0
            let sv21 : u64 = MB_WA1
            let sv22 : u64 = MB_WA2
            MB_WAS = MB_CPS[ck]
            MB_WA0 = MB_CP0[ck]
            MB_WA1 = MB_CP1[ck]
            MB_WA2 = MB_CP2[ck]
            mb_wacc3(0i64 - MB_CPS[ck - 1u64], MB_CP0[ck - 1u64], MB_CP1[ck - 1u64], MB_CP2[ck - 1u64])
            ps = MB_WAS
            p0 = MB_WA0
            p1 = MB_WA1
            p2 = MB_WA2
            MB_WAS = sv2s
            MB_WA0 = sv20
            MB_WA1 = sv21
            MB_WA2 = sv22
        }
        mb_wacc3(ps, p0, p1, p2)
    }
    let fs : i64 = MB_CPS[nchunk - 1u64]
    if MB_WAS != fs { return 4u64 }
    if MB_WA0 != MB_CP0[nchunk - 1u64] { return 4u64 }
    if MB_WA1 != MB_CP1[nchunk - 1u64] { return 4u64 }
    if MB_WA2 != MB_CP2[nchunk - 1u64] { return 4u64 }
    MB_RLS[r] = MB_WAS
    MB_RL0[r] = MB_WA0
    MB_RL1[r] = MB_WA1
    MB_RL2[r] = MB_WA2
    MB_RLE[r] = emin - 24i64
    return 0u64
}

fn mb_arm374() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_C3_F == 0u8 {
        mb_rs("the walk: router absent from the feast (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    if MB_C3_TYPE != 0u64 {
        mb_rs("the walk: router foreign type=" as u64)
        mb_ru(MB_C3_TYPE)
        mb_rs(" (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    if MB_C3_NE0 != MB_C1_NE0 {
        mb_rs("the walk: router axis mismatch (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    let experts : u64 = MB_C3_NE / MB_C3_NE0
    if experts == 0u64 { return 374u64 }
    if experts > 256u64 {
        mb_rs("the walk: experts exceed the ledger (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    /* open the router's shard through the window reader */
    mb_mkpath(MB_C3_SHARD)
    let f : u64 = fopen((&MB_PATH) as u64, "rb" as u64)
    if f == 0u64 { return 374u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    let mut r : u64 = 0u64
    while r < experts {
        let rc : u64 = mb_walk_row(r)
        if rc == 2u64 {
            fclose(f)
            mb_rs("the walk: refused (nonfinite f32 in the router -- named)" as u64)
            mb_rb(10u8)
            return 0u64
        }
        if rc == 3u64 {
            fclose(f)
            mb_rs("the walk: refused (exponent spread beyond the guard -- named)" as u64)
            mb_rb(10u8)
            return 0u64
        }
        if rc != 0u64 {
            fclose(f)
            return 374u64
        }
        r = r + 1u64
    }
    fclose(f)
    /* global exponent alignment under the guard */
    let mut gmin : i64 = 1000i64
    r = 0u64
    while r < experts {
        if MB_RLS[r] != 0i64 {
            if MB_RLE[r] < gmin { gmin = MB_RLE[r] }
        }
        r = r + 1u64
    }
    if gmin != 1000i64 {
        r = 0u64
        while r < experts {
            if MB_RLS[r] != 0i64 {
                let sh : u64 = (MB_RLE[r] - gmin) as u64
                if sh > 32u64 {
                    mb_rs("the walk: refused (cross-expert spread beyond the guard -- named)" as u64)
                    mb_rb(10u8)
                    return 0u64
                }
                if sh != 0u64 {
                    let l0 : u64 = MB_RL0[r]
                    let l1 : u64 = MB_RL1[r]
                    let l2 : u64 = MB_RL2[r]
                    if (l2 >> (64u64 - sh)) != 0u64 { return 374u64 }
                    MB_RL2[r] = (l2 << sh) | (l1 >> (64u64 - sh))
                    MB_RL1[r] = (l1 << sh) | (l0 >> (64u64 - sh))
                    MB_RL0[r] = l0 << sh
                    MB_RLE[r] = gmin
                }
            }
            r = r + 1u64
        }
    }
    /* THE TOP-8, certified: repeated argmax with the lowest-index tie law;
     * softmax-topk equals logit-topk (any strictly monotone map preserves
     * order) -- NO exp is evaluated */
    let mut taken : u64 = 0u64
    let mut ties : u64 = 0u64
    while taken < 8u64 {
        let mut bi : u64 = 0xFFFFFFFFFFFFFFFFu64
        let mut bs : i64 = 0i64
        let mut b0 : u64 = 0u64
        let mut b1 : u64 = 0u64
        let mut b2 : u64 = 0u64
        r = 0u64
        while r < experts {
            let mut skip : u64 = 0u64
            let mut q : u64 = 0u64
            while q < taken {
                if MB_TOP[q] == r { skip = 1u64 }
                q = q + 1u64
            }
            if skip == 0u64 {
                if bi == 0xFFFFFFFFFFFFFFFFu64 {
                    bi = r
                    bs = MB_RLS[r]
                    b0 = MB_RL0[r]
                    b1 = MB_RL1[r]
                    b2 = MB_RL2[r]
                }
                if bi != r {
                    let c : i64 = mb_scmp192(MB_RLS[r], MB_RL0[r], MB_RL1[r], MB_RL2[r], bs, b0, b1, b2)
                    if c > 0i64 {
                        bi = r
                        bs = MB_RLS[r]
                        b0 = MB_RL0[r]
                        b1 = MB_RL1[r]
                        b2 = MB_RL2[r]
                    }
                    if c == 0i64 { ties = ties + 1u64 }
                }
            }
            r = r + 1u64
        }
        if bi == 0xFFFFFFFFFFFFFFFFu64 { return 374u64 }
        MB_TOP[taken] = bi
        taken = taken + 1u64
    }
    mb_rs("the walk: router=" as u64)
    let mut nn : u64 = 0u64
    while nn < MB_C3_NN {
        mb_rb(MB_C3_NAME[nn])
        nn = nn + 1u64
    }
    mb_rs(" type=f32 experts=" as u64)
    mb_ru(experts)
    mb_rs(" top8=" as u64)
    taken = 0u64
    while taken < 8u64 {
        if taken != 0u64 { mb_rb(44u8) }
        mb_ru(MB_TOP[taken])
        taken = taken + 1u64
    }
    mb_rs(" ties=" as u64)
    mb_ru(ties)
    mb_rs(" prefix-law=ok no-exp (monotone: softmax-topk = logit-topk)" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ============ arm 375: THE GAZE (exact attention QK, per head) ============ */

/* THE GAZE LAW: every RMSNorm in the MLA chain divides by ONE shared
 * positive scalar (a square root of a rational).  Per head, the score is
 * (C_i.E_i)/(sqrtQS sqrtKS) + (Crope_i.Drope)/(sqrtQS sqrtR): the surds are
 * COMMON POSITIVE FACTORS across all heads -- so per-head ORDER, SIGNS and
 * DOMINANCE of the true normalized scores are EXACT INTEGER facts.  The
 * roots never need taking.  At position 0 RoPE is rotation by zero -- the
 * identity, exactly -- so the first-position scores are whole.  Positions
 * beyond zero need certified sin/cos ladders: named, not faked. */

/* preloaded exact f32 norm vectors (mant, exp per element) */
var MB_ANM : [i64; 7168]
var MB_ANE : [i64; 7168]
var MB_QNM : [i64; 1536]
var MB_QNE : [i64; 1536]
var MB_KNM : [i64; 512]
var MB_KNE : [i64; 512]
/* stage vectors: sign, 3 limbs, exponent (canonical, bitlen <= 160) */
var MB_BVS : [i64; 1536]
var MB_BV0 : [u64; 1536]
var MB_BV1 : [u64; 1536]
var MB_BV2 : [u64; 1536]
var MB_BVE : [i64; 1536]
var MB_DVS : [i64; 576]
var MB_DV0 : [u64; 576]
var MB_DV1 : [u64; 576]
var MB_DV2 : [u64; 576]
var MB_DVE : [i64; 576]
/* per-head transients */
var MB_CHS : [i64; 192]
var MB_CH0 : [u64; 192]
var MB_CH1 : [u64; 192]
var MB_CH2 : [u64; 192]
var MB_CHE : [i64; 192]
var MB_EHS : [i64; 128]
var MB_EH0 : [u64; 128]
var MB_EH1 : [u64; 128]
var MB_EH2 : [u64; 128]
var MB_EHE : [i64; 128]
/* per-head verdicts: N1 (nope) and N2 (rope), 6-limb + exp */
var MB_N1S : [i64; 128]
var MB_N1L : [u64; 768]
var MB_N1E : [i64; 128]
var MB_N2S : [i64; 128]
var MB_N2L : [u64; 768]
var MB_N2E : [i64; 128]
/* the row's decoded weights (one row of any gaze tensor) */
var MB_GW : [i64; 7168]
/* the signed 6-limb accumulator */
var MB_6S : i64 = 0i64
var MB_6L : [u64; 6]
/* 6-limb source/term scratch */
var MB_T6 : [u64; 6]
/* 6-limb chunk prefixes (the per-row teeth) */
var MB_6CS : [i64; 112]
var MB_6CL : [u64; 672]
var MB_SVL : [u64; 6]
var MB_GZOVF : u64 = 0u64             /* the named guard ledger */

fn mb_t6_clear() -> i32 {
    let mut k : u64 = 0u64
    while k < 6u64 {
        MB_T6[k] = 0u64
        k = k + 1u64
    }
    return 0i32
}

/* magnitude compare acc vs T6 */
fn mb_6magcmp() -> i64 {
    let mut k : u64 = 6u64
    while k != 0u64 {
        k = k - 1u64
        if MB_6L[k] > MB_T6[k] { return 1i64 }
        if MB_6L[k] < MB_T6[k] { return 0i64 - 1i64 }
    }
    return 0i64
}

/* acc += sign*T6 (sign-magnitude, 6-limb) */
fn mb_acc6_add(ss: i64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let mut nz : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 6u64 {
        nz = nz | MB_T6[k]
        k = k + 1u64
    }
    if nz == 0u64 { return 0i32 }
    if MB_6S == 0i64 {
        MB_6S = ss
        k = 0u64
        while k < 6u64 {
            MB_6L[k] = MB_T6[k]
            k = k + 1u64
        }
        return 0i32
    }
    if MB_6S == ss {
        let mut carry : u64 = 0u64
        k = 0u64
        while k < 6u64 {
            let a : u64 = MB_6L[k] + MB_T6[k]
            let mut c2 : u64 = 0u64
            if a < MB_T6[k] { c2 = 1u64 }
            let b : u64 = a + carry
            if b < carry { c2 = c2 + 1u64 }
            MB_6L[k] = b
            carry = c2
            k = k + 1u64
        }
        if carry != 0u64 { MB_GZOVF = MB_GZOVF + 1u64 }
        return 0i32
    }
    let cmp : i64 = mb_6magcmp()
    if cmp == 0i64 {
        MB_6S = 0i64
        k = 0u64
        while k < 6u64 {
            MB_6L[k] = 0u64
            k = k + 1u64
        }
        return 0i32
    }
    if cmp > 0i64 {
        let mut borrow : u64 = 0u64
        k = 0u64
        while k < 6u64 {
            let d : u64 = MB_6L[k] - MB_T6[k]
            let mut b2 : u64 = 0u64
            if MB_6L[k] < MB_T6[k] { b2 = 1u64 }
            let e2 : u64 = d - borrow
            if d < borrow { b2 = b2 + 1u64 }
            MB_6L[k] = e2
            borrow = b2
            k = k + 1u64
        }
        return 0i32
    }
    let mut borrow2 : u64 = 0u64
    k = 0u64
    while k < 6u64 {
        let d3 : u64 = MB_T6[k] - MB_6L[k]
        let mut b3 : u64 = 0u64
        if MB_T6[k] < MB_6L[k] { b3 = 1u64 }
        let e3 : u64 = d3 - borrow2
        if d3 < borrow2 { b3 = b3 + 1u64 }
        MB_6L[k] = e3
        borrow2 = b3
        k = k + 1u64
    }
    MB_6S = ss
    return 0i32
}

/* T6 = (l0..l3) * m  (4 limbs by 1), then T6 <<= sh (sh <= 48) */
fn mb_t6_mul4_shl(l0: u64, l1: u64, l2: u64, l3: u64, m: u64, sh: u64) -> i32 {
    mb_t6_clear()
    mb_mul64(l0, m)
    MB_T6[0] = MB_MLO
    MB_T6[1] = MB_MHI
    mb_mul64(l1, m)
    let s1 : u64 = MB_T6[1] + MB_MLO
    let mut c1 : u64 = 0u64
    if s1 < MB_MLO { c1 = 1u64 }
    MB_T6[1] = s1
    MB_T6[2] = MB_MHI + c1
    mb_mul64(l2, m)
    let s2 : u64 = MB_T6[2] + MB_MLO
    let mut c2 : u64 = 0u64
    if s2 < MB_MLO { c2 = 1u64 }
    MB_T6[2] = s2
    MB_T6[3] = MB_MHI + c2
    mb_mul64(l3, m)
    let s3 : u64 = MB_T6[3] + MB_MLO
    let mut c3 : u64 = 0u64
    if s3 < MB_MLO { c3 = 1u64 }
    MB_T6[3] = s3
    MB_T6[4] = MB_MHI + c3
    if sh != 0u64 {
        let mut k : u64 = 6u64
        while k != 0u64 {
            k = k - 1u64
            let mut v : u64 = MB_T6[k] << sh
            if k != 0u64 { v = v | (MB_T6[k - 1u64] >> (64u64 - sh)) }
            MB_T6[k] = v
        }
    }
    return 0i32
}

/* fetch source element `c` for kind (0 hw, 1 B*w_qan, 2 D*w_kvn):
 * writes sign MB_SFS, limbs MB_SF0..3, exp MB_SFE */
var MB_SFS : i64 = 0i64
var MB_SF0 : u64 = 0u64
var MB_SF1 : u64 = 0u64
var MB_SF2 : u64 = 0u64
var MB_SF3 : u64 = 0u64
var MB_SFE : i64 = 0i64
fn mb_gz_src(kind: u64, c: u64) -> i32 {
    if kind == 0u64 {
        let h : i64 = MB_XV[c]
        let wm : i64 = MB_ANM[c]
        MB_SFS = 0i64
        if h > 0i64 {
            if wm > 0i64 { MB_SFS = 1i64 }
            if wm < 0i64 { MB_SFS = 0i64 - 1i64 }
        }
        if h < 0i64 {
            if wm > 0i64 { MB_SFS = 0i64 - 1i64 }
            if wm < 0i64 { MB_SFS = 1i64 }
        }
        let mut hm : u64 = h as u64
        if h < 0i64 { hm = (0i64 - h) as u64 }
        let mut wmm : u64 = wm as u64
        if wm < 0i64 { wmm = (0i64 - wm) as u64 }
        mb_mul64(hm, wmm)
        MB_SF0 = MB_MLO
        MB_SF1 = MB_MHI
        MB_SF2 = 0u64
        MB_SF3 = 0u64
        MB_SFE = MB_ANE[c] - 24i64
        return 0i32
    }
    let mut vs : i64 = 0i64
    let mut v0 : u64 = 0u64
    let mut v1 : u64 = 0u64
    let mut v2 : u64 = 0u64
    let mut ve : i64 = 0i64
    let mut wm2 : i64 = 0i64
    let mut we2 : i64 = 0i64
    if kind == 1u64 {
        vs = MB_BVS[c]
        v0 = MB_BV0[c]
        v1 = MB_BV1[c]
        v2 = MB_BV2[c]
        ve = MB_BVE[c]
        wm2 = MB_QNM[c]
        we2 = MB_QNE[c]
    }
    if kind == 2u64 {
        vs = MB_DVS[c]
        v0 = MB_DV0[c]
        v1 = MB_DV1[c]
        v2 = MB_DV2[c]
        ve = MB_DVE[c]
        wm2 = MB_KNM[c]
        we2 = MB_KNE[c]
    }
    MB_SFS = 0i64
    if vs != 0i64 {
        if wm2 > 0i64 { MB_SFS = vs }
        if wm2 < 0i64 { MB_SFS = 0i64 - vs }
    }
    let mut wmm2 : u64 = wm2 as u64
    if wm2 < 0i64 { wmm2 = (0i64 - wm2) as u64 }
    /* (v0..v2) * wmm2 -> 4 limbs */
    mb_mul64(v0, wmm2)
    MB_SF0 = MB_MLO
    let mut t1 : u64 = MB_MHI
    mb_mul64(v1, wmm2)
    let s1 : u64 = t1 + MB_MLO
    let mut c1 : u64 = 0u64
    if s1 < MB_MLO { c1 = 1u64 }
    MB_SF1 = s1
    let mut t2 : u64 = MB_MHI + c1
    mb_mul64(v2, wmm2)
    let s2 : u64 = t2 + MB_MLO
    let mut c2 : u64 = 0u64
    if s2 < MB_MLO { c2 = 1u64 }
    MB_SF2 = s2
    MB_SF3 = MB_MHI + c2
    MB_SFE = ve + we2
    return 0i32
}

/* decode one full row of gaze tensor slot g into MB_GW (dyadic mants) */
fn mb_gz_wrow(g: u64, row: u64) -> u64 {
    let ty : u64 = MB_G_TYPE[g]
    let bb : u64 = mb_tbb(ty)
    let bv : u64 = mb_tbv(ty)
    if bv != 256u64 { return 1u64 }
    let ne0 : u64 = MB_G_NE0[g]
    let bpr : u64 = ne0 / 256u64
    let mut b : u64 = 0u64
    while b < bpr {
        let abs : u64 = MB_G_DB[g] + MB_G_OFF[g] + (row * bpr + b) * bb
        if mb_wread(0u64, abs, bb) != 0u64 { return 1u64 }
        if mb_wdec(0u64, ty, 0u64) != 0u64 { return 1u64 }
        let mut e : u64 = 0u64
        while e < 256u64 {
            MB_GW[b * 256u64 + e] = MB_LVA[e]
            e = e + 1u64
        }
        b = b + 1u64
    }
    return 0u64
}

/* one exact matvec row: weights (MB_GW, already decoded) . source(kind).
 * Two passes (exponent window, then aligned 6-limb accumulation with
 * per-64-chunk prefixes), then the PREFIX LAW re-fold, then canonical
 * store into (s, 3 limbs, exp).  returns 0 ok / 1 red / 2 guard */
var MB_RRS : i64 = 0i64
var MB_RR0 : u64 = 0u64
var MB_RR1 : u64 = 0u64
var MB_RR2 : u64 = 0u64
var MB_RRE : i64 = 0i64
fn mb_gz_dotrow(n: u64, kind: u64) -> u64 {
    let mut emin : i64 = 100000i64
    let mut emax : i64 = 0i64 - 100000i64
    let mut c : u64 = 0u64
    while c < n {
        if MB_GW[c] != 0i64 {
            mb_gz_src(kind, c)
            if MB_SFS != 0i64 {
                if MB_SFE < emin { emin = MB_SFE }
                if MB_SFE > emax { emax = MB_SFE }
            }
        }
        c = c + 1u64
    }
    if emin == 100000i64 {
        MB_RRS = 0i64
        MB_RR0 = 0u64
        MB_RR1 = 0u64
        MB_RR2 = 0u64
        MB_RRE = 0i64
        return 0u64
    }
    if emax - emin > 48i64 { return 2u64 }
    MB_6S = 0i64
    let mut k : u64 = 0u64
    while k < 6u64 {
        MB_6L[k] = 0u64
        k = k + 1u64
    }
    MB_GZOVF = 0u64
    let nch : u64 = (n + 63u64) / 64u64
    let mut ch : u64 = 0u64
    while ch < nch {
        let mut ce : u64 = ch * 64u64
        let mut cend : u64 = ce + 64u64
        if cend > n { cend = n }
        while ce < cend {
            let wq : i64 = MB_GW[ce]
            if wq != 0i64 {
                mb_gz_src(kind, ce)
                if MB_SFS != 0i64 {
                    let mut wqm : u64 = wq as u64
                    if wq < 0i64 { wqm = (0i64 - wq) as u64 }
                    let mut sgn : i64 = MB_SFS
                    if wq < 0i64 { sgn = 0i64 - MB_SFS }
                    let sh : u64 = (MB_SFE - emin) as u64
                    mb_t6_mul4_shl(MB_SF0, MB_SF1, MB_SF2, MB_SF3, wqm, sh)
                    mb_acc6_add(sgn)
                }
            }
            ce = ce + 1u64
        }
        MB_6CS[ch] = MB_6S
        let mut q : u64 = 0u64
        while q < 6u64 {
            MB_6CL[ch * 6u64 + q] = MB_6L[q]
            q = q + 1u64
        }
        ch = ch + 1u64
    }
    if MB_GZOVF != 0u64 { return 2u64 }
    /* THE PREFIX LAW: deltas re-folded backwards must land on the row */
    let fin_s : i64 = MB_6CS[nch - 1u64]
    MB_6S = 0i64
    k = 0u64
    while k < 6u64 {
        MB_6L[k] = 0u64
        k = k + 1u64
    }
    let mut ck : u64 = nch
    while ck != 0u64 {
        ck = ck - 1u64
        /* delta_ck = prefix_ck - prefix_{ck-1}: fold via two adds */
        let mut q2 : u64 = 0u64
        while q2 < 6u64 {
            MB_T6[q2] = MB_6CL[ck * 6u64 + q2]
            q2 = q2 + 1u64
        }
        mb_acc6_add(MB_6CS[ck])
        if ck != 0u64 {
            q2 = 0u64
            while q2 < 6u64 {
                MB_T6[q2] = MB_6CL[(ck - 1u64) * 6u64 + q2]
                q2 = q2 + 1u64
            }
            mb_acc6_add(0i64 - MB_6CS[ck - 1u64])
        }
    }
    if MB_6S != fin_s { return 1u64 }
    k = 0u64
    while k < 6u64 {
        if MB_6L[k] != MB_6CL[(nch - 1u64) * 6u64 + k] { return 1u64 }
        k = k + 1u64
    }
    /* canonical store: strip twos, demand bitlen <= 160 */
    let mut tz : u64 = 0u64
    let mut nzk : u64 = 0u64
    k = 0u64
    while k < 6u64 {
        nzk = nzk | MB_6L[k]
        k = k + 1u64
    }
    if nzk == 0u64 {
        MB_RRS = 0i64
        MB_RR0 = 0u64
        MB_RR1 = 0u64
        MB_RR2 = 0u64
        MB_RRE = 0i64
        return 0u64
    }
    let mut go : u8 = 1u8
    while go == 1u8 {
        go = 0u8
        if (MB_6L[0] & 1u64) == 0u64 {
            k = 0u64
            while k < 5u64 {
                MB_6L[k] = (MB_6L[k] >> 1u64) | (MB_6L[k + 1u64] << 63u64)
                k = k + 1u64
            }
            MB_6L[5] = MB_6L[5] >> 1u64
            tz = tz + 1u64
            go = 1u8
        }
    }
    if MB_6L[3] != 0u64 { return 2u64 }
    if MB_6L[4] != 0u64 { return 2u64 }
    if MB_6L[5] != 0u64 { return 2u64 }
    if mb_bitlen(MB_6L[2]) > 32u64 { return 2u64 }
    MB_RRS = fin_s
    MB_RR0 = MB_6L[0]
    MB_RR1 = MB_6L[1]
    MB_RR2 = MB_6L[2]
    MB_RRE = emin - 24i64 + (tz as i64)
    return 0u64
}

/* pair-dot: sum over d of A[d]*B[d] where both sides are (s,3limb,exp)
 * arrays; which 0 = C(nope 0..127) x E, 1 = C(rope 128..) x D(512+).
 * result -> MB_6S/MB_6L + exp MB_PDE.  returns 0/1/2 as above */
var MB_PDE : i64 = 0i64
fn mb_gz_pairdot(which: u64, n: u64) -> u64 {
    let mut emin : i64 = 100000i64
    let mut emax : i64 = 0i64 - 100000i64
    let mut d : u64 = 0u64
    while d < n {
        let mut sa : i64 = 0i64
        let mut sb : i64 = 0i64
        let mut ea : i64 = 0i64
        let mut eb : i64 = 0i64
        if which == 0u64 {
            sa = MB_CHS[d]
            ea = MB_CHE[d]
            sb = MB_EHS[d]
            eb = MB_EHE[d]
        }
        if which == 1u64 {
            sa = MB_CHS[128u64 + d]
            ea = MB_CHE[128u64 + d]
            sb = MB_DVS[512u64 + d]
            eb = MB_DVE[512u64 + d]
        }
        if sa != 0i64 {
            if sb != 0i64 {
                let te : i64 = ea + eb
                if te < emin { emin = te }
                if te > emax { emax = te }
            }
        }
        d = d + 1u64
    }
    if emin == 100000i64 {
        MB_6S = 0i64
        let mut kq : u64 = 0u64
        while kq < 6u64 {
            MB_6L[kq] = 0u64
            kq = kq + 1u64
        }
        MB_PDE = 0i64
        return 0u64
    }
    if emax - emin > 48i64 { return 2u64 }
    MB_6S = 0i64
    let mut k : u64 = 0u64
    while k < 6u64 {
        MB_6L[k] = 0u64
        k = k + 1u64
    }
    MB_GZOVF = 0u64
    d = 0u64
    while d < n {
        let mut sa2 : i64 = 0i64
        let mut a0 : u64 = 0u64
        let mut a1 : u64 = 0u64
        let mut a2 : u64 = 0u64
        let mut ea2 : i64 = 0i64
        let mut sb2 : i64 = 0i64
        let mut b0 : u64 = 0u64
        let mut b1 : u64 = 0u64
        let mut b2 : u64 = 0u64
        let mut eb2 : i64 = 0i64
        if which == 0u64 {
            sa2 = MB_CHS[d]
            a0 = MB_CH0[d]
            a1 = MB_CH1[d]
            a2 = MB_CH2[d]
            ea2 = MB_CHE[d]
            sb2 = MB_EHS[d]
            b0 = MB_EH0[d]
            b1 = MB_EH1[d]
            b2 = MB_EH2[d]
            eb2 = MB_EHE[d]
        }
        if which == 1u64 {
            sa2 = MB_CHS[128u64 + d]
            a0 = MB_CH0[128u64 + d]
            a1 = MB_CH1[128u64 + d]
            a2 = MB_CH2[128u64 + d]
            ea2 = MB_CHE[128u64 + d]
            sb2 = MB_DVS[512u64 + d]
            b0 = MB_DV0[512u64 + d]
            b1 = MB_DV1[512u64 + d]
            b2 = MB_DV2[512u64 + d]
            eb2 = MB_DVE[512u64 + d]
        }
        if sa2 != 0i64 {
            if sb2 != 0i64 {
                mb_mul192(a0, a1, a2, b0, b1, b2)
                let sh : u64 = ((ea2 + eb2) - emin) as u64
                let mut q3 : u64 = 0u64
                while q3 < 6u64 {
                    MB_T6[q3] = MB_R6[q3]
                    q3 = q3 + 1u64
                }
                if sh != 0u64 {
                    let mut kk : u64 = 6u64
                    while kk != 0u64 {
                        kk = kk - 1u64
                        let mut v2 : u64 = MB_T6[kk] << sh
                        if kk != 0u64 { v2 = v2 | (MB_T6[kk - 1u64] >> (64u64 - sh)) }
                        MB_T6[kk] = v2
                    }
                }
                let mut sg : i64 = sa2
                if sb2 < 0i64 { sg = 0i64 - sg }
                mb_acc6_add(sg)
            }
        }
        d = d + 1u64
    }
    if MB_GZOVF != 0u64 { return 2u64 }
    MB_PDE = emin
    return 0u64
}

/* head comparison of stored (s, 6-limb, exp): decisive by sign, then by
 * (bitlen + exp), then by aligned limbs */
fn mb_gz_hbits(arr_l: u64, i: u64) -> u64 {
    /* bitlen of head i's 6 limbs in N1L (arr_l 0) or N2L (arr_l 1) */
    let mut k : u64 = 6u64
    while k != 0u64 {
        k = k - 1u64
        let mut v : u64 = 0u64
        if arr_l == 0u64 { v = MB_N1L[i * 6u64 + k] }
        if arr_l == 1u64 { v = MB_N2L[i * 6u64 + k] }
        if v != 0u64 { return k * 64u64 + mb_bitlen(v) }
    }
    return 0u64
}

fn mb_gz_hcmp(arr: u64, i: u64, j: u64) -> i64 {
    let mut si : i64 = 0i64
    let mut sj : i64 = 0i64
    let mut ei : i64 = 0i64
    let mut ej : i64 = 0i64
    if arr == 0u64 {
        si = MB_N1S[i]
        sj = MB_N1S[j]
        ei = MB_N1E[i]
        ej = MB_N1E[j]
    }
    if arr == 1u64 {
        si = MB_N2S[i]
        sj = MB_N2S[j]
        ei = MB_N2E[i]
        ej = MB_N2E[j]
    }
    if si > sj { return 1i64 }
    if si < sj { return 0i64 - 1i64 }
    if si == 0i64 { return 0i64 }
    let bi : i64 = (mb_gz_hbits(arr, i) as i64) + ei
    let bj : i64 = (mb_gz_hbits(arr, j) as i64) + ej
    let mut mag : i64 = 0i64
    if bi > bj { mag = 1i64 }
    if bi < bj { mag = 0i64 - 1i64 }
    if mag == 0i64 {
        /* same magnitude class: align to the smaller exponent and compare */
        let mut sh_i : u64 = 0u64
        let mut sh_j : u64 = 0u64
        if ei > ej { sh_i = (ei - ej) as u64 }
        if ej > ei { sh_j = (ej - ei) as u64 }
        let mut k : u64 = 6u64
        let mut cmp : i64 = 0i64
        while k != 0u64 {
            k = k - 1u64
            /* aligned limb extraction with shift-left by sh (guarded small) */
            let mut vi : u64 = 0u64
            let mut vj : u64 = 0u64
            if arr == 0u64 {
                vi = MB_N1L[i * 6u64 + k] << sh_i
                if k != 0u64 {
                    if sh_i != 0u64 { vi = vi | (MB_N1L[i * 6u64 + k - 1u64] >> (64u64 - sh_i)) }
                }
                vj = MB_N1L[j * 6u64 + k] << sh_j
                if k != 0u64 {
                    if sh_j != 0u64 { vj = vj | (MB_N1L[j * 6u64 + k - 1u64] >> (64u64 - sh_j)) }
                }
            }
            if arr == 1u64 {
                vi = MB_N2L[i * 6u64 + k] << sh_i
                if k != 0u64 {
                    if sh_i != 0u64 { vi = vi | (MB_N2L[i * 6u64 + k - 1u64] >> (64u64 - sh_i)) }
                }
                vj = MB_N2L[j * 6u64 + k] << sh_j
                if k != 0u64 {
                    if sh_j != 0u64 { vj = vj | (MB_N2L[j * 6u64 + k - 1u64] >> (64u64 - sh_j)) }
                }
            }
            if cmp == 0i64 {
                if vi > vj { cmp = 1i64 }
                if vi < vj { cmp = 0i64 - 1i64 }
            }
        }
        mag = cmp
    }
    if si < 0i64 { return 0i64 - mag }
    return mag
}

/* load an f32 norm vector (slot g) into the chosen preload arrays */
fn mb_gz_loadf32(g: u64, which: u64, n: u64) -> u64 {
    if MB_G_TYPE[g] != 0u64 { return 1u64 }
    if MB_G_NE[g] != n { return 1u64 }
    mb_mkpath(MB_G_SH[g])
    let f : u64 = fopen((&MB_PATH) as u64, "rb" as u64)
    if f == 0u64 { return 1u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    mb_seek_abs(MB_G_DB[g] + MB_G_OFF[g])
    let mut c : u64 = 0u64
    while c < n {
        let bits : u64 = mb_u32()
        let m : i64 = mb_f32m(bits)
        if m == 4611686018427387904i64 {
            fclose(f)
            return 1u64
        }
        if which == 0u64 {
            MB_ANM[c] = m
            MB_ANE[c] = MB_F32E
        }
        if which == 1u64 {
            MB_QNM[c] = m
            MB_QNE[c] = MB_F32E
        }
        if which == 2u64 {
            MB_KNM[c] = m
            MB_KNE[c] = MB_F32E
        }
        c = c + 1u64
    }
    let mut rr : u64 = 0u64
    if MB_IOERR != 0u8 { rr = 1u64 }
    fclose(f)
    return rr
}

fn mb_arm375() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    /* the seven organs must all be on the table; foreignness is named */
    let mut g : u64 = 0u64
    while g < 7u64 {
        if MB_G_F[g] == 0u8 {
            mb_rs("the gaze: blk.0 attention absent from the feast (named, lawful)" as u64)
            mb_rb(10u8)
            return 0u64
        }
        g = g + 1u64
    }
    if MB_NHEAD == 0u64 { return 375u64 }
    if MB_NHEAD > 128u64 {
        mb_rs("the gaze: heads exceed the ledger (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    let hw : u64 = MB_G_NE[3] / MB_G_NE0[3] / MB_NHEAD    /* per-head q width */
    if hw <= MB_NROPE { return 375u64 }
    let nope : u64 = hw - MB_NROPE
    let kvw : u64 = MB_G_NE[6] / MB_G_NE0[6] / MB_NHEAD   /* per-head kv width */
    if kvw < nope { return 375u64 }
    if MB_G_NE0[1] != MB_G_NE[0] { return 375u64 }        /* q_a input = embed */
    if MB_G_NE0[3] != MB_G_NE[2] { return 375u64 }        /* q_b input = q_a_norm width */
    if MB_G_NE0[6] != MB_G_NE[5] { return 375u64 }        /* kv_b input = kv_a_norm width */
    let qa_rank : u64 = MB_G_NE[2]
    let kv_rank : u64 = MB_G_NE[5]
    if MB_G_NE0[4] != MB_G_NE[0] { return 375u64 }
    if MB_G_NE[4] / MB_G_NE0[4] < kv_rank + MB_NROPE { return 375u64 }
    /* the one-shard premise for the weight streams (true of this feast;
     * a scattered layout would be a lawful named refusal) */
    g = 1u64
    while g < 7u64 {
        if MB_G_SH[g] != MB_G_SH[1] {
            mb_rs("the gaze: attention scattered across shards (named, lawful)" as u64)
            mb_rb(10u8)
            return 0u64
        }
        g = g + 1u64
    }
    /* preload the three f32 norm vectors */
    if mb_gz_loadf32(0u64, 0u64, MB_G_NE[0]) != 0u64 { return 375u64 }
    if mb_gz_loadf32(2u64, 1u64, qa_rank) != 0u64 { return 375u64 }
    if mb_gz_loadf32(5u64, 2u64, kv_rank) != 0u64 { return 375u64 }
    /* the weight streams live on shard(s): open worker-0 handle per tensor
     * as needed (all gaze tensors sit in shard 1 for this feast; the path
     * is rebuilt per tensor from its OWN shard index) */
    mb_mkpath(MB_G_SH[1])
    MB_LFILE[0] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0] == 0u64 { return 375u64 }
    /* stage B: q_a rows (into BV), then D: kv_a rows (into DV) */
    let mut r : u64 = 0u64
    while r < qa_rank {
        if mb_gz_wrow(1u64, r) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        let rc : u64 = mb_gz_dotrow(MB_G_NE0[1], 0u64)
        if rc != 0u64 {
            fclose(MB_LFILE[0])
            if rc == 2u64 {
                mb_rs("the gaze: refused (guard tripped in stage B -- named)" as u64)
                mb_rb(10u8)
                return 0u64
            }
            return 375u64
        }
        MB_BVS[r] = MB_RRS
        MB_BV0[r] = MB_RR0
        MB_BV1[r] = MB_RR1
        MB_BV2[r] = MB_RR2
        MB_BVE[r] = MB_RRE
        r = r + 1u64
    }
    let d_rows : u64 = kv_rank + MB_NROPE
    r = 0u64
    while r < d_rows {
        if mb_gz_wrow(4u64, r) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        let rc2 : u64 = mb_gz_dotrow(MB_G_NE0[4], 0u64)
        if rc2 != 0u64 {
            fclose(MB_LFILE[0])
            if rc2 == 2u64 {
                mb_rs("the gaze: refused (guard tripped in stage D -- named)" as u64)
                mb_rb(10u8)
                return 0u64
            }
            return 375u64
        }
        MB_DVS[r] = MB_RRS
        MB_DV0[r] = MB_RR0
        MB_DV1[r] = MB_RR1
        MB_DV2[r] = MB_RR2
        MB_DVE[r] = MB_RRE
        r = r + 1u64
    }
    /* the heads */
    let mut hh : u64 = 0u64
    while hh < MB_NHEAD {
        let mut d2 : u64 = 0u64
        while d2 < hw {
            if mb_gz_wrow(3u64, hh * hw + d2) != 0u64 {
                fclose(MB_LFILE[0])
                return 375u64
            }
            let rc3 : u64 = mb_gz_dotrow(MB_G_NE0[3], 1u64)
            if rc3 != 0u64 {
                fclose(MB_LFILE[0])
                return 375u64
            }
            MB_CHS[d2] = MB_RRS
            MB_CH0[d2] = MB_RR0
            MB_CH1[d2] = MB_RR1
            MB_CH2[d2] = MB_RR2
            MB_CHE[d2] = MB_RRE
            d2 = d2 + 1u64
        }
        d2 = 0u64
        while d2 < nope {
            if mb_gz_wrow(6u64, hh * kvw + d2) != 0u64 {
                fclose(MB_LFILE[0])
                return 375u64
            }
            let rc4 : u64 = mb_gz_dotrow(MB_G_NE0[6], 2u64)
            if rc4 != 0u64 {
                fclose(MB_LFILE[0])
                return 375u64
            }
            MB_EHS[d2] = MB_RRS
            MB_EH0[d2] = MB_RR0
            MB_EH1[d2] = MB_RR1
            MB_EH2[d2] = MB_RR2
            MB_EHE[d2] = MB_RRE
            d2 = d2 + 1u64
        }
        if mb_gz_pairdot(0u64, nope) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        MB_N1S[hh] = MB_6S
        MB_N1E[hh] = MB_PDE
        let mut q4 : u64 = 0u64
        while q4 < 6u64 {
            MB_N1L[hh * 6u64 + q4] = MB_6L[q4]
            q4 = q4 + 1u64
        }
        if mb_gz_pairdot(1u64, MB_NROPE) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        MB_N2S[hh] = MB_6S
        MB_N2E[hh] = MB_PDE
        q4 = 0u64
        while q4 < 6u64 {
            MB_N2L[hh * 6u64 + q4] = MB_6L[q4]
            q4 = q4 + 1u64
        }
        hh = hh + 1u64
    }
    fclose(MB_LFILE[0])
    /* the verdicts: per-part argmax (lowest index on ties), sign census,
     * and the DOMINANCE fold over all pairs */
    let mut a1 : u64 = 0u64
    let mut a2 : u64 = 0u64
    let mut i : u64 = 1u64
    while i < MB_NHEAD {
        if mb_gz_hcmp(0u64, i, a1) > 0i64 { a1 = i }
        if mb_gz_hcmp(1u64, i, a2) > 0i64 { a2 = i }
        i = i + 1u64
    }
    let mut sp : u64 = 0u64
    let mut sn : u64 = 0u64
    let mut sz : u64 = 0u64
    i = 0u64
    while i < MB_NHEAD {
        if MB_N1S[i] > 0i64 { sp = sp + 1u64 }
        if MB_N1S[i] < 0i64 { sn = sn + 1u64 }
        if MB_N1S[i] == 0i64 { sz = sz + 1u64 }
        i = i + 1u64
    }
    if sp + sn + sz != MB_NHEAD { return 375u64 }
    let mut conc : u64 = 0u64
    let mut disc : u64 = 0u64
    i = 0u64
    while i < MB_NHEAD {
        let mut j : u64 = i + 1u64
        while j < MB_NHEAD {
            let c1 : i64 = mb_gz_hcmp(0u64, i, j)
            let c2 : i64 = mb_gz_hcmp(1u64, i, j)
            let mut isdisc : u64 = 0u64
            if c1 > 0i64 {
                if c2 < 0i64 { isdisc = 1u64 }
            }
            if c1 < 0i64 {
                if c2 > 0i64 { isdisc = 1u64 }
            }
            if isdisc == 1u64 { disc = disc + 1u64 }
            if isdisc == 0u64 { conc = conc + 1u64 }
            j = j + 1u64
        }
        i = i + 1u64
    }
    if conc + disc != (MB_NHEAD * (MB_NHEAD - 1u64)) / 2u64 { return 375u64 }
    /* THE DOUBLE STREAM: the nope-argmax head recomputed from fresh reads */
    let sv_s : i64 = MB_N1S[a1]
    let sv_e : i64 = MB_N1E[a1]
    let mut q5 : u64 = 0u64
    while q5 < 6u64 {
        MB_SVL[q5] = MB_N1L[a1 * 6u64 + q5]
        q5 = q5 + 1u64
    }
    mb_mkpath(MB_G_SH[1])
    MB_LFILE[0] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0] == 0u64 { return 375u64 }
    let mut d3 : u64 = 0u64
    while d3 < hw {
        if mb_gz_wrow(3u64, a1 * hw + d3) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        if mb_gz_dotrow(MB_G_NE0[3], 1u64) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        MB_CHS[d3] = MB_RRS
        MB_CH0[d3] = MB_RR0
        MB_CH1[d3] = MB_RR1
        MB_CH2[d3] = MB_RR2
        MB_CHE[d3] = MB_RRE
        d3 = d3 + 1u64
    }
    d3 = 0u64
    while d3 < nope {
        if mb_gz_wrow(6u64, a1 * kvw + d3) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        if mb_gz_dotrow(MB_G_NE0[6], 2u64) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        MB_EHS[d3] = MB_RRS
        MB_EH0[d3] = MB_RR0
        MB_EH1[d3] = MB_RR1
        MB_EH2[d3] = MB_RR2
        MB_EHE[d3] = MB_RRE
        d3 = d3 + 1u64
    }
    fclose(MB_LFILE[0])
    if mb_gz_pairdot(0u64, nope) != 0u64 { return 375u64 }
    if MB_6S != sv_s { return 375u64 }
    if MB_PDE != sv_e { return 375u64 }
    q5 = 0u64
    while q5 < 6u64 {
        if MB_6L[q5] != MB_SVL[q5] { return 375u64 }
        q5 = q5 + 1u64
    }
    MB_GAZE_OK = 1u64
    mb_rs("the gaze: layer=0 pos=0 heads=" as u64)
    mb_ru(MB_NHEAD)
    mb_rs(" width=" as u64)
    mb_ru(nope)
    mb_rs("+" as u64)
    mb_ru(MB_NROPE)
    mb_rs(" rope-at-0=identity nope-argmax=" as u64)
    mb_ru(a1)
    mb_rs(" rope-argmax=" as u64)
    mb_ru(a2)
    mb_rs(" sign p/n/z=" as u64)
    mb_ru(sp)
    mb_rs("/" as u64)
    mb_ru(sn)
    mb_rs("/" as u64)
    mb_ru(sz)
    mb_rs(" dominance concordant=" as u64)
    mb_ru(conc)
    mb_rs(" discordant=" as u64)
    mb_ru(disc)
    mb_rs(" (surd frontier named) prefix-law=ok double-stream=ok norm-scalars=shared (order is integer-exact)" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ============ arm 376: THE TELOS (the surd frontier closed) ============ */

/* sign(dN1*sqrtR + dN2*sqrtKS) with R = (RN/7)*2^ra, KS = (KSn/7)*2^kc:
 * same signs decide at once; opposite signs square-compare with the 7s
 * cancelling: m1^2*RN*2^(2e1+ra) vs m2^2*KSn*2^(2e2+kc) -- pure integers.
 * No root is ever taken. */

var MB_TLA : [u64; 24]
var MB_TLB : [u64; 24]
var MB_TLT : [u64; 24]
var MB_S8A : [u64; 8]
var MB_S8B : [u64; 8]
var MB_TLOVF : u64 = 0u64
var MB_RNL : [u64; 4]
var MB_RA : i64 = 0i64
var MB_KSN : [u64; 12]
var MB_KC : i64 = 0i64
var MB_SD2 : [u64; 12]
var MB_WINS : [u64; 128]
var MB_WSEEN : [u8; 128]

fn mb_tl_clear(w: u64) -> i32 {
    let mut k : u64 = 0u64
    while k < 24u64 {
        if w == 0u64 { MB_TLA[k] = 0u64 }
        if w == 1u64 { MB_TLB[k] = 0u64 }
        k = k + 1u64
    }
    return 0i32
}

fn mb_tl_addat(w: u64, k0: u64, v: u64) -> i32 {
    if v == 0u64 { return 0i32 }
    let mut k : u64 = k0
    let mut carry : u64 = v
    while carry != 0u64 {
        if k >= 24u64 {
            MB_TLOVF = 1u64
            return 0i32
        }
        let mut cur : u64 = 0u64
        if w == 0u64 { cur = MB_TLA[k] }
        if w == 1u64 { cur = MB_TLB[k] }
        let s : u64 = cur + carry
        let mut nc : u64 = 0u64
        if s < carry { nc = 1u64 }
        if w == 0u64 { MB_TLA[k] = s }
        if w == 1u64 { MB_TLB[k] = s }
        carry = nc
        k = k + 1u64
    }
    return 0i32
}

/* w := square of the 8-limb S8 source (0 -> S8A, 1 -> S8B) */
fn mb_tl_sq8(w: u64) -> i32 {
    mb_tl_clear(w)
    let mut i : u64 = 0u64
    while i < 8u64 {
        let mut ai : u64 = 0u64
        if w == 0u64 { ai = MB_S8A[i] }
        if w == 1u64 { ai = MB_S8B[i] }
        let mut j : u64 = 0u64
        while j < 8u64 {
            let mut bj : u64 = 0u64
            if w == 0u64 { bj = MB_S8A[j] }
            if w == 1u64 { bj = MB_S8B[j] }
            if ai != 0u64 {
                if bj != 0u64 {
                    mb_mul64(ai, bj)
                    mb_tl_addat(w, i + j, MB_MLO)
                    mb_tl_addat(w, i + j + 1u64, MB_MHI)
                }
            }
            j = j + 1u64
        }
        i = i + 1u64
    }
    return 0i32
}

/* w *= src (src = RNL(4) when which 0, KSN(12) when which 1) */
fn mb_tl_mulsrc(w: u64, which: u64) -> i32 {
    let mut k : u64 = 0u64
    while k < 24u64 {
        if w == 0u64 { MB_TLT[k] = MB_TLA[k] }
        if w == 1u64 { MB_TLT[k] = MB_TLB[k] }
        k = k + 1u64
    }
    mb_tl_clear(w)
    let mut i : u64 = 0u64
    while i < 24u64 {
        if MB_TLT[i] != 0u64 {
            let mut n : u64 = 4u64
            if which == 1u64 { n = 12u64 }
            let mut j : u64 = 0u64
            while j < n {
                let mut sj : u64 = 0u64
                if which == 0u64 { sj = MB_RNL[j] }
                if which == 1u64 { sj = MB_KSN[j] }
                if sj != 0u64 {
                    mb_mul64(MB_TLT[i], sj)
                    mb_tl_addat(w, i + j, MB_MLO)
                    mb_tl_addat(w, i + j + 1u64, MB_MHI)
                }
                j = j + 1u64
            }
        }
        i = i + 1u64
    }
    return 0i32
}

fn mb_tl_shl(w: u64, sh: u64) -> i32 {
    let ls : u64 = sh / 64u64
    let bs : u64 = sh % 64u64
    let mut k : u64 = 24u64
    while k != 0u64 {
        k = k - 1u64
        let mut v : u64 = 0u64
        if k >= ls {
            let src : u64 = k - ls
            let mut lo : u64 = 0u64
            if w == 0u64 { lo = MB_TLA[src] }
            if w == 1u64 { lo = MB_TLB[src] }
            v = lo << bs
            if bs != 0u64 {
                if src != 0u64 {
                    let mut lo2 : u64 = 0u64
                    if w == 0u64 { lo2 = MB_TLA[src - 1u64] }
                    if w == 1u64 { lo2 = MB_TLB[src - 1u64] }
                    v = v | (lo2 >> (64u64 - bs))
                }
            }
            /* dropped high bits would be an overflow */
            if k == 23u64 {
                if bs != 0u64 {
                    let mut hi : u64 = 0u64
                    if w == 0u64 { hi = MB_TLA[src] }
                    if w == 1u64 { hi = MB_TLB[src] }
                    if (hi >> (64u64 - bs)) != 0u64 { MB_TLOVF = 1u64 }
                }
            }
        }
        if w == 0u64 { MB_TLA[k] = v }
        if w == 1u64 { MB_TLB[k] = v }
    }
    return 0i32
}

fn mb_tl_cmp() -> i64 {
    let mut k : u64 = 24u64
    while k != 0u64 {
        k = k - 1u64
        if MB_TLA[k] > MB_TLB[k] { return 1i64 }
        if MB_TLA[k] < MB_TLB[k] { return 0i64 - 1i64 }
    }
    return 0i64
}

/* delta of head values (arr 0 = N1, 1 = N2): sign/mant8/exp of value(i)-value(j) */
var MB_TDS : i64 = 0i64
var MB_TDE : i64 = 0i64
fn mb_tel_sub(arr: u64, i: u64, j: u64, into_b: u64) -> u64 {
    let mut si : i64 = 0i64
    let mut sj : i64 = 0i64
    let mut ei : i64 = 0i64
    let mut ej : i64 = 0i64
    if arr == 0u64 { si = MB_N1S[i]   sj = MB_N1S[j]   ei = MB_N1E[i]   ej = MB_N1E[j] }
    if arr == 1u64 { si = MB_N2S[i]   sj = MB_N2S[j]   ei = MB_N2E[i]   ej = MB_N2E[j] }
    /* aligned 8-limb magnitudes */
    let mut base : i64 = ei
    if ej < base { base = ej }
    let shi : u64 = (ei - base) as u64
    let shj : u64 = (ej - base) as u64
    if shi > 120u64 { return 1u64 }
    if shj > 120u64 { return 1u64 }
    let mut k : u64 = 0u64
    while k < 8u64 {
        MB_S8A[k] = 0u64
        MB_S8B[k] = 0u64
        k = k + 1u64
    }
    k = 0u64
    while k < 6u64 {
        if arr == 0u64 {
            MB_S8A[k] = MB_N1L[i * 6u64 + k]
            MB_S8B[k] = MB_N1L[j * 6u64 + k]
        }
        if arr == 1u64 {
            MB_S8A[k] = MB_N2L[i * 6u64 + k]
            MB_S8B[k] = MB_N2L[j * 6u64 + k]
        }
        k = k + 1u64
    }
    /* shift each in place (<= 120 bits within 8 limbs) */
    let mut t : u64 = 0u64
    while t < 2u64 {
        let mut sh : u64 = shi
        if t == 1u64 { sh = shj }
        if sh != 0u64 {
            let ls : u64 = sh / 64u64
            let bs : u64 = sh % 64u64
            let mut k2 : u64 = 8u64
            while k2 != 0u64 {
                k2 = k2 - 1u64
                let mut v : u64 = 0u64
                if k2 >= ls {
                    let src : u64 = k2 - ls
                    let mut lo : u64 = 0u64
                    if t == 0u64 { lo = MB_S8A[src] }
                    if t == 1u64 { lo = MB_S8B[src] }
                    v = lo << bs
                    if bs != 0u64 {
                        if src != 0u64 {
                            let mut lo2 : u64 = 0u64
                            if t == 0u64 { lo2 = MB_S8A[src - 1u64] }
                            if t == 1u64 { lo2 = MB_S8B[src - 1u64] }
                            v = v | (lo2 >> (64u64 - bs))
                        }
                    }
                }
                if t == 0u64 { MB_S8A[k2] = v }
                if t == 1u64 { MB_S8B[k2] = v }
            }
        }
        t = t + 1u64
    }
    /* signed combine: si*A - sj*B */
    let mut cmp : i64 = 0i64
    k = 8u64
    while k != 0u64 {
        k = k - 1u64
        if cmp == 0i64 {
            if MB_S8A[k] > MB_S8B[k] { cmp = 1i64 }
            if MB_S8A[k] < MB_S8B[k] { cmp = 0i64 - 1i64 }
        }
    }
    let mut rs : i64 = 0i64
    if si == sj {
        if si == 0i64 {
            MB_TDS = 0i64
            MB_TDE = base
            return 0u64
        }
        /* |A - B| with sign si*cmp */
        if cmp == 0i64 {
            MB_TDS = 0i64
            MB_TDE = base
            return 0u64
        }
        let mut borrow : u64 = 0u64
        k = 0u64
        while k < 8u64 {
            let mut x : u64 = MB_S8A[k]
            let mut y : u64 = MB_S8B[k]
            if cmp < 0i64 {
                x = MB_S8B[k]
                y = MB_S8A[k]
            }
            let d : u64 = x - y
            let mut b2 : u64 = 0u64
            if x < y { b2 = 1u64 }
            let e2 : u64 = d - borrow
            if d < borrow { b2 = b2 + 1u64 }
            MB_S8A[k] = e2
            borrow = b2
            k = k + 1u64
        }
        rs = si * cmp
    }
    if si != sj {
        if si == 0i64 {
            /* value = -sj*B */
            k = 0u64
            while k < 8u64 {
                MB_S8A[k] = MB_S8B[k]
                k = k + 1u64
            }
            rs = 0i64 - sj
        }
        if sj == 0i64 { rs = si }
        if si != 0i64 {
            if sj != 0i64 {
                /* opposite: |A| + |B|, sign si */
                let mut carry : u64 = 0u64
                k = 0u64
                while k < 8u64 {
                    let s2 : u64 = MB_S8A[k] + MB_S8B[k]
                    let mut c2 : u64 = 0u64
                    if s2 < MB_S8B[k] { c2 = 1u64 }
                    let s3 : u64 = s2 + carry
                    if s3 < carry { c2 = c2 + 1u64 }
                    MB_S8A[k] = s3
                    carry = c2
                    k = k + 1u64
                }
                if carry != 0u64 { return 1u64 }
                rs = si
            }
        }
    }
    if into_b == 1u64 {
        k = 0u64
        while k < 8u64 {
            MB_S8B[k] = MB_S8A[k]
            k = k + 1u64
        }
    }
    MB_TDS = rs
    MB_TDE = base
    return 0u64
}

fn mb_arm376() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_GAZE_OK == 0u64 {
        mb_rs("the telos: fasting (no gaze standing)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    if MB_EPSF == 0u8 {
        mb_rs("the telos: epsilon absent from the KV forest (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    /* R = (RN/7)*2^ra from the standing x-norm and the artifact's epsilon */
    let me : i64 = mb_f32m(MB_EPSB)
    if me == 4611686018427387904i64 { return 376u64 }
    if me <= 0i64 { return 376u64 }
    let ee : i64 = MB_F32E
    let mut k : u64 = 0u64
    while k < 4u64 {
        MB_RNL[k] = 0u64
        k = k + 1u64
    }
    let d : i64 = ee + 58i64
    MB_RA = 0i64 - 58i64
    if d >= 0i64 {
        if d > 100i64 { return 376u64 }
        /* RN = SV + 7*me << d */
        MB_RNL[0] = MB_SYN_V0
        MB_RNL[1] = MB_SYN_V1
        MB_RNL[2] = MB_SYN_V2
        let sev : u64 = (7i64 * me) as u64
        let ls : u64 = (d as u64) / 64u64
        let bs : u64 = (d as u64) % 64u64
        let lo : u64 = sev << bs
        let mut hi : u64 = 0u64
        if bs != 0u64 { hi = sev >> (64u64 - bs) }
        let s0 : u64 = MB_RNL[ls] + lo
        let mut c0 : u64 = 0u64
        if s0 < lo { c0 = 1u64 }
        MB_RNL[ls] = s0
        MB_RNL[ls + 1u64] = MB_RNL[ls + 1u64] + hi + c0
    }
    if d < 0i64 {
        let nd : u64 = (0i64 - d) as u64
        if nd > 100u64 { return 376u64 }
        /* RN = (SV << nd) + 7*me ; ra = -58 - nd */
        MB_RNL[0] = MB_SYN_V0
        MB_RNL[1] = MB_SYN_V1
        MB_RNL[2] = MB_SYN_V2
        let ls2 : u64 = nd / 64u64
        let bs2 : u64 = nd % 64u64
        let mut k3 : u64 = 4u64
        while k3 != 0u64 {
            k3 = k3 - 1u64
            let mut v : u64 = 0u64
            if k3 >= ls2 {
                let src : u64 = k3 - ls2
                v = MB_RNL[src] << bs2
                if bs2 != 0u64 {
                    if src != 0u64 { v = v | (MB_RNL[src - 1u64] >> (64u64 - bs2)) }
                }
            }
            MB_RNL[k3] = v
        }
        let sev2 : u64 = (7i64 * me) as u64
        let s4 : u64 = MB_RNL[0] + sev2
        let mut c4 : u64 = 0u64
        if s4 < sev2 { c4 = 1u64 }
        MB_RNL[0] = s4
        MB_RNL[1] = MB_RNL[1] + c4
        MB_RA = 0i64 - 58i64 - (nd as i64)
    }
    /* SD2 = sum of D[0..512)^2, aligned to twice the minimal exponent */
    let mut e2min : i64 = 100000i64
    let mut c : u64 = 0u64
    while c < 512u64 {
        if MB_DVS[c] != 0i64 {
            let te : i64 = 2i64 * MB_DVE[c]
            if te < e2min { e2min = te }
        }
        c = c + 1u64
    }
    if e2min == 100000i64 { return 376u64 }
    mb_tl_clear(0u64)
    MB_TLOVF = 0u64
    c = 0u64
    while c < 512u64 {
        if MB_DVS[c] != 0i64 {
            mb_mul192(MB_DV0[c], MB_DV1[c], MB_DV2[c], MB_DV0[c], MB_DV1[c], MB_DV2[c])
            let sh : i64 = 2i64 * MB_DVE[c] - e2min
            if sh > 120i64 { return 376u64 }
            /* add R6 << sh into TLA */
            let ls3 : u64 = (sh as u64) / 64u64
            let bs3 : u64 = (sh as u64) % 64u64
            let mut q : u64 = 0u64
            let mut prev : u64 = 0u64
            while q < 6u64 {
                let cur : u64 = MB_R6[q]
                let mut v2 : u64 = cur << bs3
                if bs3 != 0u64 { v2 = v2 | (prev >> (64u64 - bs3)) }
                mb_tl_addat(0u64, ls3 + q, v2)
                prev = cur
                q = q + 1u64
            }
            if bs3 != 0u64 { mb_tl_addat(0u64, ls3 + 6u64, prev >> (64u64 - bs3)) }
        }
        c = c + 1u64
    }
    if MB_TLOVF != 0u64 { return 376u64 }
    k = 0u64
    while k < 12u64 {
        MB_SD2[k] = MB_TLA[k]
        k = k + 1u64
    }
    k = 12u64
    let mut over : u64 = 0u64
    while k < 24u64 {
        over = over | MB_TLA[k]
        k = k + 1u64
    }
    if over != 0u64 { return 376u64 }
    /* KS = (KSn/7)*2^kc with KSn = 7*SD2<<(se'-kc) + me*RN<<(ee+ra-kc) */
    let sep : i64 = e2min - 9i64
    let er : i64 = ee + MB_RA
    MB_KC = sep
    if er < MB_KC { MB_KC = er }
    let sh_a : i64 = sep - MB_KC
    let sh_b : i64 = er - MB_KC
    if sh_a > 160i64 { return 376u64 }
    if sh_b > 160i64 { return 376u64 }
    mb_tl_clear(0u64)
    /* 7*SD2 << sh_a */
    c = 0u64
    while c < 12u64 {
        if MB_SD2[c] != 0u64 {
            mb_mul64(MB_SD2[c], 7u64)
            let base2 : u64 = (sh_a as u64) / 64u64
            let bb2 : u64 = (sh_a as u64) % 64u64
            let mut lo3 : u64 = MB_MLO << bb2
            let mut mid3 : u64 = (MB_MHI << bb2)
            if bb2 != 0u64 { mid3 = mid3 | (MB_MLO >> (64u64 - bb2)) }
            let mut hi3 : u64 = 0u64
            if bb2 != 0u64 { hi3 = MB_MHI >> (64u64 - bb2) }
            mb_tl_addat(0u64, c + base2, lo3)
            mb_tl_addat(0u64, c + base2 + 1u64, mid3)
            mb_tl_addat(0u64, c + base2 + 2u64, hi3)
        }
        c = c + 1u64
    }
    /* + me*RN << sh_b */
    c = 0u64
    while c < 4u64 {
        if MB_RNL[c] != 0u64 {
            mb_mul64(MB_RNL[c], me as u64)
            let base3 : u64 = (sh_b as u64) / 64u64
            let bb3 : u64 = (sh_b as u64) % 64u64
            let mut lo4 : u64 = MB_MLO << bb3
            let mut mid4 : u64 = (MB_MHI << bb3)
            if bb3 != 0u64 { mid4 = mid4 | (MB_MLO >> (64u64 - bb3)) }
            let mut hi4 : u64 = 0u64
            if bb3 != 0u64 { hi4 = MB_MHI >> (64u64 - bb3) }
            mb_tl_addat(0u64, c + base3, lo4)
            mb_tl_addat(0u64, c + base3 + 1u64, mid4)
            mb_tl_addat(0u64, c + base3 + 2u64, hi4)
        }
        c = c + 1u64
    }
    if MB_TLOVF != 0u64 { return 376u64 }
    k = 0u64
    while k < 12u64 {
        MB_KSN[k] = MB_TLA[k]
        k = k + 1u64
    }
    k = 12u64
    over = 0u64
    while k < 24u64 {
        over = over | MB_TLA[k]
        k = k + 1u64
    }
    if over != 0u64 { return 376u64 }
    /* the complete pairwise verdict */
    let mut i : u64 = 0u64
    while i < MB_NHEAD {
        MB_WINS[i] = 0u64
        MB_WSEEN[i] = 0u8
        i = i + 1u64
    }
    let mut ties : u64 = 0u64
    let mut dom : u64 = 0u64
    let mut surd : u64 = 0u64
    i = 0u64
    while i < MB_NHEAD {
        let mut j : u64 = i + 1u64
        while j < MB_NHEAD {
            let c1 : i64 = mb_gz_hcmp(0u64, i, j)
            let c2 : i64 = mb_gz_hcmp(1u64, i, j)
            let mut v : i64 = 0i64
            let mut decided : u64 = 0u64
            if c1 >= 0i64 {
                if c2 >= 0i64 {
                    if c1 + c2 > 0i64 { v = 1i64 }
                    decided = 1u64
                    dom = dom + 1u64
                }
            }
            if decided == 0u64 {
                if c1 <= 0i64 {
                    if c2 <= 0i64 {
                        v = 0i64 - 1i64
                        decided = 1u64
                        dom = dom + 1u64
                    }
                }
            }
            if decided == 0u64 {
                /* the surd: sign(dN1*sqrtR + dN2*sqrtKS) with opposite parts */
                surd = surd + 1u64
                if mb_tel_sub(0u64, i, j, 0u64) != 0u64 { return 376u64 }
                let s1 : i64 = MB_TDS
                let e1 : i64 = MB_TDE
                /* keep dN1 in S8A; compute dN2 into S8B */
                let mut q2 : u64 = 0u64
                while q2 < 8u64 {
                    MB_TLT[q2] = MB_S8A[q2]
                    q2 = q2 + 1u64
                }
                if mb_tel_sub(1u64, i, j, 1u64) != 0u64 { return 376u64 }
                let s2 : i64 = MB_TDS
                let e2 : i64 = MB_TDE
                q2 = 0u64
                while q2 < 8u64 {
                    MB_S8A[q2] = MB_TLT[q2]
                    q2 = q2 + 1u64
                }
                if s1 == 0i64 { v = s2 }
                if s2 == 0i64 { v = s1 }
                if s1 != 0i64 {
                    if s2 != 0i64 {
                        if s1 == s2 { v = s1 }
                        if s1 != s2 {
                            MB_TLOVF = 0u64
                            mb_tl_sq8(0u64)
                            mb_tl_mulsrc(0u64, 0u64)
                            mb_tl_sq8(1u64)
                            mb_tl_mulsrc(1u64, 1u64)
                            let ea : i64 = 2i64 * e1 + MB_RA
                            let eb : i64 = 2i64 * e2 + MB_KC
                            let mut baseE : i64 = ea
                            if eb < baseE { baseE = eb }
                            if ea - baseE > 256i64 { return 376u64 }
                            if eb - baseE > 256i64 { return 376u64 }
                            if ea > baseE { mb_tl_shl(0u64, (ea - baseE) as u64) }
                            if eb > baseE { mb_tl_shl(1u64, (eb - baseE) as u64) }
                            if MB_TLOVF != 0u64 { return 376u64 }
                            let cq : i64 = mb_tl_cmp()
                            if cq > 0i64 { v = s1 }
                            if cq < 0i64 { v = s2 }
                            if cq == 0i64 { v = 0i64 }
                        }
                    }
                }
            }
            if v > 0i64 { MB_WINS[i] = MB_WINS[i] + 1u64 }
            if v < 0i64 { MB_WINS[j] = MB_WINS[j] + 1u64 }
            if v == 0i64 { ties = ties + 1u64 }
            j = j + 1u64
        }
        i = i + 1u64
    }
    /* THE WIN-PERMUTATION THEOREM: with zero ties, the win counts must be
     * exactly the permutation 0..H-1 -- any comparator cycle breaks it */
    let mut perm_ok : u64 = 1u64
    if ties == 0u64 {
        i = 0u64
        while i < MB_NHEAD {
            let wv : u64 = MB_WINS[i]
            if wv >= MB_NHEAD { perm_ok = 0u64 }
            if wv < MB_NHEAD {
                if MB_WSEEN[wv] == 1u8 { perm_ok = 0u64 }
                MB_WSEEN[wv] = 1u8
            }
            i = i + 1u64
        }
    }
    if perm_ok == 0u64 { return 376u64 }
    /* the crown and the court */
    let mut top1 : u64 = 0u64
    let mut top2 : u64 = 0u64
    let mut top3 : u64 = 0u64
    i = 0u64
    while i < MB_NHEAD {
        if MB_WINS[i] == MB_NHEAD - 1u64 { top1 = i }
        if MB_WINS[i] == MB_NHEAD - 2u64 { top2 = i }
        if MB_WINS[i] == MB_NHEAD - 3u64 { top3 = i }
        i = i + 1u64
    }
    mb_rs("the telos: pairs=" as u64)
    mb_ru((MB_NHEAD * (MB_NHEAD - 1u64)) / 2u64)
    mb_rs(" dominance=" as u64)
    mb_ru(dom)
    mb_rs(" surd-decided=" as u64)
    mb_ru(surd)
    mb_rs(" ties=" as u64)
    mb_ru(ties)
    mb_rs(" win-permutation=ok total-order=[" as u64)
    mb_ru(top1)
    mb_rs("," as u64)
    mb_ru(top2)
    mb_rs("," as u64)
    mb_ru(top3)
    mb_rs(",...] -- the frontier CLOSED, no root taken" as u64)
    mb_rb(10u8)
    return 0u64
}

fn mb_arm371() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    /* the resident stomach: the sum of every buffer this organ owns.
     * window 65536 + spans 2x4096 + key 256 + hist 512 + blk 256
     * + values 2x2048 + report 4096 + partials 512 + 3x512 + names 2x64+48
     * + paths 2x64 + arch 32 + digits 64 + splits 128+16
     * + loom slices (blk 1024 + values 2x8192 + ledgers ~576)
     * + the fleet (x 57344 + xbmax 256 + ledgers/samples ~1000)
     * + the walk (logits 256x40 + chunks 112x32 + top 64) */
    let resident : u64 = 65536u64 + 4096u64 + 4096u64 + 256u64 + 512u64 + 256u64 + 2048u64 + 2048u64 + 4096u64 + 512u64 + 1536u64 + 176u64 + 128u64 + 32u64 + 64u64 + 144u64 + 1024u64 + 16384u64 + 576u64 + 57344u64 + 256u64 + 1000u64 + 10240u64 + 3584u64 + 64u64 + 324936u64
    if MB_STREAMED == 0u64 { return 371u64 }
    if MB_STREAMED <= resident { return 371u64 }
    mb_rs("the stomach: streamed=" as u64)
    mb_ru(MB_STREAMED)
    mb_rs(" resident=" as u64)
    mb_ru(resident)
    mb_rs(" -- the feast passes through a fixed stomach: blocks in, proofs out" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ==================== arm 366: THE SCROLL ==================== */

fn mb_arm366() -> u64 {
    eol_reset()
    let doc : u64 = "[weight = dyadic rational] [fp16 value = dyadic rational] [dyadic rational < exact number] [block sum = dyadic rational] [conservation = byte tiling] [argmax = order fact] [order fact < exact decision]" as u64
    let dl : u64 = mb_slen(doc)
    if eol_read(doc, dl) < 0i64 { return 366u64 }
    if eol_lawcheck() != 0u64 { return 366u64 }
    let a1 : u64 = eol_addr()
    if a1 == 0u64 { return 366u64 }
    /* DERIVED (absent from the text): the weight sits under exact number */
    let wa : u64 = "weight" as u64
    let xb : u64 = "exact number" as u64
    if eol_entails(wa, mb_slen(wa), 0u64, xb, mb_slen(xb)) != 1u64 { return 366u64 }
    /* the reversal REFUSES: exact number does not sit under the weight */
    if eol_entails(xb, mb_slen(xb), 0u64, wa, mb_slen(wa)) != 0u64 { return 366u64 }
    /* cross-class refusal: conservation is not the weight */
    let ca : u64 = "conservation" as u64
    if eol_entails(ca, mb_slen(ca), 2u64, wa, mb_slen(wa)) != 0u64 { return 366u64 }
    /* determinism: re-reading the law lands on the same address */
    eol_reset()
    if eol_read(doc, dl) < 0i64 { return 366u64 }
    if eol_addr() != a1 { return 366u64 }
    MB_SCROLL = a1
    return 0u64
}

/* ==================== the organ's spine ==================== */

fn mb_selfprove() -> u64 @export {
    MB_REPN = 0u64
    MB_SCROLL = 0u64
    MB_STREAMED = 0u64
    MB_C1_F = 0u8
    MB_C2_F = 0u8
    MB_C3_F = 0u8
    MB_C3_HERE = 0u8
    let mut gz0 : u64 = 0u64
    while gz0 < 8u64 {
        MB_G_F[gz0] = 0u8
        MB_G_HERE[gz0] = 0u8
        gz0 = gz0 + 1u64
    }
    MB_NHEAD = 0u64
    MB_NROPE = 0u64
    MB_ARCHN = 0u64
    MB_EMBED = 0u64
    MB_LAYERS = 0u64
    MB_SPLITCT_F = 0u8
    MB_SPLITTN_F = 0u8
    let mut h : u64 = 0u64
    while h < 64u64 {
        MB_HIST[h] = 0u64
        h = h + 1u64
    }
    let r0 : u64 = mb_arm360()
    if r0 != 0u64 { return r0 }
    let r1 : u64 = mb_arm361()
    if r1 != 0u64 { return r1 }
    let r2 : u64 = mb_arm362()
    if r2 != 0u64 { return r2 }
    let r3 : u64 = mb_arm363()
    if r3 != 0u64 { return r3 }
    let r4 : u64 = mb_arm364()
    if r4 != 0u64 { return r4 }
    let r5 : u64 = mb_arm365()
    if r5 != 0u64 { return r5 }
    let r5b : u64 = mb_arm370()
    if r5b != 0u64 { return r5b }
    let r5d : u64 = mb_arm372()
    if r5d != 0u64 { return r5d }
    let r5e : u64 = mb_arm373()
    if r5e != 0u64 { return r5e }
    let r5f : u64 = mb_arm374()
    if r5f != 0u64 { return r5f }
    let r5g : u64 = mb_arm375()
    if r5g != 0u64 { return r5g }
    let r5h : u64 = mb_arm376()
    if r5h != 0u64 { return r5h }
    let r5c : u64 = mb_arm371()
    if r5c != 0u64 { return r5c }
    let r6 : u64 = mb_arm366()
    if r6 != 0u64 { return r6 }
    mb_rs("the boundary: softmax mixing is transcendental -- beyond metabole's arms, referred to the interval organ" as u64)
    mb_rb(10u8)
    return 0u64
}

fn mb_addr() -> u64 @export { return MB_SCROLL }
fn mb_report_len() -> u64 @export { return MB_REPN }
fn mb_report_byte(i: u64) -> u8 @export {
    if i >= MB_REPN { return 0u8 }
    return MB_REP[i]
}

/* the digested flesh, served onward (PERAS eats from this table) */
fn mb_nva() -> u64 @export { return MB_NVA }
fn mb_nvb() -> u64 @export { return MB_NVB }
fn mb_val_a(i: u64) -> i64 @export {
    if i >= MB_NVA { return 0i64 }
    return MB_VA[i]
}
fn mb_val_b(i: u64) -> i64 @export {
    if i >= MB_NVB { return 0i64 }
    return MB_VB[i]
}
fn mb_feast() -> u64 @export { return MB_FEAST as u64 }

/* METABOLE: the organism now has a mouth.  What it eats, it proves. */
