var MB_EB_OFF  : [u64; 61]
var MB_EB_NE   : [u64; 61]
var MB_EB_NE0  : [u64; 61]
var MB_EB_DB   : [u64; 61]
var MB_EB_SH   : [u64; 61]
var MB_EB_F    : [u8; 61]
var MB_EB_HERE : [u8; 61]
/* the specials: 0 token_embd.weight, 1 output_norm.weight,
 * 2 output.weight (the voice's head), 3 rope_freqs.weight (optional) */
var MB_SP_TYPE : [u64; 4]
var MB_SP_OFF  : [u64; 4]
var MB_SP_NE   : [u64; 4]
var MB_SP_NE0  : [u64; 4]
var MB_SP_DB   : [u64; 4]
var MB_SP_SH   : [u64; 4]
var MB_SP_F    : [u8; 4]
var MB_SP_HERE : [u8; 4]
var MB_NHEAD  : u64 = 0u64
var MB_NROPE  : u64 = 0u64
var MB_EPSB   : u64 = 0u64            /* rms epsilon, raw f32 bits */
var MB_EPSF   : u8 = 0u8
var MB_GAZE_OK : u64 = 0u64
var MB_GZ_A1 : u64 = 0u64             /* the crowned head (nope argmax) */
var MB_C2_NAME : [u8; 64]
var MB_C2_NN   : u64 = 0u64
var MB_C2_F    : u8 = 0u8
var MB_DBASE1  : u64 = 0u64           /* shard 1 data_base (absolute) */
var MB_PATH1   : [u8; 64]             /* shard 1 path (kept for reopen) */

/* decoded blocks: exact mantissas, value = mant * 2^-24 */
var MB_BLK  : [u8; 256]               /* raw block bytes */
var MB_VA   : [i64; 256]              /* candidate 1 block values */
var MB_VB   : [i64; 256]              /* candidate 2 block values */
var MB_NVA  : u64 = 0u64
var MB_NVB  : u64 = 0u64
var MB_SUMA : i64 = 0i64              /* exact sums (mant * 2^-24) */
var MB_SUMB : i64 = 0i64
/* exact sums of squares (mant * 2^-48), 2-limb little-endian */
var MB_SSA0 : u64 = 0u64
var MB_SSA1 : u64 = 0u64
var MB_SSB0 : u64 = 0u64
var MB_SSB1 : u64 = 0u64

/* 128-bit multiply result */
var MB_MHI : u64 = 0u64
var MB_MLO : u64 = 0u64

/* 3-limb accumulators (little-endian limbs) */
var MB_X : [u64; 3]
var MB_Y : [u64; 3]
var MB_Z : [u64; 3]

/* the report the driver prints, and the sealed scroll */
var MB_REP  : [u8; 8192]
var MB_REPN : u64 = 0u64
var MB_SCROLL : u64 = 0u64

/* the stomach meter: actual bytes pulled through the window this census */
var MB_STREAMED : u64 = 0u64

/* the voice's first breath: the BOS token id from the tokenizer ledger */
var MB_BOS : u64 = 0u64
var MB_BOSF : u8 = 0u8

/* THE LEXIS: the tokenizer's own words, captured whole from the ledger
 * so the krisis speaks TEXT, not bare ids.  129280 tokens, raw bytes as
 * the artifact carries them (byte-level BPE surface forms). */
var MB_TKT : [u8; 4194304]
var MB_TKOFF : [u64; 129280]
var MB_TKLEN : [u64; 129280]
var MB_TKN : u64 = 0u64
var MB_TKUSED : u64 = 0u64
var MB_TKF : u8 = 0u8

/* ==================== tiny utils ==================== */

fn mb_slen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { i = i + 1u64 }
    return i
}

fn mb_rb(b: u8) -> i32 {
    if MB_REPN >= 8191u64 { return 0i32 }
    MB_REP[MB_REPN] = b
    MB_REPN = MB_REPN + 1u64
    return 0i32
}

fn mb_rs(s: u64) -> i32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 {
        mb_rb(p[i])
        i = i + 1u64
    }
    return 0i32
}

fn mb_ru(v: u64) -> i32 {
    if v >= 10u64 { mb_ru(v / 10u64) }
    mb_rb((48u64 + (v % 10u64)) as u8)
    return 0i32
}

fn mb_ri(v: i64) -> i32 {
    if v < 0i64 {
        mb_rb(45u8)
        let m : u64 = (0i64 - v) as u64
        mb_ru(m)
        return 0i32
    }
    mb_ru(v as u64)
    return 0i32
}

fn mb_bitlen(v: u64) -> u64 {
    let mut n : u64 = 0u64
    let mut x : u64 = v
    while x != 0u64 {
        x = x >> 1u64
        n = n + 1u64
    }
    return n
}

/* 64x64 -> 128 (classic 32-bit split; no intermediate overflow) */
fn mb_mul64(a: u64, b: u64) -> i32 {
    let a0 : u64 = a & 0xFFFFFFFFu64
    let a1 : u64 = a >> 32u64
    let b0 : u64 = b & 0xFFFFFFFFu64
    let b1 : u64 = b >> 32u64
    let p00 : u64 = a0 * b0
    let p01 : u64 = a0 * b1
    let p10 : u64 = a1 * b0
    let p11 : u64 = a1 * b1
    let mid1 : u64 = p01 + (p00 >> 32u64)
    let mid2 : u64 = p10 + (mid1 & 0xFFFFFFFFu64)
    MB_MHI = p11 + (mid1 >> 32u64) + (mid2 >> 32u64)
    MB_MLO = (mid2 << 32u64) | (p00 & 0xFFFFFFFFu64)
    return 0i32
}

/* MB_Z = |a| * b as 3 limbs, where (ahi,alo) is a 128-bit value, b 64-bit */
fn mb_mul128by64(ahi: u64, alo: u64, b: u64) -> i32 {
    mb_mul64(alo, b)
    let l0 : u64 = MB_MLO
    let l1a : u64 = MB_MHI
    mb_mul64(ahi, b)
    let l1b : u64 = MB_MLO
    let l2a : u64 = MB_MHI
    let s : u64 = l1a + l1b
    let mut c : u64 = 0u64
    if s < l1a { c = 1u64 }
    MB_Z[0] = l0
    MB_Z[1] = s
    MB_Z[2] = l2a + c
    return 0i32
}

/* MB_X += MB_Z (3-limb, carries) */
fn mb_x_add_z() -> i32 {
    let s0 : u64 = MB_X[0] + MB_Z[0]
    let mut c0 : u64 = 0u64
    if s0 < MB_Z[0] { c0 = 1u64 }
    let s1a : u64 = MB_X[1] + MB_Z[1]
    let mut c1 : u64 = 0u64
    if s1a < MB_Z[1] { c1 = 1u64 }
    let s1 : u64 = s1a + c0
    if s1 < c0 { c1 = c1 + 1u64 }
    MB_X[0] = s0
    MB_X[1] = s1
    MB_X[2] = MB_X[2] + MB_Z[2] + c1
    return 0i32
}

/* MB_X -= MB_Z (3-limb, borrows); caller guarantees X >= Z */
fn mb_x_sub_z() -> i32 {
    let mut b : u64 = 0u64
    let d0 : u64 = MB_X[0] - MB_Z[0]
    if MB_X[0] < MB_Z[0] { b = 1u64 }
    let mut b1 : u64 = 0u64
    let d1a : u64 = MB_X[1] - MB_Z[1]
    if MB_X[1] < MB_Z[1] { b1 = 1u64 }
    let d1 : u64 = d1a - b
    if d1a < b { b1 = b1 + 1u64 }
    MB_X[0] = d0
    MB_X[1] = d1
    MB_X[2] = MB_X[2] - MB_Z[2] - b1
    return 0i32
}

/* compare MB_X vs MB_Y: -1 / 0 / +1 */
fn mb_x_cmp_y() -> i64 {
    if MB_X[2] > MB_Y[2] { return 1i64 }
    if MB_X[2] < MB_Y[2] { return 0i64 - 1i64 }
    if MB_X[1] > MB_Y[1] { return 1i64 }
    if MB_X[1] < MB_Y[1] { return 0i64 - 1i64 }
    if MB_X[0] > MB_Y[0] { return 1i64 }
    if MB_X[0] < MB_Y[0] { return 0i64 - 1i64 }
    return 0i64
}

/* append 3-limb MB_X as decimal to the report (binary long division by 10) */
var MB_DDIG : [u8; 64]
fn mb_rx3() -> i32 {
    let mut h : u64 = MB_X[2]
    let mut m : u64 = MB_X[1]
    let mut l : u64 = MB_X[0]
    let mut nd : u64 = 0u64
    if h == 0u64 {
        if m == 0u64 {
            if l == 0u64 {
                mb_rb(48u8)
                return 0i32
            }
        }
    }
    while (h | m | l) != 0u64 {
        /* divide (h,m,l) by 10 via binary long division over 192 bits */
        let mut rem : u64 = 0u64
        let mut qh : u64 = 0u64
        let mut qm : u64 = 0u64
        let mut ql : u64 = 0u64
        let mut bit : u64 = 192u64
        while bit != 0u64 {
            bit = bit - 1u64
            let mut src : u64 = 0u64
            if bit >= 128u64 { src = (h >> (bit - 128u64)) & 1u64 }
            if bit < 128u64 {
                if bit >= 64u64 { src = (m >> (bit - 64u64)) & 1u64 }
            }
            if bit < 64u64 { src = (l >> bit) & 1u64 }
            rem = (rem << 1u64) | src
            if rem >= 10u64 {
                rem = rem - 10u64
                if bit >= 128u64 { qh = qh | (1u64 << (bit - 128u64)) }
                if bit < 128u64 {
                    if bit >= 64u64 { qm = qm | (1u64 << (bit - 64u64)) }
                }
                if bit < 64u64 { ql = ql | (1u64 << bit) }
            }
        }
        MB_DDIG[nd] = (48u64 + rem) as u8
        nd = nd + 1u64
        h = qh
        m = qm
        l = ql
    }
    while nd != 0u64 {
        nd = nd - 1u64
        mb_rb(MB_DDIG[nd])
    }
    return 0i32
}

/* ==================== arm 360: THE FLESH (fp16 complete) ==================== */

var MB_F16S : u64 = 0u64              /* sign of last decode */
var MB_F16A : u64 = 0u64              /* magnitude mantissa (value = A * 2^-24) */

/* classify pattern: 0 finite (sets MB_F16S / MB_F16A), 1 inf, 2 nan */
fn mb_f16_dec(p: u64) -> u64 {
    let s : u64 = (p >> 15u64) & 1u64
    let e : u64 = (p >> 10u64) & 31u64
    let m : u64 = p & 1023u64
    if e == 31u64 {
        if m == 0u64 { return 1u64 }
        return 2u64
    }
    MB_F16S = s
    if e == 0u64 {
        MB_F16A = m
        return 0u64
    }
    MB_F16A = (1024u64 + m) << (e - 1u64)
    return 0u64
}

/* signed mantissa of a finite fp16 (value = result * 2^-24); nonfinite -> sets MB_IOERR */
fn mb_f16_mant(p: u64) -> i64 {
    let c : u64 = mb_f16_dec(p)
    if c != 0u64 {
        MB_IOERR = 1u8
        return 0i64
    }
    let a : i64 = MB_F16A as i64
    if MB_F16S == 1u64 { return 0i64 - a }
    return a
}

/* re-encode (s, A) -> pattern; 0xFFFFFFFFFFFFFFFF = not a valid fp16 mantissa */
fn mb_f16_enc(s: u64, a: u64) -> u64 {
    if a == 0u64 { return s << 15u64 }
    let bl : u64 = mb_bitlen(a)
    if bl <= 10u64 { return (s << 15u64) | a }
    let e : u64 = bl - 10u64
    if e > 30u64 { return 0xFFFFFFFFFFFFFFFFu64 }
    let low : u64 = e - 1u64
    if ((a >> low) << low) != a { return 0xFFFFFFFFFFFFFFFFu64 }
    let mm : u64 = (a >> low) - 1024u64
    if mm > 1023u64 { return 0xFFFFFFFFFFFFFFFFu64 }
    return (s << 15u64) | (e << 10u64) | mm
}

fn mb_arm360() -> u64 {
    let mut fin : u64 = 0u64
    let mut nonfin : u64 = 0u64
    let mut p : u64 = 0u64
    while p < 65536u64 {
        let c : u64 = mb_f16_dec(p)
        if c == 0u64 {
            fin = fin + 1u64
            /* bijection: re-encode must reproduce the exact bits */
            if mb_f16_enc(MB_F16S, MB_F16A) != p { return 360u64 }
        }
        if c != 0u64 { nonfin = nonfin + 1u64 }
        p = p + 1u64
    }
    /* the closed forms the walk must re-derive: 2*31*1024 finite, 2*1024 not */
    if fin != 63488u64 { return 360u64 }
    if nonfin != 2048u64 { return 360u64 }
    /* the independent order engine: positive finite magnitudes strictly rise */
    let mut prev : u64 = 0u64
    p = 1u64
    while p < 31744u64 {
        if mb_f16_dec(p) != 0u64 { return 360u64 }
        if MB_F16A <= prev { return 360u64 }
        prev = MB_F16A
        p = p + 1u64
    }
    mb_rs("the flesh: fp16 finite=" as u64)
    mb_ru(fin)
    mb_rs(" nonfinite=" as u64)
    mb_ru(nonfin)
    mb_rs(" bijection=ok monotone=ok lattice=2^-24" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ==================== arm 361: THE TYPES ==================== */

/* values per block; 0 = outside this organ's certified table */
fn mb_tbv(t: u64) -> u64 {
    if t == 0u64 { return 1u64 }      /* F32 */
    if t == 1u64 { return 1u64 }      /* F16 */
    if t == 2u64 { return 32u64 }     /* Q4_0 */
    if t == 3u64 { return 32u64 }     /* Q4_1 */
    if t == 6u64 { return 32u64 }     /* Q5_0 */
    if t == 7u64 { return 32u64 }     /* Q5_1 */
    if t == 8u64 { return 32u64 }     /* Q8_0 */
    if t == 9u64 { return 32u64 }     /* Q8_1 */
    if t == 10u64 { return 256u64 }   /* Q2_K */
    if t == 11u64 { return 256u64 }   /* Q3_K */
    if t == 12u64 { return 256u64 }   /* Q4_K */
    if t == 13u64 { return 256u64 }   /* Q5_K */
    if t == 14u64 { return 256u64 }   /* Q6_K */
    if t == 15u64 { return 256u64 }   /* Q8_K */
    if t == 24u64 { return 1u64 }     /* I8 */
    if t == 25u64 { return 1u64 }     /* I16 */
    if t == 26u64 { return 1u64 }     /* I32 */
    if t == 27u64 { return 1u64 }     /* I64 */
    if t == 28u64 { return 1u64 }     /* F64 */
    if t == 30u64 { return 1u64 }     /* BF16 */
    return 0u64
}

fn mb_tbb(t: u64) -> u64 {
    if t == 0u64 { return 4u64 }
    if t == 1u64 { return 2u64 }
    if t == 2u64 { return 18u64 }
    if t == 3u64 { return 20u64 }
    if t == 6u64 { return 22u64 }
    if t == 7u64 { return 24u64 }
    if t == 8u64 { return 34u64 }
    if t == 9u64 { return 36u64 }
    if t == 10u64 { return 84u64 }
    if t == 11u64 { return 110u64 }
    if t == 12u64 { return 144u64 }
    if t == 13u64 { return 176u64 }
    if t == 14u64 { return 210u64 }
    if t == 15u64 { return 292u64 }
    if t == 24u64 { return 1u64 }
    if t == 25u64 { return 2u64 }
    if t == 26u64 { return 4u64 }
    if t == 27u64 { return 8u64 }
    if t == 28u64 { return 8u64 }
    if t == 30u64 { return 2u64 }
    return 0u64
}

fn mb_arm361() -> u64 {
    /* internal consistency: bv and bb tables agree on membership; k-quants
     * are exactly the 256-value blocks; unit types carry unit-value sizes */
    let mut known : u64 = 0u64
    let mut kq : u64 = 0u64
    let mut t : u64 = 0u64
    while t < 64u64 {
        let bv : u64 = mb_tbv(t)
        let bb : u64 = mb_tbb(t)
        if bv == 0u64 {
            if bb != 0u64 { return 361u64 }
        }
        if bv != 0u64 {
            if bb == 0u64 { return 361u64 }
            known = known + 1u64
            if bv == 256u64 { kq = kq + 1u64 }
            /* a block never holds fewer bytes than one value of its lattice:
             * every certified type packs at most 16 values per byte-pair */
            if bb * 16u64 < bv { return 361u64 }
        }
        t = t + 1u64
    }
    if known != 20u64 { return 361u64 }
    if kq != 6u64 { return 361u64 }
    mb_rs("the types: known=" as u64)
    mb_ru(known)
    mb_rs(" kquant=" as u64)
    mb_ru(kq)
    mb_rb(10u8)
    return 0u64
}

/* ==================== the windowed 64-bit reader ==================== */

fn mb_pos() -> u64 { return MB_WBASE + MB_WPOS }

fn mb_seek_abs(off: u64) -> i32 {
    if off >= MB_WBASE {
        if off < MB_WBASE + MB_WLEN {
            MB_WPOS = off - MB_WBASE
            return 0i32
        }
    }
    let rc : i32 = _fseeki64(MB_F, off as i64, 0i32)
    if rc != 0i32 { MB_IOERR = 1u8 }
    MB_WBASE = off
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    return rc
}

fn mb_refill() -> i32 {
    if MB_WPOS < MB_WLEN { return 0i32 }
    let base : u64 = MB_WBASE + MB_WLEN
    let rc : i32 = _fseeki64(MB_F, base as i64, 0i32)
    if rc != 0i32 {
        MB_IOERR = 1u8
        return 1i32
    }
    let got : u64 = fread((&MB_WIN) as u64, 1u64, 65536u64, MB_F)
    MB_STREAMED = MB_STREAMED + got
    MB_WBASE = base
    MB_WLEN = got
    MB_WPOS = 0u64
    if got == 0u64 {
        MB_IOERR = 1u8
        return 1i32
    }
    return 0i32
}

fn mb_u8() -> u64 {
    if mb_refill() != 0i32 { return 0u64 }
    let b : u64 = MB_WIN[MB_WPOS] as u64
    MB_WPOS = MB_WPOS + 1u64
    return b
}

fn mb_u16() -> u64 {
    let b0 : u64 = mb_u8()
    let b1 : u64 = mb_u8()
    return b0 | (b1 << 8u64)
}

fn mb_u32() -> u64 {
    let b0 : u64 = mb_u16()
    let b1 : u64 = mb_u16()
    return b0 | (b1 << 16u64)
}

fn mb_u64() -> u64 {
    let b0 : u64 = mb_u32()
    let b1 : u64 = mb_u32()
    return b0 | (b1 << 32u64)
}

fn mb_skip(n: u64) -> i32 {
    let target : u64 = mb_pos() + n
    return mb_seek_abs(target)
}

/* ==================== the GGUF walk (one shard) ==================== */

var MB_PATH : [u8; 64]

fn mb_mkpath(i: u64) -> i32 {
    /* "Feast/r1_shardNN.gguf" + NUL */
    let s : u64 = "Feast/r1_shard" as u64
    let p : *u8 = s as *u8
    let mut k : u64 = 0u64
    while p[k] != 0u8 {
        MB_PATH[k] = p[k]
        k = k + 1u64
    }
    MB_PATH[k] = (48u64 + (i / 10u64)) as u8
    MB_PATH[k + 1u64] = (48u64 + (i % 10u64)) as u8
    let t : u64 = ".gguf" as u64
    let q : *u8 = t as *u8
    let mut j : u64 = 0u64
    while q[j] != 0u8 {
        MB_PATH[k + 2u64 + j] = q[j]
        j = j + 1u64
    }
    MB_PATH[k + 2u64 + j] = 0u8
    return 0i32
}

fn mb_keyis(lit: u64, klen: u64) -> u64 {
    let p : *u8 = lit as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 {
        if i >= klen { return 0u64 }
        if p[i] != MB_KEY[i] { return 0u64 }
        i = i + 1u64
    }
    if i != klen { return 0u64 }
    return 1u64
}

fn mb_scalar_size(vt: u64) -> u64 {
    if vt == 0u64 { return 1u64 }
    if vt == 1u64 { return 1u64 }
    if vt == 2u64 { return 2u64 }
    if vt == 3u64 { return 2u64 }
    if vt == 4u64 { return 4u64 }
    if vt == 5u64 { return 4u64 }
    if vt == 6u64 { return 4u64 }
    if vt == 7u64 { return 1u64 }
    if vt == 10u64 { return 8u64 }
    if vt == 11u64 { return 8u64 }
    if vt == 12u64 { return 8u64 }
    return 0u64
}

/* read a scalar KV value as u64 (unsigned reading of the stored bytes) */
fn mb_scalar_read(vt: u64) -> u64 {
    let sz : u64 = mb_scalar_size(vt)
    if sz == 1u64 { return mb_u8() }
    if sz == 2u64 { return mb_u16() }
    if sz == 4u64 { return mb_u32() }
    return mb_u64()
}

/* walk one KV entry: extract the named facts, skip everything else.
 * returns 0 ok, 1 refuse (nested array / unknown vtype) */
fn mb_kv_one(shard: u64) -> u64 {
    let klen : u64 = mb_u64()
    if klen > 255u64 { return 1u64 }
    let mut i : u64 = 0u64
    while i < klen {
        MB_KEY[i] = mb_u8() as u8
        i = i + 1u64
    }
    let vt : u64 = mb_u32()
    if MB_IOERR != 0u8 { return 1u64 }
    if vt == 8u64 {
        /* string */
        let slen : u64 = mb_u64()
        if mb_keyis("deepseek2.rope.scaling.type" as u64, klen) == 1u64 {
            let mut cap : u64 = slen
            if cap > 15u64 { cap = 15u64 }
            let mut rt : u64 = 0u64
            while rt < cap {
                MB_ROPETYP[rt] = mb_u8() as u8
                rt = rt + 1u64
            }
            MB_ROPETN = cap
            mb_skip(slen - cap)
            return 0u64
        }
        if mb_keyis("general.architecture" as u64, klen) == 1u64 {
            let mut cap : u64 = slen
            if cap > 31u64 { cap = 31u64 }
            let mut a : u64 = 0u64
            while a < cap {
                MB_ARCH[a] = mb_u8() as u8
                a = a + 1u64
            }
            MB_ARCHN = cap
            mb_skip(slen - cap)
            return 0u64
        }
        mb_skip(slen)
        return 0u64
    }
    if vt == 9u64 {
        /* array: elem type + count */
        let et : u64 = mb_u32()
        let cnt : u64 = mb_u64()
        if et == 8u64 {
            /* THE LEXIS capture: tokenizer.ggml.tokens, once, whole --
             * each surface form's raw bytes packed into MB_TKT with an
             * offset/length index.  Over-long or over-count tokens are
             * clamped (the byte pool is bounded); the index stays exact. */
            let mut want : u64 = 0u64
            if MB_TKF == 0u8 {
                if mb_keyis("tokenizer.ggml.tokens" as u64, klen) == 1u64 { want = 1u64 }
            }
            if want == 1u64 {
                MB_TKN = cnt
                if MB_TKN > 129280u64 { MB_TKN = 129280u64 }
                MB_TKUSED = 0u64
                let mut a : u64 = 0u64
                while a < cnt {
                    let sl : u64 = mb_u64()
                    if a < 129280u64 {
                        MB_TKOFF[a] = MB_TKUSED
                        let mut cap : u64 = sl
                        if MB_TKUSED + cap > 4194304u64 { cap = 4194304u64 - MB_TKUSED }
                        let mut c : u64 = 0u64
                        while c < cap {
                            MB_TKT[MB_TKUSED + c] = mb_u8() as u8
                            c = c + 1u64
                        }
                        MB_TKLEN[a] = cap
                        MB_TKUSED = MB_TKUSED + cap
                        mb_skip(sl - cap)
                    }
                    if a >= 129280u64 { mb_skip(sl) }
                    if MB_IOERR != 0u8 { return 1u64 }
                    a = a + 1u64
                }
                MB_TKF = 1u8
                return 0u64
            }
            let mut a2 : u64 = 0u64
            while a2 < cnt {
                let sl : u64 = mb_u64()
                mb_skip(sl)
                if MB_IOERR != 0u8 { return 1u64 }
                a2 = a2 + 1u64
            }
            return 0u64
        }
        if et == 9u64 { return 1u64 }
        let esz : u64 = mb_scalar_size(et)
        if esz == 0u64 { return 1u64 }
        mb_skip(esz * cnt)
        return 0u64
    }
    let ssz : u64 = mb_scalar_size(vt)
    if ssz == 0u64 { return 1u64 }
    /* scalar: extract the named facts */
    if mb_keyis("general.alignment" as u64, klen) == 1u64 {
        MB_ALIGN = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("split.no" as u64, klen) == 1u64 {
        MB_SPLITNO = mb_scalar_read(vt)
        MB_SPLITNO_F = 1u8
        return 0u64
    }
    if mb_keyis("split.count" as u64, klen) == 1u64 {
        let v : u64 = mb_scalar_read(vt)
        if MB_SPLITCT_F == 1u8 {
            if v != MB_SPLITCT { return 1u64 }
        }
        MB_SPLITCT = v
        MB_SPLITCT_F = 1u8
        return 0u64
    }
    if mb_keyis("split.tensors.count" as u64, klen) == 1u64 {
        MB_SPLITTN = mb_scalar_read(vt)
        MB_SPLITTN_F = 1u8
        return 0u64
    }
    if mb_keyis("deepseek2.embedding_length" as u64, klen) == 1u64 {
        MB_EMBED = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.block_count" as u64, klen) == 1u64 {
        MB_LAYERS = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.attention.head_count" as u64, klen) == 1u64 {
        MB_NHEAD = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.rope.dimension_count" as u64, klen) == 1u64 {
        MB_NROPE = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.attention.layer_norm_rms_epsilon" as u64, klen) == 1u64 {
        MB_EPSB = mb_scalar_read(vt)
        MB_EPSF = 1u8
        return 0u64
    }
    if mb_keyis("deepseek2.expert_count" as u64, klen) == 1u64 {
        MB_EXPCNT = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.expert_used_count" as u64, klen) == 1u64 {
        MB_EXPUSED = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.expert_shared_count" as u64, klen) == 1u64 {
        MB_EXPSHARE = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.expert_feed_forward_length" as u64, klen) == 1u64 {
        MB_EXPFFN = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.expert_weights_scale" as u64, klen) == 1u64 {
        MB_EXPSCALE = mb_scalar_read(vt)
        MB_EXPSCF = 1u8
        return 0u64
    }
    if mb_keyis("deepseek2.leading_dense_block_count" as u64, klen) == 1u64 {
        MB_DENSE = mb_scalar_read(vt)
        MB_DENSEF = 1u8
        return 0u64
    }
    if mb_keyis("deepseek2.attention.kv_lora_rank" as u64, klen) == 1u64 {
        MB_KVLORA = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.attention.q_lora_rank" as u64, klen) == 1u64 {
        MB_QLORA = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.attention.key_length" as u64, klen) == 1u64 {
        MB_KEYLEN = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.attention.value_length" as u64, klen) == 1u64 {
        MB_VALLEN = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("tokenizer.ggml.bos_token_id" as u64, klen) == 1u64 {
        MB_BOS = mb_scalar_read(vt)
        MB_BOSF = 1u8
        return 0u64
    }
    if mb_keyis("deepseek2.rope.freq_base" as u64, klen) == 1u64 {
        MB_FREQBASE = mb_scalar_read(vt)
        MB_FREQBF = 1u8
        return 0u64
    }
    if mb_keyis("deepseek2.rope.scaling.factor" as u64, klen) == 1u64 {
        MB_ROPEFAC = mb_scalar_read(vt)
        MB_ROPEFACF = 1u8
        return 0u64
    }
    if mb_keyis("deepseek2.rope.scaling.original_context_length" as u64, klen) == 1u64 {
        MB_ROPEORIG = mb_scalar_read(vt)
        return 0u64
    }
    if mb_keyis("deepseek2.rope.scaling.yarn_log_multiplier" as u64, klen) == 1u64 {
        MB_YARNMULT = mb_scalar_read(vt)
        MB_YARNMF = 1u8
        return 0u64
    }
    if mb_keyis("deepseek2.expert_weights_norm" as u64, klen) == 1u64 {
        MB_EXPNORM = mb_scalar_read(vt)
        MB_EXPNORMF = 1u8
        return 0u64
    }
    if mb_keyis("deepseek2.expert_gating_func" as u64, klen) == 1u64 {
        MB_EXPGATE = mb_scalar_read(vt)
        MB_EXPGATEF = 1u8
        return 0u64
    }
    mb_skip(ssz)
    return 0u64
}

fn mb_align_up(x: u64, a: u64) -> u64 {
    return (x + a - 1u64) & (0u64 - a)
}

/* exact match of MB_KEY[off..nlen] against a NUL-terminated literal */
fn mb_tail_is(off: u64, lit: u64, nlen: u64) -> u64 {
    let p : *u8 = lit as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 {
        if off + i >= nlen { return 0u64 }
        if MB_KEY[off + i] != p[i] { return 0u64 }
        i = i + 1u64
    }
    if off + i != nlen { return 0u64 }
    return 1u64
}

/* parse "blk.<L>.<role>" into slot L*12+role for L in 0..60; 732 = no match */
fn mb_blk_slot(nlen: u64) -> u64 {
    if nlen < 6u64 { return 732u64 }
    if MB_KEY[0] != 98u8 { return 732u64 }
    if MB_KEY[1] != 108u8 { return 732u64 }
    if MB_KEY[2] != 107u8 { return 732u64 }
    if MB_KEY[3] != 46u8 { return 732u64 }
    let mut i : u64 = 4u64
    let mut lay : u64 = 0u64
    let mut hasd : u64 = 0u64
    let mut done : u64 = 0u64
    while done == 0u64 {
        if i >= nlen { done = 1u64 }
        if done == 0u64 {
            let c : u64 = MB_KEY[i] as u64
            if c < 48u64 { done = 1u64 }
            if c > 57u64 { done = 1u64 }
            if done == 0u64 {
                lay = lay * 10u64 + (c - 48u64)
                hasd = 1u64
                i = i + 1u64
            }
        }
    }
    if hasd == 0u64 { return 732u64 }
    if lay >= 61u64 { return 732u64 }
    if i >= nlen { return 732u64 }
    if MB_KEY[i] != 46u8 { return 732u64 }
    let off : u64 = i + 1u64
    let mut role : u64 = 12u64
    if mb_tail_is(off, "attn_norm.weight" as u64, nlen) == 1u64 { role = 0u64 }
    if mb_tail_is(off, "attn_q_a.weight" as u64, nlen) == 1u64 { role = 1u64 }
    if mb_tail_is(off, "attn_q_a_norm.weight" as u64, nlen) == 1u64 { role = 2u64 }
    if mb_tail_is(off, "attn_q_b.weight" as u64, nlen) == 1u64 { role = 3u64 }
    if mb_tail_is(off, "attn_kv_a_mqa.weight" as u64, nlen) == 1u64 { role = 4u64 }
    if mb_tail_is(off, "attn_kv_a_norm.weight" as u64, nlen) == 1u64 { role = 5u64 }
    if mb_tail_is(off, "attn_kv_b.weight" as u64, nlen) == 1u64 { role = 6u64 }
    if mb_tail_is(off, "attn_output.weight" as u64, nlen) == 1u64 { role = 7u64 }
    if mb_tail_is(off, "ffn_norm.weight" as u64, nlen) == 1u64 { role = 8u64 }
    if mb_tail_is(off, "ffn_gate.weight" as u64, nlen) == 1u64 { role = 9u64 }
    if mb_tail_is(off, "ffn_up.weight" as u64, nlen) == 1u64 { role = 10u64 }
    if mb_tail_is(off, "ffn_down.weight" as u64, nlen) == 1u64 { role = 11u64 }
    if role == 12u64 { return 732u64 }
    return lay * 12u64 + role
}

/* parse the "blk.<L>." prefix of MB_KEY: the layer returned (0..60), the
 * index AFTER the dot into MB_LAYOFF; 61 = no such prefix.  The same
 * digit law as mb_blk_slot -- one grammar, many organs. */
var MB_LAYOFF : u64 = 0u64
fn mb_lay_at(nlen: u64) -> u64 {
    if nlen < 6u64 { return 61u64 }
    if MB_KEY[0] != 98u8 { return 61u64 }
    if MB_KEY[1] != 108u8 { return 61u64 }
    if MB_KEY[2] != 107u8 { return 61u64 }
    if MB_KEY[3] != 46u8 { return 61u64 }
    let mut i : u64 = 4u64
    let mut lay : u64 = 0u64
    let mut hasd : u64 = 0u64
    let mut done : u64 = 0u64
    while done == 0u64 {
        if i >= nlen { done = 1u64 }
        if done == 0u64 {
            let c : u64 = MB_KEY[i] as u64
            if c < 48u64 { done = 1u64 }
            if c > 57u64 { done = 1u64 }
            if done == 0u64 {
                lay = lay * 10u64 + (c - 48u64)
                hasd = 1u64
                i = i + 1u64
            }
        }
    }
    if hasd == 0u64 { return 61u64 }
    if lay >= 61u64 { return 61u64 }
    if i >= nlen { return 61u64 }
    if MB_KEY[i] != 46u8 { return 61u64 }
    MB_LAYOFF = i + 1u64
    return lay
}

/* parse "blk.<L>.ffn_*_{exps,shexp}.weight" into slot L*6+role; 366 = no */
fn mb_moe_slot(nlen: u64) -> u64 {
    let lay : u64 = mb_lay_at(nlen)
    if lay >= 61u64 { return 366u64 }
    let off : u64 = MB_LAYOFF
    let mut role : u64 = 6u64
    if mb_tail_is(off, "ffn_gate_exps.weight" as u64, nlen) == 1u64 { role = 0u64 }
    if mb_tail_is(off, "ffn_up_exps.weight" as u64, nlen) == 1u64 { role = 1u64 }
    if mb_tail_is(off, "ffn_down_exps.weight" as u64, nlen) == 1u64 { role = 2u64 }
    if mb_tail_is(off, "ffn_gate_shexp.weight" as u64, nlen) == 1u64 { role = 3u64 }
    if mb_tail_is(off, "ffn_up_shexp.weight" as u64, nlen) == 1u64 { role = 4u64 }
    if mb_tail_is(off, "ffn_down_shexp.weight" as u64, nlen) == 1u64 { role = 5u64 }
    if role == 6u64 { return 366u64 }
    return lay * 6u64 + role
}

/* the election organs of layer L: router row tensor / selection bias */
fn mb_rt_slot(nlen: u64) -> u64 {
    let lay : u64 = mb_lay_at(nlen)
    if lay >= 61u64 { return 61u64 }
    if mb_tail_is(MB_LAYOFF, "ffn_gate_inp.weight" as u64, nlen) == 1u64 { return lay }
    return 61u64
}
fn mb_eb_slot(nlen: u64) -> u64 {
    let lay : u64 = mb_lay_at(nlen)
    if lay >= 61u64 { return 61u64 }
    if mb_tail_is(MB_LAYOFF, "exp_probs_b.bias" as u64, nlen) == 1u64 { return lay }
    return 61u64
}

/* the specials; 4 = no match */
fn mb_sp_slot(nlen: u64) -> u64 {
    if mb_keyis("token_embd.weight" as u64, nlen) == 1u64 { return 0u64 }
    if mb_keyis("output_norm.weight" as u64, nlen) == 1u64 { return 1u64 }
    if mb_keyis("output.weight" as u64, nlen) == 1u64 { return 2u64 }
    if mb_keyis("rope_freqs.weight" as u64, nlen) == 1u64 { return 3u64 }
    return 4u64
}

/* walk one tensor info; index t < MB_MAXT.  returns 0 ok, 1 refuse */
fn mb_tensor_one(shard: u64, t: u64) -> u64 {
    let nlen : u64 = mb_u64()
    if nlen > 255u64 { return 1u64 }
    /* keep the name only if this becomes a digestion candidate */
    let mut i : u64 = 0u64
    while i < nlen {
        if i < 255u64 { MB_KEY[i] = mb_u8() as u8 }
        if i >= 255u64 { mb_u8() }
        i = i + 1u64
    }
    let nd : u64 = mb_u32()
    if nd > 8u64 { return 1u64 }
    let mut ne : u64 = 1u64
    let mut ne0 : u64 = 0u64
    let mut d : u64 = 0u64
    while d < nd {
        let dim : u64 = mb_u64()
        if d == 0u64 { ne0 = dim }
        ne = ne * dim
        d = d + 1u64
    }
    let ty : u64 = mb_u32()
    let off : u64 = mb_u64()
    if MB_IOERR != 0u8 { return 1u64 }
    if ty < 64u64 { MB_HIST[ty] = MB_HIST[ty] + 1u64 }
    /* the router capture: first name containing "ffn_gate_inp" in ANY shard */
    if MB_C3_F == 0u8 {
        if nlen >= 12u64 {
            let ndl : u64 = "ffn_gate_inp" as u64
            let np : *u8 = ndl as *u8
            let mut si : u64 = 0u64
            let mut hit : u64 = 0u64
            while si + 12u64 <= nlen {
                let mut sj : u64 = 0u64
                let mut ok : u64 = 1u64
                while sj < 12u64 {
                    if MB_KEY[si + sj] != np[sj] { ok = 0u64   sj = 12u64 }
                    sj = sj + 1u64
                }
                if ok == 1u64 { hit = 1u64   si = nlen }
                si = si + 1u64
            }
            if hit == 1u64 {
                MB_C3_TYPE = ty
                MB_C3_OFF = off
                MB_C3_NE = ne
                MB_C3_NE0 = ne0
                MB_C3_SHARD = shard
                let mut cc : u64 = nlen
                if cc > 47u64 { cc = 47u64 }
                let mut ck : u64 = 0u64
                while ck < cc {
                    MB_C3_NAME[ck] = MB_KEY[ck]
                    ck = ck + 1u64
                }
                MB_C3_NN = cc
                MB_C3_F = 1u8
                MB_C3_HERE = 1u8
            }
        }
    }
    /* the per-layer capture: blk.<L>.<role> for L in 0..60 -> slot L*12+role */
    let gsl : u64 = mb_blk_slot(nlen)
    if gsl < 732u64 {
        if MB_G_F[gsl] == 0u8 {
            MB_G_TYPE[gsl] = ty
            MB_G_OFF[gsl] = off
            MB_G_NE[gsl] = ne
            MB_G_NE0[gsl] = ne0
            MB_G_SH[gsl] = shard
            MB_G_F[gsl] = 1u8
            MB_G_HERE[gsl] = 1u8
        }
    }
    /* the MoE expert capture for EVERY layer (3D expert tensors + shared) */
    let mesl : u64 = mb_moe_slot(nlen)
    if mesl < 366u64 {
        if MB_ME_F[mesl] == 0u8 {
            MB_ME_TYPE[mesl] = ty
            MB_ME_OFF[mesl] = off
            MB_ME_NE[mesl] = ne
            MB_ME_NE0[mesl] = ne0
            MB_ME_SH[mesl] = shard
            MB_ME_F[mesl] = 1u8
            MB_ME_HERE[mesl] = 1u8
        }
    }
    /* the election organs: per-layer router + selection bias */
    let rtl : u64 = mb_rt_slot(nlen)
    if rtl < 61u64 {
        if MB_RT_F[rtl] == 0u8 {
            MB_RT_TYPE[rtl] = ty
            MB_RT_OFF[rtl] = off
            MB_RT_NE[rtl] = ne
            MB_RT_NE0[rtl] = ne0
            MB_RT_SH[rtl] = shard
            MB_RT_F[rtl] = 1u8
            MB_RT_HERE[rtl] = 1u8
        }
    }
    let ebl : u64 = mb_eb_slot(nlen)
    if ebl < 61u64 {
        if MB_EB_F[ebl] == 0u8 {
            MB_EB_TYPE[ebl] = ty
            MB_EB_OFF[ebl] = off
            MB_EB_NE[ebl] = ne
            MB_EB_NE0[ebl] = ne0
            MB_EB_SH[ebl] = shard
            MB_EB_F[ebl] = 1u8
            MB_EB_HERE[ebl] = 1u8
        }
    }
    /* the specials */
    let spl : u64 = mb_sp_slot(nlen)
    if spl < 4u64 {
        if MB_SP_F[spl] == 0u8 {
            MB_SP_TYPE[spl] = ty
            MB_SP_OFF[spl] = off
            MB_SP_NE[spl] = ne
            MB_SP_NE0[spl] = ne0
            MB_SP_SH[spl] = shard
            MB_SP_F[spl] = 1u8
            MB_SP_HERE[spl] = 1u8
        }
    }
    let bv : u64 = mb_tbv(ty)
    if bv == 0u64 { return 1u64 }
    if ne0 % bv != 0u64 { return 1u64 }
    let nb : u64 = (ne / bv) * mb_tbb(ty)
    MB_OFF[t] = off
    MB_NB[t] = nb
    /* digestion candidates: the first two quantized tensors of shard 1 */
    if shard == 1u64 {
        let mut isq : u64 = 0u64
        if ty == 8u64 { isq = 1u64 }
        if ty == 12u64 { isq = 1u64 }
        if ty == 14u64 { isq = 1u64 }
        if isq == 1u64 {
            if MB_C1_F == 0u8 {
                MB_C1_TYPE = ty
                MB_C1_OFF = off
                MB_C1_NE = ne
                MB_C1_NE0 = ne0
                let mut c : u64 = nlen
                if c > 63u64 { c = 63u64 }
                let mut k : u64 = 0u64
                while k < c {
                    MB_C1_NAME[k] = MB_KEY[k]
                    k = k + 1u64
                }
                MB_C1_NN = c
                MB_C1_F = 1u8
                return 0u64
            }
            if MB_C2_F == 0u8 {
                MB_C2_TYPE = ty
                MB_C2_OFF = off
                MB_C2_NE = ne
                MB_C2_NE0 = ne0
                let mut c2 : u64 = nlen
                if c2 > 63u64 { c2 = 63u64 }
                let mut k2 : u64 = 0u64
                while k2 < c2 {
                    MB_C2_NAME[k2] = MB_KEY[k2]
                    k2 = k2 + 1u64
                }
                MB_C2_NN = c2
                MB_C2_F = 1u8
            }
        }
    }
    return 0u64
}

/* full walk + conservation of one shard.  returns:
 * 0 conserved / 1 refused (named) / 2 io-broken / 3 not found */
fn mb_shard(i: u64) -> u64 {
    mb_mkpath(i)
    let f : u64 = fopen((&MB_PATH) as u64, "rb" as u64)
    if f == 0u64 { return 3u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    /* file size */
    _fseeki64(f, 0i64, 2i32)
    let fsz : u64 = _ftelli64(f) as u64
    mb_seek_abs(0u64)
    /* header */
    let magic : u64 = mb_u32()
    if magic != 0x46554747u64 {
        fclose(f)
        return 1u64
    }
    let ver : u64 = mb_u32()
    if ver != 3u64 {
        fclose(f)
        return 1u64
    }
    let ntens : u64 = mb_u64()
    let nkv : u64 = mb_u64()
    if ntens > MB_MAXT {
        fclose(f)
        return 1u64
    }
    /* per-shard extraction state */
    MB_ALIGN = MB_ALIGN_DEF
    MB_SPLITNO_F = 0u8
    /* the KV forest */
    let mut k : u64 = 0u64
    while k < nkv {
        if mb_kv_one(i) != 0u64 {
            fclose(f)
            return 1u64
        }
        k = k + 1u64
    }
    /* alignment must be a power of two */
    if MB_ALIGN == 0u64 {
        fclose(f)
        return 1u64
    }
    if (MB_ALIGN & (MB_ALIGN - 1u64)) != 0u64 {
        fclose(f)
        return 1u64
    }
    /* the tensor infos */
    let mut t : u64 = 0u64
    while t < ntens {
        if mb_tensor_one(i, t) != 0u64 {
            fclose(f)
            return 1u64
        }
        t = t + 1u64
    }
    if MB_IOERR != 0u8 {
        fclose(f)
        return 2u64
    }
    let data_base : u64 = mb_align_up(mb_pos(), MB_ALIGN)
    if MB_C3_HERE == 1u8 {
        MB_C3_DBASE = data_base
        MB_C3_HERE = 0u8
    }
    let mut gdb : u64 = 0u64
    while gdb < 732u64 {
        if MB_G_HERE[gdb] == 1u8 {
            MB_G_DB[gdb] = data_base
            MB_G_HERE[gdb] = 0u8
        }
        gdb = gdb + 1u64
    }
    let mut edb : u64 = 0u64
    while edb < 366u64 {
        if MB_ME_HERE[edb] == 1u8 {
            MB_ME_DB[edb] = data_base
            MB_ME_HERE[edb] = 0u8
        }
        edb = edb + 1u64
    }
    let mut rdb : u64 = 0u64
    while rdb < 61u64 {
        if MB_RT_HERE[rdb] == 1u8 {
            MB_RT_DB[rdb] = data_base
            MB_RT_HERE[rdb] = 0u8
        }
        if MB_EB_HERE[rdb] == 1u8 {
            MB_EB_DB[rdb] = data_base
            MB_EB_HERE[rdb] = 0u8
        }
        rdb = rdb + 1u64
    }
    let mut sdb : u64 = 0u64
    while sdb < 4u64 {
        if MB_SP_HERE[sdb] == 1u8 {
            MB_SP_DB[sdb] = data_base
            MB_SP_HERE[sdb] = 0u8
        }
        sdb = sdb + 1u64
    }
    if i == 1u64 {
        MB_DBASE1 = data_base
        let mut pc : u64 = 0u64
        while pc < 64u64 {
            MB_PATH1[pc] = MB_PATH[pc]
            pc = pc + 1u64
        }
    }
    /* sort spans by offset (insertion; ntens <= 512) */
    let mut a : u64 = 1u64
    while a < ntens {
        let ko : u64 = MB_OFF[a]
        let kn : u64 = MB_NB[a]
        let mut b : u64 = a
        let mut go : u8 = 1u8
        while go == 1u8 {
            go = 0u8
            if b > 0u64 {
                if MB_OFF[b - 1u64] > ko {
                    MB_OFF[b] = MB_OFF[b - 1u64]
                    MB_NB[b] = MB_NB[b - 1u64]
                    b = b - 1u64
                    go = 1u8
                }
            }
        }
        MB_OFF[b] = ko
        MB_NB[b] = kn
        a = a + 1u64
    }
    /* THE TILING: spans, each padded to the artifact's alignment, must fit
     * flush -- first at zero, each next exactly at the padded end of the
     * previous, the last ending within one pad of the file end */
    let mut expect : u64 = 0u64
    let mut last_end : u64 = 0u64
    t = 0u64
    while t < ntens {
        if MB_OFF[t] != expect {
            fclose(f)
            return 1u64
        }
        last_end = MB_OFF[t] + MB_NB[t]
        expect = mb_align_up(last_end, MB_ALIGN)
        t = t + 1u64
    }
    let end_abs : u64 = data_base + last_end
    if end_abs > fsz {
        fclose(f)
        return 1u64
    }
    let tail : u64 = fsz - end_abs
    if tail >= MB_ALIGN {
        fclose(f)
        return 1u64
    }
    /* split coherence bookkeeping */
    if i <= 16u64 {
        MB_SPNOSF[i - 1u64] = MB_SPLITNO_F
        MB_SPNOS[i - 1u64] = MB_SPLITNO
    }
    MB_TOT_TENS = MB_TOT_TENS + ntens
    MB_TOT_BYTES = MB_TOT_BYTES + fsz
    fclose(f)
    return 0u64
}

fn mb_arm362() -> u64 {
    MB_SHARDS = 0u64
    MB_TOT_TENS = 0u64
    MB_TOT_BYTES = 0u64
    MB_CONSERVED = 0u64
    MB_REFUSED = 0u64
    MB_FEAST = 0u8
    let mut i : u64 = 1u64
    let mut stop : u8 = 0u8
    while stop == 0u8 {
        let rc : u64 = mb_shard(i)
        if rc == 3u64 { stop = 1u8 }
        if rc == 0u64 { MB_CONSERVED = MB_CONSERVED + 1u64 }
        if rc == 1u64 { MB_REFUSED = MB_REFUSED + 1u64 }
        if rc == 2u64 {
            /* an unreadable shard is a broken door, not a lawful fast */
            return 362u64
        }
        if stop == 0u8 {
            MB_SHARDS = i
            i = i + 1u64
            if i > 99u64 { stop = 1u8 }
        }
    }
    if MB_SHARDS == 0u64 {
        mb_rs("the feast: absent (lawful) -- the door stands, the table waits" as u64)
        mb_rb(10u8)
        return 0u64
    }
    MB_FEAST = 1u8
    /* every found shard must have conserved (a refused shard is a red door) */
    if MB_CONSERVED != MB_SHARDS { return 362u64 }
    /* split coherence: if split KVs exist they must name this very feast --
     * indices all present and distinct, spanning 0..N-1 or 1..N; the declared
     * count equal to the number of files on the table */
    let mut split_ok : u64 = 0u64
    if MB_SPLITCT_F == 1u8 {
        if MB_SPLITCT != MB_SHARDS { return 362u64 }
        let mut allf : u64 = 1u64
        let mut mn : u64 = 0xFFFFFFFFFFFFFFFFu64
        let mut mx : u64 = 0u64
        let mut s : u64 = 0u64
        while s < MB_SHARDS {
            if MB_SPNOSF[s] == 0u8 { allf = 0u64 }
            if MB_SPNOSF[s] == 1u8 {
                if MB_SPNOS[s] < mn { mn = MB_SPNOS[s] }
                if MB_SPNOS[s] > mx { mx = MB_SPNOS[s] }
                let mut s2 : u64 = 0u64
                while s2 < s {
                    if MB_SPNOS[s2] == MB_SPNOS[s] { allf = 0u64 }
                    s2 = s2 + 1u64
                }
            }
            s = s + 1u64
        }
        if allf == 1u64 {
            /* distinct + contiguous: zero-based or one-based, both lawful */
            if mn == 0u64 {
                if mx == MB_SHARDS - 1u64 { split_ok = 1u64 }
            }
            if mn == 1u64 {
                if mx == MB_SHARDS { split_ok = 1u64 }
            }
        }
        if split_ok == 0u64 { return 362u64 }
    }
    /* the declared whole vs the derived whole */
    if MB_SPLITTN_F == 1u8 {
        if MB_SPLITTN != MB_TOT_TENS { return 362u64 }
    }
    mb_rs("the feast: shards=" as u64)
    mb_ru(MB_SHARDS)
    mb_rs(" split=" as u64)
    if MB_SPLITCT_F == 1u8 { mb_ru(MB_SPLITCT) }
    if MB_SPLITCT_F == 0u8 { mb_rs("none" as u64) }
    mb_rs(" arch=" as u64)
    let mut ai : u64 = 0u64
    while ai < MB_ARCHN {
        mb_rb(MB_ARCH[ai])
        ai = ai + 1u64
    }
    mb_rs(" tensors=" as u64)
    mb_ru(MB_TOT_TENS)
    mb_rs("/" as u64)
    if MB_SPLITTN_F == 1u8 { mb_ru(MB_SPLITTN) }
    if MB_SPLITTN_F == 0u8 { mb_ru(MB_TOT_TENS) }
    mb_rs(" bytes=" as u64)
    mb_ru(MB_TOT_BYTES)
    mb_rs(" conserved=" as u64)
    mb_ru(MB_CONSERVED)
    mb_rs("/" as u64)
    mb_ru(MB_SHARDS)
    mb_rs(" refused=" as u64)
    mb_ru(MB_REFUSED)
    mb_rb(10u8)
    if MB_EMBED != 0u64 {
        mb_rs("the anatomy: embed=" as u64)
        mb_ru(MB_EMBED)
        mb_rs(" layers=" as u64)
        mb_ru(MB_LAYERS)
        mb_rs(" align=" as u64)
        mb_ru(MB_ALIGN)
        mb_rb(10u8)
        mb_rs("the ledger: dense=" as u64)
        mb_ru(MB_DENSE)
        mb_rs(" experts=" as u64)
        mb_ru(MB_EXPCNT)
        mb_rs(" used=" as u64)
        mb_ru(MB_EXPUSED)
        mb_rs(" shared=" as u64)
        mb_ru(MB_EXPSHARE)
        mb_rs(" expffn=" as u64)
        mb_ru(MB_EXPFFN)
        mb_rs(" kvlora=" as u64)
        mb_ru(MB_KVLORA)
        mb_rs(" qlora=" as u64)
        mb_ru(MB_QLORA)
        mb_rs(" keylen=" as u64)
        mb_ru(MB_KEYLEN)
        mb_rs(" vallen=" as u64)
        mb_ru(MB_VALLEN)
        mb_rs(" rope=" as u64)
        let mut rti : u64 = 0u64
        while rti < MB_ROPETN {
            mb_rb(MB_ROPETYP[rti])
            rti = rti + 1u64
        }
        mb_rs(" orig=" as u64)
        mb_ru(MB_ROPEORIG)
        mb_rs(" freqbase=" as u64)
        mb_ru(MB_FREQBASE)
        mb_rs(" ropefac=" as u64)
        mb_ru(MB_ROPEFAC)
        mb_rs(" expscale=" as u64)
        mb_ru(MB_EXPSCALE)
        mb_rs(" yarnmult=" as u64)
        mb_ru(MB_YARNMULT)
        mb_rs(" gate=" as u64)
        mb_ru(MB_EXPGATE)
        mb_rs(" wnorm=" as u64)
        mb_ru(MB_EXPNORM)
        mb_rb(10u8)
    }
    return 0u64
}

/* ==================== THE ANATOMIA (the whole body) ====================
 * The registry now holds every layer's organs.  This arm walks the WHOLE
 * body -- 61 layers, the per-layer routers and selection biases, the
 * expert tensors, the specials -- and speaks the anatomy as ONE derived
 * line: how many layers carry the full attention octet, how many dense
 * layers carry the dense dozen, how many MoE layers stand complete
 * (norm + router + six expert tensors), how many carry the selection
 * bias, whether the head and embedding are on the table, and how many
 * registry tensors are shape-twins of an earlier one.  The NEGATIVE arm
 * stands beside the positive: an over-layer name must refuse WHOLE at
 * every parser; the layer-selector must serve a deep layer's geometry
 * and return home.  Headers only -- the anatomy costs no new stream.
 * Code 386 on red. */

/* fill MB_KEY from a literal; returns its length (the parsers' scratch) */
fn mb_keyset(lit: u64) -> u64 {
    let p : *u8 = lit as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 {
        if i < 255u64 { MB_KEY[i] = p[i] }
        i = i + 1u64
    }
    return i
}

fn mb_anatomia() -> u64 {
    if MB_FEAST == 0u8 {
        mb_rs("the anatomia: fasting (no feast) -- the body waits" as u64)
        mb_rb(10u8)
        return 0u64
    }
    /* the negative arms: over-layer and foreign names refuse WHOLE */
    let n1 : u64 = mb_keyset("blk.61.attn_norm.weight" as u64)
    if mb_blk_slot(n1) != 732u64 { return 386u64 }
    let n2 : u64 = mb_keyset("blk.99.ffn_gate_exps.weight" as u64)
    if mb_moe_slot(n2) != 366u64 { return 386u64 }
    let n3 : u64 = mb_keyset("blk.7.nonsense.weight" as u64)
    if mb_blk_slot(n3) != 732u64 { return 386u64 }
    let n4 : u64 = mb_keyset("blk.61.ffn_gate_inp.weight" as u64)
    if mb_rt_slot(n4) != 61u64 { return 386u64 }
    /* the presence walk */
    let mut layers : u64 = MB_LAYERS
    if layers > 61u64 { layers = 61u64 }
    let mut dense : u64 = MB_DENSE
    if dense > layers { dense = layers }
    let mut attn_ok : u64 = 0u64
    let mut densef_ok : u64 = 0u64
    let mut moe_ok : u64 = 0u64
    let mut rt_ok : u64 = 0u64
    let mut eb_ok : u64 = 0u64
    let mut lay : u64 = 0u64
    while lay < layers {
        let b : u64 = lay * 12u64
        let mut r : u64 = 0u64
        let mut all8 : u64 = 1u64
        while r < 8u64 {
            if MB_G_F[b + r] == 0u8 { all8 = 0u64 }
            r = r + 1u64
        }
        if all8 == 1u64 { attn_ok = attn_ok + 1u64 }
        if lay < dense {
            let mut alld : u64 = 1u64
            r = 8u64
            while r < 12u64 {
                if MB_G_F[b + r] == 0u8 { alld = 0u64 }
                r = r + 1u64
            }
            if alld == 1u64 { densef_ok = densef_ok + 1u64 }
        }
        if lay >= dense {
            let mb2 : u64 = lay * 6u64
            let mut allm : u64 = 1u64
            if MB_G_F[b + 8u64] == 0u8 { allm = 0u64 }
            if MB_RT_F[lay] == 0u8 { allm = 0u64 }
            let mut r2 : u64 = 0u64
            while r2 < 6u64 {
                if MB_ME_F[mb2 + r2] == 0u8 { allm = 0u64 }
                r2 = r2 + 1u64
            }
            if allm == 1u64 { moe_ok = moe_ok + 1u64 }
            if MB_RT_F[lay] == 1u8 { rt_ok = rt_ok + 1u64 }
            if MB_EB_F[lay] == 1u8 { eb_ok = eb_ok + 1u64 }
        }
        lay = lay + 1u64
    }
    let mut sp_ok : u64 = 0u64
    let mut sk : u64 = 0u64
    while sk < 3u64 {
        if MB_SP_F[sk] == 1u8 { sp_ok = sp_ok + 1u64 }
        sk = sk + 1u64
    }
    /* the voice's width: output.weight rows over its input dim */
    let mut voc : u64 = 0u64
    if MB_SP_F[2u64] == 1u8 {
        if MB_SP_NE0[2u64] != 0u64 { voc = MB_SP_NE[2u64] / MB_SP_NE0[2u64] }
    }
    /* twin shapes across the layer registry */
    let mut twins : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 732u64 {
        if MB_G_F[i] == 1u8 {
            let mut j : u64 = 0u64
            let mut dup : u64 = 0u64
            while j < i {
                if dup == 0u64 {
                    if MB_G_F[j] == 1u8 {
                        if MB_G_TYPE[j] == MB_G_TYPE[i] {
                            if MB_G_NE[j] == MB_G_NE[i] {
                                if MB_G_NE0[j] == MB_G_NE0[i] { dup = 1u64 }
                            }
                        }
                    }
                }
                j = j + 1u64
            }
            if dup == 1u64 { twins = twins + 1u64 }
        }
        i = i + 1u64
    }
    /* the selector exercised: a DEEP layer's geometry served through the
     * standing faces, the bias loaded finite, and the selector returned
     * home to the proven layer 3 */
    let mut selex : u64 = 1u64
    if moe_ok > 1u64 {
        if mb_me_sel(4u64) != 0u64 { selex = 0u64 }
        if mb_me_ne0(0u64) != 7168u64 { selex = 0u64 }
        if mb_me_ne(0u64) / 7168u64 / 256u64 != 2048u64 { selex = 0u64 }
        if mb_eb_present(4u64) == 1u64 {
            if mb_moe_bias_load() != 0u64 { selex = 0u64 }
        }
        if mb_me_sel(3u64) != 0u64 { selex = 0u64 }
        if mb_me_ne0(0u64) != 7168u64 { selex = 0u64 }
    }
    if selex == 0u64 { return 386u64 }
    mb_rs("the anatomia: layers=" as u64)
    mb_ru(layers)
    mb_rs(" attn=" as u64)
    mb_ru(attn_ok)
    mb_rs("/" as u64)
    mb_ru(layers)
    mb_rs(" dense-ffn=" as u64)
    mb_ru(densef_ok)
    mb_rs("/" as u64)
    mb_ru(dense)
    mb_rs(" moe=" as u64)
    mb_ru(moe_ok)
    mb_rs("/" as u64)
    mb_ru(layers - dense)
    mb_rs(" router=" as u64)
    mb_ru(rt_ok)
    mb_rs("/" as u64)
    mb_ru(layers - dense)
    mb_rs(" bias=" as u64)
    mb_ru(eb_ok)
    mb_rs("/" as u64)
    mb_ru(layers - dense)
    mb_rs(" specials=" as u64)
    mb_ru(sp_ok)
    mb_rs("/3 voc=" as u64)
    mb_ru(voc)
    mb_rs(" twins(shape)=" as u64)
    mb_ru(twins)
    mb_rs(" over-layer-refused=ok sel-exercise=ok -- the whole body on the registry, headers only" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ==================== arm 363: THE DIGESTION ==================== */

/* read `n` raw bytes at absolute offset into MB_BLK (shard 1 must be open) */
fn mb_read_block(abs: u64, n: u64) -> u64 {
    mb_seek_abs(abs)
    let mut i : u64 = 0u64
    while i < n {
        MB_BLK[i] = mb_u8() as u8
        i = i + 1u64
    }
    if MB_IOERR != 0u8 { return 1u64 }
    return 0u64
}

/* q4_K sub-block scale/min unpack (the 6-bit law) */
var MB_SC : u64 = 0u64
var MB_SM : u64 = 0u64
fn mb_q4k_scale(j: u64) -> i32 {
    if j < 4u64 {
        MB_SC = (MB_BLK[4u64 + j] as u64) & 63u64
        MB_SM = (MB_BLK[8u64 + j] as u64) & 63u64
        return 0i32
    }
    /* llama.cpp: sc = (s[j+4] & 0xF) | ((s[j-4] >> 6) << 4)
     *            m  = (s[j+4] >> 4)  | ((s[j]   >> 6) << 4)
     * our BLK holds scales at bytes 4..15: s[k] = BLK[4+k] */
    let sj4 : u64 = MB_BLK[4u64 + j + 4u64] as u64
    let sjm4 : u64 = MB_BLK[4u64 + j - 4u64] as u64
    let sj : u64 = MB_BLK[4u64 + j] as u64
    MB_SC = (sj4 & 0xFu64) | ((sjm4 >> 6u64) << 4u64)
    MB_SM = (sj4 >> 4u64) | ((sj >> 6u64) << 4u64)
    return 0i32
}

/* decode one q4_K block from MB_BLK into out (256 mants, value = mant*2^-24).
 * two-engine: fills the factored accumulators for the distributive check.
 * returns 0 ok / arm code on nonfinite scale */
var MB_E2_SUM : i64 = 0i64            /* factored engine: sum */
var MB_D2P : u64 = 0u64               /* factored engine sumsq pieces */
var MB_D2R : u64 = 0u64
var MB_D2S : u64 = 0u64
var MB_MD : i64 = 0i64
var MB_MDM : i64 = 0i64

fn mb_dec_q4k(into_b: u64) -> u64 {
    let dbits : u64 = (MB_BLK[0] as u64) | ((MB_BLK[1] as u64) << 8u64)
    let mbits : u64 = (MB_BLK[2] as u64) | ((MB_BLK[3] as u64) << 8u64)
    MB_IOERR = 0u8
    let md : i64 = mb_f16_mant(dbits)
    let mdm : i64 = mb_f16_mant(mbits)
    if MB_IOERR != 0u8 { return 1u64 }
    MB_MD = md
    MB_MDM = mdm
    let mut sumsc : i64 = 0i64        /* sum over sub-blocks of sc*Q */
    let mut summ : i64 = 0i64         /* sum over sub-blocks of m*32 */
    MB_D2P = 0u64
    MB_D2R = 0u64
    MB_D2S = 0u64
    let mut t : u64 = 0u64
    while t < 4u64 {
        let mut half : u64 = 0u64
        while half < 2u64 {
            let j : u64 = t * 2u64 + half
            mb_q4k_scale(j)
            let sc : i64 = MB_SC as i64
            let mn : i64 = MB_SM as i64
            let mut q_acc : i64 = 0i64
            let mut l : u64 = 0u64
            while l < 32u64 {
                let raw : u64 = MB_BLK[16u64 + t * 32u64 + l] as u64
                let mut q : u64 = raw & 0xFu64
                if half == 1u64 { q = raw >> 4u64 }
                let x : i64 = sc * (q as i64)
                let vm : i64 = md * x - mdm * mn
                let idx : u64 = t * 64u64 + half * 32u64 + l
                if into_b == 0u64 { MB_VA[idx] = vm }
                if into_b == 1u64 { MB_VB[idx] = vm }
                q_acc = q_acc + (q as i64)
                /* factored sumsq pieces: P += x^2, R += x*m, S += m^2 */
                MB_D2P = MB_D2P + ((x * x) as u64)
                MB_D2R = MB_D2R + ((x * mn) as u64)
                MB_D2S = MB_D2S + ((mn * mn) as u64)
                l = l + 1u64
            }
            sumsc = sumsc + sc * q_acc
            summ = summ + mn * 32i64
            half = half + 1u64
        }
        t = t + 1u64
    }
    MB_E2_SUM = md * sumsc - mdm * summ
    return 0u64
}

/* decode one q6_K block; same contract as q4 */
fn mb_dec_q6k(into_b: u64) -> u64 {
    let dbits : u64 = (MB_BLK[208] as u64) | ((MB_BLK[209] as u64) << 8u64)
    MB_IOERR = 0u8
    let md : i64 = mb_f16_mant(dbits)
    if MB_IOERR != 0u8 { return 1u64 }
    MB_MD = md
    MB_MDM = 0i64
    let mut sumsc : i64 = 0i64
    MB_D2P = 0u64
    MB_D2R = 0u64
    MB_D2S = 0u64
    let mut n2 : u64 = 0u64
    while n2 < 2u64 {
        let vbase : u64 = n2 * 128u64
        let qlb : u64 = n2 * 64u64
        let qhb : u64 = 128u64 + n2 * 32u64
        let scb : u64 = 192u64 + n2 * 8u64
        let mut l : u64 = 0u64
        while l < 32u64 {
            let isx : u64 = l / 16u64
            let ql0 : u64 = MB_BLK[qlb + l] as u64
            let ql32 : u64 = MB_BLK[qlb + l + 32u64] as u64
            let qh : u64 = MB_BLK[qhb + l] as u64
            let q1 : i64 = (((ql0 & 0xFu64) | (((qh >> 0u64) & 3u64) << 4u64)) as i64) - 32i64
            let q2 : i64 = (((ql32 & 0xFu64) | (((qh >> 2u64) & 3u64) << 4u64)) as i64) - 32i64
            let q3 : i64 = (((ql0 >> 4u64) | (((qh >> 4u64) & 3u64) << 4u64)) as i64) - 32i64
            let q4 : i64 = (((ql32 >> 4u64) | (((qh >> 6u64) & 3u64) << 4u64)) as i64) - 32i64
            let mut w : u64 = 0u64
            while w < 4u64 {
                let mut qv : i64 = q1
                if w == 1u64 { qv = q2 }
                if w == 2u64 { qv = q3 }
                if w == 3u64 { qv = q4 }
                let sidx : u64 = scb + isx + w * 2u64
                let scraw : u64 = MB_BLK[sidx] as u64
                let mut sc : i64 = scraw as i64
                if scraw >= 128u64 { sc = (scraw as i64) - 256i64 }
                let x : i64 = sc * qv
                let vm : i64 = md * x
                let idx : u64 = vbase + w * 32u64 + l
                if into_b == 0u64 { MB_VA[idx] = vm }
                if into_b == 1u64 { MB_VB[idx] = vm }
                /* factored: P += x^2 (R,S stay zero: no min term) */
                MB_D2P = MB_D2P + ((x * x) as u64)
                sumsc = sumsc + x
                w = w + 1u64
            }
            l = l + 1u64
        }
        n2 = n2 + 1u64
    }
    MB_E2_SUM = md * sumsc
    return 0u64
}

/* decode one q8_0 block (32 values) */
fn mb_dec_q80(into_b: u64) -> u64 {
    let dbits : u64 = (MB_BLK[0] as u64) | ((MB_BLK[1] as u64) << 8u64)
    MB_IOERR = 0u8
    let md : i64 = mb_f16_mant(dbits)
    if MB_IOERR != 0u8 { return 1u64 }
    MB_MD = md
    MB_MDM = 0i64
    let mut sq : i64 = 0i64
    MB_D2P = 0u64
    MB_D2R = 0u64
    MB_D2S = 0u64
    let mut l : u64 = 0u64
    while l < 32u64 {
        let raw : u64 = MB_BLK[2u64 + l] as u64
        let mut q : i64 = raw as i64
        if raw >= 128u64 { q = (raw as i64) - 256i64 }
        let vm : i64 = md * q
        if into_b == 0u64 { MB_VA[l] = vm }
        if into_b == 1u64 { MB_VB[l] = vm }
        sq = sq + q
        MB_D2P = MB_D2P + ((q * q) as u64)
        l = l + 1u64
    }
    MB_E2_SUM = md * sq
    return 0u64
}

fn mb_type_bytes(ty: u64) -> u64 { return mb_tbb(ty) }
fn mb_type_vals(ty: u64) -> u64 { return mb_tbv(ty) }

fn mb_type_name_rep(ty: u64) -> i32 {
    if ty == 8u64 { mb_rs("q8_0" as u64)   return 0i32 }
    if ty == 12u64 { mb_rs("q4_K" as u64)   return 0i32 }
    if ty == 14u64 { mb_rs("q6_K" as u64)   return 0i32 }
    mb_rs("t" as u64)
    mb_ru(ty)
    return 0i32
}

/* digest block `blk` of candidate `c` (0/1) into VA/VB.  E1 per-value sums
 * vs E2 factored sums must agree EXACTLY (the distributive theorem).
 * On success stores sum/sumsq into the candidate slots.  returns 0 ok */
fn mb_digest(c: u64, blk: u64) -> u64 {
    let mut ty : u64 = MB_C1_TYPE
    let mut off : u64 = MB_C1_OFF
    if c == 1u64 {
        ty = MB_C2_TYPE
        off = MB_C2_OFF
    }
    let bb : u64 = mb_type_bytes(ty)
    let bv : u64 = mb_type_vals(ty)
    let abs : u64 = MB_DBASE1 + off + blk * bb
    if mb_read_block(abs, bb) != 0u64 { return 1u64 }
    let mut rc : u64 = 1u64
    if ty == 12u64 { rc = mb_dec_q4k(c) }
    if ty == 14u64 { rc = mb_dec_q6k(c) }
    if ty == 8u64 { rc = mb_dec_q80(c) }
    if rc != 0u64 { return 1u64 }
    /* E1: per-value walk (association order 1) */
    let mut s1 : i64 = 0i64
    MB_X[0] = 0u64
    MB_X[1] = 0u64
    MB_X[2] = 0u64
    let mut i : u64 = 0u64
    while i < bv {
        let mut vm : i64 = 0i64
        if c == 0u64 { vm = MB_VA[i] }
        if c == 1u64 { vm = MB_VB[i] }
        s1 = s1 + vm
        let mut mag : u64 = vm as u64
        if vm < 0i64 { mag = (0i64 - vm) as u64 }
        mb_mul64(mag, mag)
        MB_Z[0] = MB_MLO
        MB_Z[1] = MB_MHI
        MB_Z[2] = 0u64
        mb_x_add_z()
        i = i + 1u64
    }
    /* E2 sum: the factored form (association order 2) */
    if s1 != MB_E2_SUM { return 1u64 }
    /* E2 sumsq: Md^2*P - 2*Md*Mdm*R + Mdm^2*S in 3-limb arithmetic */
    let mut mdm_mag : u64 = MB_MD as u64
    if MB_MD < 0i64 { mdm_mag = (0i64 - MB_MD) as u64 }
    let mut mmm_mag : u64 = MB_MDM as u64
    if MB_MDM < 0i64 { mmm_mag = (0i64 - MB_MDM) as u64 }
    /* Y := Md^2 * P */
    mb_mul64(mdm_mag, mdm_mag)
    mb_mul128by64(MB_MHI, MB_MLO, MB_D2P)
    MB_Y[0] = MB_Z[0]
    MB_Y[1] = MB_Z[1]
    MB_Y[2] = MB_Z[2]
    /* Y += Mdm^2 * S */
    mb_mul64(mmm_mag, mmm_mag)
    mb_mul128by64(MB_MHI, MB_MLO, MB_D2S)
    let t0 : u64 = MB_Y[0] + MB_Z[0]
    let mut tc : u64 = 0u64
    if t0 < MB_Z[0] { tc = 1u64 }
    let t1a : u64 = MB_Y[1] + MB_Z[1]
    let mut tc1 : u64 = 0u64
    if t1a < MB_Z[1] { tc1 = 1u64 }
    let t1 : u64 = t1a + tc
    if t1 < tc { tc1 = tc1 + 1u64 }
    MB_Y[0] = t0
    MB_Y[1] = t1
    MB_Y[2] = MB_Y[2] + MB_Z[2] + tc1
    /* Y -= 2*Md*Mdm*R when Md*Mdm > 0; += when < 0 (the cross term) */
    mb_mul64(mdm_mag, mmm_mag)
    mb_mul128by64(MB_MHI, MB_MLO, 2u64 * MB_D2R)
    let mut same_sign : u64 = 0u64
    if MB_MD > 0i64 {
        if MB_MDM > 0i64 { same_sign = 1u64 }
    }
    if MB_MD < 0i64 {
        if MB_MDM < 0i64 { same_sign = 1u64 }
    }
    /* swap X into Y-slot temporarily: do the cross op on Y via X machinery */
    let sx0 : u64 = MB_X[0]
    let sx1 : u64 = MB_X[1]
    let sx2 : u64 = MB_X[2]
    MB_X[0] = MB_Y[0]
    MB_X[1] = MB_Y[1]
    MB_X[2] = MB_Y[2]
    if same_sign == 1u64 { mb_x_sub_z() }
    if same_sign == 0u64 {
        if MB_D2R != 0u64 { mb_x_add_z() }
    }
    MB_Y[0] = MB_X[0]
    MB_Y[1] = MB_X[1]
    MB_Y[2] = MB_X[2]
    MB_X[0] = sx0
    MB_X[1] = sx1
    MB_X[2] = sx2
    /* THE DISTRIBUTIVE THEOREM: the two engines must agree exactly */
    if mb_x_cmp_y() != 0i64 { return 1u64 }
    if c == 0u64 {
        MB_SUMA = s1
        MB_SSA0 = MB_X[0]
        MB_SSA1 = MB_X[1]
        MB_NVA = bv
    }
    if c == 1u64 {
        MB_SUMB = s1
        MB_SSB0 = MB_X[0]
        MB_SSB1 = MB_X[1]
        MB_NVB = bv
    }
    if MB_X[2] != 0u64 { return 1u64 }
    return 0u64
}

fn mb_arm363() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_C1_F == 0u8 { return 363u64 }
    if MB_C2_F == 0u8 { return 363u64 }
    /* reopen shard 1 for ranged reads */
    let f : u64 = fopen((&MB_PATH1) as u64, "rb" as u64)
    if f == 0u64 { return 363u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    if mb_digest(0u64, 0u64) != 0u64 {
        fclose(f)
        return 363u64
    }
    if mb_digest(1u64, 0u64) != 0u64 {
        fclose(f)
        return 363u64
    }
    fclose(f)
    mb_rs("the digestion: " as u64)
    mb_type_name_rep(MB_C1_TYPE)
    mb_rs(" " as u64)
    let mut i : u64 = 0u64
    while i < MB_C1_NN {
        mb_rb(MB_C1_NAME[i])
        i = i + 1u64
    }
    mb_rs(" + " as u64)
    mb_type_name_rep(MB_C2_TYPE)
    mb_rs(" " as u64)
    i = 0u64
    while i < MB_C2_NN {
        mb_rb(MB_C2_NAME[i])
        i = i + 1u64
    }
    mb_rs(" block0 sum1=" as u64)
    mb_ri(MB_SUMA)
    mb_rs("*2^-24 sum2=" as u64)
    mb_ri(MB_SUMB)
    mb_rs("*2^-24 distributive=ok" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ==================== arm 364: THE WITNESS ==================== */

var MB_W_BITS : u64 = 0u64
var MB_W_K : u64 = 0u64
var MB_W_G0 : u64 = 0u64
var MB_W_G1 : u64 = 0u64

/* try the standing sumsq (SSA1,SSA0): canonical odd mantissa must exceed
 * 24 bits; compute the round-to-nearest-even fp32 gap.  returns 1 = witness
 * found, 0 = representable (walk on) */
fn mb_witness_try() -> u64 {
    let mut h : u64 = MB_SSA1
    let mut l : u64 = MB_SSA0
    if (h | l) == 0u64 { return 0u64 }
    /* strip twos: the canonical exponent k = 48 - tz */
    let mut tz : u64 = 0u64
    let mut go : u8 = 1u8
    while go == 1u8 {
        go = 0u8
        if (l & 1u64) == 0u64 {
            l = (l >> 1u64) | (h << 63u64)
            h = h >> 1u64
            tz = tz + 1u64
            go = 1u8
        }
    }
    let mut bl : u64 = mb_bitlen(h)
    if bl != 0u64 { bl = bl + 64u64 }
    if bl == 0u64 { bl = mb_bitlen(l) }
    MB_W_BITS = bl
    MB_W_K = 48u64 - tz
    if bl <= 24u64 { return 0u64 }
    /* the low (bl-24) bits are the part fp32 must throw away; the mantissa
     * is ODD, so the lowest bit is set and the gap can never be zero */
    let sh : u64 = bl - 24u64
    let mut lo_h : u64 = 0u64
    let mut lo_l : u64 = 0u64
    if sh >= 64u64 {
        lo_l = l
        lo_h = h & ((1u64 << (sh - 64u64)) - 1u64)
    }
    if sh < 64u64 {
        lo_l = l & ((1u64 << sh) - 1u64)
        lo_h = 0u64
    }
    /* round to nearest even: gap = min(low, 2^sh - low) in exact integers */
    let mut g_h : u64 = lo_h
    let mut g_l : u64 = lo_l
    /* compute 2^sh - low into (c_h, c_l) */
    let mut c_h : u64 = 0u64
    let mut c_l : u64 = 0u64
    if sh < 64u64 {
        c_l = (1u64 << sh) - lo_l
        c_h = 0u64
    }
    if sh >= 64u64 {
        /* 2^sh = (1 << (sh-64)) : 0 ; subtract (lo_h, lo_l) */
        let top : u64 = 1u64 << (sh - 64u64)
        c_l = 0u64 - lo_l
        c_h = top - lo_h
        if lo_l != 0u64 { c_h = c_h - 1u64 }
    }
    /* choose the smaller distance (round-to-nearest; the tie cannot happen
     * with an odd mantissa when sh >= 1 and low has its lsb set unless low
     * is exactly half -- half has lsb 0 for sh >= 2, and sh > 24 here) */
    let mut use_c : u64 = 0u64
    if c_h < g_h { use_c = 1u64 }
    if c_h == g_h {
        if c_l < g_l { use_c = 1u64 }
    }
    if use_c == 1u64 {
        g_h = c_h
        g_l = c_l
    }
    MB_W_G0 = g_l
    MB_W_G1 = g_h
    return 1u64
}

fn mb_arm364() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    /* the standing block's sumsq; walk later blocks only if fp32 could
     * hold the first (bounded, deterministic first-hit) */
    let mut found : u64 = mb_witness_try()
    let mut blk : u64 = 1u64
    let nblocks : u64 = MB_C1_NE / mb_type_vals(MB_C1_TYPE)
    let mut bound : u64 = nblocks
    if bound > 64u64 { bound = 64u64 }
    let mut f : u64 = 0u64
    if found == 0u64 {
        f = fopen((&MB_PATH1) as u64, "rb" as u64)
        if f == 0u64 { return 364u64 }
        MB_F = f
        MB_IOERR = 0u8
        MB_WBASE = 0u64
        MB_WLEN = 0u64
        MB_WPOS = 0u64
    }
    while found == 0u64 {
        if blk >= bound {
            fclose(f)
            return 364u64
        }
        if mb_digest(0u64, blk) != 0u64 {
            fclose(f)
            return 364u64
        }
        found = mb_witness_try()
        blk = blk + 1u64
    }
    if f != 0u64 { fclose(f) }
    mb_rs("the witness: sumsq odd-mantissa bits=" as u64)
    mb_ru(MB_W_BITS)
    mb_rs(" > 24 at 2^-" as u64)
    mb_ru(MB_W_K)
    mb_rs(" gap=" as u64)
    MB_X[0] = MB_W_G0
    MB_X[1] = MB_W_G1
    MB_X[2] = 0u64
    mb_rx3()
    mb_rs(" -- fp32 must round, the organ holds it exact" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ==================== arm 365: THE KRISIS ==================== */

fn mb_arm365() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    /* (a) certified argmax over the digested block by two paths.
     * NOTE: the standing MB_VA may hold a later block (the witness walk);
     * that block is real flesh all the same -- the decision is certified
     * on whatever exact values stand. */
    let n : u64 = MB_NVA
    if n == 0u64 { return 365u64 }
    let mut best : u64 = 0u64
    let mut i : u64 = 1u64
    while i < n {
        if MB_VA[i] > MB_VA[best] { best = i }
        i = i + 1u64
    }
    /* path 2: count how many values strictly exceed each candidate; the
     * argmax is the value nothing exceeds, found without comparing to the
     * path-1 winner's index */
    let mut best2 : u64 = 0xFFFFFFFFFFFFFFFFu64
    let mut ties : u64 = 0u64
    i = 0u64
    while i < n {
        let mut above : u64 = 0u64
        let mut j : u64 = 0u64
        while j < n {
            if MB_VA[j] > MB_VA[i] { above = above + 1u64 }
            j = j + 1u64
        }
        if above == 0u64 {
            ties = ties + 1u64
            if best2 == 0xFFFFFFFFFFFFFFFFu64 { best2 = i }
        }
        i = i + 1u64
    }
    if best2 != best { return 365u64 }
    if ties == 0u64 { return 365u64 }
    /* (b) the RMSNorm-shaped comparison on real sub-rows: a/sqrt(S1) vs
     * b/sqrt(S2) decided as sign(a*sqrt(S2) - b*sqrt(S1)) by two engines.
     * Sub-rows: the first 16 values of each digested block, with a mantissa
     * guard so every intermediate stays in-lane. */
    let mut a : i64 = 0i64
    let mut s1 : u64 = 0u64
    let mut b : i64 = 0i64
    let mut s2 : u64 = 0u64
    let mut guard : u64 = 0u64
    i = 0u64
    while i < 16u64 {
        let va : i64 = MB_VA[i]
        let vb : i64 = MB_VB[i]
        let mut ma : u64 = va as u64
        if va < 0i64 { ma = (0i64 - va) as u64 }
        let mut mbv : u64 = vb as u64
        if vb < 0i64 { mbv = (0i64 - vb) as u64 }
        if ma >= 536870912u64 { guard = 1u64 }
        if mbv >= 536870912u64 { guard = 1u64 }
        a = a + va
        b = b + vb
        s1 = s1 + ((va * va) as u64)
        s2 = s2 + ((vb * vb) as u64)
        i = i + 1u64
    }
    if guard == 1u64 { return 365u64 }
    if s1 == 0u64 { return 365u64 }
    if s2 == 0u64 { return 365u64 }
    /* engine 1: elementary square-compare with sign analysis (192-bit) */
    let mut e1 : i64 = 0i64
    let mut sa : i64 = 0i64
    if a > 0i64 { sa = 1i64 }
    if a < 0i64 { sa = 0i64 - 1i64 }
    let mut sb : i64 = 0i64
    if b > 0i64 { sb = 1i64 }
    if b < 0i64 { sb = 0i64 - 1i64 }
    if sa > sb { e1 = 1i64 }
    if sa < sb { e1 = 0i64 - 1i64 }
    if sa == sb {
        if sa == 0i64 { e1 = 0i64 }
        if sa != 0i64 {
            let mut ma2 : u64 = a as u64
            if a < 0i64 { ma2 = (0i64 - a) as u64 }
            let mut mb2 : u64 = b as u64
            if b < 0i64 { mb2 = (0i64 - b) as u64 }
            /* X := a^2 * S2 ; Y := b^2 * S1 */
            mb_mul64(ma2, ma2)
            mb_mul128by64(MB_MHI, MB_MLO, s2)
            MB_X[0] = MB_Z[0]
            MB_X[1] = MB_Z[1]
            MB_X[2] = MB_Z[2]
            mb_mul64(mb2, mb2)
            mb_mul128by64(MB_MHI, MB_MLO, s1)
            MB_Y[0] = MB_Z[0]
            MB_Y[1] = MB_Z[1]
            MB_Y[2] = MB_Z[2]
            let cmp : i64 = mb_x_cmp_y()
            e1 = cmp
            if sa < 0i64 { e1 = 0i64 - cmp }
        }
    }
    /* engine 2: the standing surd kernel -- sign(0 + a*sqrt(S2) - b*sqrt(S1)) */
    let e2 : i32 = ui_sign_bi_big(0i64, a, s2 as i64, 0i64 - b, s1 as i64)
    if (e2 as i64) != e1 { return 365u64 }
    /* the reflexive control: a*sqrt(S1) - a*sqrt(S1) must vanish by the kernel */
    let ez : i32 = ui_sign_bi_big(0i64, a, s1 as i64, 0i64 - a, s1 as i64)
    if ez != 0i32 { return 365u64 }
    mb_rs("the krisis: argmax=" as u64)
    mb_ru(best)
    mb_rs("/" as u64)
    mb_ru(n)
    mb_rs(" ties=" as u64)
    mb_ru(ties)
    mb_rs(" no-exp (monotone premise named) sign1=" as u64)
    mb_ri(e1)
    mb_rs(" sign2=" as u64)
    mb_ri(e2 as i64)
    mb_rs(" agree=ok" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ============ arms 370/371: THE SYNAPSE + THE STOMACH ============ */

/* signed 192-bit accumulators: which 0 = the running total, 1 = the block
 * partial, 2 = the regroup checker */
var MB_TS : i64 = 0i64
var MB_T0 : u64 = 0u64
var MB_T1 : u64 = 0u64
var MB_T2 : u64 = 0u64
var MB_BS : i64 = 0i64
var MB_B0 : u64 = 0u64
var MB_B1 : u64 = 0u64
var MB_B2 : u64 = 0u64
var MB_GS : i64 = 0i64
var MB_G0 : u64 = 0u64
var MB_G1 : u64 = 0u64
var MB_G2 : u64 = 0u64

fn mb_sacc_clear(which: u64) -> i32 {
    if which == 0u64 { MB_TS = 0i64   MB_T0 = 0u64   MB_T1 = 0u64   MB_T2 = 0u64 }
    if which == 1u64 { MB_BS = 0i64   MB_B0 = 0u64   MB_B1 = 0u64   MB_B2 = 0u64 }
    if which == 2u64 { MB_GS = 0i64   MB_G0 = 0u64   MB_G1 = 0u64   MB_G2 = 0u64 }
    return 0i32
}

fn mb_sacc_add(which: u64, ss: i64, s0: u64, s1: u64, s2: u64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let mut ds : i64 = 0i64
    let mut d0 : u64 = 0u64
    let mut d1 : u64 = 0u64
    let mut d2 : u64 = 0u64
    if which == 0u64 { ds = MB_TS   d0 = MB_T0   d1 = MB_T1   d2 = MB_T2 }
    if which == 1u64 { ds = MB_BS   d0 = MB_B0   d1 = MB_B1   d2 = MB_B2 }
    if which == 2u64 { ds = MB_GS   d0 = MB_G0   d1 = MB_G1   d2 = MB_G2 }
    let mut r_s : i64 = ds
    let mut r0 : u64 = d0
    let mut r1 : u64 = d1
    let mut r2 : u64 = d2
    if ds == 0i64 {
        r_s = ss
        r0 = s0
        r1 = s1
        r2 = s2
    }
    if ds == ss {
        let a0 : u64 = d0 + s0
        let mut c0 : u64 = 0u64
        if a0 < s0 { c0 = 1u64 }
        let a1a : u64 = d1 + s1
        let mut c1 : u64 = 0u64
        if a1a < s1 { c1 = 1u64 }
        let a1 : u64 = a1a + c0
        if a1 < c0 { c1 = c1 + 1u64 }
        r0 = a0
        r1 = a1
        r2 = d2 + s2 + c1
        r_s = ds
    }
    if ds != 0i64 {
        if ds != ss {
            let mut cmp : i64 = 0i64
            if d2 > s2 { cmp = 1i64 }
            if d2 < s2 { cmp = 0i64 - 1i64 }
            if cmp == 0i64 {
                if d1 > s1 { cmp = 1i64 }
                if d1 < s1 { cmp = 0i64 - 1i64 }
            }
            if cmp == 0i64 {
                if d0 > s0 { cmp = 1i64 }
                if d0 < s0 { cmp = 0i64 - 1i64 }
            }
            if cmp == 0i64 {
                r_s = 0i64
                r0 = 0u64
                r1 = 0u64
                r2 = 0u64
            }
            if cmp > 0i64 {
                let mut b : u64 = 0u64
                let x0 : u64 = d0 - s0
                if d0 < s0 { b = 1u64 }
                let mut b1 : u64 = 0u64
                let x1a : u64 = d1 - s1
                if d1 < s1 { b1 = 1u64 }
                let x1 : u64 = x1a - b
                if x1a < b { b1 = b1 + 1u64 }
                r0 = x0
                r1 = x1
                r2 = d2 - s2 - b1
                r_s = ds
            }
            if cmp < 0i64 {
                let mut b2 : u64 = 0u64
                let y0 : u64 = s0 - d0
                if s0 < d0 { b2 = 1u64 }
                let mut b3 : u64 = 0u64
                let y1a : u64 = s1 - d1
                if s1 < d1 { b3 = 1u64 }
                let y1 : u64 = y1a - b2
                if y1a < b2 { b3 = b3 + 1u64 }
                r0 = y0
                r1 = y1
                r2 = s2 - d2 - b3
                r_s = ss
            }
        }
    }
    if which == 0u64 { MB_TS = r_s   MB_T0 = r0   MB_T1 = r1   MB_T2 = r2 }
    if which == 1u64 { MB_BS = r_s   MB_B0 = r0   MB_B1 = r1   MB_B2 = r2 }
    if which == 2u64 { MB_GS = r_s   MB_G0 = r0   MB_G1 = r1   MB_G2 = r2 }
    return 0i32
}

/* unsigned 192-bit norms: u.u and v.v */
var MB_UU0 : u64 = 0u64
var MB_UU1 : u64 = 0u64
var MB_UU2 : u64 = 0u64
var MB_VV0 : u64 = 0u64
var MB_VV1 : u64 = 0u64
var MB_VV2 : u64 = 0u64

fn mb_uu_add(hi: u64, lo: u64) -> i32 {
    let a0 : u64 = MB_UU0 + lo
    let mut c0 : u64 = 0u64
    if a0 < lo { c0 = 1u64 }
    let a1a : u64 = MB_UU1 + hi
    let mut c1 : u64 = 0u64
    if a1a < hi { c1 = 1u64 }
    let a1 : u64 = a1a + c0
    if a1 < c0 { c1 = c1 + 1u64 }
    MB_UU0 = a0
    MB_UU1 = a1
    MB_UU2 = MB_UU2 + c1
    return 0i32
}

fn mb_vv_add(hi: u64, lo: u64) -> i32 {
    let a0 : u64 = MB_VV0 + lo
    let mut c0 : u64 = 0u64
    if a0 < lo { c0 = 1u64 }
    let a1a : u64 = MB_VV1 + hi
    let mut c1 : u64 = 0u64
    if a1a < hi { c1 = 1u64 }
    let a1 : u64 = a1a + c0
    if a1 < c0 { c1 = c1 + 1u64 }
    MB_VV0 = a0
    MB_VV1 = a1
    MB_VV2 = MB_VV2 + c1
    return 0i32
}

/* per-block synapse partials (the regroup engine's evidence) */
var MB_PS : [i64; 64]
var MB_PP0 : [u64; 64]
var MB_PP1 : [u64; 64]
var MB_PP2 : [u64; 64]
var MB_NP : u64 = 0u64

/* 384-bit product for the exact Cauchy-Schwarz: MB_R6 = a * b (3x3 limbs) */
var MB_R6 : [u64; 6]
var MB_R6A : [u64; 6]

fn mb_r6_addat(k: u64, v: u64) -> i32 {
    if v == 0u64 { return 0i32 }
    let s : u64 = MB_R6[k] + v
    let mut carry : u64 = 0u64
    if s < v { carry = 1u64 }
    MB_R6[k] = s
    let mut kk : u64 = k + 1u64
    while carry == 1u64 {
        let s2 : u64 = MB_R6[kk] + 1u64
        carry = 0u64
        if s2 == 0u64 { carry = 1u64 }
        MB_R6[kk] = s2
        kk = kk + 1u64
    }
    return 0i32
}

fn mb_mul192(a0: u64, a1: u64, a2: u64, b0: u64, b1: u64, b2: u64) -> i32 {
    let mut k : u64 = 0u64
    while k < 6u64 {
        MB_R6[k] = 0u64
        k = k + 1u64
    }
    let mut i : u64 = 0u64
    while i < 3u64 {
        let mut ai : u64 = a0
        if i == 1u64 { ai = a1 }
        if i == 2u64 { ai = a2 }
        let mut j : u64 = 0u64
        while j < 3u64 {
            let mut bj : u64 = b0
            if j == 1u64 { bj = b1 }
            if j == 2u64 { bj = b2 }
            mb_mul64(ai, bj)
            mb_r6_addat(i + j, MB_MLO)
            mb_r6_addat(i + j + 1u64, MB_MHI)
            j = j + 1u64
        }
        i = i + 1u64
    }
    return 0i32
}

/* compare MB_R6A vs MB_R6: -1/0/+1 */
fn mb_cmp6() -> i64 {
    let mut k : u64 = 6u64
    while k != 0u64 {
        k = k - 1u64
        if MB_R6A[k] > MB_R6[k] { return 1i64 }
        if MB_R6A[k] < MB_R6[k] { return 0i64 - 1i64 }
    }
    return 0i64
}

/* stream one full row pair: candidate 0 row ru dotted with candidate 1 row
 * rv, bpr blocks per row.  Every block passes the two-engine digest; the
 * dot, both norms and per-block partials accumulate.  returns 0 ok */
fn mb_synapse_stream(ru: u64, rv: u64, bpr: u64) -> u64 {
    mb_sacc_clear(0u64)
    MB_UU0 = 0u64
    MB_UU1 = 0u64
    MB_UU2 = 0u64
    MB_VV0 = 0u64
    MB_VV1 = 0u64
    MB_VV2 = 0u64
    MB_NP = 0u64
    let mut b : u64 = 0u64
    while b < bpr {
        if mb_digest(0u64, ru * bpr + b) != 0u64 { return 1u64 }
        if mb_digest(1u64, rv * bpr + b) != 0u64 { return 1u64 }
        mb_sacc_clear(1u64)
        let mut e : u64 = 0u64
        while e < 256u64 {
            let va : i64 = MB_VA[e]
            let vb : i64 = MB_VB[e]
            let mut ma : u64 = va as u64
            if va < 0i64 { ma = (0i64 - va) as u64 }
            let mut mbv : u64 = vb as u64
            if vb < 0i64 { mbv = (0i64 - vb) as u64 }
            if va != 0i64 {
                if vb != 0i64 {
                    let mut sgn : i64 = 1i64
                    if va < 0i64 {
                        if vb > 0i64 { sgn = 0i64 - 1i64 }
                    }
                    if va > 0i64 {
                        if vb < 0i64 { sgn = 0i64 - 1i64 }
                    }
                    mb_mul64(ma, mbv)
                    mb_sacc_add(1u64, sgn, MB_MLO, MB_MHI, 0u64)
                }
                mb_mul64(ma, ma)
                mb_uu_add(MB_MHI, MB_MLO)
            }
            if va == 0i64 {
                if vb != 0i64 {
                    mb_mul64(mbv, mbv)
                    mb_vv_add(MB_MHI, MB_MLO)
                }
            }
            if va != 0i64 {
                if vb != 0i64 {
                    mb_mul64(mbv, mbv)
                    mb_vv_add(MB_MHI, MB_MLO)
                }
            }
            e = e + 1u64
        }
        MB_PS[b] = MB_BS
        MB_PP0[b] = MB_B0
        MB_PP1[b] = MB_B1
        MB_PP2[b] = MB_B2
        mb_sacc_add(0u64, MB_BS, MB_B0, MB_B1, MB_B2)
        b = b + 1u64
    }
    MB_NP = bpr
    return 0u64
}

/* does row r of candidate c carry any nonzero value?  2 = io/decode red */
fn mb_row_alive(c: u64, r: u64, bpr: u64) -> u64 {
    let mut b : u64 = 0u64
    while b < bpr {
        if mb_digest(c, r * bpr + b) != 0u64 { return 2u64 }
        let mut e : u64 = 0u64
        while e < 256u64 {
            let mut v : i64 = 0i64
            if c == 0u64 { v = MB_VA[e] }
            if c == 1u64 { v = MB_VB[e] }
            if v != 0i64 { return 1u64 }
            e = e + 1u64
        }
        b = b + 1u64
    }
    return 0u64
}

var MB_SYN_RU : u64 = 0u64
var MB_SYN_RV : u64 = 0u64
var MB_SYN_CS : u64 = 0u64            /* 1 = strict, 2 = proportional */
var MB_SYN_S : i64 = 0i64
var MB_SYN_0 : u64 = 0u64
var MB_SYN_1 : u64 = 0u64
var MB_SYN_2 : u64 = 0u64
var MB_SYN_U0 : u64 = 0u64
var MB_SYN_U1 : u64 = 0u64
var MB_SYN_U2 : u64 = 0u64
var MB_SYN_V0 : u64 = 0u64
var MB_SYN_V1 : u64 = 0u64
var MB_SYN_V2 : u64 = 0u64

fn mb_arm370() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_C1_F == 0u8 { return 370u64 }
    if MB_C2_F == 0u8 { return 370u64 }
    /* the synapse law: one shared embedding axis, k-quant lattice both sides */
    if MB_C1_NE0 != MB_C2_NE0 { return 370u64 }
    if mb_tbv(MB_C1_TYPE) != 256u64 { return 370u64 }
    if mb_tbv(MB_C2_TYPE) != 256u64 { return 370u64 }
    let bpr : u64 = MB_C1_NE0 / 256u64
    if bpr == 0u64 { return 370u64 }
    if bpr > 64u64 { return 370u64 }
    let rows_u : u64 = MB_C1_NE / MB_C1_NE0
    let rows_v : u64 = MB_C2_NE / MB_C2_NE0
    let f : u64 = fopen((&MB_PATH1) as u64, "rb" as u64)
    if f == 0u64 { return 370u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    /* deterministic row choice: the first living row of each side */
    let mut ru : u64 = 0u64
    let mut found : u64 = 0u64
    while found == 0u64 {
        if ru >= 8u64 {
            fclose(f)
            return 370u64
        }
        if ru >= rows_u {
            fclose(f)
            return 370u64
        }
        let al : u64 = mb_row_alive(0u64, ru, bpr)
        if al == 2u64 {
            fclose(f)
            return 370u64
        }
        if al == 1u64 { found = 1u64 }
        if found == 0u64 { ru = ru + 1u64 }
    }
    let mut rv : u64 = 0u64
    found = 0u64
    while found == 0u64 {
        if rv >= 8u64 {
            fclose(f)
            return 370u64
        }
        if rv >= rows_v {
            fclose(f)
            return 370u64
        }
        let al2 : u64 = mb_row_alive(1u64, rv, bpr)
        if al2 == 2u64 {
            fclose(f)
            return 370u64
        }
        if al2 == 1u64 { found = 1u64 }
        if found == 0u64 { rv = rv + 1u64 }
    }
    MB_SYN_RU = ru
    MB_SYN_RV = rv
    /* PASS ONE */
    if mb_synapse_stream(ru, rv, bpr) != 0u64 {
        fclose(f)
        return 370u64
    }
    let p1s : i64 = MB_TS
    let p10 : u64 = MB_T0
    let p11 : u64 = MB_T1
    let p12 : u64 = MB_T2
    let u10 : u64 = MB_UU0
    let u11 : u64 = MB_UU1
    let u12 : u64 = MB_UU2
    let v10 : u64 = MB_VV0
    let v11 : u64 = MB_VV1
    let v12 : u64 = MB_VV2
    /* THE REVERSED REGROUP: partials summed backwards must equal the stream */
    mb_sacc_clear(2u64)
    let mut b2 : u64 = MB_NP
    while b2 != 0u64 {
        b2 = b2 - 1u64
        mb_sacc_add(2u64, MB_PS[b2], MB_PP0[b2], MB_PP1[b2], MB_PP2[b2])
    }
    if MB_GS != p1s {
        fclose(f)
        return 370u64
    }
    if MB_G0 != p10 {
        fclose(f)
        return 370u64
    }
    if MB_G1 != p11 {
        fclose(f)
        return 370u64
    }
    if MB_G2 != p12 {
        fclose(f)
        return 370u64
    }
    fclose(f)
    /* PASS TWO: a fresh stream must reproduce every limb */
    let f2 : u64 = fopen((&MB_PATH1) as u64, "rb" as u64)
    if f2 == 0u64 { return 370u64 }
    MB_F = f2
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    if mb_synapse_stream(ru, rv, bpr) != 0u64 {
        fclose(f2)
        return 370u64
    }
    fclose(f2)
    if MB_TS != p1s { return 370u64 }
    if MB_T0 != p10 { return 370u64 }
    if MB_T1 != p11 { return 370u64 }
    if MB_T2 != p12 { return 370u64 }
    if MB_UU0 != u10 { return 370u64 }
    if MB_UU1 != u11 { return 370u64 }
    if MB_UU2 != u12 { return 370u64 }
    if MB_VV0 != v10 { return 370u64 }
    if MB_VV1 != v11 { return 370u64 }
    if MB_VV2 != v12 { return 370u64 }
    /* THE EXACT CAUCHY-SCHWARZ: (u.v)^2 <= (u.u)(v.v) in 384-bit integers */
    if (MB_UU0 | MB_UU1 | MB_UU2) == 0u64 { return 370u64 }
    if (MB_VV0 | MB_VV1 | MB_VV2) == 0u64 { return 370u64 }
    mb_mul192(p10, p11, p12, p10, p11, p12)
    let mut k6 : u64 = 0u64
    while k6 < 6u64 {
        MB_R6A[k6] = MB_R6[k6]
        k6 = k6 + 1u64
    }
    mb_mul192(u10, u11, u12, v10, v11, v12)
    /* R6A = (u.v)^2 must be <= R6 = (u.u)(v.v) */
    let cs : i64 = mb_cmp6()
    if cs > 0i64 { return 370u64 }
    MB_SYN_CS = 1u64
    if cs == 0i64 { MB_SYN_CS = 2u64 }
    MB_SYN_S = p1s
    MB_SYN_0 = p10
    MB_SYN_1 = p11
    MB_SYN_2 = p12
    MB_SYN_U0 = u10
    MB_SYN_U1 = u11
    MB_SYN_U2 = u12
    MB_SYN_V0 = v10
    MB_SYN_V1 = v11
    MB_SYN_V2 = v12
    mb_rs("the synapse: output[" as u64)
    mb_ru(MB_SYN_RU)
    mb_rs("] x token_embd[" as u64)
    mb_ru(MB_SYN_RV)
    mb_rs("] dot=" as u64)
    if MB_SYN_S < 0i64 { mb_rb(45u8) }
    MB_X[0] = MB_SYN_0
    MB_X[1] = MB_SYN_1
    MB_X[2] = MB_SYN_2
    mb_rx3()
    mb_rs("*2^-48 blocks=" as u64)
    mb_ru(bpr)
    mb_rs("+" as u64)
    mb_ru(bpr)
    mb_rs(" regroup=ok stream=identical cauchy-schwarz=" as u64)
    if MB_SYN_CS == 1u64 { mb_rs("strict" as u64) }
    if MB_SYN_CS == 2u64 { mb_rs("proportional" as u64) }
    mb_rb(10u8)
    return 0u64
}

/* ==================== arm 372: THE LOOM ==================== */

const MB_NW : u64 = 4u64              /* the weavers */

/* worker-private state: slice `w` of every array belongs to worker w alone */
var MB_LFILE : [u64; 4]
var MB_LBLK : [u8; 1024]              /* 256 bytes per worker */
var MB_LVA : [i64; 1024]              /* 256 values per worker */
var MB_LVB : [i64; 1024]
var MB_LMH : [u64; 4]                 /* per-worker multiply scratch */
var MB_LML : [u64; 4]
var MB_LDS : [i64; 4]                 /* per-worker signed 192-bit dot */
var MB_LD0 : [u64; 4]
var MB_LD1 : [u64; 4]
var MB_LD2 : [u64; 4]
var MB_LU0 : [u64; 4]                 /* per-worker norms */
var MB_LU1 : [u64; 4]
var MB_LU2 : [u64; 4]
var MB_LV0 : [u64; 4]
var MB_LV1 : [u64; 4]
var MB_LV2 : [u64; 4]
var MB_LRC : [u64; 4]                 /* per-worker verdict */
/* the loom's read-only warp (set by the main thread before launch) */
var MB_L_RU : u64 = 0u64
var MB_L_RV : u64 = 0u64
var MB_L_BPR : u64 = 0u64
var MB_L_CHUNK : u64 = 0u64

/* pure fp16 mantissa: value = result * 2^-24; the sentinel marks nonfinite */
fn mb_f16m(p: u64) -> i64 {
    let e : u64 = (p >> 10u64) & 31u64
    let m : u64 = p & 1023u64
    if e == 31u64 { return 4611686018427387904i64 }
    let mut a : u64 = m
    if e != 0u64 { a = (1024u64 + m) << (e - 1u64) }
    let s : u64 = (p >> 15u64) & 1u64
    let av : i64 = a as i64
    if s == 1u64 { return 0i64 - av }
    return av
}

fn mb_wmul64(w: u64, a: u64, b: u64) -> i32 {
    let a0 : u64 = a & 0xFFFFFFFFu64
    let a1 : u64 = a >> 32u64
    let b0 : u64 = b & 0xFFFFFFFFu64
    let b1 : u64 = b >> 32u64
    let p00 : u64 = a0 * b0
    let p01 : u64 = a0 * b1
    let p10 : u64 = a1 * b0
    let p11 : u64 = a1 * b1
    let mid1 : u64 = p01 + (p00 >> 32u64)
    let mid2 : u64 = p10 + (mid1 & 0xFFFFFFFFu64)
    MB_LMH[w] = p11 + (mid1 >> 32u64) + (mid2 >> 32u64)
    MB_LML[w] = (mid2 << 32u64) | (p00 & 0xFFFFFFFFu64)
    return 0i32
}

/* worker signed 192-bit accumulate of (ss, magnitude (lo, hi, 0)) */
fn mb_wsacc(w: u64, ss: i64, lo: u64, hi: u64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let ds : i64 = MB_LDS[w]
    let d0 : u64 = MB_LD0[w]
    let d1 : u64 = MB_LD1[w]
    let d2 : u64 = MB_LD2[w]
    if ds == 0i64 {
        MB_LDS[w] = ss
        MB_LD0[w] = lo
        MB_LD1[w] = hi
        MB_LD2[w] = 0u64
        return 0i32
    }
    if ds == ss {
        let a0 : u64 = d0 + lo
        let mut c0 : u64 = 0u64
        if a0 < lo { c0 = 1u64 }
        let a1a : u64 = d1 + hi
        let mut c1 : u64 = 0u64
        if a1a < hi { c1 = 1u64 }
        let a1 : u64 = a1a + c0
        if a1 < c0 { c1 = c1 + 1u64 }
        MB_LD0[w] = a0
        MB_LD1[w] = a1
        MB_LD2[w] = d2 + c1
        return 0i32
    }
    /* different signs: compare magnitudes (src has limb2 = 0) */
    let mut cmp : i64 = 0i64
    if d2 != 0u64 { cmp = 1i64 }
    if cmp == 0i64 {
        if d1 > hi { cmp = 1i64 }
        if d1 < hi { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        if d0 > lo { cmp = 1i64 }
        if d0 < lo { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        MB_LDS[w] = 0i64
        MB_LD0[w] = 0u64
        MB_LD1[w] = 0u64
        MB_LD2[w] = 0u64
        return 0i32
    }
    if cmp > 0i64 {
        let mut b : u64 = 0u64
        let x0 : u64 = d0 - lo
        if d0 < lo { b = 1u64 }
        let mut b1 : u64 = 0u64
        let x1a : u64 = d1 - hi
        if d1 < hi { b1 = 1u64 }
        let x1 : u64 = x1a - b
        if x1a < b { b1 = b1 + 1u64 }
        MB_LD0[w] = x0
        MB_LD1[w] = x1
        MB_LD2[w] = d2 - b1
        return 0i32
    }
    let mut b2 : u64 = 0u64
    let y0 : u64 = lo - d0
    if lo < d0 { b2 = 1u64 }
    let y1 : u64 = hi - d1 - b2
    MB_LD0[w] = y0
    MB_LD1[w] = y1
    MB_LD2[w] = 0u64
    MB_LDS[w] = ss
    return 0i32
}

fn mb_wuadd(w: u64, hi: u64, lo: u64) -> i32 {
    let a0 : u64 = MB_LU0[w] + lo
    let mut c0 : u64 = 0u64
    if a0 < lo { c0 = 1u64 }
    let a1a : u64 = MB_LU1[w] + hi
    let mut c1 : u64 = 0u64
    if a1a < hi { c1 = 1u64 }
    let a1 : u64 = a1a + c0
    if a1 < c0 { c1 = c1 + 1u64 }
    MB_LU0[w] = a0
    MB_LU1[w] = a1
    MB_LU2[w] = MB_LU2[w] + c1
    return 0i32
}

fn mb_wvadd(w: u64, hi: u64, lo: u64) -> i32 {
    let a0 : u64 = MB_LV0[w] + lo
    let mut c0 : u64 = 0u64
    if a0 < lo { c0 = 1u64 }
    let a1a : u64 = MB_LV1[w] + hi
    let mut c1 : u64 = 0u64
    if a1a < hi { c1 = 1u64 }
    let a1 : u64 = a1a + c0
    if a1 < c0 { c1 = c1 + 1u64 }
    MB_LV0[w] = a0
    MB_LV1[w] = a1
    MB_LV2[w] = MB_LV2[w] + c1
    return 0i32
}

/* read n bytes at abs into worker w's private block buffer */
fn mb_wread(w: u64, abs: u64, n: u64) -> u64 {
    let f : u64 = MB_LFILE[w]
    if _fseeki64(f, abs as i64, 0i32) != 0i32 { return 1u64 }
    let dst : u64 = ((&MB_LBLK) as u64) + w * 256u64
    let got : u64 = fread(dst, 1u64, n, f)
    if got != n { return 1u64 }
    return 0u64
}

/* worker q4_K sub-block scales, packed (sc << 8) | mn */
fn mb_wq4ks(w: u64, j: u64) -> u64 {
    let base : u64 = w * 256u64
    if j < 4u64 {
        let sc : u64 = (MB_LBLK[base + 4u64 + j] as u64) & 63u64
        let mn : u64 = (MB_LBLK[base + 8u64 + j] as u64) & 63u64
        return (sc << 8u64) | mn
    }
    let sj4 : u64 = MB_LBLK[base + 8u64 + j] as u64
    let sjm4 : u64 = MB_LBLK[base + j] as u64
    let sj : u64 = MB_LBLK[base + 4u64 + j] as u64
    let sc2 : u64 = (sj4 & 0xFu64) | ((sjm4 >> 6u64) << 4u64)
    let mn2 : u64 = (sj4 >> 4u64) | ((sj >> 6u64) << 4u64)
    return (sc2 << 8u64) | mn2
}

/* worker decoders: private buffer in, private values out.  1 = refuse */
fn mb_wdec_q4k(w: u64, into_b: u64) -> u64 {
    let base : u64 = w * 256u64
    let dbits : u64 = (MB_LBLK[base] as u64) | ((MB_LBLK[base + 1u64] as u64) << 8u64)
    let mbits : u64 = (MB_LBLK[base + 2u64] as u64) | ((MB_LBLK[base + 3u64] as u64) << 8u64)
    let md : i64 = mb_f16m(dbits)
    let mdm : i64 = mb_f16m(mbits)
    if md == 4611686018427387904i64 { return 1u64 }
    if mdm == 4611686018427387904i64 { return 1u64 }
    let mut t : u64 = 0u64
    while t < 4u64 {
        let mut half : u64 = 0u64
        while half < 2u64 {
            let pk : u64 = mb_wq4ks(w, t * 2u64 + half)
            let sc : i64 = (pk >> 8u64) as i64
            let mn : i64 = (pk & 0xFFu64) as i64
            let mut l : u64 = 0u64
            while l < 32u64 {
                let raw : u64 = MB_LBLK[base + 16u64 + t * 32u64 + l] as u64
                let mut q : u64 = raw & 0xFu64
                if half == 1u64 { q = raw >> 4u64 }
                let vm : i64 = md * sc * (q as i64) - mdm * mn
                let idx : u64 = base + t * 64u64 + half * 32u64 + l
                if into_b == 0u64 { MB_LVA[idx] = vm }
                if into_b == 1u64 { MB_LVB[idx] = vm }
                l = l + 1u64
            }
            half = half + 1u64
        }
        t = t + 1u64
    }
    return 0u64
}

fn mb_wdec_q6k(w: u64, into_b: u64) -> u64 {
    let base : u64 = w * 256u64
    let dbits : u64 = (MB_LBLK[base + 208u64] as u64) | ((MB_LBLK[base + 209u64] as u64) << 8u64)
    let md : i64 = mb_f16m(dbits)
    if md == 4611686018427387904i64 { return 1u64 }
    let mut n2 : u64 = 0u64
    while n2 < 2u64 {
        let vbase : u64 = base + n2 * 128u64
        let qlb : u64 = base + n2 * 64u64
        let qhb : u64 = base + 128u64 + n2 * 32u64
        let scb : u64 = base + 192u64 + n2 * 8u64
        let mut l : u64 = 0u64
        while l < 32u64 {
            let isx : u64 = l / 16u64
            let ql0 : u64 = MB_LBLK[qlb + l] as u64
            let ql32 : u64 = MB_LBLK[qlb + l + 32u64] as u64
            let qh : u64 = MB_LBLK[qhb + l] as u64
            let q1 : i64 = (((ql0 & 0xFu64) | (((qh >> 0u64) & 3u64) << 4u64)) as i64) - 32i64
            let q2 : i64 = (((ql32 & 0xFu64) | (((qh >> 2u64) & 3u64) << 4u64)) as i64) - 32i64
            let q3 : i64 = (((ql0 >> 4u64) | (((qh >> 4u64) & 3u64) << 4u64)) as i64) - 32i64
            let q4 : i64 = (((ql32 >> 4u64) | (((qh >> 6u64) & 3u64) << 4u64)) as i64) - 32i64
            let mut wv : u64 = 0u64
            while wv < 4u64 {
                let mut qv : i64 = q1
                if wv == 1u64 { qv = q2 }
                if wv == 2u64 { qv = q3 }
                if wv == 3u64 { qv = q4 }
                let scraw : u64 = MB_LBLK[scb + isx + wv * 2u64] as u64
                let mut sc : i64 = scraw as i64
                if scraw >= 128u64 { sc = (scraw as i64) - 256i64 }
                let vm : i64 = md * sc * qv
                let idx : u64 = vbase + wv * 32u64 + l
                if into_b == 0u64 { MB_LVA[idx] = vm }
                if into_b == 1u64 { MB_LVB[idx] = vm }
                wv = wv + 1u64
            }
            l = l + 1u64
        }
        n2 = n2 + 1u64
    }
    return 0u64
}

fn mb_wdec_q80(w: u64, into_b: u64) -> u64 {
    let base : u64 = w * 256u64
    let dbits : u64 = (MB_LBLK[base] as u64) | ((MB_LBLK[base + 1u64] as u64) << 8u64)
    let md : i64 = mb_f16m(dbits)
    if md == 4611686018427387904i64 { return 1u64 }
    let mut l : u64 = 0u64
    while l < 32u64 {
        let raw : u64 = MB_LBLK[base + 2u64 + l] as u64
        let mut q : i64 = raw as i64
        if raw >= 128u64 { q = (raw as i64) - 256i64 }
        let vm : i64 = md * q
        let idx : u64 = base + l
        if into_b == 0u64 { MB_LVA[idx] = vm }
        if into_b == 1u64 { MB_LVB[idx] = vm }
        l = l + 1u64
    }
    return 0u64
}

fn mb_wdec(w: u64, ty: u64, into_b: u64) -> u64 {
    if ty == 12u64 { return mb_wdec_q4k(w, into_b) }
    if ty == 14u64 { return mb_wdec_q6k(w, into_b) }
    if ty == 8u64 { return mb_wdec_q80(w, into_b) }
    return 1u64
}

/* the weaver: OS thread entry (win64: arg arrives in rcx).  Processes the
 * static block range [w*chunk, min((w+1)*chunk, bpr)) with PRIVATE state
 * only -- the timing of the weavers is entirely free. */
fn mb_loom_worker(arg: u64) -> u32 {
    let w : u64 = arg
    MB_LDS[w] = 0i64
    MB_LD0[w] = 0u64
    MB_LD1[w] = 0u64
    MB_LD2[w] = 0u64
    MB_LU0[w] = 0u64
    MB_LU1[w] = 0u64
    MB_LU2[w] = 0u64
    MB_LV0[w] = 0u64
    MB_LV1[w] = 0u64
    MB_LV2[w] = 0u64
    let bbu : u64 = mb_tbb(MB_C1_TYPE)
    let bbv : u64 = mb_tbb(MB_C2_TYPE)
    let start : u64 = w * MB_L_CHUNK
    let mut endb : u64 = start + MB_L_CHUNK
    if endb > MB_L_BPR { endb = MB_L_BPR }
    let mut b : u64 = start
    while b < endb {
        let ub : u64 = MB_DBASE1 + MB_C1_OFF + (MB_L_RU * MB_L_BPR + b) * bbu
        if mb_wread(w, ub, bbu) != 0u64 {
            MB_LRC[w] = 372u64
            return 0u32
        }
        if mb_wdec(w, MB_C1_TYPE, 0u64) != 0u64 {
            MB_LRC[w] = 372u64
            return 0u32
        }
        let vb2 : u64 = MB_DBASE1 + MB_C2_OFF + (MB_L_RV * MB_L_BPR + b) * bbv
        if mb_wread(w, vb2, bbv) != 0u64 {
            MB_LRC[w] = 372u64
            return 0u32
        }
        if mb_wdec(w, MB_C2_TYPE, 1u64) != 0u64 {
            MB_LRC[w] = 372u64
            return 0u32
        }
        let base : u64 = w * 256u64
        let mut e : u64 = 0u64
        while e < 256u64 {
            let va : i64 = MB_LVA[base + e]
            let vbv : i64 = MB_LVB[base + e]
            let mut ma : u64 = va as u64
            if va < 0i64 { ma = (0i64 - va) as u64 }
            let mut mbv : u64 = vbv as u64
            if vbv < 0i64 { mbv = (0i64 - vbv) as u64 }
            if va != 0i64 {
                if vbv != 0i64 {
                    let mut sgn : i64 = 1i64
                    if va < 0i64 {
                        if vbv > 0i64 { sgn = 0i64 - 1i64 }
                    }
                    if va > 0i64 {
                        if vbv < 0i64 { sgn = 0i64 - 1i64 }
                    }
                    mb_wmul64(w, ma, mbv)
                    mb_wsacc(w, sgn, MB_LML[w], MB_LMH[w])
                }
                mb_wmul64(w, ma, ma)
                mb_wuadd(w, MB_LMH[w], MB_LML[w])
            }
            if vbv != 0i64 {
                mb_wmul64(w, mbv, mbv)
                mb_wvadd(w, MB_LMH[w], MB_LML[w])
            }
            e = e + 1u64
        }
        b = b + 1u64
    }
    MB_LRC[w] = 0u64
    return 0u32
}

/* one full launch: open private files, weave, join, verdict.  0 = ok.
 * `entry` is the thread routine (a bare fn-as-u64 -- the verified lea). */
var MB_LH : [u64; 4]
fn mb_loom_launch(entry: u64) -> u64 {
    let mut w : u64 = 0u64
    while w < MB_NW {
        MB_LFILE[w] = fopen((&MB_PATH1) as u64, "rb" as u64)
        if MB_LFILE[w] == 0u64 {
            let mut c : u64 = 0u64
            while c < w {
                fclose(MB_LFILE[c])
                c = c + 1u64
            }
            return 1u64
        }
        w = w + 1u64
    }
    w = 0u64
    while w < MB_NW {
        MB_LRC[w] = 999u64
        MB_LH[w] = CreateThread(0u64, 0u64, entry, w, 0u64, 0u64)
        if MB_LH[w] == 0u64 {
            /* join what launched, close everything, refuse */
            let mut j : u64 = 0u64
            while j < w {
                WaitForSingleObject(MB_LH[j], 0xFFFFFFFFu32)
                CloseHandle(MB_LH[j])
                j = j + 1u64
            }
            let mut c2 : u64 = 0u64
            while c2 < MB_NW {
                fclose(MB_LFILE[c2])
                c2 = c2 + 1u64
            }
            return 1u64
        }
        w = w + 1u64
    }
    w = 0u64
    while w < MB_NW {
        WaitForSingleObject(MB_LH[w], 0xFFFFFFFFu32)
        CloseHandle(MB_LH[w])
        w = w + 1u64
    }
    w = 0u64
    while w < MB_NW {
        fclose(MB_LFILE[w])
        w = w + 1u64
    }
    w = 0u64
    while w < MB_NW {
        if MB_LRC[w] != 0u64 { return 1u64 }
        w = w + 1u64
    }
    return 0u64
}

fn mb_arm372() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_SYN_CS == 0u64 { return 372u64 }
    let bpr : u64 = MB_C1_NE0 / 256u64
    MB_L_RU = MB_SYN_RU
    MB_L_RV = MB_SYN_RV
    MB_L_BPR = bpr
    MB_L_CHUNK = (bpr + MB_NW - 1u64) / MB_NW
    /* FIRST LAUNCH */
    if mb_loom_launch(mb_loom_worker as u64) != 0u64 { return 372u64 }
    /* the canonical fold, w = 0..NW-1 */
    mb_sacc_clear(0u64)
    let mut w : u64 = 0u64
    while w < MB_NW {
        mb_sacc_add(0u64, MB_LDS[w], MB_LD0[w], MB_LD1[w], MB_LD2[w])
        w = w + 1u64
    }
    let f1s : i64 = MB_TS
    let f10 : u64 = MB_T0
    let f11 : u64 = MB_T1
    let f12 : u64 = MB_T2
    /* the REVERSED fold: associativity witnessed at the fold itself */
    mb_sacc_clear(0u64)
    w = MB_NW
    while w != 0u64 {
        w = w - 1u64
        mb_sacc_add(0u64, MB_LDS[w], MB_LD0[w], MB_LD1[w], MB_LD2[w])
    }
    if MB_TS != f1s { return 372u64 }
    if MB_T0 != f10 { return 372u64 }
    if MB_T1 != f11 { return 372u64 }
    if MB_T2 != f12 { return 372u64 }
    /* THE THEOREM: the parallel weave equals the sequential stream */
    if f1s != MB_SYN_S { return 372u64 }
    if f10 != MB_SYN_0 { return 372u64 }
    if f11 != MB_SYN_1 { return 372u64 }
    if f12 != MB_SYN_2 { return 372u64 }
    /* the norms agree too (positive folds) */
    mb_sacc_clear(0u64)
    w = 0u64
    while w < MB_NW {
        let mut us : i64 = 0i64
        if (MB_LU0[w] | MB_LU1[w] | MB_LU2[w]) != 0u64 { us = 1i64 }
        mb_sacc_add(0u64, us, MB_LU0[w], MB_LU1[w], MB_LU2[w])
        w = w + 1u64
    }
    if MB_T0 != MB_SYN_U0 { return 372u64 }
    if MB_T1 != MB_SYN_U1 { return 372u64 }
    if MB_T2 != MB_SYN_U2 { return 372u64 }
    mb_sacc_clear(0u64)
    w = 0u64
    while w < MB_NW {
        let mut vs : i64 = 0i64
        if (MB_LV0[w] | MB_LV1[w] | MB_LV2[w]) != 0u64 { vs = 1i64 }
        mb_sacc_add(0u64, vs, MB_LV0[w], MB_LV1[w], MB_LV2[w])
        w = w + 1u64
    }
    if MB_T0 != MB_SYN_V0 { return 372u64 }
    if MB_T1 != MB_SYN_V1 { return 372u64 }
    if MB_T2 != MB_SYN_V2 { return 372u64 }
    /* SECOND LAUNCH: a fresh weave under fresh timing must land identically */
    if mb_loom_launch(mb_loom_worker as u64) != 0u64 { return 372u64 }
    mb_sacc_clear(0u64)
    w = 0u64
    while w < MB_NW {
        mb_sacc_add(0u64, MB_LDS[w], MB_LD0[w], MB_LD1[w], MB_LD2[w])
        w = w + 1u64
    }
    if MB_TS != f1s { return 372u64 }
    if MB_T0 != f10 { return 372u64 }
    if MB_T1 != f11 { return 372u64 }
    if MB_T2 != f12 { return 372u64 }
    mb_rs("the loom: workers=" as u64)
    mb_ru(MB_NW)
    mb_rs(" chunk=" as u64)
    mb_ru(MB_L_CHUNK)
    mb_rs(" partition=static timing=free result=sequential-identical fold=order-invariant relaunch=identical" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ============ arm 373: THE ROW-FLEET (matvec across the vocabulary) ============ */

/* the shared activation x: the digested embedding row, decoded ONCE through
 * the two-engine path, then READ-ONLY for every weaver (read-only sharing
 * is determinism-safe) */
var MB_XV : [i64; 7168]
var MB_XBMAX : [u64; 32]
var MB_L_V : u64 = 0u64
var MB_L_CHR : u64 = 0u64
var MB_SSTRIDE : u64 = 0u64

/* per-worker fleet ledgers */
var MB_FBI : [u64; 4]                 /* best row index (sentinel = empty) */
var MB_FBS : [i64; 4]
var MB_FB0 : [u64; 4]
var MB_FB1 : [u64; 4]
var MB_FB2 : [u64; 4]
var MB_FTIE : [u64; 4]
var MB_FPOS : [u64; 4]
var MB_FNEG : [u64; 4]
var MB_FZR : [u64; 4]
var MB_FSS : [i64; 4]                 /* per-worker signed sum of all dots */
var MB_FS0 : [u64; 4]
var MB_FS1 : [u64; 4]
var MB_FS2 : [u64; 4]

/* the eight witness rows: workers deposit, the main thread re-derives */
var MB_SMS : [i64; 8]
var MB_SM0 : [u64; 8]
var MB_SM1 : [u64; 8]
var MB_SM2 : [u64; 8]
var MB_SMF : [u8; 8]

/* the fold verdict */
var MB_GBI : u64 = 0u64
var MB_GBS : i64 = 0i64
var MB_GB0 : u64 = 0u64
var MB_GB1 : u64 = 0u64
var MB_GB2 : u64 = 0u64
var MB_GTS : u64 = 0u64

fn mb_scmp192(sa: i64, a0: u64, a1: u64, a2: u64, sb: i64, b0: u64, b1: u64, b2: u64) -> i64 {
    if sa > sb { return 1i64 }
    if sa < sb { return 0i64 - 1i64 }
    if sa == 0i64 { return 0i64 }
    let mut cmp : i64 = 0i64
    if a2 > b2 { cmp = 1i64 }
    if a2 < b2 { cmp = 0i64 - 1i64 }
    if cmp == 0i64 {
        if a1 > b1 { cmp = 1i64 }
        if a1 < b1 { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        if a0 > b0 { cmp = 1i64 }
        if a0 < b0 { cmp = 0i64 - 1i64 }
    }
    if sa < 0i64 { return 0i64 - cmp }
    return cmp
}

/* per-worker signed 3-limb fold accumulator (the sum-of-dots ledger) */
fn mb_wfold(w: u64, ss: i64, s0: u64, s1: u64, s2: u64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let ds : i64 = MB_FSS[w]
    let d0 : u64 = MB_FS0[w]
    let d1 : u64 = MB_FS1[w]
    let d2 : u64 = MB_FS2[w]
    if ds == 0i64 {
        MB_FSS[w] = ss
        MB_FS0[w] = s0
        MB_FS1[w] = s1
        MB_FS2[w] = s2
        return 0i32
    }
    if ds == ss {
        let a0 : u64 = d0 + s0
        let mut c0 : u64 = 0u64
        if a0 < s0 { c0 = 1u64 }
        let a1a : u64 = d1 + s1
        let mut c1 : u64 = 0u64
        if a1a < s1 { c1 = 1u64 }
        let a1 : u64 = a1a + c0
        if a1 < c0 { c1 = c1 + 1u64 }
        MB_FS0[w] = a0
        MB_FS1[w] = a1
        MB_FS2[w] = d2 + s2 + c1
        return 0i32
    }
    let mut cmp : i64 = 0i64
    if d2 > s2 { cmp = 1i64 }
    if d2 < s2 { cmp = 0i64 - 1i64 }
    if cmp == 0i64 {
        if d1 > s1 { cmp = 1i64 }
        if d1 < s1 { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        if d0 > s0 { cmp = 1i64 }
        if d0 < s0 { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        MB_FSS[w] = 0i64
        MB_FS0[w] = 0u64
        MB_FS1[w] = 0u64
        MB_FS2[w] = 0u64
        return 0i32
    }
    if cmp > 0i64 {
        let mut b : u64 = 0u64
        let x0 : u64 = d0 - s0
        if d0 < s0 { b = 1u64 }
        let mut b1 : u64 = 0u64
        let x1a : u64 = d1 - s1
        if d1 < s1 { b1 = 1u64 }
        let x1 : u64 = x1a - b
        if x1a < b { b1 = b1 + 1u64 }
        MB_FS0[w] = x0
        MB_FS1[w] = x1
        MB_FS2[w] = d2 - s2 - b1
        return 0i32
    }
    let mut b2 : u64 = 0u64
    let y0 : u64 = s0 - d0
    if s0 < d0 { b2 = 1u64 }
    let mut b3 : u64 = 0u64
    let y1a : u64 = s1 - d1
    if s1 < d1 { b3 = 1u64 }
    let y1 : u64 = y1a - b2
    if y1a < b2 { b3 = b3 + 1u64 }
    MB_FS0[w] = y0
    MB_FS1[w] = y1
    MB_FS2[w] = s2 - d2 - b3
    MB_FSS[w] = ss
    return 0i32
}

/* one row's exact dot against MB_XV, into worker w's LDS slot.
 * THE FAST PATH: when every mantissa in the block and in x's block sits
 * below 2^27, each product is below 2^54 and 256 of them stay below 2^62 --
 * plain i64/u64 block accumulation is EXACT (the guard is checked, never
 * assumed).  Guard-tripped blocks take the per-element 128-bit path. */
fn mb_fleet_row_dot(w: u64, t: u64) -> u64 {
    MB_LDS[w] = 0i64
    MB_LD0[w] = 0u64
    MB_LD1[w] = 0u64
    MB_LD2[w] = 0u64
    let bbu : u64 = mb_tbb(MB_C1_TYPE)
    let bpr : u64 = MB_L_BPR
    let base : u64 = w * 256u64
    let mut b : u64 = 0u64
    while b < bpr {
        let abs : u64 = MB_DBASE1 + MB_C1_OFF + (t * bpr + b) * bbu
        if mb_wread(w, abs, bbu) != 0u64 { return 1u64 }
        if mb_wdec(w, MB_C1_TYPE, 0u64) != 0u64 { return 1u64 }
        let boff : u64 = b * 256u64
        let mut vmax : u64 = 0u64
        let mut e : u64 = 0u64
        while e < 256u64 {
            let v : i64 = MB_LVA[base + e]
            let mut a : u64 = v as u64
            if v < 0i64 { a = (0i64 - v) as u64 }
            if a > vmax { vmax = a }
            e = e + 1u64
        }
        let mut fast : u64 = 0u64
        if vmax < 134217728u64 {
            if MB_XBMAX[b] < 134217728u64 { fast = 1u64 }
        }
        if fast == 1u64 {
            let mut pos : u64 = 0u64
            let mut neg : u64 = 0u64
            e = 0u64
            while e < 256u64 {
                let p : i64 = MB_LVA[base + e] * MB_XV[boff + e]
                if p > 0i64 { pos = pos + (p as u64) }
                if p < 0i64 { neg = neg + ((0i64 - p) as u64) }
                e = e + 1u64
            }
            if pos > neg { mb_wsacc(w, 1i64, pos - neg, 0u64) }
            if neg > pos { mb_wsacc(w, 0i64 - 1i64, neg - pos, 0u64) }
        }
        if fast == 0u64 {
            e = 0u64
            while e < 256u64 {
                let va : i64 = MB_LVA[base + e]
                let xv : i64 = MB_XV[boff + e]
                if va != 0i64 {
                    if xv != 0i64 {
                        let mut ma : u64 = va as u64
                        if va < 0i64 { ma = (0i64 - va) as u64 }
                        let mut mx : u64 = xv as u64
                        if xv < 0i64 { mx = (0i64 - xv) as u64 }
                        let mut sgn : i64 = 1i64
                        if va < 0i64 {
                            if xv > 0i64 { sgn = 0i64 - 1i64 }
                        }
                        if va > 0i64 {
                            if xv < 0i64 { sgn = 0i64 - 1i64 }
                        }
                        mb_wmul64(w, ma, mx)
                        mb_wsacc(w, sgn, MB_LML[w], MB_LMH[w])
                    }
                }
                e = e + 1u64
            }
        }
        b = b + 1u64
    }
    return 0u64
}

/* the fleet weaver: a static slice of the vocabulary, rows never split */
fn mb_fleet_worker(arg: u64) -> u32 {
    let w : u64 = arg
    MB_FBI[w] = 0xFFFFFFFFFFFFFFFFu64
    MB_FTIE[w] = 0u64
    MB_FPOS[w] = 0u64
    MB_FNEG[w] = 0u64
    MB_FZR[w] = 0u64
    MB_FSS[w] = 0i64
    MB_FS0[w] = 0u64
    MB_FS1[w] = 0u64
    MB_FS2[w] = 0u64
    let start : u64 = w * MB_L_CHR
    let mut endr : u64 = start + MB_L_CHR
    if endr > MB_L_V { endr = MB_L_V }
    let mut t : u64 = start
    while t < endr {
        if mb_fleet_row_dot(w, t) != 0u64 {
            MB_LRC[w] = 373u64
            return 0u32
        }
        let rs : i64 = MB_LDS[w]
        let r0 : u64 = MB_LD0[w]
        let r1 : u64 = MB_LD1[w]
        let r2 : u64 = MB_LD2[w]
        if rs > 0i64 { MB_FPOS[w] = MB_FPOS[w] + 1u64 }
        if rs < 0i64 { MB_FNEG[w] = MB_FNEG[w] + 1u64 }
        if rs == 0i64 { MB_FZR[w] = MB_FZR[w] + 1u64 }
        mb_wfold(w, rs, r0, r1, r2)
        if t % MB_SSTRIDE == 0u64 {
            let k : u64 = t / MB_SSTRIDE
            if k < 8u64 {
                MB_SMS[k] = rs
                MB_SM0[k] = r0
                MB_SM1[k] = r1
                MB_SM2[k] = r2
                MB_SMF[k] = 1u8
            }
        }
        if MB_FBI[w] == 0xFFFFFFFFFFFFFFFFu64 {
            MB_FBI[w] = t
            MB_FBS[w] = rs
            MB_FB0[w] = r0
            MB_FB1[w] = r1
            MB_FB2[w] = r2
            MB_FTIE[w] = 1u64
        }
        if MB_FBI[w] != t {
            let c : i64 = mb_scmp192(rs, r0, r1, r2, MB_FBS[w], MB_FB0[w], MB_FB1[w], MB_FB2[w])
            if c > 0i64 {
                MB_FBI[w] = t
                MB_FBS[w] = rs
                MB_FB0[w] = r0
                MB_FB1[w] = r1
                MB_FB2[w] = r2
                MB_FTIE[w] = 1u64
            }
            if c == 0i64 { MB_FTIE[w] = MB_FTIE[w] + 1u64 }
        }
        t = t + 1u64
    }
    MB_LRC[w] = 0u64
    return 0u32
}

/* fold the worker bests; dir 0 = canonical (w ascending), 1 = reversed.
 * The one law both directions must land on: highest value wins; on equal
 * values the LOWEST row index is the name; attained = ties summed over
 * every worker standing at the winning value. */
fn mb_fleet_fold(dir: u64) -> i32 {
    MB_GBI = 0xFFFFFFFFFFFFFFFFu64
    MB_GBS = 0i64
    MB_GB0 = 0u64
    MB_GB1 = 0u64
    MB_GB2 = 0u64
    MB_GTS = 0u64
    let mut k : u64 = 0u64
    while k < MB_NW {
        let mut w : u64 = k
        if dir == 1u64 { w = MB_NW - 1u64 - k }
        if MB_FBI[w] != 0xFFFFFFFFFFFFFFFFu64 {
            if MB_GBI == 0xFFFFFFFFFFFFFFFFu64 {
                MB_GBI = MB_FBI[w]
                MB_GBS = MB_FBS[w]
                MB_GB0 = MB_FB0[w]
                MB_GB1 = MB_FB1[w]
                MB_GB2 = MB_FB2[w]
                MB_GTS = MB_FTIE[w]
            }
            if MB_GBI != MB_FBI[w] {
                let c : i64 = mb_scmp192(MB_FBS[w], MB_FB0[w], MB_FB1[w], MB_FB2[w], MB_GBS, MB_GB0, MB_GB1, MB_GB2)
                if c > 0i64 {
                    MB_GBI = MB_FBI[w]
                    MB_GBS = MB_FBS[w]
                    MB_GB0 = MB_FB0[w]
                    MB_GB1 = MB_FB1[w]
                    MB_GB2 = MB_FB2[w]
                    MB_GTS = MB_FTIE[w]
                }
                if c == 0i64 {
                    MB_GTS = MB_GTS + MB_FTIE[w]
                    if MB_FBI[w] < MB_GBI { MB_GBI = MB_FBI[w] }
                }
            }
        }
        k = k + 1u64
    }
    return 0i32
}

/* decode the winner row and take its exact norm (into MB_LU slot 0) */
fn mb_fleet_row_norm(w: u64, t: u64) -> u64 {
    MB_LU0[w] = 0u64
    MB_LU1[w] = 0u64
    MB_LU2[w] = 0u64
    let bbu : u64 = mb_tbb(MB_C1_TYPE)
    let base : u64 = w * 256u64
    let mut b : u64 = 0u64
    while b < MB_L_BPR {
        let abs : u64 = MB_DBASE1 + MB_C1_OFF + (t * MB_L_BPR + b) * bbu
        if mb_wread(w, abs, bbu) != 0u64 { return 1u64 }
        if mb_wdec(w, MB_C1_TYPE, 0u64) != 0u64 { return 1u64 }
        let mut e : u64 = 0u64
        while e < 256u64 {
            let v : i64 = MB_LVA[base + e]
            if v != 0i64 {
                let mut a : u64 = v as u64
                if v < 0i64 { a = (0i64 - v) as u64 }
                mb_wmul64(w, a, a)
                mb_wuadd(w, MB_LMH[w], MB_LML[w])
            }
            e = e + 1u64
        }
        b = b + 1u64
    }
    return 0u64
}

/* build the shared activation from the digested embedding row */
fn mb_fleet_load_x() -> u64 {
    let f : u64 = fopen((&MB_PATH1) as u64, "rb" as u64)
    if f == 0u64 { return 1u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    let mut b : u64 = 0u64
    while b < MB_L_BPR {
        if mb_digest(1u64, MB_SYN_RV * MB_L_BPR + b) != 0u64 {
            fclose(f)
            return 1u64
        }
        let mut mx : u64 = 0u64
        let mut e : u64 = 0u64
        while e < 256u64 {
            let v : i64 = MB_VB[e]
            MB_XV[b * 256u64 + e] = v
            let mut a : u64 = v as u64
            if v < 0i64 { a = (0i64 - v) as u64 }
            if a > mx { mx = a }
            e = e + 1u64
        }
        MB_XBMAX[b] = mx
        b = b + 1u64
    }
    fclose(f)
    return 0u64
}

fn mb_arm373() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_SYN_CS == 0u64 { return 373u64 }
    let v_all : u64 = MB_C1_NE / MB_C1_NE0
    if v_all < 16u64 { return 373u64 }
    MB_L_BPR = MB_C1_NE0 / 256u64
    MB_L_V = v_all
    MB_L_CHR = (v_all + MB_NW - 1u64) / MB_NW
    MB_SSTRIDE = v_all / 8u64
    if MB_SSTRIDE == 0u64 { return 373u64 }
    let mut k : u64 = 0u64
    while k < 8u64 {
        MB_SMF[k] = 0u8
        k = k + 1u64
    }
    if mb_fleet_load_x() != 0u64 { return 373u64 }
    /* THE FLEET SAILS */
    if mb_loom_launch(mb_fleet_worker as u64) != 0u64 { return 373u64 }
    /* the histogram must partition the vocabulary exactly */
    let mut hp : u64 = 0u64
    let mut hn : u64 = 0u64
    let mut hz : u64 = 0u64
    let mut w : u64 = 0u64
    while w < MB_NW {
        hp = hp + MB_FPOS[w]
        hn = hn + MB_FNEG[w]
        hz = hz + MB_FZR[w]
        w = w + 1u64
    }
    if hp + hn + hz != v_all { return 373u64 }
    /* canonical fold, then the reversed fold must land identically */
    mb_fleet_fold(0u64)
    let g_i : u64 = MB_GBI
    let g_s : i64 = MB_GBS
    let g_0 : u64 = MB_GB0
    let g_1 : u64 = MB_GB1
    let g_2 : u64 = MB_GB2
    let g_t : u64 = MB_GTS
    mb_fleet_fold(1u64)
    if MB_GBI != g_i { return 373u64 }
    if MB_GBS != g_s { return 373u64 }
    if MB_GB0 != g_0 { return 373u64 }
    if MB_GB1 != g_1 { return 373u64 }
    if MB_GB2 != g_2 { return 373u64 }
    if MB_GTS != g_t { return 373u64 }
    if g_i == 0xFFFFFFFFFFFFFFFFu64 { return 373u64 }
    /* the sum-of-dots fold: canonical vs reversed (order-invariance) */
    mb_sacc_clear(0u64)
    w = 0u64
    while w < MB_NW {
        mb_sacc_add(0u64, MB_FSS[w], MB_FS0[w], MB_FS1[w], MB_FS2[w])
        w = w + 1u64
    }
    let ts_s : i64 = MB_TS
    let ts_0 : u64 = MB_T0
    let ts_1 : u64 = MB_T1
    let ts_2 : u64 = MB_T2
    mb_sacc_clear(0u64)
    w = MB_NW
    while w != 0u64 {
        w = w - 1u64
        mb_sacc_add(0u64, MB_FSS[w], MB_FS0[w], MB_FS1[w], MB_FS2[w])
    }
    if MB_TS != ts_s { return 373u64 }
    if MB_T0 != ts_0 { return 373u64 }
    if MB_T1 != ts_1 { return 373u64 }
    if MB_T2 != ts_2 { return 373u64 }
    /* the main thread reopens the flesh and re-derives: the anchor row
     * (must equal the twice-proven synapse) and all eight witness rows */
    MB_LFILE[0] = fopen((&MB_PATH1) as u64, "rb" as u64)
    if MB_LFILE[0] == 0u64 { return 373u64 }
    if mb_fleet_row_dot(0u64, MB_SYN_RU) != 0u64 {
        fclose(MB_LFILE[0])
        return 373u64
    }
    let mut anchor_ok : u64 = 1u64
    if MB_LDS[0] != MB_SYN_S { anchor_ok = 0u64 }
    if MB_LD0[0] != MB_SYN_0 { anchor_ok = 0u64 }
    if MB_LD1[0] != MB_SYN_1 { anchor_ok = 0u64 }
    if MB_LD2[0] != MB_SYN_2 { anchor_ok = 0u64 }
    if anchor_ok == 0u64 {
        fclose(MB_LFILE[0])
        return 373u64
    }
    let mut samples_ok : u64 = 0u64
    k = 0u64
    while k < 8u64 {
        if MB_SMF[k] != 1u8 {
            fclose(MB_LFILE[0])
            return 373u64
        }
        if mb_fleet_row_dot(0u64, k * MB_SSTRIDE) != 0u64 {
            fclose(MB_LFILE[0])
            return 373u64
        }
        let mut same : u64 = 1u64
        if MB_LDS[0] != MB_SMS[k] { same = 0u64 }
        if MB_LD0[0] != MB_SM0[k] { same = 0u64 }
        if MB_LD1[0] != MB_SM1[k] { same = 0u64 }
        if MB_LD2[0] != MB_SM2[k] { same = 0u64 }
        if same == 0u64 {
            fclose(MB_LFILE[0])
            return 373u64
        }
        samples_ok = samples_ok + 1u64
        k = k + 1u64
    }
    /* the winner's Cauchy-Schwarz: (dot)^2 <= (row.row)(x.x), exact */
    if mb_fleet_row_norm(0u64, g_i) != 0u64 {
        fclose(MB_LFILE[0])
        return 373u64
    }
    fclose(MB_LFILE[0])
    mb_mul192(g_0, g_1, g_2, g_0, g_1, g_2)
    let mut k6 : u64 = 0u64
    while k6 < 6u64 {
        MB_R6A[k6] = MB_R6[k6]
        k6 = k6 + 1u64
    }
    mb_mul192(MB_LU0[0], MB_LU1[0], MB_LU2[0], MB_SYN_V0, MB_SYN_V1, MB_SYN_V2)
    let cs : i64 = mb_cmp6()
    if cs > 0i64 { return 373u64 }
    mb_rs("the fleet: vocab=" as u64)
    mb_ru(v_all)
    mb_rs(" argmax=" as u64)
    mb_ru(g_i)
    mb_rs(" value=" as u64)
    if g_s < 0i64 { mb_rb(45u8) }
    MB_X[0] = g_0
    MB_X[1] = g_1
    MB_X[2] = g_2
    mb_rx3()
    mb_rs("*2^-48 attained=" as u64)
    mb_ru(g_t)
    mb_rs(" pos=" as u64)
    mb_ru(hp)
    mb_rs(" neg=" as u64)
    mb_ru(hn)
    mb_rs(" zero=" as u64)
    mb_ru(hz)
    mb_rs(" anchor=synapse-exact samples=" as u64)
    mb_ru(samples_ok)
    mb_rs("/8 winner-cs=" as u64)
    if cs < 0i64 { mb_rs("strict" as u64) }
    if cs == 0i64 { mb_rs("proportional" as u64) }
    mb_rs(" fold=order-invariant" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ============ arm 374: THE EXPERT WALK (the router, certified) ============ */

/* exact f32: value = mant * 2^exp with mant signed, exp in MB_F32E.
 * The sentinel marks nonfinite. */
var MB_F32E : i64 = 0i64
fn mb_f32m(bits: u64) -> i64 {
    let e : u64 = (bits >> 23u64) & 255u64
    let m : u64 = bits & 0x7FFFFFu64
    if e == 255u64 { return 4611686018427387904i64 }
    let mut mm : u64 = m
    MB_F32E = 0i64 - 149i64
    if e != 0u64 {
        mm = 8388608u64 + m
        MB_F32E = (e as i64) - 150i64
    }
    let mv : i64 = mm as i64
    if (bits >> 31u64) == 1u64 { return 0i64 - mv }
    return mv
}

/* the router's 256 logits, exact: sign, 3 limbs, exponent */
var MB_RLS : [i64; 256]
var MB_RL0 : [u64; 256]
var MB_RL1 : [u64; 256]
var MB_RL2 : [u64; 256]
var MB_RLE : [i64; 256]
/* per-64-element chunk partials for the reversed-fold teeth */
var MB_CPS : [i64; 112]
var MB_CP0 : [u64; 112]
var MB_CP1 : [u64; 112]
var MB_CP2 : [u64; 112]
var MB_TOP : [u64; 8]

/* signed accumulate (ss, l0,l1,l2) into slot arrays A (0 = row acc via
 * globals below); the walk is single-threaded so plain globals serve */
var MB_WAS : i64 = 0i64
var MB_WA0 : u64 = 0u64
var MB_WA1 : u64 = 0u64
var MB_WA2 : u64 = 0u64
fn mb_wacc3(ss: i64, s0: u64, s1: u64, s2: u64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let ds : i64 = MB_WAS
    let d0 : u64 = MB_WA0
    let d1 : u64 = MB_WA1
    let d2 : u64 = MB_WA2
    if ds == 0i64 {
        MB_WAS = ss
        MB_WA0 = s0
        MB_WA1 = s1
        MB_WA2 = s2
        return 0i32
    }
    if ds == ss {
        let a0 : u64 = d0 + s0
        let mut c0 : u64 = 0u64
        if a0 < s0 { c0 = 1u64 }
        let a1a : u64 = d1 + s1
        let mut c1 : u64 = 0u64
        if a1a < s1 { c1 = 1u64 }
        let a1 : u64 = a1a + c0
        if a1 < c0 { c1 = c1 + 1u64 }
        MB_WA0 = a0
        MB_WA1 = a1
        MB_WA2 = d2 + s2 + c1
        return 0i32
    }
    let mut cmp : i64 = 0i64
    if d2 > s2 { cmp = 1i64 }
    if d2 < s2 { cmp = 0i64 - 1i64 }
    if cmp == 0i64 {
        if d1 > s1 { cmp = 1i64 }
        if d1 < s1 { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        if d0 > s0 { cmp = 1i64 }
        if d0 < s0 { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        MB_WAS = 0i64
        MB_WA0 = 0u64
        MB_WA1 = 0u64
        MB_WA2 = 0u64
        return 0i32
    }
    if cmp > 0i64 {
        let mut b : u64 = 0u64
        let x0 : u64 = d0 - s0
        if d0 < s0 { b = 1u64 }
        let mut b1 : u64 = 0u64
        let x1a : u64 = d1 - s1
        if d1 < s1 { b1 = 1u64 }
        let x1 : u64 = x1a - b
        if x1a < b { b1 = b1 + 1u64 }
        MB_WA0 = x0
        MB_WA1 = x1
        MB_WA2 = d2 - s2 - b1
        return 0i32
    }
    let mut b2 : u64 = 0u64
    let y0 : u64 = s0 - d0
    if s0 < d0 { b2 = 1u64 }
    let mut b3 : u64 = 0u64
    let y1a : u64 = s1 - d1
    if s1 < d1 { b3 = 1u64 }
    let y1 : u64 = y1a - b2
    if y1a < b2 { b3 = b3 + 1u64 }
    MB_WA0 = y0
    MB_WA1 = y1
    MB_WA2 = s2 - d2 - b3
    MB_WAS = ss
    return 0i32
}

/* one router row, two window passes: exponent scan, then accumulation at
 * the row's own minimal exponent with per-chunk partials.
 * returns 0 ok / 1 io / 2 nonfinite / 3 spread-guard */
fn mb_walk_row(r: u64) -> u64 {
    let ne0 : u64 = MB_C3_NE0
    let row_abs : u64 = MB_C3_DBASE + MB_C3_OFF + r * ne0 * 4u64
    /* pass A: the exponent window of the row */
    mb_seek_abs(row_abs)
    let mut emin : i64 = 1000i64
    let mut emax : i64 = 0i64 - 1000i64
    let mut e : u64 = 0u64
    while e < ne0 {
        let bits : u64 = mb_u32()
        let mf : i64 = mb_f32m(bits)
        if mf == 4611686018427387904i64 { return 2u64 }
        if mf != 0i64 {
            if MB_XV[e] != 0i64 {
                if MB_F32E < emin { emin = MB_F32E }
                if MB_F32E > emax { emax = MB_F32E }
            }
        }
        e = e + 1u64
    }
    if MB_IOERR != 0u8 { return 1u64 }
    if emin == 1000i64 {
        /* an all-orthogonal row: the logit is exactly zero */
        MB_RLS[r] = 0i64
        MB_RL0[r] = 0u64
        MB_RL1[r] = 0u64
        MB_RL2[r] = 0u64
        MB_RLE[r] = 0i64
        return 0u64
    }
    if emax - emin > 32i64 { return 3u64 }
    /* pass B: exact accumulation at 2^(emin-24), chunk partials kept */
    mb_seek_abs(row_abs)
    MB_WAS = 0i64
    MB_WA0 = 0u64
    MB_WA1 = 0u64
    MB_WA2 = 0u64
    let nchunk : u64 = ne0 / 64u64
    let mut ch : u64 = 0u64
    while ch < nchunk {
        let mut ce : u64 = 0u64
        while ce < 64u64 {
            let bits : u64 = mb_u32()
            let mf : i64 = mb_f32m(bits)
            let xe : u64 = ch * 64u64 + ce
            let xv : i64 = MB_XV[xe]
            if mf != 0i64 {
                if xv != 0i64 {
                    let mut mfa : u64 = mf as u64
                    if mf < 0i64 { mfa = (0i64 - mf) as u64 }
                    let mut mxa : u64 = xv as u64
                    if xv < 0i64 { mxa = (0i64 - xv) as u64 }
                    let mut sgn : i64 = 1i64
                    if mf < 0i64 {
                        if xv > 0i64 { sgn = 0i64 - 1i64 }
                    }
                    if mf > 0i64 {
                        if xv < 0i64 { sgn = 0i64 - 1i64 }
                    }
                    mb_mul64(mfa, mxa)
                    let sh : u64 = (MB_F32E - emin) as u64
                    let mut l0 : u64 = MB_MLO
                    let mut l1 : u64 = MB_MHI
                    let mut l2 : u64 = 0u64
                    if sh != 0u64 {
                        l2 = l1 >> (64u64 - sh)
                        l1 = (l1 << sh) | (l0 >> (64u64 - sh))
                        l0 = l0 << sh
                    }
                    mb_wacc3(sgn, l0, l1, l2)
                }
            }
            ce = ce + 1u64
        }
        /* running prefix totals; the reversed teeth below derive the
         * per-chunk deltas and re-fold them backwards */
        MB_CPS[ch] = MB_WAS
        MB_CP0[ch] = MB_WA0
        MB_CP1[ch] = MB_WA1
        MB_CP2[ch] = MB_WA2
        ch = ch + 1u64
    }
    if MB_IOERR != 0u8 { return 1u64 }
    /* THE PREFIX LAW: the running totals must be reproducible by folding
     * the per-chunk deltas backwards -- derive each delta as total_k minus
     * total_{k-1} and re-fold in reverse; the result must equal the row */
    MB_WAS = 0i64
    MB_WA0 = 0u64
    MB_WA1 = 0u64
    MB_WA2 = 0u64
    let mut ck : u64 = nchunk
    while ck != 0u64 {
        ck = ck - 1u64
        let mut ps : i64 = 0i64
        let mut p0 : u64 = 0u64
        let mut p1 : u64 = 0u64
        let mut p2 : u64 = 0u64
        if ck == 0u64 {
            ps = MB_CPS[0]
            p0 = MB_CP0[0]
            p1 = MB_CP1[0]
            p2 = MB_CP2[0]
        }
        if ck != 0u64 {
            /* delta_k = total_k + (-total_{k-1}) via the signed acc */
            let sv2s : i64 = MB_WAS
            let sv20 : u64 = MB_WA0
            let sv21 : u64 = MB_WA1
            let sv22 : u64 = MB_WA2
            MB_WAS = MB_CPS[ck]
            MB_WA0 = MB_CP0[ck]
            MB_WA1 = MB_CP1[ck]
            MB_WA2 = MB_CP2[ck]
            mb_wacc3(0i64 - MB_CPS[ck - 1u64], MB_CP0[ck - 1u64], MB_CP1[ck - 1u64], MB_CP2[ck - 1u64])
            ps = MB_WAS
            p0 = MB_WA0
            p1 = MB_WA1
            p2 = MB_WA2
            MB_WAS = sv2s
            MB_WA0 = sv20
            MB_WA1 = sv21
            MB_WA2 = sv22
        }
        mb_wacc3(ps, p0, p1, p2)
    }
    let fs : i64 = MB_CPS[nchunk - 1u64]
    if MB_WAS != fs { return 4u64 }
    if MB_WA0 != MB_CP0[nchunk - 1u64] { return 4u64 }
    if MB_WA1 != MB_CP1[nchunk - 1u64] { return 4u64 }
    if MB_WA2 != MB_CP2[nchunk - 1u64] { return 4u64 }
    MB_RLS[r] = MB_WAS
    MB_RL0[r] = MB_WA0
    MB_RL1[r] = MB_WA1
    MB_RL2[r] = MB_WA2
    MB_RLE[r] = emin - 24i64
    return 0u64
}

fn mb_arm374() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_C3_F == 0u8 {
        mb_rs("the walk: router absent from the feast (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    if MB_C3_TYPE != 0u64 {
        mb_rs("the walk: router foreign type=" as u64)
        mb_ru(MB_C3_TYPE)
        mb_rs(" (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    if MB_C3_NE0 != MB_C1_NE0 {
        mb_rs("the walk: router axis mismatch (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    let experts : u64 = MB_C3_NE / MB_C3_NE0
    if experts == 0u64 { return 374u64 }
    if experts > 256u64 {
        mb_rs("the walk: experts exceed the ledger (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    /* open the router's shard through the window reader */
    mb_mkpath(MB_C3_SHARD)
    let f : u64 = fopen((&MB_PATH) as u64, "rb" as u64)
    if f == 0u64 { return 374u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    let mut r : u64 = 0u64
    while r < experts {
        let rc : u64 = mb_walk_row(r)
        if rc == 2u64 {
            fclose(f)
            mb_rs("the walk: refused (nonfinite f32 in the router -- named)" as u64)
            mb_rb(10u8)
            return 0u64
        }
        if rc == 3u64 {
            fclose(f)
            mb_rs("the walk: refused (exponent spread beyond the guard -- named)" as u64)
            mb_rb(10u8)
            return 0u64
        }
        if rc != 0u64 {
            fclose(f)
            return 374u64
        }
        r = r + 1u64
    }
    fclose(f)
    /* global exponent alignment under the guard */
    let mut gmin : i64 = 1000i64
    r = 0u64
    while r < experts {
        if MB_RLS[r] != 0i64 {
            if MB_RLE[r] < gmin { gmin = MB_RLE[r] }
        }
        r = r + 1u64
    }
    if gmin != 1000i64 {
        r = 0u64
        while r < experts {
            if MB_RLS[r] != 0i64 {
                let sh : u64 = (MB_RLE[r] - gmin) as u64
                if sh > 32u64 {
                    mb_rs("the walk: refused (cross-expert spread beyond the guard -- named)" as u64)
                    mb_rb(10u8)
                    return 0u64
                }
                if sh != 0u64 {
                    let l0 : u64 = MB_RL0[r]
                    let l1 : u64 = MB_RL1[r]
                    let l2 : u64 = MB_RL2[r]
                    if (l2 >> (64u64 - sh)) != 0u64 { return 374u64 }
                    MB_RL2[r] = (l2 << sh) | (l1 >> (64u64 - sh))
                    MB_RL1[r] = (l1 << sh) | (l0 >> (64u64 - sh))
                    MB_RL0[r] = l0 << sh
                    MB_RLE[r] = gmin
                }
            }
            r = r + 1u64
        }
    }
    /* THE TOP-8, certified: repeated argmax with the lowest-index tie law;
     * softmax-topk equals logit-topk (any strictly monotone map preserves
     * order) -- NO exp is evaluated */
    let mut taken : u64 = 0u64
    let mut ties : u64 = 0u64
    while taken < 8u64 {
        let mut bi : u64 = 0xFFFFFFFFFFFFFFFFu64
        let mut bs : i64 = 0i64
        let mut b0 : u64 = 0u64
        let mut b1 : u64 = 0u64
        let mut b2 : u64 = 0u64
        r = 0u64
        while r < experts {
            let mut skip : u64 = 0u64
            let mut q : u64 = 0u64
            while q < taken {
                if MB_TOP[q] == r { skip = 1u64 }
                q = q + 1u64
            }
            if skip == 0u64 {
                if bi == 0xFFFFFFFFFFFFFFFFu64 {
                    bi = r
                    bs = MB_RLS[r]
                    b0 = MB_RL0[r]
                    b1 = MB_RL1[r]
                    b2 = MB_RL2[r]
                }
                if bi != r {
                    let c : i64 = mb_scmp192(MB_RLS[r], MB_RL0[r], MB_RL1[r], MB_RL2[r], bs, b0, b1, b2)
                    if c > 0i64 {
                        bi = r
                        bs = MB_RLS[r]
                        b0 = MB_RL0[r]
                        b1 = MB_RL1[r]
                        b2 = MB_RL2[r]
                    }
                    if c == 0i64 { ties = ties + 1u64 }
                }
            }
            r = r + 1u64
        }
        if bi == 0xFFFFFFFFFFFFFFFFu64 { return 374u64 }
        MB_TOP[taken] = bi
        taken = taken + 1u64
    }
    mb_rs("the walk: router=" as u64)
    let mut nn : u64 = 0u64
    while nn < MB_C3_NN {
        mb_rb(MB_C3_NAME[nn])
        nn = nn + 1u64
    }
    mb_rs(" type=f32 experts=" as u64)
    mb_ru(experts)
    mb_rs(" top8=" as u64)
    taken = 0u64
    while taken < 8u64 {
        if taken != 0u64 { mb_rb(44u8) }
        mb_ru(MB_TOP[taken])
        taken = taken + 1u64
    }
    mb_rs(" ties=" as u64)
    mb_ru(ties)
    mb_rs(" prefix-law=ok no-exp (monotone: softmax-topk = logit-topk)" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ============ arm 375: THE GAZE (exact attention QK, per head) ============ */

/* THE GAZE LAW: every RMSNorm in the MLA chain divides by ONE shared
 * positive scalar (a square root of a rational).  Per head, the score is
 * (C_i.E_i)/(sqrtQS sqrtKS) + (Crope_i.Drope)/(sqrtQS sqrtR): the surds are
 * COMMON POSITIVE FACTORS across all heads -- so per-head ORDER, SIGNS and
 * DOMINANCE of the true normalized scores are EXACT INTEGER facts.  The
 * roots never need taking.  At position 0 RoPE is rotation by zero -- the
 * identity, exactly -- so the first-position scores are whole.  Positions
 * beyond zero need certified sin/cos ladders: named, not faked. */

/* preloaded exact f32 norm vectors (mant, exp per element) */
var MB_ANM : [i64; 7168]
var MB_ANE : [i64; 7168]
var MB_FNM : [i64; 7168]
var MB_FNE : [i64; 7168]
var MB_QNM : [i64; 1536]
var MB_QNE : [i64; 1536]
var MB_KNM : [i64; 512]
var MB_KNE : [i64; 512]
/* stage vectors: sign, 3 limbs, exponent (canonical, bitlen <= 160) */
var MB_BVS : [i64; 1536]
var MB_BV0 : [u64; 1536]
var MB_BV1 : [u64; 1536]
var MB_BV2 : [u64; 1536]
var MB_BVE : [i64; 1536]
var MB_DVS : [i64; 576]
var MB_DV0 : [u64; 576]
var MB_DV1 : [u64; 576]
var MB_DV2 : [u64; 576]
var MB_DVE : [i64; 576]
/* per-head transients */
var MB_CHS : [i64; 192]
var MB_CH0 : [u64; 192]
var MB_CH1 : [u64; 192]
var MB_CH2 : [u64; 192]
var MB_CHE : [i64; 192]
var MB_EHS : [i64; 128]
var MB_EH0 : [u64; 128]
var MB_EH1 : [u64; 128]
var MB_EH2 : [u64; 128]
var MB_EHE : [i64; 128]
/* per-head verdicts: N1 (nope) and N2 (rope), 6-limb + exp */
var MB_N1S : [i64; 128]
var MB_N1L : [u64; 768]
var MB_N1E : [i64; 128]
var MB_N2S : [i64; 128]
var MB_N2L : [u64; 768]
var MB_N2E : [i64; 128]
/* the row's decoded weights (one row of any gaze tensor; o_proj rows are
 * 16384 wide -- the buffer holds the widest row it will ever be asked) */
var MB_GW : [i64; 18432]
/* the signed 6-limb accumulator */
var MB_6S : i64 = 0i64
var MB_6L : [u64; 6]
/* 6-limb source/term scratch */
var MB_T6 : [u64; 6]
/* 6-limb chunk prefixes (the per-row teeth) */
var MB_6CS : [i64; 112]
var MB_6CL : [u64; 672]
var MB_SVL : [u64; 6]
var MB_GZOVF : u64 = 0u64             /* the named guard ledger */

fn mb_t6_clear() -> i32 {
    let mut k : u64 = 0u64
    while k < 6u64 {
        MB_T6[k] = 0u64
        k = k + 1u64
    }
    return 0i32
}

/* magnitude compare acc vs T6 */
fn mb_6magcmp() -> i64 {
    let mut k : u64 = 6u64
    while k != 0u64 {
        k = k - 1u64
        if MB_6L[k] > MB_T6[k] { return 1i64 }
        if MB_6L[k] < MB_T6[k] { return 0i64 - 1i64 }
    }
    return 0i64
}

/* acc += sign*T6 (sign-magnitude, 6-limb) */
fn mb_acc6_add(ss: i64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let mut nz : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 6u64 {
        nz = nz | MB_T6[k]
        k = k + 1u64
    }
    if nz == 0u64 { return 0i32 }
    if MB_6S == 0i64 {
        MB_6S = ss
        k = 0u64
        while k < 6u64 {
            MB_6L[k] = MB_T6[k]
            k = k + 1u64
        }
        return 0i32
    }
    if MB_6S == ss {
        let mut carry : u64 = 0u64
        k = 0u64
        while k < 6u64 {
            let a : u64 = MB_6L[k] + MB_T6[k]
            let mut c2 : u64 = 0u64
            if a < MB_T6[k] { c2 = 1u64 }
            let b : u64 = a + carry
            if b < carry { c2 = c2 + 1u64 }
            MB_6L[k] = b
            carry = c2
            k = k + 1u64
        }
        if carry != 0u64 { MB_GZOVF = MB_GZOVF + 1u64 }
        return 0i32
    }
    let cmp : i64 = mb_6magcmp()
    if cmp == 0i64 {
        MB_6S = 0i64
        k = 0u64
        while k < 6u64 {
            MB_6L[k] = 0u64
            k = k + 1u64
        }
        return 0i32
    }
    if cmp > 0i64 {
        let mut borrow : u64 = 0u64
        k = 0u64
        while k < 6u64 {
            let d : u64 = MB_6L[k] - MB_T6[k]
            let mut b2 : u64 = 0u64
            if MB_6L[k] < MB_T6[k] { b2 = 1u64 }
            let e2 : u64 = d - borrow
            if d < borrow { b2 = b2 + 1u64 }
            MB_6L[k] = e2
            borrow = b2
            k = k + 1u64
        }
        return 0i32
    }
    let mut borrow2 : u64 = 0u64
    k = 0u64
    while k < 6u64 {
        let d3 : u64 = MB_T6[k] - MB_6L[k]
        let mut b3 : u64 = 0u64
        if MB_T6[k] < MB_6L[k] { b3 = 1u64 }
        let e3 : u64 = d3 - borrow2
        if d3 < borrow2 { b3 = b3 + 1u64 }
        MB_6L[k] = e3
        borrow2 = b3
        k = k + 1u64
    }
    MB_6S = ss
    return 0i32
}

/* T6 = (l0..l3) * m  (4 limbs by 1), then T6 <<= sh (sh <= 48) */
fn mb_t6_mul4_shl(l0: u64, l1: u64, l2: u64, l3: u64, m: u64, sh: u64) -> i32 {
    mb_t6_clear()
    mb_mul64(l0, m)
    MB_T6[0] = MB_MLO
    MB_T6[1] = MB_MHI
    mb_mul64(l1, m)
    let s1 : u64 = MB_T6[1] + MB_MLO
    let mut c1 : u64 = 0u64
    if s1 < MB_MLO { c1 = 1u64 }
    MB_T6[1] = s1
    MB_T6[2] = MB_MHI + c1
    mb_mul64(l2, m)
    let s2 : u64 = MB_T6[2] + MB_MLO
    let mut c2 : u64 = 0u64
    if s2 < MB_MLO { c2 = 1u64 }
    MB_T6[2] = s2
    MB_T6[3] = MB_MHI + c2
    mb_mul64(l3, m)
    let s3 : u64 = MB_T6[3] + MB_MLO
    let mut c3 : u64 = 0u64
    if s3 < MB_MLO { c3 = 1u64 }
    MB_T6[3] = s3
    MB_T6[4] = MB_MHI + c3
    if sh != 0u64 {
        let mut k : u64 = 6u64
        while k != 0u64 {
            k = k - 1u64
            let mut v : u64 = MB_T6[k] << sh
            if k != 0u64 { v = v | (MB_T6[k - 1u64] >> (64u64 - sh)) }
            MB_T6[k] = v
        }
    }
    return 0i32
}

/* fetch source element `c` for kind (0 hw, 1 B*w_qan, 2 D*w_kvn):
 * writes sign MB_SFS, limbs MB_SF0..3, exp MB_SFE */
var MB_SFS : i64 = 0i64
var MB_SF0 : u64 = 0u64
var MB_SF1 : u64 = 0u64
var MB_SF2 : u64 = 0u64
var MB_SF3 : u64 = 0u64
var MB_SFE : i64 = 0i64
fn mb_gz_src(kind: u64, c: u64) -> i32 {
    if kind == 0u64 {
        let h : i64 = MB_XV[c]
        let wm : i64 = MB_ANM[c]
        MB_SFS = 0i64
        if h > 0i64 {
            if wm > 0i64 { MB_SFS = 1i64 }
            if wm < 0i64 { MB_SFS = 0i64 - 1i64 }
        }
        if h < 0i64 {
            if wm > 0i64 { MB_SFS = 0i64 - 1i64 }
            if wm < 0i64 { MB_SFS = 1i64 }
        }
        let mut hm : u64 = h as u64
        if h < 0i64 { hm = (0i64 - h) as u64 }
        let mut wmm : u64 = wm as u64
        if wm < 0i64 { wmm = (0i64 - wm) as u64 }
        mb_mul64(hm, wmm)
        MB_SF0 = MB_MLO
        MB_SF1 = MB_MHI
        MB_SF2 = 0u64
        MB_SF3 = 0u64
        MB_SFE = MB_ANE[c] - 24i64
        return 0i32
    }
    let mut vs : i64 = 0i64
    let mut v0 : u64 = 0u64
    let mut v1 : u64 = 0u64
    let mut v2 : u64 = 0u64
    let mut ve : i64 = 0i64
    let mut wm2 : i64 = 0i64
    let mut we2 : i64 = 0i64
    if kind == 1u64 {
        vs = MB_BVS[c]
        v0 = MB_BV0[c]
        v1 = MB_BV1[c]
        v2 = MB_BV2[c]
        ve = MB_BVE[c]
        wm2 = MB_QNM[c]
        we2 = MB_QNE[c]
    }
    if kind == 2u64 {
        vs = MB_DVS[c]
        v0 = MB_DV0[c]
        v1 = MB_DV1[c]
        v2 = MB_DV2[c]
        ve = MB_DVE[c]
        wm2 = MB_KNM[c]
        we2 = MB_KNE[c]
    }
    MB_SFS = 0i64
    if vs != 0i64 {
        if wm2 > 0i64 { MB_SFS = vs }
        if wm2 < 0i64 { MB_SFS = 0i64 - vs }
    }
    let mut wmm2 : u64 = wm2 as u64
    if wm2 < 0i64 { wmm2 = (0i64 - wm2) as u64 }
    /* (v0..v2) * wmm2 -> 4 limbs */
    mb_mul64(v0, wmm2)
    MB_SF0 = MB_MLO
    let mut t1 : u64 = MB_MHI
    mb_mul64(v1, wmm2)
    let s1 : u64 = t1 + MB_MLO
    let mut c1 : u64 = 0u64
    if s1 < MB_MLO { c1 = 1u64 }
    MB_SF1 = s1
    let mut t2 : u64 = MB_MHI + c1
    mb_mul64(v2, wmm2)
    let s2 : u64 = t2 + MB_MLO
    let mut c2 : u64 = 0u64
    if s2 < MB_MLO { c2 = 1u64 }
    MB_SF2 = s2
    MB_SF3 = MB_MHI + c2
    MB_SFE = ve + we2
    return 0i32
}

/* decode one full row of gaze tensor slot g into MB_GW (dyadic mants) */
fn mb_gz_wrow(g: u64, row: u64) -> u64 {
    let ty : u64 = MB_G_TYPE[g]
    let bb : u64 = mb_tbb(ty)
    let bv : u64 = mb_tbv(ty)
    if bv != 256u64 { return 1u64 }
    let ne0 : u64 = MB_G_NE0[g]
    let bpr : u64 = ne0 / 256u64
    let mut b : u64 = 0u64
    while b < bpr {
        let abs : u64 = MB_G_DB[g] + MB_G_OFF[g] + (row * bpr + b) * bb
        if mb_wread(0u64, abs, bb) != 0u64 { return 1u64 }
        if mb_wdec(0u64, ty, 0u64) != 0u64 { return 1u64 }
        let mut e : u64 = 0u64
        while e < 256u64 {
            MB_GW[b * 256u64 + e] = MB_LVA[e]
            e = e + 1u64
        }
        b = b + 1u64
    }
    return 0u64
}

/* one exact matvec row: weights (MB_GW, already decoded) . source(kind).
 * Two passes (exponent window, then aligned 6-limb accumulation with
 * per-64-chunk prefixes), then the PREFIX LAW re-fold, then canonical
 * store into (s, 3 limbs, exp).  returns 0 ok / 1 red / 2 guard */
var MB_RRS : i64 = 0i64
var MB_RR0 : u64 = 0u64
var MB_RR1 : u64 = 0u64
var MB_RR2 : u64 = 0u64
var MB_RRE : i64 = 0i64
fn mb_gz_dotrow(n: u64, kind: u64) -> u64 {
    let mut emin : i64 = 100000i64
    let mut emax : i64 = 0i64 - 100000i64
    let mut c : u64 = 0u64
    while c < n {
        if MB_GW[c] != 0i64 {
            mb_gz_src(kind, c)
            if MB_SFS != 0i64 {
                if MB_SFE < emin { emin = MB_SFE }
                if MB_SFE > emax { emax = MB_SFE }
            }
        }
        c = c + 1u64
    }
    if emin == 100000i64 {
        MB_RRS = 0i64
        MB_RR0 = 0u64
        MB_RR1 = 0u64
        MB_RR2 = 0u64
        MB_RRE = 0i64
        return 0u64
    }
    if emax - emin > 48i64 { return 2u64 }
    MB_6S = 0i64
    let mut k : u64 = 0u64
    while k < 6u64 {
        MB_6L[k] = 0u64
        k = k + 1u64
    }
    MB_GZOVF = 0u64
    let nch : u64 = (n + 63u64) / 64u64
    let mut ch : u64 = 0u64
    while ch < nch {
        let mut ce : u64 = ch * 64u64
        let mut cend : u64 = ce + 64u64
        if cend > n { cend = n }
        while ce < cend {
            let wq : i64 = MB_GW[ce]
            if wq != 0i64 {
                mb_gz_src(kind, ce)
                if MB_SFS != 0i64 {
                    let mut wqm : u64 = wq as u64
                    if wq < 0i64 { wqm = (0i64 - wq) as u64 }
                    let mut sgn : i64 = MB_SFS
                    if wq < 0i64 { sgn = 0i64 - MB_SFS }
                    let sh : u64 = (MB_SFE - emin) as u64
                    mb_t6_mul4_shl(MB_SF0, MB_SF1, MB_SF2, MB_SF3, wqm, sh)
                    mb_acc6_add(sgn)
                }
            }
            ce = ce + 1u64
        }
        MB_6CS[ch] = MB_6S
        let mut q : u64 = 0u64
        while q < 6u64 {
            MB_6CL[ch * 6u64 + q] = MB_6L[q]
            q = q + 1u64
        }
        ch = ch + 1u64
    }
    if MB_GZOVF != 0u64 { return 2u64 }
    /* THE PREFIX LAW: deltas re-folded backwards must land on the row */
    let fin_s : i64 = MB_6CS[nch - 1u64]
    MB_6S = 0i64
    k = 0u64
    while k < 6u64 {
        MB_6L[k] = 0u64
        k = k + 1u64
    }
    let mut ck : u64 = nch
    while ck != 0u64 {
        ck = ck - 1u64
        /* delta_ck = prefix_ck - prefix_{ck-1}: fold via two adds */
        let mut q2 : u64 = 0u64
        while q2 < 6u64 {
            MB_T6[q2] = MB_6CL[ck * 6u64 + q2]
            q2 = q2 + 1u64
        }
        mb_acc6_add(MB_6CS[ck])
        if ck != 0u64 {
            q2 = 0u64
            while q2 < 6u64 {
                MB_T6[q2] = MB_6CL[(ck - 1u64) * 6u64 + q2]
                q2 = q2 + 1u64
            }
            mb_acc6_add(0i64 - MB_6CS[ck - 1u64])
        }
    }
    if MB_6S != fin_s { return 1u64 }
    k = 0u64
    while k < 6u64 {
        if MB_6L[k] != MB_6CL[(nch - 1u64) * 6u64 + k] { return 1u64 }
        k = k + 1u64
    }
    /* canonical store: strip twos, demand bitlen <= 160 */
    let mut tz : u64 = 0u64
    let mut nzk : u64 = 0u64
    k = 0u64
    while k < 6u64 {
        nzk = nzk | MB_6L[k]
        k = k + 1u64
    }
    if nzk == 0u64 {
        MB_RRS = 0i64
        MB_RR0 = 0u64
        MB_RR1 = 0u64
        MB_RR2 = 0u64
        MB_RRE = 0i64
        return 0u64
    }
    let mut go : u8 = 1u8
    while go == 1u8 {
        go = 0u8
        if (MB_6L[0] & 1u64) == 0u64 {
            k = 0u64
            while k < 5u64 {
                MB_6L[k] = (MB_6L[k] >> 1u64) | (MB_6L[k + 1u64] << 63u64)
                k = k + 1u64
            }
            MB_6L[5] = MB_6L[5] >> 1u64
            tz = tz + 1u64
            go = 1u8
        }
    }
    if MB_6L[3] != 0u64 { return 2u64 }
    if MB_6L[4] != 0u64 { return 2u64 }
    if MB_6L[5] != 0u64 { return 2u64 }
    if mb_bitlen(MB_6L[2]) > 32u64 { return 2u64 }
    MB_RRS = fin_s
    MB_RR0 = MB_6L[0]
    MB_RR1 = MB_6L[1]
    MB_RR2 = MB_6L[2]
    MB_RRE = emin - 24i64 + (tz as i64)
    return 0u64
}

/* pair-dot: sum over d of A[d]*B[d] where both sides are (s,3limb,exp)
 * arrays; which 0 = C(nope 0..127) x E, 1 = C(rope 128..) x D(512+).
 * result -> MB_6S/MB_6L + exp MB_PDE.  returns 0/1/2 as above */
var MB_PDE : i64 = 0i64
fn mb_gz_pairdot(which: u64, n: u64) -> u64 {
    let mut emin : i64 = 100000i64
    let mut emax : i64 = 0i64 - 100000i64
    let mut d : u64 = 0u64
    while d < n {
        let mut sa : i64 = 0i64
        let mut sb : i64 = 0i64
        let mut ea : i64 = 0i64
        let mut eb : i64 = 0i64
        if which == 0u64 {
            sa = MB_CHS[d]
            ea = MB_CHE[d]
            sb = MB_EHS[d]
            eb = MB_EHE[d]
        }
        if which == 1u64 {
            sa = MB_CHS[128u64 + d]
            ea = MB_CHE[128u64 + d]
            sb = MB_DVS[512u64 + d]
            eb = MB_DVE[512u64 + d]
        }
        if sa != 0i64 {
            if sb != 0i64 {
                let te : i64 = ea + eb
                if te < emin { emin = te }
                if te > emax { emax = te }
            }
        }
        d = d + 1u64
    }
    if emin == 100000i64 {
        MB_6S = 0i64
        let mut kq : u64 = 0u64
        while kq < 6u64 {
            MB_6L[kq] = 0u64
            kq = kq + 1u64
        }
        MB_PDE = 0i64
        return 0u64
    }
    if emax - emin > 48i64 { return 2u64 }
    MB_6S = 0i64
    let mut k : u64 = 0u64
    while k < 6u64 {
        MB_6L[k] = 0u64
        k = k + 1u64
    }
    MB_GZOVF = 0u64
    d = 0u64
    while d < n {
        let mut sa2 : i64 = 0i64
        let mut a0 : u64 = 0u64
        let mut a1 : u64 = 0u64
        let mut a2 : u64 = 0u64
        let mut ea2 : i64 = 0i64
        let mut sb2 : i64 = 0i64
        let mut b0 : u64 = 0u64
        let mut b1 : u64 = 0u64
        let mut b2 : u64 = 0u64
        let mut eb2 : i64 = 0i64
        if which == 0u64 {
            sa2 = MB_CHS[d]
            a0 = MB_CH0[d]
            a1 = MB_CH1[d]
            a2 = MB_CH2[d]
            ea2 = MB_CHE[d]
            sb2 = MB_EHS[d]
            b0 = MB_EH0[d]
            b1 = MB_EH1[d]
            b2 = MB_EH2[d]
            eb2 = MB_EHE[d]
        }
        if which == 1u64 {
            sa2 = MB_CHS[128u64 + d]
            a0 = MB_CH0[128u64 + d]
            a1 = MB_CH1[128u64 + d]
            a2 = MB_CH2[128u64 + d]
            ea2 = MB_CHE[128u64 + d]
            sb2 = MB_DVS[512u64 + d]
            b0 = MB_DV0[512u64 + d]
            b1 = MB_DV1[512u64 + d]
            b2 = MB_DV2[512u64 + d]
            eb2 = MB_DVE[512u64 + d]
        }
        if sa2 != 0i64 {
            if sb2 != 0i64 {
                mb_mul192(a0, a1, a2, b0, b1, b2)
                let sh : u64 = ((ea2 + eb2) - emin) as u64
                let mut q3 : u64 = 0u64
                while q3 < 6u64 {
                    MB_T6[q3] = MB_R6[q3]
                    q3 = q3 + 1u64
                }
                if sh != 0u64 {
                    let mut kk : u64 = 6u64
                    while kk != 0u64 {
                        kk = kk - 1u64
                        let mut v2 : u64 = MB_T6[kk] << sh
                        if kk != 0u64 { v2 = v2 | (MB_T6[kk - 1u64] >> (64u64 - sh)) }
                        MB_T6[kk] = v2
                    }
                }
                let mut sg : i64 = sa2
                if sb2 < 0i64 { sg = 0i64 - sg }
                mb_acc6_add(sg)
            }
        }
        d = d + 1u64
    }
    if MB_GZOVF != 0u64 { return 2u64 }
    MB_PDE = emin
    return 0u64
}

/* head comparison of stored (s, 6-limb, exp): decisive by sign, then by
 * (bitlen + exp), then by aligned limbs */
fn mb_gz_hbits(arr_l: u64, i: u64) -> u64 {
    /* bitlen of head i's 6 limbs in N1L (arr_l 0) or N2L (arr_l 1) */
    let mut k : u64 = 6u64
    while k != 0u64 {
        k = k - 1u64
        let mut v : u64 = 0u64
        if arr_l == 0u64 { v = MB_N1L[i * 6u64 + k] }
        if arr_l == 1u64 { v = MB_N2L[i * 6u64 + k] }
        if v != 0u64 { return k * 64u64 + mb_bitlen(v) }
    }
    return 0u64
}

fn mb_gz_hcmp(arr: u64, i: u64, j: u64) -> i64 {
    let mut si : i64 = 0i64
    let mut sj : i64 = 0i64
    let mut ei : i64 = 0i64
    let mut ej : i64 = 0i64
    if arr == 0u64 {
        si = MB_N1S[i]
        sj = MB_N1S[j]
        ei = MB_N1E[i]
        ej = MB_N1E[j]
    }
    if arr == 1u64 {
        si = MB_N2S[i]
        sj = MB_N2S[j]
        ei = MB_N2E[i]
        ej = MB_N2E[j]
    }
    if si > sj { return 1i64 }
    if si < sj { return 0i64 - 1i64 }
    if si == 0i64 { return 0i64 }
    let bi : i64 = (mb_gz_hbits(arr, i) as i64) + ei
    let bj : i64 = (mb_gz_hbits(arr, j) as i64) + ej
    let mut mag : i64 = 0i64
    if bi > bj { mag = 1i64 }
    if bi < bj { mag = 0i64 - 1i64 }
    if mag == 0i64 {
        /* same magnitude class: align to the smaller exponent and compare */
        let mut sh_i : u64 = 0u64
        let mut sh_j : u64 = 0u64
        if ei > ej { sh_i = (ei - ej) as u64 }
        if ej > ei { sh_j = (ej - ei) as u64 }
        let mut k : u64 = 6u64
        let mut cmp : i64 = 0i64
        while k != 0u64 {
            k = k - 1u64
            /* aligned limb extraction with shift-left by sh (guarded small) */
            let mut vi : u64 = 0u64
            let mut vj : u64 = 0u64
            if arr == 0u64 {
                vi = MB_N1L[i * 6u64 + k] << sh_i
                if k != 0u64 {
                    if sh_i != 0u64 { vi = vi | (MB_N1L[i * 6u64 + k - 1u64] >> (64u64 - sh_i)) }
                }
                vj = MB_N1L[j * 6u64 + k] << sh_j
                if k != 0u64 {
                    if sh_j != 0u64 { vj = vj | (MB_N1L[j * 6u64 + k - 1u64] >> (64u64 - sh_j)) }
                }
            }
            if arr == 1u64 {
                vi = MB_N2L[i * 6u64 + k] << sh_i
                if k != 0u64 {
                    if sh_i != 0u64 { vi = vi | (MB_N2L[i * 6u64 + k - 1u64] >> (64u64 - sh_i)) }
                }
                vj = MB_N2L[j * 6u64 + k] << sh_j
                if k != 0u64 {
                    if sh_j != 0u64 { vj = vj | (MB_N2L[j * 6u64 + k - 1u64] >> (64u64 - sh_j)) }
                }
            }
            if cmp == 0i64 {
                if vi > vj { cmp = 1i64 }
                if vi < vj { cmp = 0i64 - 1i64 }
            }
        }
        mag = cmp
    }
    if si < 0i64 { return 0i64 - mag }
    return mag
}

/* load an f32 norm vector (slot g) into the chosen preload arrays */
fn mb_gz_loadf32(g: u64, which: u64, n: u64) -> u64 {
    if MB_G_TYPE[g] != 0u64 { return 1u64 }
    if MB_G_NE[g] != n { return 1u64 }
    mb_mkpath(MB_G_SH[g])
    let f : u64 = fopen((&MB_PATH) as u64, "rb" as u64)
    if f == 0u64 { return 1u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    mb_seek_abs(MB_G_DB[g] + MB_G_OFF[g])
    let mut c : u64 = 0u64
    while c < n {
        let bits : u64 = mb_u32()
        let m : i64 = mb_f32m(bits)
        if m == 4611686018427387904i64 {
            fclose(f)
            return 1u64
        }
        if which == 0u64 {
            MB_ANM[c] = m
            MB_ANE[c] = MB_F32E
        }
        if which == 1u64 {
            MB_QNM[c] = m
            MB_QNE[c] = MB_F32E
        }
        if which == 2u64 {
            MB_KNM[c] = m
            MB_KNE[c] = MB_F32E
        }
        if which == 3u64 {
            MB_FNM[c] = m
            MB_FNE[c] = MB_F32E
        }
        if which == 4u64 {
            MB_NW_M[c] = m
            MB_NW_E[c] = MB_F32E
        }
        c = c + 1u64
    }
    let mut rr : u64 = 0u64
    if MB_IOERR != 0u8 { rr = 1u64 }
    fclose(f)
    return rr
}

/* the general per-layer norm-weight loader: any f32 norm tensor (slot)
 * of width n into the standing MB_NW, served exact-dyadic to probole */
var MB_NW_M : [i64; 7168]
var MB_NW_E : [i64; 7168]
fn mb_ld_normw(slot: u64, n: u64) -> u64 @export {
    if slot >= 732u64 { return 1u64 }
    if MB_G_F[slot] == 0u8 { return 1u64 }
    if n > 7168u64 { return 1u64 }
    return mb_gz_loadf32(slot, 4u64, n)
}
fn mb_nw_m(i: u64) -> i64 @export {
    if i >= 7168u64 { return 0i64 }
    return MB_NW_M[i]
}
fn mb_nw_e(i: u64) -> i64 @export {
    if i >= 7168u64 { return 0i64 }
    return MB_NW_E[i]
}
/* per-layer tensor geometry, served to probole (slot = layer*12 + role) */
fn mb_g_ne(slot: u64) -> u64 @export {
    if slot >= 732u64 { return 0u64 }
    return MB_G_NE[slot]
}
fn mb_g_ne0(slot: u64) -> u64 @export {
    if slot >= 732u64 { return 0u64 }
    return MB_G_NE0[slot]
}
fn mb_g_present(slot: u64) -> u64 @export {
    if slot >= 732u64 { return 0u64 }
    return MB_G_F[slot] as u64
}

/* ============ the MoE surface (blk.3): router rows + expert geometry ======= */
var MB_RW_M : [i64; 7168]
var MB_RW_E : [i64; 7168]
/* load router expert e's 7168 f32 weights (the SELECTED layer's router) */
fn mb_moe_router_row(e: u64) -> u64 @export {
    let lay : u64 = MB_ME_BASE / 6u64
    if MB_RT_F[lay] == 0u8 { return 1u64 }
    if MB_RT_NE0[lay] != 7168u64 { return 1u64 }
    if e >= 256u64 { return 1u64 }
    mb_mkpath(MB_RT_SH[lay])
    let f : u64 = fopen((&MB_PATH) as u64, "rb" as u64)
    if f == 0u64 { return 1u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    mb_seek_abs(MB_RT_DB[lay] + MB_RT_OFF[lay] + e * 7168u64 * 4u64)
    let mut i : u64 = 0u64
    while i < 7168u64 {
        let bits : u64 = mb_u32()
        let m : i64 = mb_f32m(bits)
        if m == 4611686018427387904i64 {
            fclose(f)
            return 1u64
        }
        MB_RW_M[i] = m
        MB_RW_E[i] = MB_F32E
        i = i + 1u64
    }
    let mut rr : u64 = 0u64
    if MB_IOERR != 0u8 { rr = 1u64 }
    fclose(f)
    return rr
}
fn mb_rw_m(i: u64) -> i64 @export {
    if i >= 7168u64 { return 0i64 }
    return MB_RW_M[i]
}
fn mb_rw_e(i: u64) -> i64 @export {
    if i >= 7168u64 { return 0i64 }
    return MB_RW_E[i]
}
/* the MoE presence + geometry of the SELECTED layer (MB_ME_BASE; default
 * layer 3 -- the proven synodos path unchanged).  The selector lets the
 * walk point the same six faces at any MoE layer's tensors. */
fn mb_me_sel(lay: u64) -> u64 @export {
    if lay >= 61u64 { return 1u64 }
    MB_ME_BASE = lay * 6u64
    return 0u64
}
fn mb_moe_present() -> u64 @export {
    let lay : u64 = MB_ME_BASE / 6u64
    if MB_RT_F[lay] == 0u8 { return 0u64 }
    let mut r : u64 = 0u64
    while r < 6u64 {
        if MB_ME_F[MB_ME_BASE + r] == 0u8 { return 0u64 }
        r = r + 1u64
    }
    return 1u64
}
fn mb_me_ne(role: u64) -> u64 @export {
    if role >= 6u64 { return 0u64 }
    return MB_ME_NE[MB_ME_BASE + role]
}
fn mb_me_ne0(role: u64) -> u64 @export {
    if role >= 6u64 { return 0u64 }
    return MB_ME_NE0[MB_ME_BASE + role]
}
fn mb_moe_scale_bits() -> u64 @export { return MB_EXPSCALE }
fn mb_moe_used() -> u64 @export { return MB_EXPUSED }
fn mb_rt_present(lay: u64) -> u64 @export {
    if lay >= 61u64 { return 0u64 }
    return MB_RT_F[lay] as u64
}
fn mb_eb_present(lay: u64) -> u64 @export {
    if lay >= 61u64 { return 0u64 }
    return MB_EB_F[lay] as u64
}
fn mb_sp_present(k: u64) -> u64 @export {
    if k >= 4u64 { return 0u64 }
    return MB_SP_F[k] as u64
}
fn mb_sp_ne(k: u64) -> u64 @export {
    if k >= 4u64 { return 0u64 }
    return MB_SP_NE[k]
}
fn mb_sp_ne0(k: u64) -> u64 @export {
    if k >= 4u64 { return 0u64 }
    return MB_SP_NE0[k]
}

/* the selection bias of the SELECTED layer: 256 f32s, served as (m,e) */
var MB_BS_M : [i64; 256]
var MB_BS_E : [i64; 256]
fn mb_moe_bias_load() -> u64 @export {
    let lay : u64 = MB_ME_BASE / 6u64
    if MB_EB_F[lay] == 0u8 { return 1u64 }
    if MB_EB_NE0[lay] != 256u64 { return 1u64 }
    mb_mkpath(MB_EB_SH[lay])
    let f : u64 = fopen((&MB_PATH) as u64, "rb" as u64)
    if f == 0u64 { return 1u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    mb_seek_abs(MB_EB_DB[lay] + MB_EB_OFF[lay])
    let mut i : u64 = 0u64
    while i < 256u64 {
        let bits : u64 = mb_u32()
        let m : i64 = mb_f32m(bits)
        if m == 4611686018427387904i64 {
            fclose(f)
            return 1u64
        }
        MB_BS_M[i] = m
        MB_BS_E[i] = MB_F32E
        i = i + 1u64
    }
    let mut rr : u64 = 0u64
    if MB_IOERR != 0u8 { rr = 1u64 }
    fclose(f)
    return rr
}
fn mb_bs_m(i: u64) -> i64 @export {
    if i >= 256u64 { return 0i64 }
    return MB_BS_M[i]
}
fn mb_bs_e(i: u64) -> i64 @export {
    if i >= 256u64 { return 0i64 }
    return MB_BS_E[i]
}

/* a 2D shared-expert projection (roles 3,4,5: no expert dim, no offset) */
fn mb_pb_run_shexp(role: u64, n: u64, rows: u64, bank: u64, passes: u64) -> u64 @export {
    if role < 3u64 { return 2u64 }
    if role >= 6u64 { return 2u64 }
    if passes != 3u64 { return 2u64 }
    let ab : u64 = MB_ME_BASE + role
    if MB_ME_F[ab] == 0u8 { return 3u64 }
    if MB_TSETL != n { return 1u64 }
    if MB_TSETH != n { return 1u64 }
    if MB_TSETX != n { return 1u64 }
    if n > 18432u64 { return 2u64 }
    if MB_ME_NE0[ab] != n { return 2u64 }
    if MB_ME_NE[ab] / n != rows { return 2u64 }
    if rows % 4u64 != 0u64 { return 2u64 }
    let mut bcap : u64 = 7168u64
    if bank == 1u64 { bcap = 18432u64 }
    if bank == 2u64 { bcap = 18432u64 }
    if bank == 4u64 { bcap = 32768u64 }
    if rows > bcap { return 2u64 }
    let bv : u64 = mb_tbv(MB_ME_TYPE[ab])
    if bv != 256u64 { return 2u64 }
    MB_PBSLOT = ab
    MB_PBN = n
    MB_PBROWS = rows
    MB_PBBANK = bank
    MB_PBPASS = passes
    MB_PBSRC = 1u64
    MB_PBEXP = 0u64
    return mb_pb_launch(MB_ME_SH[ab])
}

/* ============ THE BATHYS WEAVE: the deep anchor through the loom ============
 * The DIEXODOS carries ONE deep center (14-limb, 896-bit) through every
 * matvec of the walk.  Weights are EXACT one-limb dyadics (mant * 2^-24
 * from the quant decode), so a deep madd is 14 mul64s; each row is an
 * EXACT integer accumulation on a common grid with ONE truncation at the
 * end -- fresh error <= 1 ulp of the row, and THE LEDGER records the
 * row-mass amplification Sigma|w| so the head can PROVE its total width:
 * width_final <= Sigma_L fresh_L * Prod_{L'>L} amp_L'.  The deep thought
 * and the deep out bank live here beside the interval thought; probole
 * computes the walk's algebra through the peras deep exports and drives
 * these faces. */
var MB_DTM : [u64; 258048]
var MB_DTS : [i64; 18432]
var MB_DTE : [i64; 18432]
var MB_DTN : u64 = 0u64
var MB_DOM : [u64; 458752]
var MB_DOS : [i64; 32768]
var MB_DOE : [i64; 32768]
var MB_DON : u64 = 0u64
/* the ledger of the last run: max row amp (Sigma|w| at 2^-24), rows,
 * and the max output lsb-exponent (one truncation = one ulp = 2^e) */
var MB_DZ_AMP : u64 = 0u64
var MB_DZ_ROWS : u64 = 0u64
var MB_DZ_OEMAX : i64 = 0i64 - 1000000i64
/* THE TACHOS KNOB: active low-limb floor.  The deep dot multiplies only
 * the thought limbs at or above MB_DZ_LO (0 = full 896-bit certified;
 * 12 = the top 2 limbs = the fast tier).  The fast tier SWEARS its
 * deviation is at most one ulp of limb MB_DZ_LO -- it never lies that
 * it is exact; the certified walk sets LO=0 and the whole 896 bits ride. */
var MB_DZ_LO : u64 = 0u64
fn mb_dz_set_lo(lo: u64) -> u64 @export {
    if lo >= 14u64 { return 1u64 }
    MB_DZ_LO = lo
    return 0u64
}
fn mb_dz_lo() -> u64 @export { return MB_DZ_LO }
/* dot scratch: positive and negative magnitude windows (26 limbs) */
var MB_DZP : [u64; 26]
var MB_DZN : [u64; 26]
/* the dot result channel */
var MB_DRS : i64 = 0i64
var MB_DRM : [u64; 14]
var MB_DRE : i64 = 0i64
/* THE DEEP LOOM: four weavers over the deep dot -- rows never split,
 * each weaver owns its windows, its result channel, its ledger; the
 * static partition theorem yet again (determinism owes nothing to
 * timing because no two weavers touch one row) */
var MB_DZPW : [u64; 104]
var MB_DZNW : [u64; 104]
var MB_DRSW : [i64; 4]
var MB_DRMW : [u64; 56]
var MB_DREW : [i64; 4]
var MB_DZ_AMPW : [u64; 4]
var MB_DZ_OEW : [i64; 4]
var MB_DZRUN_N : u64 = 0u64

fn mb_dz_set(i: u64, k: u64, v: u64) -> u64 @export {
    if i >= 18432u64 { return 1u64 }
    if k >= 14u64 { return 1u64 }
    MB_DTM[i * 14u64 + k] = v
    return 0u64
}
fn mb_dz_sete(i: u64, s: i64, e: i64) -> u64 @export {
    if i >= 18432u64 { return 1u64 }
    MB_DTS[i] = s
    MB_DTE[i] = e
    return 0u64
}
fn mb_dz_mark(n: u64) -> u64 @export {
    MB_DTN = n
    return 0u64
}
fn mb_dz_x_l(i: u64, k: u64) -> u64 @export {
    if i >= 18432u64 { return 0u64 }
    if k >= 14u64 { return 0u64 }
    return MB_DTM[i * 14u64 + k]
}
fn mb_dz_x_s(i: u64) -> i64 @export {
    if i >= 18432u64 { return 0i64 }
    return MB_DTS[i]
}
fn mb_dz_x_e(i: u64) -> i64 @export {
    if i >= 18432u64 { return 0i64 }
    return MB_DTE[i]
}
fn mb_dz_o_l(i: u64, k: u64) -> u64 @export {
    if i >= 32768u64 { return 0u64 }
    if k >= 14u64 { return 0u64 }
    return MB_DOM[i * 14u64 + k]
}
fn mb_dz_o_s(i: u64) -> i64 @export {
    if i >= 32768u64 { return 0i64 }
    return MB_DOS[i]
}
fn mb_dz_o_e(i: u64) -> i64 @export {
    if i >= 32768u64 { return 0i64 }
    return MB_DOE[i]
}
fn mb_dz_amp() -> u64 @export { return MB_DZ_AMP }
fn mb_dz_oemax() -> i64 @export { return MB_DZ_OEMAX }
fn mb_dz_bos() -> u64 @export {
    if MB_BOSF == 0u8 { return 0u64 - 1u64 }
    return MB_BOS
}
/* THE LEXIS serves: the surface form of token t, byte by byte */
fn mb_tok_n() -> u64 @export { return MB_TKN }
fn mb_tok_len(t: u64) -> u64 @export {
    if MB_TKF == 0u8 { return 0u64 }
    if t >= MB_TKN { return 0u64 }
    return MB_TKLEN[t]
}
fn mb_tok_byte(t: u64, i: u64) -> u8 @export {
    if MB_TKF == 0u8 { return 0u8 }
    if t >= MB_TKN { return 0u8 }
    if i >= MB_TKLEN[t] { return 0u8 }
    return MB_TKT[MB_TKOFF[t] + i]
}

/* decode one weight row into MB_GW: src 0 = census slot g, src 1 = the
 * MoE registry at ABSOLUTE index g with the expert row offset */
fn mb_dz_wrow(src: u64, g: u64, expert: u64, rows: u64, row: u64) -> u64 {
    let mut ty : u64 = MB_G_TYPE[g]
    let mut ne0 : u64 = MB_G_NE0[g]
    let mut tdb : u64 = MB_G_DB[g]
    let mut toff : u64 = MB_G_OFF[g]
    let mut prow : u64 = row
    if src == 1u64 {
        ty = MB_ME_TYPE[g]
        ne0 = MB_ME_NE0[g]
        tdb = MB_ME_DB[g]
        toff = MB_ME_OFF[g]
        prow = row + expert * rows
    }
    if src == 2u64 {
        ty = MB_SP_TYPE[g]
        ne0 = MB_SP_NE0[g]
        tdb = MB_SP_DB[g]
        toff = MB_SP_OFF[g]
    }
    let bb : u64 = mb_tbb(ty)
    let bv : u64 = mb_tbv(ty)
    if bv != 256u64 { return 1u64 }
    let bpr : u64 = ne0 / 256u64
    let mut b : u64 = 0u64
    while b < bpr {
        let abs : u64 = tdb + toff + (prow * bpr + b) * bb
        if mb_wread(0u64, abs, bb) != 0u64 { return 1u64 }
        if mb_wdec(0u64, ty, 0u64) != 0u64 { return 1u64 }
        let mut e : u64 = 0u64
        while e < 256u64 {
            MB_GW[b * 256u64 + e] = MB_LVA[e]
            e = e + 1u64
        }
        b = b + 1u64
    }
    return 0u64
}

/* the deep dot: acc = Sigma w_i * X_i, weights i64 at 2^-24, X the deep
 * thought.  Exact mul-shift-accumulate on the emin grid; ONE truncation. */
fn mb_dz_dot(n: u64) -> u64 {
    /* the grid: emin over live pairs; the span guarded */
    let mut emin : i64 = 1000000i64
    let mut emax : i64 = 0i64 - 1000000i64
    let mut amp : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n {
        let w : i64 = MB_GW[i]
        if w != 0i64 {
            let mut aw : u64 = w as u64
            if w < 0i64 { aw = (0i64 - w) as u64 }
            amp = amp + aw
            if MB_DTS[i] != 0i64 {
                let e : i64 = MB_DTE[i]
                if e < emin { emin = e }
                if e > emax { emax = e }
            }
        }
        i = i + 1u64
    }
    if amp > MB_DZ_AMP { MB_DZ_AMP = amp }
    if emin > emax {
        MB_DRS = 0i64
        let mut z : u64 = 0u64
        while z < 14u64 {
            MB_DRM[z] = 0u64
            z = z + 1u64
        }
        MB_DRE = 0i64
        return 0u64
    }
    if (emax - emin) > 512i64 { return 1u64 }
    let mut k : u64 = 0u64
    while k < 26u64 {
        MB_DZP[k] = 0u64
        MB_DZN[k] = 0u64
        k = k + 1u64
    }
    i = 0u64
    while i < n {
        let w : i64 = MB_GW[i]
        if w != 0i64 {
            if MB_DTS[i] != 0i64 {
                let mut aw : u64 = w as u64
                let mut neg : u64 = 0u64
                if w < 0i64 {
                    aw = (0i64 - w) as u64
                    neg = 1u64
                }
                if MB_DTS[i] < 0i64 { neg = 1u64 - neg }
                let d : u64 = (MB_DTE[i] - emin) as u64
                let lw : u64 = d / 64u64
                let lb : u64 = d % 64u64
                /* product (live X limbs * aw) shifted into the window;
                 * the carry never crosses limbs here (each limb's own
                 * ripple closes it), so a zero limb is skipped cleanly */
                let base : u64 = i * 14u64
                let mut j : u64 = MB_DZ_LO
                while j < 14u64 {
                    let xj : u64 = MB_DTM[base + j]
                    if xj != 0u64 {
                        mb_mul64(xj, aw)
                        let plo : u64 = MB_MLO
                        let phi : u64 = MB_MHI
                        /* add (phi:plo) at limb lw+j, bit lb */
                        let v0 : u64 = plo << lb
                        let mut v1 : u64 = phi << lb
                        if lb != 0u64 {
                            v1 = v1 | (plo >> (64u64 - lb))
                        }
                        let mut v2 : u64 = 0u64
                        if lb != 0u64 { v2 = phi >> (64u64 - lb) }
                        let p : u64 = lw + j
                        if neg == 0u64 {
                            let t : u64 = MB_DZP[p] + v0
                            let mut c : u64 = 0u64
                            if t < v0 { c = 1u64 }
                            MB_DZP[p] = t
                            let s1 : u64 = MB_DZP[p + 1u64] + v1 + c
                            let mut c2 : u64 = 0u64
                            if s1 < v1 { c2 = 1u64 }
                            if s1 == v1 {
                                if c == 1u64 {
                                    if MB_DZP[p + 1u64] != 0u64 { c2 = 1u64 }
                                }
                            }
                            MB_DZP[p + 1u64] = s1
                            let s2 : u64 = MB_DZP[p + 2u64] + v2 + c2
                            let mut c3 : u64 = 0u64
                            if s2 < v2 { c3 = 1u64 }
                            if s2 == v2 {
                                if c2 == 1u64 {
                                    if MB_DZP[p + 2u64] != 0u64 { c3 = 1u64 }
                                }
                            }
                            MB_DZP[p + 2u64] = s2
                            let mut q : u64 = p + 3u64
                            while c3 == 1u64 {
                                MB_DZP[q] = MB_DZP[q] + 1u64
                                c3 = 0u64
                                if MB_DZP[q] == 0u64 { c3 = 1u64 }
                                q = q + 1u64
                            }
                        }
                        if neg == 1u64 {
                            let t : u64 = MB_DZN[p] + v0
                            let mut c : u64 = 0u64
                            if t < v0 { c = 1u64 }
                            MB_DZN[p] = t
                            let s1b : u64 = MB_DZN[p + 1u64] + v1 + c
                            let mut c2b : u64 = 0u64
                            if s1b < v1 { c2b = 1u64 }
                            if s1b == v1 {
                                if c == 1u64 {
                                    if MB_DZN[p + 1u64] != 0u64 { c2b = 1u64 }
                                }
                            }
                            MB_DZN[p + 1u64] = s1b
                            let s2b : u64 = MB_DZN[p + 2u64] + v2 + c2b
                            let mut c3b : u64 = 0u64
                            if s2b < v2 { c3b = 1u64 }
                            if s2b == v2 {
                                if c2b == 1u64 {
                                    if MB_DZN[p + 2u64] != 0u64 { c3b = 1u64 }
                                }
                            }
                            MB_DZN[p + 2u64] = s2b
                            let mut qb : u64 = p + 3u64
                            while c3b == 1u64 {
                                MB_DZN[qb] = MB_DZN[qb] + 1u64
                                c3b = 0u64
                                if MB_DZN[qb] == 0u64 { c3b = 1u64 }
                                qb = qb + 1u64
                            }
                        }
                    }
                    j = j + 1u64
                }
            }
        }
        i = i + 1u64
    }
    /* P - N (or N - P), then ONE truncation to 14 limbs */
    let mut cmp : i64 = 0i64
    k = 26u64
    while k != 0u64 {
        k = k - 1u64
        if cmp == 0i64 {
            if MB_DZP[k] > MB_DZN[k] { cmp = 1i64 }
            if MB_DZP[k] < MB_DZN[k] { cmp = 0i64 - 1i64 }
        }
    }
    if cmp == 0i64 {
        MB_DRS = 0i64
        let mut z2 : u64 = 0u64
        while z2 < 14u64 {
            MB_DRM[z2] = 0u64
            z2 = z2 + 1u64
        }
        MB_DRE = 0i64
        return 0u64
    }
    let mut br : u64 = 0u64
    k = 0u64
    while k < 26u64 {
        let mut a : u64 = MB_DZP[k]
        let mut b2 : u64 = MB_DZN[k]
        if cmp < 0i64 {
            a = MB_DZN[k]
            b2 = MB_DZP[k]
        }
        let d1 : u64 = a - b2
        let mut nb : u64 = 0u64
        if a < b2 { nb = 1u64 }
        let d2 : u64 = d1 - br
        if d1 < br { nb = 1u64 }
        MB_DZP[k] = d2
        br = nb
        k = k + 1u64
    }
    /* normalize: top limb, top bit; truncate low bits (the fresh ulp) */
    let mut t2 : u64 = 26u64
    k = 26u64
    while k != 0u64 {
        k = k - 1u64
        if t2 == 26u64 {
            if MB_DZP[k] != 0u64 { t2 = k }
        }
    }
    let mut bl : u64 = 0u64
    let mut tv : u64 = MB_DZP[t2]
    while tv != 0u64 {
        tv = tv >> 1u64
        bl = bl + 1u64
    }
    let top : u64 = t2 * 64u64 + bl - 1u64
    /* destination top = 895 within the 14-limb result */
    let mut sh : i64 = (top as i64) - 895i64
    let mut w2 : u64 = 0u64
    let mut b3 : u64 = 0u64
    if sh >= 0i64 {
        w2 = (sh as u64) / 64u64
        b3 = (sh as u64) % 64u64
        k = 0u64
        while k < 14u64 {
            let src2 : u64 = k + w2
            let mut v : u64 = 0u64
            if src2 < 26u64 {
                v = MB_DZP[src2] >> b3
                if b3 != 0u64 {
                    if src2 + 1u64 < 26u64 { v = v | (MB_DZP[src2 + 1u64] << (64u64 - b3)) }
                }
            }
            MB_DRM[k] = v
            k = k + 1u64
        }
    }
    if sh < 0i64 {
        let shl : u64 = (0i64 - sh) as u64
        w2 = shl / 64u64
        b3 = shl % 64u64
        k = 14u64
        while k != 0u64 {
            k = k - 1u64
            let mut v : u64 = 0u64
            if k >= w2 {
                let src3 : u64 = k - w2
                v = MB_DZP[src3] << b3
                if b3 != 0u64 {
                    if src3 != 0u64 { v = v | (MB_DZP[src3 - 1u64] >> (64u64 - b3)) }
                }
            }
            MB_DRM[k] = v
        }
    }
    MB_DRS = 1i64
    if cmp < 0i64 { MB_DRS = 0i64 - 1i64 }
    /* value = window-int * 2^(emin-24); the 14-limb result holds window
     * bits [top-895 .. top], so value = result-int * 2^(emin-24+top-895) */
    MB_DRE = emin - 24i64 + (top as i64) - 895i64
    return 0u64
}

/* the WORKER deep dot: weaver w's row (already decoded into its GWW
 * slice) against the deep thought -- the same law as mb_dz_dot with
 * every channel worker-private */
fn mb_dz_dot_w(w: u64, n: u64) -> u64 {
    let gb : u64 = w * 18432u64
    let pb : u64 = w * 26u64
    let mut emin : i64 = 1000000i64
    let mut emax : i64 = 0i64 - 1000000i64
    let mut amp : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n {
        let wv : i64 = MB_GWW[gb + i]
        if wv != 0i64 {
            let mut aw : u64 = wv as u64
            if wv < 0i64 { aw = (0i64 - wv) as u64 }
            amp = amp + aw
            if MB_DTS[i] != 0i64 {
                let e : i64 = MB_DTE[i]
                if e < emin { emin = e }
                if e > emax { emax = e }
            }
        }
        i = i + 1u64
    }
    if amp > MB_DZ_AMPW[w] { MB_DZ_AMPW[w] = amp }
    if emin > emax {
        MB_DRSW[w] = 0i64
        let mut z : u64 = 0u64
        while z < 14u64 {
            MB_DRMW[w * 14u64 + z] = 0u64
            z = z + 1u64
        }
        MB_DREW[w] = 0i64
        return 0u64
    }
    if (emax - emin) > 512i64 { return 1u64 }
    let mut k : u64 = 0u64
    while k < 26u64 {
        MB_DZPW[pb + k] = 0u64
        MB_DZNW[pb + k] = 0u64
        k = k + 1u64
    }
    i = 0u64
    while i < n {
        let wv : i64 = MB_GWW[gb + i]
        if wv != 0i64 {
            if MB_DTS[i] != 0i64 {
                let mut aw : u64 = wv as u64
                let mut neg : u64 = 0u64
                if wv < 0i64 {
                    aw = (0i64 - wv) as u64
                    neg = 1u64
                }
                if MB_DTS[i] < 0i64 { neg = 1u64 - neg }
                let d : u64 = (MB_DTE[i] - emin) as u64
                let lw : u64 = d / 64u64
                let lb : u64 = d % 64u64
                let base : u64 = i * 14u64
                let mut j : u64 = MB_DZ_LO
                while j < 14u64 {
                    let xj : u64 = MB_DTM[base + j]
                    if xj != 0u64 {
                        mb_wmul64(w, xj, aw)
                        let plo : u64 = MB_LML[w]
                        let phi : u64 = MB_LMH[w]
                        let v0 : u64 = plo << lb
                        let mut v1 : u64 = phi << lb
                        if lb != 0u64 {
                            v1 = v1 | (plo >> (64u64 - lb))
                        }
                        let mut v2 : u64 = 0u64
                        if lb != 0u64 { v2 = phi >> (64u64 - lb) }
                        let p : u64 = pb + lw + j
                        if neg == 0u64 {
                            let t : u64 = MB_DZPW[p] + v0
                            let mut c : u64 = 0u64
                            if t < v0 { c = 1u64 }
                            MB_DZPW[p] = t
                            let s1 : u64 = MB_DZPW[p + 1u64] + v1 + c
                            let mut c2 : u64 = 0u64
                            if s1 < v1 { c2 = 1u64 }
                            if s1 == v1 {
                                if c == 1u64 {
                                    if MB_DZPW[p + 1u64] != 0u64 { c2 = 1u64 }
                                }
                            }
                            MB_DZPW[p + 1u64] = s1
                            let s2 : u64 = MB_DZPW[p + 2u64] + v2 + c2
                            let mut c3 : u64 = 0u64
                            if s2 < v2 { c3 = 1u64 }
                            if s2 == v2 {
                                if c2 == 1u64 {
                                    if MB_DZPW[p + 2u64] != 0u64 { c3 = 1u64 }
                                }
                            }
                            MB_DZPW[p + 2u64] = s2
                            let mut q : u64 = p + 3u64
                            while c3 == 1u64 {
                                MB_DZPW[q] = MB_DZPW[q] + 1u64
                                c3 = 0u64
                                if MB_DZPW[q] == 0u64 { c3 = 1u64 }
                                q = q + 1u64
                            }
                        }
                        if neg == 1u64 {
                            let t : u64 = MB_DZNW[p] + v0
                            let mut c : u64 = 0u64
                            if t < v0 { c = 1u64 }
                            MB_DZNW[p] = t
                            let s1b : u64 = MB_DZNW[p + 1u64] + v1 + c
                            let mut c2b : u64 = 0u64
                            if s1b < v1 { c2b = 1u64 }
                            if s1b == v1 {
                                if c == 1u64 {
                                    if MB_DZNW[p + 1u64] != 0u64 { c2b = 1u64 }
                                }
                            }
                            MB_DZNW[p + 1u64] = s1b
                            let s2b : u64 = MB_DZNW[p + 2u64] + v2 + c2b
                            let mut c3b : u64 = 0u64
                            if s2b < v2 { c3b = 1u64 }
                            if s2b == v2 {
                                if c2b == 1u64 {
                                    if MB_DZNW[p + 2u64] != 0u64 { c3b = 1u64 }
                                }
                            }
                            MB_DZNW[p + 2u64] = s2b
                            let mut qb : u64 = p + 3u64
                            while c3b == 1u64 {
                                MB_DZNW[qb] = MB_DZNW[qb] + 1u64
                                c3b = 0u64
                                if MB_DZNW[qb] == 0u64 { c3b = 1u64 }
                                qb = qb + 1u64
                            }
                        }
                    }
                    j = j + 1u64
                }
            }
        }
        i = i + 1u64
    }
    /* P - N, one truncation, into the worker channel */
    let mut cmp : i64 = 0i64
    k = 26u64
    while k != 0u64 {
        k = k - 1u64
        if cmp == 0i64 {
            if MB_DZPW[pb + k] > MB_DZNW[pb + k] { cmp = 1i64 }
            if MB_DZPW[pb + k] < MB_DZNW[pb + k] { cmp = 0i64 - 1i64 }
        }
    }
    if cmp == 0i64 {
        MB_DRSW[w] = 0i64
        let mut z2 : u64 = 0u64
        while z2 < 14u64 {
            MB_DRMW[w * 14u64 + z2] = 0u64
            z2 = z2 + 1u64
        }
        MB_DREW[w] = 0i64
        return 0u64
    }
    let mut br : u64 = 0u64
    k = 0u64
    while k < 26u64 {
        let mut a : u64 = MB_DZPW[pb + k]
        let mut b2 : u64 = MB_DZNW[pb + k]
        if cmp < 0i64 {
            a = MB_DZNW[pb + k]
            b2 = MB_DZPW[pb + k]
        }
        let d1 : u64 = a - b2
        let mut nb : u64 = 0u64
        if a < b2 { nb = 1u64 }
        let d2 : u64 = d1 - br
        if d1 < br { nb = 1u64 }
        MB_DZPW[pb + k] = d2
        br = nb
        k = k + 1u64
    }
    let mut t2 : u64 = 26u64
    k = 26u64
    while k != 0u64 {
        k = k - 1u64
        if t2 == 26u64 {
            if MB_DZPW[pb + k] != 0u64 { t2 = k }
        }
    }
    let mut bl : u64 = 0u64
    let mut tv : u64 = MB_DZPW[pb + t2]
    while tv != 0u64 {
        tv = tv >> 1u64
        bl = bl + 1u64
    }
    let top : u64 = t2 * 64u64 + bl - 1u64
    let sh : i64 = (top as i64) - 895i64
    if sh >= 0i64 {
        let w2 : u64 = (sh as u64) / 64u64
        let b3 : u64 = (sh as u64) % 64u64
        k = 0u64
        while k < 14u64 {
            let src2 : u64 = k + w2
            let mut v : u64 = 0u64
            if src2 < 26u64 {
                v = MB_DZPW[pb + src2] >> b3
                if b3 != 0u64 {
                    if src2 + 1u64 < 26u64 { v = v | (MB_DZPW[pb + src2 + 1u64] << (64u64 - b3)) }
                }
            }
            MB_DRMW[w * 14u64 + k] = v
            k = k + 1u64
        }
    }
    if sh < 0i64 {
        let shl : u64 = (0i64 - sh) as u64
        let w2 : u64 = shl / 64u64
        let b3 : u64 = shl % 64u64
        k = 14u64
        while k != 0u64 {
            k = k - 1u64
            let mut v : u64 = 0u64
            if k >= w2 {
                let src3 : u64 = k - w2
                v = MB_DZPW[pb + src3] << b3
                if b3 != 0u64 {
                    if src3 != 0u64 { v = v | (MB_DZPW[pb + src3 - 1u64] >> (64u64 - b3)) }
                }
            }
            MB_DRMW[w * 14u64 + k] = v
        }
    }
    MB_DRSW[w] = 1i64
    if cmp < 0i64 { MB_DRSW[w] = 0i64 - 1i64 }
    let dre : i64 = emin - 24i64 + (top as i64) - 895i64
    MB_DREW[w] = dre
    if MB_DREW[w] > MB_DZ_OEW[w] { MB_DZ_OEW[w] = MB_DREW[w] }
    return 0u64
}

/* the deep weaver: rows [w*rows/4, (w+1)*rows/4) decoded and dotted */
fn mb_dz_worker(arg: u64) -> u32 {
    let w : u64 = arg
    let g : u64 = MB_PBSLOT
    let n : u64 = MB_DZRUN_N
    let slice : u64 = MB_PBROWS / 4u64
    let start : u64 = w * slice
    let endr : u64 = start + slice
    let mut r : u64 = start
    while r < endr {
        if mb_pb_wrow(w, g, r) != 0u64 {
            MB_LRC[w] = 382u64
            return 0u32
        }
        if mb_dz_dot_w(w, n) != 0u64 {
            MB_LRC[w] = 381u64
            return 0u32
        }
        MB_DOS[r] = MB_DRSW[w]
        MB_DOE[r] = MB_DREW[w]
        let mut k : u64 = 0u64
        while k < 14u64 {
            MB_DOM[r * 14u64 + k] = MB_DRMW[w * 14u64 + k]
            k = k + 1u64
        }
        r = r + 1u64
    }
    MB_LRC[w] = 0u64
    return 0u32
}

/* the four-weaver deep launch (config in the MB_PB premises and
 * MB_DZRUN_N); folds the per-worker ledgers on join */
fn mb_dz_launch(shard: u64) -> u64 {
    let mut w : u64 = 0u64
    while w < 4u64 {
        MB_DZ_AMPW[w] = 0u64
        MB_DZ_OEW[w] = 0i64 - 1000000i64
        w = w + 1u64
    }
    mb_mkpath(shard)
    w = 0u64
    while w < 4u64 {
        MB_LFILE[w] = fopen((&MB_PATH) as u64, "rb" as u64)
        if MB_LFILE[w] == 0u64 {
            let mut c : u64 = 0u64
            while c < w {
                fclose(MB_LFILE[c])
                c = c + 1u64
            }
            return 1u64
        }
        w = w + 1u64
    }
    let entry : u64 = mb_dz_worker as u64
    w = 0u64
    while w < 4u64 {
        MB_LRC[w] = 999u64
        MB_LH[w] = CreateThread(0u64, 0u64, entry, w, 0u64, 0u64)
        if MB_LH[w] == 0u64 {
            let mut j : u64 = 0u64
            while j < w {
                WaitForSingleObject(MB_LH[j], 0xFFFFFFFFu32)
                CloseHandle(MB_LH[j])
                j = j + 1u64
            }
            let mut c2 : u64 = 0u64
            while c2 < 4u64 {
                fclose(MB_LFILE[c2])
                c2 = c2 + 1u64
            }
            return 1u64
        }
        w = w + 1u64
    }
    w = 0u64
    while w < 4u64 {
        WaitForSingleObject(MB_LH[w], 0xFFFFFFFFu32)
        CloseHandle(MB_LH[w])
        w = w + 1u64
    }
    w = 0u64
    while w < 4u64 {
        fclose(MB_LFILE[w])
        w = w + 1u64
    }
    w = 0u64
    while w < 4u64 {
        if MB_LRC[w] != 0u64 { return 1u64 }
        w = w + 1u64
    }
    w = 0u64
    while w < 4u64 {
        if MB_DZ_AMPW[w] > MB_DZ_AMP { MB_DZ_AMP = MB_DZ_AMPW[w] }
        if MB_DZ_OEW[w] > MB_DZ_OEMAX { MB_DZ_OEMAX = MB_DZ_OEW[w] }
        w = w + 1u64
    }
    return 0u64
}

/* one deep projection: rows of slot/expert against the deep thought */
fn mb_dz_run(slot: u64, n: u64, rows: u64) -> u64 @export {
    if slot >= 732u64 { return 2u64 }
    if MB_G_F[slot] == 0u8 { return 3u64 }
    if MB_DTN != n { return 1u64 }
    if n > 18432u64 { return 2u64 }
    if rows > 32768u64 { return 2u64 }
    if MB_G_NE0[slot] != n { return 2u64 }
    if MB_G_NE[slot] / n != rows { return 2u64 }
    MB_DZ_AMP = 0u64
    MB_DZ_OEMAX = 0i64 - 1000000i64
    /* the deep loom carries every 4-divisible run; the remainder walks
     * sequentially (same law, one weaver) */
    if rows % 4u64 == 0u64 {
        MB_PBSLOT = slot
        MB_PBROWS = rows
        MB_PBSRC = 0u64
        MB_PBEXP = 0u64
        MB_DZRUN_N = n
        if mb_dz_launch(MB_G_SH[slot]) != 0u64 { return 1u64 }
        MB_DON = rows
        MB_DZ_ROWS = rows
        return 0u64
    }
    mb_mkpath(MB_G_SH[slot])
    MB_LFILE[0u64] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0u64] == 0u64 { return 1u64 }
    let mut r : u64 = 0u64
    while r < rows {
        if mb_dz_wrow(0u64, slot, 0u64, rows, r) != 0u64 {
            fclose(MB_LFILE[0u64])
            return 1u64
        }
        if mb_dz_dot(n) != 0u64 {
            fclose(MB_LFILE[0u64])
            return 1u64
        }
        MB_DOS[r] = MB_DRS
        MB_DOE[r] = MB_DRE
        if MB_DRS != 0i64 {
            if MB_DRE > MB_DZ_OEMAX { MB_DZ_OEMAX = MB_DRE }
        }
        let mut k : u64 = 0u64
        while k < 14u64 {
            MB_DOM[r * 14u64 + k] = MB_DRM[k]
            k = k + 1u64
        }
        r = r + 1u64
    }
    fclose(MB_LFILE[0u64])
    MB_DON = rows
    MB_DZ_ROWS = rows
    return 0u64
}

/* the deep MoE projection at the SELECTED layer */
fn mb_dz_run_exp(role: u64, expert: u64, n: u64, rows: u64) -> u64 @export {
    if role >= 6u64 { return 2u64 }
    let ab : u64 = MB_ME_BASE + role
    if MB_ME_F[ab] == 0u8 { return 3u64 }
    if MB_DTN != n { return 1u64 }
    if n > 18432u64 { return 2u64 }
    if rows > 18432u64 { return 2u64 }
    if MB_ME_NE0[ab] != n { return 2u64 }
    if role < 3u64 {
        if MB_ME_NE[ab] / n / 256u64 != rows { return 2u64 }
        if expert >= 256u64 { return 2u64 }
    }
    if role >= 3u64 {
        if MB_ME_NE[ab] / n != rows { return 2u64 }
        if expert != 0u64 { return 2u64 }
    }
    MB_DZ_AMP = 0u64
    MB_DZ_OEMAX = 0i64 - 1000000i64
    if rows % 4u64 == 0u64 {
        MB_PBSLOT = ab
        MB_PBROWS = rows
        MB_PBSRC = 1u64
        MB_PBEXP = expert
        MB_DZRUN_N = n
        if mb_dz_launch(MB_ME_SH[ab]) != 0u64 { return 1u64 }
        MB_DON = rows
        MB_DZ_ROWS = rows
        return 0u64
    }
    mb_mkpath(MB_ME_SH[ab])
    MB_LFILE[0u64] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0u64] == 0u64 { return 1u64 }
    let mut r : u64 = 0u64
    while r < rows {
        if mb_dz_wrow(1u64, ab, expert, rows, r) != 0u64 {
            fclose(MB_LFILE[0u64])
            return 1u64
        }
        if mb_dz_dot(n) != 0u64 {
            fclose(MB_LFILE[0u64])
            return 1u64
        }
        MB_DOS[r] = MB_DRS
        MB_DOE[r] = MB_DRE
        if MB_DRS != 0i64 {
            if MB_DRE > MB_DZ_OEMAX { MB_DZ_OEMAX = MB_DRE }
        }
        let mut k : u64 = 0u64
        while k < 14u64 {
            MB_DOM[r * 14u64 + k] = MB_DRM[k]
            k = k + 1u64
        }
        r = r + 1u64
    }
    fclose(MB_LFILE[0u64])
    MB_DON = rows
    MB_DZ_ROWS = rows
    return 0u64
}

/* the lm head and other specials, driven by the same deep law */
fn mb_dz_run_sp(k: u64, n: u64, rows: u64) -> u64 @export {
    if k >= 4u64 { return 2u64 }
    if MB_SP_F[k] == 0u8 { return 3u64 }
    if MB_DTN != n { return 1u64 }
    if n > 18432u64 { return 2u64 }
    if rows > 18432u64 { return 2u64 }
    if MB_SP_NE0[k] != n { return 2u64 }
    if MB_SP_NE[k] / n != rows { return 2u64 }
    mb_mkpath(MB_SP_SH[k])
    MB_LFILE[0u64] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0u64] == 0u64 { return 1u64 }
    MB_DZ_AMP = 0u64
    MB_DZ_OEMAX = 0i64 - 1000000i64
    let mut r : u64 = 0u64
    while r < rows {
        if mb_dz_wrow(2u64, k, 0u64, rows, r) != 0u64 {
            fclose(MB_LFILE[0u64])
            return 1u64
        }
        if mb_dz_dot(n) != 0u64 {
            fclose(MB_LFILE[0u64])
            return 1u64
        }
        MB_DOS[r] = MB_DRS
        MB_DOE[r] = MB_DRE
        if MB_DRS != 0i64 {
            if MB_DRE > MB_DZ_OEMAX { MB_DZ_OEMAX = MB_DRE }
        }
        let mut k2 : u64 = 0u64
        while k2 < 14u64 {
            MB_DOM[r * 14u64 + k2] = MB_DRM[k2]
            k2 = k2 + 1u64
        }
        r = r + 1u64
    }
    fclose(MB_LFILE[0u64])
    MB_DON = rows
    MB_DZ_ROWS = rows
    return 0u64
}

/* THE KRISIS SWEEP: every lm-head row dotted against the thought, only
 * the podium kept -- the elected token, the runner-up, and the certified
 * gap seed (their centers).  The head has 129280 rows; the out bank
 * holds none of them. */
var MB_KR_TOK : u64 = 0u64
var MB_KR_S : i64 = 0i64
var MB_KR_M : u64 = 0u64
var MB_KR_E : i64 = 0i64
var MB_KR_TOK2 : u64 = 0u64
var MB_KR_S2 : i64 = 0i64
var MB_KR_M2 : u64 = 0u64
var MB_KR_E2 : i64 = 0i64
fn mb_dz_head_cmp(sa: i64, ma: u64, ea: i64, sb: i64, mb2: u64, eb: i64) -> i64 {
    if sa > sb { return 1i64 }
    if sa < sb { return 0i64 - 1i64 }
    if sa == 0i64 { return 0i64 }
    let mut c : i64 = 0i64
    if ea > eb { c = 1i64 }
    if ea < eb { c = 0i64 - 1i64 }
    if c == 0i64 {
        if ma > mb2 { c = 1i64 }
        if ma < mb2 { c = 0i64 - 1i64 }
    }
    if sa < 0i64 { return 0i64 - c }
    return c
}
fn mb_dz_krisis(k: u64, n: u64) -> u64 @export {
    if k >= 4u64 { return 2u64 }
    if MB_SP_F[k] == 0u8 { return 3u64 }
    if MB_DTN != n { return 1u64 }
    if MB_SP_NE0[k] != n { return 2u64 }
    let rows : u64 = MB_SP_NE[k] / n
    mb_mkpath(MB_SP_SH[k])
    MB_LFILE[0u64] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0u64] == 0u64 { return 1u64 }
    MB_DZ_AMP = 0u64
    MB_DZ_OEMAX = 0i64 - 1000000i64
    MB_KR_S = 0i64
    MB_KR_S2 = 0i64
    MB_KR_TOK = 0u64
    MB_KR_TOK2 = 0u64
    let mut seen : u64 = 0u64
    let mut r : u64 = 0u64
    while r < rows {
        if mb_dz_wrow(2u64, k, 0u64, rows, r) != 0u64 {
            fclose(MB_LFILE[0u64])
            return 1u64
        }
        if mb_dz_dot(n) != 0u64 {
            fclose(MB_LFILE[0u64])
            return 1u64
        }
        if MB_DRS != 0i64 {
            if MB_DRE > MB_DZ_OEMAX { MB_DZ_OEMAX = MB_DRE }
        }
        /* the podium: (sign, top-limb, exp) carry the order; ties fall to
         * the earlier token (deterministic).  ONE comparison against the
         * best chooses among three EXCLUSIVE fates -- new best (old best
         * demoted to runner-up), new runner-up, or nothing.  `seen`
         * counts admitted rows: 1 = only a best so far, 2+ = both filled. */
        let cm : u64 = MB_DRM[13u64]
        if seen == 0u64 {
            MB_KR_TOK = r
            MB_KR_S = MB_DRS
            MB_KR_M = cm
            MB_KR_E = MB_DRE
            seen = 1u64
        }
        if seen != 0u64 {
            if r != MB_KR_TOK {
                let cvb : i64 = mb_dz_head_cmp(MB_DRS, cm, MB_DRE, MB_KR_S, MB_KR_M, MB_KR_E)
                if cvb > 0i64 {
                    MB_KR_TOK2 = MB_KR_TOK
                    MB_KR_S2 = MB_KR_S
                    MB_KR_M2 = MB_KR_M
                    MB_KR_E2 = MB_KR_E
                    MB_KR_TOK = r
                    MB_KR_S = MB_DRS
                    MB_KR_M = cm
                    MB_KR_E = MB_DRE
                    seen = 2u64
                }
                if cvb <= 0i64 {
                    let mut isb : u64 = 0u64
                    if seen == 1u64 { isb = 1u64 }
                    if seen != 1u64 {
                        if mb_dz_head_cmp(MB_DRS, cm, MB_DRE, MB_KR_S2, MB_KR_M2, MB_KR_E2) > 0i64 { isb = 1u64 }
                    }
                    if isb == 1u64 {
                        MB_KR_TOK2 = r
                        MB_KR_S2 = MB_DRS
                        MB_KR_M2 = cm
                        MB_KR_E2 = MB_DRE
                        seen = 2u64
                    }
                }
            }
        }
        r = r + 1u64
    }
    fclose(MB_LFILE[0u64])
    return 0u64
}
fn mb_kr_tok() -> u64 @export { return MB_KR_TOK }
fn mb_kr_s() -> i64 @export { return MB_KR_S }
fn mb_kr_m() -> u64 @export { return MB_KR_M }
fn mb_kr_e() -> i64 @export { return MB_KR_E }
fn mb_kr_tok2() -> u64 @export { return MB_KR_TOK2 }
fn mb_kr_s2() -> i64 @export { return MB_KR_S2 }
fn mb_kr_m2() -> u64 @export { return MB_KR_M2 }
fn mb_kr_e2() -> i64 @export { return MB_KR_E2 }

/* the specials' norm weights (output_norm) into the standing NW arrays */
fn mb_ld_normw_sp(k: u64, n: u64) -> u64 @export {
    if k >= 4u64 { return 1u64 }
    if MB_SP_F[k] == 0u8 { return 1u64 }
    if n > 7168u64 { return 1u64 }
    if MB_SP_NE[k] != n { return 1u64 }
    mb_mkpath(MB_SP_SH[k])
    let f : u64 = fopen((&MB_PATH) as u64, "rb" as u64)
    if f == 0u64 { return 1u64 }
    MB_F = f
    MB_IOERR = 0u8
    MB_WBASE = 0u64
    MB_WLEN = 0u64
    MB_WPOS = 0u64
    mb_seek_abs(MB_SP_DB[k] + MB_SP_OFF[k])
    let mut i : u64 = 0u64
    while i < n {
        let bits : u64 = mb_u32()
        let m : i64 = mb_f32m(bits)
        if m == 4611686018427387904i64 {
            fclose(f)
            return 1u64
        }
        MB_NW_M[i] = m
        MB_NW_E[i] = MB_F32E
        i = i + 1u64
    }
    let mut rr : u64 = 0u64
    if MB_IOERR != 0u8 { rr = 1u64 }
    fclose(f)
    return rr
}

/* the light census: registries + conservation only (the diexodos does
 * not need the full battery, only the body's map) */
fn mb_census_only() -> u64 @export {
    MB_REPN = 0u64
    MB_STREAMED = 0u64
    MB_C1_F = 0u8
    MB_C2_F = 0u8
    MB_C3_F = 0u8
    MB_C3_HERE = 0u8
    let mut gz0 : u64 = 0u64
    while gz0 < 732u64 {
        MB_G_F[gz0] = 0u8
        MB_G_HERE[gz0] = 0u8
        gz0 = gz0 + 1u64
    }
    let mut me0 : u64 = 0u64
    while me0 < 366u64 {
        MB_ME_F[me0] = 0u8
        MB_ME_HERE[me0] = 0u8
        me0 = me0 + 1u64
    }
    MB_ME_BASE = 18u64
    let mut rt0 : u64 = 0u64
    while rt0 < 61u64 {
        MB_RT_F[rt0] = 0u8
        MB_RT_HERE[rt0] = 0u8
        MB_EB_F[rt0] = 0u8
        MB_EB_HERE[rt0] = 0u8
        rt0 = rt0 + 1u64
    }
    let mut sp0 : u64 = 0u64
    while sp0 < 4u64 {
        MB_SP_F[sp0] = 0u8
        MB_SP_HERE[sp0] = 0u8
        sp0 = sp0 + 1u64
    }
    MB_NHEAD = 0u64
    MB_NROPE = 0u64
    MB_ARCHN = 0u64
    MB_EMBED = 0u64
    MB_LAYERS = 0u64
    MB_BOSF = 0u8
    MB_SPLITCT_F = 0u8
    MB_SPLITTN_F = 0u8
    let mut h : u64 = 0u64
    while h < 64u64 {
        MB_HIST[h] = 0u64
        h = h + 1u64
    }
    let r2 : u64 = mb_arm362()
    if r2 != 0u64 { return r2 }
    return 0u64
}

/* the first breath: token row t of token_embd, EXACT, into the thought */
fn mb_dz_embed(tok: u64) -> u64 @export {
    if MB_SP_F[0u64] == 0u8 { return 3u64 }
    let n : u64 = MB_SP_NE0[0u64]
    if n > 18432u64 { return 2u64 }
    let rows : u64 = MB_SP_NE[0u64] / n
    if tok >= rows { return 2u64 }
    mb_mkpath(MB_SP_SH[0u64])
    MB_LFILE[0u64] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0u64] == 0u64 { return 1u64 }
    if mb_dz_wrow(2u64, 0u64, 0u64, rows, tok) != 0u64 {
        fclose(MB_LFILE[0u64])
        return 1u64
    }
    fclose(MB_LFILE[0u64])
    let mut i : u64 = 0u64
    while i < n {
        let v : i64 = MB_GW[i]
        let mut k : u64 = 0u64
        while k < 14u64 {
            MB_DTM[i * 14u64 + k] = 0u64
            k = k + 1u64
        }
        if v == 0i64 {
            MB_DTS[i] = 0i64
            MB_DTE[i] = 0i64
        }
        if v != 0i64 {
            let mut av : u64 = v as u64
            let mut s : i64 = 1i64
            if v < 0i64 {
                av = (0i64 - v) as u64
                s = 0i64 - 1i64
            }
            let mut sh : u64 = 0u64
            let mut hh : u64 = av
            while (hh >> 63u64) == 0u64 {
                hh = hh << 1u64
                sh = sh + 1u64
            }
            MB_DTM[i * 14u64 + 13u64] = av << sh
            MB_DTS[i] = s
            MB_DTE[i] = (0i64 - 24i64) - 832i64 - (sh as i64)
        }
        i = i + 1u64
    }
    MB_DTN = n
    return 0u64
}

fn mb_arm375() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    /* the seven organs must all be on the table; foreignness is named */
    let mut g : u64 = 0u64
    while g < 7u64 {
        if MB_G_F[g] == 0u8 {
            mb_rs("the gaze: blk.0 attention absent from the feast (named, lawful)" as u64)
            mb_rb(10u8)
            return 0u64
        }
        g = g + 1u64
    }
    if MB_NHEAD == 0u64 { return 375u64 }
    if MB_NHEAD > 128u64 {
        mb_rs("the gaze: heads exceed the ledger (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    let hw : u64 = MB_G_NE[3] / MB_G_NE0[3] / MB_NHEAD    /* per-head q width */
    if hw <= MB_NROPE { return 375u64 }
    let nope : u64 = hw - MB_NROPE
    let kvw : u64 = MB_G_NE[6] / MB_G_NE0[6] / MB_NHEAD   /* per-head kv width */
    if kvw < nope { return 375u64 }
    if MB_G_NE0[1] != MB_G_NE[0] { return 375u64 }        /* q_a input = embed */
    if MB_G_NE0[3] != MB_G_NE[2] { return 375u64 }        /* q_b input = q_a_norm width */
    if MB_G_NE0[6] != MB_G_NE[5] { return 375u64 }        /* kv_b input = kv_a_norm width */
    let qa_rank : u64 = MB_G_NE[2]
    let kv_rank : u64 = MB_G_NE[5]
    if MB_G_NE0[4] != MB_G_NE[0] { return 375u64 }
    if MB_G_NE[4] / MB_G_NE0[4] < kv_rank + MB_NROPE { return 375u64 }
    /* the one-shard premise for the weight streams (true of this feast;
     * a scattered layout would be a lawful named refusal) */
    g = 1u64
    while g < 7u64 {
        if MB_G_SH[g] != MB_G_SH[1] {
            mb_rs("the gaze: attention scattered across shards (named, lawful)" as u64)
            mb_rb(10u8)
            return 0u64
        }
        g = g + 1u64
    }
    /* preload the three f32 norm vectors */
    if mb_gz_loadf32(0u64, 0u64, MB_G_NE[0]) != 0u64 { return 375u64 }
    if mb_gz_loadf32(2u64, 1u64, qa_rank) != 0u64 { return 375u64 }
    if mb_gz_loadf32(5u64, 2u64, kv_rank) != 0u64 { return 375u64 }
    /* the weight streams live on shard(s): open worker-0 handle per tensor
     * as needed (all gaze tensors sit in shard 1 for this feast; the path
     * is rebuilt per tensor from its OWN shard index) */
    mb_mkpath(MB_G_SH[1])
    MB_LFILE[0] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0] == 0u64 { return 375u64 }
    /* stage B: q_a rows (into BV), then D: kv_a rows (into DV) */
    let mut r : u64 = 0u64
    while r < qa_rank {
        if mb_gz_wrow(1u64, r) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        let rc : u64 = mb_gz_dotrow(MB_G_NE0[1], 0u64)
        if rc != 0u64 {
            fclose(MB_LFILE[0])
            if rc == 2u64 {
                mb_rs("the gaze: refused (guard tripped in stage B -- named)" as u64)
                mb_rb(10u8)
                return 0u64
            }
            return 375u64
        }
        MB_BVS[r] = MB_RRS
        MB_BV0[r] = MB_RR0
        MB_BV1[r] = MB_RR1
        MB_BV2[r] = MB_RR2
        MB_BVE[r] = MB_RRE
        r = r + 1u64
    }
    let d_rows : u64 = kv_rank + MB_NROPE
    r = 0u64
    while r < d_rows {
        if mb_gz_wrow(4u64, r) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        let rc2 : u64 = mb_gz_dotrow(MB_G_NE0[4], 0u64)
        if rc2 != 0u64 {
            fclose(MB_LFILE[0])
            if rc2 == 2u64 {
                mb_rs("the gaze: refused (guard tripped in stage D -- named)" as u64)
                mb_rb(10u8)
                return 0u64
            }
            return 375u64
        }
        MB_DVS[r] = MB_RRS
        MB_DV0[r] = MB_RR0
        MB_DV1[r] = MB_RR1
        MB_DV2[r] = MB_RR2
        MB_DVE[r] = MB_RRE
        r = r + 1u64
    }
    /* the heads */
    let mut hh : u64 = 0u64
    while hh < MB_NHEAD {
        let mut d2 : u64 = 0u64
        while d2 < hw {
            if mb_gz_wrow(3u64, hh * hw + d2) != 0u64 {
                fclose(MB_LFILE[0])
                return 375u64
            }
            let rc3 : u64 = mb_gz_dotrow(MB_G_NE0[3], 1u64)
            if rc3 != 0u64 {
                fclose(MB_LFILE[0])
                return 375u64
            }
            MB_CHS[d2] = MB_RRS
            MB_CH0[d2] = MB_RR0
            MB_CH1[d2] = MB_RR1
            MB_CH2[d2] = MB_RR2
            MB_CHE[d2] = MB_RRE
            /* the choir's standing store: every head's rope rows kept
             * (the row is already decoded here -- store, never restream) */
            if d2 >= nope {
                if MB_NROPE == 64u64 {
                    if MB_NHEAD <= 128u64 {
                        let qrx : u64 = hh * 64u64 + (d2 - nope)
                        MB_QRS[qrx] = MB_RRS
                        MB_QR0[qrx] = MB_RR0
                        MB_QR1[qrx] = MB_RR1
                        MB_QR2[qrx] = MB_RR2
                        MB_QRE[qrx] = MB_RRE
                    }
                }
            }
            d2 = d2 + 1u64
        }
        d2 = 0u64
        while d2 < nope {
            if mb_gz_wrow(6u64, hh * kvw + d2) != 0u64 {
                fclose(MB_LFILE[0])
                return 375u64
            }
            let rc4 : u64 = mb_gz_dotrow(MB_G_NE0[6], 2u64)
            if rc4 != 0u64 {
                fclose(MB_LFILE[0])
                return 375u64
            }
            MB_EHS[d2] = MB_RRS
            MB_EH0[d2] = MB_RR0
            MB_EH1[d2] = MB_RR1
            MB_EH2[d2] = MB_RR2
            MB_EHE[d2] = MB_RRE
            d2 = d2 + 1u64
        }
        if mb_gz_pairdot(0u64, nope) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        MB_N1S[hh] = MB_6S
        MB_N1E[hh] = MB_PDE
        let mut q4 : u64 = 0u64
        while q4 < 6u64 {
            MB_N1L[hh * 6u64 + q4] = MB_6L[q4]
            q4 = q4 + 1u64
        }
        if mb_gz_pairdot(1u64, MB_NROPE) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        MB_N2S[hh] = MB_6S
        MB_N2E[hh] = MB_PDE
        q4 = 0u64
        while q4 < 6u64 {
            MB_N2L[hh * 6u64 + q4] = MB_6L[q4]
            q4 = q4 + 1u64
        }
        hh = hh + 1u64
    }
    fclose(MB_LFILE[0])
    /* the verdicts: per-part argmax (lowest index on ties), sign census,
     * and the DOMINANCE fold over all pairs */
    let mut a1 : u64 = 0u64
    let mut a2 : u64 = 0u64
    let mut i : u64 = 1u64
    while i < MB_NHEAD {
        if mb_gz_hcmp(0u64, i, a1) > 0i64 { a1 = i }
        if mb_gz_hcmp(1u64, i, a2) > 0i64 { a2 = i }
        i = i + 1u64
    }
    MB_GZ_A1 = a1
    let mut sp : u64 = 0u64
    let mut sn : u64 = 0u64
    let mut sz : u64 = 0u64
    i = 0u64
    while i < MB_NHEAD {
        if MB_N1S[i] > 0i64 { sp = sp + 1u64 }
        if MB_N1S[i] < 0i64 { sn = sn + 1u64 }
        if MB_N1S[i] == 0i64 { sz = sz + 1u64 }
        i = i + 1u64
    }
    if sp + sn + sz != MB_NHEAD { return 375u64 }
    let mut conc : u64 = 0u64
    let mut disc : u64 = 0u64
    i = 0u64
    while i < MB_NHEAD {
        let mut j : u64 = i + 1u64
        while j < MB_NHEAD {
            let c1 : i64 = mb_gz_hcmp(0u64, i, j)
            let c2 : i64 = mb_gz_hcmp(1u64, i, j)
            let mut isdisc : u64 = 0u64
            if c1 > 0i64 {
                if c2 < 0i64 { isdisc = 1u64 }
            }
            if c1 < 0i64 {
                if c2 > 0i64 { isdisc = 1u64 }
            }
            if isdisc == 1u64 { disc = disc + 1u64 }
            if isdisc == 0u64 { conc = conc + 1u64 }
            j = j + 1u64
        }
        i = i + 1u64
    }
    if conc + disc != (MB_NHEAD * (MB_NHEAD - 1u64)) / 2u64 { return 375u64 }
    /* THE DOUBLE STREAM: the nope-argmax head recomputed from fresh reads */
    let sv_s : i64 = MB_N1S[a1]
    let sv_e : i64 = MB_N1E[a1]
    let mut q5 : u64 = 0u64
    while q5 < 6u64 {
        MB_SVL[q5] = MB_N1L[a1 * 6u64 + q5]
        q5 = q5 + 1u64
    }
    mb_mkpath(MB_G_SH[1])
    MB_LFILE[0] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0] == 0u64 { return 375u64 }
    let mut d3 : u64 = 0u64
    while d3 < hw {
        if mb_gz_wrow(3u64, a1 * hw + d3) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        if mb_gz_dotrow(MB_G_NE0[3], 1u64) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        MB_CHS[d3] = MB_RRS
        MB_CH0[d3] = MB_RR0
        MB_CH1[d3] = MB_RR1
        MB_CH2[d3] = MB_RR2
        MB_CHE[d3] = MB_RRE
        d3 = d3 + 1u64
    }
    d3 = 0u64
    while d3 < nope {
        if mb_gz_wrow(6u64, a1 * kvw + d3) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        if mb_gz_dotrow(MB_G_NE0[6], 2u64) != 0u64 {
            fclose(MB_LFILE[0])
            return 375u64
        }
        MB_EHS[d3] = MB_RRS
        MB_EH0[d3] = MB_RR0
        MB_EH1[d3] = MB_RR1
        MB_EH2[d3] = MB_RR2
        MB_EHE[d3] = MB_RRE
        d3 = d3 + 1u64
    }
    fclose(MB_LFILE[0])
    if mb_gz_pairdot(0u64, nope) != 0u64 { return 375u64 }
    if MB_6S != sv_s { return 375u64 }
    if MB_PDE != sv_e { return 375u64 }
    q5 = 0u64
    while q5 < 6u64 {
        if MB_6L[q5] != MB_SVL[q5] { return 375u64 }
        q5 = q5 + 1u64
    }
    MB_GAZE_OK = 1u64
    mb_rs("the gaze: layer=0 pos=0 heads=" as u64)
    mb_ru(MB_NHEAD)
    mb_rs(" width=" as u64)
    mb_ru(nope)
    mb_rs("+" as u64)
    mb_ru(MB_NROPE)
    mb_rs(" rope-at-0=identity nope-argmax=" as u64)
    mb_ru(a1)
    mb_rs(" rope-argmax=" as u64)
    mb_ru(a2)
    mb_rs(" sign p/n/z=" as u64)
    mb_ru(sp)
    mb_rs("/" as u64)
    mb_ru(sn)
    mb_rs("/" as u64)
    mb_ru(sz)
    mb_rs(" dominance concordant=" as u64)
    mb_ru(conc)
    mb_rs(" discordant=" as u64)
    mb_ru(disc)
    mb_rs(" (surd frontier named) prefix-law=ok double-stream=ok norm-scalars=shared (order is integer-exact)" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ============ arm 376: THE TELOS (the surd frontier closed) ============ */

/* sign(dN1*sqrtR + dN2*sqrtKS) with R = (RN/7)*2^ra, KS = (KSn/7)*2^kc:
 * same signs decide at once; opposite signs square-compare with the 7s
 * cancelling: m1^2*RN*2^(2e1+ra) vs m2^2*KSn*2^(2e2+kc) -- pure integers.
 * No root is ever taken. */

var MB_TLA : [u64; 24]
var MB_TLB : [u64; 24]
var MB_TLT : [u64; 24]
var MB_S8A : [u64; 8]
var MB_S8B : [u64; 8]
var MB_TLOVF : u64 = 0u64
var MB_RNL : [u64; 4]
var MB_RA : i64 = 0i64
var MB_KSN : [u64; 12]
var MB_KC : i64 = 0i64
var MB_SD2 : [u64; 12]
var MB_WINS : [u64; 128]
var MB_WSEEN : [u8; 128]

fn mb_tl_clear(w: u64) -> i32 {
    let mut k : u64 = 0u64
    while k < 24u64 {
        if w == 0u64 { MB_TLA[k] = 0u64 }
        if w == 1u64 { MB_TLB[k] = 0u64 }
        k = k + 1u64
    }
    return 0i32
}

fn mb_tl_addat(w: u64, k0: u64, v: u64) -> i32 {
    if v == 0u64 { return 0i32 }
    let mut k : u64 = k0
    let mut carry : u64 = v
    while carry != 0u64 {
        if k >= 24u64 {
            MB_TLOVF = 1u64
            return 0i32
        }
        let mut cur : u64 = 0u64
        if w == 0u64 { cur = MB_TLA[k] }
        if w == 1u64 { cur = MB_TLB[k] }
        let s : u64 = cur + carry
        let mut nc : u64 = 0u64
        if s < carry { nc = 1u64 }
        if w == 0u64 { MB_TLA[k] = s }
        if w == 1u64 { MB_TLB[k] = s }
        carry = nc
        k = k + 1u64
    }
    return 0i32
}

/* w := square of the 8-limb S8 source (0 -> S8A, 1 -> S8B) */
fn mb_tl_sq8(w: u64) -> i32 {
    mb_tl_clear(w)
    let mut i : u64 = 0u64
    while i < 8u64 {
        let mut ai : u64 = 0u64
        if w == 0u64 { ai = MB_S8A[i] }
        if w == 1u64 { ai = MB_S8B[i] }
        let mut j : u64 = 0u64
        while j < 8u64 {
            let mut bj : u64 = 0u64
            if w == 0u64 { bj = MB_S8A[j] }
            if w == 1u64 { bj = MB_S8B[j] }
            if ai != 0u64 {
                if bj != 0u64 {
                    mb_mul64(ai, bj)
                    mb_tl_addat(w, i + j, MB_MLO)
                    mb_tl_addat(w, i + j + 1u64, MB_MHI)
                }
            }
            j = j + 1u64
        }
        i = i + 1u64
    }
    return 0i32
}

/* w *= src (src = RNL(4) when which 0, KSN(12) when which 1) */
fn mb_tl_mulsrc(w: u64, which: u64) -> i32 {
    let mut k : u64 = 0u64
    while k < 24u64 {
        if w == 0u64 { MB_TLT[k] = MB_TLA[k] }
        if w == 1u64 { MB_TLT[k] = MB_TLB[k] }
        k = k + 1u64
    }
    mb_tl_clear(w)
    let mut i : u64 = 0u64
    while i < 24u64 {
        if MB_TLT[i] != 0u64 {
            let mut n : u64 = 4u64
            if which == 1u64 { n = 12u64 }
            let mut j : u64 = 0u64
            while j < n {
                let mut sj : u64 = 0u64
                if which == 0u64 { sj = MB_RNL[j] }
                if which == 1u64 { sj = MB_KSN[j] }
                if sj != 0u64 {
                    mb_mul64(MB_TLT[i], sj)
                    mb_tl_addat(w, i + j, MB_MLO)
                    mb_tl_addat(w, i + j + 1u64, MB_MHI)
                }
                j = j + 1u64
            }
        }
        i = i + 1u64
    }
    return 0i32
}

fn mb_tl_shl(w: u64, sh: u64) -> i32 {
    let ls : u64 = sh / 64u64
    let bs : u64 = sh % 64u64
    let mut k : u64 = 24u64
    while k != 0u64 {
        k = k - 1u64
        let mut v : u64 = 0u64
        if k >= ls {
            let src : u64 = k - ls
            let mut lo : u64 = 0u64
            if w == 0u64 { lo = MB_TLA[src] }
            if w == 1u64 { lo = MB_TLB[src] }
            v = lo << bs
            if bs != 0u64 {
                if src != 0u64 {
                    let mut lo2 : u64 = 0u64
                    if w == 0u64 { lo2 = MB_TLA[src - 1u64] }
                    if w == 1u64 { lo2 = MB_TLB[src - 1u64] }
                    v = v | (lo2 >> (64u64 - bs))
                }
            }
            /* dropped high bits would be an overflow */
            if k == 23u64 {
                if bs != 0u64 {
                    let mut hi : u64 = 0u64
                    if w == 0u64 { hi = MB_TLA[src] }
                    if w == 1u64 { hi = MB_TLB[src] }
                    if (hi >> (64u64 - bs)) != 0u64 { MB_TLOVF = 1u64 }
                }
            }
        }
        if w == 0u64 { MB_TLA[k] = v }
        if w == 1u64 { MB_TLB[k] = v }
    }
    return 0i32
}

fn mb_tl_cmp() -> i64 {
    let mut k : u64 = 24u64
    while k != 0u64 {
        k = k - 1u64
        if MB_TLA[k] > MB_TLB[k] { return 1i64 }
        if MB_TLA[k] < MB_TLB[k] { return 0i64 - 1i64 }
    }
    return 0i64
}

/* delta of head values (arr 0 = N1, 1 = N2): sign/mant8/exp of value(i)-value(j) */
var MB_TDS : i64 = 0i64
var MB_TDE : i64 = 0i64
fn mb_tel_sub(arr: u64, i: u64, j: u64, into_b: u64) -> u64 {
    let mut si : i64 = 0i64
    let mut sj : i64 = 0i64
    let mut ei : i64 = 0i64
    let mut ej : i64 = 0i64
    if arr == 0u64 { si = MB_N1S[i]   sj = MB_N1S[j]   ei = MB_N1E[i]   ej = MB_N1E[j] }
    if arr == 1u64 { si = MB_N2S[i]   sj = MB_N2S[j]   ei = MB_N2E[i]   ej = MB_N2E[j] }
    /* aligned 8-limb magnitudes */
    let mut base : i64 = ei
    if ej < base { base = ej }
    let shi : u64 = (ei - base) as u64
    let shj : u64 = (ej - base) as u64
    if shi > 120u64 { return 1u64 }
    if shj > 120u64 { return 1u64 }
    let mut k : u64 = 0u64
    while k < 8u64 {
        MB_S8A[k] = 0u64
        MB_S8B[k] = 0u64
        k = k + 1u64
    }
    k = 0u64
    while k < 6u64 {
        if arr == 0u64 {
            MB_S8A[k] = MB_N1L[i * 6u64 + k]
            MB_S8B[k] = MB_N1L[j * 6u64 + k]
        }
        if arr == 1u64 {
            MB_S8A[k] = MB_N2L[i * 6u64 + k]
            MB_S8B[k] = MB_N2L[j * 6u64 + k]
        }
        k = k + 1u64
    }
    /* shift each in place (<= 120 bits within 8 limbs) */
    let mut t : u64 = 0u64
    while t < 2u64 {
        let mut sh : u64 = shi
        if t == 1u64 { sh = shj }
        if sh != 0u64 {
            let ls : u64 = sh / 64u64
            let bs : u64 = sh % 64u64
            let mut k2 : u64 = 8u64
            while k2 != 0u64 {
                k2 = k2 - 1u64
                let mut v : u64 = 0u64
                if k2 >= ls {
                    let src : u64 = k2 - ls
                    let mut lo : u64 = 0u64
                    if t == 0u64 { lo = MB_S8A[src] }
                    if t == 1u64 { lo = MB_S8B[src] }
                    v = lo << bs
                    if bs != 0u64 {
                        if src != 0u64 {
                            let mut lo2 : u64 = 0u64
                            if t == 0u64 { lo2 = MB_S8A[src - 1u64] }
                            if t == 1u64 { lo2 = MB_S8B[src - 1u64] }
                            v = v | (lo2 >> (64u64 - bs))
                        }
                    }
                }
                if t == 0u64 { MB_S8A[k2] = v }
                if t == 1u64 { MB_S8B[k2] = v }
            }
        }
        t = t + 1u64
    }
    /* signed combine: si*A - sj*B */
    let mut cmp : i64 = 0i64
    k = 8u64
    while k != 0u64 {
        k = k - 1u64
        if cmp == 0i64 {
            if MB_S8A[k] > MB_S8B[k] { cmp = 1i64 }
            if MB_S8A[k] < MB_S8B[k] { cmp = 0i64 - 1i64 }
        }
    }
    let mut rs : i64 = 0i64
    if si == sj {
        if si == 0i64 {
            MB_TDS = 0i64
            MB_TDE = base
            return 0u64
        }
        /* |A - B| with sign si*cmp */
        if cmp == 0i64 {
            MB_TDS = 0i64
            MB_TDE = base
            return 0u64
        }
        let mut borrow : u64 = 0u64
        k = 0u64
        while k < 8u64 {
            let mut x : u64 = MB_S8A[k]
            let mut y : u64 = MB_S8B[k]
            if cmp < 0i64 {
                x = MB_S8B[k]
                y = MB_S8A[k]
            }
            let d : u64 = x - y
            let mut b2 : u64 = 0u64
            if x < y { b2 = 1u64 }
            let e2 : u64 = d - borrow
            if d < borrow { b2 = b2 + 1u64 }
            MB_S8A[k] = e2
            borrow = b2
            k = k + 1u64
        }
        rs = si * cmp
    }
    if si != sj {
        if si == 0i64 {
            /* value = -sj*B */
            k = 0u64
            while k < 8u64 {
                MB_S8A[k] = MB_S8B[k]
                k = k + 1u64
            }
            rs = 0i64 - sj
        }
        if sj == 0i64 { rs = si }
        if si != 0i64 {
            if sj != 0i64 {
                /* opposite: |A| + |B|, sign si */
                let mut carry : u64 = 0u64
                k = 0u64
                while k < 8u64 {
                    let s2 : u64 = MB_S8A[k] + MB_S8B[k]
                    let mut c2 : u64 = 0u64
                    if s2 < MB_S8B[k] { c2 = 1u64 }
                    let s3 : u64 = s2 + carry
                    if s3 < carry { c2 = c2 + 1u64 }
                    MB_S8A[k] = s3
                    carry = c2
                    k = k + 1u64
                }
                if carry != 0u64 { return 1u64 }
                rs = si
            }
        }
    }
    if into_b == 1u64 {
        k = 0u64
        while k < 8u64 {
            MB_S8B[k] = MB_S8A[k]
            k = k + 1u64
        }
    }
    MB_TDS = rs
    MB_TDE = base
    return 0u64
}

fn mb_arm376() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    if MB_GAZE_OK == 0u64 {
        mb_rs("the telos: fasting (no gaze standing)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    if MB_EPSF == 0u8 {
        mb_rs("the telos: epsilon absent from the KV forest (named, lawful)" as u64)
        mb_rb(10u8)
        return 0u64
    }
    /* R = (RN/7)*2^ra from the standing x-norm and the artifact's epsilon */
    let me : i64 = mb_f32m(MB_EPSB)
    if me == 4611686018427387904i64 { return 376u64 }
    if me <= 0i64 { return 376u64 }
    let ee : i64 = MB_F32E
    let mut k : u64 = 0u64
    while k < 4u64 {
        MB_RNL[k] = 0u64
        k = k + 1u64
    }
    let d : i64 = ee + 58i64
    MB_RA = 0i64 - 58i64
    if d >= 0i64 {
        if d > 100i64 { return 376u64 }
        /* RN = SV + 7*me << d */
        MB_RNL[0] = MB_SYN_V0
        MB_RNL[1] = MB_SYN_V1
        MB_RNL[2] = MB_SYN_V2
        let sev : u64 = (7i64 * me) as u64
        let ls : u64 = (d as u64) / 64u64
        let bs : u64 = (d as u64) % 64u64
        let lo : u64 = sev << bs
        let mut hi : u64 = 0u64
        if bs != 0u64 { hi = sev >> (64u64 - bs) }
        let s0 : u64 = MB_RNL[ls] + lo
        let mut c0 : u64 = 0u64
        if s0 < lo { c0 = 1u64 }
        MB_RNL[ls] = s0
        MB_RNL[ls + 1u64] = MB_RNL[ls + 1u64] + hi + c0
    }
    if d < 0i64 {
        let nd : u64 = (0i64 - d) as u64
        if nd > 100u64 { return 376u64 }
        /* RN = (SV << nd) + 7*me ; ra = -58 - nd */
        MB_RNL[0] = MB_SYN_V0
        MB_RNL[1] = MB_SYN_V1
        MB_RNL[2] = MB_SYN_V2
        let ls2 : u64 = nd / 64u64
        let bs2 : u64 = nd % 64u64
        let mut k3 : u64 = 4u64
        while k3 != 0u64 {
            k3 = k3 - 1u64
            let mut v : u64 = 0u64
            if k3 >= ls2 {
                let src : u64 = k3 - ls2
                v = MB_RNL[src] << bs2
                if bs2 != 0u64 {
                    if src != 0u64 { v = v | (MB_RNL[src - 1u64] >> (64u64 - bs2)) }
                }
            }
            MB_RNL[k3] = v
        }
        let sev2 : u64 = (7i64 * me) as u64
        let s4 : u64 = MB_RNL[0] + sev2
        let mut c4 : u64 = 0u64
        if s4 < sev2 { c4 = 1u64 }
        MB_RNL[0] = s4
        MB_RNL[1] = MB_RNL[1] + c4
        MB_RA = 0i64 - 58i64 - (nd as i64)
    }
    /* SD2 = sum of D[0..512)^2, aligned to twice the minimal exponent */
    let mut e2min : i64 = 100000i64
    let mut c : u64 = 0u64
    while c < 512u64 {
        if MB_DVS[c] != 0i64 {
            let te : i64 = 2i64 * MB_DVE[c]
            if te < e2min { e2min = te }
        }
        c = c + 1u64
    }
    if e2min == 100000i64 { return 376u64 }
    mb_tl_clear(0u64)
    MB_TLOVF = 0u64
    c = 0u64
    while c < 512u64 {
        if MB_DVS[c] != 0i64 {
            mb_mul192(MB_DV0[c], MB_DV1[c], MB_DV2[c], MB_DV0[c], MB_DV1[c], MB_DV2[c])
            let sh : i64 = 2i64 * MB_DVE[c] - e2min
            if sh > 120i64 { return 376u64 }
            /* add R6 << sh into TLA */
            let ls3 : u64 = (sh as u64) / 64u64
            let bs3 : u64 = (sh as u64) % 64u64
            let mut q : u64 = 0u64
            let mut prev : u64 = 0u64
            while q < 6u64 {
                let cur : u64 = MB_R6[q]
                let mut v2 : u64 = cur << bs3
                if bs3 != 0u64 { v2 = v2 | (prev >> (64u64 - bs3)) }
                mb_tl_addat(0u64, ls3 + q, v2)
                prev = cur
                q = q + 1u64
            }
            if bs3 != 0u64 { mb_tl_addat(0u64, ls3 + 6u64, prev >> (64u64 - bs3)) }
        }
        c = c + 1u64
    }
    if MB_TLOVF != 0u64 { return 376u64 }
    k = 0u64
    while k < 12u64 {
        MB_SD2[k] = MB_TLA[k]
        k = k + 1u64
    }
    k = 12u64
    let mut over : u64 = 0u64
    while k < 24u64 {
        over = over | MB_TLA[k]
        k = k + 1u64
    }
    if over != 0u64 { return 376u64 }
    /* KS = (KSn/7)*2^kc with KSn = 7*SD2<<(se'-kc) + me*RN<<(ee+ra-kc) */
    let sep : i64 = e2min - 9i64
    let er : i64 = ee + MB_RA
    MB_KC = sep
    if er < MB_KC { MB_KC = er }
    let sh_a : i64 = sep - MB_KC
    let sh_b : i64 = er - MB_KC
    if sh_a > 160i64 { return 376u64 }
    if sh_b > 160i64 { return 376u64 }
    mb_tl_clear(0u64)
    /* 7*SD2 << sh_a */
    c = 0u64
    while c < 12u64 {
        if MB_SD2[c] != 0u64 {
            mb_mul64(MB_SD2[c], 7u64)
            let base2 : u64 = (sh_a as u64) / 64u64
            let bb2 : u64 = (sh_a as u64) % 64u64
            let mut lo3 : u64 = MB_MLO << bb2
            let mut mid3 : u64 = (MB_MHI << bb2)
            if bb2 != 0u64 { mid3 = mid3 | (MB_MLO >> (64u64 - bb2)) }
            let mut hi3 : u64 = 0u64
            if bb2 != 0u64 { hi3 = MB_MHI >> (64u64 - bb2) }
            mb_tl_addat(0u64, c + base2, lo3)
            mb_tl_addat(0u64, c + base2 + 1u64, mid3)
            mb_tl_addat(0u64, c + base2 + 2u64, hi3)
        }
        c = c + 1u64
    }
    /* + me*RN << sh_b */
    c = 0u64
    while c < 4u64 {
        if MB_RNL[c] != 0u64 {
            mb_mul64(MB_RNL[c], me as u64)
            let base3 : u64 = (sh_b as u64) / 64u64
            let bb3 : u64 = (sh_b as u64) % 64u64
            let mut lo4 : u64 = MB_MLO << bb3
            let mut mid4 : u64 = (MB_MHI << bb3)
            if bb3 != 0u64 { mid4 = mid4 | (MB_MLO >> (64u64 - bb3)) }
            let mut hi4 : u64 = 0u64
            if bb3 != 0u64 { hi4 = MB_MHI >> (64u64 - bb3) }
            mb_tl_addat(0u64, c + base3, lo4)
            mb_tl_addat(0u64, c + base3 + 1u64, mid4)
            mb_tl_addat(0u64, c + base3 + 2u64, hi4)
        }
        c = c + 1u64
    }
    if MB_TLOVF != 0u64 { return 376u64 }
    k = 0u64
    while k < 12u64 {
        MB_KSN[k] = MB_TLA[k]
        k = k + 1u64
    }
    k = 12u64
    over = 0u64
    while k < 24u64 {
        over = over | MB_TLA[k]
        k = k + 1u64
    }
    if over != 0u64 { return 376u64 }
    /* the complete pairwise verdict */
    let mut i : u64 = 0u64
    while i < MB_NHEAD {
        MB_WINS[i] = 0u64
        MB_WSEEN[i] = 0u8
        i = i + 1u64
    }
    let mut ties : u64 = 0u64
    let mut dom : u64 = 0u64
    let mut surd : u64 = 0u64
    i = 0u64
    while i < MB_NHEAD {
        let mut j : u64 = i + 1u64
        while j < MB_NHEAD {
            let c1 : i64 = mb_gz_hcmp(0u64, i, j)
            let c2 : i64 = mb_gz_hcmp(1u64, i, j)
            let mut v : i64 = 0i64
            let mut decided : u64 = 0u64
            if c1 >= 0i64 {
                if c2 >= 0i64 {
                    if c1 + c2 > 0i64 { v = 1i64 }
                    decided = 1u64
                    dom = dom + 1u64
                }
            }
            if decided == 0u64 {
                if c1 <= 0i64 {
                    if c2 <= 0i64 {
                        v = 0i64 - 1i64
                        decided = 1u64
                        dom = dom + 1u64
                    }
                }
            }
            if decided == 0u64 {
                /* the surd: sign(dN1*sqrtR + dN2*sqrtKS) with opposite parts */
                surd = surd + 1u64
                if mb_tel_sub(0u64, i, j, 0u64) != 0u64 { return 376u64 }
                let s1 : i64 = MB_TDS
                let e1 : i64 = MB_TDE
                /* keep dN1 in S8A; compute dN2 into S8B */
                let mut q2 : u64 = 0u64
                while q2 < 8u64 {
                    MB_TLT[q2] = MB_S8A[q2]
                    q2 = q2 + 1u64
                }
                if mb_tel_sub(1u64, i, j, 1u64) != 0u64 { return 376u64 }
                let s2 : i64 = MB_TDS
                let e2 : i64 = MB_TDE
                q2 = 0u64
                while q2 < 8u64 {
                    MB_S8A[q2] = MB_TLT[q2]
                    q2 = q2 + 1u64
                }
                if s1 == 0i64 { v = s2 }
                if s2 == 0i64 { v = s1 }
                if s1 != 0i64 {
                    if s2 != 0i64 {
                        if s1 == s2 { v = s1 }
                        if s1 != s2 {
                            MB_TLOVF = 0u64
                            mb_tl_sq8(0u64)
                            mb_tl_mulsrc(0u64, 0u64)
                            mb_tl_sq8(1u64)
                            mb_tl_mulsrc(1u64, 1u64)
                            let ea : i64 = 2i64 * e1 + MB_RA
                            let eb : i64 = 2i64 * e2 + MB_KC
                            let mut baseE : i64 = ea
                            if eb < baseE { baseE = eb }
                            if ea - baseE > 256i64 { return 376u64 }
                            if eb - baseE > 256i64 { return 376u64 }
                            if ea > baseE { mb_tl_shl(0u64, (ea - baseE) as u64) }
                            if eb > baseE { mb_tl_shl(1u64, (eb - baseE) as u64) }
                            if MB_TLOVF != 0u64 { return 376u64 }
                            let cq : i64 = mb_tl_cmp()
                            if cq > 0i64 { v = s1 }
                            if cq < 0i64 { v = s2 }
                            if cq == 0i64 { v = 0i64 }
                        }
                    }
                }
            }
            if v > 0i64 { MB_WINS[i] = MB_WINS[i] + 1u64 }
            if v < 0i64 { MB_WINS[j] = MB_WINS[j] + 1u64 }
            if v == 0i64 { ties = ties + 1u64 }
            j = j + 1u64
        }
        i = i + 1u64
    }
    /* THE WIN-PERMUTATION THEOREM: with zero ties, the win counts must be
     * exactly the permutation 0..H-1 -- any comparator cycle breaks it */
    let mut perm_ok : u64 = 1u64
    if ties == 0u64 {
        i = 0u64
        while i < MB_NHEAD {
            let wv : u64 = MB_WINS[i]
            if wv >= MB_NHEAD { perm_ok = 0u64 }
            if wv < MB_NHEAD {
                if MB_WSEEN[wv] == 1u8 { perm_ok = 0u64 }
                MB_WSEEN[wv] = 1u8
            }
            i = i + 1u64
        }
    }
    if perm_ok == 0u64 { return 376u64 }
    /* the crown and the court */
    let mut top1 : u64 = 0u64
    let mut top2 : u64 = 0u64
    let mut top3 : u64 = 0u64
    i = 0u64
    while i < MB_NHEAD {
        if MB_WINS[i] == MB_NHEAD - 1u64 { top1 = i }
        if MB_WINS[i] == MB_NHEAD - 2u64 { top2 = i }
        if MB_WINS[i] == MB_NHEAD - 3u64 { top3 = i }
        i = i + 1u64
    }
    mb_rs("the telos: pairs=" as u64)
    mb_ru((MB_NHEAD * (MB_NHEAD - 1u64)) / 2u64)
    mb_rs(" dominance=" as u64)
    mb_ru(dom)
    mb_rs(" surd-decided=" as u64)
    mb_ru(surd)
    mb_rs(" ties=" as u64)
    mb_ru(ties)
    mb_rs(" win-permutation=ok total-order=[" as u64)
    mb_ru(top1)
    mb_rs("," as u64)
    mb_ru(top2)
    mb_rs("," as u64)
    mb_ru(top3)
    mb_rs(",...] -- the frontier CLOSED, no root taken" as u64)
    mb_rb(10u8)
    return 0u64
}

fn mb_arm371() -> u64 {
    if MB_FEAST == 0u8 { return 0u64 }
    /* the resident stomach: the sum of every buffer this organ owns.
     * window 65536 + spans 2x4096 + key 256 + hist 512 + blk 256
     * + values 2x2048 + report 4096 + partials 512 + 3x512 + names 2x64+48
     * + paths 2x64 + arch 32 + digits 64 + splits 128+16
     * + loom slices (blk 1024 + values 2x8192 + ledgers ~576)
     * + the fleet (x 57344 + xbmax 256 + ledgers/samples ~1000)
     * + the walk (logits 256x40 + chunks 112x32 + top 64) */
    let resident : u64 = 65536u64 + 4096u64 + 4096u64 + 256u64 + 512u64 + 256u64 + 2048u64 + 2048u64 + 4096u64 + 512u64 + 1536u64 + 176u64 + 128u64 + 32u64 + 64u64 + 144u64 + 1024u64 + 16384u64 + 576u64 + 57344u64 + 256u64 + 1000u64 + 10240u64 + 3584u64 + 64u64 + 324936u64
    if MB_STREAMED == 0u64 { return 371u64 }
    if MB_STREAMED <= resident { return 371u64 }
    mb_rs("the stomach: streamed=" as u64)
    mb_ru(MB_STREAMED)
    mb_rs(" resident=" as u64)
    mb_ru(resident)
    mb_rs(" -- the feast passes through a fixed stomach: blocks in, proofs out" as u64)
    mb_rb(10u8)
    return 0u64
}

/* ==================== arm 366: THE SCROLL ==================== */

fn mb_arm366() -> u64 {
    eol_reset()
    let doc : u64 = "[weight = dyadic rational] [fp16 value = dyadic rational] [dyadic rational < exact number] [block sum = dyadic rational] [conservation = byte tiling] [argmax = order fact] [order fact < exact decision]" as u64
    let dl : u64 = mb_slen(doc)
    if eol_read(doc, dl) < 0i64 { return 366u64 }
    if eol_lawcheck() != 0u64 { return 366u64 }
    let a1 : u64 = eol_addr()
    if a1 == 0u64 { return 366u64 }
    /* DERIVED (absent from the text): the weight sits under exact number */
    let wa : u64 = "weight" as u64
    let xb : u64 = "exact number" as u64
    if eol_entails(wa, mb_slen(wa), 0u64, xb, mb_slen(xb)) != 1u64 { return 366u64 }
    /* the reversal REFUSES: exact number does not sit under the weight */
    if eol_entails(xb, mb_slen(xb), 0u64, wa, mb_slen(wa)) != 0u64 { return 366u64 }
    /* cross-class refusal: conservation is not the weight */
    let ca : u64 = "conservation" as u64
    if eol_entails(ca, mb_slen(ca), 2u64, wa, mb_slen(wa)) != 0u64 { return 366u64 }
    /* determinism: re-reading the law lands on the same address */
    eol_reset()
    if eol_read(doc, dl) < 0i64 { return 366u64 }
    if eol_addr() != a1 { return 366u64 }
    MB_SCROLL = a1
    return 0u64
}

/* ==================== the organ's spine ==================== */

fn mb_selfprove() -> u64 @export {
    MB_REPN = 0u64
    MB_SCROLL = 0u64
    MB_STREAMED = 0u64
    MB_C1_F = 0u8
    MB_C2_F = 0u8
    MB_C3_F = 0u8
    MB_C3_HERE = 0u8
    let mut gz0 : u64 = 0u64
    while gz0 < 732u64 {
        MB_G_F[gz0] = 0u8
        MB_G_HERE[gz0] = 0u8
        gz0 = gz0 + 1u64
    }
    let mut me0 : u64 = 0u64
    while me0 < 366u64 {
        MB_ME_F[me0] = 0u8
        MB_ME_HERE[me0] = 0u8
        me0 = me0 + 1u64
    }
    MB_ME_BASE = 18u64
    let mut rt0 : u64 = 0u64
    while rt0 < 61u64 {
        MB_RT_F[rt0] = 0u8
        MB_RT_HERE[rt0] = 0u8
        MB_EB_F[rt0] = 0u8
        MB_EB_HERE[rt0] = 0u8
        rt0 = rt0 + 1u64
    }
    let mut sp0 : u64 = 0u64
    while sp0 < 4u64 {
        MB_SP_F[sp0] = 0u8
        MB_SP_HERE[sp0] = 0u8
        sp0 = sp0 + 1u64
    }
    MB_NHEAD = 0u64
    MB_NROPE = 0u64
    MB_ARCHN = 0u64
    MB_EMBED = 0u64
    MB_LAYERS = 0u64
    MB_SPLITCT_F = 0u8
    MB_SPLITTN_F = 0u8
    let mut h : u64 = 0u64
    while h < 64u64 {
        MB_HIST[h] = 0u64
        h = h + 1u64
    }
    let r0 : u64 = mb_arm360()
    if r0 != 0u64 { return r0 }
    let r1 : u64 = mb_arm361()
    if r1 != 0u64 { return r1 }
    let r2 : u64 = mb_arm362()
    if r2 != 0u64 { return r2 }
    let r2b : u64 = mb_anatomia()
    if r2b != 0u64 { return r2b }
    let r3 : u64 = mb_arm363()
    if r3 != 0u64 { return r3 }
    let r4 : u64 = mb_arm364()
    if r4 != 0u64 { return r4 }
    let r5 : u64 = mb_arm365()
    if r5 != 0u64 { return r5 }
    let r5b : u64 = mb_arm370()
    if r5b != 0u64 { return r5b }
    let r5d : u64 = mb_arm372()
    if r5d != 0u64 { return r5d }
    let r5e : u64 = mb_arm373()
    if r5e != 0u64 { return r5e }
    let r5f : u64 = mb_arm374()
    if r5f != 0u64 { return r5f }
    let r5g : u64 = mb_arm375()
    if r5g != 0u64 { return r5g }
    let r5h : u64 = mb_arm376()
    if r5h != 0u64 { return r5h }
    let r5c : u64 = mb_arm371()
    if r5c != 0u64 { return r5c }
    let r6 : u64 = mb_arm366()
    if r6 != 0u64 { return r6 }
    mb_rs("the boundary: softmax mixing is transcendental -- beyond metabole's arms, referred to the interval organ" as u64)
    mb_rb(10u8)
    return 0u64
}

fn mb_addr() -> u64 @export { return MB_SCROLL }
fn mb_report_len() -> u64 @export { return MB_REPN }
fn mb_report_byte(i: u64) -> u8 @export {
    if i >= MB_REPN { return 0u8 }
    return MB_REP[i]
}

/* the digested flesh, served onward (PERAS eats from this table) */
fn mb_nva() -> u64 @export { return MB_NVA }
fn mb_nvb() -> u64 @export { return MB_NVB }
fn mb_val_a(i: u64) -> i64 @export {
    if i >= MB_NVA { return 0i64 }
    return MB_VA[i]
}
fn mb_val_b(i: u64) -> i64 @export {
    if i >= MB_NVB { return 0i64 }
    return MB_VB[i]
}
fn mb_feast() -> u64 @export { return MB_FEAST as u64 }

/* the crowned head's standing gaze state, served to the assembly:
 * after arm 375's double stream, MB_CH holds head a1's full q numerators
 * and MB_DV the shared kv_a outputs; N1/N2 hold every head's parts */
fn mb_gz_ok() -> u64 @export { return MB_GAZE_OK }
fn mb_gz_head() -> u64 @export { return MB_GZ_A1 }
fn mb_gz_nrope() -> u64 @export { return MB_NROPE }
fn mb_gz_cr_s(r: u64) -> i64 @export {
    if r >= 64u64 { return 0i64 }
    return MB_CHS[128u64 + r]
}
fn mb_gz_cr_l(r: u64, k: u64) -> u64 @export {
    if r >= 64u64 { return 0u64 }
    if k == 0u64 { return MB_CH0[128u64 + r] }
    if k == 1u64 { return MB_CH1[128u64 + r] }
    return MB_CH2[128u64 + r]
}
fn mb_gz_cr_e(r: u64) -> i64 @export {
    if r >= 64u64 { return 0i64 }
    return MB_CHE[128u64 + r]
}
fn mb_gz_dr_s(r: u64) -> i64 @export {
    if r >= 64u64 { return 0i64 }
    return MB_DVS[512u64 + r]
}
fn mb_gz_dr_l(r: u64, k: u64) -> u64 @export {
    if r >= 64u64 { return 0u64 }
    if k == 0u64 { return MB_DV0[512u64 + r] }
    if k == 1u64 { return MB_DV1[512u64 + r] }
    return MB_DV2[512u64 + r]
}
fn mb_gz_dr_e(r: u64) -> i64 @export {
    if r >= 64u64 { return 0i64 }
    return MB_DVE[512u64 + r]
}
fn mb_gz_n2_s(h: u64) -> i64 @export {
    if h >= 128u64 { return 0i64 }
    return MB_N2S[h]
}
fn mb_gz_n2_l(h: u64, k: u64) -> u64 @export {
    if h >= 128u64 { return 0u64 }
    if k >= 6u64 { return 0u64 }
    return MB_N2L[h * 6u64 + k]
}
fn mb_gz_n2_e(h: u64) -> i64 @export {
    if h >= 128u64 { return 0i64 }
    return MB_N2E[h]
}

/* ============ the pleroma's serves (arm 380 consumes) ============
 * Everything below reads STANDING state or streams once through the
 * standing mouth -- no recompute of anything already proven. */

/* the standing voice: the digested embedding row id */
fn mb_gz_voice() -> u64 @export { return MB_SYN_RV }

/* embd mantissas (value = m * 2^-24) for the r1^2 sum */
fn mb_gz_nembd() -> u64 @export { return MB_G_NE[0] }
fn mb_gz_xv(c: u64) -> i64 @export {
    if c >= 7168u64 { return 0i64 }
    return MB_XV[c]
}

/* q_a stage rows (canonical sign, 3 limbs, exp) for the r2^2 sum */
fn mb_gz_qark() -> u64 @export { return MB_G_NE[2] }
fn mb_gz_bv_s(r: u64) -> i64 @export {
    if r >= 1536u64 { return 0i64 }
    return MB_BVS[r]
}
fn mb_gz_bv_l(r: u64, k: u64) -> u64 @export {
    if r >= 1536u64 { return 0u64 }
    if k == 0u64 { return MB_BV0[r] }
    if k == 1u64 { return MB_BV1[r] }
    return MB_BV2[r]
}
fn mb_gz_bv_e(r: u64) -> i64 @export {
    if r >= 1536u64 { return 0i64 }
    return MB_BVE[r]
}

/* the rms epsilon as an exact dyadic (f32 is dyadic; sentinel guarded) */
fn mb_gz_eps_m() -> i64 @export {
    if MB_EPSF == 0u8 { return 0i64 }
    return mb_f32m(MB_EPSB)
}
fn mb_gz_eps_e() -> i64 @export {
    if MB_EPSF == 0u8 { return 0i64 }
    mb_f32m(MB_EPSB)
    return MB_F32E
}

/* per-head qk width (nope + rope) for the 1/sqrt(width) scale */
fn mb_gz_hw() -> u64 @export {
    if MB_NHEAD == 0u64 { return 0u64 }
    return MB_G_NE[3] / MB_G_NE0[3] / MB_NHEAD
}

/* THE V SERVE: the crowned head's value rows, streamed ONCE through the
 * standing mouth (kv_b v-block dotted through the normed latent, kind 2;
 * layout premise NAMED at the gaze: kv_b head = [k nope | v]) */
var MB_VHS : [i64; 128]
var MB_VH0 : [u64; 128]
var MB_VH1 : [u64; 128]
var MB_VH2 : [u64; 128]
var MB_VHE : [i64; 128]
var MB_VOK : u64 = 0u64
fn mb_gz_vserve() -> u64 @export {
    if MB_VOK == 1u64 { return 0u64 }
    if MB_GAZE_OK != 1u64 { return 1u64 }
    let hw : u64 = MB_G_NE[3] / MB_G_NE0[3] / MB_NHEAD
    let nope : u64 = hw - MB_NROPE
    let kvw : u64 = MB_G_NE[6] / MB_G_NE0[6] / MB_NHEAD
    let nv : u64 = kvw - nope
    if nv != 128u64 { return 2u64 }
    mb_mkpath(MB_G_SH[1])
    MB_LFILE[0] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0] == 0u64 { return 1u64 }
    let mut d : u64 = 0u64
    while d < nv {
        if mb_gz_wrow(6u64, MB_GZ_A1 * kvw + nope + d) != 0u64 {
            fclose(MB_LFILE[0])
            return 1u64
        }
        if mb_gz_dotrow(MB_G_NE0[6], 2u64) != 0u64 {
            fclose(MB_LFILE[0])
            return 1u64
        }
        MB_VHS[d] = MB_RRS
        MB_VH0[d] = MB_RR0
        MB_VH1[d] = MB_RR1
        MB_VH2[d] = MB_RR2
        MB_VHE[d] = MB_RRE
        d = d + 1u64
    }
    fclose(MB_LFILE[0])
    MB_VOK = 1u64
    return 0u64
}
fn mb_gz_v_s(d: u64) -> i64 @export {
    if d >= 128u64 { return 0i64 }
    return MB_VHS[d]
}
fn mb_gz_v_l(d: u64, k: u64) -> u64 @export {
    if d >= 128u64 { return 0u64 }
    if k == 0u64 { return MB_VH0[d] }
    if k == 1u64 { return MB_VH1[d] }
    return MB_VH2[d]
}
fn mb_gz_v_e(d: u64) -> i64 @export {
    if d >= 128u64 { return 0i64 }
    return MB_VHE[d]
}

/* ============ the probole's serves (arms 381-383 consume) ============
 * The choir needs every head's rope rows (stored in arm 375's own loop),
 * every head's value rows (streamed once), and the latent rows for r3^2;
 * the projection needs the o_proj tensor (census slot 7), the deposited
 * 16384-wide interval thought, and the two-engine row dot below. */

/* every head's q rope rows, canonical (s, 3 limbs, e) -- filled by 375 */
var MB_QRS : [i64; 8192]
var MB_QR0 : [u64; 8192]
var MB_QR1 : [u64; 8192]
var MB_QR2 : [u64; 8192]
var MB_QRE : [i64; 8192]
fn mb_qr_s(h: u64, d: u64) -> i64 @export {
    if h >= 128u64 { return 0i64 }
    if d >= 64u64 { return 0i64 }
    return MB_QRS[h * 64u64 + d]
}
fn mb_qr_l(h: u64, d: u64, k: u64) -> u64 @export {
    if h >= 128u64 { return 0u64 }
    if d >= 64u64 { return 0u64 }
    if k == 0u64 { return MB_QR0[h * 64u64 + d] }
    if k == 1u64 { return MB_QR1[h * 64u64 + d] }
    return MB_QR2[h * 64u64 + d]
}
fn mb_qr_e(h: u64, d: u64) -> i64 @export {
    if h >= 128u64 { return 0i64 }
    if d >= 64u64 { return 0i64 }
    return MB_QRE[h * 64u64 + d]
}

/* the latent rows of kv_a (r < 512) for the r3^2 sum */
fn mb_gz_dv_s(r: u64) -> i64 @export {
    if r >= 512u64 { return 0i64 }
    return MB_DVS[r]
}
fn mb_gz_dv_l(r: u64, k: u64) -> u64 @export {
    if r >= 512u64 { return 0u64 }
    if k == 0u64 { return MB_DV0[r] }
    if k == 1u64 { return MB_DV1[r] }
    return MB_DV2[r]
}
fn mb_gz_dv_e(r: u64) -> i64 @export {
    if r >= 512u64 { return 0i64 }
    return MB_DVE[r]
}

/* THE ALL-HEAD V SERVE: every head's value rows, streamed ONCE */
var MB_WVS : [i64; 16384]
var MB_WV0 : [u64; 16384]
var MB_WV1 : [u64; 16384]
var MB_WV2 : [u64; 16384]
var MB_WVE : [i64; 16384]
var MB_WVOK : u64 = 0u64
fn mb_pb_vall() -> u64 @export {
    if MB_WVOK == 1u64 { return 0u64 }
    if MB_GAZE_OK != 1u64 { return 1u64 }
    if MB_NHEAD != 128u64 { return 2u64 }
    let hw : u64 = MB_G_NE[3] / MB_G_NE0[3] / MB_NHEAD
    let nope : u64 = hw - MB_NROPE
    let kvw : u64 = MB_G_NE[6] / MB_G_NE0[6] / MB_NHEAD
    let nv : u64 = kvw - nope
    if nv != 128u64 { return 2u64 }
    mb_mkpath(MB_G_SH[1])
    MB_LFILE[0] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0] == 0u64 { return 1u64 }
    let mut hh : u64 = 0u64
    while hh < 128u64 {
        let mut d : u64 = 0u64
        while d < 128u64 {
            if mb_gz_wrow(6u64, hh * kvw + nope + d) != 0u64 {
                fclose(MB_LFILE[0])
                return 1u64
            }
            if mb_gz_dotrow(MB_G_NE0[6], 2u64) != 0u64 {
                fclose(MB_LFILE[0])
                return 1u64
            }
            let ix : u64 = hh * 128u64 + d
            MB_WVS[ix] = MB_RRS
            MB_WV0[ix] = MB_RR0
            MB_WV1[ix] = MB_RR1
            MB_WV2[ix] = MB_RR2
            MB_WVE[ix] = MB_RRE
            d = d + 1u64
        }
        hh = hh + 1u64
    }
    fclose(MB_LFILE[0])
    MB_WVOK = 1u64
    return 0u64
}
fn mb_pb_v_s(i: u64) -> i64 @export {
    if i >= 16384u64 { return 0i64 }
    return MB_WVS[i]
}
fn mb_pb_v_l(i: u64, k: u64) -> u64 @export {
    if i >= 16384u64 { return 0u64 }
    if k == 0u64 { return MB_WV0[i] }
    if k == 1u64 { return MB_WV1[i] }
    return MB_WV2[i]
}
fn mb_pb_v_e(i: u64) -> i64 @export {
    if i >= 16384u64 { return 0i64 }
    return MB_WVE[i]
}

/* THE STANDING THOUGHT: the deposited interval vector (lo/hi bounds and
 * the exact point beside them), each (sign, 4 limbs, exp).  Sized for the
 * WIDEST consumer: the choir deposits 16384, the threpsis h 18432. */
var MB_TLS : [i64; 18432]
var MB_TL0 : [u64; 18432]
var MB_TL1 : [u64; 18432]
var MB_TL2 : [u64; 18432]
var MB_TL3 : [u64; 18432]
var MB_TLE : [i64; 18432]
var MB_THS : [i64; 18432]
var MB_TH0 : [u64; 18432]
var MB_TH1 : [u64; 18432]
var MB_TH2 : [u64; 18432]
var MB_TH3 : [u64; 18432]
var MB_THE : [i64; 18432]
var MB_TXS : [i64; 18432]
var MB_TX0 : [u64; 18432]
var MB_TX1 : [u64; 18432]
var MB_TX2 : [u64; 18432]
var MB_TX3 : [u64; 18432]
var MB_TXE : [i64; 18432]
var MB_TSETL : u64 = 0u64
var MB_TSETH : u64 = 0u64
var MB_TSETX : u64 = 0u64
fn mb_pb_set_lo(i: u64, s: i64, l0: u64, l1: u64, l2: u64, l3: u64, e: i64) -> u64 @export {
    if i >= 18432u64 { return 1u64 }
    if MB_TLS[i] == 0i64 {
        if (l0 | l1 | l2 | l3) != 0u64 { MB_TSETL = MB_TSETL + 1u64 }
    }
    MB_TLS[i] = s
    MB_TL0[i] = l0
    MB_TL1[i] = l1
    MB_TL2[i] = l2
    MB_TL3[i] = l3
    MB_TLE[i] = e
    return 0u64
}
fn mb_pb_set_hi(i: u64, s: i64, l0: u64, l1: u64, l2: u64, l3: u64, e: i64) -> u64 @export {
    if i >= 18432u64 { return 1u64 }
    MB_THS[i] = s
    MB_TH0[i] = l0
    MB_TH1[i] = l1
    MB_TH2[i] = l2
    MB_TH3[i] = l3
    MB_THE[i] = e
    return 0u64
}
fn mb_pb_set_ex(i: u64, s: i64, l0: u64, l1: u64, l2: u64, l3: u64, e: i64) -> u64 @export {
    if i >= 18432u64 { return 1u64 }
    MB_TXS[i] = s
    MB_TX0[i] = l0
    MB_TX1[i] = l1
    MB_TX2[i] = l2
    MB_TX3[i] = l3
    MB_TXE[i] = e
    return 0u64
}
fn mb_pb_mark(nl: u64, nh: u64, nx: u64) -> u64 @export {
    MB_TSETL = nl
    MB_TSETH = nh
    MB_TSETX = nx
    return 0u64
}

/* THE PROJECTION: o_proj rows against the standing thought.
 * which 0 = lower bound (law of signs picks the crossing endpoint),
 * 1 = upper bound, 2 = the exact one-voice point.  Every product is an
 * exact integer shift-and-add; the interval carries ONLY the widths the
 * softmax ladders created.  Chunked prefixes re-folded = the row teeth. */
var MB_OLS : [i64; 7168]
var MB_OLL : [u64; 57344]
var MB_OLE : [i64; 7168]
var MB_OHS : [i64; 7168]
var MB_OHL : [u64; 57344]
var MB_OHE : [i64; 7168]
var MB_OXS : [i64; 7168]
var MB_OXL : [u64; 57344]
var MB_OXE : [i64; 7168]
var MB_PBGUARD : u64 = 0u64

/* 8-limb term/acc engine (the deposit mantissas are 4-limb and the
 * canonical exponents scatter; 512 bits with a multi-word shift) */
var MB_P8 : [u64; 8]
var MB_A8S : i64 = 0i64
var MB_A8 : [u64; 8]
var MB_C8S : [i64; 96]
var MB_C8L : [u64; 768]

/* P8 = (l0..l3) * m << sh (sh <= 192; top spill counted as overflow) */
fn mb_p8_mul4_shl(l0: u64, l1: u64, l2: u64, l3: u64, m: u64, sh: u64) -> i32 {
    let mut k : u64 = 0u64
    while k < 8u64 {
        MB_P8[k] = 0u64
        k = k + 1u64
    }
    mb_mul64(l0, m)
    MB_P8[0] = MB_MLO
    MB_P8[1] = MB_MHI
    /* zero upper limbs contribute exactly zero with zero carry: skip the
     * multiplies (the df-shaped deposits are one limb wide) */
    if l1 != 0u64 {
        mb_mul64(l1, m)
        let s1 : u64 = MB_P8[1] + MB_MLO
        let mut c1 : u64 = 0u64
        if s1 < MB_MLO { c1 = 1u64 }
        MB_P8[1] = s1
        MB_P8[2] = MB_MHI + c1
    }
    if l2 != 0u64 {
        mb_mul64(l2, m)
        let s2 : u64 = MB_P8[2] + MB_MLO
        let mut c2 : u64 = 0u64
        if s2 < MB_MLO { c2 = 1u64 }
        MB_P8[2] = s2
        MB_P8[3] = MB_MHI + c2
    }
    if l3 != 0u64 {
        mb_mul64(l3, m)
        let s3 : u64 = MB_P8[3] + MB_MLO
        let mut c3 : u64 = 0u64
        if s3 < MB_MLO { c3 = 1u64 }
        MB_P8[3] = s3
        MB_P8[4] = MB_MHI + c3
    }
    if sh != 0u64 {
        let w : u64 = sh / 64u64
        let b : u64 = sh % 64u64
        let mut k2 : u64 = 8u64
        while k2 != 0u64 {
            k2 = k2 - 1u64
            let mut v : u64 = 0u64
            if k2 >= w {
                let src : u64 = k2 - w
                v = MB_P8[src] << b
                if b != 0u64 {
                    if src != 0u64 { v = v | (MB_P8[src - 1u64] >> (64u64 - b)) }
                }
            }
            /* spill guard: anything shifted beyond limb 7 is overflow */
            if k2 == 7u64 {
                if w != 0u64 {
                    let hi_src : u64 = 8u64 - w
                    let mut sp : u64 = 0u64
                    let mut ks : u64 = hi_src
                    while ks < 5u64 {
                        sp = sp | MB_P8[ks]
                        ks = ks + 1u64
                    }
                    if sp != 0u64 { MB_GZOVF = MB_GZOVF + 1u64 }
                }
                if b != 0u64 {
                    let mut top_src : u64 = 7u64
                    if w <= 7u64 { top_src = 7u64 - w }
                    if top_src <= 4u64 {
                        if (MB_P8[top_src] >> (64u64 - b)) != 0u64 { MB_GZOVF = MB_GZOVF + 1u64 }
                    }
                }
            }
            if k2 >= w {
                /* write after the guard pass uses old values above it */
                MB_P8[k2] = v
            }
            if k2 < w { MB_P8[k2] = 0u64 }
        }
    }
    return 0i32
}

/* MB_A8 += ss * P8, sign-magnitude */
fn mb_a8_add(ss: i64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let mut nz : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        nz = nz | MB_P8[k]
        k = k + 1u64
    }
    if nz == 0u64 { return 0i32 }
    if MB_A8S == 0i64 {
        MB_A8S = ss
        k = 0u64
        while k < 8u64 {
            MB_A8[k] = MB_P8[k]
            k = k + 1u64
        }
        return 0i32
    }
    if MB_A8S == ss {
        let mut carry : u64 = 0u64
        k = 0u64
        while k < 8u64 {
            let a : u64 = MB_A8[k] + MB_P8[k]
            let mut c2 : u64 = 0u64
            if a < MB_P8[k] { c2 = 1u64 }
            let b : u64 = a + carry
            if b < carry { c2 = c2 + 1u64 }
            MB_A8[k] = b
            carry = c2
            k = k + 1u64
        }
        if carry != 0u64 { MB_GZOVF = MB_GZOVF + 1u64 }
        return 0i32
    }
    let mut cmp : i64 = 0i64
    k = 8u64
    while k != 0u64 {
        k = k - 1u64
        if cmp == 0i64 {
            let x : u64 = MB_A8[k]
            let y : u64 = MB_P8[k]
            if x > y { cmp = 1i64 }
            if x < y { cmp = 0i64 - 1i64 }
        }
    }
    if cmp == 0i64 {
        MB_A8S = 0i64
        k = 0u64
        while k < 8u64 {
            MB_A8[k] = 0u64
            k = k + 1u64
        }
        return 0i32
    }
    if cmp > 0i64 {
        let mut borrow : u64 = 0u64
        k = 0u64
        while k < 8u64 {
            let d : u64 = MB_A8[k] - MB_P8[k]
            let mut b2 : u64 = 0u64
            if MB_A8[k] < MB_P8[k] { b2 = 1u64 }
            let e : u64 = d - borrow
            if d < borrow { b2 = b2 + 1u64 }
            MB_A8[k] = e
            borrow = b2
            k = k + 1u64
        }
        return 0i32
    }
    let mut borrow2 : u64 = 0u64
    k = 0u64
    while k < 8u64 {
        let d3 : u64 = MB_P8[k] - MB_A8[k]
        let mut b3 : u64 = 0u64
        if MB_P8[k] < MB_A8[k] { b3 = 1u64 }
        let e3 : u64 = d3 - borrow2
        if d3 < borrow2 { b3 = b3 + 1u64 }
        MB_A8[k] = e3
        borrow2 = b3
        k = k + 1u64
    }
    MB_A8S = ss
    return 0i32
}

/* one bound's row accumulation over the decoded MB_GW row */
fn mb_pb_rowdot(n: u64, which: u64) -> u64 {
    let mut emin : i64 = 1000000i64
    let mut emax : i64 = 0i64 - 1000000i64
    let mut c : u64 = 0u64
    while c < n {
        let wq : i64 = MB_GW[c]
        if wq != 0i64 {
            let mut ts : i64 = 0i64
            let mut te : i64 = 0i64
            if which == 0u64 {
                ts = MB_TLS[c]
                te = MB_TLE[c]
                if wq < 0i64 {
                    ts = MB_THS[c]
                    te = MB_THE[c]
                }
            }
            if which == 1u64 {
                ts = MB_THS[c]
                te = MB_THE[c]
                if wq < 0i64 {
                    ts = MB_TLS[c]
                    te = MB_TLE[c]
                }
            }
            if which == 2u64 {
                ts = MB_TXS[c]
                te = MB_TXE[c]
            }
            if ts != 0i64 {
                let ee : i64 = te - 24i64
                if ee < emin { emin = ee }
                if ee > emax { emax = ee }
            }
        }
        c = c + 1u64
    }
    if emin == 1000000i64 {
        MB_A8S = 0i64
        let mut kz : u64 = 0u64
        while kz < 8u64 {
            MB_A8[kz] = 0u64
            kz = kz + 1u64
        }
        MB_PDE = 0i64
        return 0u64
    }
    if emax - emin > 160i64 { return 2u64 }
    MB_A8S = 0i64
    let mut k : u64 = 0u64
    while k < 8u64 {
        MB_A8[k] = 0u64
        k = k + 1u64
    }
    MB_GZOVF = 0u64
    let nch : u64 = (n + 255u64) / 256u64
    let mut ch : u64 = 0u64
    while ch < nch {
        let mut ce : u64 = ch * 256u64
        let mut cend : u64 = ce + 256u64
        if cend > n { cend = n }
        while ce < cend {
            let wq2 : i64 = MB_GW[ce]
            if wq2 != 0i64 {
                let mut s2 : i64 = 0i64
                let mut v0 : u64 = 0u64
                let mut v1 : u64 = 0u64
                let mut v2 : u64 = 0u64
                let mut v3 : u64 = 0u64
                let mut e2 : i64 = 0i64
                let mut pick_hi : u64 = 0u64
                if which == 1u64 { pick_hi = 1u64 }
                if wq2 < 0i64 { pick_hi = 1u64 - pick_hi }
                if which == 2u64 {
                    s2 = MB_TXS[ce]
                    v0 = MB_TX0[ce]
                    v1 = MB_TX1[ce]
                    v2 = MB_TX2[ce]
                    v3 = MB_TX3[ce]
                    e2 = MB_TXE[ce]
                }
                if which != 2u64 {
                    if pick_hi == 0u64 {
                        s2 = MB_TLS[ce]
                        v0 = MB_TL0[ce]
                        v1 = MB_TL1[ce]
                        v2 = MB_TL2[ce]
                        v3 = MB_TL3[ce]
                        e2 = MB_TLE[ce]
                    }
                    if pick_hi == 1u64 {
                        s2 = MB_THS[ce]
                        v0 = MB_TH0[ce]
                        v1 = MB_TH1[ce]
                        v2 = MB_TH2[ce]
                        v3 = MB_TH3[ce]
                        e2 = MB_THE[ce]
                    }
                }
                if s2 != 0i64 {
                    let mut wm : u64 = wq2 as u64
                    if wq2 < 0i64 { wm = (0i64 - wq2) as u64 }
                    let mut sg : i64 = s2
                    if wq2 < 0i64 { sg = 0i64 - sg }
                    let sh : u64 = ((e2 - 24i64) - emin) as u64
                    mb_p8_mul4_shl(v0, v1, v2, v3, wm, sh)
                    mb_a8_add(sg)
                }
            }
            ce = ce + 1u64
        }
        MB_C8S[ch] = MB_A8S
        let mut q : u64 = 0u64
        while q < 8u64 {
            MB_C8L[ch * 8u64 + q] = MB_A8[q]
            q = q + 1u64
        }
        ch = ch + 1u64
    }
    if MB_GZOVF != 0u64 { return 2u64 }
    /* the prefix law: deltas re-folded backwards must land on the row */
    let fin_s : i64 = MB_C8S[nch - 1u64]
    MB_A8S = 0i64
    k = 0u64
    while k < 8u64 {
        MB_A8[k] = 0u64
        k = k + 1u64
    }
    let mut ck : u64 = nch
    while ck != 0u64 {
        ck = ck - 1u64
        let mut q2 : u64 = 0u64
        while q2 < 8u64 {
            MB_P8[q2] = MB_C8L[ck * 8u64 + q2]
            q2 = q2 + 1u64
        }
        mb_a8_add(MB_C8S[ck])
        if ck != 0u64 {
            q2 = 0u64
            while q2 < 8u64 {
                MB_P8[q2] = MB_C8L[(ck - 1u64) * 8u64 + q2]
                q2 = q2 + 1u64
            }
            mb_a8_add(0i64 - MB_C8S[ck - 1u64])
        }
    }
    if MB_A8S != fin_s { return 1u64 }
    k = 0u64
    while k < 8u64 {
        if MB_A8[k] != MB_C8L[(nch - 1u64) * 8u64 + k] { return 1u64 }
        k = k + 1u64
    }
    MB_PDE = emin
    return 0u64
}

/* the full projection sweep: 0 ok / 1 red / 2 guard / 3 absent (named) */
fn mb_pb_project() -> u64 @export {
    if MB_G_F[7] == 0u8 { return 3u64 }
    if MB_TSETL != 16384u64 { return 1u64 }
    if MB_TSETH != 16384u64 { return 1u64 }
    if MB_TSETX != 16384u64 { return 1u64 }
    let n : u64 = MB_G_NE0[7]
    if n != 16384u64 { return 2u64 }
    let rows : u64 = MB_G_NE[7] / n
    if rows != MB_G_NE[0] { return 2u64 }
    if rows != 7168u64 { return 2u64 }
    let bv : u64 = mb_tbv(MB_G_TYPE[7])
    if bv != 256u64 { return 2u64 }
    mb_mkpath(MB_G_SH[7])
    MB_LFILE[0] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0] == 0u64 { return 1u64 }
    let mut r : u64 = 0u64
    while r < rows {
        if mb_gz_wrow(7u64, r) != 0u64 {
            fclose(MB_LFILE[0])
            return 1u64
        }
        let mut w : u64 = 0u64
        while w < 3u64 {
            let rc : u64 = mb_pb_rowdot(n, w)
            if rc != 0u64 {
                fclose(MB_LFILE[0])
                if rc == 2u64 { MB_PBGUARD = MB_PBGUARD + 1u64 }
                return rc
            }
            if w == 0u64 {
                MB_OLS[r] = MB_A8S
                MB_OLE[r] = MB_PDE
            }
            if w == 1u64 {
                MB_OHS[r] = MB_A8S
                MB_OHE[r] = MB_PDE
            }
            if w == 2u64 {
                MB_OXS[r] = MB_A8S
                MB_OXE[r] = MB_PDE
            }
            let mut k2 : u64 = 0u64
            while k2 < 8u64 {
                if w == 0u64 { MB_OLL[r * 8u64 + k2] = MB_A8[k2] }
                if w == 1u64 { MB_OHL[r * 8u64 + k2] = MB_A8[k2] }
                if w == 2u64 { MB_OXL[r * 8u64 + k2] = MB_A8[k2] }
                k2 = k2 + 1u64
            }
            w = w + 1u64
        }
        r = r + 1u64
    }
    fclose(MB_LFILE[0])
    return 0u64
}
fn mb_pb_o_s(r: u64, which: u64) -> i64 @export {
    if r >= 7168u64 { return 0i64 }
    if which == 0u64 { return MB_OLS[r] }
    if which == 1u64 { return MB_OHS[r] }
    return MB_OXS[r]
}
fn mb_pb_o_l(r: u64, which: u64, k: u64) -> u64 @export {
    if r >= 7168u64 { return 0u64 }
    if k >= 8u64 { return 0u64 }
    if which == 0u64 { return MB_OLL[r * 8u64 + k] }
    if which == 1u64 { return MB_OHL[r * 8u64 + k] }
    return MB_OXL[r * 8u64 + k]
}
fn mb_pb_o_e(r: u64, which: u64) -> i64 @export {
    if r >= 7168u64 { return 0i64 }
    if which == 0u64 { return MB_OLE[r] }
    if which == 1u64 { return MB_OHE[r] }
    return MB_OXE[r]
}

/* ============ THE PROJECTION LOOM: four weavers, one thought ============
 * The static partition theorem again: rows are never split, every weaver
 * owns its own file handle, row buffer, term/acc engines and guards; the
 * deposited thought is READ-ONLY under the launch.  Determinism owes
 * nothing to timing; the witness rows re-derived on the main thread by
 * the SEQUENTIAL engine must match the fleet limb for limb. */

var MB_GWW : [i64; 73728]
var MB_PA8S : [i64; 4]
var MB_PA8 : [u64; 32]
var MB_PP8 : [u64; 32]
var MB_PC8S : [i64; 384]
var MB_PC8L : [u64; 3072]
var MB_POVF : [u64; 4]
var MB_PPDE : [i64; 4]

/* worker row decode of census slot g into the private row buffer */
fn mb_pb_wrow(w: u64, g: u64, row: u64) -> u64 {
    let mut ty : u64 = MB_G_TYPE[g]
    let mut ne0 : u64 = MB_G_NE0[g]
    let mut tdb : u64 = MB_G_DB[g]
    let mut toff : u64 = MB_G_OFF[g]
    let mut prow : u64 = row
    if MB_PBSRC == 1u64 {
        ty = MB_ME_TYPE[g]
        ne0 = MB_ME_NE0[g]
        tdb = MB_ME_DB[g]
        toff = MB_ME_OFF[g]
        prow = row + MB_PBEXP * MB_PBROWS
    }
    let bb : u64 = mb_tbb(ty)
    let bv : u64 = mb_tbv(ty)
    if bv != 256u64 { return 1u64 }
    let bpr : u64 = ne0 / 256u64
    let base : u64 = w * 18432u64
    let vbase : u64 = w * 256u64
    let mut b : u64 = 0u64
    while b < bpr {
        let abs : u64 = tdb + toff + (prow * bpr + b) * bb
        if mb_wread(w, abs, bb) != 0u64 { return 1u64 }
        if mb_wdec(w, ty, 0u64) != 0u64 { return 1u64 }
        let mut e : u64 = 0u64
        while e < 256u64 {
            MB_GWW[base + b * 256u64 + e] = MB_LVA[vbase + e]
            e = e + 1u64
        }
        b = b + 1u64
    }
    return 0u64
}

/* worker 8-limb term: P8[w] = (l0..l3) * m << sh (worker-private multiply
 * scratch ONLY -- the shared MB_MHI/MB_MLO would be a race) */
fn mb_pw8_mul4_shl(w: u64, l0: u64, l1: u64, l2: u64, l3: u64, m: u64, sh: u64) -> i32 {
    let base : u64 = w * 8u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        MB_PP8[base + k] = 0u64
        k = k + 1u64
    }
    mb_wmul64(w, l0, m)
    MB_PP8[base] = MB_LML[w]
    MB_PP8[base + 1u64] = MB_LMH[w]
    /* zero upper limbs contribute exactly zero with zero carry: skip */
    if l1 != 0u64 {
        mb_wmul64(w, l1, m)
        let s1 : u64 = MB_PP8[base + 1u64] + MB_LML[w]
        let mut c1 : u64 = 0u64
        if s1 < MB_LML[w] { c1 = 1u64 }
        MB_PP8[base + 1u64] = s1
        MB_PP8[base + 2u64] = MB_LMH[w] + c1
    }
    if l2 != 0u64 {
        mb_wmul64(w, l2, m)
        let s2 : u64 = MB_PP8[base + 2u64] + MB_LML[w]
        let mut c2 : u64 = 0u64
        if s2 < MB_LML[w] { c2 = 1u64 }
        MB_PP8[base + 2u64] = s2
        MB_PP8[base + 3u64] = MB_LMH[w] + c2
    }
    if l3 != 0u64 {
        mb_wmul64(w, l3, m)
        let s3 : u64 = MB_PP8[base + 3u64] + MB_LML[w]
        let mut c3 : u64 = 0u64
        if s3 < MB_LML[w] { c3 = 1u64 }
        MB_PP8[base + 3u64] = s3
        MB_PP8[base + 4u64] = MB_LMH[w] + c3
    }
    if sh != 0u64 {
        let ww : u64 = sh / 64u64
        let bb2 : u64 = sh % 64u64
        if ww == 3u64 {
            if bb2 != 0u64 {
                if (MB_PP8[base + 4u64] >> (64u64 - bb2)) != 0u64 { MB_POVF[w] = MB_POVF[w] + 1u64 }
            }
        }
        let mut k2 : u64 = 8u64
        while k2 != 0u64 {
            k2 = k2 - 1u64
            let mut v : u64 = 0u64
            if k2 >= ww {
                let src : u64 = k2 - ww
                v = MB_PP8[base + src] << bb2
                if bb2 != 0u64 {
                    if src != 0u64 { v = v | (MB_PP8[base + src - 1u64] >> (64u64 - bb2)) }
                }
            }
            MB_PP8[base + k2] = v
            if k2 < ww { MB_PP8[base + k2] = 0u64 }
        }
    }
    return 0i32
}

/* worker acc: A8[w] += ss * P8[w] */
fn mb_pw8_add(w: u64, ss: i64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let base : u64 = w * 8u64
    let mut nz : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        nz = nz | MB_PP8[base + k]
        k = k + 1u64
    }
    if nz == 0u64 { return 0i32 }
    if MB_PA8S[w] == 0i64 {
        MB_PA8S[w] = ss
        k = 0u64
        while k < 8u64 {
            MB_PA8[base + k] = MB_PP8[base + k]
            k = k + 1u64
        }
        return 0i32
    }
    if MB_PA8S[w] == ss {
        let mut carry : u64 = 0u64
        k = 0u64
        while k < 8u64 {
            let a : u64 = MB_PA8[base + k] + MB_PP8[base + k]
            let mut c2 : u64 = 0u64
            if a < MB_PP8[base + k] { c2 = 1u64 }
            let b : u64 = a + carry
            if b < carry { c2 = c2 + 1u64 }
            MB_PA8[base + k] = b
            carry = c2
            k = k + 1u64
        }
        if carry != 0u64 { MB_POVF[w] = MB_POVF[w] + 1u64 }
        return 0i32
    }
    let mut cmp : i64 = 0i64
    k = 8u64
    while k != 0u64 {
        k = k - 1u64
        if cmp == 0i64 {
            let x : u64 = MB_PA8[base + k]
            let y : u64 = MB_PP8[base + k]
            if x > y { cmp = 1i64 }
            if x < y { cmp = 0i64 - 1i64 }
        }
    }
    if cmp == 0i64 {
        MB_PA8S[w] = 0i64
        k = 0u64
        while k < 8u64 {
            MB_PA8[base + k] = 0u64
            k = k + 1u64
        }
        return 0i32
    }
    if cmp > 0i64 {
        let mut borrow : u64 = 0u64
        k = 0u64
        while k < 8u64 {
            let d : u64 = MB_PA8[base + k] - MB_PP8[base + k]
            let mut b2 : u64 = 0u64
            if MB_PA8[base + k] < MB_PP8[base + k] { b2 = 1u64 }
            let e : u64 = d - borrow
            if d < borrow { b2 = b2 + 1u64 }
            MB_PA8[base + k] = e
            borrow = b2
            k = k + 1u64
        }
        return 0i32
    }
    let mut borrow2 : u64 = 0u64
    k = 0u64
    while k < 8u64 {
        let d3 : u64 = MB_PP8[base + k] - MB_PA8[base + k]
        let mut b3 : u64 = 0u64
        if MB_PP8[base + k] < MB_PA8[base + k] { b3 = 1u64 }
        let e3 : u64 = d3 - borrow2
        if d3 < borrow2 { b3 = b3 + 1u64 }
        MB_PA8[base + k] = e3
        borrow2 = b3
        k = k + 1u64
    }
    MB_PA8S[w] = ss
    return 0i32
}

/* worker row dot over the private buffer (same law as the sequential) */
fn mb_pb_rowdot_w(w: u64, n: u64, which: u64) -> u64 {
    let gbase : u64 = w * 18432u64
    let mut emin : i64 = 1000000i64
    let mut emax : i64 = 0i64 - 1000000i64
    let mut c : u64 = 0u64
    while c < n {
        let wq : i64 = MB_GWW[gbase + c]
        if wq != 0i64 {
            let mut ts : i64 = 0i64
            let mut te : i64 = 0i64
            if which == 0u64 {
                ts = MB_TLS[c]
                te = MB_TLE[c]
                if wq < 0i64 {
                    ts = MB_THS[c]
                    te = MB_THE[c]
                }
            }
            if which == 1u64 {
                ts = MB_THS[c]
                te = MB_THE[c]
                if wq < 0i64 {
                    ts = MB_TLS[c]
                    te = MB_TLE[c]
                }
            }
            if which == 2u64 {
                ts = MB_TXS[c]
                te = MB_TXE[c]
            }
            if ts != 0i64 {
                let ee : i64 = te - 24i64
                if ee < emin { emin = ee }
                if ee > emax { emax = ee }
            }
        }
        c = c + 1u64
    }
    if emin == 1000000i64 {
        MB_PA8S[w] = 0i64
        let mut kz : u64 = 0u64
        while kz < 8u64 {
            MB_PA8[w * 8u64 + kz] = 0u64
            kz = kz + 1u64
        }
        MB_PPDE[w] = 0i64
        return 0u64
    }
    if emax - emin > 160i64 { return 2u64 }
    MB_PA8S[w] = 0i64
    let mut k : u64 = 0u64
    while k < 8u64 {
        MB_PA8[w * 8u64 + k] = 0u64
        k = k + 1u64
    }
    MB_POVF[w] = 0u64
    let nch : u64 = (n + 255u64) / 256u64
    let mut ch : u64 = 0u64
    while ch < nch {
        let mut ce : u64 = ch * 256u64
        let mut cend : u64 = ce + 256u64
        if cend > n { cend = n }
        while ce < cend {
            let wq2 : i64 = MB_GWW[gbase + ce]
            if wq2 != 0i64 {
                let mut s2 : i64 = 0i64
                let mut v0 : u64 = 0u64
                let mut v1 : u64 = 0u64
                let mut v2 : u64 = 0u64
                let mut v3 : u64 = 0u64
                let mut e2 : i64 = 0i64
                let mut pick_hi : u64 = 0u64
                if which == 1u64 { pick_hi = 1u64 }
                if wq2 < 0i64 { pick_hi = 1u64 - pick_hi }
                if which == 2u64 {
                    s2 = MB_TXS[ce]
                    v0 = MB_TX0[ce]
                    v1 = MB_TX1[ce]
                    v2 = MB_TX2[ce]
                    v3 = MB_TX3[ce]
                    e2 = MB_TXE[ce]
                }
                if which != 2u64 {
                    if pick_hi == 0u64 {
                        s2 = MB_TLS[ce]
                        v0 = MB_TL0[ce]
                        v1 = MB_TL1[ce]
                        v2 = MB_TL2[ce]
                        v3 = MB_TL3[ce]
                        e2 = MB_TLE[ce]
                    }
                    if pick_hi == 1u64 {
                        s2 = MB_THS[ce]
                        v0 = MB_TH0[ce]
                        v1 = MB_TH1[ce]
                        v2 = MB_TH2[ce]
                        v3 = MB_TH3[ce]
                        e2 = MB_THE[ce]
                    }
                }
                if s2 != 0i64 {
                    let mut wm : u64 = wq2 as u64
                    if wq2 < 0i64 { wm = (0i64 - wq2) as u64 }
                    let mut sg : i64 = s2
                    if wq2 < 0i64 { sg = 0i64 - sg }
                    let sh : u64 = ((e2 - 24i64) - emin) as u64
                    mb_pw8_mul4_shl(w, v0, v1, v2, v3, wm, sh)
                    mb_pw8_add(w, sg)
                }
            }
            ce = ce + 1u64
        }
        MB_PC8S[w * 96u64 + ch] = MB_PA8S[w]
        let mut q : u64 = 0u64
        while q < 8u64 {
            MB_PC8L[(w * 96u64 + ch) * 8u64 + q] = MB_PA8[w * 8u64 + q]
            q = q + 1u64
        }
        ch = ch + 1u64
    }
    if MB_POVF[w] != 0u64 { return 2u64 }
    /* the prefix law, worker-private */
    let cb : u64 = w * 96u64
    let fin_s : i64 = MB_PC8S[cb + nch - 1u64]
    MB_PA8S[w] = 0i64
    k = 0u64
    while k < 8u64 {
        MB_PA8[w * 8u64 + k] = 0u64
        k = k + 1u64
    }
    let mut ck : u64 = nch
    while ck != 0u64 {
        ck = ck - 1u64
        let mut q2 : u64 = 0u64
        while q2 < 8u64 {
            MB_PP8[w * 8u64 + q2] = MB_PC8L[(cb + ck) * 8u64 + q2]
            q2 = q2 + 1u64
        }
        mb_pw8_add(w, MB_PC8S[cb + ck])
        if ck != 0u64 {
            q2 = 0u64
            while q2 < 8u64 {
                MB_PP8[w * 8u64 + q2] = MB_PC8L[(cb + ck - 1u64) * 8u64 + q2]
                q2 = q2 + 1u64
            }
            mb_pw8_add(w, 0i64 - MB_PC8S[cb + ck - 1u64])
        }
    }
    if MB_PA8S[w] != fin_s { return 1u64 }
    k = 0u64
    while k < 8u64 {
        if MB_PA8[w * 8u64 + k] != MB_PC8L[(cb + nch - 1u64) * 8u64 + k] { return 1u64 }
        k = k + 1u64
    }
    MB_PPDE[w] = emin
    return 0u64
}

/* ============ THE BANKS: one law, many vessels ============
 * bank 0 = the attention vessel (O, 7168 rows -- the arrays above),
 * bank 1 = the gate (18432), bank 2 = the up (18432), bank 3 = the down
 * (7168).  Each row holds (sign, 8 limbs, exp) x (lo, hi, exact). */
var MB_BGLS : [i64; 18432]
var MB_BGLL : [u64; 147456]
var MB_BGLE : [i64; 18432]
var MB_BGHS : [i64; 18432]
var MB_BGHL : [u64; 147456]
var MB_BGHE : [i64; 18432]
var MB_BGXS : [i64; 18432]
var MB_BGXL : [u64; 147456]
var MB_BGXE : [i64; 18432]
var MB_BULS : [i64; 18432]
var MB_BULL : [u64; 147456]
var MB_BULE : [i64; 18432]
var MB_BUHS : [i64; 18432]
var MB_BUHL : [u64; 147456]
var MB_BUHE : [i64; 18432]
var MB_BUXS : [i64; 18432]
var MB_BUXL : [u64; 147456]
var MB_BUXE : [i64; 18432]
var MB_BDLS : [i64; 7168]
var MB_BDLL : [u64; 57344]
var MB_BDLE : [i64; 7168]
var MB_BDHS : [i64; 7168]
var MB_BDHL : [u64; 57344]
var MB_BDHE : [i64; 7168]
var MB_BDXS : [i64; 7168]
var MB_BDXL : [u64; 57344]
var MB_BDXE : [i64; 7168]
/* bank 4 = the MLA kv_b vessel (512 -> 32768 = 128 heads x [k128|v128]) */
var MB_B4LS : [i64; 32768]
var MB_B4LL : [u64; 262144]
var MB_B4LE : [i64; 32768]
var MB_B4HS : [i64; 32768]
var MB_B4HL : [u64; 262144]
var MB_B4HE : [i64; 32768]
var MB_B4XS : [i64; 32768]
var MB_B4XL : [u64; 262144]
var MB_B4XE : [i64; 32768]

/* store worker w's standing acc into bank (r, which) */
fn mb_pb_bstore(bank: u64, r: u64, which: u64, w: u64) -> i32 {
    let ss : i64 = MB_PA8S[w]
    let ee : i64 = MB_PPDE[w]
    if bank == 0u64 {
        if which == 0u64 {
            MB_OLS[r] = ss
            MB_OLE[r] = ee
        }
        if which == 1u64 {
            MB_OHS[r] = ss
            MB_OHE[r] = ee
        }
        if which == 2u64 {
            MB_OXS[r] = ss
            MB_OXE[r] = ee
        }
    }
    if bank == 1u64 {
        if which == 0u64 {
            MB_BGLS[r] = ss
            MB_BGLE[r] = ee
        }
        if which == 1u64 {
            MB_BGHS[r] = ss
            MB_BGHE[r] = ee
        }
        if which == 2u64 {
            MB_BGXS[r] = ss
            MB_BGXE[r] = ee
        }
    }
    if bank == 2u64 {
        if which == 0u64 {
            MB_BULS[r] = ss
            MB_BULE[r] = ee
        }
        if which == 1u64 {
            MB_BUHS[r] = ss
            MB_BUHE[r] = ee
        }
        if which == 2u64 {
            MB_BUXS[r] = ss
            MB_BUXE[r] = ee
        }
    }
    if bank == 3u64 {
        if which == 0u64 {
            MB_BDLS[r] = ss
            MB_BDLE[r] = ee
        }
        if which == 1u64 {
            MB_BDHS[r] = ss
            MB_BDHE[r] = ee
        }
        if which == 2u64 {
            MB_BDXS[r] = ss
            MB_BDXE[r] = ee
        }
    }
    if bank == 4u64 {
        if which == 0u64 {
            MB_B4LS[r] = ss
            MB_B4LE[r] = ee
        }
        if which == 1u64 {
            MB_B4HS[r] = ss
            MB_B4HE[r] = ee
        }
        if which == 2u64 {
            MB_B4XS[r] = ss
            MB_B4XE[r] = ee
        }
    }
    let mut k : u64 = 0u64
    while k < 8u64 {
        let v : u64 = MB_PA8[w * 8u64 + k]
        let ix : u64 = r * 8u64 + k
        if bank == 0u64 {
            if which == 0u64 { MB_OLL[ix] = v }
            if which == 1u64 { MB_OHL[ix] = v }
            if which == 2u64 { MB_OXL[ix] = v }
        }
        if bank == 1u64 {
            if which == 0u64 { MB_BGLL[ix] = v }
            if which == 1u64 { MB_BGHL[ix] = v }
            if which == 2u64 { MB_BGXL[ix] = v }
        }
        if bank == 2u64 {
            if which == 0u64 { MB_BULL[ix] = v }
            if which == 1u64 { MB_BUHL[ix] = v }
            if which == 2u64 { MB_BUXL[ix] = v }
        }
        if bank == 3u64 {
            if which == 0u64 { MB_BDLL[ix] = v }
            if which == 1u64 { MB_BDHL[ix] = v }
            if which == 2u64 { MB_BDXL[ix] = v }
        }
        if bank == 4u64 {
            if which == 0u64 { MB_B4LL[ix] = v }
            if which == 1u64 { MB_B4HL[ix] = v }
            if which == 2u64 { MB_B4XL[ix] = v }
        }
        k = k + 1u64
    }
    return 0i32
}

/* the run premises, set once before the fleet launches (read-only under
 * the launch -- the same static-partition theorem as the loom) */
var MB_PBSLOT : u64 = 0u64
var MB_PBN : u64 = 0u64
var MB_PBROWS : u64 = 0u64
var MB_PBBANK : u64 = 0u64
var MB_PBPASS : u64 = 0u64
/* source select: 0 = the layer census (MB_G), 1 = a MoE expert (MB_ME
 * at role MB_PBSLOT, physical rows offset by expert*rows) */
var MB_PBSRC : u64 = 0u64
var MB_PBEXP : u64 = 0u64

/* the weaver: a static slice of the run's output rows */
fn mb_pb_worker(arg: u64) -> u32 {
    let w : u64 = arg
    let g : u64 = MB_PBSLOT
    let n : u64 = MB_PBN
    let slice : u64 = MB_PBROWS / 4u64
    let start : u64 = w * slice
    let endr : u64 = start + slice
    let mut r : u64 = start
    while r < endr {
        if mb_pb_wrow(w, g, r) != 0u64 {
            MB_LRC[w] = 382u64
            return 0u32
        }
        let mut ww : u64 = 0u64
        while ww < MB_PBPASS {
            let rc : u64 = mb_pb_rowdot_w(w, n, ww)
            if rc != 0u64 {
                MB_LRC[w] = 380u64 + rc
                return 0u32
            }
            mb_pb_bstore(MB_PBBANK, r, ww, w)
            ww = ww + 1u64
        }
        r = r + 1u64
    }
    MB_LRC[w] = 0u64
    return 0u32
}

/* the parallel run: one law for every projection of the layer.
 * returns 0 ok / 1 red / 2 guard-or-geometry (named) / 3 absent (named) */
fn mb_pb_run_par(slot: u64, n: u64, rows: u64, bank: u64, passes: u64) -> u64 @export {
    if slot >= 732u64 { return 2u64 }
    if bank >= 5u64 { return 2u64 }
    if passes != 3u64 { return 2u64 }
    if MB_G_F[slot] == 0u8 { return 3u64 }
    if MB_TSETL != n { return 1u64 }
    if MB_TSETH != n { return 1u64 }
    if MB_TSETX != n { return 1u64 }
    if n > 18432u64 { return 2u64 }
    if MB_G_NE0[slot] != n { return 2u64 }
    if MB_G_NE[slot] / n != rows { return 2u64 }
    if rows % 4u64 != 0u64 { return 2u64 }
    let mut bcap : u64 = 7168u64
    if bank == 1u64 { bcap = 18432u64 }
    if bank == 2u64 { bcap = 18432u64 }
    if bank == 4u64 { bcap = 32768u64 }
    if rows > bcap { return 2u64 }
    let bv : u64 = mb_tbv(MB_G_TYPE[slot])
    if bv != 256u64 { return 2u64 }
    MB_PBSLOT = slot
    MB_PBN = n
    MB_PBROWS = rows
    MB_PBBANK = bank
    MB_PBPASS = passes
    MB_PBSRC = 0u64
    return mb_pb_launch(MB_G_SH[slot])
}

/* the shared four-weaver launch (config already in the MB_PB* premises,
 * source-select in MB_PBSRC): open private handles, spin, join, verdict.
 * 0 ok / 1 red / 2 guard */
fn mb_pb_launch(shard: u64) -> u64 {
    mb_mkpath(shard)
    let mut w : u64 = 0u64
    while w < 4u64 {
        MB_LFILE[w] = fopen((&MB_PATH) as u64, "rb" as u64)
        if MB_LFILE[w] == 0u64 {
            let mut c : u64 = 0u64
            while c < w {
                fclose(MB_LFILE[c])
                c = c + 1u64
            }
            return 1u64
        }
        w = w + 1u64
    }
    let entry : u64 = mb_pb_worker as u64
    w = 0u64
    while w < 4u64 {
        MB_LRC[w] = 999u64
        MB_LH[w] = CreateThread(0u64, 0u64, entry, w, 0u64, 0u64)
        if MB_LH[w] == 0u64 {
            let mut j : u64 = 0u64
            while j < w {
                WaitForSingleObject(MB_LH[j], 0xFFFFFFFFu32)
                CloseHandle(MB_LH[j])
                j = j + 1u64
            }
            let mut c2 : u64 = 0u64
            while c2 < 4u64 {
                fclose(MB_LFILE[c2])
                c2 = c2 + 1u64
            }
            return 1u64
        }
        w = w + 1u64
    }
    w = 0u64
    while w < 4u64 {
        WaitForSingleObject(MB_LH[w], 0xFFFFFFFFu32)
        CloseHandle(MB_LH[w])
        w = w + 1u64
    }
    w = 0u64
    while w < 4u64 {
        fclose(MB_LFILE[w])
        w = w + 1u64
    }
    w = 0u64
    while w < 4u64 {
        if MB_LRC[w] == 382u64 { return 1u64 }
        if MB_LRC[w] == 381u64 { return 1u64 }
        if MB_LRC[w] == 383u64 { return 2u64 }
        if MB_LRC[w] != 0u64 { return 1u64 }
        w = w + 1u64
    }
    return 0u64
}

/* a MoE expert projection: role (MB_ME) + expert index, rows per expert.
 * The physical rows are offset by expert*rows inside the 3D expert tensor. */
fn mb_pb_run_exp(role: u64, expert: u64, n: u64, rows: u64, bank: u64, passes: u64) -> u64 @export {
    if role >= 6u64 { return 2u64 }
    if bank >= 5u64 { return 2u64 }
    if passes != 3u64 { return 2u64 }
    let ab : u64 = MB_ME_BASE + role
    if MB_ME_F[ab] == 0u8 { return 3u64 }
    if MB_TSETL != n { return 1u64 }
    if MB_TSETH != n { return 1u64 }
    if MB_TSETX != n { return 1u64 }
    if n > 18432u64 { return 2u64 }
    if MB_ME_NE0[ab] != n { return 2u64 }
    if MB_ME_NE[ab] / n / 256u64 != rows { return 2u64 }
    if rows % 4u64 != 0u64 { return 2u64 }
    if expert >= 256u64 { return 2u64 }
    let mut bcap : u64 = 7168u64
    if bank == 1u64 { bcap = 18432u64 }
    if bank == 2u64 { bcap = 18432u64 }
    if bank == 4u64 { bcap = 32768u64 }
    if rows > bcap { return 2u64 }
    let bv : u64 = mb_tbv(MB_ME_TYPE[ab])
    if bv != 256u64 { return 2u64 }
    MB_PBSLOT = ab
    MB_PBN = n
    MB_PBROWS = rows
    MB_PBBANK = bank
    MB_PBPASS = passes
    MB_PBSRC = 1u64
    MB_PBEXP = expert
    return mb_pb_launch(MB_ME_SH[ab])
}

/* the attention projection, as always: the same law through the vessel */
fn mb_pb_project_par() -> u64 @export {
    return mb_pb_run_par(7u64, 16384u64, 7168u64, 0u64, 3u64)
}

/* one witness row of ANY slot re-derived by the SEQUENTIAL engine (the
 * fleet must match it limb for limb); results in the MB_PW* scratch */
var MB_PWS : [i64; 3]
var MB_PWL : [u64; 24]
var MB_PWE : [i64; 3]
fn mb_pb_rwit(slot: u64, r: u64) -> u64 @export {
    if slot >= 732u64 { return 1u64 }
    if MB_G_F[slot] == 0u8 { return 1u64 }
    let n : u64 = MB_G_NE0[slot]
    mb_mkpath(MB_G_SH[slot])
    MB_LFILE[0] = fopen((&MB_PATH) as u64, "rb" as u64)
    if MB_LFILE[0] == 0u64 { return 1u64 }
    if mb_gz_wrow(slot, r) != 0u64 {
        fclose(MB_LFILE[0])
        return 1u64
    }
    fclose(MB_LFILE[0])
    let mut ww : u64 = 0u64
    while ww < 3u64 {
        if mb_pb_rowdot(n, ww) != 0u64 { return 1u64 }
        MB_PWS[ww] = MB_A8S
        MB_PWE[ww] = MB_PDE
        let mut k : u64 = 0u64
        while k < 8u64 {
            MB_PWL[ww * 8u64 + k] = MB_A8[k]
            k = k + 1u64
        }
        ww = ww + 1u64
    }
    return 0u64
}
fn mb_pb_row_witness(r: u64) -> u64 @export {
    return mb_pb_rwit(7u64, r)
}
fn mb_pb_w_s(which: u64) -> i64 @export {
    if which >= 3u64 { return 0i64 }
    return MB_PWS[which]
}
fn mb_pb_w_l(which: u64, k: u64) -> u64 @export {
    if which >= 3u64 { return 0u64 }
    if k >= 8u64 { return 0u64 }
    return MB_PWL[which * 8u64 + k]
}
fn mb_pb_w_e(which: u64) -> i64 @export {
    if which >= 3u64 { return 0i64 }
    return MB_PWE[which]
}

/* the banked bounds, served: bank 1 = gate, 2 = up, 3 = down */
fn mb_pb_b_s(bank: u64, r: u64, which: u64) -> i64 @export {
    if bank == 1u64 {
        if r >= 18432u64 { return 0i64 }
        if which == 0u64 { return MB_BGLS[r] }
        if which == 1u64 { return MB_BGHS[r] }
        return MB_BGXS[r]
    }
    if bank == 2u64 {
        if r >= 18432u64 { return 0i64 }
        if which == 0u64 { return MB_BULS[r] }
        if which == 1u64 { return MB_BUHS[r] }
        return MB_BUXS[r]
    }
    if bank == 3u64 {
        if r >= 7168u64 { return 0i64 }
        if which == 0u64 { return MB_BDLS[r] }
        if which == 1u64 { return MB_BDHS[r] }
        return MB_BDXS[r]
    }
    if bank == 4u64 {
        if r >= 32768u64 { return 0i64 }
        if which == 0u64 { return MB_B4LS[r] }
        if which == 1u64 { return MB_B4HS[r] }
        return MB_B4XS[r]
    }
    return 0i64
}
fn mb_pb_b_l(bank: u64, r: u64, which: u64, k: u64) -> u64 @export {
    if k >= 8u64 { return 0u64 }
    let ix : u64 = r * 8u64 + k
    if bank == 1u64 {
        if r >= 18432u64 { return 0u64 }
        if which == 0u64 { return MB_BGLL[ix] }
        if which == 1u64 { return MB_BGHL[ix] }
        return MB_BGXL[ix]
    }
    if bank == 2u64 {
        if r >= 18432u64 { return 0u64 }
        if which == 0u64 { return MB_BULL[ix] }
        if which == 1u64 { return MB_BUHL[ix] }
        return MB_BUXL[ix]
    }
    if bank == 3u64 {
        if r >= 7168u64 { return 0u64 }
        if which == 0u64 { return MB_BDLL[ix] }
        if which == 1u64 { return MB_BDHL[ix] }
        return MB_BDXL[ix]
    }
    if bank == 4u64 {
        if r >= 32768u64 { return 0u64 }
        if which == 0u64 { return MB_B4LL[ix] }
        if which == 1u64 { return MB_B4HL[ix] }
        return MB_B4XL[ix]
    }
    return 0u64
}
fn mb_pb_b_e(bank: u64, r: u64, which: u64) -> i64 @export {
    if bank == 1u64 {
        if r >= 18432u64 { return 0i64 }
        if which == 0u64 { return MB_BGLE[r] }
        if which == 1u64 { return MB_BGHE[r] }
        return MB_BGXE[r]
    }
    if bank == 2u64 {
        if r >= 18432u64 { return 0i64 }
        if which == 0u64 { return MB_BULE[r] }
        if which == 1u64 { return MB_BUHE[r] }
        return MB_BUXE[r]
    }
    if bank == 3u64 {
        if r >= 7168u64 { return 0i64 }
        if which == 0u64 { return MB_BDLE[r] }
        if which == 1u64 { return MB_BDHE[r] }
        return MB_BDXE[r]
    }
    if bank == 4u64 {
        if r >= 32768u64 { return 0i64 }
        if which == 0u64 { return MB_B4LE[r] }
        if which == 1u64 { return MB_B4HE[r] }
        return MB_B4XE[r]
    }
    return 0i64
}

/* THE FFN PREMISES: the dense blk.0 feed-forward on the ledger's terms.
 * Checks the census slots 8..11 (norm f32 7168; gate/up 18432 x 7168;
 * down 7168 x 18432; 256-value blocks) and loads gamma4 exactly.
 * 0 ok / 2 foreign geometry (named) / 3 absent (named) */
var MB_FFNOK : u64 = 0u64
fn mb_pb_ffn_ok() -> u64 @export {
    MB_FFNOK = 0u64
    if MB_G_F[8] == 0u8 { return 3u64 }
    if MB_G_F[9] == 0u8 { return 3u64 }
    if MB_G_F[10] == 0u8 { return 3u64 }
    if MB_G_F[11] == 0u8 { return 3u64 }
    if MB_G_NE[8] != 7168u64 { return 2u64 }
    if MB_G_TYPE[8] != 0u64 { return 2u64 }
    if MB_G_NE0[9] != 7168u64 { return 2u64 }
    if MB_G_NE[9] != 132120576u64 { return 2u64 }
    if MB_G_NE0[10] != 7168u64 { return 2u64 }
    if MB_G_NE[10] != 132120576u64 { return 2u64 }
    if MB_G_NE0[11] != 18432u64 { return 2u64 }
    if MB_G_NE[11] != 132120576u64 { return 2u64 }
    if mb_tbv(MB_G_TYPE[9]) != 256u64 { return 2u64 }
    if mb_tbv(MB_G_TYPE[10]) != 256u64 { return 2u64 }
    if mb_tbv(MB_G_TYPE[11]) != 256u64 { return 2u64 }
    if mb_gz_loadf32(8u64, 3u64, 7168u64) != 0u64 { return 2u64 }
    MB_FFNOK = 1u64
    return 0u64
}

/* gamma4, the ffn_norm weight, exact dyadic: value = m * 2^e */
fn mb_pb_fn_m(i: u64) -> i64 @export {
    if i >= 7168u64 { return 0i64 }
    if MB_FFNOK != 1u64 { return 0i64 }
    return MB_FNM[i]
}
fn mb_pb_fn_e(i: u64) -> i64 @export {
    if i >= 7168u64 { return 0i64 }
    if MB_FFNOK != 1u64 { return 0i64 }
    return MB_FNE[i]
}

/* METABOLE: the organism now has a mouth.  What it eats, it proves. */
