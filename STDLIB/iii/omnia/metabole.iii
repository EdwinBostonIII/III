/* the gaze's seven organs of blk.0 attention (slot order: attn_norm, q_a,
 * q_a_norm, q_b, kv_a_mqa, kv_a_norm, kv_b) */
/* the per-layer tensor census: slot = layer*12 + role, layer 0..60 (the
 * WHOLE body -- 61 layers, sentinel 732), role 0..11 (attn_norm, q_a,
 * q_a_norm, q_b, kv_a_mqa, kv_a_norm, kv_b, attn_output, ffn_norm,
 * ffn_gate, ffn_up, ffn_down).  Layer 0 keeps slots 0..11 exactly --
 * the proven gaze/choir/threpsis path is untouched; layers 1..3 keep
 * their proven slots; layers 4..60 join by the SAME law. */
var MB_G_TYPE : [u64; 732]
var MB_G_OFF  : [u64; 732]
var MB_G_NE   : [u64; 732]
var MB_G_NE0  : [u64; 732]
var MB_G_DB   : [u64; 732]
var MB_G_SH   : [u64; 732]
var MB_G_F    : [u8; 732]
var MB_G_HERE : [u8; 732]
/* the MoE expert census for EVERY MoE layer: slot = layer*6 + role
 * (sentinel 366), role 0=gate_exps 1=up_exps 2=down_exps 3=gate_shexp
 * 4=up_shexp 5=down_shexp (3D expert tensors + shared FFN).  The organ
 * SERVES one selected layer at a time through the standing role faces
 * (MB_ME_BASE, default layer 3 -- the proven synodos path unchanged). */
var MB_ME_TYPE : [u64; 366]
var MB_ME_OFF  : [u64; 366]
var MB_ME_NE   : [u64; 366]
var MB_ME_NE0  : [u64; 366]
var MB_ME_DB   : [u64; 366]
var MB_ME_SH   : [u64; 366]
var MB_ME_F    : [u8; 366]
var MB_ME_HERE : [u8; 366]
var MB_ME_BASE : u64 = 18u64
/* the per-layer router (ffn_gate_inp) and selection bias (exp_probs_b):
 * one slot per layer -- the election organs of every MoE layer */
var MB_RT_TYPE : [u64; 61]
var MB_RT_OFF  : [u64; 61]
var MB_RT_NE   : [u64; 61]
var MB_RT_NE0  : [u64; 61]
var MB_RT_DB   : [u64; 61]
var MB_RT_SH   : [u64; 61]
var MB_RT_F    : [u8; 61]
var MB_RT_HERE : [u8; 61]
