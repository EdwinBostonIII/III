/* STDLIB/iii/omnia/metron.iii -- METRON (the measure): the cost envelope is MEASURED and the
 * violation REFUSED; redundancy is a shadow, measured -- never an opinion.
 *
 * COST.  III is bit-deterministic, so step counts are exact and reproducible -- not benchmarks.
 * The counter is not invented here: omnia/exec_cert already folds one sha256 update per event,
 * so xc_len IS a tamper-evident step meter, and any organ that emits events is counted for free.
 * METRON measures REAL processes (live px_pin calls, bytes through the real fold) and judges a
 * declared envelope steps <= c*n. Within = MAINTAIN; beyond = VIOLATION, refused.
 *
 * HONEST BOUNDARY.  Inferring asymptotic complexity in general is undecidable. A measured
 * envelope at named n with a refusal is not -- and it is what a mandate needs. The quadratic
 * arm below is a REAL process (prefix re-pinning through the live organ), not a fixture.
 *
 * DESCRIPTIVE REDUNDANCY (anti-bloat, measured).  Two oracles whose verdict tables are equal
 * element-wise are ONE oracle consulted twice: [dup < origin]. The comparison runs through the
 * live ONTOS meters (ont_tbl_set / ont_image_ext -- the Tier 0 exports, consumed here). */
module omnia_metron

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn px_begin() -> i32 from "praxis.iii"
extern @abi(c-msvc-x64) fn px_pin(s: u64) -> u64 from "praxis.iii"
extern @abi(c-msvc-x64) fn xc_len() -> u64 from "exec_cert.iii"
extern @abi(c-msvc-x64) fn ont_tbl_set(i: u64, v: u64) -> i32 from "ontos.iii"
extern @abi(c-msvc-x64) fn ont_image_ext(size: u64) -> u64 from "ontos.iii"

var MT_BUF : [u8; 64]        /* the scroll under construction (module var: stable address) */
var MT_TA  : [u64; 16]       /* oracle A's verdict table */
var MT_TB  : [u64; 16]       /* oracle B's verdict table */

/* build a well-formed n-byte scroll "[aa...a < b]" (n >= 8, n <= 62): 1 + k + 5 = n. */
fn mt_mkscroll(n: u64) -> u64 {
    let k : u64 = n - 6u64
    MT_BUF[0] = 91u8
    let mut i : u64 = 0u64
    while i < k { MT_BUF[1u64 + i] = 97u8   i = i + 1u64 }
    MT_BUF[1u64 + k] = 32u8
    MT_BUF[2u64 + k] = 60u8
    MT_BUF[3u64 + k] = 32u8
    MT_BUF[4u64 + k] = 98u8
    MT_BUF[5u64 + k] = 93u8
    MT_BUF[6u64 + k] = 0u8
    return (&MT_BUF) as u64
}

/* the exact cost of ONE real pin of an n-byte scroll: n payload bytes + 1 newline through the
 * live fold. Measured, not derived -- the meter is exec_cert's own counter. */
fn mt_pin_cost(n: u64) -> u64 @export {
    px_begin()
    let a : u64 = xc_len()
    px_pin(mt_mkscroll(n))
    return xc_len() - a
}

/* the exact cost of a REAL quadratic process: re-pin every prefix scroll from 8..n bytes.
 * Total = sum(i+1) for i in 8..n -- the shape that betrays an accidental O(n^2) rescan. */
fn mt_quad_cost(n: u64) -> u64 @export {
    px_begin()
    let a : u64 = xc_len()
    let mut i : u64 = 8u64
    while i <= n {
        px_pin(mt_mkscroll(i))
        i = i + 1u64
    }
    return xc_len() - a
}

/* THE ENVELOPE JUDGE: 0 = within steps <= c*n (MAINTAIN) ; 1 = VIOLATION (refused). */
fn mt_envelope(steps: u64, c: u64, n: u64) -> u64 @export {
    if steps <= c * n { return 0u64 }
    return 1u64
}

/* REDUNDANCY, MEASURED: build oracle A (alternating verdicts) and oracle B either identical
 * (same=1) or differing at one probe (same=0), over 8 probes. B is redundant iff its table is
 * a FLAT shadow of A's -- element-wise equal -- and A's own image is confirmed through the LIVE
 * ONTOS meter (2 distinct verdicts), so the comparison rides a measured table, not an assertion. */
fn mt_shadow_demo(same: u64) -> u64 @export {
    let mut i : u64 = 0u64
    while i < 8u64 {
        MT_TA[i] = i % 2u64
        MT_TB[i] = i % 2u64
        i = i + 1u64
    }
    if same == 0u64 { MT_TB[3u64] = 1u64 - MT_TB[3u64] }
    let mut j : u64 = 0u64
    while j < 8u64 { ont_tbl_set(j, MT_TA[j])   j = j + 1u64 }
    if ont_image_ext(8u64) != 2u64 { return 9u64 }          /* the meter must see A's two verdicts */
    let mut k : u64 = 0u64
    while k < 8u64 {
        if MT_TA[k] != MT_TB[k] { return 0u64 }             /* differs: NOT a shadow */
        k = k + 1u64
    }
    return 1u64                                             /* element-wise equal: [dup < origin] */
}

fn metron_selfprove() -> u64 @export {
    /* ARM 1: THE METER IS EXACT -- one real pin of an n-byte scroll costs exactly n+1 events
     * through the live fold, at three sizes. Not approximately: exactly. */
    if mt_pin_cost(8u64) != 9u64 { return 1u64 }
    if mt_pin_cost(16u64) != 17u64 { return 1u64 }
    if mt_pin_cost(32u64) != 33u64 { return 1u64 }

    /* ARM 2: THE LINEAR PROCESS HOLDS ITS ENVELOPE -- steps <= 2n at every measured n. */
    if mt_envelope(mt_pin_cost(8u64), 2u64, 8u64) != 0u64 { return 2u64 }
    if mt_envelope(mt_pin_cost(16u64), 2u64, 16u64) != 0u64 { return 2u64 }
    if mt_envelope(mt_pin_cost(32u64), 2u64, 32u64) != 0u64 { return 2u64 }

    /* ARM 3: THE QUADRATIC PROCESS VIOLATES THE SAME ENVELOPE -- the refusal is real, on a real
     * process. sum(i+1) for i in 8..32 = 525; 525 > 2*32. The declared envelope catches the
     * rescan shape that "looks linear" one call at a time. */
    let q : u64 = mt_quad_cost(32u64)
    if q != 525u64 { return 3u64 }
    if mt_envelope(q, 2u64, 32u64) != 1u64 { return 3u64 }

    /* ARM 4: THE BOUNDARY IS EXACT -- steps == c*n is WITHIN (the envelope is a promise kept at
     * its edge); one past is a violation. No off-by-one mercy in either direction. */
    if mt_envelope(64u64, 2u64, 32u64) != 0u64 { return 4u64 }
    if mt_envelope(65u64, 2u64, 32u64) != 1u64 { return 4u64 }

    /* ARM 5: REDUNDANCY IS A SHADOW, MEASURED -- identical verdict tables are [dup < origin];
     * one differing probe breaks the shadow. Both polarities, through the live ONTOS meter. */
    if mt_shadow_demo(1u64) != 1u64 { return 5u64 }
    if mt_shadow_demo(0u64) != 0u64 { return 5u64 }

    return 0u64
}

fn mt_ps(s: u64) -> u32 { let p : *u8 = s as *u8   let mut i : u64 = 0u64   while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }   return 1u32 }
fn mt_pu(v: u64) -> u32 { if v >= 10u64 { mt_pu(v / 10u64) }   putchar((48u64 + (v % 10u64)) as i32)   return 1u32 }

fn main(argc: i32, argv: u64) -> u64 {
    let _a : i32 = argc   let _v : u64 = argv
    let r : u64 = metron_selfprove()
    mt_ps("metron_selfprove = " as u64)   mt_pu(r)   putchar(10i32)
    if r == 0u64 { mt_ps("GREEN: the meter is exact (n+1, measured live); the linear holds its envelope; the quadratic VIOLATES it (525 > 64); the boundary is exact; redundancy is a measured shadow.\n" as u64) }
    return r
}
