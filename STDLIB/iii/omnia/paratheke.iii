/* STDLIB/iii/omnia/paratheke.iii -- THE STANDING DEPOSIT: reasoning that survives
 * the session, held only under re-derivation.
 *
 * THE GAP THIS CLOSES: every organ re-derives itself and forgets.  PRAXIS traces
 * are session-keyed; KERYGMA reseals and drops; the exact-order verdict on the
 * real R1 head was earned, sealed, embodied -- and evaporated when the process
 * exited.  Nothing a session establishes survives to the next as STANDING,
 * re-derivable knowledge.  PARATHEKE is that binding: a durable, append-only,
 * content-chained ledger whose entries are EIDOLOS scrolls.
 *
 * THE LAW (kardia's, made cross-session): a deposit is never a truth; it is a
 * DEBT OF RE-DERIVATION.  An entry stores
 *   - the QUESTION      (krisis terms, or an order pair),
 *   - the CLAIMED verdict (kept ONLY as a contradiction tripwire, never read as
 *     truth),
 *   - the ENGINE PIN     (a content-address of the deciding source),
 *   - the CHAIN          (the previous entry's scroll address).
 * Reading the ledger = re-earning every entry through the LIVE kernel:
 *   agreement, pin current      -> STANDS
 *   agreement, pin drifted      -> DUE   (heal by APPENDING a superseding entry
 *                                  with the fresh pin -- of_eN -- never rewriting)
 *   disagreement                -> REFUSED (contradiction: the ledger was bent,
 *                                  or the body no longer derives its past; both stop)
 *   any byte bent anywhere      -> REFUSED at the exact link (the chain names it)
 * CONTRADICTION DOMINATES DUE: the verdict is re-derived FIRST and pins are
 * consulted ONLY after agreement, so a body regression can never hide behind
 * "the engine changed, just re-earn".  Supersession waives ONLY the pin check --
 * a superseded entry still re-earns its body forever.
 *
 * THE ORACLE RATCHET (the first instance rides in the genesis ledger): the R1
 * oracle PROPOSED an ordering; the membrane re-derived it exactly (two engines,
 * kr_sign over 7165 live dims, sign +1, zero width); mantis sealed it as the
 * `<`-claim [k...0785 < k...60d8].  The deposit holds the pair (24792, 1925) and
 * re-earns the SEAL through the same sealer (man_seal_order) on every read; the
 * measurement obligation is discharged transitively by ethos_r1_gate (the
 * connected proof web).  III consumed the oracle and keeps only what it
 * re-derives itself.
 *
 * ENTRIES ARE SCROLLS (one line, one EIDOLOS house, canonical byte-form; the
 * entry's content-address IS its scroll address):
 *   [e<q> < paratheke] [prev_k<16hex> < e<q>] [kind_krisis < e<q>]
 *     { [of_e<q0> < e<q>] } [verdict_<p|n|z> < e<q>]
 *     [t<i>_<s>_m<16hex>_e<p|n><16hex>_b<16hex> < e<q>] ... [pin_k<16hex> < e<q>]
 *   [e<q> < paratheke] [prev_k<16hex> < e<q>] [kind_order < e<q>]
 *     { [of_e<q0> < e<q>] } [winner_k<16hex> < e<q>] [loser_k<16hex> < e<q>]
 *     [order_k<16hex> < e<q>] [pin_k<16hex> < e<q>]
 * ONE builder writes this form; mint refuses to write anything it did not just
 * re-derive (deposit-by-rederivation); parse enforces the exact claim order, so
 * mint(parse(x)) == x is a proven law, not a hope.
 *
 * FOUNDATION STONE: the chain stands on EIDOLOS address canonicalization.  If
 * the logos itself evolves, every link reddens at once -- that is CORRECT (the
 * substrate drifted); the ledger is then REBORN by mint-genesis, deliberately
 * and visibly, a new covenant.  Pins are 64-bit sha256 heads: drift detection,
 * not adversarial security (named, not hidden).
 *
 * Ring R0.  Pure (no filesystem): the cli carries the file I/O.  Composes
 * eidolos (the barometer) + krisis (the decision kernel) + mantis (the order
 * sealer).  NIH: no new hash, no new logic, no island.  Hexad: kind_essence
 * (the standing memory) + kind_witness (every entry re-earned). */
module omnia_paratheke

/* ---- the one barometer (EIDOLOS) ---- */
extern @abi(c-msvc-x64) fn eol_reset() -> i32 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_read(addr: u64, len: u64) -> i64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_addr() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_lawcheck() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_entails(a_addr: u64, a_len: u64, verb: u64, b_addr: u64, b_len: u64) -> u64 from "eidolos.iii"

/* ---- the decision kernel (the one exact-sign law) ---- */
extern @abi(c-msvc-x64) fn kr_begin() -> i32 from "krisis.iii"
extern @abi(c-msvc-x64) fn kr_term(s: i64, m: u64, e: i64, b: i64) -> i32 from "krisis.iii"
extern @abi(c-msvc-x64) fn kr_sign() -> i64 from "krisis.iii"

/* ---- the order sealer (the SAME organ that sealed the R1 head order) ---- */
extern @abi(c-msvc-x64) fn man_seal_order(winner: u64, loser: u64) -> u64 from "mantis.iii"

const PK_LCAP : u64 = 1024u64             /* canonical line bytes (loud refusal past it) */
const PK_TCAP : u64 = 8u64                /* terms per krisis entry (loud refusal past it) */
const PK_KRISIS : u64 = 1u64
const PK_ORDER  : u64 = 2u64
const PK_ENTAIL : u64 = 3u64              /* Path D: a theorem the logos re-derives every read */
const PK_FRCAP  : u64 = 4u64              /* provenance edges per entry (loud refusal past it) */
const PK_WCAP   : u64 = 24u64             /* entail word bytes (loud refusal past it) */
const PK_NOTF   : u64 = 0x8000000000000000u64    /* scan sentinel: not found */

/* ---- the mint staging (what the builder writes FROM) ---- */
var PKM_SEQ  : u64 = 0u64
var PKM_PREV : u64 = 0u64
var PKM_KIND : u64 = 0u64
var PKM_OF   : u64 = 0u64
var PKM_VERD : i64 = 0i64
var PKM_TS : [i64; 8]
var PKM_TM : [u64; 8]
var PKM_TE : [i64; 8]
var PKM_TB : [u64; 8]
var PKM_TN : u64 = 0u64
var PKM_WIN : u64 = 0u64
var PKM_LOS : u64 = 0u64
var PKM_ORD : u64 = 0u64
var PKM_PIN : u64 = 0u64
var PKM_FR : [u64; 4]                     /* provenance: the standing entries this one grew from */
var PKM_FN : u64 = 0u64
var PKM_WS : [u8; 144]                    /* entail words: 6 slots x 24 (p1a p1b p2a p2b ca cb) */
var PKM_WL : [u64; 6]

/* ---- the canonical output line ---- */
var PK_OUT : [u8; 1024]
var PK_ON  : u64 = 0u64
var PK_OFLOW : u64 = 0u64
var PK_MADDR : u64 = 0u64                 /* the last minted line's scroll address */

/* ---- the parse result ---- */
var PK_SEQ  : u64 = 0u64
var PK_PREV : u64 = 0u64
var PK_KIND : u64 = 0u64
var PK_OF   : u64 = 0u64
var PK_VERD : i64 = 0i64
var PK_TS : [i64; 8]
var PK_TM : [u64; 8]
var PK_TE : [i64; 8]
var PK_TB : [u64; 8]
var PK_TN : u64 = 0u64
var PK_WIN : u64 = 0u64
var PK_LOS : u64 = 0u64
var PK_ORD : u64 = 0u64
var PK_PIN : u64 = 0u64
var PK_FR : [u64; 4]
var PK_FN : u64 = 0u64
var PK_WS : [u8; 144]
var PK_WL : [u64; 6]

/* ---- the parse cursor (module-held so helpers stay slot-light) ---- */
var PKP_B : u64 = 0u64
var PKP_L : u64 = 0u64
var PKP_P : u64 = 0u64
var PK_PV : u64 = 0u64                    /* the last parsed hex value */

/* ---- the stand sweep ---- */
var PK_STD_PREV : u64 = 0u64
var PK_STD_HEAD : u64 = 0u64

var PK_HEX : [u8; 16]

fn pk_hex_init() -> i32 {
    PK_HEX[0u64]=48u8  PK_HEX[1u64]=49u8  PK_HEX[2u64]=50u8  PK_HEX[3u64]=51u8
    PK_HEX[4u64]=52u8  PK_HEX[5u64]=53u8  PK_HEX[6u64]=54u8  PK_HEX[7u64]=55u8
    PK_HEX[8u64]=56u8  PK_HEX[9u64]=57u8  PK_HEX[10u64]=97u8 PK_HEX[11u64]=98u8
    PK_HEX[12u64]=99u8 PK_HEX[13u64]=100u8 PK_HEX[14u64]=101u8 PK_HEX[15u64]=102u8
    return 0i32
}

/* ==================== the one builder ==================== */

fn pk_put(c: u8) -> i32 {
    if PK_ON < PK_LCAP { PK_OUT[PK_ON] = c   PK_ON = PK_ON + 1u64   return 0i32 }
    PK_OFLOW = 1u64
    return 0i32
}

fn pk_putz(s: u64) -> i32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { pk_put(p[i])   i = i + 1u64 }
    return 0i32
}

/* 16 lowercase hex of a u64 (the canonical fixed-width value form) */
fn pk_hex16(v: u64) -> i32 {
    let mut sh : u64 = 60u64
    let mut go : u64 = 1u64
    while go == 1u64 {
        pk_put(PK_HEX[(v >> sh) & 15u64])
        if sh == 0u64 { go = 0u64 }
        if sh != 0u64 { sh = sh - 4u64 }
    }
    return 0i32
}

/* minimal lowercase hex (the canonical seq form; v=0 emits "0") */
fn pk_hexmin(v: u64) -> i32 {
    if v == 0u64 { pk_put(48u8)   return 0i32 }
    let mut sh : u64 = 60u64
    let mut on : u64 = 0u64
    let mut go : u64 = 1u64
    while go == 1u64 {
        let nyb : u64 = (v >> sh) & 15u64
        if nyb != 0u64 { on = 1u64 }
        if on == 1u64 { pk_put(PK_HEX[nyb]) }
        if sh == 0u64 { go = 0u64 }
        if sh != 0u64 { sh = sh - 4u64 }
    }
    return 0i32
}

/* emit len raw bytes from base (an entail word travels verbatim) */
fn pk_putw(base: u64, len: u64) -> i32 {
    let p : *u8 = base as *u8
    let mut i : u64 = 0u64
    while i < len { pk_put(p[i])   i = i + 1u64 }
    return 0i32
}

fn pkm_wbase(i: u64) -> u64 { return ((&PKM_WS) as u64) + i * 24u64 }
fn pk_wbase(i: u64) -> u64 { return ((&PK_WS) as u64) + i * 24u64 }

/* close the current claim: " < e<seq>]" */
fn pk_eclose() -> i32 {
    pk_putz(" < e" as u64)
    pk_hexmin(PKM_SEQ)
    pk_put(93u8)
    return 0i32
}

fn pk_emit_term(i: u64) -> i32 {
    pk_putz(" [t" as u64)
    pk_put(PK_HEX[i & 15u64])
    pk_put(95u8)
    let s : i64 = PKM_TS[i]
    if s > 0i64 { pk_put(112u8) }
    if s < 0i64 { pk_put(110u8) }
    if s == 0i64 { pk_put(122u8) }
    pk_putz("_m" as u64)
    pk_hex16(PKM_TM[i])
    pk_putz("_e" as u64)
    let e : i64 = PKM_TE[i]
    if e < 0i64 { pk_put(110u8)   pk_hex16((0i64 - e) as u64) }
    if e >= 0i64 { pk_put(112u8)   pk_hex16(e as u64) }
    pk_putz("_b" as u64)
    pk_hex16(PKM_TB[i])
    pk_eclose()
    return 0i32
}

/* build the canonical line from the mint staging; 0 = built, 1 = overflow/invalid */
fn pk_build() -> u64 {
    pk_hex_init()
    PK_ON = 0u64
    PK_OFLOW = 0u64
    pk_putz("[e" as u64)
    pk_hexmin(PKM_SEQ)
    pk_putz(" < paratheke]" as u64)
    pk_putz(" [prev_k" as u64)
    pk_hex16(PKM_PREV)
    pk_eclose()
    if PKM_KIND == PK_KRISIS { pk_putz(" [kind_krisis" as u64)   pk_eclose() }
    if PKM_KIND == PK_ORDER  { pk_putz(" [kind_order" as u64)    pk_eclose() }
    if PKM_KIND == PK_ENTAIL { pk_putz(" [kind_entail" as u64)   pk_eclose() }
    if PKM_OF != 0u64 {
        pk_putz(" [of_e" as u64)
        pk_hexmin(PKM_OF)
        pk_eclose()
    }
    let mut fr : u64 = 0u64
    while fr < PKM_FN {
        pk_putz(" [from_e" as u64)
        pk_hexmin(PKM_FR[fr])
        pk_eclose()
        fr = fr + 1u64
    }
    if PKM_KIND == PK_KRISIS {
        pk_putz(" [verdict_" as u64)
        let v : i64 = PKM_VERD
        if v > 0i64 { pk_put(112u8) }
        if v < 0i64 { pk_put(110u8) }
        if v == 0i64 { pk_put(122u8) }
        pk_eclose()
        let mut i : u64 = 0u64
        while i < PKM_TN { pk_emit_term(i)   i = i + 1u64 }
    }
    if PKM_KIND == PK_ORDER {
        pk_putz(" [winner_k" as u64)   pk_hex16(PKM_WIN)   pk_eclose()
        pk_putz(" [loser_k" as u64)    pk_hex16(PKM_LOS)   pk_eclose()
        pk_putz(" [order_k" as u64)    pk_hex16(PKM_ORD)   pk_eclose()
    }
    if PKM_KIND == PK_ENTAIL {
        pk_putz(" [pa_" as u64)   pk_putw(pkm_wbase(0u64), PKM_WL[0u64])   pk_eclose()
        pk_putz(" [pb_" as u64)   pk_putw(pkm_wbase(1u64), PKM_WL[1u64])   pk_eclose()
        pk_putz(" [pc_" as u64)   pk_putw(pkm_wbase(2u64), PKM_WL[2u64])   pk_eclose()
        pk_putz(" [pd_" as u64)   pk_putw(pkm_wbase(3u64), PKM_WL[3u64])   pk_eclose()
        pk_putz(" [ce_" as u64)   pk_putw(pkm_wbase(4u64), PKM_WL[4u64])   pk_eclose()
        pk_putz(" [cf_" as u64)   pk_putw(pkm_wbase(5u64), PKM_WL[5u64])   pk_eclose()
    }
    pk_putz(" [pin_k" as u64)
    pk_hex16(PKM_PIN)
    pk_eclose()
    if PK_OFLOW != 0u64 { return 1u64 }
    return 0u64
}

/* ==================== the scroll address ==================== */

/* the line's EIDOLOS address; 0 = unlawful.  Every use resets the house both
 * ways (one bad scroll must never poison a later judgment). */
fn pk_line_addr(base: u64, len: u64) -> u64 {
    eol_reset()
    if eol_read(base, len) < 0i64 { eol_reset()   return 0u64 }
    if eol_lawcheck() != 0u64 { eol_reset()   return 0u64 }
    let a : u64 = eol_addr()
    eol_reset()
    return a
}

/* ==================== the re-derivation (the verdict is EARNED, never read) ==================== */

fn pk_rederive_krisis() -> i64 {
    kr_begin()
    let mut i : u64 = 0u64
    while i < PKM_TN {
        kr_term(PKM_TS[i], PKM_TM[i], PKM_TE[i], PKM_TB[i] as i64)
        i = i + 1u64
    }
    return kr_sign()
}

/* Path D re-derivation -- the LOGOS judges the theorem: do the carried premises
 * [w0 < w1] [w2 < w3] entail the carried conclusion [w4 < w5]?  1 = entailed.
 * NOT a tautology: disconnected premises are expressible and are REFUSED. */
var PK_EB : [u8; 128]
var PK_EBN : u64 = 0u64
fn pk_ebput(c: u8) -> i32 { if PK_EBN < 128u64 { PK_EB[PK_EBN] = c   PK_EBN = PK_EBN + 1u64 }   return 0i32 }
fn pk_ebw(base: u64, len: u64) -> i32 {
    let p : *u8 = base as *u8
    let mut i : u64 = 0u64
    while i < len { pk_ebput(p[i])   i = i + 1u64 }
    return 0i32
}
fn pk_ebz(s: u64) -> i32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { pk_ebput(p[i])   i = i + 1u64 }
    return 0i32
}
fn pk_rederive_entail() -> u64 {
    let mut w : u64 = 0u64
    while w < 6u64 {
        if PKM_WL[w] == 0u64 { return 0u64 }
        w = w + 1u64
    }
    PK_EBN = 0u64
    pk_ebput(91u8)
    pk_ebw(pkm_wbase(0u64), PKM_WL[0u64])   pk_ebz(" < " as u64)   pk_ebw(pkm_wbase(1u64), PKM_WL[1u64])
    pk_ebz("] [" as u64)
    pk_ebw(pkm_wbase(2u64), PKM_WL[2u64])   pk_ebz(" < " as u64)   pk_ebw(pkm_wbase(3u64), PKM_WL[3u64])
    pk_ebput(93u8)
    eol_reset()
    if eol_read((&PK_EB) as u64, PK_EBN) < 0i64 { eol_reset()   return 0u64 }
    if eol_lawcheck() != 0u64 { eol_reset()   return 0u64 }
    let r : u64 = eol_entails(pkm_wbase(4u64), PKM_WL[4u64], 0u64, pkm_wbase(5u64), PKM_WL[5u64])
    eol_reset()
    return r
}

/* ==================== the mint (deposit-by-rederivation) ==================== */

fn pk_mint_begin(seq: u64, prev: u64, kind: u64, of_seq: u64) -> i32 @export {
    PKM_SEQ = seq
    PKM_PREV = prev
    PKM_KIND = kind
    PKM_OF = of_seq
    PKM_TN = 0u64
    PKM_WIN = 0u64
    PKM_LOS = 0u64
    PKM_ORD = 0u64
    PKM_VERD = 0i64
    PKM_FN = 0u64
    let mut w : u64 = 0u64
    while w < 6u64 { PKM_WL[w] = 0u64   w = w + 1u64 }
    return 0i32
}

/* stage one provenance edge (the standing entry this deposit grew from) */
fn pk_mint_from_add(seq: u64) -> u64 @export {
    if PKM_FN >= PK_FRCAP { return 1u64 }
    if seq == 0u64 { return 1u64 }
    PKM_FR[PKM_FN] = seq
    PKM_FN = PKM_FN + 1u64
    return 0u64
}

/* stage one entail word (0..3 = premise words, 4..5 = conclusion) from a
 * NUL-terminated string; loud refusal on empty or over PK_WCAP */
fn pk_mint_word(which: u64, s: u64) -> u64 @export {
    if which >= 6u64 { return 1u64 }
    let p : *u8 = s as *u8
    let d : *u8 = pkm_wbase(which) as *u8
    let mut n : u64 = 0u64
    while p[n] != 0u8 {
        if n >= PK_WCAP { return 1u64 }
        d[n] = p[n]
        n = n + 1u64
    }
    if n == 0u64 { return 1u64 }
    PKM_WL[which] = n
    return 0u64
}

fn pk_mint_term(s: i64, m: u64, e: i64, b: u64) -> i32 @export {
    if PKM_TN >= PK_TCAP { return 1i32 }
    PKM_TS[PKM_TN] = s
    PKM_TM[PKM_TN] = m
    PKM_TE[PKM_TN] = e
    PKM_TB[PKM_TN] = b
    PKM_TN = PKM_TN + 1u64
    return 0i32
}

fn pk_mint_pair(win: u64, los: u64) -> i32 @export {
    PKM_WIN = win
    PKM_LOS = los
    return 0i32
}

/* seal the deposit: re-derive the body LIVE, build the canonical line, address it.
 * 0 = minted (PK_OUT/PK_ON/PK_MADDR set) | 1 = empty krisis body | 2 = the kernel
 * refused by name | 3 = the order would not seal | 4 = no such kind | 5 = the
 * line overflowed | 6 = the line is not lawful in the logos. */
fn pk_mint_close(pin: u64) -> u64 @export {
    if PKM_KIND == PK_KRISIS {
        if PKM_TN == 0u64 { return 1u64 }
        let sg : i64 = pk_rederive_krisis()
        if sg == (0i64 - 2i64) { return 2u64 }
        PKM_VERD = sg
    }
    if PKM_KIND == PK_ORDER {
        let oa : u64 = man_seal_order(PKM_WIN, PKM_LOS)
        if oa == 0u64 { return 3u64 }
        PKM_ORD = oa
    }
    if PKM_KIND == PK_ENTAIL {
        if pk_rederive_entail() != 1u64 { return 7u64 }      /* a theorem the logos does not derive is never deposited */
    }
    if PKM_KIND != PK_KRISIS { if PKM_KIND != PK_ORDER { if PKM_KIND != PK_ENTAIL { return 4u64 } } }
    PKM_PIN = pin
    if pk_build() != 0u64 { return 5u64 }
    let a : u64 = pk_line_addr((&PK_OUT) as u64, PK_ON)
    if a == 0u64 { return 6u64 }
    PK_MADDR = a
    return 0u64
}

fn pk_mint_addr() -> u64 @export { return PK_MADDR }
fn pk_mint_verdict() -> i64 @export { return PKM_VERD }   /* the DERIVED verdict (the oracle door compares) */
fn pk_out_len() -> u64 @export { return PK_ON }
fn pk_out_byte(i: u64) -> u8 @export { if i < PK_ON { return PK_OUT[i] }   return 0u8 }

/* ==================== the parser (the exact canonical grammar, nothing looser) ==================== */

fn pk_hexval(c: u8) -> i64 {
    if c >= 48u8 { if c <= 57u8 { return (c - 48u8) as i64 } }
    if c >= 97u8 { if c <= 102u8 { return ((c - 97u8) as i64) + 10i64 } }
    return 0i64 - 1i64
}

/* match a NUL-terminated literal at the cursor; 1 = matched (cursor advanced) */
fn pkp_lit(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let b : *u8 = PKP_B as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 {
        if PKP_P + i >= PKP_L { return 0u64 }
        if b[PKP_P + i] != p[i] { return 0u64 }
        i = i + 1u64
    }
    PKP_P = PKP_P + i
    return 1u64
}

/* exactly 16 lowercase hex at the cursor -> PK_PV; 1 = ok */
fn pkp_hex16() -> u64 {
    let b : *u8 = PKP_B as *u8
    let mut v : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 16u64 {
        if PKP_P + i >= PKP_L { return 0u64 }
        let hv : i64 = pk_hexval(b[PKP_P + i])
        if hv < 0i64 { return 0u64 }
        v = (v << 4u64) | (hv as u64)
        i = i + 1u64
    }
    PKP_P = PKP_P + 16u64
    PK_PV = v
    return 1u64
}

/* 1..16 hex chars at the cursor (stops at the first non-hex) -> PK_PV; 1 = ok */
fn pkp_hexseq() -> u64 {
    let b : *u8 = PKP_B as *u8
    let mut v : u64 = 0u64
    let mut n : u64 = 0u64
    let mut go : u64 = 1u64
    while go == 1u64 {
        if PKP_P >= PKP_L { go = 0u64 }
        if go == 1u64 {
            let hv : i64 = pk_hexval(b[PKP_P])
            if hv < 0i64 { go = 0u64 }
            if hv >= 0i64 {
                if n >= 16u64 { return 0u64 }
                v = (v << 4u64) | (hv as u64)
                n = n + 1u64
                PKP_P = PKP_P + 1u64
            }
        }
    }
    if n == 0u64 { return 0u64 }
    PK_PV = v
    return 1u64
}

/* the claim close: " < e<seq>]" where seq must equal PK_SEQ */
fn pkp_close() -> u64 {
    if pkp_lit(" < e" as u64) == 0u64 { return 0u64 }
    if pkp_hexseq() == 0u64 { return 0u64 }
    if PK_PV != PK_SEQ { return 0u64 }
    if pkp_lit("]" as u64) == 0u64 { return 0u64 }
    return 1u64
}

/* one term claim, after " [t" is consumed; 1 = ok (stored at PK_TN) */
fn pkp_term() -> u64 {
    let b : *u8 = PKP_B as *u8
    if PK_TN >= PK_TCAP { return 0u64 }
    if PKP_P >= PKP_L { return 0u64 }
    let iv : i64 = pk_hexval(b[PKP_P])
    if iv < 0i64 { return 0u64 }
    if (iv as u64) != PK_TN { return 0u64 }        /* canonical index order */
    PKP_P = PKP_P + 1u64
    if pkp_lit("_" as u64) == 0u64 { return 0u64 }
    if PKP_P >= PKP_L { return 0u64 }
    let sc : u8 = b[PKP_P]
    let mut s : i64 = 99i64
    if sc == 112u8 { s = 1i64 }
    if sc == 110u8 { s = 0i64 - 1i64 }
    if sc == 122u8 { s = 0i64 }
    if s == 99i64 { return 0u64 }
    PKP_P = PKP_P + 1u64
    if pkp_lit("_m" as u64) == 0u64 { return 0u64 }
    if pkp_hex16() == 0u64 { return 0u64 }
    let m : u64 = PK_PV
    if pkp_lit("_e" as u64) == 0u64 { return 0u64 }
    if PKP_P >= PKP_L { return 0u64 }
    let ec : u8 = b[PKP_P]
    if ec != 112u8 { if ec != 110u8 { return 0u64 } }
    PKP_P = PKP_P + 1u64
    if pkp_hex16() == 0u64 { return 0u64 }
    let mut e : i64 = PK_PV as i64
    if ec == 110u8 { e = 0i64 - e }
    if pkp_lit("_b" as u64) == 0u64 { return 0u64 }
    if pkp_hex16() == 0u64 { return 0u64 }
    let bb : u64 = PK_PV
    if pkp_close() == 0u64 { return 0u64 }
    PK_TS[PK_TN] = s
    PK_TM[PK_TN] = m
    PK_TE[PK_TN] = e
    PK_TB[PK_TN] = bb
    PK_TN = PK_TN + 1u64
    return 1u64
}

fn pk_is_wch(c: u8) -> u64 {
    if c >= 97u8 { if c <= 122u8 { return 1u64 } }
    if c >= 48u8 { if c <= 57u8 { return 1u64 } }
    if c == 95u8 { return 1u64 }
    if c == 45u8 { return 1u64 }
    return 0u64
}

/* one entail word (legal EIDOLOS word bytes, 1..24) into parse slot `which` */
fn pkp_word(which: u64) -> u64 {
    let b : *u8 = PKP_B as *u8
    let d : *u8 = pk_wbase(which) as *u8
    let mut n : u64 = 0u64
    let mut go : u64 = 1u64
    while go == 1u64 {
        if PKP_P >= PKP_L { go = 0u64 }
        if go == 1u64 {
            let c : u8 = b[PKP_P]
            if pk_is_wch(c) == 0u64 { go = 0u64 }
            if go == 1u64 {
                if n >= PK_WCAP { return 0u64 }
                d[n] = c
                n = n + 1u64
                PKP_P = PKP_P + 1u64
            }
        }
    }
    if n == 0u64 { return 0u64 }
    PK_WL[which] = n
    return 1u64
}

/* parse one canonical entry line.  0 = parsed | 5 = malformed (the exact
 * grammar or nothing; a bent line never half-parses). */
fn pk_parse_line(base: u64, len: u64) -> u64 @export {
    let b : *u8 = base as *u8
    let mut l : u64 = len
    if l > 0u64 { let lc : u8 = b[l - 1u64]   if lc == 13u8 { l = l - 1u64 } }
    PKP_B = base
    PKP_L = l
    PKP_P = 0u64
    PK_TN = 0u64
    PK_OF = 0u64
    PK_WIN = 0u64
    PK_LOS = 0u64
    PK_ORD = 0u64
    PK_VERD = 0i64
    PK_FN = 0u64
    let mut wz : u64 = 0u64
    while wz < 6u64 { PK_WL[wz] = 0u64   wz = wz + 1u64 }
    if pkp_lit("[e" as u64) == 0u64 { return 5u64 }
    if pkp_hexseq() == 0u64 { return 5u64 }
    PK_SEQ = PK_PV
    if PK_SEQ == 0u64 { return 5u64 }
    if pkp_lit(" < paratheke]" as u64) == 0u64 { return 5u64 }
    if pkp_lit(" [prev_k" as u64) == 0u64 { return 5u64 }
    if pkp_hex16() == 0u64 { return 5u64 }
    PK_PREV = PK_PV
    if pkp_close() == 0u64 { return 5u64 }
    if pkp_lit(" [kind_" as u64) == 0u64 { return 5u64 }
    PK_KIND = 0u64
    if pkp_lit("krisis" as u64) == 1u64 { PK_KIND = PK_KRISIS }
    if PK_KIND == 0u64 { if pkp_lit("order" as u64) == 1u64 { PK_KIND = PK_ORDER } }
    if PK_KIND == 0u64 { if pkp_lit("entail" as u64) == 1u64 { PK_KIND = PK_ENTAIL } }
    if PK_KIND == 0u64 { return 5u64 }
    if pkp_close() == 0u64 { return 5u64 }
    if pkp_lit(" [of_e" as u64) == 1u64 {
        if pkp_hexseq() == 0u64 { return 5u64 }
        PK_OF = PK_PV
        if PK_OF == 0u64 { return 5u64 }
        if pkp_close() == 0u64 { return 5u64 }
    }
    let mut morefr : u64 = 1u64
    while morefr == 1u64 {
        if pkp_lit(" [from_e" as u64) == 1u64 {
            if PK_FN >= PK_FRCAP { return 5u64 }
            if pkp_hexseq() == 0u64 { return 5u64 }
            if PK_PV == 0u64 { return 5u64 }
            PK_FR[PK_FN] = PK_PV
            PK_FN = PK_FN + 1u64
            if pkp_close() == 0u64 { return 5u64 }
        }
        if pkp_lit(" [from_e" as u64) == 0u64 { morefr = 0u64 }
        if morefr == 1u64 { PKP_P = PKP_P - 8u64 }   /* un-consume the probe */
    }
    if PK_KIND == PK_KRISIS {
        if pkp_lit(" [verdict_" as u64) == 0u64 { return 5u64 }
        let b2 : *u8 = PKP_B as *u8
        if PKP_P >= PKP_L { return 5u64 }
        let vc : u8 = b2[PKP_P]
        let mut vs : i64 = 99i64
        if vc == 112u8 { vs = 1i64 }
        if vc == 110u8 { vs = 0i64 - 1i64 }
        if vc == 122u8 { vs = 0i64 }
        if vs == 99i64 { return 5u64 }
        PK_VERD = vs
        PKP_P = PKP_P + 1u64
        if pkp_close() == 0u64 { return 5u64 }
        let mut more : u64 = 1u64
        while more == 1u64 {
            if pkp_lit(" [t" as u64) == 1u64 {
                if pkp_term() == 0u64 { return 5u64 }
            }
            if pkp_lit(" [t" as u64) == 0u64 { more = 0u64 }
            if more == 1u64 { PKP_P = PKP_P - 3u64 }   /* un-consume the probe */
        }
        if PK_TN == 0u64 { return 5u64 }
    }
    if PK_KIND == PK_ORDER {
        if pkp_lit(" [winner_k" as u64) == 0u64 { return 5u64 }
        if pkp_hex16() == 0u64 { return 5u64 }
        PK_WIN = PK_PV
        if pkp_close() == 0u64 { return 5u64 }
        if pkp_lit(" [loser_k" as u64) == 0u64 { return 5u64 }
        if pkp_hex16() == 0u64 { return 5u64 }
        PK_LOS = PK_PV
        if pkp_close() == 0u64 { return 5u64 }
        if pkp_lit(" [order_k" as u64) == 0u64 { return 5u64 }
        if pkp_hex16() == 0u64 { return 5u64 }
        PK_ORD = PK_PV
        if pkp_close() == 0u64 { return 5u64 }
    }
    if PK_KIND == PK_ENTAIL {
        if pkp_lit(" [pa_" as u64) == 0u64 { return 5u64 }
        if pkp_word(0u64) == 0u64 { return 5u64 }
        if pkp_close() == 0u64 { return 5u64 }
        if pkp_lit(" [pb_" as u64) == 0u64 { return 5u64 }
        if pkp_word(1u64) == 0u64 { return 5u64 }
        if pkp_close() == 0u64 { return 5u64 }
        if pkp_lit(" [pc_" as u64) == 0u64 { return 5u64 }
        if pkp_word(2u64) == 0u64 { return 5u64 }
        if pkp_close() == 0u64 { return 5u64 }
        if pkp_lit(" [pd_" as u64) == 0u64 { return 5u64 }
        if pkp_word(3u64) == 0u64 { return 5u64 }
        if pkp_close() == 0u64 { return 5u64 }
        if pkp_lit(" [ce_" as u64) == 0u64 { return 5u64 }
        if pkp_word(4u64) == 0u64 { return 5u64 }
        if pkp_close() == 0u64 { return 5u64 }
        if pkp_lit(" [cf_" as u64) == 0u64 { return 5u64 }
        if pkp_word(5u64) == 0u64 { return 5u64 }
        if pkp_close() == 0u64 { return 5u64 }
    }
    if pkp_lit(" [pin_k" as u64) == 0u64 { return 5u64 }
    if pkp_hex16() == 0u64 { return 5u64 }
    PK_PIN = PK_PV
    if pkp_close() == 0u64 { return 5u64 }
    if PKP_P != PKP_L { return 5u64 }
    return 0u64
}

fn pk_parsed_seq() -> u64 @export { return PK_SEQ }
fn pk_parsed_of() -> u64 @export { return PK_OF }
fn pk_parsed_kind() -> u64 @export { return PK_KIND }
fn pk_parsed_from_count() -> u64 @export { return PK_FN }
fn pk_parsed_from(i: u64) -> u64 @export { if i < PK_FN { return PK_FR[i] }   return 0u64 }

/* copy the parse result into the mint staging (the body travels; the verdict
 * and the order address are RE-DERIVED, never copied). */
fn pk_stage_from_parse() -> i32 {
    PKM_KIND = PK_KIND
    PKM_TN = PK_TN
    let mut i : u64 = 0u64
    while i < PK_TN {
        PKM_TS[i] = PK_TS[i]
        PKM_TM[i] = PK_TM[i]
        PKM_TE[i] = PK_TE[i]
        PKM_TB[i] = PK_TB[i]
        i = i + 1u64
    }
    PKM_WIN = PK_WIN
    PKM_LOS = PK_LOS
    PKM_FN = PK_FN
    let mut f : u64 = 0u64
    while f < PK_FN { PKM_FR[f] = PK_FR[f]   f = f + 1u64 }
    let mut w : u64 = 0u64
    while w < 6u64 {
        PKM_WL[w] = PK_WL[w]
        let s : *u8 = pk_wbase(w) as *u8
        let d : *u8 = pkm_wbase(w) as *u8
        let mut c : u64 = 0u64
        while c < PK_WL[w] { d[c] = s[c]   c = c + 1u64 }
        w = w + 1u64
    }
    return 0i32
}

/* Path C: APPEND the parsed krisis terms to the staging (the growth union);
 * 1 = the fold refuses (not krisis, or the union exceeds the exact cap) */
fn pk_stage_append_terms() -> u64 @export {
    if PK_KIND != PK_KRISIS { return 1u64 }
    let mut i : u64 = 0u64
    while i < PK_TN {
        if PKM_TN >= PK_TCAP { return 1u64 }
        PKM_TS[PKM_TN] = PK_TS[i]
        PKM_TM[PKM_TN] = PK_TM[i]
        PKM_TE[PKM_TN] = PK_TE[i]
        PKM_TB[PKM_TN] = PK_TB[i]
        PKM_TN = PKM_TN + 1u64
        i = i + 1u64
    }
    return 0u64
}

/* re-mint the just-parsed line verbatim (the round-trip law: mint(parse(x)) == x) */
fn pk_remint_parsed() -> u64 @export {
    pk_mint_begin(PK_SEQ, PK_PREV, PK_KIND, PK_OF)
    pk_stage_from_parse()
    return pk_mint_close(PK_PIN)
}

/* mint a SUPERSESSION of the just-parsed entry: same body, fresh pin, of_ set */
fn pk_mint_from_parse(newseq: u64, prev: u64, pin: u64) -> u64 @export {
    pk_mint_begin(newseq, prev, PK_KIND, PK_SEQ)
    pk_stage_from_parse()
    return pk_mint_close(pin)
}

/* ==================== the stand (the reading that re-earns) ==================== */

fn pk_std_begin() -> i32 @export {
    PK_STD_PREV = 0u64
    PK_STD_HEAD = 0u64
    return 0i32
}

/* judge one entry against the live body.
 *   0 = STANDS | 4 = DUE (pin drift; body re-earned; heal by supersession)
 *   1 = the line is not lawful | 2 = the chain is bent at this link
 *   3 = CONTRADICTION (the live body no longer derives the recorded verdict)
 *   5 = malformed | 6 = the engine refused by name
 * Contradiction dominates DUE: the body is re-earned BEFORE pins are consulted.
 * waive=1 (a superseded entry) waives ONLY the pin check -- never the body.
 * Pins by deciding engine: krisis entries pin the kernel, order entries the
 * probe, entail entries the logos itself. */
fn pk_std_line(base: u64, len: u64, pin_krisis: u64, pin_order: u64, pin_entail: u64, waive: u64) -> u64 @export {
    if pk_parse_line(base, len) != 0u64 { return 5u64 }
    let a : u64 = pk_line_addr(base, PKP_L)
    if a == 0u64 { return 1u64 }
    if PK_PREV != PK_STD_PREV { return 2u64 }
    let mut live : u64 = 0u64
    if PK_KIND == PK_KRISIS {
        pk_stage_from_parse()
        let sg : i64 = pk_rederive_krisis()
        if sg == (0i64 - 2i64) { return 6u64 }
        if sg != PK_VERD { return 3u64 }
        live = pin_krisis
    }
    if PK_KIND == PK_ORDER {
        let oa : u64 = man_seal_order(PK_WIN, PK_LOS)
        if oa == 0u64 { return 6u64 }
        if oa != PK_ORD { return 3u64 }
        live = pin_order
    }
    if PK_KIND == PK_ENTAIL {
        pk_stage_from_parse()
        if pk_rederive_entail() != 1u64 { return 3u64 }
        live = pin_entail
    }
    PK_STD_PREV = a
    PK_STD_HEAD = a
    if waive == 0u64 { if PK_PIN != live { return 4u64 } }
    return 0u64
}

fn pk_std_head() -> u64 @export { return PK_STD_HEAD }

/* ==================== the fixtures (pure; the selfprove's in-memory ledger) ==================== */

var PK_F  : [u8; 8192]                    /* 8 slots x 1024 */
var PK_FL : [u64; 8]
var PK_FA : [u64; 8]

fn pk_fbase(slot: u64) -> u64 { return ((&PK_F) as u64) + slot * 1024u64 }

fn pk_fset(slot: u64) -> i32 {
    let d : *u8 = pk_fbase(slot) as *u8
    let mut i : u64 = 0u64
    while i < PK_ON { d[i] = PK_OUT[i]   i = i + 1u64 }
    PK_FL[slot] = PK_ON
    PK_FA[slot] = PK_MADDR
    return 0i32
}

fn pk_fdup(src: u64, dst: u64) -> i32 {
    let s : *u8 = pk_fbase(src) as *u8
    let d : *u8 = pk_fbase(dst) as *u8
    let n : u64 = PK_FL[src]
    let mut i : u64 = 0u64
    while i < n { d[i] = s[i]   i = i + 1u64 }
    PK_FL[dst] = n
    PK_FA[dst] = 0u64
    return 0i32
}

/* first index of a NUL-terminated literal in a fixture slot; PK_NOTF if absent */
fn pk_fscan(slot: u64, lit: u64) -> u64 {
    let b : *u8 = pk_fbase(slot) as *u8
    let p : *u8 = lit as *u8
    let n : u64 = PK_FL[slot]
    let mut i : u64 = 0u64
    while i < n {
        let mut j : u64 = 0u64
        let mut ok : u64 = 1u64
        let mut go : u64 = 1u64
        while go == 1u64 {
            if p[j] == 0u8 { go = 0u64 }
            if go == 1u64 {
                if i + j >= n { ok = 0u64   go = 0u64 }
                if go == 1u64 {
                    if b[i + j] != p[j] { ok = 0u64   go = 0u64 }
                    if go == 1u64 { j = j + 1u64 }
                }
            }
        }
        if ok == 1u64 { return i }
        i = i + 1u64
    }
    return PK_NOTF
}

/* the fixture sweep; 0 = every entry stands, else (slot+1)*100 + code */
fn pk_sp_sweep(n: u64, pkr: u64, por: u64, pen: u64, waive_mask: u64) -> u64 {
    pk_std_begin()
    let mut i : u64 = 0u64
    while i < n {
        let w : u64 = (waive_mask >> i) & 1u64
        let rc : u64 = pk_std_line(pk_fbase(i), PK_FL[i], pkr, por, pen, w)
        if rc != 0u64 { return (i + 1u64) * 100u64 + rc }
        i = i + 1u64
    }
    return 0u64
}

/* mint the three genesis-shaped fixtures with pins aa/bb; arms 1..7 */
fn pk_sp_mint3() -> u64 {
    pk_mint_begin(1u64, 0u64, PK_KRISIS, 0u64)
    pk_mint_term(1i64, 1u64, 100i64, 1u64)
    pk_mint_term(1i64, 1u64, 30i64, 1u64)
    pk_mint_term(0i64 - 1i64, 1u64, 100i64, 1u64)
    if pk_mint_close(170u64) != 0u64 { return 1u64 }         /* the truncation refutation, +1 */
    pk_fset(0u64)
    pk_mint_begin(2u64, PK_FA[0u64], PK_KRISIS, 0u64)
    pk_mint_term(1i64, 2u64, 0i64, 2u64)
    pk_mint_term(0i64 - 1i64, 1u64, 0i64, 8u64)
    if pk_mint_close(170u64) != 0u64 { return 2u64 }         /* the exact surd zero, 2sqrt2 - sqrt8 = 0 */
    pk_fset(1u64)
    pk_mint_begin(3u64, PK_FA[1u64], PK_ORDER, 0u64)
    pk_mint_pair(24792u64, 1925u64)
    if pk_mint_close(187u64) != 0u64 { return 3u64 }         /* the R1 head order, re-sealed live */
    pk_fset(2u64)
    if PK_FA[0u64] == 0u64 { return 4u64 }
    if PK_FA[0u64] == PK_FA[1u64] { return 5u64 }            /* content-addressing separates entries */
    if PK_FA[1u64] == PK_FA[2u64] { return 6u64 }
    if PK_FL[0u64] == 0u64 { return 7u64 }
    return 0u64
}

/* the round-trip law on fixture 0: parse -> re-mint -> byte-equal; arms 8..9 */
fn pk_sp_roundtrip() -> u64 {
    if pk_parse_line(pk_fbase(0u64), PK_FL[0u64]) != 0u64 { return 8u64 }
    if pk_remint_parsed() != 0u64 { return 8u64 }
    if PK_ON != PK_FL[0u64] { return 9u64 }
    let b : *u8 = pk_fbase(0u64) as *u8
    let mut i : u64 = 0u64
    while i < PK_ON {
        if PK_OUT[i] != b[i] { return 9u64 }
        i = i + 1u64
    }
    return 0u64
}

/* the teeth: contradiction, and one bent byte breaking the exact next link; arms 12..15 */
fn pk_sp_teeth() -> u64 {
    /* a flipped verdict is a CONTRADICTION -- the kernel wins over the record */
    pk_fdup(0u64, 3u64)
    let vi : u64 = pk_fscan(3u64, "verdict_" as u64)
    if vi == PK_NOTF { return 12u64 }
    let d : *u8 = pk_fbase(3u64) as *u8
    d[vi + 8u64] = 110u8                                     /* p -> n */
    pk_std_begin()
    if pk_std_line(pk_fbase(3u64), PK_FL[3u64], 170u64, 187u64, 221u64, 0u64) != 3u64 { return 13u64 }
    /* one bent pin nybble: the entry itself only goes DUE, but its ADDRESS moved,
     * so the NEXT entry's chain refuses at exactly that link */
    pk_fdup(0u64, 3u64)
    let pi : u64 = pk_fscan(3u64, "pin_k" as u64)
    if pi == PK_NOTF { return 14u64 }
    let d2 : *u8 = pk_fbase(3u64) as *u8
    d2[pi + 5u64] = 49u8                                     /* leading pin nybble 0 -> 1 */
    pk_std_begin()
    let r1 : u64 = pk_std_line(pk_fbase(3u64), PK_FL[3u64], 170u64, 187u64, 221u64, 0u64)
    if r1 != 4u64 { return 15u64 }
    let r2 : u64 = pk_std_line(pk_fbase(1u64), PK_FL[1u64], 170u64, 187u64, 221u64, 0u64)
    if r2 != 2u64 { return 15u64 }
    return 0u64
}

/* pin drift -> DUE -> heal by supersession -> stands; waive never skips the body; arms 16..24 */
fn pk_sp_drift() -> u64 {
    pk_std_begin()
    if pk_std_line(pk_fbase(0u64), PK_FL[0u64], 204u64, 187u64, 221u64, 0u64) != 4u64 { return 16u64 }
    /* re-earn e1 and e2 under the new pin cc, appended as of_ supersessions */
    if pk_parse_line(pk_fbase(0u64), PK_FL[0u64]) != 0u64 { return 17u64 }
    if pk_mint_from_parse(4u64, PK_FA[2u64], 204u64) != 0u64 { return 18u64 }
    pk_fset(3u64)
    if pk_parse_line(pk_fbase(1u64), PK_FL[1u64]) != 0u64 { return 19u64 }
    if pk_mint_from_parse(5u64, PK_FA[3u64], 204u64) != 0u64 { return 20u64 }
    pk_fset(4u64)
    /* the healed ledger stands whole: e1/e2 waived (superseded), e4/e5 current */
    let sw : u64 = pk_sp_sweep(5u64, 204u64, 187u64, 221u64, 3u64)
    if sw != 0u64 { return 21u64 }
    /* waive can NEVER skip the body: a fresh standalone entry with a flipped
     * verdict refuses 3 even when its pin check is waived */
    pk_mint_begin(9u64, 0u64, PK_KRISIS, 0u64)
    pk_mint_term(1i64, 1u64, 5i64, 1u64)
    if pk_mint_close(204u64) != 0u64 { return 22u64 }
    pk_fset(5u64)
    let vi : u64 = pk_fscan(5u64, "verdict_" as u64)
    if vi == PK_NOTF { return 23u64 }
    let d : *u8 = pk_fbase(5u64) as *u8
    d[vi + 8u64] = 110u8
    pk_std_begin()
    if pk_std_line(pk_fbase(5u64), PK_FL[5u64], 204u64, 187u64, 221u64, 1u64) != 3u64 { return 24u64 }
    return 0u64
}

/* an empty deposit refuses; the sweep is deterministic; arms 25..27 */
fn pk_sp_det() -> u64 {
    pk_mint_begin(6u64, 0u64, PK_KRISIS, 0u64)
    if pk_mint_close(170u64) != 1u64 { return 25u64 }        /* nothing re-derived, nothing minted */
    let s1 : u64 = pk_sp_sweep(3u64, 170u64, 187u64, 221u64, 0u64)
    if s1 != 0u64 { return 26u64 }
    let h1 : u64 = pk_std_head()
    let s2 : u64 = pk_sp_sweep(3u64, 170u64, 187u64, 221u64, 0u64)
    if s2 != 0u64 { return 26u64 }
    if pk_std_head() != h1 { return 27u64 }
    if h1 != PK_FA[2u64] { return 27u64 }
    return 0u64
}

/* Paths B/C/D law arms (pure): the growth union with provenance round-trips and
 * stands (C); a TRUE transitivity theorem mints and stands while a DISCONNECTED
 * one is REFUSED at the mint -- the logos owns the verdict, both outcomes
 * expressible, no tautology (D); the entail tamper tooth (a bent premise word is
 * a CONTRADICTION); arms 30..38. */
fn pk_sp_paths() -> u64 {
    /* C: union of fixture e1 + e2 bodies, from_e1 from_e2, minted by re-derivation */
    if pk_parse_line(pk_fbase(0u64), PK_FL[0u64]) != 0u64 { return 30u64 }
    pk_mint_begin(7u64, 0u64, PK_KRISIS, 0u64)
    if pk_stage_append_terms() != 0u64 { return 30u64 }
    if pk_mint_from_add(1u64) != 0u64 { return 30u64 }
    if pk_parse_line(pk_fbase(1u64), PK_FL[1u64]) != 0u64 { return 30u64 }
    if pk_stage_append_terms() != 0u64 { return 30u64 }
    if pk_mint_from_add(2u64) != 0u64 { return 30u64 }
    if pk_mint_close(204u64) != 0u64 { return 31u64 }
    pk_fset(6u64)
    if pk_parse_line(pk_fbase(6u64), PK_FL[6u64]) != 0u64 { return 32u64 }
    if pk_parsed_from_count() != 2u64 { return 32u64 }
    if pk_remint_parsed() != 0u64 { return 32u64 }
    if PK_ON != PK_FL[6u64] { return 33u64 }
    let b6 : *u8 = pk_fbase(6u64) as *u8
    let mut i : u64 = 0u64
    while i < PK_ON { if PK_OUT[i] != b6[i] { return 33u64 }   i = i + 1u64 }
    pk_std_begin()
    if pk_std_line(pk_fbase(6u64), PK_FL[6u64], 204u64, 187u64, 221u64, 0u64) != 0u64 { return 34u64 }
    /* D: the true theorem [alpha<beta][beta<gamma] |- [alpha<gamma] mints + stands */
    pk_mint_begin(8u64, 0u64, PK_ENTAIL, 0u64)
    if pk_mint_word(0u64, "alpha" as u64) != 0u64 { return 35u64 }
    if pk_mint_word(1u64, "beta" as u64) != 0u64 { return 35u64 }
    if pk_mint_word(2u64, "beta" as u64) != 0u64 { return 35u64 }
    if pk_mint_word(3u64, "gamma" as u64) != 0u64 { return 35u64 }
    if pk_mint_word(4u64, "alpha" as u64) != 0u64 { return 35u64 }
    if pk_mint_word(5u64, "gamma" as u64) != 0u64 { return 35u64 }
    if pk_mint_close(221u64) != 0u64 { return 35u64 }
    pk_fset(7u64)
    if pk_parse_line(pk_fbase(7u64), PK_FL[7u64]) != 0u64 { return 36u64 }
    if pk_remint_parsed() != 0u64 { return 36u64 }
    if PK_ON != PK_FL[7u64] { return 36u64 }
    let b7 : *u8 = pk_fbase(7u64) as *u8
    i = 0u64
    while i < PK_ON { if PK_OUT[i] != b7[i] { return 36u64 }   i = i + 1u64 }
    pk_std_begin()
    if pk_std_line(pk_fbase(7u64), PK_FL[7u64], 204u64, 187u64, 221u64, 0u64) != 0u64 { return 36u64 }
    /* D negative: DISCONNECTED premises never deposit -- the mint refuses (7) */
    pk_mint_begin(9u64, 0u64, PK_ENTAIL, 0u64)
    pk_mint_word(0u64, "alpha" as u64)
    pk_mint_word(1u64, "beta" as u64)
    pk_mint_word(2u64, "gamma" as u64)
    pk_mint_word(3u64, "delta" as u64)
    pk_mint_word(4u64, "alpha" as u64)
    pk_mint_word(5u64, "delta" as u64)
    if pk_mint_close(221u64) != 7u64 { return 37u64 }
    /* D tooth: a bent premise word in the standing theorem is a CONTRADICTION */
    let bi : u64 = pk_fscan(7u64, "pb_beta" as u64)
    if bi == PK_NOTF { return 38u64 }
    let d7 : *u8 = pk_fbase(7u64) as *u8
    d7[bi + 3u64] = 120u8                                    /* beta -> xeta: the chain no longer connects */
    pk_std_begin()
    if pk_std_line(pk_fbase(7u64), PK_FL[7u64], 204u64, 187u64, 221u64, 0u64) != 3u64 { return 38u64 }
    return 0u64
}

/* THE CONDITION OF MOTION (pure, no filesystem): every invocation re-derives the
 * whole deposit law -- mint-by-rederivation, the round-trip identity, the chain
 * that names its bent link, contradiction over DUE, supersession that waives
 * only pins, refusal of the empty deposit, the growth union with provenance,
 * the entailment theorem law (true deposits, forged refusals), determinism.
 * 0 = the law holds; a nonzero arm code names the exact clause that failed. */
fn paratheke_selfprove() -> u64 @export {
    let m : u64 = pk_sp_mint3()
    if m != 0u64 { return m }
    let r : u64 = pk_sp_roundtrip()
    if r != 0u64 { return r }
    let s : u64 = pk_sp_sweep(3u64, 170u64, 187u64, 221u64, 0u64)
    if s != 0u64 { return 10u64 }
    if pk_std_head() != PK_FA[2u64] { return 11u64 }
    let t : u64 = pk_sp_teeth()
    if t != 0u64 { return t }
    let dr : u64 = pk_sp_drift()
    if dr != 0u64 { return dr }
    let de : u64 = pk_sp_det()
    if de != 0u64 { return de }
    let pp : u64 = pk_sp_paths()
    if pp != 0u64 { return pp }
    return 0u64
}
