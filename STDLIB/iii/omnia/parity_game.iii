/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\parity_game.iii
 *
 * III STDLIB - omnia::parity_game  --  the recursive ZIELONKA parity-game solver, as a wired organ.
 *
 * Lifted from the PROVEN grail solver (corpus 1839): attractors + the recursive even/odd decomposition.
 * The full mu-calculus model-checking oracle, the ground truth III's parity research refuted two poly
 * predictors against (max-reachable-priority 223/400, recurrent-cycle-priority 168/400 -- both blind to
 * CONTROL, which the recursion supplies).  Here it becomes a reusable organ so a real consumer
 * (omnia::event_substrate, corpus 1902) can fold the plays the solver's winning regions induce and
 * cross-check the parity ACCEPTANCE condition against the game VALUE -- determinacy where the play stays
 * in the winner's region, control-blindness where it leaves it.
 *
 * Game: up to 16 vertices.  pg_own[v] in {0,1} (owner).  pg_pri[v] = priority.  pg_suc[v] = successor SET
 * as a bitmask (bit w set <=> edge v->w).  Regions are u32 bitmasks.  pg_zielonka(region) -> u64 =
 * (Weven in low32, Wodd in high32).
 *
 * Ring R0.  K 1.00 (a pure function of the game tables).  NIH: libc only, zero externs.
 */
module omnia_parity_game

const PG_CAP    : u32 = 16u32
const PG_NULL   : u32 = 0xFFFFFFFFu32
const PG_ALL32  : u32 = 0xFFFFFFFFu32

var PG_OWN : [u8;  16]
var PG_PRI : [u32; 16]
var PG_SUC : [u32; 16]
var PG_NV  : u32 = 0u32

/* ── construction ─────────────────────────────────────────────────────── */
fn pg_reset() -> i32 @export {
    PG_NV = 0u32
    return 0i32
}

fn pg_set_nv(n: u32) -> i32 @export {
    if n > PG_CAP { return -1i32 }
    PG_NV = n
    return 0i32
}

fn pg_set_vertex(v: u32, owner: u8, prio: u32, succ_mask: u32) -> i32 @export {
    if v >= PG_CAP { return -1i32 }
    PG_OWN[v as u64] = owner
    PG_PRI[v as u64] = prio
    PG_SUC[v as u64] = succ_mask
    return 0i32
}

fn pg_nv() -> u32 @export { return PG_NV }
fn pg_pri(v: u32) -> u32 @export { if v >= PG_NV { return 0u32 } return PG_PRI[v as u64] }
fn pg_own(v: u32) -> u8  @export { if v >= PG_NV { return 0u8 }  return PG_OWN[v as u64] }
fn pg_succ(v: u32) -> u32 @export { if v >= PG_NV { return 0u32 } return PG_SUC[v as u64] }

/* the full-game region = all NV vertices set. */
fn pg_full() -> u32 @export {
    if PG_NV == 0u32 { return 0u32 }
    let mut r : u32 = 0u32
    let mut v : u32 = 0u32
    while v < PG_NV {
        r = r | (1u32 << v)
        v = v + 1u32
    }
    return r
}

/* ── the solver (verbatim algorithm from the proven grail 1839) ───────── */
fn pg_max_prio(region: u32) -> u32 @export {
    let mut m : u32 = 0u32
    let mut v : u32 = 0u32
    let n : u32 = PG_NV
    while v < n {
        if (region & (1u32 << v)) != 0u32 {
            if PG_PRI[v as u64] > m { m = PG_PRI[v as u64] }
        }
        v = v + 1u32
    }
    return m
}

fn pg_attractor(region: u32, player: u32, target: u32) -> u32 @export {
    let mut a : u32 = target & region
    let mut done : u8 = 0u8
    let n : u32 = PG_NV
    while done == 0u8 {
        let mut added : u8 = 0u8
        let mut v : u32 = 0u32
        while v < n {
            let bit : u32 = 1u32 << v
            if (region & bit) != 0u32 {
                if (a & bit) == 0u32 {
                    if PG_OWN[v as u64] == (player as u8) {
                        if (PG_SUC[v as u64] & a & region) != 0u32 { a = a | bit  added = 1u8 }
                    } else {
                        let sir : u32 = PG_SUC[v as u64] & region
                        if sir != 0u32 {
                            if (sir & (a ^ 0xFFFFFFFFu32)) == 0u32 { a = a | bit  added = 1u8 }
                        }
                    }
                }
            }
            v = v + 1u32
        }
        if added == 0u8 { done = 1u8 }
    }
    return a
}

fn pg_zielonka(region: u32) -> u64 @export {
    if region == 0u32 { return 0u64 }
    let d : u32 = pg_max_prio(region)
    let p : u32 = d & 1u32
    let mut u : u32 = 0u32
    let mut v : u32 = 0u32
    let n : u32 = PG_NV
    while v < n {
        if (region & (1u32 << v)) != 0u32 {
            if PG_PRI[v as u64] == d { u = u | (1u32 << v) }
        }
        v = v + 1u32
    }
    let a : u32 = pg_attractor(region, p, u)
    let r1 : u64 = pg_zielonka(region & (a ^ 0xFFFFFFFFu32))
    let w0a : u32 = (r1 & 0xFFFFFFFFu64) as u32
    let w1a : u32 = (r1 >> 32u64) as u32
    let mut wopp : u32 = w1a
    if p != 0u32 { wopp = w0a }
    if wopp == 0u32 {
        if p == 0u32 { return region as u64 }
        return (region as u64) << 32u64
    }
    let opp : u32 = 1u32 - p
    let b : u32 = pg_attractor(region, opp, wopp)
    let r2 : u64 = pg_zielonka(region & (b ^ 0xFFFFFFFFu32))
    let w0b : u32 = (r2 & 0xFFFFFFFFu64) as u32
    let w1b : u32 = (r2 >> 32u64) as u32
    if p == 0u32 { return (w0b as u64) | (((w1b | b) as u64) << 32u64) }
    return ((w0b | b) as u64) | ((w1b as u64) << 32u64)
}

/* winner at a vertex: solve the full game, return 0 if v is in Weven, 1 if in Wodd. */
fn pg_winner_at(v: u32) -> u32 @export {
    let r : u64 = pg_zielonka(pg_full())
    let we : u32 = (r & 0xFFFFFFFFu64) as u32
    if (we & (1u32 << v)) != 0u32 { return 0u32 }
    return 1u32
}

/* ── play generation: a winning-region-following strategy ───────────────
 * the lowest-index successor of v that stays in `region`.  Following this from a vertex in a player's
 * winning region realises a play that stays in that region forever (a lasso) -- the determinacy witness.
 * Returns PG_NULL if v has no successor inside region. */
fn pg_succ_in_region(v: u32, region: u32) -> u32 @export {
    if v >= PG_NV { return PG_NULL }
    let s : u32 = PG_SUC[v as u64] & region
    if s == 0u32 { return PG_NULL }
    let mut w : u32 = 0u32
    let n : u32 = PG_NV
    while w < n {
        if (s & (1u32 << w)) != 0u32 { return w }
        w = w + 1u32
    }
    return PG_NULL
}
