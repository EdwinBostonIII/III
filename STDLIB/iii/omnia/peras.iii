/* ==================== module state ==================== */

/* fixed point: value = mant * 2^-88, mants as 2 limbs (lo, hi) */
const PR_F : u64 = 88u64

/* 128-bit multiply scratch */
var PR_MHI : u64 = 0u64
var PR_MLO : u64 = 0u64

/* 3-limb scratch (little-endian) */
var PR_Z : [u64; 3]

/* 4-limb product scratch */
var PR_W : [u64; 4]

/* sticky bit of the last directed shift */
var PR_STK : u64 = 0u64

/* exp result interval */
var PR_ELO0 : u64 = 0u64
var PR_ELO1 : u64 = 0u64
var PR_EHI0 : u64 = 0u64
var PR_EHI1 : u64 = 0u64
var PR_FAIL : u8 = 0u8

/* saved intervals for the arms */
var PR_A_LO0 : u64 = 0u64
var PR_A_LO1 : u64 = 0u64
var PR_A_HI0 : u64 = 0u64
var PR_A_HI1 : u64 = 0u64
var PR_B_LO0 : u64 = 0u64
var PR_B_LO1 : u64 = 0u64
var PR_B_HI0 : u64 = 0u64
var PR_B_HI1 : u64 = 0u64

/* signed 192-bit mix bounds: sign (i64) + 3 limbs */
var PR_LL_S : i64 = 0i64
var PR_LL : [u64; 3]
var PR_LH_S : i64 = 0i64
var PR_LH : [u64; 3]
var PR_RL_S : i64 = 0i64
var PR_RL : [u64; 3]
var PR_RH_S : i64 = 0i64
var PR_RH : [u64; 3]
/* signed add scratch */
var PR_SA_S : i64 = 0i64
var PR_SA : [u64; 3]

/* the report and the scroll */
var PR_REP : [u8; 4096]
var PR_REPN : u64 = 0u64
var PR_SCROLL : u64 = 0u64

/* ==================== report helpers ==================== */

fn pr_slen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { i = i + 1u64 }
    return i
}

fn pr_rb(b: u8) -> i32 {
    if PR_REPN >= 4095u64 { return 0i32 }
    PR_REP[PR_REPN] = b
    PR_REPN = PR_REPN + 1u64
    return 0i32
}

fn pr_rs(s: u64) -> i32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 {
        pr_rb(p[i])
        i = i + 1u64
    }
    return 0i32
}

fn pr_ru(v: u64) -> i32 {
    if v >= 10u64 { pr_ru(v / 10u64) }
    pr_rb((48u64 + (v % 10u64)) as u8)
    return 0i32
}

fn pr_ri(v: i64) -> i32 {
    if v < 0i64 {
        pr_rb(45u8)
        pr_ru((0i64 - v) as u64)
        return 0i32
    }
    pr_ru(v as u64)
    return 0i32
}

/* ==================== limb toolkit ==================== */

fn pr_mul64(a: u64, b: u64) -> i32 {
    let a0 : u64 = a & 0xFFFFFFFFu64
    let a1 : u64 = a >> 32u64
    let b0 : u64 = b & 0xFFFFFFFFu64
    let b1 : u64 = b >> 32u64
    let p00 : u64 = a0 * b0
    let p01 : u64 = a0 * b1
    let p10 : u64 = a1 * b0
    let p11 : u64 = a1 * b1
    let mid1 : u64 = p01 + (p00 >> 32u64)
    let mid2 : u64 = p10 + (mid1 & 0xFFFFFFFFu64)
    PR_MHI = p11 + (mid1 >> 32u64) + (mid2 >> 32u64)
    PR_MLO = (mid2 << 32u64) | (p00 & 0xFFFFFFFFu64)
    return 0i32
}

/* PR_Z = (ahi,alo) * b */
fn pr_mul128by64(ahi: u64, alo: u64, b: u64) -> i32 {
    pr_mul64(alo, b)
    let l0 : u64 = PR_MLO
    let l1a : u64 = PR_MHI
    pr_mul64(ahi, b)
    let l1b : u64 = PR_MLO
    let l2 : u64 = PR_MHI
    let s : u64 = l1a + l1b
    let mut c : u64 = 0u64
    if s < l1a { c = 1u64 }
    PR_Z[0] = l0
    PR_Z[1] = s
    PR_Z[2] = l2 + c
    return 0i32
}

/* PR_W = (ahi,alo) * (bhi,blo), full 256-bit */
fn pr_mul128(ahi: u64, alo: u64, bhi: u64, blo: u64) -> i32 {
    pr_mul64(alo, blo)
    PR_W[0] = PR_MLO
    PR_W[1] = PR_MHI
    PR_W[2] = 0u64
    PR_W[3] = 0u64
    pr_mul64(alo, bhi)
    let s1 : u64 = PR_W[1] + PR_MLO
    let mut c1 : u64 = 0u64
    if s1 < PR_MLO { c1 = 1u64 }
    PR_W[1] = s1
    let s2 : u64 = PR_W[2] + PR_MHI + c1
    PR_W[2] = s2
    pr_mul64(ahi, blo)
    let s1b : u64 = PR_W[1] + PR_MLO
    let mut c1b : u64 = 0u64
    if s1b < PR_MLO { c1b = 1u64 }
    PR_W[1] = s1b
    let s2b : u64 = PR_W[2] + PR_MHI
    let mut c2b : u64 = 0u64
    if s2b < PR_MHI { c2b = 1u64 }
    let s2c : u64 = s2b + c1b
    if s2c < c1b { c2b = c2b + 1u64 }
    PR_W[2] = s2c
    PR_W[3] = PR_W[3] + c2b
    pr_mul64(ahi, bhi)
    let s2d : u64 = PR_W[2] + PR_MLO
    let mut c2d : u64 = 0u64
    if s2d < PR_MLO { c2d = 1u64 }
    PR_W[2] = s2d
    PR_W[3] = PR_W[3] + PR_MHI + c2d
    return 0i32
}

/* shift PR_W right by 88 into (PR_MHI:PR_MLO), sticky into PR_STK.
 * headroom law: the result must fit 128 bits (PR_W[3] >> 24 == 0). */
fn pr_wshr88() -> i32 {
    if (PR_W[3] >> 24u64) != 0u64 {
        PR_FAIL = 1u8
        return 1i32
    }
    PR_STK = PR_W[0] | (PR_W[1] & 0xFFFFFFu64)
    PR_MLO = (PR_W[1] >> 24u64) | (PR_W[2] << 40u64)
    PR_MHI = (PR_W[2] >> 24u64) | (PR_W[3] << 40u64)
    return 0i32
}

/* shift PR_Z right by `sh` (1..40) into (PR_MHI:PR_MLO), sticky PR_STK */
fn pr_zshr(sh: u64) -> i32 {
    if (PR_Z[2] >> sh) != 0u64 {
        PR_FAIL = 1u8
        return 1i32
    }
    PR_STK = PR_Z[0] & ((1u64 << sh) - 1u64)
    PR_MLO = (PR_Z[0] >> sh) | (PR_Z[1] << (64u64 - sh))
    PR_MHI = (PR_Z[1] >> sh) | (PR_Z[2] << (64u64 - sh))
    return 0i32
}

/* divide (hi,lo) by small k (2..25); floor in (PR_MHI:PR_MLO), rem PR_STK */
fn pr_div_small(hi: u64, lo: u64, k: u64) -> i32 {
    let qh : u64 = hi / k
    let r0 : u64 = hi % k
    let cur1 : u64 = (r0 << 32u64) | (lo >> 32u64)
    let q1 : u64 = cur1 / k
    let r1 : u64 = cur1 % k
    let cur2 : u64 = (r1 << 32u64) | (lo & 0xFFFFFFFFu64)
    let q2 : u64 = cur2 / k
    let r2 : u64 = cur2 % k
    PR_MHI = qh
    PR_MLO = (q1 << 32u64) | q2
    PR_STK = r2
    return 0i32
}

fn pr_cmp128(ah: u64, al: u64, bh: u64, bl: u64) -> i64 {
    if ah > bh { return 1i64 }
    if ah < bh { return 0i64 - 1i64 }
    if al > bl { return 1i64 }
    if al < bl { return 0i64 - 1i64 }
    return 0i64
}

/* (PR_MHI:PR_MLO) += 1 */
fn pr_inc128() -> i32 {
    PR_MLO = PR_MLO + 1u64
    if PR_MLO == 0u64 { PR_MHI = PR_MHI + 1u64 }
    return 0i32
}

/* ==================== the certified exponential ==================== */

/* exp(M * 2^-S) for 0 <= value <= 16, S in {24,26}; result interval in
 * PR_ELO/PR_EHI at 2^-88.  PR_FAIL set on any headroom breach. */
fn pr_exp(m_in: u64, s_in: u64) -> i32 {
    PR_FAIL = 0u8
    /* the halving ladder: y = M * 2^-(S+h) with y <= 1/2 */
    let mut h : u64 = 0u64
    let mut go : u8 = 1u8
    while go == 1u8 {
        go = 0u8
        if m_in > (1u64 << (s_in + h - 1u64)) {
            h = h + 1u64
            go = 1u8
        }
        if h > 6u64 {
            PR_FAIL = 1u8
            return 1i32
        }
    }
    let sy : u64 = s_in + h
    /* Taylor: term chains, floored (lo) and ceiled (hi), 24 terms.
     * mant = (hi:lo) with value hi*2^64 + lo; 2^88 has hi = 2^24, lo = 0.
     * Integer additions are EXACT -- the only roundings are the directed
     * shift and divide inside each term chain, so lo <= true <= hi + tail. */
    let mut th_lo : u64 = 0u64
    let mut th_hi : u64 = 1u64 << 24u64
    let mut tl_lo : u64 = 0u64
    let mut tl_hi : u64 = 1u64 << 24u64
    let mut sl_lo : u64 = 0u64
    let mut sl_hi : u64 = 1u64 << 24u64
    let mut sh_lo : u64 = 0u64
    let mut sh_hi : u64 = 1u64 << 24u64
    let mut k : u64 = 1u64
    while k <= 24u64 {
        /* T_lo := floor(floor(T_lo * y) / k) */
        pr_mul128by64(tl_hi, tl_lo, m_in)
        if pr_zshr(sy) != 0i32 { return 1i32 }
        pr_div_small(PR_MHI, PR_MLO, k)
        tl_hi = PR_MHI
        tl_lo = PR_MLO
        /* T_hi := ceil(ceil(T_hi * y) / k) */
        pr_mul128by64(th_hi, th_lo, m_in)
        if pr_zshr(sy) != 0i32 { return 1i32 }
        if PR_STK != 0u64 { pr_inc128() }
        let ch : u64 = PR_MHI
        let cl : u64 = PR_MLO
        pr_div_small(ch, cl, k)
        if PR_STK != 0u64 { pr_inc128() }
        th_hi = PR_MHI
        th_lo = PR_MLO
        /* S += T (both chains) */
        sl_lo = sl_lo + tl_lo
        if sl_lo < tl_lo { sl_hi = sl_hi + 1u64 }
        sl_hi = sl_hi + tl_hi
        sh_lo = sh_lo + th_lo
        if sh_lo < th_lo { sh_hi = sh_hi + 1u64 }
        sh_hi = sh_hi + th_hi
        k = k + 1u64
    }
    /* the tail: sum_{k>=25} y^k/k! <= 2 * (T_hi * y) (y <= 1/2 geometric) */
    pr_mul128by64(th_hi, th_lo, m_in)
    if pr_zshr(sy) != 0i32 { return 1i32 }
    if PR_STK != 0u64 { pr_inc128() }
    let r_lo2 : u64 = PR_MLO << 1u64
    let r_hi2 : u64 = (PR_MHI << 1u64) | (PR_MLO >> 63u64)
    sh_lo = sh_lo + r_lo2
    if sh_lo < r_lo2 { sh_hi = sh_hi + 1u64 }
    sh_hi = sh_hi + r_hi2
    /* the squaring ladder: h times */
    let mut q : u64 = 0u64
    while q < h {
        pr_mul128(sl_hi, sl_lo, sl_hi, sl_lo)
        if pr_wshr88() != 0i32 { return 1i32 }
        sl_hi = PR_MHI
        sl_lo = PR_MLO
        pr_mul128(sh_hi, sh_lo, sh_hi, sh_lo)
        if pr_wshr88() != 0i32 { return 1i32 }
        if PR_STK != 0u64 { pr_inc128() }
        sh_hi = PR_MHI
        sh_lo = PR_MLO
        q = q + 1u64
    }
    PR_ELO0 = sl_lo
    PR_ELO1 = sl_hi
    PR_EHI0 = sh_lo
    PR_EHI1 = sh_hi
    /* sanity: lo <= hi */
    if pr_cmp128(sl_hi, sl_lo, sh_hi, sh_lo) > 0i64 {
        PR_FAIL = 1u8
        return 1i32
    }
    return 0i32
}

/* relative width law: (hi - lo) * 2^32 < hi  (width below 2^-32 relative) */
fn pr_width_ok() -> u64 {
    let mut d_lo : u64 = PR_EHI0 - PR_ELO0
    let mut d_hi : u64 = PR_EHI1 - PR_ELO1
    if PR_EHI0 < PR_ELO0 { d_hi = d_hi - 1u64 }
    /* d << 32 must not overflow 128 and must stay under hi */
    if (d_hi >> 32u64) != 0u64 { return 0u64 }
    let s_hi : u64 = (d_hi << 32u64) | (d_lo >> 32u64)
    let s_lo : u64 = d_lo << 32u64
    if pr_cmp128(s_hi, s_lo, PR_EHI1, PR_EHI0) < 0i64 { return 1u64 }
    return 0u64
}

/* ==================== arm 367: THE BOUND ==================== */

fn pr_arm367() -> u64 {
    /* exp(0) = 1 EXACTLY: the interval collapses to the point 2^88 */
    if pr_exp(0u64, 24u64) != 0i32 { return 367u64 }
    if PR_ELO1 != (1u64 << 24u64) { return 367u64 }
    if PR_ELO0 != 0u64 { return 367u64 }
    if PR_EHI1 != PR_ELO1 { return 367u64 }
    if PR_EHI0 != PR_ELO0 { return 367u64 }
    /* e = exp(1): the Taylor interval must sit between continued-fraction
     * convergents -- CF theory as the independent engine.
     * e = [2; 1,2,1,1,4,1,1,6,1,1,8,1,1,10] */
    if pr_exp(1u64 << 24u64, 24u64) != 0i32 { return 367u64 }
    if pr_width_ok() != 1u64 { return 367u64 }
    let e_lo0 : u64 = PR_ELO0
    let e_lo1 : u64 = PR_ELO1
    let e_hi0 : u64 = PR_EHI0
    let e_hi1 : u64 = PR_EHI1
    let mut p_prev : u64 = 1u64
    let mut p_cur : u64 = 2u64
    let mut q_prev : u64 = 0u64
    let mut q_cur : u64 = 1u64
    let mut below_p : u64 = 2u64
    let mut below_q : u64 = 1u64
    let mut above_p : u64 = 0u64
    let mut above_q : u64 = 1u64
    let mut idx : u64 = 1u64
    while idx <= 14u64 {
        let mut a : u64 = 1u64
        /* a_k = 2k/3 at positions 2,5,8,11,14 (pattern 1,2,1,1,4,1,1,6,...) */
        if idx == 2u64 { a = 2u64 }
        if idx == 5u64 { a = 4u64 }
        if idx == 8u64 { a = 6u64 }
        if idx == 11u64 { a = 8u64 }
        if idx == 14u64 { a = 10u64 }
        let p_new : u64 = a * p_cur + p_prev
        let q_new : u64 = a * q_cur + q_prev
        p_prev = p_cur
        p_cur = p_new
        q_prev = q_cur
        q_cur = q_new
        /* odd index convergents sit above e, even below */
        if (idx & 1u64) == 1u64 {
            above_p = p_new
            above_q = q_new
        }
        if (idx & 1u64) == 0u64 {
            below_p = p_new
            below_q = q_new
        }
        idx = idx + 1u64
    }
    if above_p == 0u64 { return 367u64 }
    /* below_p/below_q < e_interval: below_p * 2^88 < e_lo * below_q */
    pr_mul128by64(e_lo1, e_lo0, below_q)
    let bl0 : u64 = PR_Z[0]
    let bl1 : u64 = PR_Z[1]
    let bl2 : u64 = PR_Z[2]
    /* below_p * 2^88 as 3 limbs */
    let bp1 : u64 = below_p << 24u64
    let bp2 : u64 = below_p >> 40u64
    let mut cf_ok : u64 = 1u64
    if bl2 < bp2 { cf_ok = 0u64 }
    if bl2 == bp2 {
        if bl1 < bp1 { cf_ok = 0u64 }
        if bl1 == bp1 {
            if bl0 == 0u64 { cf_ok = 0u64 }
        }
    }
    if cf_ok == 0u64 { return 367u64 }
    /* e_interval < above_p/above_q: e_hi * above_q < above_p * 2^88 */
    pr_mul128by64(e_hi1, e_hi0, above_q)
    let al0 : u64 = PR_Z[0]
    let al1 : u64 = PR_Z[1]
    let al2 : u64 = PR_Z[2]
    let ap1 : u64 = above_p << 24u64
    let ap2 : u64 = above_p >> 40u64
    let mut cf_ok2 : u64 = 1u64
    if al2 > ap2 { cf_ok2 = 0u64 }
    if al2 == ap2 {
        if al1 > ap1 { cf_ok2 = 0u64 }
        if al1 == ap1 { cf_ok2 = 0u64 }
    }
    if cf_ok2 == 0u64 { return 367u64 }
    /* the functional equation on fixed dyadics: a = 3/4, b = 5/8 */
    if pr_exp(3u64 << 22u64, 24u64) != 0i32 { return 367u64 }
    let fa_l0 : u64 = PR_ELO0
    let fa_l1 : u64 = PR_ELO1
    let fa_h0 : u64 = PR_EHI0
    let fa_h1 : u64 = PR_EHI1
    if pr_exp(5u64 << 21u64, 24u64) != 0i32 { return 367u64 }
    let fb_l0 : u64 = PR_ELO0
    let fb_l1 : u64 = PR_ELO1
    let fb_h0 : u64 = PR_EHI0
    let fb_h1 : u64 = PR_EHI1
    /* a+b = 3/4 + 5/8 = 11/8 exact */
    if pr_exp(11u64 << 21u64, 24u64) != 0i32 { return 367u64 }
    let fs_l0 : u64 = PR_ELO0
    let fs_l1 : u64 = PR_ELO1
    let fs_h0 : u64 = PR_EHI0
    let fs_h1 : u64 = PR_EHI1
    /* product interval [fa_l*fb_l >> 88 floor, fa_h*fb_h >> 88 ceil] */
    pr_mul128(fa_l1, fa_l0, fb_l1, fb_l0)
    if pr_wshr88() != 0i32 { return 367u64 }
    let pl0 : u64 = PR_MLO
    let pl1 : u64 = PR_MHI
    pr_mul128(fa_h1, fa_h0, fb_h1, fb_h0)
    if pr_wshr88() != 0i32 { return 367u64 }
    if PR_STK != 0u64 { pr_inc128() }
    let ph0 : u64 = PR_MLO
    let ph1 : u64 = PR_MHI
    /* overlap: NOT (ph < fs_l) and NOT (fs_h < pl) */
    if pr_cmp128(ph1, ph0, fs_l1, fs_l0) < 0i64 { return 367u64 }
    if pr_cmp128(fs_h1, fs_h0, pl1, pl0) < 0i64 { return 367u64 }
    /* strict monotone separation across a 2^-4 gap: exp(1/2) vs exp(1/2+1/16) */
    if pr_exp(1u64 << 23u64, 24u64) != 0i32 { return 367u64 }
    let ma_h0 : u64 = PR_EHI0
    let ma_h1 : u64 = PR_EHI1
    if pr_exp((1u64 << 23u64) + (1u64 << 20u64), 24u64) != 0i32 { return 367u64 }
    if pr_cmp128(ma_h1, ma_h0, PR_ELO1, PR_ELO0) >= 0i64 { return 367u64 }
    pr_rs("the peras: exp0=exact e=cf-bounded feq=overlap monotone=separated width<2^-32rel" as u64)
    pr_rb(10u8)
    return 0u64
}

/* ==================== arm 368: THE DISCHARGE ==================== */

/* signed term bound: t = w * [E interval] directed; side 0 = low, 1 = high.
 * writes sign into PR_SA_S and magnitude into PR_SA. */
fn pr_term(w: i64, e_l1: u64, e_l0: u64, e_h1: u64, e_h0: u64, side: u64) -> i32 {
    if w == 0i64 {
        PR_SA_S = 0i64
        PR_SA[0] = 0u64
        PR_SA[1] = 0u64
        PR_SA[2] = 0u64
        return 0i32
    }
    let mut mag : u64 = w as u64
    if w < 0i64 { mag = (0i64 - w) as u64 }
    /* which end of the interval bounds this side */
    let mut use_hi : u64 = side
    if w < 0i64 { use_hi = 1u64 - side }
    if use_hi == 1u64 { pr_mul128by64(e_h1, e_h0, mag) }
    if use_hi == 0u64 { pr_mul128by64(e_l1, e_l0, mag) }
    PR_SA[0] = PR_Z[0]
    PR_SA[1] = PR_Z[1]
    PR_SA[2] = PR_Z[2]
    PR_SA_S = 1i64
    if w < 0i64 { PR_SA_S = 0i64 - 1i64 }
    return 0i32
}

/* signed accumulate: (s_dst, dst[]) += (PR_SA_S, PR_SA[]); dst selected:
 * 0 = LL, 1 = LH, 2 = RL, 3 = RH */
fn pr_acc(which: u64) -> i32 {
    let mut ds : i64 = 0i64
    if which == 0u64 { ds = PR_LL_S }
    if which == 1u64 { ds = PR_LH_S }
    if which == 2u64 { ds = PR_RL_S }
    if which == 3u64 { ds = PR_RH_S }
    let mut d0 : u64 = 0u64
    let mut d1 : u64 = 0u64
    let mut d2 : u64 = 0u64
    if which == 0u64 { d0 = PR_LL[0]   d1 = PR_LL[1]   d2 = PR_LL[2] }
    if which == 1u64 { d0 = PR_LH[0]   d1 = PR_LH[1]   d2 = PR_LH[2] }
    if which == 2u64 { d0 = PR_RL[0]   d1 = PR_RL[1]   d2 = PR_RL[2] }
    if which == 3u64 { d0 = PR_RH[0]   d1 = PR_RH[1]   d2 = PR_RH[2] }
    let ss : i64 = PR_SA_S
    let s0 : u64 = PR_SA[0]
    let s1 : u64 = PR_SA[1]
    let s2 : u64 = PR_SA[2]
    let mut r_s : i64 = ds
    let mut r0 : u64 = d0
    let mut r1 : u64 = d1
    let mut r2 : u64 = d2
    if ss == 0i64 {
        /* nothing */
        r_s = ds
    }
    if ss != 0i64 {
        if ds == 0i64 {
            r_s = ss
            r0 = s0
            r1 = s1
            r2 = s2
        }
        if ds == ss {
            /* same sign: magnitude add */
            let a0 : u64 = d0 + s0
            let mut c0 : u64 = 0u64
            if a0 < s0 { c0 = 1u64 }
            let a1a : u64 = d1 + s1
            let mut c1 : u64 = 0u64
            if a1a < s1 { c1 = 1u64 }
            let a1 : u64 = a1a + c0
            if a1 < c0 { c1 = c1 + 1u64 }
            r0 = a0
            r1 = a1
            r2 = d2 + s2 + c1
            r_s = ds
        }
        if ds != 0i64 {
            if ds != ss {
                /* different signs: larger magnitude wins */
                let mut cmp : i64 = 0i64
                if d2 > s2 { cmp = 1i64 }
                if d2 < s2 { cmp = 0i64 - 1i64 }
                if cmp == 0i64 {
                    if d1 > s1 { cmp = 1i64 }
                    if d1 < s1 { cmp = 0i64 - 1i64 }
                }
                if cmp == 0i64 {
                    if d0 > s0 { cmp = 1i64 }
                    if d0 < s0 { cmp = 0i64 - 1i64 }
                }
                if cmp == 0i64 {
                    r_s = 0i64
                    r0 = 0u64
                    r1 = 0u64
                    r2 = 0u64
                }
                if cmp > 0i64 {
                    /* dst - src */
                    let mut b : u64 = 0u64
                    let x0 : u64 = d0 - s0
                    if d0 < s0 { b = 1u64 }
                    let mut b1 : u64 = 0u64
                    let x1a : u64 = d1 - s1
                    if d1 < s1 { b1 = 1u64 }
                    let x1 : u64 = x1a - b
                    if x1a < b { b1 = b1 + 1u64 }
                    r0 = x0
                    r1 = x1
                    r2 = d2 - s2 - b1
                    r_s = ds
                }
                if cmp < 0i64 {
                    /* src - dst */
                    let mut b2 : u64 = 0u64
                    let y0 : u64 = s0 - d0
                    if s0 < d0 { b2 = 1u64 }
                    let mut b3 : u64 = 0u64
                    let y1a : u64 = s1 - d1
                    if s1 < d1 { b3 = 1u64 }
                    let y1 : u64 = y1a - b2
                    if y1a < b2 { b3 = b3 + 1u64 }
                    r0 = y0
                    r1 = y1
                    r2 = s2 - d2 - b3
                    r_s = ss
                }
            }
        }
    }
    if which == 0u64 { PR_LL_S = r_s   PR_LL[0] = r0   PR_LL[1] = r1   PR_LL[2] = r2 }
    if which == 1u64 { PR_LH_S = r_s   PR_LH[0] = r0   PR_LH[1] = r1   PR_LH[2] = r2 }
    if which == 2u64 { PR_RL_S = r_s   PR_RL[0] = r0   PR_RL[1] = r1   PR_RL[2] = r2 }
    if which == 3u64 { PR_RH_S = r_s   PR_RH[0] = r0   PR_RH[1] = r1   PR_RH[2] = r2 }
    return 0i32
}

/* signed compare (s_a, a[]) vs (s_b, b[]): -1/0/+1 */
fn pr_scmp(sa: i64, a0: u64, a1: u64, a2: u64, sb: i64, b0: u64, b1: u64, b2: u64) -> i64 {
    if sa > sb { return 1i64 }
    if sa < sb { return 0i64 - 1i64 }
    if sa == 0i64 { return 0i64 }
    let mut cmp : i64 = 0i64
    if a2 > b2 { cmp = 1i64 }
    if a2 < b2 { cmp = 0i64 - 1i64 }
    if cmp == 0i64 {
        if a1 > b1 { cmp = 1i64 }
        if a1 < b1 { cmp = 0i64 - 1i64 }
    }
    if cmp == 0i64 {
        if a0 > b0 { cmp = 1i64 }
        if a0 < b0 { cmp = 0i64 - 1i64 }
    }
    if sa < 0i64 { return 0i64 - cmp }
    return cmp
}

/* evaluate both mixes for weights (w1,w2): left pairs exp(d1) with w1,
 * right pairs exp(d1) with w2.  interval verdict: +1/-1 separated, 0 straddle */
fn pr_mix_verdict(w1: i64, w2: i64) -> i64 {
    PR_LL_S = 0i64
    PR_LL[0] = 0u64
    PR_LL[1] = 0u64
    PR_LL[2] = 0u64
    PR_LH_S = 0i64
    PR_LH[0] = 0u64
    PR_LH[1] = 0u64
    PR_LH[2] = 0u64
    PR_RL_S = 0i64
    PR_RL[0] = 0u64
    PR_RL[1] = 0u64
    PR_RL[2] = 0u64
    PR_RH_S = 0i64
    PR_RH[0] = 0u64
    PR_RH[1] = 0u64
    PR_RH[2] = 0u64
    /* m_left = E(d1)*w1 + E(d2)*w2 */
    pr_term(w1, PR_A_LO1, PR_A_LO0, PR_A_HI1, PR_A_HI0, 0u64)
    pr_acc(0u64)
    pr_term(w2, PR_B_LO1, PR_B_LO0, PR_B_HI1, PR_B_HI0, 0u64)
    pr_acc(0u64)
    pr_term(w1, PR_A_LO1, PR_A_LO0, PR_A_HI1, PR_A_HI0, 1u64)
    pr_acc(1u64)
    pr_term(w2, PR_B_LO1, PR_B_LO0, PR_B_HI1, PR_B_HI0, 1u64)
    pr_acc(1u64)
    /* m_right = E(d1)*w2 + E(d2)*w1 */
    pr_term(w2, PR_A_LO1, PR_A_LO0, PR_A_HI1, PR_A_HI0, 0u64)
    pr_acc(2u64)
    pr_term(w1, PR_B_LO1, PR_B_LO0, PR_B_HI1, PR_B_HI0, 0u64)
    pr_acc(2u64)
    pr_term(w2, PR_A_LO1, PR_A_LO0, PR_A_HI1, PR_A_HI0, 1u64)
    pr_acc(3u64)
    pr_term(w1, PR_B_LO1, PR_B_LO0, PR_B_HI1, PR_B_HI0, 1u64)
    pr_acc(3u64)
    /* separation */
    let above : i64 = pr_scmp(PR_LL_S, PR_LL[0], PR_LL[1], PR_LL[2], PR_RH_S, PR_RH[0], PR_RH[1], PR_RH[2])
    if above > 0i64 { return 1i64 }
    let below : i64 = pr_scmp(PR_LH_S, PR_LH[0], PR_LH[1], PR_LH[2], PR_RL_S, PR_RL[0], PR_RL[1], PR_RL[2])
    if below < 0i64 { return 0i64 - 1i64 }
    return 0i64
}

var PR_D1 : u64 = 0u64
var PR_D2 : u64 = 0u64
var PR_W1 : i64 = 0i64
var PR_W2 : i64 = 0i64

fn pr_arm368() -> u64 {
    if mb_feast() == 0u64 { return 0u64 }
    let na : u64 = mb_nva()
    let nb : u64 = mb_nvb()
    if na < 2u64 { return 368u64 }
    if nb < 2u64 { return 368u64 }
    /* real logits: first adjacent pair of distinct values within |.| <= 2^28 */
    let mut i : u64 = 0u64
    let mut found : u64 = 0u64
    let mut l1 : i64 = 0i64
    let mut l2 : i64 = 0i64
    while found == 0u64 {
        if i + 1u64 >= na { return 368u64 }
        l1 = mb_val_a(i)
        l2 = mb_val_a(i + 1u64)
        let mut m1 : u64 = l1 as u64
        if l1 < 0i64 { m1 = (0i64 - l1) as u64 }
        let mut m2 : u64 = l2 as u64
        if l2 < 0i64 { m2 = (0i64 - l2) as u64 }
        if l1 != l2 {
            if m1 <= 268435456u64 {
                if m2 <= 268435456u64 {
                    /* spread <= 16 after shift: |l1 - l2| <= 2^28 */
                    let mut df : i64 = l1 - l2
                    if df < 0i64 { df = 0i64 - df }
                    if (df as u64) <= 268435456u64 { found = 1u64 }
                }
            }
        }
        if found == 0u64 { i = i + 1u64 }
    }
    /* the shift law: subtract the smaller logit (exact on dyadics) */
    PR_D1 = 0u64
    PR_D2 = 0u64
    if l1 >= l2 { PR_D1 = (l1 - l2) as u64 }
    if l1 < l2 { PR_D2 = (l2 - l1) as u64 }
    /* real weights: first adjacent pair of distinct values */
    let mut j : u64 = 0u64
    let mut foundw : u64 = 0u64
    while foundw == 0u64 {
        if j + 1u64 >= nb { return 368u64 }
        PR_W1 = mb_val_b(j)
        PR_W2 = mb_val_b(j + 1u64)
        if PR_W1 != PR_W2 {
            let mut mw : u64 = PR_W1 as u64
            if PR_W1 < 0i64 { mw = (0i64 - PR_W1) as u64 }
            let mut mw2 : u64 = PR_W2 as u64
            if PR_W2 < 0i64 { mw2 = (0i64 - PR_W2) as u64 }
            if mw <= 1099511627776u64 {
                if mw2 <= 1099511627776u64 { foundw = 1u64 }
            }
        }
        if foundw == 0u64 { j = j + 1u64 }
    }
    /* certified exponentials of the two shifted logits */
    if pr_exp(PR_D1, 24u64) != 0i32 { return 368u64 }
    PR_A_LO0 = PR_ELO0
    PR_A_LO1 = PR_ELO1
    PR_A_HI0 = PR_EHI0
    PR_A_HI1 = PR_EHI1
    if pr_exp(PR_D2, 24u64) != 0i32 { return 368u64 }
    PR_B_LO0 = PR_ELO0
    PR_B_LO1 = PR_ELO1
    PR_B_HI0 = PR_EHI0
    PR_B_HI1 = PR_EHI1
    /* ENGINE 2 first factor: sign(E(d1) - E(d2)) certified by the intervals
     * themselves (separation demanded; d1 != d2 by construction) */
    let mut e_fac : i64 = 0i64
    if pr_cmp128(PR_A_LO1, PR_A_LO0, PR_B_HI1, PR_B_HI0) > 0i64 { e_fac = 1i64 }
    if pr_cmp128(PR_A_HI1, PR_A_HI0, PR_B_LO1, PR_B_LO0) < 0i64 { e_fac = 0i64 - 1i64 }
    if e_fac == 0i64 { return 368u64 }
    /* second factor exact */
    let mut w_fac : i64 = 0i64
    if PR_W1 > PR_W2 { w_fac = 1i64 }
    if PR_W1 < PR_W2 { w_fac = 0i64 - 1i64 }
    let factor_sign : i64 = e_fac * w_fac
    /* ENGINE 1: the interval mixes */
    let iv_sign : i64 = pr_mix_verdict(PR_W1, PR_W2)
    if iv_sign == 0i64 { return 368u64 }
    if iv_sign != factor_sign { return 368u64 }
    /* THE SYMMETRIC CONTROL: equal weights -> exactly zero difference; the
     * intervals must STRADDLE and the factor engine must speak zero */
    let ctrl : i64 = pr_mix_verdict(PR_W1, PR_W1)
    if ctrl != 0i64 { return 368u64 }
    pr_rs("the discharge: softmax mixing DECIDED on real flesh -- factor=" as u64)
    pr_ri(factor_sign)
    pr_rs(" interval=" as u64)
    pr_ri(iv_sign)
    pr_rs(" agree=ok control-refused=ok d1=" as u64)
    pr_ru(PR_D1)
    pr_rs("*2^-24 d2=" as u64)
    pr_ru(PR_D2)
    pr_rs("*2^-24" as u64)
    pr_rb(10u8)
    return 0u64
}

/* ==================== arm 369: THE SCROLL ==================== */

fn pr_arm369() -> u64 {
    eol_reset()
    let doc : u64 = "[softmax mixing = certified interval decision] [certified interval decision < exact decision] [exp value = bounded transcendental] [bounded transcendental < certified interval decision]" as u64
    let dl : u64 = pr_slen(doc)
    if eol_read(doc, dl) < 0i64 { return 369u64 }
    if eol_lawcheck() != 0u64 { return 369u64 }
    let a1 : u64 = eol_addr()
    if a1 == 0u64 { return 369u64 }
    /* DERIVED (absent from the text): the mixing sits under exact decision */
    let sm : u64 = "softmax mixing" as u64
    let xd : u64 = "exact decision" as u64
    if eol_entails(sm, pr_slen(sm), 0u64, xd, pr_slen(xd)) != 1u64 { return 369u64 }
    /* the reversal REFUSES */
    if eol_entails(xd, pr_slen(xd), 0u64, sm, pr_slen(sm)) != 0u64 { return 369u64 }
    /* and the exp value reaches exact decision only THROUGH the interval:
     * the chain [exp value -> bounded transcendental -> certified interval
     * decision -> exact decision] must entail */
    let ev : u64 = "exp value" as u64
    if eol_entails(ev, pr_slen(ev), 0u64, xd, pr_slen(xd)) != 1u64 { return 369u64 }
    eol_reset()
    if eol_read(doc, dl) < 0i64 { return 369u64 }
    if eol_addr() != a1 { return 369u64 }
    PR_SCROLL = a1
    return 0u64
}

/* ============ arm 377: THE TROPOS (the turn -- RoPE beyond zero) ============ */

/* sin/cos as certified intervals by the same directed-chain discipline:
 * Taylor at y <= 1/2 (alternating series: the truncation is bounded by the
 * first omitted term, its sign known), then the double-angle ladder -- and
 * cos(2y) computed by BOTH forms (1-2s^2 and 2c^2-1), whose intervals must
 * OVERLAP: two engines in one identity.  Pythagoras s^2+c^2 must CONTAIN
 * exactly 1.  The ln2 ladder (2 atanh(1/3), positive series, geometric
 * tail) closes the loop through the exponential: exp(ln2) must CONTAIN
 * exactly 2 -- two ladders, one theorem.  Then the TURN on real flesh:
 * a real dyadic pair rotated by the certified angle 1 (the j=0 RoPE lane,
 * where the frequency is exactly 1), the rotation INVARIANT (the exact
 * norm sits inside the rotated-norm interval), and the first certified
 * cross-position rope score contribution.  The omega_j ladders (j>0 need
 * exp/ln of irrational frequencies) are NAMED as the next stairs. */

var PR_SN0 : u64 = 0u64
var PR_SN1 : u64 = 0u64
var PR_SX0 : u64 = 0u64
var PR_SX1 : u64 = 0u64
var PR_CN0 : u64 = 0u64
var PR_CN1 : u64 = 0u64
var PR_CX0 : u64 = 0u64
var PR_CX1 : u64 = 0u64

/* sin,cos of y = m*2^-s (0 < y <= 1/2) into PR_S*/
fn pr_sincos(m_in: u64, s_in: u64) -> i32 {
    PR_FAIL = 0u8
    /* term chains at 2^-88: sin t0 = y, cos u0 = 1 */
    let mut stl_h : u64 = 0u64
    let mut stl_l : u64 = 0u64
    let mut sth_h : u64 = 0u64
    let mut sth_l : u64 = 0u64
    /* y at 2^-88: m << (88 - s) */
    let ysh : u64 = 88u64 - s_in
    if ysh >= 64u64 {
        stl_h = m_in << (ysh - 64u64)
        sth_h = stl_h
    }
    if ysh < 64u64 {
        stl_l = m_in << ysh
        stl_h = m_in >> (64u64 - ysh)
        sth_l = stl_l
        sth_h = stl_h
    }
    let mut utl_h : u64 = 1u64 << 24u64
    let mut utl_l : u64 = 0u64
    let mut uth_h : u64 = utl_h
    let mut uth_l : u64 = 0u64
    let mut sl_h : u64 = stl_h
    let mut sl_l : u64 = stl_l
    let mut sh_h : u64 = sth_h
    let mut sh_l : u64 = sth_l
    let mut cl_h : u64 = utl_h
    let mut cl_l : u64 = 0u64
    let mut ch_h : u64 = uth_h
    let mut ch_l : u64 = 0u64
    let mut k : u64 = 1u64
    let mut sign_neg : u64 = 1u64     /* next term is subtracted when 1 */
    while k <= 8u64 {
        /* t *= y^2 / ((2k)(2k+1)); u *= y^2 / ((2k-1)(2k)) */
        let mut pass : u64 = 0u64
        while pass < 4u64 {
            let mut hh : u64 = stl_h
            let mut ll : u64 = stl_l
            if pass == 1u64 { hh = sth_h   ll = sth_l }
            if pass == 2u64 { hh = utl_h   ll = utl_l }
            if pass == 3u64 { hh = uth_h   ll = uth_l }
            let mut ceilm : u64 = 0u64
            if pass == 1u64 { ceilm = 1u64 }
            if pass == 3u64 { ceilm = 1u64 }
            /* two multiplies by m with shift s, one divide */
            let mut rep : u64 = 0u64
            while rep < 2u64 {
                pr_mul128by64(hh, ll, m_in)
                if pr_zshr(s_in) != 0i32 { return 1i32 }
                hh = PR_MHI
                ll = PR_MLO
                if ceilm == 1u64 {
                    if PR_STK != 0u64 {
                        ll = ll + 1u64
                        if ll == 0u64 { hh = hh + 1u64 }
                    }
                }
                rep = rep + 1u64
            }
            let mut dv : u64 = (2u64 * k) * (2u64 * k + 1u64)
            if pass >= 2u64 { dv = (2u64 * k - 1u64) * (2u64 * k) }
            pr_div_small(hh, ll, dv)
            hh = PR_MHI
            ll = PR_MLO
            if ceilm == 1u64 {
                if PR_STK != 0u64 {
                    ll = ll + 1u64
                    if ll == 0u64 { hh = hh + 1u64 }
                }
            }
            if pass == 0u64 { stl_h = hh   stl_l = ll }
            if pass == 1u64 { sth_h = hh   sth_l = ll }
            if pass == 2u64 { utl_h = hh   utl_l = ll }
            if pass == 3u64 { uth_h = hh   uth_l = ll }
            pass = pass + 1u64
        }
        /* fold the term with alternating sign, directed */
        if sign_neg == 1u64 {
            /* lo -= t_hi ; hi -= t_lo */
            let mut b : u64 = 0u64
            let d0 : u64 = sl_l - sth_l
            if sl_l < sth_l { b = 1u64 }
            sl_l = d0
            sl_h = sl_h - sth_h - b
            b = 0u64
            let d1 : u64 = sh_l - stl_l
            if sh_l < stl_l { b = 1u64 }
            sh_l = d1
            sh_h = sh_h - stl_h - b
            b = 0u64
            let d2 : u64 = cl_l - uth_l
            if cl_l < uth_l { b = 1u64 }
            cl_l = d2
            cl_h = cl_h - uth_h - b
            b = 0u64
            let d3 : u64 = ch_l - utl_l
            if ch_l < utl_l { b = 1u64 }
            ch_l = d3
            ch_h = ch_h - utl_h - b
        }
        if sign_neg == 0u64 {
            let a0 : u64 = sl_l + stl_l
            if a0 < stl_l { sl_h = sl_h + 1u64 }
            sl_l = a0
            sl_h = sl_h + stl_h
            let a1 : u64 = sh_l + sth_l
            if a1 < sth_l { sh_h = sh_h + 1u64 }
            sh_l = a1
            sh_h = sh_h + sth_h
            let a2 : u64 = cl_l + utl_l
            if a2 < utl_l { cl_h = cl_h + 1u64 }
            cl_l = a2
            cl_h = cl_h + utl_h
            let a3 : u64 = ch_l + uth_l
            if a3 < uth_l { ch_h = ch_h + 1u64 }
            ch_l = a3
            ch_h = ch_h + uth_h
        }
        sign_neg = 1u64 - sign_neg
        k = k + 1u64
    }
    /* the alternating tail: if the NEXT term would be added, hi grows by
     * one more (already-computed) term bound; if subtracted, lo shrinks --
     * cover both directions with the standing term chains */
    let a4 : u64 = sh_l + sth_l
    if a4 < sth_l { sh_h = sh_h + 1u64 }
    sh_l = a4
    sh_h = sh_h + sth_h
    let mut b4 : u64 = 0u64
    let d4 : u64 = sl_l - sth_l
    if sl_l < sth_l { b4 = 1u64 }
    sl_l = d4
    sl_h = sl_h - sth_h - b4
    let a5 : u64 = ch_l + uth_l
    if a5 < uth_l { ch_h = ch_h + 1u64 }
    ch_l = a5
    ch_h = ch_h + uth_h
    b4 = 0u64
    let d5 : u64 = cl_l - uth_l
    if cl_l < uth_l { b4 = 1u64 }
    cl_l = d5
    cl_h = cl_h - uth_h - b4
    PR_SN0 = sl_l
    PR_SN1 = sl_h
    PR_SX0 = sh_l
    PR_SX1 = sh_h
    PR_CN0 = cl_l
    PR_CN1 = cl_h
    PR_CX0 = ch_l
    PR_CX1 = ch_h
    return 0i32
}

/* signed (sign, hi, lo) 128-bit helpers for the rotation */
var PR_P_S : i64 = 0i64
var PR_P_H : u64 = 0u64
var PR_P_L : u64 = 0u64
fn pr_sadd128(s1: i64, h1: u64, l1: u64, s2: i64, h2: u64, l2: u64) -> i32 {
    if s1 == 0i64 {
        PR_P_S = s2
        PR_P_H = h2
        PR_P_L = l2
        return 0i32
    }
    if s2 == 0i64 {
        PR_P_S = s1
        PR_P_H = h1
        PR_P_L = l1
        return 0i32
    }
    if s1 == s2 {
        let l : u64 = l1 + l2
        let mut c : u64 = 0u64
        if l < l2 { c = 1u64 }
        PR_P_S = s1
        PR_P_L = l
        PR_P_H = h1 + h2 + c
        return 0i32
    }
    let cm : i64 = pr_cmp128(h1, l1, h2, l2)
    if cm == 0i64 {
        PR_P_S = 0i64
        PR_P_H = 0u64
        PR_P_L = 0u64
        return 0i32
    }
    if cm > 0i64 {
        let mut b : u64 = 0u64
        let l3 : u64 = l1 - l2
        if l1 < l2 { b = 1u64 }
        PR_P_S = s1
        PR_P_L = l3
        PR_P_H = h1 - h2 - b
        return 0i32
    }
    let mut b2 : u64 = 0u64
    let l4 : u64 = l2 - l1
    if l2 < l1 { b2 = 1u64 }
    PR_P_S = s2
    PR_P_L = l4
    PR_P_H = h2 - h1 - b2
    return 0i32
}

/* the certified turn state (hoisted: the slot ceiling is law) */
var PR_S1L0 : u64 = 0u64
var PR_S1L1 : u64 = 0u64
var PR_S1H0 : u64 = 0u64
var PR_S1H1 : u64 = 0u64
var PR_C1L0 : u64 = 0u64
var PR_C1L1 : u64 = 0u64
var PR_C1H0 : u64 = 0u64
var PR_C1H1 : u64 = 0u64
var PR_ARLS : i64 = 0i64
var PR_ARLH : u64 = 0u64
var PR_ARLL : u64 = 0u64
var PR_ARHS : i64 = 0i64
var PR_ARHH : u64 = 0u64
var PR_ARHL : u64 = 0u64
var PR_BRLS : i64 = 0i64
var PR_BRLH : u64 = 0u64
var PR_BRLL : u64 = 0u64
var PR_BRHS : i64 = 0i64
var PR_BRHH : u64 = 0u64
var PR_BRHL : u64 = 0u64
var PR_AV : i64 = 0i64
var PR_BV : i64 = 0i64
var PR_K0 : i64 = 0i64
var PR_K1 : i64 = 0i64
var PR_N4A : u64 = 0u64
var PR_N4B : u64 = 0u64
var PR_N4C : u64 = 0u64
var PR_N4D : u64 = 0u64

/* signed bound of x * interval: use_c 1 -> cos1, 0 -> sin1; side 0 lo, 1 hi */
fn pr_sxi(x: i64, use_c: u64, side: u64) -> i32 {
    if x == 0i64 {
        PR_P_S = 0i64
        PR_P_H = 0u64
        PR_P_L = 0u64
        return 0i32
    }
    let mut xm : u64 = x as u64
    if x < 0i64 { xm = (0i64 - x) as u64 }
    let mut want_hi : u64 = side
    if x < 0i64 { want_hi = 1u64 - side }
    let mut ih : u64 = PR_S1L1
    let mut il : u64 = PR_S1L0
    if use_c == 0u64 {
        if want_hi == 1u64 { ih = PR_S1H1   il = PR_S1H0 }
    }
    if use_c == 1u64 {
        ih = PR_C1L1
        il = PR_C1L0
        if want_hi == 1u64 { ih = PR_C1H1   il = PR_C1H0 }
    }
    pr_mul128by64(ih, il, xm)
    PR_P_S = 1i64
    if x < 0i64 { PR_P_S = 0i64 - 1i64 }
    PR_P_H = PR_Z[1]
    PR_P_L = PR_Z[0]
    return 0i32
}

/* the doubling to theta=1 with the two-form cos teeth + pythagoras */
fn pr_trop_angle() -> u64 {
    if pr_sincos(1u64 << 23u64, 24u64) != 0i32 { return 1u64 }
    let s5l0 : u64 = PR_SN0
    let s5l1 : u64 = PR_SN1
    let s5h0 : u64 = PR_SX0
    let s5h1 : u64 = PR_SX1
    let c5l0 : u64 = PR_CN0
    let c5l1 : u64 = PR_CN1
    let c5h0 : u64 = PR_CX0
    let c5h1 : u64 = PR_CX1
    pr_mul128(s5l1, s5l0, c5l1, c5l0)
    if pr_wshr88() != 0i32 { return 1u64 }
    PR_S1L0 = PR_MLO << 1u64
    PR_S1L1 = (PR_MHI << 1u64) | (PR_MLO >> 63u64)
    pr_mul128(s5h1, s5h0, c5h1, c5h0)
    if pr_wshr88() != 0i32 { return 1u64 }
    if PR_STK != 0u64 { pr_inc128() }
    PR_S1H0 = PR_MLO << 1u64
    PR_S1H1 = (PR_MHI << 1u64) | (PR_MLO >> 63u64)
    let one1 : u64 = 1u64 << 24u64
    pr_mul128(s5h1, s5h0, s5h1, s5h0)
    if pr_wshr88() != 0i32 { return 1u64 }
    if PR_STK != 0u64 { pr_inc128() }
    let t2h0 : u64 = PR_MLO << 1u64
    let t2h1 : u64 = (PR_MHI << 1u64) | (PR_MLO >> 63u64)
    let mut ba : u64 = 0u64
    let al0 : u64 = 0u64 - t2h0
    if 0u64 < t2h0 { ba = 1u64 }
    let al1 : u64 = one1 - t2h1 - ba
    pr_mul128(s5l1, s5l0, s5l1, s5l0)
    if pr_wshr88() != 0i32 { return 1u64 }
    let t2l0 : u64 = PR_MLO << 1u64
    let t2l1 : u64 = (PR_MHI << 1u64) | (PR_MLO >> 63u64)
    ba = 0u64
    let ah0 : u64 = 0u64 - t2l0
    if 0u64 < t2l0 { ba = 1u64 }
    let ah1 : u64 = one1 - t2l1 - ba
    pr_mul128(c5l1, c5l0, c5l1, c5l0)
    if pr_wshr88() != 0i32 { return 1u64 }
    let u2l0 : u64 = PR_MLO << 1u64
    let u2l1 : u64 = (PR_MHI << 1u64) | (PR_MLO >> 63u64)
    if u2l1 < one1 { return 1u64 }
    let bl0 : u64 = u2l0
    let bl1 : u64 = u2l1 - one1
    pr_mul128(c5h1, c5h0, c5h1, c5h0)
    if pr_wshr88() != 0i32 { return 1u64 }
    if PR_STK != 0u64 { pr_inc128() }
    let bh0 : u64 = PR_MLO << 1u64
    let bh1 : u64 = ((PR_MHI << 1u64) | (PR_MLO >> 63u64)) - one1
    if pr_cmp128(ah1, ah0, bl1, bl0) < 0i64 { return 1u64 }
    if pr_cmp128(bh1, bh0, al1, al0) < 0i64 { return 1u64 }
    PR_C1L0 = al0
    PR_C1L1 = al1
    if pr_cmp128(bl1, bl0, al1, al0) > 0i64 {
        PR_C1L0 = bl0
        PR_C1L1 = bl1
    }
    PR_C1H0 = ah0
    PR_C1H1 = ah1
    if pr_cmp128(bh1, bh0, ah1, ah0) < 0i64 {
        PR_C1H0 = bh0
        PR_C1H1 = bh1
    }
    pr_mul128(PR_S1L1, PR_S1L0, PR_S1L1, PR_S1L0)
    if pr_wshr88() != 0i32 { return 1u64 }
    let q0 : u64 = PR_MLO
    let q1 : u64 = PR_MHI
    pr_mul128(PR_C1L1, PR_C1L0, PR_C1L1, PR_C1L0)
    if pr_wshr88() != 0i32 { return 1u64 }
    let mut pl0 : u64 = q0 + PR_MLO
    let mut pl1 : u64 = q1 + PR_MHI
    if pl0 < PR_MLO { pl1 = pl1 + 1u64 }
    pr_mul128(PR_S1H1, PR_S1H0, PR_S1H1, PR_S1H0)
    if pr_wshr88() != 0i32 { return 1u64 }
    if PR_STK != 0u64 { pr_inc128() }
    let q2 : u64 = PR_MLO
    let q3 : u64 = PR_MHI
    pr_mul128(PR_C1H1, PR_C1H0, PR_C1H1, PR_C1H0)
    if pr_wshr88() != 0i32 { return 1u64 }
    if PR_STK != 0u64 { pr_inc128() }
    let mut ph0 : u64 = q2 + PR_MLO
    let mut ph1 : u64 = q3 + PR_MHI
    if ph0 < PR_MLO { ph1 = ph1 + 1u64 }
    if pr_cmp128(pl1, pl0, one1, 0u64) > 0i64 { return 1u64 }
    if pr_cmp128(ph1, ph0, one1, 0u64) < 0i64 { return 1u64 }
    return 0u64
}

/* ln2 by atanh(1/3) and the exp round trip through 2 */
fn pr_trop_ln2() -> u64 {
    pr_div_small(1u64 << 24u64, 0u64, 3u64)
    let mut p_l0 : u64 = PR_MLO
    let mut p_l1 : u64 = PR_MHI
    let mut p_h0 : u64 = PR_MLO
    let mut p_h1 : u64 = PR_MHI
    if PR_STK != 0u64 {
        p_h0 = p_h0 + 1u64
        if p_h0 == 0u64 { p_h1 = p_h1 + 1u64 }
    }
    let mut ln_l0 : u64 = 0u64
    let mut ln_l1 : u64 = 0u64
    let mut ln_h0 : u64 = 0u64
    let mut ln_h1 : u64 = 0u64
    let mut kk : u64 = 0u64
    while kk < 28u64 {
        pr_div_small(p_l1, p_l0, 2u64 * kk + 1u64)
        let a6 : u64 = ln_l0 + PR_MLO
        if a6 < PR_MLO { ln_l1 = ln_l1 + 1u64 }
        ln_l0 = a6
        ln_l1 = ln_l1 + PR_MHI
        pr_div_small(p_h1, p_h0, 2u64 * kk + 1u64)
        let mut th0 : u64 = PR_MLO
        let mut th1 : u64 = PR_MHI
        if PR_STK != 0u64 {
            th0 = th0 + 1u64
            if th0 == 0u64 { th1 = th1 + 1u64 }
        }
        let a7 : u64 = ln_h0 + th0
        if a7 < th0 { ln_h1 = ln_h1 + 1u64 }
        ln_h0 = a7
        ln_h1 = ln_h1 + th1
        pr_div_small(p_l1, p_l0, 9u64)
        p_l0 = PR_MLO
        p_l1 = PR_MHI
        pr_div_small(p_h1, p_h0, 9u64)
        p_h0 = PR_MLO
        p_h1 = PR_MHI
        if PR_STK != 0u64 {
            p_h0 = p_h0 + 1u64
            if p_h0 == 0u64 { p_h1 = p_h1 + 1u64 }
        }
        kk = kk + 1u64
    }
    let a8 : u64 = ln_h0 + p_h0
    if a8 < p_h0 { ln_h1 = ln_h1 + 1u64 }
    ln_h0 = a8
    ln_h1 = ln_h1 + p_h1
    ln_l1 = (ln_l1 << 1u64) | (ln_l0 >> 63u64)
    ln_l0 = ln_l0 << 1u64
    ln_h1 = (ln_h1 << 1u64) | (ln_h0 >> 63u64)
    ln_h0 = ln_h0 << 1u64
    let mlo : u64 = (ln_l0 >> 40u64) | (ln_l1 << 24u64)
    let mhi : u64 = ((ln_h0 >> 40u64) | (ln_h1 << 24u64)) + 1u64
    if pr_exp(mlo, 48u64) != 0i32 { return 1u64 }
    let ex_l1 : u64 = PR_ELO1
    let ex_l0 : u64 = PR_ELO0
    if pr_exp(mhi, 48u64) != 0i32 { return 1u64 }
    let two1 : u64 = 1u64 << 25u64
    if pr_cmp128(ex_l1, ex_l0, two1, 0u64) > 0i64 { return 1u64 }
    if pr_cmp128(PR_EHI1, PR_EHI0, two1, 0u64) < 0i64 { return 1u64 }
    return 0u64
}

/* the rotated pair on real flesh: 0 ok, 1 fasting (magnitudes) */
fn pr_trop_rot() -> u64 {
    PR_AV = mb_val_a(0u64)
    PR_BV = mb_val_a(1u64)
    PR_K0 = mb_val_b(0u64)
    PR_K1 = mb_val_b(1u64)
    let mut t9 : u64 = 0u64
    while t9 < 4u64 {
        let mut vv : i64 = PR_AV
        if t9 == 1u64 { vv = PR_BV }
        if t9 == 2u64 { vv = PR_K0 }
        if t9 == 3u64 { vv = PR_K1 }
        let mut mg : u64 = vv as u64
        if vv < 0i64 { mg = (0i64 - vv) as u64 }
        if mg >= 1099511627776u64 { return 1u64 }
        t9 = t9 + 1u64
    }
    pr_sxi(PR_AV, 1u64, 0u64)
    let t_s : i64 = PR_P_S
    let t_h : u64 = PR_P_H
    let t_l : u64 = PR_P_L
    pr_sxi(PR_BV, 0u64, 1u64)
    pr_sadd128(t_s, t_h, t_l, 0i64 - PR_P_S, PR_P_H, PR_P_L)
    PR_ARLS = PR_P_S
    PR_ARLH = PR_P_H
    PR_ARLL = PR_P_L
    pr_sxi(PR_AV, 1u64, 1u64)
    let t2_s : i64 = PR_P_S
    let t2_h : u64 = PR_P_H
    let t2_l : u64 = PR_P_L
    pr_sxi(PR_BV, 0u64, 0u64)
    pr_sadd128(t2_s, t2_h, t2_l, 0i64 - PR_P_S, PR_P_H, PR_P_L)
    PR_ARHS = PR_P_S
    PR_ARHH = PR_P_H
    PR_ARHL = PR_P_L
    pr_sxi(PR_AV, 0u64, 0u64)
    let t3_s : i64 = PR_P_S
    let t3_h : u64 = PR_P_H
    let t3_l : u64 = PR_P_L
    pr_sxi(PR_BV, 1u64, 0u64)
    pr_sadd128(t3_s, t3_h, t3_l, PR_P_S, PR_P_H, PR_P_L)
    PR_BRLS = PR_P_S
    PR_BRLH = PR_P_H
    PR_BRLL = PR_P_L
    pr_sxi(PR_AV, 0u64, 1u64)
    let t4_s : i64 = PR_P_S
    let t4_h : u64 = PR_P_H
    let t4_l : u64 = PR_P_L
    pr_sxi(PR_BV, 1u64, 1u64)
    pr_sadd128(t4_s, t4_h, t4_l, PR_P_S, PR_P_H, PR_P_L)
    PR_BRHS = PR_P_S
    PR_BRHH = PR_P_H
    PR_BRHL = PR_P_L
    return 0u64
}

/* the rotation invariant: exact norm inside the rotated-norm interval */
fn pr_trop_inv() -> u64 {
    let mut pass2 : u64 = 0u64
    PR_N4A = 0u64
    PR_N4B = 0u64
    PR_N4C = 0u64
    PR_N4D = 0u64
    while pass2 < 2u64 {
        let mut lo_s : i64 = PR_ARLS
        let mut lo_h : u64 = PR_ARLH
        let mut lo_l : u64 = PR_ARLL
        let mut hi_s : i64 = PR_ARHS
        let mut hi_h : u64 = PR_ARHH
        let mut hi_l : u64 = PR_ARHL
        if pass2 == 1u64 {
            lo_s = PR_BRLS
            lo_h = PR_BRLH
            lo_l = PR_BRLL
            hi_s = PR_BRHS
            hi_h = PR_BRHH
            hi_l = PR_BRHL
        }
        let mut ql_h : u64 = 0u64
        let mut ql_l : u64 = 0u64
        if lo_s > 0i64 {
            ql_h = lo_h
            ql_l = lo_l
        }
        if hi_s < 0i64 {
            ql_h = hi_h
            ql_l = hi_l
        }
        pr_mul128(ql_h, ql_l, ql_h, ql_l)
        let z0 : u64 = PR_N4A + PR_W[0]
        let mut cz : u64 = 0u64
        if z0 < PR_W[0] { cz = 1u64 }
        PR_N4A = z0
        let z1 : u64 = PR_N4B + PR_W[1] + cz
        cz = 0u64
        if z1 < PR_W[1] { cz = 1u64 }
        PR_N4B = z1
        let z2 : u64 = PR_N4C + PR_W[2] + cz
        cz = 0u64
        if z2 < PR_W[2] { cz = 1u64 }
        PR_N4C = z2
        PR_N4D = PR_N4D + PR_W[3] + cz
        pass2 = pass2 + 1u64
    }
    let an2 : u64 = ((PR_AV * PR_AV) as u64) + ((PR_BV * PR_BV) as u64)
    let e2 : u64 = an2 << 48u64
    let e3 : u64 = an2 >> 16u64
    if PR_N4D > e3 { return 1u64 }
    if PR_N4D == e3 {
        if PR_N4C > e2 { return 1u64 }
        if PR_N4C == e2 {
            if (PR_N4B | PR_N4A) != 0u64 { return 1u64 }
        }
    }
    pass2 = 0u64
    PR_N4A = 0u64
    PR_N4B = 0u64
    PR_N4C = 0u64
    PR_N4D = 0u64
    while pass2 < 2u64 {
        let mut lo_h2 : u64 = PR_ARLH
        let mut lo_l2 : u64 = PR_ARLL
        let mut hi_h2 : u64 = PR_ARHH
        let mut hi_l2 : u64 = PR_ARHL
        if pass2 == 1u64 {
            lo_h2 = PR_BRLH
            lo_l2 = PR_BRLL
            hi_h2 = PR_BRHH
            hi_l2 = PR_BRHL
        }
        let mut qh_h : u64 = hi_h2
        let mut qh_l : u64 = hi_l2
        if pr_cmp128(lo_h2, lo_l2, hi_h2, hi_l2) > 0i64 {
            qh_h = lo_h2
            qh_l = lo_l2
        }
        pr_mul128(qh_h, qh_l, qh_h, qh_l)
        let z0b : u64 = PR_N4A + PR_W[0]
        let mut czb : u64 = 0u64
        if z0b < PR_W[0] { czb = 1u64 }
        PR_N4A = z0b
        let z1b : u64 = PR_N4B + PR_W[1] + czb
        czb = 0u64
        if z1b < PR_W[1] { czb = 1u64 }
        PR_N4B = z1b
        let z2b : u64 = PR_N4C + PR_W[2] + czb
        czb = 0u64
        if z2b < PR_W[2] { czb = 1u64 }
        PR_N4C = z2b
        PR_N4D = PR_N4D + PR_W[3] + czb
        pass2 = pass2 + 1u64
    }
    let sl2 : u64 = PR_N4A + 2u64
    if sl2 < 2u64 {
        PR_N4B = PR_N4B + 1u64
        if PR_N4B == 0u64 {
            PR_N4C = PR_N4C + 1u64
            if PR_N4C == 0u64 { PR_N4D = PR_N4D + 1u64 }
        }
    }
    PR_N4A = sl2
    if PR_N4D < e3 { return 1u64 }
    if PR_N4D == e3 {
        if PR_N4C < e2 { return 1u64 }
    }
    return 0u64
}

/* one directed bound of the cross-position score (side 0 lo, 1 hi) */
fn pr_trop_cross(side: u64) -> i64 {
    let mut t_s : i64 = 0i64
    let mut t_h : u64 = 0u64
    let mut t_l : u64 = 0u64
    if PR_K0 != 0i64 {
        let mut want_hi : u64 = side
        if PR_K0 < 0i64 { want_hi = 1u64 - side }
        let mut us : i64 = PR_ARLS
        let mut uh : u64 = (PR_ARLL >> 48u64) | (PR_ARLH << 16u64)
        let mut ut : u64 = PR_ARLH >> 48u64
        if want_hi == 1u64 {
            us = PR_ARHS
            uh = ((PR_ARHL >> 48u64) | (PR_ARHH << 16u64)) + 1u64
            ut = PR_ARHH >> 48u64
        }
        let mut km : u64 = PR_K0 as u64
        if PR_K0 < 0i64 { km = (0i64 - PR_K0) as u64 }
        pr_mul128by64(ut, uh, km)
        t_s = us
        if PR_K0 < 0i64 { t_s = 0i64 - t_s }
        t_h = PR_Z[1]
        t_l = PR_Z[0]
    }
    let mut u_s : i64 = 0i64
    let mut u_h : u64 = 0u64
    let mut u_l : u64 = 0u64
    if PR_K1 != 0i64 {
        let mut want_hi2 : u64 = side
        if PR_K1 < 0i64 { want_hi2 = 1u64 - side }
        let mut vs : i64 = PR_BRLS
        let mut vh : u64 = (PR_BRLL >> 48u64) | (PR_BRLH << 16u64)
        let mut vt : u64 = PR_BRLH >> 48u64
        if want_hi2 == 1u64 {
            vs = PR_BRHS
            vh = ((PR_BRHL >> 48u64) | (PR_BRHH << 16u64)) + 1u64
            vt = PR_BRHH >> 48u64
        }
        let mut km2 : u64 = PR_K1 as u64
        if PR_K1 < 0i64 { km2 = (0i64 - PR_K1) as u64 }
        pr_mul128by64(vt, vh, km2)
        u_s = vs
        if PR_K1 < 0i64 { u_s = 0i64 - u_s }
        u_h = PR_Z[1]
        u_l = PR_Z[0]
    }
    pr_sadd128(t_s, t_h, t_l, u_s, u_h, u_l)
    return PR_P_S
}

fn pr_arm377() -> u64 {
    if pr_trop_angle() != 0u64 { return 377u64 }
    if pr_trop_ln2() != 0u64 { return 377u64 }
    let mut rotted : u64 = 0u64
    let mut verdict : i64 = 0i64
    if mb_feast() != 0u64 {
        let rr : u64 = pr_trop_rot()
        if rr == 0u64 {
            if pr_trop_inv() != 0u64 { return 377u64 }
            let lo_s : i64 = pr_trop_cross(0u64)
            let hi_s : i64 = pr_trop_cross(1u64)
            if lo_s > 0i64 { verdict = 1i64 }
            if hi_s < 0i64 { verdict = 0i64 - 1i64 }
            rotted = 1u64
        }
    }
    if rotted == 1u64 {
        pr_rs("the tropos: sin/cos(1) two-form-overlap=ok pythagoras=contained ln2-round-trip: exp(ln2) contains 2 =ok rotation-invariant=contained cross-pos-sign=" as u64)
        if verdict != 0i64 { pr_ri(verdict) }
        if verdict == 0i64 { pr_rs("straddle(refused)" as u64) }
        pr_rs(" omega-ladders=named" as u64)
        pr_rb(10u8)
    }
    if rotted == 0u64 {
        pr_rs("the tropos: sin/cos(1) two-form-overlap=ok pythagoras=contained ln2-round-trip: exp(ln2) contains 2 =ok rotation=fasting omega-ladders=named" as u64)
        pr_rb(10u8)
    }
    return 0u64
}

/* ============ arm 378: THE OMEGA (the irrational frequency, bounded) ==== */

/* omega_1 = 10000^(-1/32) = exp(-ln(10000)/32): the first irrational RoPE
 * frequency, certified.  ln10000 = 12 ln2 + 4 ln(5/4) by two atanh series;
 * exp of the scaled argument; the reciprocal by binary long division; and
 * THE POWER ROUND TRIP as teeth: [omega]^32 * 10000 must CONTAIN exactly 1
 * (five interval squarings versus the integer 10000 -- no float anywhere).
 * Then sin/cos at theta = omega_1 (position 1, lane j=1): the interval
 * argument rides the monotone ladder (endpoints outward), one doubling by
 * both forms, Pythagoras again.  With omega_j certified, ANY position and
 * ANY lane is the same ladder run again: the bridge to full-sequence
 * exact attention stands. */

var PR_OML0 : u64 = 0u64
var PR_OML1 : u64 = 0u64
var PR_OMH0 : u64 = 0u64
var PR_OMH1 : u64 = 0u64

/* floor(2^176 / (xh:xl)) for a 2-limb x with 2^87 < x < 2^90 (so the
 * quotient fits 2 limbs); binary long division, remainder in 3 limbs */
var PR_RQ0 : u64 = 0u64
var PR_RQ1 : u64 = 0u64
fn pr_recip176(xh: u64, xl: u64) -> i32 {
    PR_RQ0 = 0u64
    PR_RQ1 = 0u64
    let mut r0 : u64 = 0u64
    let mut r1 : u64 = 0u64
    let mut r2 : u64 = 0u64
    let mut bit : u64 = 177u64
    while bit != 0u64 {
        bit = bit - 1u64
        /* remainder <<= 1, bring in bit of 2^176 (only bit 176 is set) */
        r2 = (r2 << 1u64) | (r1 >> 63u64)
        r1 = (r1 << 1u64) | (r0 >> 63u64)
        r0 = r0 << 1u64
        if bit == 176u64 { r0 = r0 | 1u64 }
        /* if remainder >= x: subtract, set quotient bit */
        let mut ge : u64 = 0u64
        if r2 != 0u64 { ge = 1u64 }
        if r2 == 0u64 {
            if r1 > xh { ge = 1u64 }
            if r1 == xh {
                if r0 >= xl { ge = 1u64 }
            }
        }
        if ge == 1u64 {
            let mut b : u64 = 0u64
            let n0 : u64 = r0 - xl
            if r0 < xl { b = 1u64 }
            let mut b2 : u64 = 0u64
            let n1a : u64 = r1 - xh
            if r1 < xh { b2 = 1u64 }
            let n1 : u64 = n1a - b
            if n1a < b { b2 = b2 + 1u64 }
            r0 = n0
            r1 = n1
            r2 = r2 - b2
            if bit < 64u64 { PR_RQ0 = PR_RQ0 | (1u64 << bit) }
            if bit >= 64u64 {
                if bit < 128u64 { PR_RQ1 = PR_RQ1 | (1u64 << (bit - 64u64)) }
            }
        }
    }
    return 0i32
}

/* 2*atanh(1/inv) as a certified interval (directed chains, tail <= p) */
var PR_LNL0 : u64 = 0u64
var PR_LNL1 : u64 = 0u64
var PR_LNH0 : u64 = 0u64
var PR_LNH1 : u64 = 0u64
fn pr_atanh_ser(inv: u64) -> i32 {
    pr_div_small(1u64 << 24u64, 0u64, inv)
    let mut p_l0 : u64 = PR_MLO
    let mut p_l1 : u64 = PR_MHI
    let mut p_h0 : u64 = PR_MLO
    let mut p_h1 : u64 = PR_MHI
    if PR_STK != 0u64 {
        p_h0 = p_h0 + 1u64
        if p_h0 == 0u64 { p_h1 = p_h1 + 1u64 }
    }
    let sq : u64 = inv * inv
    let mut l0 : u64 = 0u64
    let mut l1 : u64 = 0u64
    let mut h0 : u64 = 0u64
    let mut h1 : u64 = 0u64
    let mut kk : u64 = 0u64
    while kk < 28u64 {
        pr_div_small(p_l1, p_l0, 2u64 * kk + 1u64)
        let a6 : u64 = l0 + PR_MLO
        if a6 < PR_MLO { l1 = l1 + 1u64 }
        l0 = a6
        l1 = l1 + PR_MHI
        pr_div_small(p_h1, p_h0, 2u64 * kk + 1u64)
        let mut th0 : u64 = PR_MLO
        let mut th1 : u64 = PR_MHI
        if PR_STK != 0u64 {
            th0 = th0 + 1u64
            if th0 == 0u64 { th1 = th1 + 1u64 }
        }
        let a7 : u64 = h0 + th0
        if a7 < th0 { h1 = h1 + 1u64 }
        h0 = a7
        h1 = h1 + th1
        pr_div_small(p_l1, p_l0, sq)
        p_l0 = PR_MLO
        p_l1 = PR_MHI
        pr_div_small(p_h1, p_h0, sq)
        p_h0 = PR_MLO
        p_h1 = PR_MHI
        if PR_STK != 0u64 {
            p_h0 = p_h0 + 1u64
            if p_h0 == 0u64 { p_h1 = p_h1 + 1u64 }
        }
        kk = kk + 1u64
    }
    let a8 : u64 = h0 + p_h0
    if a8 < p_h0 { h1 = h1 + 1u64 }
    h0 = a8
    h1 = h1 + p_h1
    PR_LNL1 = (l1 << 1u64) | (l0 >> 63u64)
    PR_LNL0 = l0 << 1u64
    PR_LNH1 = (h1 << 1u64) | (h0 >> 63u64)
    PR_LNH0 = h0 << 1u64
    return 0i32
}

/* omega_1 certified, with the power-32 round trip through 10000 */
fn pr_omega() -> u64 {
    /* ln10000 = 12 ln2 + 4 ln(5/4) */
    pr_atanh_ser(3u64)
    let mut ll0 : u64 = 0u64
    let mut ll1 : u64 = 0u64
    let mut lh0 : u64 = 0u64
    let mut lh1 : u64 = 0u64
    let mut rep : u64 = 0u64
    while rep < 12u64 {
        let a : u64 = ll0 + PR_LNL0
        if a < PR_LNL0 { ll1 = ll1 + 1u64 }
        ll0 = a
        ll1 = ll1 + PR_LNL1
        let b : u64 = lh0 + PR_LNH0
        if b < PR_LNH0 { lh1 = lh1 + 1u64 }
        lh0 = b
        lh1 = lh1 + PR_LNH1
        rep = rep + 1u64
    }
    pr_atanh_ser(9u64)
    rep = 0u64
    while rep < 4u64 {
        let a2 : u64 = ll0 + PR_LNL0
        if a2 < PR_LNL0 { ll1 = ll1 + 1u64 }
        ll0 = a2
        ll1 = ll1 + PR_LNL1
        let b2 : u64 = lh0 + PR_LNH0
        if b2 < PR_LNH0 { lh1 = lh1 + 1u64 }
        lh0 = b2
        lh1 = lh1 + PR_LNH1
        rep = rep + 1u64
    }
    /* x = ln10000/32: floor lo, ceil hi */
    let xl0 : u64 = (ll0 >> 5u64) | (ll1 << 59u64)
    let xl1 : u64 = ll1 >> 5u64
    let mut xh0 : u64 = (lh0 >> 5u64) | (lh1 << 59u64)
    let mut xh1 : u64 = lh1 >> 5u64
    if (lh0 & 31u64) != 0u64 {
        xh0 = xh0 + 1u64
        if xh0 == 0u64 { xh1 = xh1 + 1u64 }
    }
    /* exp(x) endpoints (48-bit outward dyadics; x ~ 0.2878 fits) */
    let mlo : u64 = (xl0 >> 40u64) | (xl1 << 24u64)
    let mhi : u64 = ((xh0 >> 40u64) | (xh1 << 24u64)) + 1u64
    if pr_exp(mlo, 48u64) != 0i32 { return 1u64 }
    let el0 : u64 = PR_ELO0
    let el1 : u64 = PR_ELO1
    if pr_exp(mhi, 48u64) != 0i32 { return 1u64 }
    let eh0 : u64 = PR_EHI0
    let eh1 : u64 = PR_EHI1
    /* omega = 1/exp(x): [recip(hi), recip(lo)+1] at 2^-88 */
    pr_recip176(eh1, eh0)
    PR_OML0 = PR_RQ0
    PR_OML1 = PR_RQ1
    pr_recip176(el1, el0)
    PR_OMH0 = PR_RQ0 + 1u64
    PR_OMH1 = PR_RQ1
    if PR_OMH0 == 0u64 { PR_OMH1 = PR_OMH1 + 1u64 }
    /* THE POWER ROUND TRIP: omega^32 * 10000 must contain exactly 1 */
    let mut wl0 : u64 = PR_OML0
    let mut wl1 : u64 = PR_OML1
    let mut wh0 : u64 = PR_OMH0
    let mut wh1 : u64 = PR_OMH1
    let mut sqr : u64 = 0u64
    while sqr < 5u64 {
        pr_mul128(wl1, wl0, wl1, wl0)
        if pr_wshr88() != 0i32 { return 1u64 }
        wl0 = PR_MLO
        wl1 = PR_MHI
        pr_mul128(wh1, wh0, wh1, wh0)
        if pr_wshr88() != 0i32 { return 1u64 }
        if PR_STK != 0u64 { pr_inc128() }
        wh0 = PR_MLO
        wh1 = PR_MHI
        sqr = sqr + 1u64
    }
    pr_mul128by64(wl1, wl0, 10000u64)
    if PR_Z[2] != 0u64 { return 1u64 }
    let tl0 : u64 = PR_Z[0]
    let tl1 : u64 = PR_Z[1]
    pr_mul128by64(wh1, wh0, 10000u64)
    if PR_Z[2] != 0u64 { return 1u64 }
    let th0b : u64 = PR_Z[0]
    let th1b : u64 = PR_Z[1]
    let one1 : u64 = 1u64 << 24u64
    if pr_cmp128(tl1, tl0, one1, 0u64) > 0i64 { return 1u64 }
    if pr_cmp128(th1b, th0b, one1, 0u64) < 0i64 { return 1u64 }
    return 0u64
}

/* sin/cos at theta = omega_1 (interval argument, monotone endpoints,
 * one doubling by both forms) + pythagoras there */
fn pr_omega_angle() -> u64 {
    /* y = omega/2, endpoints outward to 24-bit dyadics: y*2^24 = mant>>65,
     * and (hi:lo)>>65 = hi>>1 (the hi limb sits at 2^64) */
    let m_lo24 : u64 = PR_OML1 >> 1u64
    let m_hi24 : u64 = (PR_OMH1 >> 1u64) + 1u64
    if pr_sincos(m_lo24, 24u64) != 0i32 { return 1u64 }
    let sl0 : u64 = PR_SN0
    let sl1 : u64 = PR_SN1
    let cxh0 : u64 = PR_CX0
    let cxh1 : u64 = PR_CX1
    if pr_sincos(m_hi24, 24u64) != 0i32 { return 1u64 }
    /* sin increasing: [sin(ylo).lo, sin(yhi).hi]; cos decreasing */
    let s5l0 : u64 = sl0
    let s5l1 : u64 = sl1
    let s5h0 : u64 = PR_SX0
    let s5h1 : u64 = PR_SX1
    let c5l0 : u64 = PR_CN0
    let c5l1 : u64 = PR_CN1
    let c5h0 : u64 = cxh0
    let c5h1 : u64 = cxh1
    /* one doubling with both cos forms; pythagoras */
    pr_mul128(s5l1, s5l0, c5l1, c5l0)
    if pr_wshr88() != 0i32 { return 1u64 }
    let d_sl0 : u64 = PR_MLO << 1u64
    let d_sl1 : u64 = (PR_MHI << 1u64) | (PR_MLO >> 63u64)
    pr_mul128(s5h1, s5h0, c5h1, c5h0)
    if pr_wshr88() != 0i32 { return 1u64 }
    if PR_STK != 0u64 { pr_inc128() }
    let d_sh0 : u64 = PR_MLO << 1u64
    let d_sh1 : u64 = (PR_MHI << 1u64) | (PR_MLO >> 63u64)
    let one1 : u64 = 1u64 << 24u64
    pr_mul128(s5h1, s5h0, s5h1, s5h0)
    if pr_wshr88() != 0i32 { return 1u64 }
    if PR_STK != 0u64 { pr_inc128() }
    let t0 : u64 = PR_MLO << 1u64
    let t1 : u64 = (PR_MHI << 1u64) | (PR_MLO >> 63u64)
    let mut ba : u64 = 0u64
    let al0 : u64 = 0u64 - t0
    if 0u64 < t0 { ba = 1u64 }
    let al1 : u64 = one1 - t1 - ba
    pr_mul128(s5l1, s5l0, s5l1, s5l0)
    if pr_wshr88() != 0i32 { return 1u64 }
    let t2 : u64 = PR_MLO << 1u64
    let t3 : u64 = (PR_MHI << 1u64) | (PR_MLO >> 63u64)
    ba = 0u64
    let ah0 : u64 = 0u64 - t2
    if 0u64 < t2 { ba = 1u64 }
    let ah1 : u64 = one1 - t3 - ba
    pr_mul128(c5l1, c5l0, c5l1, c5l0)
    if pr_wshr88() != 0i32 { return 1u64 }
    let u0 : u64 = PR_MLO << 1u64
    let u1 : u64 = (PR_MHI << 1u64) | (PR_MLO >> 63u64)
    if u1 < one1 { return 1u64 }
    let bl0 : u64 = u0
    let bl1 : u64 = u1 - one1
    pr_mul128(c5h1, c5h0, c5h1, c5h0)
    if pr_wshr88() != 0i32 { return 1u64 }
    if PR_STK != 0u64 { pr_inc128() }
    let bh0 : u64 = PR_MLO << 1u64
    let bh1 : u64 = ((PR_MHI << 1u64) | (PR_MLO >> 63u64)) - one1
    if pr_cmp128(ah1, ah0, bl1, bl0) < 0i64 { return 1u64 }
    if pr_cmp128(bh1, bh0, al1, al0) < 0i64 { return 1u64 }
    let mut c_l0 : u64 = al0
    let mut c_l1 : u64 = al1
    if pr_cmp128(bl1, bl0, al1, al0) > 0i64 {
        c_l0 = bl0
        c_l1 = bl1
    }
    let mut c_h0 : u64 = ah0
    let mut c_h1 : u64 = ah1
    if pr_cmp128(bh1, bh0, ah1, ah0) < 0i64 {
        c_h0 = bh0
        c_h1 = bh1
    }
    /* pythagoras at theta = omega */
    pr_mul128(d_sl1, d_sl0, d_sl1, d_sl0)
    if pr_wshr88() != 0i32 { return 1u64 }
    let p0 : u64 = PR_MLO
    let p1 : u64 = PR_MHI
    pr_mul128(c_l1, c_l0, c_l1, c_l0)
    if pr_wshr88() != 0i32 { return 1u64 }
    let mut pl0 : u64 = p0 + PR_MLO
    let mut pl1 : u64 = p1 + PR_MHI
    if pl0 < PR_MLO { pl1 = pl1 + 1u64 }
    pr_mul128(d_sh1, d_sh0, d_sh1, d_sh0)
    if pr_wshr88() != 0i32 { return 1u64 }
    if PR_STK != 0u64 { pr_inc128() }
    let p2 : u64 = PR_MLO
    let p3 : u64 = PR_MHI
    pr_mul128(c_h1, c_h0, c_h1, c_h0)
    if pr_wshr88() != 0i32 { return 1u64 }
    if PR_STK != 0u64 { pr_inc128() }
    let mut ph0 : u64 = p2 + PR_MLO
    let mut ph1 : u64 = p3 + PR_MHI
    if ph0 < PR_MLO { ph1 = ph1 + 1u64 }
    if pr_cmp128(pl1, pl0, one1, 0u64) > 0i64 { return 1u64 }
    if pr_cmp128(ph1, ph0, one1, 0u64) < 0i64 { return 1u64 }
    return 0u64
}

fn pr_arm378() -> u64 {
    if pr_omega() != 0u64 { return 378u64 }
    if pr_omega_angle() != 0u64 { return 378u64 }
    pr_rs("the omega: ln10000 laddered, omega1=10000^(-1/32) certified, power-round-trip: omega^32 x 10000 contains 1 =ok sincos(omega1) pythagoras=contained -- any position, any lane: the same ladder; full-sequence exact attention BRIDGED" as u64)
    pr_rb(10u8)
    return 0u64
}

/* ============ THE PI LADDER (Machin) ============
 * pi = 16 arctan(1/5) - 4 arctan(1/239).  arctan(1/inv) is the atanh
 * series with ALTERNATING signs: sum_k (-1)^k (1/inv)^(2k+1)/(2k+1).  The
 * terms strictly decrease, so an even number of terms is a rigorous lower
 * bound and adding the first omitted term is a rigorous upper bound (the
 * alternating-series bracket).  Two power chains (floor p_l, ceil p_h) at
 * 2^-88 feed a directed accumulation: to keep the lower bound low, ADDED
 * terms round down and SUBTRACTED terms round up; the upper bound flips
 * both.  Then pi is assembled by integer shifts (16x = <<4, 4x = <<2) and
 * a directed subtraction.  THE PROOF is cross-engine: sin(pi/4)^2 must
 * contain 1/2 exactly (the sin ladder is independent of the arctan
 * ladder), and the sin and cos intervals at pi/4 must overlap. */
var PR_ATL0 : u64 = 0u64
var PR_ATL1 : u64 = 0u64
var PR_ATH0 : u64 = 0u64
var PR_ATH1 : u64 = 0u64
var PR_PIL0 : u64 = 0u64
var PR_PIL1 : u64 = 0u64
var PR_PIH0 : u64 = 0u64
var PR_PIH1 : u64 = 0u64
var PR_PIOK : u64 = 0u64

/* arctan(1/inv) as a certified interval at 2^-88 (28 even terms + tail) */
fn pr_arctan_ser(inv: u64) -> i32 {
    pr_div_small(1u64 << 24u64, 0u64, inv)
    let mut pl0 : u64 = PR_MLO
    let mut pl1 : u64 = PR_MHI
    let mut ph0 : u64 = PR_MLO
    let mut ph1 : u64 = PR_MHI
    if PR_STK != 0u64 {
        ph0 = ph0 + 1u64
        if ph0 == 0u64 { ph1 = ph1 + 1u64 }
    }
    let sq : u64 = inv * inv
    let mut lo0 : u64 = 0u64
    let mut lo1 : u64 = 0u64
    let mut hi0 : u64 = 0u64
    let mut hi1 : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 28u64 {
        let denom : u64 = 2u64 * k + 1u64
        pr_div_small(pl1, pl0, denom)
        let ft0 : u64 = PR_MLO
        let ft1 : u64 = PR_MHI
        pr_div_small(ph1, ph0, denom)
        let mut ct0 : u64 = PR_MLO
        let mut ct1 : u64 = PR_MHI
        if PR_STK != 0u64 {
            ct0 = ct0 + 1u64
            if ct0 == 0u64 { ct1 = ct1 + 1u64 }
        }
        if (k & 1u64) == 0u64 {
            /* add: lo += floor, hi += ceil */
            let a : u64 = lo0 + ft0
            if a < ft0 { lo1 = lo1 + 1u64 }
            lo0 = a
            lo1 = lo1 + ft1
            let b : u64 = hi0 + ct0
            if b < ct0 { hi1 = hi1 + 1u64 }
            hi0 = b
            hi1 = hi1 + ct1
        }
        if (k & 1u64) == 1u64 {
            /* subtract: lo -= ceil, hi -= floor */
            let mut bw : u64 = 0u64
            let d0 : u64 = lo0 - ct0
            if lo0 < ct0 { bw = 1u64 }
            lo0 = d0
            lo1 = lo1 - ct1 - bw
            bw = 0u64
            let e0 : u64 = hi0 - ft0
            if hi0 < ft0 { bw = 1u64 }
            hi0 = e0
            hi1 = hi1 - ft1 - bw
        }
        pr_div_small(pl1, pl0, sq)
        pl0 = PR_MLO
        pl1 = PR_MHI
        pr_div_small(ph1, ph0, sq)
        ph0 = PR_MLO
        ph1 = PR_MHI
        if PR_STK != 0u64 {
            ph0 = ph0 + 1u64
            if ph0 == 0u64 { ph1 = ph1 + 1u64 }
        }
        k = k + 1u64
    }
    /* the alternating tail: arctan < S_28 + t_28, so hi += ceil(t_28) */
    pr_div_small(ph1, ph0, 57u64)
    let mut tt0 : u64 = PR_MLO
    let mut tt1 : u64 = PR_MHI
    if PR_STK != 0u64 {
        tt0 = tt0 + 1u64
        if tt0 == 0u64 { tt1 = tt1 + 1u64 }
    }
    let c : u64 = hi0 + tt0
    if c < tt0 { hi1 = hi1 + 1u64 }
    hi0 = c
    hi1 = hi1 + tt1
    PR_ATL0 = lo0
    PR_ATL1 = lo1
    PR_ATH0 = hi0
    PR_ATH1 = hi1
    return 0i32
}

fn pr_pi() -> u64 {
    pr_arctan_ser(5u64)
    let a5l0 : u64 = PR_ATL0
    let a5l1 : u64 = PR_ATL1
    let a5h0 : u64 = PR_ATH0
    let a5h1 : u64 = PR_ATH1
    pr_arctan_ser(239u64)
    let a2l0 : u64 = PR_ATL0
    let a2l1 : u64 = PR_ATL1
    let a2h0 : u64 = PR_ATH0
    let a2h1 : u64 = PR_ATH1
    /* 16*A5 = A5 << 4 ; 4*A239 = A239 << 2 */
    let s5l0 : u64 = a5l0 << 4u64
    let s5l1 : u64 = (a5l1 << 4u64) | (a5l0 >> 60u64)
    let s5h0 : u64 = a5h0 << 4u64
    let s5h1 : u64 = (a5h1 << 4u64) | (a5h0 >> 60u64)
    let q2l0 : u64 = a2l0 << 2u64
    let q2l1 : u64 = (a2l1 << 2u64) | (a2l0 >> 62u64)
    let q2h0 : u64 = a2h0 << 2u64
    let q2h1 : u64 = (a2h1 << 2u64) | (a2h0 >> 62u64)
    /* pi_lo = 16A5_lo - 4A239_hi ; pi_hi = 16A5_hi - 4A239_lo */
    let mut bw : u64 = 0u64
    let l0 : u64 = s5l0 - q2h0
    if s5l0 < q2h0 { bw = 1u64 }
    PR_PIL0 = l0
    PR_PIL1 = s5l1 - q2h1 - bw
    bw = 0u64
    let h0 : u64 = s5h0 - q2l0
    if s5h0 < q2l0 { bw = 1u64 }
    PR_PIH0 = h0
    PR_PIH1 = s5h1 - q2l1 - bw
    return 0u64
}

/* 256-bit unsigned compare (most significant limb first) */
fn pr_cmp256(a3: u64, a2: u64, a1: u64, a0: u64, b3: u64, b2: u64, b1: u64, b0: u64) -> i64 {
    if a3 > b3 { return 1i64 }
    if a3 < b3 { return 0i64 - 1i64 }
    if a2 > b2 { return 1i64 }
    if a2 < b2 { return 0i64 - 1i64 }
    if a1 > b1 { return 1i64 }
    if a1 < b1 { return 0i64 - 1i64 }
    if a0 > b0 { return 1i64 }
    if a0 < b0 { return 0i64 - 1i64 }
    return 0i64
}

/* the cross-engine proof: sin(pi/4)^2 contains 1/2, sin=cos overlap */
fn pr_pi_check() -> u64 {
    /* pi/4 at 2^-88: floor lo, ceil hi */
    let p4l0 : u64 = (PR_PIL0 >> 2u64) | (PR_PIL1 << 62u64)
    let p4l1 : u64 = PR_PIL1 >> 2u64
    let mut p4h0 : u64 = (PR_PIH0 >> 2u64) | (PR_PIH1 << 62u64)
    let mut p4h1 : u64 = PR_PIH1 >> 2u64
    if (PR_PIH0 & 3u64) != 0u64 {
        let t : u64 = p4h0 + 1u64
        if t == 0u64 { p4h1 = p4h1 + 1u64 }
        p4h0 = t
    }
    /* down to a 2^-48 dyadic angle: floor a_lo, ceil a_hi */
    let a_lo : u64 = (p4l0 >> 40u64) | (p4l1 << 24u64)
    let mut a_hi : u64 = (p4h0 >> 40u64) | (p4h1 << 24u64)
    if (p4h0 & ((1u64 << 40u64) - 1u64)) != 0u64 { a_hi = a_hi + 1u64 }
    /* sincos at the low angle: sin lower bound, cos upper bound */
    pr_sincos(a_lo, 48u64)
    let sinl0 : u64 = PR_SN0
    let sinl1 : u64 = PR_SN1
    let cosh0 : u64 = PR_CX0
    let cosh1 : u64 = PR_CX1
    /* sincos at the high angle: sin upper bound, cos lower bound */
    pr_sincos(a_hi, 48u64)
    let sinh0 : u64 = PR_SX0
    let sinh1 : u64 = PR_SX1
    let cosl0 : u64 = PR_CN0
    let cosl1 : u64 = PR_CN1
    /* sin=cos at pi/4: the two intervals must overlap */
    if pr_cmp128(sinl1, sinl0, cosh1, cosh0) > 0i64 { return 1u64 }
    if pr_cmp128(cosl1, cosl0, sinh1, sinh0) > 0i64 { return 1u64 }
    /* sin(pi/4)^2 contains 1/2 = 2^175 at scale 2^-176 (the ANCHOR) */
    let half2 : u64 = 1u64 << 47u64
    pr_mul128(sinl1, sinl0, sinl1, sinl0)
    if pr_cmp256(PR_W[3], PR_W[2], PR_W[1], PR_W[0], 0u64, half2, 0u64, 0u64) > 0i64 { return 1u64 }
    pr_mul128(sinh1, sinh0, sinh1, sinh0)
    if pr_cmp256(PR_W[3], PR_W[2], PR_W[1], PR_W[0], 0u64, half2, 0u64, 0u64) < 0i64 { return 1u64 }
    return 0u64
}

fn pr_arm_pi() -> u64 {
    PR_PIOK = 0u64
    if pr_pi() != 0u64 { return 386u64 }
    if pr_pi_check() != 0u64 { return 386u64 }
    PR_PIOK = 1u64
    pr_rs("the pi: machin 16 atan(1/5) - 4 atan(1/239) certified; sin(pi/4)^2 contains 1/2 =ok sin=cos overlap=ok -- the circle's constant laddered from pure integers" as u64)
    pr_rb(10u8)
    return 0u64
}

/* ============ THE YARN (the attention rescaling of the long rope) ============
 * DeepSeek-R1 extends its 4096 context to 163840 by YaRN (factor s=40).
 * The attention logits are rescaled by mscale^2, where the ledger's
 * yarn_log_multiplier m=0.1 gives mscale = 1 + m*ln(s) = 1 + ln(40)/10.
 * ln(40) = 5 ln2 + ln(5/4) = 5*(2 atanh(1/3)) + (2 atanh(1/9)) -- the very
 * ladders that built ln10000 for omega.  The certified mscale interval is
 * cross-checked against the rational bracket [13688/10000, 13689/10000].
 * (The per-lane frequency ramp bites only at nonzero positions; it rides
 * with the distinct-token stair.  At position 0 every rotation is the
 * identity, so mscale is the whole of yarn the single-token walk sees.) */
var PR_MSL0 : u64 = 0u64
var PR_MSL1 : u64 = 0u64
var PR_MSH0 : u64 = 0u64
var PR_MSH1 : u64 = 0u64
var PR_YARNOK : u64 = 0u64

/* ln(40) as a certified interval at 2^-88 into (lo0/lo1, hi0/hi1) */
fn pr_ln40(dst_lo0: u64, dst_lo1: u64) -> u64 {
    pr_atanh_ser(3u64)
    /* 5 * (2 atanh(1/3)) */
    let mut ll0 : u64 = 0u64
    let mut ll1 : u64 = 0u64
    let mut lh0 : u64 = 0u64
    let mut lh1 : u64 = 0u64
    let mut rep : u64 = 0u64
    while rep < 5u64 {
        let a : u64 = ll0 + PR_LNL0
        if a < PR_LNL0 { ll1 = ll1 + 1u64 }
        ll0 = a
        ll1 = ll1 + PR_LNL1
        let b : u64 = lh0 + PR_LNH0
        if b < PR_LNH0 { lh1 = lh1 + 1u64 }
        lh0 = b
        lh1 = lh1 + PR_LNH1
        rep = rep + 1u64
    }
    pr_atanh_ser(9u64)
    let a2 : u64 = ll0 + PR_LNL0
    if a2 < PR_LNL0 { ll1 = ll1 + 1u64 }
    ll0 = a2
    ll1 = ll1 + PR_LNL1
    let b2 : u64 = lh0 + PR_LNH0
    if b2 < PR_LNH0 { lh1 = lh1 + 1u64 }
    lh0 = b2
    lh1 = lh1 + PR_LNH1
    PR_MSL0 = ll0
    PR_MSL1 = ll1
    PR_MSH0 = lh0
    PR_MSH1 = lh1
    return 0u64
}

fn pr_yarn() -> u64 {
    pr_ln40(0u64, 0u64)
    /* mscale = 1 + ln40/10 : divide the ln40 interval by 10 (dir), add 1 */
    pr_div_small(PR_MSL1, PR_MSL0, 10u64)
    let ml0 : u64 = PR_MLO
    let ml1 : u64 = PR_MHI
    pr_div_small(PR_MSH1, PR_MSH0, 10u64)
    let mut mh0 : u64 = PR_MLO
    let mut mh1 : u64 = PR_MHI
    if PR_STK != 0u64 {
        mh0 = mh0 + 1u64
        if mh0 == 0u64 { mh1 = mh1 + 1u64 }
    }
    /* + 1 at 2^-88 = + (1 << 88) = + (1<<24) into the high limb */
    let one88 : u64 = 1u64 << 24u64
    PR_MSL0 = ml0
    PR_MSL1 = ml1 + one88
    PR_MSH0 = mh0
    PR_MSH1 = mh1 + one88
    /* cross-check against [13688/10000, 13689/10000] (external anchor):
     * mscale_lo * 10000 >= 13688 * 2^88 ; mscale_hi * 10000 <= 13689 * 2^88 */
    pr_mul128by64(PR_MSL1, PR_MSL0, 10000u64)
    let lo0 : u64 = PR_Z[0]
    let lo1 : u64 = PR_Z[1]
    let lo2 : u64 = PR_Z[2]
    pr_mul128by64(one88, 0u64, 13688u64)
    let b0 : u64 = PR_Z[0]
    let b1 : u64 = PR_Z[1]
    let b2 : u64 = PR_Z[2]
    if pr_cmp256(0u64, lo2, lo1, lo0, 0u64, b2, b1, b0) < 0i64 { return 1u64 }
    pr_mul128by64(PR_MSH1, PR_MSH0, 10000u64)
    let hi0 : u64 = PR_Z[0]
    let hi1 : u64 = PR_Z[1]
    let hi2 : u64 = PR_Z[2]
    pr_mul128by64(one88, 0u64, 13689u64)
    let c0 : u64 = PR_Z[0]
    let c1 : u64 = PR_Z[1]
    let c2 : u64 = PR_Z[2]
    if pr_cmp256(0u64, hi2, hi1, hi0, 0u64, c2, c1, c0) > 0i64 { return 1u64 }
    return 0u64
}

fn pr_arm_yarn() -> u64 {
    PR_YARNOK = 0u64
    if pr_yarn() != 0u64 { return 387u64 }
    PR_YARNOK = 1u64
    pr_rs("the yarn: factor=40 mscale = 1 + ln(40)/10 certified in [13688/10000, 13689/10000] (the softmax rescaling of the extended rope) -- ln40 = 5 ln2 + ln(5/4) off the standing atanh ladders" as u64)
    pr_rb(10u8)
    return 0u64
}

/* ============ THE YARN FREQUENCIES (yarn-active RoPE) ============
 * The mscale rescales the logits; the FREQUENCY RAMP rescales the rope
 * lanes themselves.  A lane whose wavelength exceeds the original 4096
 * context is INTERPOLATED (freq / factor); a short-wavelength lane is
 * EXTRAPOLATED (freq unchanged); between the two correction dimensions it
 * ramps.  The correction dims need the WAVELENGTH -- and so ln(pi): the
 * one transcendental the ratio-atanh ladders could not reach.  So this
 * stair first mints a GENERAL natural log (2 atanh of an arbitrary small
 * interval argument, ln pi = 2 ln2 - 2 atanh((1-pi/4)/(1+pi/4))), verified
 * against the rational bracket, then the correction dims low/high, then
 * the clamped ramp t_i for every lane -- certified: t at lane 0 pinned to
 * 0 (full interpolation), t at lane 31 pinned to 1 (full extrapolation),
 * monotone through the transition.  This is the whole of yarn the rope
 * sees at a NONZERO position; the distinct-token forward rides the
 * harmonia's certified cross-position delta-ladder on these lanes. */
var PR_AGL0 : u64 = 0u64
var PR_AGL1 : u64 = 0u64
var PR_AGH0 : u64 = 0u64
var PR_AGH1 : u64 = 0u64
var PR_LPL0 : u64 = 0u64
var PR_LPL1 : u64 = 0u64
var PR_LPH0 : u64 = 0u64
var PR_LPH1 : u64 = 0u64
var PR_YFREQOK : u64 = 0u64
var PR_YT0 : u64 = 0u64
var PR_YT31 : u64 = 0u64
var PR_YMONO : u64 = 0u64

/* add a 128-bit (b1:b0) into (a1:a0) accumulators via module scratch */
var PR_ADD0 : u64 = 0u64
var PR_ADD1 : u64 = 0u64
fn pr_add128(a0: u64, a1: u64, b0: u64, b1: u64) -> i32 {
    let s : u64 = a0 + b0
    let mut c : u64 = 0u64
    if s < b0 { c = 1u64 }
    PR_ADD0 = s
    PR_ADD1 = a1 + b1 + c
    return 0i32
}

/* 2 atanh(|a|) as an interval at 2^-88 for a small positive df |a|
 * (ae + 88 in [0,64)); result in PR_AGL / PR_AGH */
fn pr_atanh_gen(am: u64, ae: i64) -> i32 {
    let s : u64 = (ae + 88i64) as u64
    let al0 : u64 = am << s
    let mut al1 : u64 = 0u64
    if s != 0u64 { al1 = am >> (64u64 - s) }
    pr_mul128(al1, al0, al1, al0)
    pr_wshr88()
    let a2l0 : u64 = PR_MLO
    let a2l1 : u64 = PR_MHI
    let mut a2h0 : u64 = PR_MLO
    let mut a2h1 : u64 = PR_MHI
    if PR_STK != 0u64 {
        a2h0 = a2h0 + 1u64
        if a2h0 == 0u64 { a2h1 = a2h1 + 1u64 }
    }
    let mut pl0 : u64 = al0
    let mut pl1 : u64 = al1
    let mut ph0 : u64 = al0
    let mut ph1 : u64 = al1
    let mut lo0 : u64 = 0u64
    let mut lo1 : u64 = 0u64
    let mut hi0 : u64 = 0u64
    let mut hi1 : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 40u64 {
        let denom : u64 = 2u64 * k + 1u64
        pr_div_small(pl1, pl0, denom)
        pr_add128(lo0, lo1, PR_MLO, PR_MHI)
        lo0 = PR_ADD0
        lo1 = PR_ADD1
        pr_div_small(ph1, ph0, denom)
        let mut ct0 : u64 = PR_MLO
        let mut ct1 : u64 = PR_MHI
        if PR_STK != 0u64 {
            ct0 = ct0 + 1u64
            if ct0 == 0u64 { ct1 = ct1 + 1u64 }
        }
        pr_add128(hi0, hi1, ct0, ct1)
        hi0 = PR_ADD0
        hi1 = PR_ADD1
        pr_mul128(pl1, pl0, a2l1, a2l0)
        pr_wshr88()
        pl0 = PR_MLO
        pl1 = PR_MHI
        pr_mul128(ph1, ph0, a2h1, a2h0)
        pr_wshr88()
        ph0 = PR_MLO
        ph1 = PR_MHI
        if PR_STK != 0u64 {
            ph0 = ph0 + 1u64
            if ph0 == 0u64 { ph1 = ph1 + 1u64 }
        }
        k = k + 1u64
    }
    /* the geometric tail (loose over-cover of the remainder onto hi) */
    pr_div_small(ph1, ph0, 81u64)
    let mut tt0 : u64 = PR_MLO
    let mut tt1 : u64 = PR_MHI
    if PR_STK != 0u64 {
        tt0 = tt0 + 1u64
        if tt0 == 0u64 { tt1 = tt1 + 1u64 }
    }
    pr_add128(hi0, hi1, tt0, tt1)
    hi0 = PR_ADD0
    hi1 = PR_ADD1
    PR_AGL1 = (lo1 << 1u64) | (lo0 >> 63u64)
    PR_AGL0 = lo0 << 1u64
    PR_AGH1 = (hi1 << 1u64) | (hi0 >> 63u64)
    PR_AGH0 = hi0 << 1u64
    return 0i32
}

/* ln(pi) as a certified interval at 2^-88 into PR_LP* */
fn pr_lnpi() -> u64 {
    /* pi/4 at 2^-88: floor lo, ceil hi */
    let p4l0 : u64 = (PR_PIL0 >> 2u64) | (PR_PIL1 << 62u64)
    let p4l1 : u64 = PR_PIL1 >> 2u64
    let mut p4h0 : u64 = (PR_PIH0 >> 2u64) | (PR_PIH1 << 62u64)
    let mut p4h1 : u64 = PR_PIH1 >> 2u64
    if (PR_PIH0 & 3u64) != 0u64 {
        let t : u64 = p4h0 + 1u64
        if t == 0u64 { p4h1 = p4h1 + 1u64 }
        p4h0 = t
    }
    pr_dfn2(p4l1, p4l0, 0i64 - 88i64, 0u64)
    let pi4lm : u64 = PR_DFM
    let pi4le : i64 = PR_DFE
    pr_dfn2(p4h1, p4h0, 0i64 - 88i64, 1u64)
    let pi4hm : u64 = PR_DFM
    let pi4he : i64 = PR_DFE
    let onem : u64 = 1u64 << 63u64
    let onee : i64 = 0i64 - 63i64
    /* |a| = (1 - pi/4)/(1 + pi/4) : num = 1 - pi/4, den = 1 + pi/4 */
    pr_dfsub128(onem, onee, pi4hm, pi4he, 0u64)
    let numlm : u64 = PR_DFM
    let numle : i64 = PR_DFE
    pr_dfsub128(onem, onee, pi4lm, pi4le, 1u64)
    let numhm : u64 = PR_DFM
    let numhe : i64 = PR_DFE
    pr_dfadd(onem, onee, pi4lm, pi4le, 0u64)
    let denlm : u64 = PR_DFM
    let denle : i64 = PR_DFE
    pr_dfadd(onem, onee, pi4hm, pi4he, 1u64)
    let denhm : u64 = PR_DFM
    let denhe : i64 = PR_DFE
    pr_dfrecip(denhm, denhe, 0u64)
    pr_dfmul(numlm, numle, PR_DFM, PR_DFE, 0u64)
    let alm : u64 = PR_DFM
    let ale : i64 = PR_DFE
    pr_dfrecip(denlm, denle, 1u64)
    pr_dfmul(numhm, numhe, PR_DFM, PR_DFE, 1u64)
    let ahm : u64 = PR_DFM
    let ahe : i64 = PR_DFE
    /* 2 atanh(|a|): lo from |a|_lo, hi from |a|_hi (atanh increasing) */
    pr_atanh_gen(alm, ale)
    let at_lo0 : u64 = PR_AGL0
    let at_lo1 : u64 = PR_AGL1
    pr_atanh_gen(ahm, ahe)
    let at_hi0 : u64 = PR_AGH0
    let at_hi1 : u64 = PR_AGH1
    /* 2 ln2 = 2 * (2 atanh(1/3)) at 2^-88 */
    pr_atanh_ser(3u64)
    let l20 : u64 = PR_LNL0 << 1u64
    let l21 : u64 = (PR_LNL1 << 1u64) | (PR_LNL0 >> 63u64)
    let h20 : u64 = PR_LNH0 << 1u64
    let h21 : u64 = (PR_LNH1 << 1u64) | (PR_LNH0 >> 63u64)
    /* lnpi = 2ln2 - 2atanh(|a|): lo = 2ln2_lo - at_hi, hi = 2ln2_hi - at_lo */
    let mut bw : u64 = 0u64
    let d0 : u64 = l20 - at_hi0
    if l20 < at_hi0 { bw = 1u64 }
    PR_LPL0 = d0
    PR_LPL1 = l21 - at_hi1 - bw
    bw = 0u64
    let e0 : u64 = h20 - at_lo0
    if h20 < at_lo0 { bw = 1u64 }
    PR_LPH0 = e0
    PR_LPH1 = h21 - at_lo1 - bw
    /* the external anchor: lnpi in [11447/10000, 11448/10000] */
    pr_mul128by64(PR_LPL1, PR_LPL0, 10000u64)
    let cl0 : u64 = PR_Z[0]
    let cl1 : u64 = PR_Z[1]
    let cl2 : u64 = PR_Z[2]
    let one88 : u64 = 1u64 << 24u64
    pr_mul128by64(one88, 0u64, 11447u64)
    if pr_cmp256(0u64, cl2, cl1, cl0, 0u64, PR_Z[2], PR_Z[1], PR_Z[0]) < 0i64 { return 1u64 }
    pr_mul128by64(PR_LPH1, PR_LPH0, 10000u64)
    let ch0 : u64 = PR_Z[0]
    let ch1 : u64 = PR_Z[1]
    let ch2 : u64 = PR_Z[2]
    pr_mul128by64(one88, 0u64, 11448u64)
    if pr_cmp256(0u64, ch2, ch1, ch0, 0u64, PR_Z[2], PR_Z[1], PR_Z[0]) > 0i64 { return 1u64 }
    return 0u64
}

/* |a - b| for two positive dfs, a >= b, rounded per up (128-bit safe) */
fn pr_dfsub128(ma: u64, ea: i64, mb: u64, eb: i64, up: u64) -> i32 {
    if mb == 0u64 {
        PR_DFM = ma
        PR_DFE = ea
        return 0i32
    }
    let d : i64 = ea - eb
    if d >= 64i64 {
        PR_DFM = ma
        PR_DFE = ea
        if up == 0u64 {
            PR_DFM = PR_DFM - 1u64
            if PR_DFM < (1u64 << 63u64) {
                PR_DFM = (PR_DFM << 1u64) | 1u64
                PR_DFE = PR_DFE - 1i64
            }
        }
        return 0i32
    }
    let du : u64 = d as u64
    let mut hi : u64 = 0u64
    let mut lo : u64 = 0u64
    if du == 0u64 {
        lo = ma - mb
        hi = 0u64
    }
    if du != 0u64 {
        hi = ma >> (64u64 - du)
        lo = ma << du
        let mut bw : u64 = 0u64
        if lo < mb { bw = 1u64 }
        lo = lo - mb
        hi = hi - bw
    }
    pr_dfn2(hi, lo, eb, up)
    return 0i32
}

/* the correction dims + the clamped ramp t_i for every lane */
fn pr_yarn_freq() -> u64 {
    if pr_lnpi() != 0u64 { return 1u64 }
    /* ln(base) = ln(10000) = 12 ln2 + 4 ln(5/4) at 2^-88 (lo/hi) */
    pr_atanh_ser(3u64)
    let mut lbl0 : u64 = 0u64
    let mut lbl1 : u64 = 0u64
    let mut lbh0 : u64 = 0u64
    let mut lbh1 : u64 = 0u64
    let mut rep : u64 = 0u64
    while rep < 12u64 {
        pr_add128(lbl0, lbl1, PR_LNL0, PR_LNL1)
        lbl0 = PR_ADD0
        lbl1 = PR_ADD1
        pr_add128(lbh0, lbh1, PR_LNH0, PR_LNH1)
        lbh0 = PR_ADD0
        lbh1 = PR_ADD1
        rep = rep + 1u64
    }
    pr_atanh_ser(9u64)
    rep = 0u64
    while rep < 4u64 {
        pr_add128(lbl0, lbl1, PR_LNL0, PR_LNL1)
        lbl0 = PR_ADD0
        lbl1 = PR_ADD1
        pr_add128(lbh0, lbh1, PR_LNH0, PR_LNH1)
        lbh0 = PR_ADD0
        lbh1 = PR_ADD1
        rep = rep + 1u64
    }
    /* low_arg = 6 ln2 - lnpi ; high_arg = 11 ln2 - lnpi (at 2^-88).
     * 6 ln2 = 6 * (2 atanh(1/3)) ; here ln2 = PR from atanh_ser(3). */
    pr_atanh_ser(3u64)
    let mut l6l0 : u64 = 0u64
    let mut l6l1 : u64 = 0u64
    let mut l6h0 : u64 = 0u64
    let mut l6h1 : u64 = 0u64
    let mut l11l0 : u64 = 0u64
    let mut l11l1 : u64 = 0u64
    let mut l11h0 : u64 = 0u64
    let mut l11h1 : u64 = 0u64
    rep = 0u64
    while rep < 11u64 {
        if rep < 6u64 {
            pr_add128(l6l0, l6l1, PR_LNL0, PR_LNL1)
            l6l0 = PR_ADD0
            l6l1 = PR_ADD1
            pr_add128(l6h0, l6h1, PR_LNH0, PR_LNH1)
            l6h0 = PR_ADD0
            l6h1 = PR_ADD1
        }
        pr_add128(l11l0, l11l1, PR_LNL0, PR_LNL1)
        l11l0 = PR_ADD0
        l11l1 = PR_ADD1
        pr_add128(l11h0, l11h1, PR_LNH0, PR_LNH1)
        l11h0 = PR_ADD0
        l11h1 = PR_ADD1
        rep = rep + 1u64
    }
    /* low_arg = 6ln2 - lnpi : lo = 6ln2_lo - lnpi_hi, hi = 6ln2_hi - lnpi_lo */
    let mut bw : u64 = 0u64
    let la0 : u64 = l6l0 - PR_LPH0
    if l6l0 < PR_LPH0 { bw = 1u64 }
    let lalo0 : u64 = la0
    let lalo1 : u64 = l6l1 - PR_LPH1 - bw
    bw = 0u64
    let lb0 : u64 = l6h0 - PR_LPL0
    if l6h0 < PR_LPL0 { bw = 1u64 }
    let lahi0 : u64 = lb0
    let lahi1 : u64 = l6h1 - PR_LPL1 - bw
    bw = 0u64
    let ha0 : u64 = l11l0 - PR_LPH0
    if l11l0 < PR_LPH0 { bw = 1u64 }
    let halo0 : u64 = ha0
    let halo1 : u64 = l11l1 - PR_LPH1 - bw
    bw = 0u64
    let hb0 : u64 = l11h0 - PR_LPL0
    if l11h0 < PR_LPL0 { bw = 1u64 }
    let hahi0 : u64 = hb0
    let hahi1 : u64 = l11h1 - PR_LPL1 - bw
    /* low = 64 * low_arg / (2 lnbase) ; high = 64 * high_arg / (2 lnbase).
     * As dfs: multiply the arg by 32 (=64/2), reciprocal of lnbase.  Work
     * through the df toolkit at reduced width (correction dims need only
     * modest precision; the ramp clamps). */
    pr_dfn2(lalo1, lalo0, 0i64 - 88i64, 0u64)
    let lowamlo : u64 = PR_DFM
    let lowamle : i64 = PR_DFE
    pr_dfn2(lahi1, lahi0, 0i64 - 88i64, 1u64)
    let lowamhi : u64 = PR_DFM
    let lowamhe : i64 = PR_DFE
    pr_dfn2(halo1, halo0, 0i64 - 88i64, 0u64)
    let hiamlo : u64 = PR_DFM
    let hiamle : i64 = PR_DFE
    pr_dfn2(hahi1, hahi0, 0i64 - 88i64, 1u64)
    let hiamhi : u64 = PR_DFM
    let hiamhe : i64 = PR_DFE
    pr_dfn2(lbl1, lbl0, 0i64 - 88i64, 0u64)
    let lbm_lo : u64 = PR_DFM
    let lbe_lo : i64 = PR_DFE
    pr_dfn2(lbh1, lbh0, 0i64 - 88i64, 1u64)
    let lbm_hi : u64 = PR_DFM
    let lbe_hi : i64 = PR_DFE
    /* low = 32 * low_arg / lnbase (32 = 64/2); scale exp by +5 for *32 */
    pr_dfrecip(lbm_hi, lbe_hi, 0u64)
    pr_dfmul(lowamlo, lowamle + 5i64, PR_DFM, PR_DFE, 0u64)
    let low_m_lo : u64 = PR_DFM
    let low_e_lo : i64 = PR_DFE
    pr_dfrecip(lbm_lo, lbe_lo, 1u64)
    pr_dfmul(lowamhi, lowamhe + 5i64, PR_DFM, PR_DFE, 1u64)
    let low_m_hi : u64 = PR_DFM
    let low_e_hi : i64 = PR_DFE
    pr_dfrecip(lbm_hi, lbe_hi, 0u64)
    pr_dfmul(hiamlo, hiamle + 5i64, PR_DFM, PR_DFE, 0u64)
    let high_m_lo : u64 = PR_DFM
    let high_e_lo : i64 = PR_DFE
    pr_dfrecip(lbm_lo, lbe_lo, 1u64)
    pr_dfmul(hiamhi, hiamhe + 5i64, PR_DFM, PR_DFE, 1u64)
    let high_m_hi : u64 = PR_DFM
    let high_e_hi : i64 = PR_DFE
    /* the ramp t_i = clamp((i - low)/(high - low), 0, 1) for lanes 0..31.
     * Verify: t_0 pinned to 0 (0 < low), t_31 pinned to 1 (31 > high),
     * and t monotone non-decreasing across the transition. */
    PR_YT0 = 0u64
    PR_YT31 = 0u64
    PR_YMONO = 1u64
    /* t_0: 0 <= low (with the low interval > 0) => clamp low = 0 */
    if pr_df_cmp(low_m_lo, low_e_lo, 0u64, 0i64) > 0i64 { PR_YT0 = 1u64 }
    /* t_31: 31 >= high (high < 31) => clamp high = 1.  31 as df: */
    pr_dfn2(0u64, 31u64, 0i64, 0u64)
    if pr_df_cmp(high_m_hi, high_e_hi, PR_DFM, PR_DFE) < 0i64 { PR_YT31 = 1u64 }
    /* the window must be ordered: high > low */
    if pr_df_cmp(high_m_lo, high_e_lo, low_m_hi, low_e_hi) <= 0i64 { PR_YMONO = 0u64 }
    if PR_YT0 != 1u64 { return 1u64 }
    if PR_YT31 != 1u64 { return 1u64 }
    if PR_YMONO != 1u64 { return 1u64 }
    return 0u64
}

fn pr_arm_yarnfreq() -> u64 {
    PR_YFREQOK = 0u64
    if pr_yarn_freq() != 0u64 { return 390u64 }
    PR_YFREQOK = 1u64
    pr_rs("the yarn frequencies: ln(pi) minted (general atanh ladder) in [11447/10000, 11448/10000]; correction dims low/high certified 0<low<high<31; ramp t pinned: lane0=interp(t=0) lane31=extrap(t=1) window-ordered=ok -- yarn-active RoPE stands; the distinct-token forward rides the harmonia delta-ladder on these lanes" as u64)
    pr_rb(10u8)
    return 0u64
}
/* ============ arm 379: THE HARMONIA (the assembled gaze) ============ */

/* All 32 omega lanes of RoPE, the general delta-angle ladder, and the
 * first exact cross-position QK matrix of the real R1.
 *
 * THE LANES: omega_j = 10000^(-j/32) = omega_1^j -- the whole bank is a
 * directed product chain off arm 378's certified omega_1.  Teeth: the
 * FIVE POWER ROUND TRIPS ([omega_j]^(32/j) x 10000 must contain exactly
 * 1, for j in {1,2,4,8,16}), the THREE RATIONAL ISLANDS (lanes 8/16/24
 * are 10^-1/10^-2/10^-3 EXACTLY -- each interval must contain its
 * rational), and strict monotone separation of all 32 lanes.
 *
 * THE LADDER: sin/cos at theta = delta * omega_j for ANY delta.  Halve
 * the interval angle into the first quadrant, ride the monotone Taylor
 * endpoints at 2^-48 outward, then SIGNED double-angle rungs (the
 * rotation leaves the first quadrant, so intervals carry signs; both
 * cos forms 1-2s^2 and 2c^2-1 must OVERLAP at every rung -- two engines
 * in one identity -- and Pythagoras must contain 1 at the top).
 *
 * THE ASSEMBLY: per lane the EXACT integers P_j = qa*ka + qb*kb and
 * X_j = qa*kb - qb*ka (neox pairing (d, d+32) -- the premise NAMED);
 * R(delta) = sum_j [ P_j cos(delta w_j) + X_j sin(delta w_j) ] built as
 * sign-magnitude 14-limb integers.  Integer x dyadic-endpoint products
 * are EXACT, so the only width in R is the width of the circle itself.
 * ANCHOR: R(0) must equal arm 375's standing rope total N2 LIMB-EXACT
 * (two organs, two routes, one integer).  Then the 8x8 causal QK(t,s)
 * matrix (Toeplitz in t-s: the standing numerators speak at every seat,
 * positions differ only by the turn) and THE CROSS-POSITION VERDICT:
 * the certified order of the eight deltas, straddles refused by name.
 * Premise NAMED: base frequency theta=10000 (yarn ramp = next stair). */

/* the 32 omega lanes at 2^-88 (lo/hi endpoints, 2 limbs each) */
var PR_WJL0 : [u64; 32]
var PR_WJL1 : [u64; 32]
var PR_WJH0 : [u64; 32]
var PR_WJH1 : [u64; 32]

/* exact P/X integers per lane: sign + 9 limbs aligned at 2^PR_EALN */
var PR_PJS : [i64; 32]
var PR_PJL : [u64; 288]
var PR_XJS : [i64; 32]
var PR_XJL : [u64; 288]
var PR_EALN : i64 = 0i64

/* 6-limb product + 9-limb shifted term + 9-limb signed accumulator */
var PR_P6 : [u64; 6]
var PR_T9 : [u64; 9]
var PR_A9S : i64 = 0i64
var PR_A9L : [u64; 9]

/* 14-limb term + signed score accumulators (lo and hi bounds) */
var PR_T14 : [u64; 14]
var PR_U14 : [u64; 14]
var PR_USS : i64 = 0i64
var PR_ALS : i64 = 0i64
var PR_AL : [u64; 14]
var PR_AHS : i64 = 0i64
var PR_AH : [u64; 14]

/* stored score intervals per delta 0..7: sign + 14 limbs, both bounds */
var PR_RDLS : [i64; 8]
var PR_RDLL : [u64; 112]
var PR_RDHS : [i64; 8]
var PR_RDHL : [u64; 112]

/* the certified ladder output: signed sin/cos endpoint intervals */
var PR_HSLS : i64 = 0i64
var PR_HSL1 : u64 = 0u64
var PR_HSL0 : u64 = 0u64
var PR_HSHS : i64 = 0i64
var PR_HSH1 : u64 = 0u64
var PR_HSH0 : u64 = 0u64
var PR_HCLS : i64 = 0i64
var PR_HCL1 : u64 = 0u64
var PR_HCL0 : u64 = 0u64
var PR_HCHS : i64 = 0i64
var PR_HCH1 : u64 = 0u64
var PR_HCH0 : u64 = 0u64

/* signed-interval multiply operands and result */
var PR_QAS : i64 = 0i64
var PR_QA1 : u64 = 0u64
var PR_QA0 : u64 = 0u64
var PR_QBS : i64 = 0i64
var PR_QB1 : u64 = 0u64
var PR_QB0 : u64 = 0u64
var PR_RAS : i64 = 0i64
var PR_RA1 : u64 = 0u64
var PR_RA0 : u64 = 0u64
var PR_RBS : i64 = 0i64
var PR_RB1 : u64 = 0u64
var PR_RB0 : u64 = 0u64
var PR_IRLS : i64 = 0i64
var PR_IRL1 : u64 = 0u64
var PR_IRL0 : u64 = 0u64
var PR_IRHS : i64 = 0i64
var PR_IRH1 : u64 = 0u64
var PR_IRH0 : u64 = 0u64

/* signed-interval square result (nonnegative bounds) */
var PR_SQL1 : u64 = 0u64
var PR_SQL0 : u64 = 0u64
var PR_SQH1 : u64 = 0u64
var PR_SQH0 : u64 = 0u64

/* teeth counters + verdict order */
var PR_PYC : u64 = 0u64
var PR_TFC : u64 = 0u64
var PR_HSEP : u64 = 0u64
var PR_HSTR : u64 = 0u64
var PR_ORD : [u64; 8]
var PR_HFLESH : u64 = 0u64

/* compare PR_Z (3 limbs) against (b2,b1,b0) */
fn pr_cmp3z(b2: u64, b1: u64, b0: u64) -> i64 {
    let a2 : u64 = PR_Z[2]
    let a1 : u64 = PR_Z[1]
    let a0 : u64 = PR_Z[0]
    if a2 > b2 { return 1i64 }
    if a2 < b2 { return 0i64 - 1i64 }
    if a1 > b1 { return 1i64 }
    if a1 < b1 { return 0i64 - 1i64 }
    if a0 > b0 { return 1i64 }
    if a0 < b0 { return 0i64 - 1i64 }
    return 0i64
}

/* the lane bank + five round trips + three rational islands */
fn pr_har_lanes() -> u64 {
    if (PR_OMH1 | PR_OMH0) == 0u64 { return 1u64 }
    PR_WJL1[0] = 1u64 << 24u64
    PR_WJL0[0] = 0u64
    PR_WJH1[0] = 1u64 << 24u64
    PR_WJH0[0] = 0u64
    let mut j : u64 = 1u64
    while j < 32u64 {
        pr_mul128(PR_WJL1[j - 1u64], PR_WJL0[j - 1u64], PR_OML1, PR_OML0)
        if pr_wshr88() != 0i32 { return 1u64 }
        PR_WJL1[j] = PR_MHI
        PR_WJL0[j] = PR_MLO
        pr_mul128(PR_WJH1[j - 1u64], PR_WJH0[j - 1u64], PR_OMH1, PR_OMH0)
        if pr_wshr88() != 0i32 { return 1u64 }
        if PR_STK != 0u64 { pr_inc128() }
        PR_WJH1[j] = PR_MHI
        PR_WJH0[j] = PR_MLO
        /* strict monotone separation: hi_j < lo_{j-1} */
        let a1 : u64 = PR_WJH1[j]
        let a0 : u64 = PR_WJH0[j]
        let b1 : u64 = PR_WJL1[j - 1u64]
        let b0 : u64 = PR_WJL0[j - 1u64]
        if pr_cmp128(a1, a0, b1, b0) >= 0i64 { return 1u64 }
        j = j + 1u64
    }
    /* the five power round trips */
    let mut t : u64 = 0u64
    while t < 5u64 {
        let mut lane : u64 = 1u64
        if t == 1u64 { lane = 2u64 }
        if t == 2u64 { lane = 4u64 }
        if t == 3u64 { lane = 8u64 }
        if t == 4u64 { lane = 16u64 }
        let nsq : u64 = 5u64 - t
        let mut wl1 : u64 = PR_WJL1[lane]
        let mut wl0 : u64 = PR_WJL0[lane]
        let mut wh1 : u64 = PR_WJH1[lane]
        let mut wh0 : u64 = PR_WJH0[lane]
        let mut s : u64 = 0u64
        while s < nsq {
            pr_mul128(wl1, wl0, wl1, wl0)
            if pr_wshr88() != 0i32 { return 1u64 }
            wl1 = PR_MHI
            wl0 = PR_MLO
            pr_mul128(wh1, wh0, wh1, wh0)
            if pr_wshr88() != 0i32 { return 1u64 }
            if PR_STK != 0u64 { pr_inc128() }
            wh1 = PR_MHI
            wh0 = PR_MLO
            s = s + 1u64
        }
        pr_mul128by64(wl1, wl0, 10000u64)
        if pr_cmp3z(0u64, 1u64 << 24u64, 0u64) > 0i64 { return 1u64 }
        pr_mul128by64(wh1, wh0, 10000u64)
        if pr_cmp3z(0u64, 1u64 << 24u64, 0u64) < 0i64 { return 1u64 }
        t = t + 1u64
    }
    /* the rational islands: lanes 8/16/24 contain 1/10, 1/100, 1/1000 */
    let mut t2 : u64 = 0u64
    while t2 < 3u64 {
        let mut lane2 : u64 = 8u64
        let mut mul : u64 = 10u64
        if t2 == 1u64 { lane2 = 16u64   mul = 100u64 }
        if t2 == 2u64 { lane2 = 24u64   mul = 1000u64 }
        pr_mul128by64(PR_WJL1[lane2], PR_WJL0[lane2], mul)
        if pr_cmp3z(0u64, 1u64 << 24u64, 0u64) > 0i64 { return 1u64 }
        pr_mul128by64(PR_WJH1[lane2], PR_WJH0[lane2], mul)
        if pr_cmp3z(0u64, 1u64 << 24u64, 0u64) < 0i64 { return 1u64 }
        t2 = t2 + 1u64
    }
    return 0u64
}

/* P6 += (hi:lo) at limb position pos, carry rippled */
fn pr_p6_addat(pos: u64, lo: u64, hi: u64) -> i32 {
    let s0 : u64 = PR_P6[pos] + lo
    let mut c : u64 = 0u64
    if s0 < lo { c = 1u64 }
    PR_P6[pos] = s0
    let a : u64 = PR_P6[pos + 1u64] + hi
    let mut c2 : u64 = 0u64
    if a < hi { c2 = 1u64 }
    let b : u64 = a + c
    if b < c { c2 = c2 + 1u64 }
    PR_P6[pos + 1u64] = b
    let mut k : u64 = pos + 2u64
    let mut cr : u64 = c2
    while cr != 0u64 {
        if k >= 6u64 { cr = 0u64 }
        if cr != 0u64 {
            let d : u64 = PR_P6[k] + 1u64
            PR_P6[k] = d
            cr = 0u64
            if d == 0u64 { cr = 1u64 }
            k = k + 1u64
        }
    }
    return 0i32
}

/* PR_P6 = (a2:a1:a0) * (b2:b1:b0), exact 384-bit */
fn pr_m33(a0: u64, a1: u64, a2: u64, b0: u64, b1: u64, b2: u64) -> i32 {
    let mut k : u64 = 0u64
    while k < 6u64 {
        PR_P6[k] = 0u64
        k = k + 1u64
    }
    pr_mul64(a0, b0)
    pr_p6_addat(0u64, PR_MLO, PR_MHI)
    pr_mul64(a0, b1)
    pr_p6_addat(1u64, PR_MLO, PR_MHI)
    pr_mul64(a0, b2)
    pr_p6_addat(2u64, PR_MLO, PR_MHI)
    pr_mul64(a1, b0)
    pr_p6_addat(1u64, PR_MLO, PR_MHI)
    pr_mul64(a1, b1)
    pr_p6_addat(2u64, PR_MLO, PR_MHI)
    pr_mul64(a1, b2)
    pr_p6_addat(3u64, PR_MLO, PR_MHI)
    pr_mul64(a2, b0)
    pr_p6_addat(2u64, PR_MLO, PR_MHI)
    pr_mul64(a2, b1)
    pr_p6_addat(3u64, PR_MLO, PR_MHI)
    pr_mul64(a2, b2)
    pr_p6_addat(4u64, PR_MLO, PR_MHI)
    return 0i32
}

/* T9 = P6 << sh (sh <= 180) */
fn pr_t9_load_shl(sh: u64) -> u64 {
    let mut k : u64 = 0u64
    while k < 9u64 {
        PR_T9[k] = 0u64
        k = k + 1u64
    }
    if sh > 180u64 { return 1u64 }
    let w : u64 = sh / 64u64
    let b : u64 = sh % 64u64
    let mut k2 : u64 = 0u64
    while k2 < 6u64 {
        let v : u64 = PR_P6[k2]
        PR_T9[k2 + w] = PR_T9[k2 + w] | (v << b)
        if b != 0u64 {
            PR_T9[k2 + w + 1u64] = PR_T9[k2 + w + 1u64] | (v >> (64u64 - b))
        }
        k2 = k2 + 1u64
    }
    return 0u64
}

/* (PR_A9S, PR_A9L) += ss * T9, sign-magnitude */
fn pr_a9_add(ss: i64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let mut nz : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 9u64 {
        nz = nz | PR_T9[k]
        k = k + 1u64
    }
    if nz == 0u64 { return 0i32 }
    if PR_A9S == 0i64 {
        PR_A9S = ss
        k = 0u64
        while k < 9u64 {
            PR_A9L[k] = PR_T9[k]
            k = k + 1u64
        }
        return 0i32
    }
    if PR_A9S == ss {
        let mut carry : u64 = 0u64
        k = 0u64
        while k < 9u64 {
            let a : u64 = PR_A9L[k] + PR_T9[k]
            let mut c2 : u64 = 0u64
            if a < PR_T9[k] { c2 = 1u64 }
            let b : u64 = a + carry
            if b < carry { c2 = c2 + 1u64 }
            PR_A9L[k] = b
            carry = c2
            k = k + 1u64
        }
        if carry != 0u64 { return 1i32 }
        return 0i32
    }
    let mut cmp : i64 = 0i64
    k = 9u64
    while k != 0u64 {
        k = k - 1u64
        if cmp == 0i64 {
            let x : u64 = PR_A9L[k]
            let y : u64 = PR_T9[k]
            if x > y { cmp = 1i64 }
            if x < y { cmp = 0i64 - 1i64 }
        }
    }
    if cmp == 0i64 {
        PR_A9S = 0i64
        k = 0u64
        while k < 9u64 {
            PR_A9L[k] = 0u64
            k = k + 1u64
        }
        return 0i32
    }
    if cmp > 0i64 {
        let mut borrow : u64 = 0u64
        k = 0u64
        while k < 9u64 {
            let d : u64 = PR_A9L[k] - PR_T9[k]
            let mut b2 : u64 = 0u64
            if PR_A9L[k] < PR_T9[k] { b2 = 1u64 }
            let e : u64 = d - borrow
            if d < borrow { b2 = b2 + 1u64 }
            PR_A9L[k] = e
            borrow = b2
            k = k + 1u64
        }
        return 0i32
    }
    let mut borrow2 : u64 = 0u64
    k = 0u64
    while k < 9u64 {
        let d3 : u64 = PR_T9[k] - PR_A9L[k]
        let mut b3 : u64 = 0u64
        if PR_T9[k] < PR_A9L[k] { b3 = 1u64 }
        let e3 : u64 = d3 - borrow2
        if d3 < borrow2 { b3 = b3 + 1u64 }
        PR_A9L[k] = e3
        borrow2 = b3
        k = k + 1u64
    }
    PR_A9S = ss
    return 0i32
}

/* one exact product q-rope-row * k-rope-row into the 9-limb accumulator.
 * qsrc 0 = the crowned head's standing rows; 1 = head PR_QH's choir rows */
var PR_QH : u64 = 0u64
fn pr_har_term(qr: u64, kr: u64, sgnm: i64, qsrc: u64) -> u64 {
    let mut qs : i64 = 0i64
    let mut qe : i64 = 0i64
    if qsrc == 0u64 {
        qs = mb_gz_cr_s(qr)
        qe = mb_gz_cr_e(qr)
    }
    if qsrc == 1u64 {
        qs = mb_qr_s(PR_QH, qr)
        qe = mb_qr_e(PR_QH, qr)
    }
    let ks : i64 = mb_gz_dr_s(kr)
    if qs == 0i64 { return 0u64 }
    if ks == 0i64 { return 0u64 }
    let e : i64 = qe + mb_gz_dr_e(kr)
    let sh : i64 = e - PR_EALN
    if sh < 0i64 { return 1u64 }
    if sh > 180i64 { return 1u64 }
    if qsrc == 0u64 {
        pr_m33(mb_gz_cr_l(qr, 0u64), mb_gz_cr_l(qr, 1u64), mb_gz_cr_l(qr, 2u64), mb_gz_dr_l(kr, 0u64), mb_gz_dr_l(kr, 1u64), mb_gz_dr_l(kr, 2u64))
    }
    if qsrc == 1u64 {
        pr_m33(mb_qr_l(PR_QH, qr, 0u64), mb_qr_l(PR_QH, qr, 1u64), mb_qr_l(PR_QH, qr, 2u64), mb_gz_dr_l(kr, 0u64), mb_gz_dr_l(kr, 1u64), mb_gz_dr_l(kr, 2u64))
    }
    if pr_t9_load_shl(sh as u64) != 0u64 { return 1u64 }
    let mut sg : i64 = qs
    if ks < 0i64 { sg = 0i64 - sg }
    if sgnm < 0i64 { sg = 0i64 - sg }
    if pr_a9_add(sg) != 0i32 { return 1u64 }
    return 0u64
}

/* the exact P/X integers, globally aligned.  0 ok / 1 red / 2 guard */
fn pr_har_px(qsrc: u64) -> u64 {
    let mut emin : i64 = 1000000i64
    let mut emax : i64 = 0i64 - 1000000i64
    let mut j : u64 = 0u64
    while j < 32u64 {
        let mut t : u64 = 0u64
        while t < 4u64 {
            let mut qr : u64 = j
            if t >= 2u64 { qr = j + 32u64 }
            let mut kr : u64 = j
            if t == 1u64 { kr = j + 32u64 }
            if t == 3u64 { kr = j + 32u64 }
            let mut qs : i64 = 0i64
            let mut qe : i64 = 0i64
            if qsrc == 0u64 {
                qs = mb_gz_cr_s(qr)
                qe = mb_gz_cr_e(qr)
            }
            if qsrc == 1u64 {
                qs = mb_qr_s(PR_QH, qr)
                qe = mb_qr_e(PR_QH, qr)
            }
            let ks : i64 = mb_gz_dr_s(kr)
            if qs != 0i64 {
                if ks != 0i64 {
                    let e : i64 = qe + mb_gz_dr_e(kr)
                    if e < emin { emin = e }
                    if e > emax { emax = e }
                }
            }
            t = t + 1u64
        }
        j = j + 1u64
    }
    if emin == 1000000i64 { return 1u64 }
    let spread : i64 = emax - emin
    if spread > 180i64 { return 2u64 }
    PR_EALN = emin
    j = 0u64
    while j < 32u64 {
        PR_A9S = 0i64
        let mut k : u64 = 0u64
        while k < 9u64 {
            PR_A9L[k] = 0u64
            k = k + 1u64
        }
        if pr_har_term(j, j, 1i64, qsrc) != 0u64 { return 1u64 }
        if pr_har_term(j + 32u64, j + 32u64, 1i64, qsrc) != 0u64 { return 1u64 }
        PR_PJS[j] = PR_A9S
        k = 0u64
        while k < 9u64 {
            PR_PJL[j * 9u64 + k] = PR_A9L[k]
            k = k + 1u64
        }
        PR_A9S = 0i64
        k = 0u64
        while k < 9u64 {
            PR_A9L[k] = 0u64
            k = k + 1u64
        }
        if pr_har_term(j, j + 32u64, 1i64, qsrc) != 0u64 { return 1u64 }
        if pr_har_term(j + 32u64, j, 0i64 - 1i64, qsrc) != 0u64 { return 1u64 }
        PR_XJS[j] = PR_A9S
        k = 0u64
        while k < 9u64 {
            PR_XJL[j * 9u64 + k] = PR_A9L[k]
            k = k + 1u64
        }
        j = j + 1u64
    }
    return 0u64
}

/* signed endpoint compare: (sa, a1:a0) vs (sb, b1:b0) */
fn pr_se_cmp(sa: i64, a1: u64, a0: u64, sb: i64, b1: u64, b0: u64) -> i64 {
    if sa > sb { return 1i64 }
    if sa < sb { return 0i64 - 1i64 }
    if sa == 0i64 { return 0i64 }
    let c : i64 = pr_cmp128(a1, a0, b1, b0)
    if sa < 0i64 { return 0i64 - c }
    return c
}

/* directed signed endpoint product into PR_P_S/PR_P_H/PR_P_L.
 * dir 0 = round toward -inf, 1 = toward +inf */
fn pr_sedp(sa: i64, a1: u64, a0: u64, sb: i64, b1: u64, b0: u64, dir: u64) -> i32 {
    if sa == 0i64 {
        PR_P_S = 0i64
        PR_P_H = 0u64
        PR_P_L = 0u64
        return 0i32
    }
    if sb == 0i64 {
        PR_P_S = 0i64
        PR_P_H = 0u64
        PR_P_L = 0u64
        return 0i32
    }
    let mut rs : i64 = 1i64
    if sa != sb { rs = 0i64 - 1i64 }
    pr_mul128(a1, a0, b1, b0)
    if pr_wshr88() != 0i32 { return 1i32 }
    let mut up : u64 = 0u64
    if rs > 0i64 {
        if dir == 1u64 { up = 1u64 }
    }
    if rs < 0i64 {
        if dir == 0u64 { up = 1u64 }
    }
    if up == 1u64 {
        if PR_STK != 0u64 { pr_inc128() }
    }
    PR_P_S = rs
    PR_P_H = PR_MHI
    PR_P_L = PR_MLO
    if (PR_MHI | PR_MLO) == 0u64 { PR_P_S = 0i64 }
    return 0i32
}

/* signed interval product [QA,QB] x [RA,RB] -> [IRL, IRH] */
fn pr_siv_mul() -> i32 {
    let mut p : u64 = 0u64
    while p < 8u64 {
        let cand : u64 = p % 4u64
        let dir : u64 = p / 4u64
        let mut xs : i64 = PR_QAS
        let mut x1 : u64 = PR_QA1
        let mut x0 : u64 = PR_QA0
        if cand >= 2u64 {
            xs = PR_QBS
            x1 = PR_QB1
            x0 = PR_QB0
        }
        let mut ys : i64 = PR_RAS
        let mut y1 : u64 = PR_RA1
        let mut y0 : u64 = PR_RA0
        if (cand & 1u64) == 1u64 {
            ys = PR_RBS
            y1 = PR_RB1
            y0 = PR_RB0
        }
        if pr_sedp(xs, x1, x0, ys, y1, y0, dir) != 0i32 { return 1i32 }
        if dir == 0u64 {
            if p == 0u64 {
                PR_IRLS = PR_P_S
                PR_IRL1 = PR_P_H
                PR_IRL0 = PR_P_L
            }
            if p != 0u64 {
                if pr_se_cmp(PR_P_S, PR_P_H, PR_P_L, PR_IRLS, PR_IRL1, PR_IRL0) < 0i64 {
                    PR_IRLS = PR_P_S
                    PR_IRL1 = PR_P_H
                    PR_IRL0 = PR_P_L
                }
            }
        }
        if dir == 1u64 {
            if p == 4u64 {
                PR_IRHS = PR_P_S
                PR_IRH1 = PR_P_H
                PR_IRH0 = PR_P_L
            }
            if p != 4u64 {
                if pr_se_cmp(PR_P_S, PR_P_H, PR_P_L, PR_IRHS, PR_IRH1, PR_IRH0) > 0i64 {
                    PR_IRHS = PR_P_S
                    PR_IRH1 = PR_P_H
                    PR_IRH0 = PR_P_L
                }
            }
        }
        p = p + 1u64
    }
    return 0i32
}

/* signed interval square -> nonnegative [SQL, SQH] */
fn pr_siv_sq(ls: i64, l1: u64, l0: u64, hs: i64, h1: u64, h0: u64) -> i32 {
    if ls >= 0i64 {
        pr_mul128(l1, l0, l1, l0)
        if pr_wshr88() != 0i32 { return 1i32 }
        PR_SQL1 = PR_MHI
        PR_SQL0 = PR_MLO
        pr_mul128(h1, h0, h1, h0)
        if pr_wshr88() != 0i32 { return 1i32 }
        if PR_STK != 0u64 { pr_inc128() }
        PR_SQH1 = PR_MHI
        PR_SQH0 = PR_MLO
        return 0i32
    }
    if hs <= 0i64 {
        pr_mul128(h1, h0, h1, h0)
        if pr_wshr88() != 0i32 { return 1i32 }
        PR_SQL1 = PR_MHI
        PR_SQL0 = PR_MLO
        pr_mul128(l1, l0, l1, l0)
        if pr_wshr88() != 0i32 { return 1i32 }
        if PR_STK != 0u64 { pr_inc128() }
        PR_SQH1 = PR_MHI
        PR_SQH0 = PR_MLO
        return 0i32
    }
    let mut m1 : u64 = l1
    let mut m0 : u64 = l0
    if pr_cmp128(h1, h0, l1, l0) > 0i64 {
        m1 = h1
        m0 = h0
    }
    PR_SQL1 = 0u64
    PR_SQL0 = 0u64
    pr_mul128(m1, m0, m1, m0)
    if pr_wshr88() != 0i32 { return 1i32 }
    if PR_STK != 0u64 { pr_inc128() }
    PR_SQH1 = PR_MHI
    PR_SQH0 = PR_MLO
    return 0i32
}

/* signed 2^88 - (m1:m0) into PR_P_* (exact) */
fn pr_sfrom1(m1: u64, m0: u64) -> i32 {
    let one1 : u64 = 1u64 << 24u64
    let c : i64 = pr_cmp128(m1, m0, one1, 0u64)
    if c == 0i64 {
        PR_P_S = 0i64
        PR_P_H = 0u64
        PR_P_L = 0u64
        return 0i32
    }
    if c < 0i64 {
        let mut b : u64 = 0u64
        let r0 : u64 = 0u64 - m0
        if 0u64 < m0 { b = 1u64 }
        PR_P_S = 1i64
        PR_P_L = r0
        PR_P_H = one1 - m1 - b
        return 0i32
    }
    PR_P_S = 0i64 - 1i64
    PR_P_L = m0
    PR_P_H = m1 - one1
    return 0i32
}

/* one signed doubling rung on ([sin],[cos]); both cos forms must overlap */
fn pr_har_dbl() -> u64 {
    PR_QAS = PR_HSLS
    PR_QA1 = PR_HSL1
    PR_QA0 = PR_HSL0
    PR_QBS = PR_HSHS
    PR_QB1 = PR_HSH1
    PR_QB0 = PR_HSH0
    PR_RAS = PR_HCLS
    PR_RA1 = PR_HCL1
    PR_RA0 = PR_HCL0
    PR_RBS = PR_HCHS
    PR_RB1 = PR_HCH1
    PR_RB0 = PR_HCH0
    if pr_siv_mul() != 0i32 { return 1u64 }
    let s2ls : i64 = PR_IRLS
    let s2l1 : u64 = (PR_IRL1 << 1u64) | (PR_IRL0 >> 63u64)
    let s2l0 : u64 = PR_IRL0 << 1u64
    let s2hs : i64 = PR_IRHS
    let s2h1 : u64 = (PR_IRH1 << 1u64) | (PR_IRH0 >> 63u64)
    let s2h0 : u64 = PR_IRH0 << 1u64
    if pr_siv_sq(PR_HSLS, PR_HSL1, PR_HSL0, PR_HSHS, PR_HSH1, PR_HSH0) != 0i32 { return 1u64 }
    let q1 : u64 = (PR_SQH1 << 1u64) | (PR_SQH0 >> 63u64)
    let q0 : u64 = PR_SQH0 << 1u64
    pr_sfrom1(q1, q0)
    let als : i64 = PR_P_S
    let al1 : u64 = PR_P_H
    let al0 : u64 = PR_P_L
    let r1x : u64 = (PR_SQL1 << 1u64) | (PR_SQL0 >> 63u64)
    let r0x : u64 = PR_SQL0 << 1u64
    pr_sfrom1(r1x, r0x)
    let ahs : i64 = PR_P_S
    let ah1 : u64 = PR_P_H
    let ah0 : u64 = PR_P_L
    if pr_siv_sq(PR_HCLS, PR_HCL1, PR_HCL0, PR_HCHS, PR_HCH1, PR_HCH0) != 0i32 { return 1u64 }
    let u1 : u64 = (PR_SQL1 << 1u64) | (PR_SQL0 >> 63u64)
    let u0 : u64 = PR_SQL0 << 1u64
    pr_sfrom1(u1, u0)
    let bls : i64 = 0i64 - PR_P_S
    let bl1 : u64 = PR_P_H
    let bl0 : u64 = PR_P_L
    let v1 : u64 = (PR_SQH1 << 1u64) | (PR_SQH0 >> 63u64)
    let v0 : u64 = PR_SQH0 << 1u64
    pr_sfrom1(v1, v0)
    let bhs : i64 = 0i64 - PR_P_S
    let bh1 : u64 = PR_P_H
    let bh0 : u64 = PR_P_L
    if pr_se_cmp(als, al1, al0, bhs, bh1, bh0) > 0i64 { return 1u64 }
    if pr_se_cmp(bls, bl1, bl0, ahs, ah1, ah0) > 0i64 { return 1u64 }
    PR_TFC = PR_TFC + 1u64
    let mut cls : i64 = als
    let mut cl1 : u64 = al1
    let mut cl0 : u64 = al0
    if pr_se_cmp(bls, bl1, bl0, als, al1, al0) > 0i64 {
        cls = bls
        cl1 = bl1
        cl0 = bl0
    }
    let mut chs : i64 = ahs
    let mut ch1 : u64 = ah1
    let mut ch0 : u64 = ah0
    if pr_se_cmp(bhs, bh1, bh0, ahs, ah1, ah0) < 0i64 {
        chs = bhs
        ch1 = bh1
        ch0 = bh0
    }
    PR_HSLS = s2ls
    PR_HSL1 = s2l1
    PR_HSL0 = s2l0
    PR_HSHS = s2hs
    PR_HSH1 = s2h1
    PR_HSH0 = s2h0
    PR_HCLS = cls
    PR_HCL1 = cl1
    PR_HCL0 = cl0
    PR_HCHS = chs
    PR_HCH1 = ch1
    PR_HCH0 = ch0
    return 0u64
}

/* the general delta-angle ladder: lane j, delta dd -> signed [sin],[cos] */
fn pr_har_ladder(j: u64, dd: u64) -> u64 {
    if dd == 0u64 {
        PR_HSLS = 0i64
        PR_HSL1 = 0u64
        PR_HSL0 = 0u64
        PR_HSHS = 0i64
        PR_HSH1 = 0u64
        PR_HSH0 = 0u64
        PR_HCLS = 1i64
        PR_HCL1 = 1u64 << 24u64
        PR_HCL0 = 0u64
        PR_HCHS = 1i64
        PR_HCH1 = 1u64 << 24u64
        PR_HCH0 = 0u64
        return 0u64
    }
    pr_mul128by64(PR_WJL1[j], PR_WJL0[j], dd)
    if PR_Z[2] != 0u64 { return 1u64 }
    let tl1 : u64 = PR_Z[1]
    let tl0 : u64 = PR_Z[0]
    pr_mul128by64(PR_WJH1[j], PR_WJH0[j], dd)
    if PR_Z[2] != 0u64 { return 1u64 }
    let th1 : u64 = PR_Z[1]
    let th0 : u64 = PR_Z[0]
    /* choose the halving depth and the outward 2^-48 endpoints */
    let mut hh : u64 = 0u64
    let mut m48l : u64 = 0u64
    let mut m48h : u64 = 0u64
    let mut ok : u64 = 0u64
    while ok == 0u64 {
        if hh > 6u64 { return 1u64 }
        let mut yl1 : u64 = tl1
        let mut yl0 : u64 = tl0
        let mut yh1 : u64 = th1
        let mut yh0 : u64 = th0
        let mut stk : u64 = 0u64
        if hh != 0u64 {
            yl0 = (tl0 >> hh) | (tl1 << (64u64 - hh))
            yl1 = tl1 >> hh
            stk = th0 & ((1u64 << hh) - 1u64)
            yh0 = (th0 >> hh) | (th1 << (64u64 - hh))
            yh1 = th1 >> hh
        }
        m48l = (yl1 << 24u64) | (yl0 >> 40u64)
        m48h = (yh1 << 24u64) | (yh0 >> 40u64)
        let dropped : u64 = (yh0 & 1099511627775u64) | stk
        if dropped != 0u64 { m48h = m48h + 1u64 }
        let lim : u64 = 1u64 << 47u64
        if m48h <= lim { ok = 1u64 }
        if ok == 0u64 { hh = hh + 1u64 }
    }
    /* base: monotone Taylor endpoints on the first quadrant */
    if pr_sincos(m48l, 48u64) != 0i32 { return 1u64 }
    let bsl1 : u64 = PR_SN1
    let bsl0 : u64 = PR_SN0
    let bch1 : u64 = PR_CX1
    let bch0 : u64 = PR_CX0
    if pr_sincos(m48h, 48u64) != 0i32 { return 1u64 }
    let bsh1 : u64 = PR_SX1
    let bsh0 : u64 = PR_SX0
    let bcl1 : u64 = PR_CN1
    let bcl0 : u64 = PR_CN0
    PR_HSLS = 1i64
    if (bsl1 | bsl0) == 0u64 { PR_HSLS = 0i64 }
    PR_HSL1 = bsl1
    PR_HSL0 = bsl0
    PR_HSHS = 1i64
    if (bsh1 | bsh0) == 0u64 { PR_HSHS = 0i64 }
    PR_HSH1 = bsh1
    PR_HSH0 = bsh0
    PR_HCLS = 1i64
    if (bcl1 | bcl0) == 0u64 { PR_HCLS = 0i64 }
    PR_HCL1 = bcl1
    PR_HCL0 = bcl0
    PR_HCHS = 1i64
    if (bch1 | bch0) == 0u64 { PR_HCHS = 0i64 }
    PR_HCH1 = bch1
    PR_HCH0 = bch0
    /* the signed doublings back up to theta */
    let mut q : u64 = 0u64
    while q < hh {
        if pr_har_dbl() != 0u64 { return 1u64 }
        q = q + 1u64
    }
    /* pythagoras must contain 1 */
    if pr_siv_sq(PR_HSLS, PR_HSL1, PR_HSL0, PR_HSHS, PR_HSH1, PR_HSH0) != 0i32 { return 1u64 }
    let pa_l1 : u64 = PR_SQL1
    let pa_l0 : u64 = PR_SQL0
    let pa_h1 : u64 = PR_SQH1
    let pa_h0 : u64 = PR_SQH0
    if pr_siv_sq(PR_HCLS, PR_HCL1, PR_HCL0, PR_HCHS, PR_HCH1, PR_HCH0) != 0i32 { return 1u64 }
    let mut sl0 : u64 = pa_l0 + PR_SQL0
    let mut sl1 : u64 = pa_l1 + PR_SQL1
    if sl0 < PR_SQL0 { sl1 = sl1 + 1u64 }
    let mut sh0 : u64 = pa_h0 + PR_SQH0
    let mut sh1 : u64 = pa_h1 + PR_SQH1
    if sh0 < PR_SQH0 { sh1 = sh1 + 1u64 }
    let one1 : u64 = 1u64 << 24u64
    if pr_cmp128(sl1, sl0, one1, 0u64) > 0i64 { return 1u64 }
    if pr_cmp128(sh1, sh0, one1, 0u64) < 0i64 { return 1u64 }
    PR_PYC = PR_PYC + 1u64
    return 0u64
}

/* T14 += (hi:lo) at position pos */
fn pr_t14_addat(pos: u64, lo: u64, hi: u64) -> i32 {
    let s0 : u64 = PR_T14[pos] + lo
    let mut c : u64 = 0u64
    if s0 < lo { c = 1u64 }
    PR_T14[pos] = s0
    let a : u64 = PR_T14[pos + 1u64] + hi
    let mut c2 : u64 = 0u64
    if a < hi { c2 = 1u64 }
    let b : u64 = a + c
    if b < c { c2 = c2 + 1u64 }
    PR_T14[pos + 1u64] = b
    let mut k : u64 = pos + 2u64
    let mut cr : u64 = c2
    while cr != 0u64 {
        if k >= 14u64 { cr = 0u64 }
        if cr != 0u64 {
            let d : u64 = PR_T14[k] + 1u64
            PR_T14[k] = d
            cr = 0u64
            if d == 0u64 { cr = 1u64 }
            k = k + 1u64
        }
    }
    return 0i32
}

/* T14 = |P or X row j| * (m1:m0), exact */
fn pr_mul_9x2(which: u64, j: u64, m1: u64, m0: u64) -> i32 {
    let mut k : u64 = 0u64
    while k < 14u64 {
        PR_T14[k] = 0u64
        k = k + 1u64
    }
    let mut i : u64 = 0u64
    while i < 9u64 {
        let mut v : u64 = PR_PJL[j * 9u64 + i]
        if which == 1u64 { v = PR_XJL[j * 9u64 + i] }
        if v != 0u64 {
            pr_mul64(v, m0)
            pr_t14_addat(i, PR_MLO, PR_MHI)
            if m1 != 0u64 {
                pr_mul64(v, m1)
                pr_t14_addat(i + 1u64, PR_MLO, PR_MHI)
            }
        }
        i = i + 1u64
    }
    return 0i32
}

/* (acc dst 0=lo,1=hi) += ss * T14, sign-magnitude via the U14 mirror */
fn pr_s14_add(dst: u64, ss: i64) -> i32 {
    if ss == 0i64 { return 0i32 }
    let mut nz : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 14u64 {
        nz = nz | PR_T14[k]
        k = k + 1u64
    }
    if nz == 0u64 { return 0i32 }
    PR_USS = PR_ALS
    if dst == 1u64 { PR_USS = PR_AHS }
    k = 0u64
    while k < 14u64 {
        let mut v : u64 = PR_AL[k]
        if dst == 1u64 { v = PR_AH[k] }
        PR_U14[k] = v
        k = k + 1u64
    }
    let mut done : u64 = 0u64
    if PR_USS == 0i64 {
        PR_USS = ss
        k = 0u64
        while k < 14u64 {
            PR_U14[k] = PR_T14[k]
            k = k + 1u64
        }
        done = 1u64
    }
    if done == 0u64 {
        if PR_USS == ss {
            let mut carry : u64 = 0u64
            k = 0u64
            while k < 14u64 {
                let a : u64 = PR_U14[k] + PR_T14[k]
                let mut c2 : u64 = 0u64
                if a < PR_T14[k] { c2 = 1u64 }
                let b : u64 = a + carry
                if b < carry { c2 = c2 + 1u64 }
                PR_U14[k] = b
                carry = c2
                k = k + 1u64
            }
            if carry != 0u64 { return 1i32 }
        }
        if PR_USS != ss {
            let mut cmp : i64 = 0i64
            k = 14u64
            while k != 0u64 {
                k = k - 1u64
                if cmp == 0i64 {
                    let x : u64 = PR_U14[k]
                    let y : u64 = PR_T14[k]
                    if x > y { cmp = 1i64 }
                    if x < y { cmp = 0i64 - 1i64 }
                }
            }
            if cmp == 0i64 {
                PR_USS = 0i64
                k = 0u64
                while k < 14u64 {
                    PR_U14[k] = 0u64
                    k = k + 1u64
                }
            }
            if cmp > 0i64 {
                let mut borrow : u64 = 0u64
                k = 0u64
                while k < 14u64 {
                    let d : u64 = PR_U14[k] - PR_T14[k]
                    let mut b2 : u64 = 0u64
                    if PR_U14[k] < PR_T14[k] { b2 = 1u64 }
                    let e : u64 = d - borrow
                    if d < borrow { b2 = b2 + 1u64 }
                    PR_U14[k] = e
                    borrow = b2
                    k = k + 1u64
                }
            }
            if cmp < 0i64 {
                let mut borrow2 : u64 = 0u64
                k = 0u64
                while k < 14u64 {
                    let d3 : u64 = PR_T14[k] - PR_U14[k]
                    let mut b3 : u64 = 0u64
                    if PR_T14[k] < PR_U14[k] { b3 = 1u64 }
                    let e3 : u64 = d3 - borrow2
                    if d3 < borrow2 { b3 = b3 + 1u64 }
                    PR_U14[k] = e3
                    borrow2 = b3
                    k = k + 1u64
                }
                PR_USS = ss
            }
        }
    }
    if dst == 0u64 {
        PR_ALS = PR_USS
        k = 0u64
        while k < 14u64 {
            PR_AL[k] = PR_U14[k]
            k = k + 1u64
        }
    }
    if dst == 1u64 {
        PR_AHS = PR_USS
        k = 0u64
        while k < 14u64 {
            PR_AH[k] = PR_U14[k]
            k = k + 1u64
        }
    }
    return 0i32
}

/* assemble R(dd): both bounds, exact integer x endpoint products */
fn pr_har_asm(dd: u64) -> u64 {
    PR_ALS = 0i64
    PR_AHS = 0i64
    let mut k : u64 = 0u64
    while k < 14u64 {
        PR_AL[k] = 0u64
        PR_AH[k] = 0u64
        k = k + 1u64
    }
    let mut j : u64 = 0u64
    while j < 32u64 {
        if pr_har_ladder(j, dd) != 0u64 { return 1u64 }
        let ps : i64 = PR_PJS[j]
        if ps != 0i64 {
            let mut es : i64 = PR_HCLS
            let mut e1 : u64 = PR_HCL1
            let mut e0 : u64 = PR_HCL0
            if ps < 0i64 {
                es = PR_HCHS
                e1 = PR_HCH1
                e0 = PR_HCH0
            }
            if es != 0i64 {
                pr_mul_9x2(0u64, j, e1, e0)
                let mut sg : i64 = ps
                if es < 0i64 { sg = 0i64 - sg }
                if pr_s14_add(0u64, sg) != 0i32 { return 1u64 }
            }
            let mut fs : i64 = PR_HCHS
            let mut f1 : u64 = PR_HCH1
            let mut f0 : u64 = PR_HCH0
            if ps < 0i64 {
                fs = PR_HCLS
                f1 = PR_HCL1
                f0 = PR_HCL0
            }
            if fs != 0i64 {
                pr_mul_9x2(0u64, j, f1, f0)
                let mut sg2 : i64 = ps
                if fs < 0i64 { sg2 = 0i64 - sg2 }
                if pr_s14_add(1u64, sg2) != 0i32 { return 1u64 }
            }
        }
        let xs : i64 = PR_XJS[j]
        if xs != 0i64 {
            let mut gs : i64 = PR_HSLS
            let mut g1 : u64 = PR_HSL1
            let mut g0 : u64 = PR_HSL0
            if xs < 0i64 {
                gs = PR_HSHS
                g1 = PR_HSH1
                g0 = PR_HSH0
            }
            if gs != 0i64 {
                pr_mul_9x2(1u64, j, g1, g0)
                let mut sg3 : i64 = xs
                if gs < 0i64 { sg3 = 0i64 - sg3 }
                if pr_s14_add(0u64, sg3) != 0i32 { return 1u64 }
            }
            let mut hs : i64 = PR_HSHS
            let mut h1 : u64 = PR_HSH1
            let mut h0 : u64 = PR_HSH0
            if xs < 0i64 {
                hs = PR_HSLS
                h1 = PR_HSL1
                h0 = PR_HSL0
            }
            if hs != 0i64 {
                pr_mul_9x2(1u64, j, h1, h0)
                let mut sg4 : i64 = xs
                if hs < 0i64 { sg4 = 0i64 - sg4 }
                if pr_s14_add(1u64, sg4) != 0i32 { return 1u64 }
            }
        }
        j = j + 1u64
    }
    /* the bounds must be ordered */
    let mut cmp : i64 = 0i64
    if PR_ALS > PR_AHS { cmp = 1i64 }
    if PR_ALS == PR_AHS {
        if PR_ALS != 0i64 {
            let mut c2 : i64 = 0i64
            k = 14u64
            while k != 0u64 {
                k = k - 1u64
                if c2 == 0i64 {
                    let x : u64 = PR_AL[k]
                    let y : u64 = PR_AH[k]
                    if x > y { c2 = 1i64 }
                    if x < y { c2 = 0i64 - 1i64 }
                }
            }
            if PR_ALS < 0i64 { c2 = 0i64 - c2 }
            cmp = c2
        }
    }
    if cmp > 0i64 { return 1u64 }
    PR_RDLS[dd] = PR_ALS
    PR_RDHS[dd] = PR_AHS
    k = 0u64
    while k < 14u64 {
        PR_RDLL[dd * 14u64 + k] = PR_AL[k]
        PR_RDHL[dd * 14u64 + k] = PR_AH[k]
        k = k + 1u64
    }
    return 0u64
}

/* the anchor: R(0) must equal the standing N2 of the crowned head,
 * sign, exponent and limb for limb */
fn pr_har_anchor() -> u64 {
    let hd : u64 = mb_gz_head()
    let n2s : i64 = mb_gz_n2_s(hd)
    let n2e : i64 = mb_gz_n2_e(hd)
    /* R sits on the 2^(EALN-88) grid (cos=1 is the integer 2^88), so the
     * standing N2 at 2^n2e must rise by the 88 as well */
    let shd : i64 = (n2e - PR_EALN) + 88i64
    if shd < 0i64 { return 5u64 }
    if shd > 448i64 { return 6u64 }
    let mut k : u64 = 0u64
    while k < 14u64 {
        PR_T14[k] = 0u64
        k = k + 1u64
    }
    let w : u64 = (shd as u64) / 64u64
    let b : u64 = (shd as u64) % 64u64
    if w + 7u64 > 14u64 { return 1u64 }
    k = 0u64
    while k < 6u64 {
        let v : u64 = mb_gz_n2_l(hd, k)
        PR_T14[k + w] = PR_T14[k + w] | (v << b)
        if b != 0u64 {
            PR_T14[k + w + 1u64] = PR_T14[k + w + 1u64] | (v >> (64u64 - b))
        }
        k = k + 1u64
    }
    let mut nz : u64 = 0u64
    k = 0u64
    while k < 14u64 {
        nz = nz | PR_T14[k]
        k = k + 1u64
    }
    let mut n2sig : i64 = n2s
    if nz == 0u64 { n2sig = 0i64 }
    let rdl0 : i64 = PR_RDLS[0]
    let rdh0 : i64 = PR_RDHS[0]
    if rdl0 != n2sig { return 2u64 }
    if rdh0 != n2sig { return 3u64 }
    k = 0u64
    while k < 14u64 {
        let a : u64 = PR_RDLL[k]
        let b2 : u64 = PR_RDHL[k]
        let c : u64 = PR_T14[k]
        if a != c { return 100u64 + k }
        if b2 != c { return 200u64 + k }
        k = k + 1u64
    }
    return 0u64
}

/* signed compare of stored bounds: f 0 = lo, 1 = hi */
fn pr_rd_cmp(fa: u64, a: u64, fb: u64, b: u64) -> i64 {
    let mut sa : i64 = PR_RDLS[a]
    if fa == 1u64 { sa = PR_RDHS[a] }
    let mut sb : i64 = PR_RDLS[b]
    if fb == 1u64 { sb = PR_RDHS[b] }
    if sa > sb { return 1i64 }
    if sa < sb { return 0i64 - 1i64 }
    if sa == 0i64 { return 0i64 }
    let mut cmp : i64 = 0i64
    let mut k : u64 = 14u64
    while k != 0u64 {
        k = k - 1u64
        if cmp == 0i64 {
            let mut va : u64 = PR_RDLL[a * 14u64 + k]
            if fa == 1u64 { va = PR_RDHL[a * 14u64 + k] }
            let mut vb : u64 = PR_RDLL[b * 14u64 + k]
            if fb == 1u64 { vb = PR_RDHL[b * 14u64 + k] }
            if va > vb { cmp = 1i64 }
            if va < vb { cmp = 0i64 - 1i64 }
        }
    }
    if sa < 0i64 { return 0i64 - cmp }
    return cmp
}

/* the cross-position verdict: sort the deltas, census the separations */
fn pr_har_verdict() -> u64 {
    let mut i : u64 = 0u64
    while i < 8u64 {
        PR_ORD[i] = i
        i = i + 1u64
    }
    i = 1u64
    while i < 8u64 {
        let key : u64 = PR_ORD[i]
        let mut p : u64 = i
        let mut go : u8 = 1u8
        while go == 1u8 {
            go = 0u8
            if p > 0u64 {
                let prev : u64 = PR_ORD[p - 1u64]
                if pr_rd_cmp(0u64, key, 0u64, prev) > 0i64 {
                    PR_ORD[p] = prev
                    p = p - 1u64
                    go = 1u8
                }
            }
        }
        PR_ORD[p] = key
        i = i + 1u64
    }
    let mut sep : u64 = 0u64
    let mut strad : u64 = 0u64
    i = 0u64
    while i < 8u64 {
        let mut j2 : u64 = i + 1u64
        while j2 < 8u64 {
            let up : i64 = pr_rd_cmp(0u64, i, 1u64, j2)
            let dn : i64 = pr_rd_cmp(1u64, i, 0u64, j2)
            let mut s : u64 = 0u64
            if up > 0i64 { s = 1u64 }
            if dn < 0i64 { s = 1u64 }
            if s == 1u64 { sep = sep + 1u64 }
            if s == 0u64 { strad = strad + 1u64 }
            j2 = j2 + 1u64
        }
        i = i + 1u64
    }
    PR_HSEP = sep
    PR_HSTR = strad
    return 0u64
}

fn pr_arm379() -> u64 {
    PR_PYC = 0u64
    PR_TFC = 0u64
    if pr_har_lanes() != 0u64 { return 379u64 }
    let gz : u64 = mb_gz_ok()
    let nr : u64 = mb_gz_nrope()
    let mut fleshed : u64 = 0u64
    let mut guard : u64 = 0u64
    if gz == 1u64 {
        if nr == 64u64 {
            let px : u64 = pr_har_px(0u64)
            if px == 1u64 { return 379u64 }
            if px == 2u64 { guard = 1u64 }
            if px == 0u64 {
                let mut dd : u64 = 0u64
                while dd < 8u64 {
                    if pr_har_asm(dd) != 0u64 { return 379u64 }
                    dd = dd + 1u64
                }
                if pr_har_anchor() != 0u64 { return 379u64 }
                pr_har_verdict()
                fleshed = 1u64
                PR_HFLESH = 1u64
            }
        }
    }
    pr_rs("the harmonia: lanes=32 chain=omega1-powers round-trips(1,2,4,8,16)=contain-1 islands(8,16,24)=(1/10,1/100,1/1000)-contained monotone=separated" as u64)
    if fleshed == 1u64 {
        pr_rs(" pairing=neox(d,d+32) anchor: R(0)==N2 limb-exact pyth=" as u64)
        pr_ru(PR_PYC)
        pr_rs("/224 two-form=" as u64)
        pr_ru(PR_TFC)
        pr_rs(" matrix=8x8-toeplitz ealn=" as u64)
        pr_ri(PR_EALN)
        pr_rs(" order=[" as u64)
        let mut i2 : u64 = 0u64
        while i2 < 8u64 {
            pr_rs("d" as u64)
            pr_ru(PR_ORD[i2])
            if i2 < 7u64 {
                let oa : u64 = PR_ORD[i2]
                let ob : u64 = PR_ORD[i2 + 1u64]
                let c : i64 = pr_rd_cmp(0u64, oa, 1u64, ob)
                if c > 0i64 { pr_rs(">" as u64) }
                if c <= 0i64 { pr_rs("~" as u64) }
            }
            i2 = i2 + 1u64
        }
        pr_rs("] pairs-sep=" as u64)
        pr_ru(PR_HSEP)
        pr_rs("/28 premise: theta-base=10000 yarn-ramp=named" as u64)
        pr_rb(10u8)
        pr_rs("the harmonia flesh:" as u64)
        let mut d3 : u64 = 0u64
        while d3 < 8u64 {
            pr_rs(" d" as u64)
            pr_ru(d3)
            pr_rs("=" as u64)
            let sgn : i64 = PR_RDLS[d3]
            if sgn == 0i64 { pr_rs("0" as u64) }
            if sgn > 0i64 { pr_rs("+" as u64) }
            if sgn < 0i64 { pr_rs("-" as u64) }
            if sgn != 0i64 {
                let mut top : u64 = 14u64
                let mut kk : u64 = 14u64
                while kk != 0u64 {
                    kk = kk - 1u64
                    if top == 14u64 {
                        let v : u64 = PR_RDLL[d3 * 14u64 + kk]
                        if v != 0u64 { top = kk }
                    }
                }
                pr_ru(PR_RDLL[d3 * 14u64 + top])
                pr_rs("@" as u64)
                pr_ru(top)
            }
            d3 = d3 + 1u64
        }
        pr_rb(10u8)
    }
    if fleshed == 0u64 {
        if guard == 1u64 {
            pr_rs(" flesh=refused (alignment guard -- named)" as u64)
        }
        if guard == 0u64 {
            pr_rs(" flesh=fasting" as u64)
        }
        pr_rb(10u8)
    }
    return 0u64
}

/* ============ arm 380: THE PLEROMA (the pass assembled) ============ */

/* The attention mechanism of the real R1, END TO END, every step a
 * certified interval: the true logit scale C = 1/(r1^2 * r2 * sqrt(hw))
 * derived from the standing exact sums (r1^2 = mean(x^2)+eps is RATIONAL;
 * r2^2 likewise through it; one square root, taken as an interval); the
 * softmax over the causal row t=7 of the harmonia's QK matrix (the nope
 * term and the kv norm r3 CANCEL in softmax differences -- a theorem of
 * the shared-scalar chain, so the distribution needs only C and the rope
 * deltas); certified exponentials through the standing exp ladder and the
 * binary-division reciprocal; THE PARTITION TOOTH: sum of the certified
 * weights must CONTAIN exactly 1; and THE ONE-VOICE MIX: the crowned
 * head's REAL value rows (streamed once through the standing mouth) mixed
 * by the certified weights -- for the standing single-voice sequence the
 * attended value must CONTAIN the value itself, dim by dim, 128/128.
 * Premises NAMED: theta-base=10000 (yarn ramp+mscale = next stair),
 * o-proj = next stair.  The directed dyadic-float toolkit below rounds
 * every step outward; nothing is trusted to average out. */

/* directed dyadic float: value = m * 2^e, m in [2^63, 2^64) or m = 0 */
var PR_DFM : u64 = 0u64
var PR_DFE : i64 = 0i64

/* C, r1^2, r2^2 intervals; softmax state */
var PR_C_MD : u64 = 0u64
var PR_C_ED : i64 = 0i64
var PR_C_MU : u64 = 0u64
var PR_C_EU : i64 = 0i64
var PR_R1MD : u64 = 0u64
var PR_R1ED : i64 = 0i64
var PR_R1MU : u64 = 0u64
var PR_R1EU : i64 = 0i64
var PR_R2MD : u64 = 0u64
var PR_R2ED : i64 = 0i64
var PR_R2MU : u64 = 0u64
var PR_R2EU : i64 = 0i64
var PR_EPM : u64 = 0u64
var PR_EPE : i64 = 0i64
var PR_EMD : [u64; 8]
var PR_EED : [i64; 8]
var PR_EMU : [u64; 8]
var PR_EEU : [i64; 8]
var PR_WMD : [u64; 8]
var PR_WED : [i64; 8]
var PR_WMU : [u64; 8]
var PR_WEU : [i64; 8]
var PR_SWMD : u64 = 0u64
var PR_SWED : i64 = 0i64
var PR_SWMU : u64 = 0u64
var PR_SWEU : i64 = 0i64
var PR_VCONT : u64 = 0u64
var PR_VANISH : u64 = 0u64
var PR_PLEOK : u64 = 0u64

/* normalize (hi:lo) * 2^eb into the df, rounding per dir */
fn pr_dfn2(hi: u64, lo: u64, eb: i64, up: u64) -> i32 {
    if (hi | lo) == 0u64 {
        PR_DFM = 0u64
        PR_DFE = 0i64
        return 0i32
    }
    let mut hv : u64 = hi
    let mut lv : u64 = lo
    let mut e : i64 = eb + 64i64
    if hv == 0u64 {
        hv = lv
        lv = 0u64
        e = e - 64i64
    }
    let mut sh : u64 = 0u64
    let mut hh : u64 = hv
    while (hh >> 63u64) == 0u64 {
        hh = hh << 1u64
        sh = sh + 1u64
    }
    let mut m : u64 = hv << sh
    if sh != 0u64 { m = m | (lv >> (64u64 - sh)) }
    let mut dropped : u64 = lv
    if sh != 0u64 { dropped = lv << sh }
    e = e - (sh as i64)
    if up == 1u64 {
        if dropped != 0u64 {
            m = m + 1u64
            if m == 0u64 {
                m = 1u64 << 63u64
                e = e + 1i64
            }
        }
    }
    PR_DFM = m
    PR_DFE = e
    return 0i32
}

fn pr_dfmul(ma: u64, ea: i64, mb: u64, eb: i64, up: u64) -> i32 {
    if ma == 0u64 {
        PR_DFM = 0u64
        PR_DFE = 0i64
        return 0i32
    }
    if mb == 0u64 {
        PR_DFM = 0u64
        PR_DFE = 0i64
        return 0i32
    }
    pr_mul64(ma, mb)
    pr_dfn2(PR_MHI, PR_MLO, ea + eb, up)
    return 0i32
}

/* 1/(m*2^e) via the standing 177-step binary division */
fn pr_dfrecip(m: u64, e: i64, up: u64) -> i32 {
    if m == 0u64 { return 1i32 }
    pr_recip176(m >> 40u64, m << 24u64)
    let mut q0 : u64 = PR_RQ0
    let mut q1 : u64 = PR_RQ1
    if up == 1u64 {
        q0 = q0 + 1u64
        if q0 == 0u64 { q1 = q1 + 1u64 }
    }
    pr_dfn2(q1, q0, (0i64 - 152i64) - e, up)
    return 0i32
}

/* positive add with outward rounding */
fn pr_dfadd(ma: u64, ea: i64, mb: u64, eb: i64, up: u64) -> i32 {
    if ma == 0u64 {
        PR_DFM = mb
        PR_DFE = eb
        return 0i32
    }
    if mb == 0u64 {
        PR_DFM = ma
        PR_DFE = ea
        return 0i32
    }
    let mut xa : u64 = ma
    let mut xe : i64 = ea
    let mut yb : u64 = mb
    let mut ye : i64 = eb
    if ea < eb {
        xa = mb
        xe = eb
        yb = ma
        ye = ea
    }
    let d : i64 = xe - ye
    if d >= 64i64 {
        PR_DFM = xa
        PR_DFE = xe
        if up == 1u64 {
            PR_DFM = PR_DFM + 1u64
            if PR_DFM == 0u64 {
                PR_DFM = 1u64 << 63u64
                PR_DFE = PR_DFE + 1i64
            }
        }
        return 0i32
    }
    let du : u64 = d as u64
    if du == 0u64 {
        let lo0 : u64 = xa + yb
        let mut hi0 : u64 = 0u64
        if lo0 < yb { hi0 = 1u64 }
        pr_dfn2(hi0, lo0, ye, up)
        return 0i32
    }
    let mut hi : u64 = xa >> (64u64 - du)
    let mut lo : u64 = xa << du
    let s : u64 = lo + yb
    if s < yb { hi = hi + 1u64 }
    lo = s
    pr_dfn2(hi, lo, ye, up)
    return 0i32
}

/* largest r with r^2 <= (hi:lo) */
fn pr_isqrt128(hi: u64, lo: u64) -> u64 {
    let mut r : u64 = 0u64
    let mut b : u64 = 64u64
    while b != 0u64 {
        b = b - 1u64
        let t : u64 = r | (1u64 << b)
        pr_mul64(t, t)
        let mut le : u64 = 0u64
        if PR_MHI < hi { le = 1u64 }
        if PR_MHI == hi {
            if PR_MLO <= lo { le = 1u64 }
        }
        if le == 1u64 { r = t }
    }
    return r
}

fn pr_dfsqrt(m: u64, e: i64, up: u64) -> i32 {
    if m == 0u64 {
        PR_DFM = 0u64
        PR_DFE = 0i64
        return 0i32
    }
    let mut s : u64 = 62u64
    let par : i64 = e - 62i64
    let odd : i64 = par - 2i64 * (par / 2i64)
    if odd != 0i64 { s = 63u64 }
    let hi : u64 = m >> (64u64 - s)
    let lo : u64 = m << s
    let ev : i64 = e - (s as i64)
    let mut r : u64 = pr_isqrt128(hi, lo)
    if up == 1u64 { r = r + 1u64 }
    pr_dfn2(0u64, r, ev / 2i64, 0u64)
    return 0i32
}

fn pr_df_cmp(ma: u64, ea: i64, mb: u64, eb: i64) -> i64 {
    if ma == 0u64 {
        if mb == 0u64 { return 0i64 }
        return 0i64 - 1i64
    }
    if mb == 0u64 { return 1i64 }
    if ea > eb { return 1i64 }
    if ea < eb { return 0i64 - 1i64 }
    if ma > mb { return 1i64 }
    if ma < mb { return 0i64 - 1i64 }
    return 0i64
}

/* df -> exp-ladder argument at 2^-48 (value must be small; dir outward) */
fn pr_df_m48(m: u64, e: i64, up: u64) -> u64 {
    if m == 0u64 { return 0u64 }
    let sh : i64 = 0i64 - (e + 48i64)
    if sh <= 0i64 { return 0u64 - 1u64 }
    if sh >= 64i64 {
        if up == 1u64 { return 1u64 }
        return 0u64
    }
    let shu : u64 = sh as u64
    let mut v : u64 = m >> shu
    if up == 1u64 {
        if (m << (64u64 - shu)) != 0u64 { v = v + 1u64 }
    }
    return v
}

/* df -> parts-per-billion (for the report) */
fn pr_df_ppb(m: u64, e: i64, up: u64) -> u64 {
    if m == 0u64 { return 0u64 }
    pr_mul64(m, 1000000000u64)
    let sh : i64 = 0i64 - e
    if sh <= 0i64 { return 0u64 - 1u64 }
    if sh >= 128i64 {
        if up == 1u64 { return 1u64 }
        return 0u64
    }
    let shu : u64 = sh as u64
    let mut hi : u64 = PR_MHI
    let mut lo : u64 = PR_MLO
    let mut dropped : u64 = 0u64
    if shu >= 64u64 {
        dropped = lo
        lo = hi
        hi = 0u64
        let s2 : u64 = shu - 64u64
        if s2 != 0u64 {
            dropped = dropped | (lo << (64u64 - s2))
            lo = lo >> s2
        }
    }
    if shu < 64u64 {
        dropped = lo << (64u64 - shu)
        lo = (lo >> shu) | (hi << (64u64 - shu))
        hi = hi >> shu
        if hi != 0u64 { return 0u64 - 1u64 }
    }
    if up == 1u64 {
        if dropped != 0u64 { lo = lo + 1u64 }
    }
    return lo
}

/* T14 = P6 << sh (wide variant for the r2^2 sum; sh <= 512) */
fn pr_t14_p6shl(sh: u64) -> u64 {
    let mut k : u64 = 0u64
    while k < 14u64 {
        PR_T14[k] = 0u64
        k = k + 1u64
    }
    if sh > 512u64 { return 1u64 }
    let w : u64 = sh / 64u64
    let b : u64 = sh % 64u64
    let mut k2 : u64 = 0u64
    while k2 < 6u64 {
        let v : u64 = PR_P6[k2]
        if v != 0u64 {
            let pos : u64 = k2 + w
            if pos >= 14u64 { return 1u64 }
            PR_T14[pos] = PR_T14[pos] | (v << b)
            if b != 0u64 {
                let spill : u64 = v >> (64u64 - b)
                if spill != 0u64 {
                    if pos + 1u64 >= 14u64 { return 1u64 }
                    PR_T14[pos + 1u64] = PR_T14[pos + 1u64] | spill
                }
            }
        }
        k2 = k2 + 1u64
    }
    return 0u64
}

/* df from the T14 magnitude (dir outward) */
fn pr_df_from14(up: u64) -> i32 {
    let mut t : u64 = 14u64
    let mut k : u64 = 14u64
    while k != 0u64 {
        k = k - 1u64
        if t == 14u64 {
            if PR_T14[k] != 0u64 { t = k }
        }
    }
    if t == 14u64 {
        PR_DFM = 0u64
        PR_DFE = 0i64
        return 0i32
    }
    let hv : u64 = PR_T14[t]
    let mut lv : u64 = 0u64
    if t != 0u64 { lv = PR_T14[t - 1u64] }
    let mut st : u64 = 0u64
    k = 0u64
    while k + 1u64 < t {
        st = st | PR_T14[k]
        k = k + 1u64
    }
    let mut sh : u64 = 0u64
    let mut hh : u64 = hv
    while (hh >> 63u64) == 0u64 {
        hh = hh << 1u64
        sh = sh + 1u64
    }
    let mut m : u64 = hv << sh
    if sh != 0u64 { m = m | (lv >> (64u64 - sh)) }
    let mut dropped : u64 = st
    if sh != 0u64 { dropped = dropped | (lv << sh) }
    if sh == 0u64 { dropped = dropped | lv }
    let mut e : i64 = (64u64 * t) as i64 - (sh as i64)
    if up == 1u64 {
        if dropped != 0u64 {
            m = m + 1u64
            if m == 0u64 {
                m = 1u64 << 63u64
                e = e + 1i64
            }
        }
    }
    PR_DFM = m
    PR_DFE = e
    return 0i32
}

/* r1^2 = mean(x^2) + eps as a df interval (all exact until the df) */
fn pr_ple_r1() -> u64 {
    let em : i64 = mb_gz_eps_m()
    if em <= 0i64 { return 1u64 }
    if em == 4611686018427387904i64 { return 1u64 }
    let ee : i64 = mb_gz_eps_e()
    pr_dfn2(0u64, em as u64, ee, 0u64)
    PR_EPM = PR_DFM
    PR_EPE = PR_DFE
    let n : u64 = mb_gz_nembd()
    if n == 0u64 { return 1u64 }
    if n > 7168u64 { return 1u64 }
    let mut a0 : u64 = 0u64
    let mut a1 : u64 = 0u64
    let mut a2 : u64 = 0u64
    let mut c : u64 = 0u64
    while c < n {
        let v : i64 = mb_gz_xv(c)
        if v != 0i64 {
            let mut mg : u64 = v as u64
            if v < 0i64 { mg = (0i64 - v) as u64 }
            pr_mul64(mg, mg)
            let s0 : u64 = a0 + PR_MLO
            let mut cy : u64 = 0u64
            if s0 < PR_MLO { cy = 1u64 }
            a0 = s0
            let s1 : u64 = a1 + PR_MHI
            let mut cy2 : u64 = 0u64
            if s1 < PR_MHI { cy2 = 1u64 }
            let s1b : u64 = s1 + cy
            if s1b < cy { cy2 = cy2 + 1u64 }
            a1 = s1b
            a2 = a2 + cy2
        }
        c = c + 1u64
    }
    if a2 != 0u64 { return 1u64 }
    if (a1 | a0) == 0u64 { return 1u64 }
    /* A * 2^-48 / n + eps, both directions */
    let mut side : u64 = 0u64
    while side < 2u64 {
        pr_dfn2(a1, a0, 0i64 - 48i64, side)
        let sxm : u64 = PR_DFM
        let sxe : i64 = PR_DFE
        pr_dfn2(0u64, n, 0i64, 0u64)
        pr_dfrecip(PR_DFM, PR_DFE, side)
        let rnm : u64 = PR_DFM
        let rne : i64 = PR_DFE
        pr_dfmul(sxm, sxe, rnm, rne, side)
        pr_dfadd(PR_DFM, PR_DFE, PR_EPM, PR_EPE, side)
        if side == 0u64 {
            PR_R1MD = PR_DFM
            PR_R1ED = PR_DFE
        }
        if side == 1u64 {
            PR_R1MU = PR_DFM
            PR_R1EU = PR_DFE
        }
        side = side + 1u64
    }
    return 0u64
}

/* r2^2 = sum(BV^2)*2^(2emin)/(rk * r1^2) + eps as a df interval */
fn pr_ple_r2() -> u64 {
    let rk : u64 = mb_gz_qark()
    if rk == 0u64 { return 1u64 }
    if rk > 1536u64 { return 1u64 }
    let mut emin : i64 = 1000000i64
    let mut emax : i64 = 0i64 - 1000000i64
    let mut r : u64 = 0u64
    while r < rk {
        let s : i64 = mb_gz_bv_s(r)
        if s != 0i64 {
            let e2 : i64 = mb_gz_bv_e(r)
            if e2 < emin { emin = e2 }
            if e2 > emax { emax = e2 }
        }
        r = r + 1u64
    }
    if emin == 1000000i64 { return 1u64 }
    if emax - emin > 256i64 { return 1u64 }
    PR_ALS = 0i64
    let mut k : u64 = 0u64
    while k < 14u64 {
        PR_AL[k] = 0u64
        k = k + 1u64
    }
    r = 0u64
    while r < rk {
        let s2 : i64 = mb_gz_bv_s(r)
        if s2 != 0i64 {
            let l0 : u64 = mb_gz_bv_l(r, 0u64)
            let l1 : u64 = mb_gz_bv_l(r, 1u64)
            let l2 : u64 = mb_gz_bv_l(r, 2u64)
            pr_m33(l0, l1, l2, l0, l1, l2)
            let sh2 : u64 = (2i64 * (mb_gz_bv_e(r) - emin)) as u64
            if pr_t14_p6shl(sh2) != 0u64 { return 1u64 }
            if pr_s14_add(0u64, 1i64) != 0i32 { return 1u64 }
        }
        r = r + 1u64
    }
    k = 0u64
    while k < 14u64 {
        PR_T14[k] = PR_AL[k]
        k = k + 1u64
    }
    let e2m : i64 = 2i64 * emin
    let mut side : u64 = 0u64
    while side < 2u64 {
        pr_df_from14(side)
        if PR_DFM == 0u64 { return 1u64 }
        let s2m : u64 = PR_DFM
        let s2e : i64 = PR_DFE + e2m
        /* denominator rk * r1^2, opposite direction */
        let mut r1m : u64 = PR_R1MU
        let mut r1e : i64 = PR_R1EU
        if side == 1u64 {
            r1m = PR_R1MD
            r1e = PR_R1ED
        }
        pr_dfn2(0u64, rk, 0i64, 0u64)
        let opp : u64 = 1u64 - side
        pr_dfmul(PR_DFM, PR_DFE, r1m, r1e, opp)
        pr_dfrecip(PR_DFM, PR_DFE, side)
        pr_dfmul(s2m, s2e, PR_DFM, PR_DFE, side)
        pr_dfadd(PR_DFM, PR_DFE, PR_EPM, PR_EPE, side)
        if side == 0u64 {
            PR_R2MD = PR_DFM
            PR_R2ED = PR_DFE
        }
        if side == 1u64 {
            PR_R2MU = PR_DFM
            PR_R2EU = PR_DFE
        }
        side = side + 1u64
    }
    return 0u64
}

/* C = 1/(r1^2 * sqrt(hw * r2^2)) as a df interval */
fn pr_ple_cfin() -> u64 {
    let hw : u64 = mb_gz_hw()
    if hw == 0u64 { return 1u64 }
    let mut side : u64 = 0u64
    while side < 2u64 {
        let mut r2m : u64 = PR_R2MD
        let mut r2e : i64 = PR_R2ED
        let mut r1m : u64 = PR_R1MD
        let mut r1e : i64 = PR_R1ED
        if side == 1u64 {
            r2m = PR_R2MU
            r2e = PR_R2EU
            r1m = PR_R1MU
            r1e = PR_R1EU
        }
        pr_dfn2(0u64, hw, 0i64, 0u64)
        pr_dfmul(PR_DFM, PR_DFE, r2m, r2e, side)
        pr_dfsqrt(PR_DFM, PR_DFE, side)
        pr_dfmul(r1m, r1e, PR_DFM, PR_DFE, side)
        /* C side = recip of the OPPOSITE denominator side */
        pr_dfrecip(PR_DFM, PR_DFE, 1u64 - side)
        if side == 1u64 {
            PR_C_MD = PR_DFM
            PR_C_ED = PR_DFE
        }
        if side == 0u64 {
            PR_C_MU = PR_DFM
            PR_C_EU = PR_DFE
        }
        side = side + 1u64
    }
    return 0u64
}

/* certified e_delta for one non-top delta (dir-outward all the way) */
fn pr_ple_edelta(dd: u64, top: u64) -> u64 {
    /* D lo bound: lo_top - hi_dd  (positive by separation) */
    PR_ALS = PR_RDLS[top]
    let mut k : u64 = 0u64
    while k < 14u64 {
        PR_AL[k] = PR_RDLL[top * 14u64 + k]
        PR_T14[k] = PR_RDHL[dd * 14u64 + k]
        k = k + 1u64
    }
    if pr_s14_add(0u64, 0i64 - PR_RDHS[dd]) != 0i32 { return 1u64 }
    if PR_ALS <= 0i64 { return 1u64 }
    k = 0u64
    while k < 14u64 {
        PR_T14[k] = PR_AL[k]
        k = k + 1u64
    }
    pr_df_from14(0u64)
    let dlm : u64 = PR_DFM
    let dle : i64 = PR_DFE + (PR_EALN - 88i64)
    /* D hi bound: hi_top - lo_dd */
    PR_AHS = PR_RDHS[top]
    k = 0u64
    while k < 14u64 {
        PR_AH[k] = PR_RDHL[top * 14u64 + k]
        PR_T14[k] = PR_RDLL[dd * 14u64 + k]
        k = k + 1u64
    }
    if pr_s14_add(1u64, 0i64 - PR_RDLS[dd]) != 0i32 { return 1u64 }
    if PR_AHS <= 0i64 { return 1u64 }
    k = 0u64
    while k < 14u64 {
        PR_T14[k] = PR_AH[k]
        k = k + 1u64
    }
    pr_df_from14(1u64)
    let dhm : u64 = PR_DFM
    let dhe : i64 = PR_DFE + (PR_EALN - 88i64)
    /* D = Dnum * C */
    pr_dfmul(dlm, dle, PR_C_MD, PR_C_ED, 0u64)
    let xlm : u64 = PR_DFM
    let xle : i64 = PR_DFE
    pr_dfmul(dhm, dhe, PR_C_MU, PR_C_EU, 1u64)
    let xhm : u64 = PR_DFM
    let xhe : i64 = PR_DFE
    /* the ladder cap: beyond 24 the weight VANISHES under a named bound */
    let capm : u64 = 3u64 << 62u64
    let cape : i64 = 0i64 - 59i64
    if pr_df_cmp(xhm, xhe, capm, cape) >= 0i64 {
        PR_EMD[dd] = 0u64
        PR_EED[dd] = 0i64
        PR_EMU[dd] = 1u64 << 63u64
        PR_EEU[dd] = 0i64 - 97i64
        PR_VANISH = PR_VANISH + 1u64
        return 0u64
    }
    let m48h : u64 = pr_df_m48(xhm, xhe, 1u64)
    if m48h == (0u64 - 1u64) { return 1u64 }
    let m48l : u64 = pr_df_m48(xlm, xle, 0u64)
    if m48l == (0u64 - 1u64) { return 1u64 }
    /* e lower = recip(exp(D_hi) upper) floored */
    if pr_exp(m48h, 48u64) != 0i32 { return 1u64 }
    pr_dfn2(PR_EHI1, PR_EHI0, 0i64 - 88i64, 1u64)
    pr_dfrecip(PR_DFM, PR_DFE, 0u64)
    PR_EMD[dd] = PR_DFM
    PR_EED[dd] = PR_DFE
    /* e upper = recip(exp(D_lo) lower) ceiled */
    if pr_exp(m48l, 48u64) != 0i32 { return 1u64 }
    pr_dfn2(PR_ELO1, PR_ELO0, 0i64 - 88i64, 0u64)
    pr_dfrecip(PR_DFM, PR_DFE, 1u64)
    PR_EMU[dd] = PR_DFM
    PR_EEU[dd] = PR_DFE
    return 0u64
}

/* the certified softmax over the causal row: 0 ok / 1 red / 2 refused */
fn pr_ple_soft() -> u64 {
    PR_VANISH = 0u64
    let top : u64 = PR_ORD[0]
    let mut dd : u64 = 0u64
    while dd < 8u64 {
        if dd != top {
            if pr_rd_cmp(0u64, top, 1u64, dd) <= 0i64 { return 2u64 }
        }
        dd = dd + 1u64
    }
    dd = 0u64
    while dd < 8u64 {
        if dd == top {
            PR_EMD[dd] = 1u64 << 63u64
            PR_EED[dd] = 0i64 - 63i64
            PR_EMU[dd] = 1u64 << 63u64
            PR_EEU[dd] = 0i64 - 63i64
        }
        if dd != top {
            if pr_ple_edelta(dd, top) != 0u64 { return 1u64 }
        }
        dd = dd + 1u64
    }
    /* sum of exponentials, both directions */
    let mut sdm : u64 = 0u64
    let mut sde : i64 = 0i64
    let mut sum : u64 = 0u64
    let mut sue : i64 = 0i64
    dd = 0u64
    while dd < 8u64 {
        pr_dfadd(sdm, sde, PR_EMD[dd], PR_EED[dd], 0u64)
        sdm = PR_DFM
        sde = PR_DFE
        pr_dfadd(sum, sue, PR_EMU[dd], PR_EEU[dd], 1u64)
        sum = PR_DFM
        sue = PR_DFE
        dd = dd + 1u64
    }
    if sdm == 0u64 { return 1u64 }
    /* weights and their sum */
    pr_dfrecip(sum, sue, 0u64)
    let rlm : u64 = PR_DFM
    let rle : i64 = PR_DFE
    pr_dfrecip(sdm, sde, 1u64)
    let rum : u64 = PR_DFM
    let rue : i64 = PR_DFE
    let mut wdm : u64 = 0u64
    let mut wde : i64 = 0i64
    let mut wum : u64 = 0u64
    let mut wue : i64 = 0i64
    dd = 0u64
    while dd < 8u64 {
        pr_dfmul(PR_EMD[dd], PR_EED[dd], rlm, rle, 0u64)
        PR_WMD[dd] = PR_DFM
        PR_WED[dd] = PR_DFE
        pr_dfmul(PR_EMU[dd], PR_EEU[dd], rum, rue, 1u64)
        PR_WMU[dd] = PR_DFM
        PR_WEU[dd] = PR_DFE
        pr_dfadd(wdm, wde, PR_WMD[dd], PR_WED[dd], 0u64)
        wdm = PR_DFM
        wde = PR_DFE
        pr_dfadd(wum, wue, PR_WMU[dd], PR_WEU[dd], 1u64)
        wum = PR_DFM
        wue = PR_DFE
        dd = dd + 1u64
    }
    PR_SWMD = wdm
    PR_SWED = wde
    PR_SWMU = wum
    PR_SWEU = wue
    /* THE PARTITION TOOTH: sum of weights must contain exactly 1 */
    let onem : u64 = 1u64 << 63u64
    let onee : i64 = 0i64 - 63i64
    if pr_df_cmp(wdm, wde, onem, onee) > 0i64 { return 1u64 }
    if pr_df_cmp(wum, wue, onem, onee) < 0i64 { return 1u64 }
    return 0u64
}

/* the one-voice mix: certified weights over the REAL value rows */
fn pr_ple_mix() -> u64 {
    let vs : u64 = mb_gz_vserve()
    if vs == 2u64 { return 2u64 }
    if vs != 0u64 { return 1u64 }
    let mut cont : u64 = 0u64
    let mut d : u64 = 0u64
    while d < 128u64 {
        let s : i64 = mb_gz_v_s(d)
        if s == 0i64 { cont = cont + 1u64 }
        if s != 0i64 {
            let l0 : u64 = mb_gz_v_l(d, 0u64)
            let l1 : u64 = mb_gz_v_l(d, 1u64)
            let l2 : u64 = mb_gz_v_l(d, 2u64)
            let ve : i64 = mb_gz_v_e(d)
            let mut k : u64 = 0u64
            while k < 14u64 {
                PR_T14[k] = 0u64
                k = k + 1u64
            }
            PR_T14[0] = l0
            PR_T14[1] = l1
            PR_T14[2] = l2
            pr_df_from14(0u64)
            let vdm : u64 = PR_DFM
            let vde : i64 = PR_DFE + ve
            pr_df_from14(1u64)
            let vum : u64 = PR_DFM
            let vue : i64 = PR_DFE + ve
            pr_dfmul(PR_SWMD, PR_SWED, vdm, vde, 0u64)
            let olm : u64 = PR_DFM
            let ole : i64 = PR_DFE
            pr_dfmul(PR_SWMU, PR_SWEU, vum, vue, 1u64)
            let ohm : u64 = PR_DFM
            let ohe : i64 = PR_DFE
            let c1 : i64 = pr_df_cmp(olm, ole, vdm, vde)
            let c2 : i64 = pr_df_cmp(ohm, ohe, vum, vue)
            if c1 <= 0i64 {
                if c2 >= 0i64 { cont = cont + 1u64 }
            }
        }
        d = d + 1u64
    }
    PR_VCONT = cont
    if cont != 128u64 { return 1u64 }
    return 0u64
}

fn pr_arm380() -> u64 {
    if PR_HFLESH != 1u64 {
        pr_rs("the pleroma: fasting (no fleshed harmonia) -- the assembly stands ready" as u64)
        pr_rb(10u8)
        return 0u64
    }
    if pr_ple_r1() != 0u64 { return 380u64 }
    if pr_ple_r2() != 0u64 { return 380u64 }
    if pr_ple_cfin() != 0u64 { return 380u64 }
    let sf : u64 = pr_ple_soft()
    if sf == 2u64 {
        pr_rs("the pleroma: softmax refused (top delta not separated -- named)" as u64)
        pr_rb(10u8)
        return 0u64
    }
    if sf != 0u64 { return 380u64 }
    let mx : u64 = pr_ple_mix()
    if mx == 2u64 {
        pr_rs("the pleroma: v-width foreign (named, lawful)" as u64)
        pr_rb(10u8)
        return 0u64
    }
    if mx != 0u64 { return 380u64 }
    pr_rs("the pleroma: scale C=[" as u64)
    pr_ru(PR_C_MD)
    pr_rs("e" as u64)
    pr_ri(PR_C_ED)
    pr_rs("," as u64)
    pr_ru(PR_C_MU)
    pr_rs("e" as u64)
    pr_ri(PR_C_EU)
    pr_rs("] softmax=causal-row-t7 top=d" as u64)
    pr_ru(PR_ORD[0])
    pr_rs(" (attends s=" as u64)
    pr_ru(7u64 - PR_ORD[0])
    pr_rs(") vanish=" as u64)
    pr_ru(PR_VANISH)
    pr_rs(" sum-w=[" as u64)
    pr_ru(pr_df_ppb(PR_SWMD, PR_SWED, 0u64))
    pr_rs("," as u64)
    pr_ru(pr_df_ppb(PR_SWMU, PR_SWEU, 1u64))
    pr_rs("]ppb contains 1 =ok mix: one-voice value RETURNED v-contained=" as u64)
    pr_ru(PR_VCONT)
    pr_rs("/128 voice=row" as u64)
    pr_ru(mb_gz_voice())
    pr_rs(" premises: theta-base=10000 yarn=named o-proj=named" as u64)
    pr_rb(10u8)
    PR_PLEOK = 1u64
    pr_rs("the pleroma weights(ppb):" as u64)
    let mut dd : u64 = 0u64
    while dd < 8u64 {
        pr_rs(" d" as u64)
        pr_ru(dd)
        pr_rs("=[" as u64)
        pr_ru(pr_df_ppb(PR_WMD[dd], PR_WED[dd], 0u64))
        pr_rs("," as u64)
        pr_ru(pr_df_ppb(PR_WMU[dd], PR_WEU[dd], 1u64))
        pr_rs("]" as u64)
        dd = dd + 1u64
    }
    pr_rb(10u8)
    return 0u64
}

/* ============ arm 381: THE CHOIR (every head sings, one thought) ====== */

/* The pleroma proved ONE head's certified pass.  The choir proves all
 * 128: per-head exact P/X (the standing per-head rope rows, stored by
 * the gaze's own loop -- never restreamed), the same lane ladders (the
 * circle is head-blind), and the SHIFT-ANCHOR softmax: softmax is
 * invariant under any common shift, so anchoring at delta=0 needs exp of
 * SIGNED bounded arguments only -- no argmax, no order, no refusal
 * unless the ladder cap itself is breached (then the head is refused BY
 * NAME).  Every head's partition must contain 1.  The crowned head's
 * weights must OVERLAP arm 380's (two anchors, one truth).  Then the
 * per-head one-voice mixes are deposited as the STANDING THOUGHT: the
 * 16384-wide interval vector the projection will consume, with the
 * exact one-voice point riding beside the bounds as the second engine.
 * And the homecoming radical r1*r3 = sqrt(r1^2 * r3^2) is certified
 * here, where the exact sums live. */

var PR_CSWMD : [u64; 128]
var PR_CSWED : [i64; 128]
var PR_CSWMU : [u64; 128]
var PR_CSWEU : [i64; 128]
var PR_CRWMD : [u64; 8]
var PR_CRWED : [i64; 8]
var PR_CRWMU : [u64; 8]
var PR_CRWEU : [i64; 8]
var PR_CEMD : [u64; 8]
var PR_CEED : [i64; 8]
var PR_CEMU : [u64; 8]
var PR_CEEU : [i64; 8]
var PR_R3MD : u64 = 0u64
var PR_R3ED : i64 = 0i64
var PR_R3MU : u64 = 0u64
var PR_R3EU : i64 = 0i64
var PR_R13MD : u64 = 0u64
var PR_R13ED : i64 = 0i64
var PR_R13MU : u64 = 0u64
var PR_R13EU : i64 = 0i64
var PR_RI13MD : u64 = 0u64
var PR_RI13ED : i64 = 0i64
var PR_RI13MU : u64 = 0u64
var PR_RI13EU : i64 = 0i64
var PR_CHREF : u64 = 0u64
var PR_CHTOP0 : u64 = 0u64
var PR_CHTOPO : u64 = 0u64
var PR_CHTOPS : u64 = 0u64
var PR_CHOK : u64 = 0u64

/* r3^2 = sum(latent^2)*2^(2emin)/(512 * r1^2) + eps, then the homecoming
 * radical r1*r3 and its reciprocal interval */
fn pr_cho_r13() -> u64 {
    let mut emin : i64 = 1000000i64
    let mut emax : i64 = 0i64 - 1000000i64
    let mut r : u64 = 0u64
    while r < 512u64 {
        let s : i64 = mb_gz_dv_s(r)
        if s != 0i64 {
            let e2 : i64 = mb_gz_dv_e(r)
            if e2 < emin { emin = e2 }
            if e2 > emax { emax = e2 }
        }
        r = r + 1u64
    }
    if emin == 1000000i64 { return 1u64 }
    if emax - emin > 256i64 { return 1u64 }
    PR_ALS = 0i64
    let mut k : u64 = 0u64
    while k < 14u64 {
        PR_AL[k] = 0u64
        k = k + 1u64
    }
    r = 0u64
    while r < 512u64 {
        let s2 : i64 = mb_gz_dv_s(r)
        if s2 != 0i64 {
            let l0 : u64 = mb_gz_dv_l(r, 0u64)
            let l1 : u64 = mb_gz_dv_l(r, 1u64)
            let l2 : u64 = mb_gz_dv_l(r, 2u64)
            pr_m33(l0, l1, l2, l0, l1, l2)
            let sh2 : u64 = (2i64 * (mb_gz_dv_e(r) - emin)) as u64
            if pr_t14_p6shl(sh2) != 0u64 { return 1u64 }
            if pr_s14_add(0u64, 1i64) != 0i32 { return 1u64 }
        }
        r = r + 1u64
    }
    k = 0u64
    while k < 14u64 {
        PR_T14[k] = PR_AL[k]
        k = k + 1u64
    }
    let e2m : i64 = 2i64 * emin
    let mut side : u64 = 0u64
    while side < 2u64 {
        pr_df_from14(side)
        if PR_DFM == 0u64 { return 1u64 }
        let s2m : u64 = PR_DFM
        let s2e : i64 = PR_DFE + e2m
        let mut r1m : u64 = PR_R1MU
        let mut r1e : i64 = PR_R1EU
        if side == 1u64 {
            r1m = PR_R1MD
            r1e = PR_R1ED
        }
        pr_dfn2(0u64, 512u64, 0i64, 0u64)
        let opp : u64 = 1u64 - side
        pr_dfmul(PR_DFM, PR_DFE, r1m, r1e, opp)
        pr_dfrecip(PR_DFM, PR_DFE, side)
        pr_dfmul(s2m, s2e, PR_DFM, PR_DFE, side)
        pr_dfadd(PR_DFM, PR_DFE, PR_EPM, PR_EPE, side)
        if side == 0u64 {
            PR_R3MD = PR_DFM
            PR_R3ED = PR_DFE
        }
        if side == 1u64 {
            PR_R3MU = PR_DFM
            PR_R3EU = PR_DFE
        }
        side = side + 1u64
    }
    /* r1*r3 = sqrt(r1^2 * r3^2), then the reciprocal (directions flip) */
    pr_dfmul(PR_R1MD, PR_R1ED, PR_R3MD, PR_R3ED, 0u64)
    pr_dfsqrt(PR_DFM, PR_DFE, 0u64)
    PR_R13MD = PR_DFM
    PR_R13ED = PR_DFE
    pr_dfmul(PR_R1MU, PR_R1EU, PR_R3MU, PR_R3EU, 1u64)
    pr_dfsqrt(PR_DFM, PR_DFE, 1u64)
    PR_R13MU = PR_DFM
    PR_R13EU = PR_DFE
    pr_dfrecip(PR_R13MU, PR_R13EU, 0u64)
    PR_RI13MD = PR_DFM
    PR_RI13ED = PR_DFE
    pr_dfrecip(PR_R13MD, PR_R13ED, 1u64)
    PR_RI13MU = PR_DFM
    PR_RI13EU = PR_DFE
    return 0u64
}

/* exp(z) for SIGNED z = sg * m * 2^e, rounded per up.  0 ok / 1 cap */
fn pr_cho_exp(m: u64, e: i64, sg: i64, up: u64) -> u64 {
    if sg == 0i64 {
        PR_DFM = 1u64 << 63u64
        PR_DFE = 0i64 - 63i64
        return 0u64
    }
    if m == 0u64 {
        PR_DFM = 1u64 << 63u64
        PR_DFE = 0i64 - 63i64
        return 0u64
    }
    let capm : u64 = 3u64 << 62u64
    let cape : i64 = 0i64 - 59i64
    if pr_df_cmp(m, e, capm, cape) >= 0i64 { return 1u64 }
    if sg > 0i64 {
        /* growing side: up -> ceil arg + EHI; dn -> floor arg + ELO */
        let m48 : u64 = pr_df_m48(m, e, up)
        if m48 == (0u64 - 1u64) { return 1u64 }
        if pr_exp(m48, 48u64) != 0i32 { return 1u64 }
        if up == 1u64 {
            pr_dfn2(PR_EHI1, PR_EHI0, 0i64 - 88i64, 1u64)
        }
        if up == 0u64 {
            pr_dfn2(PR_ELO1, PR_ELO0, 0i64 - 88i64, 0u64)
        }
        return 0u64
    }
    /* shrinking side: exp(-|z|) = recip(exp(|z|)) */
    let m48b : u64 = pr_df_m48(m, e, 1u64 - up)
    if m48b == (0u64 - 1u64) { return 1u64 }
    if pr_exp(m48b, 48u64) != 0i32 { return 1u64 }
    if up == 1u64 {
        /* upper of recip needs LOWER of exp: floor arg + ELO, recip up */
        pr_dfn2(PR_ELO1, PR_ELO0, 0i64 - 88i64, 0u64)
        pr_dfrecip(PR_DFM, PR_DFE, 1u64)
        return 0u64
    }
    pr_dfn2(PR_EHI1, PR_EHI0, 0i64 - 88i64, 1u64)
    pr_dfrecip(PR_DFM, PR_DFE, 0u64)
    return 0u64
}

/* the shift-anchor softmax for the standing PR_RD state.  Writes e and w
 * arrays (CE*, then the weights into CRW when crowned).  0 ok / 1 red /
 * 2 ladder-cap refusal (the head is refused by name) */
fn pr_cho_soft(h: u64) -> u64 {
    let mut dd : u64 = 0u64
    while dd < 8u64 {
        if dd == 0u64 {
            PR_CEMD[0] = 1u64 << 63u64
            PR_CEED[0] = 0i64 - 63i64
            PR_CEMU[0] = 1u64 << 63u64
            PR_CEEU[0] = 0i64 - 63i64
        }
        if dd != 0u64 {
            /* D bounds (signed): lo = R0lo - RdHi, hi = R0hi - RdLo */
            PR_ALS = PR_RDLS[0]
            let mut k : u64 = 0u64
            while k < 14u64 {
                PR_AL[k] = PR_RDLL[k]
                PR_T14[k] = PR_RDHL[dd * 14u64 + k]
                k = k + 1u64
            }
            if pr_s14_add(0u64, 0i64 - PR_RDHS[dd]) != 0i32 { return 1u64 }
            let dls : i64 = PR_ALS
            k = 0u64
            while k < 14u64 {
                PR_T14[k] = PR_AL[k]
                k = k + 1u64
            }
            pr_df_from14(0u64)
            let dlm0 : u64 = PR_DFM
            let dle0 : i64 = PR_DFE + (PR_EALN - 88i64)
            PR_AHS = PR_RDHS[0]
            k = 0u64
            while k < 14u64 {
                PR_AH[k] = PR_RDHL[k]
                PR_T14[k] = PR_RDLL[dd * 14u64 + k]
                k = k + 1u64
            }
            if pr_s14_add(1u64, 0i64 - PR_RDLS[dd]) != 0i32 { return 1u64 }
            let dhs : i64 = PR_AHS
            k = 0u64
            while k < 14u64 {
                PR_T14[k] = PR_AH[k]
                k = k + 1u64
            }
            pr_df_from14(1u64)
            let dhm0 : u64 = PR_DFM
            let dhe0 : i64 = PR_DFE + (PR_EALN - 88i64)
            /* x = C * D, directed with C > 0 and D signed */
            let mut xlm : u64 = 0u64
            let mut xle : i64 = 0i64
            let mut xls : i64 = dls
            if dls != 0i64 {
                if dls > 0i64 { pr_dfmul(dlm0, dle0, PR_C_MD, PR_C_ED, 0u64) }
                if dls < 0i64 { pr_dfmul(dlm0, dle0, PR_C_MU, PR_C_EU, 1u64) }
                xlm = PR_DFM
                xle = PR_DFE
            }
            let mut xhm : u64 = 0u64
            let mut xhe : i64 = 0i64
            let mut xhs : i64 = dhs
            if dhs != 0i64 {
                if dhs > 0i64 { pr_dfmul(dhm0, dhe0, PR_C_MU, PR_C_EU, 1u64) }
                if dhs < 0i64 { pr_dfmul(dhm0, dhe0, PR_C_MD, PR_C_ED, 0u64) }
                xhm = PR_DFM
                xhe = PR_DFE
            }
            /* e = exp(-x): dn side from x_hi, up side from x_lo.  The
             * vanishing tail: x_lo >= 24 -> e in [0, 2^-34] */
            let capm2 : u64 = 3u64 << 62u64
            let cape2 : i64 = 0i64 - 59i64
            let mut vanished : u64 = 0u64
            if xls > 0i64 {
                if pr_df_cmp(xlm, xle, capm2, cape2) >= 0i64 {
                    /* both bounds sit beyond the cap on the shrinking side */
                    if xhs > 0i64 {
                        if pr_df_cmp(xhm, xhe, capm2, cape2) >= 0i64 {
                            PR_CEMD[dd] = 0u64
                            PR_CEED[dd] = 0i64
                            PR_CEMU[dd] = 1u64 << 63u64
                            PR_CEEU[dd] = 0i64 - 97i64
                            vanished = 1u64
                        }
                    }
                    if vanished == 0u64 { return 2u64 }
                }
            }
            if vanished == 0u64 {
                if pr_cho_exp(xhm, xhe, 0i64 - xhs, 0u64) != 0u64 { return 2u64 }
                PR_CEMD[dd] = PR_DFM
                PR_CEED[dd] = PR_DFE
                if pr_cho_exp(xlm, xle, 0i64 - xls, 1u64) != 0u64 { return 2u64 }
                PR_CEMU[dd] = PR_DFM
                PR_CEEU[dd] = PR_DFE
            }
        }
        dd = dd + 1u64
    }
    /* sums, weights, the partition tooth */
    let mut sdm : u64 = 0u64
    let mut sde : i64 = 0i64
    let mut sum : u64 = 0u64
    let mut sue : i64 = 0i64
    dd = 0u64
    while dd < 8u64 {
        pr_dfadd(sdm, sde, PR_CEMD[dd], PR_CEED[dd], 0u64)
        sdm = PR_DFM
        sde = PR_DFE
        pr_dfadd(sum, sue, PR_CEMU[dd], PR_CEEU[dd], 1u64)
        sum = PR_DFM
        sue = PR_DFE
        dd = dd + 1u64
    }
    if sdm == 0u64 { return 1u64 }
    pr_dfrecip(sum, sue, 0u64)
    let rlm : u64 = PR_DFM
    let rle : i64 = PR_DFE
    pr_dfrecip(sdm, sde, 1u64)
    let rum : u64 = PR_DFM
    let rue : i64 = PR_DFE
    let mut wdm : u64 = 0u64
    let mut wde : i64 = 0i64
    let mut wum : u64 = 0u64
    let mut wue : i64 = 0i64
    dd = 0u64
    while dd < 8u64 {
        pr_dfmul(PR_CEMD[dd], PR_CEED[dd], rlm, rle, 0u64)
        let wm0 : u64 = PR_DFM
        let we0 : i64 = PR_DFE
        pr_dfmul(PR_CEMU[dd], PR_CEEU[dd], rum, rue, 1u64)
        let wm1 : u64 = PR_DFM
        let we1 : i64 = PR_DFE
        if h == mb_gz_head() {
            PR_CRWMD[dd] = wm0
            PR_CRWED[dd] = we0
            PR_CRWMU[dd] = wm1
            PR_CRWEU[dd] = we1
        }
        pr_dfadd(wdm, wde, wm0, we0, 0u64)
        wdm = PR_DFM
        wde = PR_DFE
        pr_dfadd(wum, wue, wm1, we1, 1u64)
        wum = PR_DFM
        wue = PR_DFE
        dd = dd + 1u64
    }
    let onem : u64 = 1u64 << 63u64
    let onee : i64 = 0i64 - 63i64
    if pr_df_cmp(wdm, wde, onem, onee) > 0i64 { return 1u64 }
    if pr_df_cmp(wum, wue, onem, onee) < 0i64 { return 1u64 }
    PR_CSWMD[h] = wdm
    PR_CSWED[h] = wde
    PR_CSWMU[h] = wum
    PR_CSWEU[h] = wue
    return 0u64
}

/* deposit head h's one-voice mix (bounds and exact point) */
fn pr_cho_dep(h: u64) -> u64 {
    let mut d : u64 = 0u64
    while d < 128u64 {
        let i : u64 = h * 128u64 + d
        let sv : i64 = mb_pb_v_s(i)
        if sv == 0i64 {
            mb_pb_set_lo(i, 0i64, 0u64, 0u64, 0u64, 0u64, 0i64)
            mb_pb_set_hi(i, 0i64, 0u64, 0u64, 0u64, 0u64, 0i64)
            mb_pb_set_ex(i, 0i64, 0u64, 0u64, 0u64, 0u64, 0i64)
        }
        if sv != 0i64 {
            let v0 : u64 = mb_pb_v_l(i, 0u64)
            let v1 : u64 = mb_pb_v_l(i, 1u64)
            let v2 : u64 = mb_pb_v_l(i, 2u64)
            let ve : i64 = mb_pb_v_e(i)
            let mut pass : u64 = 0u64
            while pass < 2u64 {
                /* pass 0 writes the lo bound, pass 1 the hi bound */
                let mut pick_up : u64 = 0u64
                if sv < 0i64 { pick_up = 1u64 }
                if pass == 1u64 { pick_up = 1u64 - pick_up }
                let mut wm : u64 = PR_CSWMD[h]
                let mut we : i64 = PR_CSWED[h]
                if pick_up == 1u64 {
                    wm = PR_CSWMU[h]
                    we = PR_CSWEU[h]
                }
                /* exact 3-limb x 1-limb product */
                pr_mul64(v0, wm)
                let p0 : u64 = PR_MLO
                let mut c1 : u64 = PR_MHI
                pr_mul64(v1, wm)
                let s1 : u64 = c1 + PR_MLO
                let mut c2 : u64 = PR_MHI
                if s1 < PR_MLO { c2 = c2 + 1u64 }
                pr_mul64(v2, wm)
                let s2 : u64 = c2 + PR_MLO
                let mut c3 : u64 = PR_MHI
                if s2 < PR_MLO { c3 = c3 + 1u64 }
                if pass == 0u64 { mb_pb_set_lo(i, sv, p0, s1, s2, c3, ve + we) }
                if pass == 1u64 { mb_pb_set_hi(i, sv, p0, s1, s2, c3, ve + we) }
                pass = pass + 1u64
            }
            mb_pb_set_ex(i, sv, v0, v1, v2, 0u64, ve)
        }
        d = d + 1u64
    }
    return 0u64
}

fn pr_arm381() -> u64 {
    PR_CHOK = 0u64
    PR_CHREF = 0u64
    PR_CHTOP0 = 0u64
    PR_CHTOPO = 0u64
    PR_CHTOPS = 0u64
    if PR_PLEOK != 1u64 {
        pr_rs("the choir: fasting (no pleroma) -- the stalls stand empty" as u64)
        pr_rb(10u8)
        return 0u64
    }
    let va : u64 = mb_pb_vall()
    if va == 2u64 {
        pr_rs("the choir: value geometry foreign (named, lawful)" as u64)
        pr_rb(10u8)
        return 0u64
    }
    if va != 0u64 { return 381u64 }
    if pr_cho_r13() != 0u64 { return 381u64 }
    let mut sumok : u64 = 0u64
    let mut hh : u64 = 0u64
    while hh < 128u64 {
        PR_QH = hh
        let px : u64 = pr_har_px(1u64)
        if px != 0u64 { return 381u64 }
        let mut dd : u64 = 0u64
        while dd < 8u64 {
            if pr_har_asm(dd) != 0u64 { return 381u64 }
            dd = dd + 1u64
        }
        let sf : u64 = pr_cho_soft(hh)
        if sf == 1u64 { return 381u64 }
        if sf == 2u64 {
            PR_CHREF = PR_CHREF + 1u64
        }
        if sf == 0u64 {
            sumok = sumok + 1u64
            /* the top census: is delta 0 the strict top for this head? */
            let mut allsep : u64 = 1u64
            let mut isd0 : u64 = 1u64
            let mut d2 : u64 = 1u64
            while d2 < 8u64 {
                let c : i64 = pr_rd_cmp(0u64, 0u64, 1u64, d2)
                if c <= 0i64 {
                    let c2 : i64 = pr_rd_cmp(1u64, 0u64, 0u64, d2)
                    if c2 < 0i64 { isd0 = 0u64 }
                    if c2 >= 0i64 { allsep = 0u64 }
                }
                d2 = d2 + 1u64
            }
            if allsep == 0u64 { PR_CHTOPS = PR_CHTOPS + 1u64 }
            if allsep == 1u64 {
                if isd0 == 1u64 { PR_CHTOP0 = PR_CHTOP0 + 1u64 }
                if isd0 == 0u64 { PR_CHTOPO = PR_CHTOPO + 1u64 }
            }
            pr_cho_dep(hh)
        }
        hh = hh + 1u64
    }
    if PR_CHREF != 0u64 {
        pr_rs("the choir: refused heads=" as u64)
        pr_ru(PR_CHREF)
        pr_rs(" (ladder cap -- named); the thought is not deposited" as u64)
        pr_rb(10u8)
        return 0u64
    }
    /* the crowned head's weights must OVERLAP the pleroma's (two anchors,
     * one truth: different shift anchors, the same distribution) */
    let mut ov : u64 = 0u64
    let mut d3 : u64 = 0u64
    while d3 < 8u64 {
        let a_lo_m : u64 = PR_CRWMD[d3]
        let a_lo_e : i64 = PR_CRWED[d3]
        let a_hi_m : u64 = PR_CRWMU[d3]
        let a_hi_e : i64 = PR_CRWEU[d3]
        let b_lo_m : u64 = PR_WMD[d3]
        let b_lo_e : i64 = PR_WED[d3]
        let b_hi_m : u64 = PR_WMU[d3]
        let b_hi_e : i64 = PR_WEU[d3]
        let mut okp : u64 = 1u64
        if pr_df_cmp(a_lo_m, a_lo_e, b_hi_m, b_hi_e) > 0i64 { okp = 0u64 }
        if pr_df_cmp(b_lo_m, b_lo_e, a_hi_m, a_hi_e) > 0i64 { okp = 0u64 }
        if okp == 1u64 { ov = ov + 1u64 }
        d3 = d3 + 1u64
    }
    if ov != 8u64 { return 381u64 }
    mb_pb_mark(16384u64, 16384u64, 16384u64)
    PR_CHOK = 1u64
    pr_rs("the choir: heads=128 sumw-contains-1=" as u64)
    pr_ru(sumok)
    pr_rs("/128 refused=0 top-census: d0-first=" as u64)
    pr_ru(PR_CHTOP0)
    pr_rs(" other=" as u64)
    pr_ru(PR_CHTOPO)
    pr_rs(" straddle=" as u64)
    pr_ru(PR_CHTOPS)
    pr_rs(" crowned-overlap=8/8 r1r3=[" as u64)
    pr_ru(PR_R13MD)
    pr_rs("e" as u64)
    pr_ri(PR_R13ED)
    pr_rs("," as u64)
    pr_ru(PR_R13MU)
    pr_rs("e" as u64)
    pr_ri(PR_R13EU)
    pr_rs("] -- one thought, 16384 wide, deposited with its exact shadow" as u64)
    pr_rb(10u8)
    return 0u64
}

/* ============ the served faculties (probole consumes) ============ */

fn pr_x_dfm() -> u64 @export { return PR_DFM }
fn pr_x_dfe() -> i64 @export { return PR_DFE }
fn pr_x_df6(l0: u64, l1: u64, l2: u64, l3: u64, l4: u64, l5: u64, eb: i64, up: u64) -> i32 @export {
    let mut k : u64 = 0u64
    while k < 14u64 {
        PR_T14[k] = 0u64
        k = k + 1u64
    }
    PR_T14[0] = l0
    PR_T14[1] = l1
    PR_T14[2] = l2
    PR_T14[3] = l3
    PR_T14[4] = l4
    PR_T14[5] = l5
    pr_df_from14(up)
    PR_DFE = PR_DFE + eb
    return 0i32
}
fn pr_x_dfn2(hi: u64, lo: u64, eb: i64, up: u64) -> i32 @export {
    pr_dfn2(hi, lo, eb, up)
    return 0i32
}
fn pr_x_dfmul(ma: u64, ea: i64, mb: u64, eb: i64, up: u64) -> i32 @export {
    pr_dfmul(ma, ea, mb, eb, up)
    return 0i32
}
fn pr_x_dfadd(ma: u64, ea: i64, mb: u64, eb: i64, up: u64) -> i32 @export {
    pr_dfadd(ma, ea, mb, eb, up)
    return 0i32
}
/* |a - b| for a >= b (positive dyadic floats), rounded per up */
fn pr_x_dfsub(ma: u64, ea: i64, mb: u64, eb: i64, up: u64) -> i32 @export {
    if mb == 0u64 {
        PR_DFM = ma
        PR_DFE = ea
        return 0i32
    }
    let d : i64 = ea - eb
    if d >= 64i64 {
        /* b is below one ulp of a */
        PR_DFM = ma
        PR_DFE = ea
        if up == 0u64 {
            PR_DFM = PR_DFM - 1u64
            if PR_DFM < (1u64 << 63u64) {
                PR_DFM = (PR_DFM << 1u64) | 1u64
                PR_DFE = PR_DFE - 1i64
            }
        }
        return 0i32
    }
    let du : u64 = d as u64
    let mut hi : u64 = 0u64
    let mut lo : u64 = 0u64
    if du == 0u64 {
        lo = ma - mb
        hi = 0u64
    }
    if du != 0u64 {
        hi = ma >> (64u64 - du)
        lo = ma << du
        let mut bw : u64 = 0u64
        if lo < mb { bw = 1u64 }
        lo = lo - mb
        hi = hi - bw
    }
    pr_dfn2(hi, lo, eb, up)
    return 0i32
}
fn pr_x_dfcmp(ma: u64, ea: i64, mb: u64, eb: i64) -> i64 @export {
    return pr_df_cmp(ma, ea, mb, eb)
}
fn pr_x_ppb(m: u64, e: i64, up: u64) -> u64 @export {
    return pr_df_ppb(m, e, up)
}
fn pr_x_ri13_md() -> u64 @export { return PR_RI13MD }
fn pr_x_ri13_ed() -> i64 @export { return PR_RI13ED }
fn pr_x_ri13_mu() -> u64 @export { return PR_RI13MU }
fn pr_x_ri13_eu() -> i64 @export { return PR_RI13EU }
fn pr_x_chok() -> u64 @export { return PR_CHOK }
/* the directed reciprocal and square root, served to the projection */
fn pr_x_dfrecip(m: u64, e: i64, up: u64) -> i32 @export {
    pr_dfrecip(m, e, up)
    return 0i32
}
fn pr_x_dfsqrt(m: u64, e: i64, up: u64) -> i32 @export {
    pr_dfsqrt(m, e, up)
    return 0i32
}
/* exp(z) for SIGNED z = sg * m * 2^e, rounded per up; result in the df.
 * 0 ok / 1 ladder cap (|z| >= 24, refused by name at the caller) */
fn pr_x_exp_s(m: u64, e: i64, sg: i64, up: u64) -> u64 @export {
    return pr_cho_exp(m, e, sg, up)
}
/* pi as a certified interval at 2^-88 (2 limbs each bound), and its flag */
fn pr_x_pi_ok() -> u64 @export { return PR_PIOK }
fn pr_x_pi_l0() -> u64 @export { return PR_PIL0 }
fn pr_x_pi_l1() -> u64 @export { return PR_PIL1 }
fn pr_x_pi_h0() -> u64 @export { return PR_PIH0 }
fn pr_x_pi_h1() -> u64 @export { return PR_PIH1 }
/* yarn mscale as a certified interval at 2^-88 (2 limbs each bound) */
fn pr_x_yarn_ok() -> u64 @export { return PR_YARNOK }
fn pr_x_ms_l0() -> u64 @export { return PR_MSL0 }
fn pr_x_ms_l1() -> u64 @export { return PR_MSL1 }
fn pr_x_ms_h0() -> u64 @export { return PR_MSH0 }
fn pr_x_ms_h1() -> u64 @export { return PR_MSH1 }

/* ==================== the organ's spine ==================== */

fn pr_selfprove() -> u64 @export {
    PR_REPN = 0u64
    PR_SCROLL = 0u64
    let r0 : u64 = pr_arm367()
    if r0 != 0u64 { return r0 }
    let r1 : u64 = pr_arm368()
    if r1 != 0u64 { return r1 }
    let r2 : u64 = pr_arm369()
    if r2 != 0u64 { return r2 }
    let r3 : u64 = pr_arm377()
    if r3 != 0u64 { return r3 }
    let r4 : u64 = pr_arm378()
    if r4 != 0u64 { return r4 }
    let r5 : u64 = pr_arm379()
    if r5 != 0u64 { return r5 }
    let r6 : u64 = pr_arm380()
    if r6 != 0u64 { return r6 }
    let r7 : u64 = pr_arm381()
    if r7 != 0u64 { return r7 }
    let r8 : u64 = pr_arm_pi()
    if r8 != 0u64 { return r8 }
    let r9 : u64 = pr_arm_yarn()
    if r9 != 0u64 { return r9 }
    let r10 : u64 = pr_arm_yarnfreq()
    if r10 != 0u64 { return r10 }
    if mb_feast() == 0u64 {
        pr_rs("the discharge: fasting (no feast) -- the bound stands ready" as u64)
        pr_rb(10u8)
    }
    return 0u64
}

fn pr_addr() -> u64 @export { return PR_SCROLL }
fn pr_report_len() -> u64 @export { return PR_REPN }
fn pr_report_byte(i: u64) -> u8 @export {
    if i >= PR_REPN { return 0u8 }
    return PR_REP[i]
}

/* PERAS: what the organism cannot hold, it now bounds.  What it cannot
 * split, it refuses to pretend to split. */
