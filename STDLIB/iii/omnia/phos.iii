/* STDLIB/iii/omnia/phos.iii -- PHOS (light): the parity fold.  ONE exact operation -- the Walsh-Hadamard
 * transform over GF(2)^n (which IS the quantum Hadamard gate H^(x)n) -- shown to be the single object behind
 * facts in FIVE separate fields, computed EXACTLY, and turned into a real single-shot photon prediction.
 *
 * THE FIVE FACES OF ONE FOLD (each an exact, checkable computation below):
 *   LINEAR ALGEBRA   -- an exponential GF(2) solution set (2^(n-rank)) counted EXACTLY, no enumeration.
 *   HARMONIC ANALYSIS-- parity's Walsh spectrum is ONE delta; the transform RECOVERS the hidden linear string.
 *   QUANTUM COMPUTING-- that same transform is H^(x)n; Bernstein-Vazirani reads the hidden string in ONE query.
 *   OPTICS/PHOTONS   -- a photonic B-V interferometer outputs that n-bit string in a SINGLE shot, P = 1 exactly.
 *   COMPLEXITY THEORY-- full parity's Fourier mass sits entirely at the TOP degree n -> no low-degree (AC0)
 *                       circuit can compute it (Linial-Mansour-Nisan): why it is classically hard, exactly.
 * The unification is not analogy: it is the SAME matrix.  Quantum interference and classical Fourier analysis
 * over GF(2) are one operation; parity is its fixed point across all five fields.
 *
 * NO SELF-GRADING: the fast butterfly is cross-checked against direct summation; the count against brute force;
 * the negative (AND) proves the transform SEES nonlinearity (spread spectrum, not one delta) -- fold-defect.
 * Self-reliant: main() runs the proof; the exit code is the verdict.  Composes omnia/ptyxis (the GF(2) fold).
 * Ring R0. */
module phos

extern @abi(c-msvc-x64) fn pt_recognise_gf2(ptr: u64, n: u64) -> u64 from "ptyxis.iii"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

const PHM : u64 = 1024u64                    /* 2^10 : the demonstration lives on n = 10 bits */
var PH_F : [i64; 1024]                        /* the function / its Walsh transform (in place) */
var PH_ROWS : [u64; 8]

fn ph_pu(v: u64) -> u32 { if v >= 10u64 { ph_pu(v / 10u64) }   putchar((48u64 + (v % 10u64)) as i32)   return 1u32 }
fn ph_ps(sp: u64) -> u32 { let p : *u8 = sp as *u8   let mut i : u64 = 0u64   while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }   return 1u32 }
fn ph_par_weight(v0: u64) -> u64 { let mut v : u64 = v0   let mut w : u64 = 0u64   while v != 0u64 { w = w + (v & 1u64)   v = v >> 1u64 }   return w }

fn ph_pow2(k: u64) -> u64 { let mut r : u64 = 1u64   let mut i : u64 = 0u64   while i < k { r = r + r   i = i + 1u64 }   return r }
fn ph_par(v0: u64) -> u64 { let mut v : u64 = v0   let mut p : u64 = 0u64   while v != 0u64 { p = p ^ (v & 1u64)   v = v >> 1u64 }   return p }

fn ph_set_parity(a: u64) -> i32 {
    let mut x : u64 = 0u64
    while x < PHM {
        if ph_par(a & x) == 0u64 { PH_F[x] = 1i64 } else { PH_F[x] = 0i64 - 1i64 }
        x = x + 1u64
    }
    return 0i32
}
/* the fast Walsh-Hadamard transform (in place): F(s) = sum_x f(x) (-1)^(s.x).  This butterfly IS H^(x)n. */
fn ph_wht() -> i32 {
    let mut len : u64 = 1u64
    while len < PHM {
        let mut i : u64 = 0u64
        while i < PHM {
            let mut j : u64 = i
            while j < i + len {
                let a : i64 = PH_F[j]
                let b : i64 = PH_F[j + len]
                PH_F[j] = a + b
                PH_F[j + len] = a - b
                j = j + 1u64
            }
            i = i + len + len
        }
        len = len + len
    }
    return 0i32
}
/* independent cross-check: the single Walsh coefficient F(s) for parity-a, by DIRECT summation (no butterfly) */
fn ph_wht_direct(a: u64, s: u64) -> i64 {
    let mut acc : i64 = 0i64
    let mut x : u64 = 0u64
    while x < PHM {
        let fx : i64 = 1i64 - 2i64 * (ph_par(a & x) as i64)
        let sx : i64 = 1i64 - 2i64 * (ph_par(s & x) as i64)
        acc = acc + fx * sx
        x = x + 1u64
    }
    return acc
}

/* ================= THE PROOF (the organ runs itself; exit 0 = all five faces exact) ================= */
fn phos_selfprove() -> u64 @export {
    /* ===== FACE 1  LINEAR ALGEBRA: an exponential GF(2) solution set counted EXACTLY, verified vs brute =====
     * homogeneous system A x = 0 on n=6 vars; #solutions = 2^(n - rank A), with NO enumeration. */
    PH_ROWS[0] = 7u64   PH_ROWS[1] = 25u64   PH_ROWS[2] = 42u64
    let rank6 : u64 = pt_recognise_gf2((&PH_ROWS) as u64, 3u64)
    let fold_count : u64 = ph_pow2(6u64 - rank6)
    let mut brute : u64 = 0u64
    let mut x : u64 = 0u64
    while x < 64u64 {
        if ph_par(7u64 & x) == 0u64 { if ph_par(25u64 & x) == 0u64 { if ph_par(42u64 & x) == 0u64 { brute = brute + 1u64 } } }
        x = x + 1u64
    }
    if fold_count != brute { return 1u64 }        /* the fold counts the exponential set EXACTLY */
    /* the SAME line on n=48 vars yields 2^(48-rank) -- an un-enumerable count from a linear computation. */

    /* ===== FACE 2  HARMONIC ANALYSIS: parity's spectrum is ONE delta -> the hidden string is RECOVERED ===== */
    let a : u64 = 726u64                           /* hidden 10-bit string 0b1011010110 */
    ph_set_parity(a)
    ph_wht()
    if PH_F[a] != 1024i64 { return 2u64 }          /* the single peak sits exactly at s = a, height 2^n */
    let mut s : u64 = 0u64
    while s < PHM { if s != a { if PH_F[s] != 0i64 { return 3u64 } }   s = s + 1u64 }   /* zero everywhere else */
    if ph_wht_direct(a, a) != 1024i64 { return 4u64 }        /* cross-check the peak by direct sum */
    if ph_wht_direct(a, 100u64) != 0i64 { return 5u64 }      /* cross-check a null by direct sum */

    /* ===== FACE 3+4  QUANTUM + PHOTONS: Bernstein-Vazirani single-shot readout =====
     * B-V state is (1/2^(n/2)) sum_x (-1)^(a.x)|x>; applying H^(x)n = the SAME transform / 2^(n/2) puts amplitude
     * F(s)/2^n on |s>.  So amplitude 1 on |a|, 0 elsewhere -> P(a) = 1.  A photonic interferometer (each qubit a
     * dual-rail photon, each H a beamsplitter) outputs the 10-bit string 726 in ONE measurement, deterministically. */
    if (PH_F[a] / 1024i64) != 1i64 { return 6u64 }           /* output amplitude exactly 1 on the hidden string */

    /* ===== FACE 5  COMPLEXITY: full parity's Fourier mass is ALL at the TOP degree -> AC0 cannot compute it ===== */
    ph_set_parity(1023u64)                          /* full 10-bit parity: a = all ones */
    ph_wht()
    if PH_F[1023u64] != 1024i64 { return 7u64 }     /* the lone peak is at s = 1023 (all ones) ... */
    /* ... whose Hamming weight is 10 = n = the top degree.  All Fourier mass at the top level => no low-degree
     * approximation => no constant-depth (AC0) circuit computes parity.  The hardness IS the top-degree delta. */

    /* ===== NEGATIVE (the honest wall): a NONLINEAR function is NOT one delta -- the fold SEES the defect =====
     * f_AND(x) = -1 exactly at x = all-ones, +1 elsewhere.  Its Walsh spectrum is SPREAD (every coefficient
     * nonzero) -- it is not a single generator; the nonlinearity is fold-defect, not foldable structure. */
    let mut y : u64 = 0u64
    while y < PHM { if y == 1023u64 { PH_F[y] = 0i64 - 1i64 } else { PH_F[y] = 1i64 }   y = y + 1u64 }
    ph_wht()
    let mut nz : u64 = 0u64
    s = 0u64
    while s < PHM { if PH_F[s] != 0i64 { nz = nz + 1u64 }   s = s + 1u64 }
    if nz <= 1u64 { return 8u64 }                   /* MUST be spread: nonlinear = defect, not one fold-generator */
    return 0u64
}

/* the verifiable numbers, printed for inspection (recomputes independently of the proof above) */
fn phos_show() -> i32 @export {
    /* FACE 1: exact count of an exponential GF(2) solution space, no enumeration */
    PH_ROWS[0] = 7u64   PH_ROWS[1] = 25u64   PH_ROWS[2] = 42u64
    let r6 : u64 = pt_recognise_gf2((&PH_ROWS) as u64, 3u64)
    let mut brute : u64 = 0u64   let mut x : u64 = 0u64
    while x < 64u64 { if ph_par(7u64 & x) == 0u64 { if ph_par(25u64 & x) == 0u64 { if ph_par(42u64 & x) == 0u64 { brute = brute + 1u64 } } }   x = x + 1u64 }
    ph_ps("[1] LINEAR ALGEBRA  6-var XOR system rank=" as u64)   ph_pu(r6)
    ph_ps("  -> exact #solutions 2^(6-rank)=" as u64)   ph_pu(ph_pow2(6u64 - r6))
    ph_ps("  (brute-force count=" as u64)   ph_pu(brute)   ph_ps(")\n" as u64)
    /* the same on 48 vars: 3 independent rows, un-enumerable solution space, exact count */
    PH_ROWS[0] = 7u64   PH_ROWS[1] = 16711680u64   PH_ROWS[2] = 18374686479671623935u64
    let r48 : u64 = pt_recognise_gf2((&PH_ROWS) as u64, 3u64)
    ph_ps("                    48-var system rank=" as u64)   ph_pu(r48)
    ph_ps("  -> exact #solutions 2^(48-rank)=" as u64)   ph_pu(ph_pow2(48u64 - r48))
    ph_ps("  (2^48 space, from 3 rows, no enumeration)\n" as u64)
    /* FACE 2: parity's Walsh spectrum = ONE delta -> the hidden string recovered */
    let a : u64 = 726u64
    ph_set_parity(a)   ph_wht()
    let mut nz : u64 = 0u64   let mut peak : u64 = 0u64   x = 0u64
    while x < PHM { if PH_F[x] != 0i64 { nz = nz + 1u64   peak = x }   x = x + 1u64 }
    ph_ps("[2] HARMONIC        parity(a=726) Walsh spectrum: nonzero coeffs=" as u64)   ph_pu(nz)
    ph_ps("  peak at s=" as u64)   ph_pu(peak)   ph_ps("  height=" as u64)   ph_pu(PH_F[a] as u64)
    ph_ps("  -> hidden string RECOVERED\n" as u64)
    /* FACE 3/4: Bernstein-Vazirani single-shot; photon output */
    ph_ps("[3] QUANTUM         B-V output amplitude on |726> = F/2^n = " as u64)   ph_pu((PH_F[a] / 1024i64) as u64)
    ph_ps("  (one query, vs 10 classical)\n" as u64)
    ph_ps("[4] PHOTONS         photonic interferometer single-shot output = " as u64)   ph_pu(peak)   ph_ps("  P=1 exactly\n" as u64)
    /* FACE 5: full parity = top-degree delta -> AC0-hard */
    ph_set_parity(1023u64)   ph_wht()
    let mut deg : u64 = 0u64   x = 0u64
    while x < PHM { if PH_F[x] != 0i64 { deg = ph_par_weight(x) }   x = x + 1u64 }
    ph_ps("[5] COMPLEXITY      full parity Walsh peak at s=1023 degree(Hamming wt)=" as u64)   ph_pu(deg)
    ph_ps(" = n=10 = TOP -> no AC0 circuit\n" as u64)
    /* NEGATIVE: AND is spread */
    let mut y : u64 = 0u64
    while y < PHM { if y == 1023u64 { PH_F[y] = 0i64 - 1i64 } else { PH_F[y] = 1i64 }   y = y + 1u64 }
    ph_wht()
    nz = 0u64   x = 0u64
    while x < PHM { if PH_F[x] != 0i64 { nz = nz + 1u64 }   x = x + 1u64 }
    ph_ps("[-] NEGATIVE        nonlinear AND: Walsh nonzero coeffs=" as u64)   ph_pu(nz)   ph_ps(" (SPREAD, not one delta = fold-defect)\n" as u64)
    return 0i32
}

fn main(argc: i32, argv: u64) -> u64 {
    let _a : i32 = argc   let _v : u64 = argv
    phos_show()
    let r : u64 = phos_selfprove()
    ph_ps("phos_selfprove = " as u64)   ph_pu(r)
    if r == 0u64 { ph_ps("  GREEN: one fold, five fields, exact.\n" as u64) } else { ph_ps("  (arm failed)\n" as u64) }
    return r
}
