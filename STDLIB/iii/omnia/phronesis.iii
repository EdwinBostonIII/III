/* STDLIB/iii/omnia/phronesis.iii -- PHRONESIS (practical judgment): a mental-model lens is not
 * a mood -- it is an OBLIGATION the evidence must determine, or the lens is refused.
 *
 * Prose says "use first principles" and is unfalsifiable. The mandate form is checkable: each
 * lens carries ONE obligation scroll, and its discharge is the ONE entailment -- the evidence
 * house either determines the obligation or it does not. The discharge COMPOSES PRAXIS
 * (begin/pin/stand/judge); no second judging substrate exists or is wanted.
 *
 * THE LENSES AND THEIR OBLIGATIONS (lowercase idents, the scroll law):
 *   1 first-principles  [conclusion < pinned]        every leaf of the decomposition reaches a pin
 *   2 pre-mortem        [cause < falsifier_ran]      every named cause carries a RUN falsifier
 *   3 pareto            [rank < measurement]         the ranking rides measurements, never self-weights
 *   4 inversion         [negation < refuted_pin]     the strongest opposite case is refuted by a pin
 *   5 adversary         [verdict < assay]            the verifier's verdict stands under the assay
 *   6 calibration       [confidence < frequency]     the number derives from a pinned frequency
 *
 * HONEST BOUNDARY.  Whether an agent invoked a lens SINCERELY is not decidable; whether the
 * lens's obligation is determined by the presented evidence IS -- and an unknown lens is a
 * NAMED refusal (2), never a guess. Ring R0. */
module omnia_phronesis

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn px_begin() -> i32 from "praxis.iii"
extern @abi(c-msvc-x64) fn px_pin(s: u64) -> u64 from "praxis.iii"
extern @abi(c-msvc-x64) fn px_stand() -> u64 from "praxis.iii"
extern @abi(c-msvc-x64) fn px_judge(s: u64) -> u64 from "praxis.iii"

const PH_FIRST_PRINCIPLES : u64 = 1u64
const PH_PREMORTEM        : u64 = 2u64
const PH_PARETO           : u64 = 3u64
const PH_INVERSION        : u64 = 4u64
const PH_ADVERSARY        : u64 = 5u64
const PH_CALIBRATION      : u64 = 6u64

/* the lens's obligation scroll; 0 for an unknown lens (the caller must treat 0 as refusal). */
fn ph_obligation(lens: u64) -> u64 @export {
    if lens == PH_FIRST_PRINCIPLES { return "[conclusion < pinned]" as u64 }
    if lens == PH_PREMORTEM        { return "[cause < falsifier_ran]" as u64 }
    if lens == PH_PARETO           { return "[rank < measurement]" as u64 }
    if lens == PH_INVERSION        { return "[negation < refuted_pin]" as u64 }
    if lens == PH_ADVERSARY        { return "[verdict < assay]" as u64 }
    if lens == PH_CALIBRATION      { return "[confidence < frequency]" as u64 }
    return 0u64
}

/* THE DISCHARGE: 1 = the evidence determines the lens's obligation (the lens was EARNED);
 * 0 = REFUSED (the obligation is not reached); 2 = unknown lens, a NAMED refusal. */
fn ph_discharge(lens: u64, evidence: u64) -> u64 @export {
    let ob : u64 = ph_obligation(lens)
    if ob == 0u64 { return 2u64 }
    px_begin()
    px_pin(evidence)
    px_stand()
    return px_judge(ob)
}

fn phronesis_selfprove() -> u64 @export {
    /* ARM 1: FIRST PRINCIPLES -- a decomposition whose leaf reaches a pin discharges; a leaf
     * left hanging refuses. One unpinned assertion is all it takes. */
    if ph_discharge(PH_FIRST_PRINCIPLES, "[conclusion < leaf_a] [leaf_a < pinned]" as u64) != 1u64 { return 1u64 }
    if ph_discharge(PH_FIRST_PRINCIPLES, "[conclusion < leaf_b]" as u64) != 0u64 { return 1u64 }

    /* ARM 2: PRE-MORTEM -- a named cause with a RUN falsifier discharges; a hunch does not.
     * A cause with no falsifier is an unfalsifiable hedge, refused. */
    if ph_discharge(PH_PREMORTEM, "[cause < named_check] [named_check < falsifier_ran]" as u64) != 1u64 { return 2u64 }
    if ph_discharge(PH_PREMORTEM, "[cause < hunch]" as u64) != 0u64 { return 2u64 }

    /* ARM 3: PARETO -- leverage ranked over pinned measurements discharges; self-assigned
     * weights refuse. This kills self-grading at the lens level. */
    if ph_discharge(PH_PARETO, "[rank < pinned_count] [pinned_count < measurement]" as u64) != 1u64 { return 3u64 }
    if ph_discharge(PH_PARETO, "[rank < self_assigned]" as u64) != 0u64 { return 3u64 }

    /* ARM 4: INVERSION -- the strongest case AGAINST, refuted by a pin, discharges; an
     * unexamined negation refuses. */
    if ph_discharge(PH_INVERSION, "[negation < strongest_case] [strongest_case < refuted_pin]" as u64) != 1u64 { return 4u64 }
    if ph_discharge(PH_INVERSION, "[negation < unexamined]" as u64) != 0u64 { return 4u64 }

    /* ARM 5: ADVERSARY -- a verdict standing under the assay (the DOKIMASIA law: the verifier
     * separates known-bad from sound) discharges; a vibe does not. */
    if ph_discharge(PH_ADVERSARY, "[verdict < separator] [separator < assay]" as u64) != 1u64 { return 5u64 }
    if ph_discharge(PH_ADVERSARY, "[verdict < vibe]" as u64) != 0u64 { return 5u64 }

    /* ARM 6: CALIBRATION -- confidence derived from a pinned frequency discharges (the DOXA
     * derived-only law); a feeling refuses. A number with no frequency under it is not a number. */
    if ph_discharge(PH_CALIBRATION, "[confidence < pinned_frequency] [pinned_frequency < frequency]" as u64) != 1u64 { return 6u64 }
    if ph_discharge(PH_CALIBRATION, "[confidence < feeling]" as u64) != 0u64 { return 6u64 }

    /* ARM 7: THE UNKNOWN LENS IS A NAMED REFUSAL -- never judged, never guessed; and the
     * obligation table returns 0 for it (the caller cannot mistake absence for law). */
    if ph_discharge(99u64, "[a < b]" as u64) != 2u64 { return 7u64 }
    if ph_obligation(0u64) != 0u64 { return 7u64 }
    if ph_obligation(7u64) != 0u64 { return 7u64 }

    return 0u64
}

fn ph_ps(s: u64) -> u32 { let p : *u8 = s as *u8   let mut i : u64 = 0u64   while p[i] != 0u8 { putchar(p[i] as i32)   i = i + 1u64 }   return 1u32 }
fn ph_pu(v: u64) -> u32 { if v >= 10u64 { ph_pu(v / 10u64) }   putchar((48u64 + (v % 10u64)) as i32)   return 1u32 }

fn main(argc: i32, argv: u64) -> u64 {
    let _a : i32 = argc   let _v : u64 = argv
    let r : u64 = phronesis_selfprove()
    ph_ps("phronesis_selfprove = " as u64)   ph_pu(r)   putchar(10i32)
    if r == 0u64 { ph_ps("GREEN: six lenses, each an obligation the evidence must determine -- discharged on real chains, refused on broken ones, and the unknown lens is a NAMED refusal.\n" as u64) }
    return r
}
