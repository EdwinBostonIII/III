/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\prespec.iii
 *
 * III STDLIB - omnia::prespec
 *
 * Pre-specialization registry for the partial evaluator (Phase C.1).
 *
 * The registry maps a content-addressed composition hash to a sealed
 * direct-dispatch entry: at compile time, when cg_r3 sees a static-
 * intent call site whose composition_hash matches a registered entry,
 * it emits a 5-byte rel32 call directly to the dispatch fp -- erasing
 * the resolver code path entirely (Phase C.6 partial-evaluator hook).
 *
 * Registry state is populated at boot via prespec_register_compositions.
 * Each entry is:
 *
 *   composition_hash : u64    SHA-256 truncated to 64 bits over
 *                              (intent_primitive_id || hexad_bag ||
 *                               arg_typegram).
 *   intent_primitive : u8     PRIMITIVE_* id (verba/intent.iii).
 *   hexad_bag        : u8     packed hexad alignments (lower 7 bits =
 *                              hexad set; bit 7 reserved).
 *   k_value          : u64    fixed-point K * 1e9.
 *   dispatch_fp      : u64    function-pointer to the canonical lowered
 *                              implementation (typically a single
 *                              hand-tuned routine in numera or omnia).
 *
 * Capacity: 256 entries (~16 KiB BSS). Lookup is linear. The cg_r3
 * partial evaluator queries via prespec_lookup; on hit it emits the
 * direct call. On miss it falls through to the full resolve() path
 * (which itself benefits from omnia/resolver_memo and omnia/jit_fuse).
 *
 * Determinism: register order is deterministic (callers register in a
 * fixed boot sequence); lookups are pure function of composition_hash.
 *
 * Hexad: kind_compose. Ring: R0. K: 1.00.
 */

module omnia_prespec

const PRESPEC_CAP : u32 = 256u32

const PRESPEC_OK         : i32 =  0i32
const PRESPEC_E_FULL     : i32 = -1i32
const PRESPEC_E_BAD_ID   : i32 = -2i32
const PRESPEC_NOT_FOUND  : u32 = 0xFFFFFFFFu32

/* Storage. */
var PRESPEC_HASH      : [u64; 256]
var PRESPEC_PRIMITIVE : [u8;  256]
var PRESPEC_HEXAD_BAG : [u8;  256]
var PRESPEC_K_VALUE   : [u64; 256]
var PRESPEC_DISPATCH  : [u64; 256]
var PRESPEC_LIVE      : [u8;  256]
var PRESPEC_USED      : u32 = 0u32

/* Register a composition. 4-arg signature (avoids iiis-0 5+ stack-arg
 * codegen issue). The metadata fields are packed:
 *
 *   packed_meta layout:
 *     bits 0..7    = intent_primitive (PRIMITIVE_* id, 1..18)
 *     bits 8..15   = hexad_bag (lower 7 bits = HEXAD set; bit 7 reserved)
 *     bits 16..47  = k_value low 32 bits (K * 1e9 fits comfortably)
 *     bits 48..63  = reserved (must be zero)
 *
 * Returns:
 *   PRESPEC_OK on success
 *   PRESPEC_E_FULL when the registry is at capacity
 *
 * Idempotent: re-registering the same composition_hash updates in place. */
fn prespec_register(composition_hash: u64,
                    packed_meta: u64,
                    dispatch_fp: u64,
                    fallback_pid: u32) -> i32 @export {
    let l_h    : u64 = composition_hash
    let l_pm   : u64 = packed_meta
    let l_fp   : u64 = dispatch_fp
    let _l_fb  : u32 = fallback_pid    /* reserved for future use */

    let l_pid  : u8  = (l_pm & 0xFFu64) as u8
    let l_bag  : u8  = ((l_pm >> 8u64) & 0xFFu64) as u8
    let l_k    : u64 = (l_pm >> 16u64) & 0xFFFFFFFFu64

    /* Idempotent update path. */
    let mut i : u32 = 0u32
    while i < PRESPEC_CAP {
        if PRESPEC_LIVE[i] == 1u8 {
            if PRESPEC_HASH[i] == l_h {
                PRESPEC_PRIMITIVE[i] = l_pid
                PRESPEC_HEXAD_BAG[i] = l_bag
                PRESPEC_K_VALUE[i]   = l_k
                PRESPEC_DISPATCH[i]  = l_fp
                return PRESPEC_OK
            }
        }
        i = i + 1u32
    }

    /* New entry. */
    let mut j : u32 = 0u32
    while j < PRESPEC_CAP {
        if PRESPEC_LIVE[j] == 0u8 {
            PRESPEC_HASH[j]      = l_h
            PRESPEC_PRIMITIVE[j] = l_pid
            PRESPEC_HEXAD_BAG[j] = l_bag
            PRESPEC_K_VALUE[j]   = l_k
            PRESPEC_DISPATCH[j]  = l_fp
            PRESPEC_LIVE[j]      = 1u8
            if PRESPEC_USED < PRESPEC_CAP { PRESPEC_USED = PRESPEC_USED + 1u32 }
            return PRESPEC_OK
        }
        j = j + 1u32
    }
    return PRESPEC_E_FULL
}

/* Convenience packer for callers building packed_meta inline. */
fn prespec_pack_meta(intent_primitive: u8, hexad_bag: u8, k_value: u32) -> u64 @export {
    let l_pid : u64 = (intent_primitive as u64) & 0xFFu64
    let l_bag : u64 = ((hexad_bag as u64) & 0xFFu64) << 8u64
    let l_k   : u64 = ((k_value as u64) & 0xFFFFFFFFu64) << 16u64
    return l_pid | l_bag | l_k
}

/* Lookup by composition hash. Returns slot index or PRESPEC_NOT_FOUND. */
fn prespec_lookup(composition_hash: u64) -> u32 @export {
    let l_h : u64 = composition_hash
    let mut i : u32 = 0u32
    while i < PRESPEC_CAP {
        if PRESPEC_LIVE[i] == 1u8 {
            if PRESPEC_HASH[i] == l_h { return i }
        }
        i = i + 1u32
    }
    return PRESPEC_NOT_FOUND
}

/* Per-slot accessors (used by cg_r3 partial-evaluator hook). */
fn prespec_dispatch_fp(slot: u32) -> u64 @export {
    let l : u32 = slot
    if l >= PRESPEC_CAP { return 0u64 }
    if PRESPEC_LIVE[l] != 1u8 { return 0u64 }
    return PRESPEC_DISPATCH[l]
}

fn prespec_primitive(slot: u32) -> u8 @export {
    let l : u32 = slot
    if l >= PRESPEC_CAP { return 0u8 }
    if PRESPEC_LIVE[l] != 1u8 { return 0u8 }
    return PRESPEC_PRIMITIVE[l]
}

fn prespec_k_value(slot: u32) -> u64 @export {
    let l : u32 = slot
    if l >= PRESPEC_CAP { return 0u64 }
    if PRESPEC_LIVE[l] != 1u8 { return 0u64 }
    return PRESPEC_K_VALUE[l]
}

fn prespec_hexad_bag(slot: u32) -> u8 @export {
    let l : u32 = slot
    if l >= PRESPEC_CAP { return 0u8 }
    if PRESPEC_LIVE[l] != 1u8 { return 0u8 }
    return PRESPEC_HEXAD_BAG[l]
}

fn prespec_used() -> u32 @export {
    return PRESPEC_USED
}

fn prespec_capacity() -> u32 @export {
    return PRESPEC_CAP
}

fn prespec_drop(slot: u32) -> i32 @export {
    let l : u32 = slot
    if l >= PRESPEC_CAP { return PRESPEC_E_BAD_ID }
    if PRESPEC_LIVE[l] != 1u8 { return PRESPEC_E_BAD_ID }
    PRESPEC_LIVE[l]      = 0u8
    PRESPEC_HASH[l]      = 0u64
    PRESPEC_PRIMITIVE[l] = 0u8
    PRESPEC_HEXAD_BAG[l] = 0u8
    PRESPEC_K_VALUE[l]   = 0u64
    PRESPEC_DISPATCH[l]  = 0u64
    if PRESPEC_USED > 0u32 { PRESPEC_USED = PRESPEC_USED - 1u32 }
    return PRESPEC_OK
}

/* Bulk registration of well-known compositions (Phase C.1).
 *
 * Single source of truth: COMPILER/BOOT/iii_compositions.def.
 * The block below between the AUTO-GENERATED sentinels is rewritten
 * by COMPILER/BOOT/gen_compositions.sh whenever the .def changes.
 * cg_r3.c reads the SAME .def via the generated iii_compositions.h.
 * Drift is structurally impossible.
 *
 * synthetic_composition_hash encoding (mirrors iii_compositions.h):
 *   bits 0..15  = sequence index
 *   bits 16..23 = primitive_id
 *   bits 24..31 = hexad_bag
 *   bits 32..63 = synthetic-marker 0x494E5450 ("INTP")
 */
