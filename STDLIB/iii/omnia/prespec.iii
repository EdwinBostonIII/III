/* Synthetic composition_hash for bulk-registered entries. Avoids
 * collision with run-time hashes via a fixed marker word. */
fn _prespec_synth_hash(seq_idx: u32, primitive_id: u8, hexad_bag: u8) -> u64 {
    let s_l : u64 = (seq_idx as u64) & 0xFFFFu64
    let p_l : u64 = ((primitive_id as u64) & 0xFFu64) << 16u64
    let b_l : u64 = ((hexad_bag as u64) & 0xFFu64) << 24u64
    let m_l : u64 = 0x494E5450u64 << 32u64    /* "INTP" marker */
    return s_l | p_l | b_l | m_l
}

fn prespec_reset() -> i32 @export {
    let mut i : u32 = 0u32
    while i < PRESPEC_CAP {
        PRESPEC_LIVE[i]      = 0u8
        PRESPEC_HASH[i]      = 0u64
        PRESPEC_PRIMITIVE[i] = 0u8
        PRESPEC_HEXAD_BAG[i] = 0u8
        PRESPEC_K_VALUE[i]   = 0u64
        PRESPEC_DISPATCH[i]  = 0u64
        i = i + 1u32
    }
    PRESPEC_USED = 0u32
    return PRESPEC_OK
}
