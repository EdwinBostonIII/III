/* ==================== the report and the scroll ==================== */

var PB_REP : [u8; 4096]
var PB_REPN : u64 = 0u64
var PB_SCROLL : u64 = 0u64
var PB_SCROLL2 : u64 = 0u64

fn pb_slen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { i = i + 1u64 }
    return i
}

fn pb_rb(b: u8) -> i32 {
    if PB_REPN >= 4095u64 { return 0i32 }
    PB_REP[PB_REPN] = b
    PB_REPN = PB_REPN + 1u64
    return 0i32
}

fn pb_rs(s: u64) -> i32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 {
        pb_rb(p[i])
        i = i + 1u64
    }
    return 0i32
}

fn pb_ru(v: u64) -> i32 {
    if v >= 10u64 { pb_ru(v / 10u64) }
    pb_rb((48u64 + (v % 10u64)) as u8)
    return 0i32
}

fn pb_ri(v: i64) -> i32 {
    if v < 0i64 {
        pb_rb(45u8)
        pb_ru((0i64 - v) as u64)
        return 0i32
    }
    pb_ru(v as u64)
    return 0i32
}

/* ==================== the aligned multi-limb compares ==================== */

/* 12-limb scratch pair for exponent-aligned bound comparisons */
var PB_U : [u64; 12]
var PB_V : [u64; 12]

/* banked bound accessors: bank 0 = the attention vessel, 1..3 = the ffn */
fn pb_gs(bank: u64, r: u64, which: u64) -> i64 {
    if bank == 0u64 { return mb_pb_o_s(r, which) }
    return mb_pb_b_s(bank, r, which)
}
fn pb_gl(bank: u64, r: u64, which: u64, k: u64) -> u64 {
    if bank == 0u64 { return mb_pb_o_l(r, which, k) }
    return mb_pb_b_l(bank, r, which, k)
}
fn pb_ge(bank: u64, r: u64, which: u64) -> i64 {
    if bank == 0u64 { return mb_pb_o_e(r, which) }
    return mb_pb_b_e(bank, r, which)
}

/* load bound (bank, r, which) shifted left by (its exp - emin) into U or
 * V.  returns 1 on shift overflow (named guard at the caller) */
fn pb_ld(bank: u64, r: u64, which: u64, emin: i64, dst: u64) -> u64 {
    let mut k : u64 = 0u64
    while k < 12u64 {
        if dst == 0u64 { PB_U[k] = 0u64 }
        if dst == 1u64 { PB_V[k] = 0u64 }
        k = k + 1u64
    }
    let d : i64 = pb_ge(bank, r, which) - emin
    if d < 0i64 { return 1u64 }
    if d > 256i64 { return 1u64 }
    let w : u64 = (d as u64) / 64u64
    let b : u64 = (d as u64) % 64u64
    k = 0u64
    while k < 8u64 {
        let v : u64 = pb_gl(bank, r, which, k)
        if v != 0u64 {
            let pos : u64 = k + w
            if pos >= 12u64 { return 1u64 }
            if dst == 0u64 { PB_U[pos] = PB_U[pos] | (v << b) }
            if dst == 1u64 { PB_V[pos] = PB_V[pos] | (v << b) }
            if b != 0u64 {
                let sp : u64 = v >> (64u64 - b)
                if sp != 0u64 {
                    if pos + 1u64 >= 12u64 { return 1u64 }
                    if dst == 0u64 { PB_U[pos + 1u64] = PB_U[pos + 1u64] | sp }
                    if dst == 1u64 { PB_V[pos + 1u64] = PB_V[pos + 1u64] | sp }
                }
            }
        }
        k = k + 1u64
    }
    return 0u64
}

/* signed compare of bounds (bank, r, wa) vs (bank, r, wb); 9 = guard */
fn pb_cmp(bank: u64, r: u64, wa: u64, wb: u64) -> i64 {
    let sa : i64 = pb_gs(bank, r, wa)
    let sb : i64 = pb_gs(bank, r, wb)
    if sa > sb { return 1i64 }
    if sa < sb { return 0i64 - 1i64 }
    if sa == 0i64 { return 0i64 }
    let mut emin : i64 = pb_ge(bank, r, wa)
    let eb : i64 = pb_ge(bank, r, wb)
    if eb < emin { emin = eb }
    if pb_ld(bank, r, wa, emin, 0u64) != 0u64 { return 9i64 }
    if pb_ld(bank, r, wb, emin, 1u64) != 0u64 { return 9i64 }
    let mut cmp : i64 = 0i64
    let mut k : u64 = 12u64
    while k != 0u64 {
        k = k - 1u64
        if cmp == 0i64 {
            let x : u64 = PB_U[k]
            let y : u64 = PB_V[k]
            if x > y { cmp = 1i64 }
            if x < y { cmp = 0i64 - 1i64 }
        }
    }
    if sa < 0i64 { return 0i64 - cmp }
    return cmp
}

/* the width hi - lo of row (bank, r) as a top-bit exponent (~ 2^ret);
 * returns -100000 for zero width, 100000 on guard */
fn pb_width_exp(bank: u64, r: u64) -> i64 {
    let sl : i64 = pb_gs(bank, r, 0u64)
    let sh : i64 = pb_gs(bank, r, 1u64)
    let mut emin : i64 = pb_ge(bank, r, 0u64)
    let eb : i64 = pb_ge(bank, r, 1u64)
    if eb < emin { emin = eb }
    if pb_ld(bank, r, 1u64, emin, 0u64) != 0u64 { return 100000i64 }
    if pb_ld(bank, r, 0u64, emin, 1u64) != 0u64 { return 100000i64 }
    /* U := hi, V := lo as SIGNED values; width = hi - lo = U + (-V):
     * both were loaded as magnitudes; fold signs into a subtraction by
     * cases.  hi >= lo is already certified by the containment pass, so
     * width = |hi_val - lo_val| computed by magnitude algebra. */
    let mut k : u64 = 0u64
    if sl == 0i64 {
        if sh == 0i64 { return 0i64 - 100000i64 }
    }
    let mut same : u64 = 0u64
    if sl > 0i64 {
        if sh > 0i64 { same = 1u64 }
    }
    if sl < 0i64 {
        if sh < 0i64 { same = 1u64 }
    }
    if same == 1u64 {
        /* same sign: width = |U - V| in magnitude */
        let mut cmp : i64 = 0i64
        k = 12u64
        while k != 0u64 {
            k = k - 1u64
            if cmp == 0i64 {
                let x : u64 = PB_U[k]
                let y : u64 = PB_V[k]
                if x > y { cmp = 1i64 }
                if x < y { cmp = 0i64 - 1i64 }
            }
        }
        if cmp == 0i64 { return 0i64 - 100000i64 }
        let mut borrow : u64 = 0u64
        k = 0u64
        while k < 12u64 {
            let mut a : u64 = PB_U[k]
            let mut b : u64 = PB_V[k]
            if cmp < 0i64 {
                a = PB_V[k]
                b = PB_U[k]
            }
            let d : u64 = a - b
            let mut b2 : u64 = 0u64
            if a < b { b2 = 1u64 }
            let e : u64 = d - borrow
            if d < borrow { b2 = b2 + 1u64 }
            PB_U[k] = e
            borrow = b2
            k = k + 1u64
        }
    }
    if same == 0u64 {
        /* signs differ (or one is zero): width = |hi| + |lo| */
        let mut carry : u64 = 0u64
        k = 0u64
        while k < 12u64 {
            let a : u64 = PB_U[k] + PB_V[k]
            let mut c2 : u64 = 0u64
            if a < PB_V[k] { c2 = 1u64 }
            let b : u64 = a + carry
            if b < carry { c2 = c2 + 1u64 }
            PB_U[k] = b
            carry = c2
            k = k + 1u64
        }
    }
    /* top bit of U */
    let mut top : i64 = 0i64 - 100000i64
    k = 12u64
    let mut found : u64 = 0u64
    while k != 0u64 {
        k = k - 1u64
        if found == 0u64 {
            let v : u64 = PB_U[k]
            if v != 0u64 {
                let mut bl : u64 = 0u64
                let mut t : u64 = v
                while t != 0u64 {
                    t = t >> 1u64
                    bl = bl + 1u64
                }
                top = emin + (64u64 * k) as i64 + (bl as i64) - 1i64
                found = 1u64
            }
        }
    }
    return top
}

/* ==================== signed df add (homecoming algebra) ============== */

var PB_SDS : i64 = 0i64
var PB_SDM : u64 = 0u64
var PB_SDE : i64 = 0i64

/* (sa, ma*2^ea) + (sb, mb*2^eb), rounded toward -inf (dir 0) / +inf (1).
 * directions are on the VALUE, so the magnitude rounding flips with the
 * result sign. */
fn pb_sadd(sa: i64, ma: u64, ea: i64, sb: i64, mb: u64, eb: i64, dir: u64) -> i32 {
    if sa == 0i64 {
        PB_SDS = sb
        PB_SDM = mb
        PB_SDE = eb
        return 0i32
    }
    if sb == 0i64 {
        PB_SDS = sa
        PB_SDM = ma
        PB_SDE = ea
        return 0i32
    }
    if sa == sb {
        let mut magdir : u64 = dir
        if sa < 0i64 { magdir = 1u64 - dir }
        pr_x_dfadd(ma, ea, mb, eb, magdir)
        PB_SDS = sa
        PB_SDM = pr_x_dfm()
        PB_SDE = pr_x_dfe()
        return 0i32
    }
    let c : i64 = pr_x_dfcmp(ma, ea, mb, eb)
    if c == 0i64 {
        PB_SDS = 0i64
        PB_SDM = 0u64
        PB_SDE = 0i64
        return 0i32
    }
    let mut rs : i64 = sa
    let mut bm : u64 = ma
    let mut be : i64 = ea
    let mut sm : u64 = mb
    let mut se : i64 = eb
    if c < 0i64 {
        rs = sb
        bm = mb
        be = eb
        sm = ma
        se = ea
    }
    let mut magdir2 : u64 = dir
    if rs < 0i64 { magdir2 = 1u64 - dir }
    pr_x_dfsub(bm, be, sm, se, magdir2)
    PB_SDS = rs
    PB_SDM = pr_x_dfm()
    PB_SDE = pr_x_dfe()
    if PB_SDM == 0u64 { PB_SDS = 0i64 }
    return 0i32
}

/* ==================== arm 382: THE PROBOLE ==================== */

var PB_STRAD : u64 = 0u64
var PB_SGP : u64 = 0u64
var PB_SGN : u64 = 0u64
var PB_SGZ : u64 = 0u64
var PB_WMAX : i64 = 0i64
var PB_PROJ_OK : u64 = 0u64

fn pb_arm382() -> u64 {
    PB_PROJ_OK = 0u64
    if pr_x_chok() != 1u64 {
        pb_rs("the probole: fasting (no deposited thought) -- the law stands ready" as u64)
        pb_rb(10u8)
        return 0u64
    }
    let rc : u64 = mb_pb_project_par()
    if rc == 3u64 {
        pb_rs("the probole: o_proj absent from the feast (named, lawful)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    if rc == 2u64 {
        pb_rs("the probole: refused (geometry or guard -- named)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    if rc != 0u64 { return 382u64 }
    /* the loom teeth: witness rows re-derived by the SEQUENTIAL engine on
     * the main thread must equal the fleet limb for limb */
    let mut wit : u64 = 0u64
    let mut wi : u64 = 0u64
    while wi < 10u64 {
        let mut wr : u64 = wi * 796u64
        if wi == 9u64 { wr = 7167u64 }
        if mb_pb_row_witness(wr) != 0u64 { return 382u64 }
        let mut wok : u64 = 1u64
        let mut wv : u64 = 0u64
        while wv < 3u64 {
            let ss : i64 = mb_pb_w_s(wv)
            let ee : i64 = mb_pb_w_e(wv)
            if ss != mb_pb_o_s(wr, wv) { wok = 0u64 }
            if ee != mb_pb_o_e(wr, wv) { wok = 0u64 }
            let mut kk : u64 = 0u64
            while kk < 8u64 {
                let la : u64 = mb_pb_w_l(wv, kk)
                let lb : u64 = mb_pb_o_l(wr, wv, kk)
                if la != lb { wok = 0u64 }
                kk = kk + 1u64
            }
            wv = wv + 1u64
        }
        if wok == 1u64 { wit = wit + 1u64 }
        wi = wi + 1u64
    }
    if wit != 10u64 { return 382u64 }
    let mut contained : u64 = 0u64
    PB_STRAD = 0u64
    PB_SGP = 0u64
    PB_SGN = 0u64
    PB_SGZ = 0u64
    PB_WMAX = 0i64 - 100000i64
    let mut r : u64 = 0u64
    while r < 7168u64 {
        let c1 : i64 = pb_cmp(0u64, r, 0u64, 2u64)
        let c2 : i64 = pb_cmp(0u64, r, 2u64, 1u64)
        if c1 == 9i64 { return 382u64 }
        if c2 == 9i64 { return 382u64 }
        if c1 <= 0i64 {
            if c2 <= 0i64 { contained = contained + 1u64 }
        }
        let sl : i64 = mb_pb_o_s(r, 0u64)
        let sh : i64 = mb_pb_o_s(r, 1u64)
        let mut str8 : u64 = 0u64
        if sl < 0i64 {
            if sh >= 0i64 { str8 = 1u64 }
        }
        if sl == 0i64 { str8 = 1u64 }
        if sh == 0i64 { str8 = 1u64 }
        if str8 == 1u64 { PB_STRAD = PB_STRAD + 1u64 }
        let sx : i64 = mb_pb_o_s(r, 2u64)
        if sx > 0i64 { PB_SGP = PB_SGP + 1u64 }
        if sx < 0i64 { PB_SGN = PB_SGN + 1u64 }
        if sx == 0i64 { PB_SGZ = PB_SGZ + 1u64 }
        let we : i64 = pb_width_exp(0u64, r)
        if we == 100000i64 { return 382u64 }
        if we > PB_WMAX { PB_WMAX = we }
        r = r + 1u64
    }
    if contained != 7168u64 { return 382u64 }
    PB_PROJ_OK = 1u64
    pb_rs("the probole: o_proj woven by 4 weavers (rows never split, timing free) witness-rows=10/10 limb-exact containment(interval holds exact)=7168/7168 law-of-signs=endpoint-selection (every product exact) prefix-law=every-row-x3 straddle-zero=" as u64)
    pb_ru(PB_STRAD)
    pb_rs(" exact-signs p/n/z=" as u64)
    pb_ru(PB_SGP)
    pb_rs("/" as u64)
    pb_ru(PB_SGN)
    pb_rs("/" as u64)
    pb_ru(PB_SGZ)
    pb_rs(" shadow(max-width-exp2)=" as u64)
    pb_ri(PB_WMAX)
    pb_rb(10u8)
    return 0u64
}

/* ==================== arm 383: THE NOSTOS ==================== */

var PB_HSTRAD : u64 = 0u64
var PB_HWMAX : i64 = 0i64
var PB_HCONT : u64 = 0u64
var PB_NOST_OK : u64 = 0u64

/* X' STORED: the homecoming's fat interval, dim by dim (signed dfs) --
 * the standing input of the threpsis */
var PB_FLS : [i64; 7168]
var PB_FLM : [u64; 7168]
var PB_FLE : [i64; 7168]
var PB_FHS : [i64; 7168]
var PB_FHM : [u64; 7168]
var PB_FHE : [i64; 7168]

/* bound (bank, r, which) as a signed df, rounded per up (sticky honored) */
var PB_ODS : i64 = 0i64
var PB_ODM : u64 = 0u64
var PB_ODE : i64 = 0i64
fn pb_odf(bank: u64, r: u64, which: u64, up: u64) -> i32 {
    let s : i64 = pb_gs(bank, r, which)
    if s == 0i64 {
        PB_ODS = 0i64
        PB_ODM = 0u64
        PB_ODE = 0i64
        return 0i32
    }
    /* top two limbs + sticky */
    let mut t : u64 = 8u64
    let mut k : u64 = 8u64
    while k != 0u64 {
        k = k - 1u64
        if t == 8u64 {
            if pb_gl(bank, r, which, k) != 0u64 { t = k }
        }
    }
    let hv : u64 = pb_gl(bank, r, which, t)
    let mut lv : u64 = 0u64
    if t != 0u64 { lv = pb_gl(bank, r, which, t - 1u64) }
    let mut st : u64 = 0u64
    k = 0u64
    while k + 1u64 < t {
        st = st | pb_gl(bank, r, which, k)
        k = k + 1u64
    }
    /* the magnitude rounding direction flips with the sign */
    let mut magup : u64 = up
    if s < 0i64 { magup = 1u64 - up }
    if magup == 1u64 {
        if st != 0u64 { lv = lv | 1u64 }
    }
    let mut ebase : i64 = pb_ge(bank, r, which)
    if t != 0u64 { ebase = ebase + 64i64 * ((t as i64) - 1i64) }
    if t == 0u64 {
        pr_x_dfn2(0u64, hv, ebase, magup)
    }
    if t != 0u64 {
        pr_x_dfn2(hv, lv, ebase, magup)
    }
    PB_ODS = s
    PB_ODM = pr_x_dfm()
    PB_ODE = pr_x_dfe()
    return 0i32
}

/* one bound of X + O*ri13: sel 0 = fat-lo, 1 = fat-hi, 2 = tight-lo,
 * 3 = tight-hi.  tight uses the EXACT O (which 2). */
fn pb_home(r: u64, sel: u64) -> i32 {
    let mut which : u64 = 0u64
    if sel == 1u64 { which = 1u64 }
    if sel >= 2u64 { which = 2u64 }
    let mut dir : u64 = 0u64
    if sel == 1u64 { dir = 1u64 }
    if sel == 3u64 { dir = 1u64 }
    pb_odf(0u64, r, which, dir)
    let os : i64 = PB_ODS
    let om : u64 = PB_ODM
    let oe : i64 = PB_ODE
    let mut ps : i64 = 0i64
    let mut pm : u64 = 0u64
    let mut pe : i64 = 0i64
    if os != 0i64 {
        /* O * ri13 (ri13 > 0): directed by the value direction */
        let mut want_up_mag : u64 = dir
        if os < 0i64 { want_up_mag = 1u64 - dir }
        let mut rm : u64 = pr_x_ri13_md()
        let mut re : i64 = pr_x_ri13_ed()
        if want_up_mag == 1u64 {
            rm = pr_x_ri13_mu()
            re = pr_x_ri13_eu()
        }
        pr_x_dfmul(om, oe, rm, re, want_up_mag)
        ps = os
        pm = pr_x_dfm()
        pe = pr_x_dfe()
    }
    /* + X (the exact voice, a tight point) */
    let xv : i64 = mb_gz_xv(r)
    let mut xs : i64 = 0i64
    let mut xm : u64 = 0u64
    let mut xe : i64 = 0i64
    if xv != 0i64 {
        let mut mg : u64 = xv as u64
        if xv < 0i64 { mg = (0i64 - xv) as u64 }
        xs = 1i64
        if xv < 0i64 { xs = 0i64 - 1i64 }
        pr_x_dfn2(0u64, mg, 0i64 - 24i64, 0u64)
        xm = pr_x_dfm()
        xe = pr_x_dfe()
    }
    pb_sadd(ps, pm, pe, xs, xm, xe, dir)
    return 0i32
}

fn pb_arm383() -> u64 {
    if PB_PROJ_OK != 1u64 {
        pb_rs("the nostos: fasting (no projection) -- the door stands open" as u64)
        pb_rb(10u8)
        return 0u64
    }
    PB_HSTRAD = 0u64
    PB_HCONT = 0u64
    PB_HWMAX = 0i64 - 100000i64
    let mut r : u64 = 0u64
    while r < 7168u64 {
        pb_home(r, 0u64)
        let fl_s : i64 = PB_SDS
        let fl_m : u64 = PB_SDM
        let fl_e : i64 = PB_SDE
        pb_home(r, 1u64)
        let fh_s : i64 = PB_SDS
        let fh_m : u64 = PB_SDM
        let fh_e : i64 = PB_SDE
        PB_FLS[r] = fl_s
        PB_FLM[r] = fl_m
        PB_FLE[r] = fl_e
        PB_FHS[r] = fh_s
        PB_FHM[r] = fh_m
        PB_FHE[r] = fh_e
        pb_home(r, 2u64)
        let tl_s : i64 = PB_SDS
        let tl_m : u64 = PB_SDM
        let tl_e : i64 = PB_SDE
        pb_home(r, 3u64)
        let th_s : i64 = PB_SDS
        let th_m : u64 = PB_SDM
        let th_e : i64 = PB_SDE
        /* the tight exact route must sit inside the fat interval route */
        let mut okc : u64 = 1u64
        /* fl <= tl */
        let mut c1 : i64 = 0i64
        if fl_s > tl_s { c1 = 1i64 }
        if fl_s < tl_s { c1 = 0i64 - 1i64 }
        if fl_s == tl_s {
            if fl_s != 0i64 {
                c1 = pr_x_dfcmp(fl_m, fl_e, tl_m, tl_e)
                if fl_s < 0i64 { c1 = 0i64 - c1 }
            }
        }
        if c1 > 0i64 { okc = 0u64 }
        /* th <= fh */
        let mut c2 : i64 = 0i64
        if th_s > fh_s { c2 = 1i64 }
        if th_s < fh_s { c2 = 0i64 - 1i64 }
        if th_s == fh_s {
            if th_s != 0i64 {
                c2 = pr_x_dfcmp(th_m, th_e, fh_m, fh_e)
                if th_s < 0i64 { c2 = 0i64 - c2 }
            }
        }
        if c2 > 0i64 { okc = 0u64 }
        if okc == 1u64 { PB_HCONT = PB_HCONT + 1u64 }
        /* the sign shadow: can the machine swear the sign of X'? */
        let mut str8 : u64 = 0u64
        if fl_s < 0i64 {
            if fh_s >= 0i64 { str8 = 1u64 }
        }
        if fl_s == 0i64 { str8 = 1u64 }
        if fh_s == 0i64 { str8 = 1u64 }
        if str8 == 1u64 { PB_HSTRAD = PB_HSTRAD + 1u64 }
        /* the width shadow: (fh - fl) top exponent via df subtraction */
        pb_sadd(fh_s, fh_m, fh_e, 0i64 - fl_s, fl_m, fl_e, 1u64)
        if PB_SDS != 0i64 {
            /* top-bit exponent of a normalized df is its e + 63 */
            let wexp : i64 = PB_SDE + 63i64
            if wexp > PB_HWMAX { PB_HWMAX = wexp }
        }
        r = r + 1u64
    }
    if PB_HCONT != 7168u64 { return 383u64 }
    /* the scroll: the law of the projection sealed */
    eol_reset()
    let doc : u64 = "[interval projection = certified containment] [certified containment < exact decision] [interval width = named shadow] [straddled sign = refused decision] [refused decision < certified containment]" as u64
    let dl : u64 = pb_slen(doc)
    if eol_read(doc, dl) < 0i64 { return 383u64 }
    if eol_lawcheck() != 0u64 { return 383u64 }
    let a1 : u64 = eol_addr()
    if a1 == 0u64 { return 383u64 }
    let ip : u64 = "interval projection" as u64
    let xd : u64 = "exact decision" as u64
    if eol_entails(ip, pb_slen(ip), 0u64, xd, pb_slen(xd)) != 1u64 { return 383u64 }
    if eol_entails(xd, pb_slen(xd), 0u64, ip, pb_slen(ip)) != 0u64 { return 383u64 }
    let rd : u64 = "refused decision" as u64
    if eol_entails(rd, pb_slen(rd), 0u64, xd, pb_slen(xd)) != 1u64 { return 383u64 }
    eol_reset()
    if eol_read(doc, dl) < 0i64 { return 383u64 }
    if eol_addr() != a1 { return 383u64 }
    PB_SCROLL = a1
    PB_NOST_OK = 1u64
    pb_rs("the nostos: X' = X + O/(r1*r3) dims=7168 tight-route-inside-fat=" as u64)
    pb_ru(PB_HCONT)
    pb_rs("/7168 sign-straddle=" as u64)
    pb_ru(PB_HSTRAD)
    pb_rs(" shadow(max-width-exp2)=" as u64)
    pb_ri(PB_HWMAX)
    pb_rs(" voice=row" as u64)
    pb_ru(mb_gz_voice())
    pb_rs(" premises: theta-base=10000 yarn=named ffn=named o-proj-width=16384 (the ledger corrected the plan)" as u64)
    pb_rb(10u8)
    return 0u64
}

/* ============ arms 384-385: THE THREPSIS + THE PEPSIS ============
 * The feed-forward of blk.0 under the very same law.  X' (the stored
 * homecoming) is rms-normed through a certified interval scalar, scaled
 * by the exact gamma4, and deposited as the standing thought; the gate
 * and up matrices are woven by the four weavers into their banks; the
 * gate passes through the STANDING sigma ladders (exp + reciprocal --
 * SiLU invents no new mathematics), the nourishment h = g*sigma(g)*u is
 * hulled and deposited; the down matrix returns 7168 wide; and the
 * digestion X'' = X' + FFN(X') closes the layer.  Every saturation is
 * COUNTED and NAMED; every fleet row owes a sequential witness; every
 * interval must hold its exact point. */

/* the rms4 interval and its reciprocal (positive dfs) */
var PB_R4LM : u64 = 0u64
var PB_R4LE : i64 = 0i64
var PB_R4HM : u64 = 0u64
var PB_R4HE : i64 = 0i64
var PB_I4LM : u64 = 0u64
var PB_I4LE : i64 = 0i64
var PB_I4HM : u64 = 0u64
var PB_I4HE : i64 = 0i64
/* sum-of-squares: forward and reversed directed folds */
var PB_QFLM : u64 = 0u64
var PB_QFLE : i64 = 0i64
var PB_QFHM : u64 = 0u64
var PB_QFHE : i64 = 0i64
var PB_QRLM : u64 = 0u64
var PB_QRLE : i64 = 0i64
var PB_QRHM : u64 = 0u64
var PB_QRHE : i64 = 0i64
/* the threpsis censuses */
var PB_TSAT : u64 = 0u64
var PB_TWMAX : i64 = 0i64
var PB_THREP_OK : u64 = 0u64
/* sigma result channel (sign 0/1, df) */
var PB_SGS : i64 = 0i64
var PB_SGM : u64 = 0u64
var PB_SGE : i64 = 0i64

/* signed df multiply, directed on the VALUE (magnitude dir flips with
 * the result sign) -- result in the PB_SD* channel */
fn pb_smul(sa: i64, ma: u64, ea: i64, sb: i64, mb: u64, eb: i64, dir: u64) -> i32 {
    if sa == 0i64 {
        PB_SDS = 0i64
        PB_SDM = 0u64
        PB_SDE = 0i64
        return 0i32
    }
    if sb == 0i64 {
        PB_SDS = 0i64
        PB_SDM = 0u64
        PB_SDE = 0i64
        return 0i32
    }
    let mut rs : i64 = 1i64
    if sa != sb { rs = 0i64 - 1i64 }
    let mut magdir : u64 = dir
    if rs < 0i64 { magdir = 1u64 - dir }
    pr_x_dfmul(ma, ea, mb, eb, magdir)
    PB_SDS = rs
    PB_SDM = pr_x_dfm()
    PB_SDE = pr_x_dfe()
    return 0i32
}

/* signed df compare */
fn pb_scmp(sa: i64, ma: u64, ea: i64, sb: i64, mb: u64, eb: i64) -> i64 {
    if sa > sb { return 1i64 }
    if sa < sb { return 0i64 - 1i64 }
    if sa == 0i64 { return 0i64 }
    let c : i64 = pr_x_dfcmp(ma, ea, mb, eb)
    if sa < 0i64 { return 0i64 - c }
    return c
}

/* the square bound of X'_i: hi 1 = the larger magnitude squared upward,
 * hi 0 = the lower bound (zero on any straddle or zero endpoint) */
fn pb_sqb(i: u64, hi: u64) -> i32 {
    let ls : i64 = PB_FLS[i]
    let hs : i64 = PB_FHS[i]
    let mut same : u64 = 0u64
    if ls > 0i64 {
        if hs > 0i64 { same = 1u64 }
    }
    if ls < 0i64 {
        if hs < 0i64 { same = 1u64 }
    }
    let mut cm : i64 = 0i64
    if ls == 0i64 {
        if hs != 0i64 { cm = 0i64 - 1i64 }
    }
    if ls != 0i64 {
        if hs == 0i64 { cm = 1i64 }
        if hs != 0i64 { cm = pr_x_dfcmp(PB_FLM[i], PB_FLE[i], PB_FHM[i], PB_FHE[i]) }
    }
    if hi == 1u64 {
        if ls == 0i64 {
            if hs == 0i64 {
                PB_SDS = 0i64
                PB_SDM = 0u64
                PB_SDE = 0i64
                return 0i32
            }
        }
        let mut mm : u64 = PB_FHM[i]
        let mut me : i64 = PB_FHE[i]
        if cm > 0i64 {
            mm = PB_FLM[i]
            me = PB_FLE[i]
        }
        pr_x_dfmul(mm, me, mm, me, 1u64)
        PB_SDS = 1i64
        PB_SDM = pr_x_dfm()
        PB_SDE = pr_x_dfe()
        return 0i32
    }
    if same == 0u64 {
        PB_SDS = 0i64
        PB_SDM = 0u64
        PB_SDE = 0i64
        return 0i32
    }
    let mut nm : u64 = PB_FLM[i]
    let mut ne : i64 = PB_FLE[i]
    if cm > 0i64 {
        nm = PB_FHM[i]
        ne = PB_FHE[i]
    }
    pr_x_dfmul(nm, ne, nm, ne, 0u64)
    PB_SDS = 1i64
    PB_SDM = pr_x_dfm()
    PB_SDE = pr_x_dfe()
    return 0i32
}

/* one directed fold of the 7168 squares; rev 1 folds in reversed order */
fn pb_sq_fold(rev: u64) -> i32 {
    let mut slm : u64 = 0u64
    let mut sle : i64 = 0i64
    let mut shm : u64 = 0u64
    let mut she : i64 = 0i64
    let mut t : u64 = 0u64
    while t < 7168u64 {
        let mut i : u64 = t
        if rev == 1u64 { i = 7167u64 - t }
        pb_sqb(i, 0u64)
        if PB_SDS != 0i64 {
            pr_x_dfadd(slm, sle, PB_SDM, PB_SDE, 0u64)
            slm = pr_x_dfm()
            sle = pr_x_dfe()
        }
        pb_sqb(i, 1u64)
        if PB_SDS != 0i64 {
            pr_x_dfadd(shm, she, PB_SDM, PB_SDE, 1u64)
            shm = pr_x_dfm()
            she = pr_x_dfe()
        }
        t = t + 1u64
    }
    if rev == 0u64 {
        PB_QFLM = slm
        PB_QFLE = sle
        PB_QFHM = shm
        PB_QFHE = she
    }
    if rev == 1u64 {
        PB_QRLM = slm
        PB_QRLE = sle
        PB_QRHM = shm
        PB_QRHE = she
    }
    return 0i32
}

/* rms4 = sqrt(mean(X'^2) + eps) and its reciprocal, all directed.
 * The two folds must OVERLAP (both contain the true sum).  0 ok / 1 red */
fn pb_rms() -> u64 {
    pb_sq_fold(0u64)
    pb_sq_fold(1u64)
    if pr_x_dfcmp(PB_QFLM, PB_QFLE, PB_QRHM, PB_QRHE) > 0i64 { return 1u64 }
    if pr_x_dfcmp(PB_QRLM, PB_QRLE, PB_QFHM, PB_QFHE) > 0i64 { return 1u64 }
    if PB_QFHM == 0u64 { return 1u64 }
    pr_x_dfn2(0u64, 7168u64, 0i64, 0u64)
    let sm : u64 = pr_x_dfm()
    let se : i64 = pr_x_dfe()
    pr_x_dfrecip(sm, se, 0u64)
    let rdm : u64 = pr_x_dfm()
    let rde : i64 = pr_x_dfe()
    pr_x_dfrecip(sm, se, 1u64)
    let rum : u64 = pr_x_dfm()
    let rue : i64 = pr_x_dfe()
    pr_x_dfmul(PB_QFLM, PB_QFLE, rdm, rde, 0u64)
    let mut mlm : u64 = pr_x_dfm()
    let mut mle : i64 = pr_x_dfe()
    pr_x_dfmul(PB_QFHM, PB_QFHE, rum, rue, 1u64)
    let mut mhm : u64 = pr_x_dfm()
    let mut mhe : i64 = pr_x_dfe()
    let em : i64 = mb_gz_eps_m()
    if em > 0i64 {
        let ee : i64 = mb_gz_eps_e()
        pr_x_dfn2(0u64, em as u64, ee, 0u64)
        let epm : u64 = pr_x_dfm()
        let epe : i64 = pr_x_dfe()
        pr_x_dfadd(mlm, mle, epm, epe, 0u64)
        mlm = pr_x_dfm()
        mle = pr_x_dfe()
        pr_x_dfadd(mhm, mhe, epm, epe, 1u64)
        mhm = pr_x_dfm()
        mhe = pr_x_dfe()
    }
    if mlm == 0u64 { return 1u64 }
    pr_x_dfsqrt(mlm, mle, 0u64)
    PB_R4LM = pr_x_dfm()
    PB_R4LE = pr_x_dfe()
    pr_x_dfsqrt(mhm, mhe, 1u64)
    PB_R4HM = pr_x_dfm()
    PB_R4HE = pr_x_dfe()
    pr_x_dfrecip(PB_R4HM, PB_R4HE, 0u64)
    PB_I4LM = pr_x_dfm()
    PB_I4LE = pr_x_dfe()
    pr_x_dfrecip(PB_R4LM, PB_R4LE, 1u64)
    PB_I4HM = pr_x_dfm()
    PB_I4HE = pr_x_dfe()
    return 0u64
}

/* deposit x-hat_i = X'_i * gamma4_i * (1/rms4): the interval endpoints
 * by selection, and the interior midpoint as the exact rider */
fn pb_xhat_one(i: u64) -> u64 {
    let gm : i64 = mb_pb_fn_m(i)
    let ge : i64 = mb_pb_fn_e(i)
    let mut dead : u64 = 0u64
    if gm == 0i64 { dead = 1u64 }
    if PB_FLS[i] == 0i64 {
        if PB_FHS[i] == 0i64 { dead = 1u64 }
    }
    if dead == 1u64 {
        if mb_pb_set_lo(i, 0i64, 0u64, 0u64, 0u64, 0u64, 0i64) != 0u64 { return 1u64 }
        if mb_pb_set_hi(i, 0i64, 0u64, 0u64, 0u64, 0u64, 0i64) != 0u64 { return 1u64 }
        if mb_pb_set_ex(i, 0i64, 0u64, 0u64, 0u64, 0u64, 0i64) != 0u64 { return 1u64 }
        return 0u64
    }
    let mut gs : i64 = 1i64
    let mut gmm : u64 = gm as u64
    if gm < 0i64 {
        gs = 0i64 - 1i64
        gmm = (0i64 - gm) as u64
    }
    pr_x_dfn2(0u64, gmm, ge, 0u64)
    let gdm : u64 = pr_x_dfm()
    let gde : i64 = pr_x_dfe()
    /* t1 = X' * gamma: a negative gamma crosses the endpoints */
    let mut a : u64 = 0u64
    if gs < 0i64 { a = 1u64 }
    let mut es : i64 = PB_FLS[i]
    let mut em2 : u64 = PB_FLM[i]
    let mut ee2 : i64 = PB_FLE[i]
    if a == 1u64 {
        es = PB_FHS[i]
        em2 = PB_FHM[i]
        ee2 = PB_FHE[i]
    }
    pb_smul(es, em2, ee2, gs, gdm, gde, 0u64)
    let t1ls : i64 = PB_SDS
    let t1lm : u64 = PB_SDM
    let t1le : i64 = PB_SDE
    es = PB_FHS[i]
    em2 = PB_FHM[i]
    ee2 = PB_FHE[i]
    if a == 1u64 {
        es = PB_FLS[i]
        em2 = PB_FLM[i]
        ee2 = PB_FLE[i]
    }
    pb_smul(es, em2, ee2, gs, gdm, gde, 1u64)
    let t1hs : i64 = PB_SDS
    let t1hm : u64 = PB_SDM
    let t1he : i64 = PB_SDE
    /* t2 = t1 * (1/rms4), a positive interval scalar */
    let mut i4m : u64 = PB_I4LM
    let mut i4e : i64 = PB_I4LE
    if t1ls < 0i64 {
        i4m = PB_I4HM
        i4e = PB_I4HE
    }
    pb_smul(t1ls, t1lm, t1le, 1i64, i4m, i4e, 0u64)
    let xls : i64 = PB_SDS
    let xlm : u64 = PB_SDM
    let xle : i64 = PB_SDE
    i4m = PB_I4HM
    i4e = PB_I4HE
    if t1hs < 0i64 {
        i4m = PB_I4LM
        i4e = PB_I4LE
    }
    pb_smul(t1hs, t1hm, t1he, 1i64, i4m, i4e, 1u64)
    let xhs : i64 = PB_SDS
    let xhm : u64 = PB_SDM
    let xhe : i64 = PB_SDE
    /* the interior rider: (lo + hi)/2 rounded down cannot leave the pen */
    pb_sadd(xls, xlm, xle, xhs, xhm, xhe, 0u64)
    let ms : i64 = PB_SDS
    let mm : u64 = PB_SDM
    let mut me : i64 = PB_SDE
    if ms != 0i64 { me = me - 1i64 }
    if mb_pb_set_lo(i, xls, xlm, 0u64, 0u64, 0u64, xle) != 0u64 { return 1u64 }
    if mb_pb_set_hi(i, xhs, xhm, 0u64, 0u64, 0u64, xhe) != 0u64 { return 1u64 }
    if mb_pb_set_ex(i, ms, mm, 0u64, 0u64, 0u64, me) != 0u64 { return 1u64 }
    return 0u64
}

/* sigma(g) at the signed df point, the bound directed per up.  A capped
 * argument saturates to the NAMED bound (counted, never silent). */
fn pb_sigma(s: i64, m: u64, e: i64, up: u64) -> i32 {
    let wex : u64 = 1u64 - up
    let rc : u64 = pr_x_exp_s(m, e, 0i64 - s, wex)
    if rc == 0u64 {
        let em3 : u64 = pr_x_dfm()
        let ee3 : i64 = pr_x_dfe()
        pr_x_dfadd(1u64 << 63u64, 0i64 - 63i64, em3, ee3, wex)
        pr_x_dfrecip(pr_x_dfm(), pr_x_dfe(), up)
        PB_SGS = 1i64
        PB_SGM = pr_x_dfm()
        PB_SGE = pr_x_dfe()
        return 0i32
    }
    PB_TSAT = PB_TSAT + 1u64
    if s > 0i64 {
        /* g >= 24: e^{-g} in [0, 2^-34] */
        if up == 1u64 {
            PB_SGS = 1i64
            PB_SGM = 1u64 << 63u64
            PB_SGE = 0i64 - 63i64
            return 0i32
        }
        pr_x_dfadd(1u64 << 63u64, 0i64 - 63i64, 1u64 << 63u64, 0i64 - 97i64, 1u64)
        pr_x_dfrecip(pr_x_dfm(), pr_x_dfe(), 0u64)
        PB_SGS = 1i64
        PB_SGM = pr_x_dfm()
        PB_SGE = pr_x_dfe()
        return 0i32
    }
    /* g <= -24: sigma in [0, 2^-34] */
    if up == 1u64 {
        PB_SGS = 1i64
        PB_SGM = 1u64 << 63u64
        PB_SGE = 0i64 - 97i64
        return 0i32
    }
    PB_SGS = 0i64
    PB_SGM = 0u64
    PB_SGE = 0i64
    return 0i32
}

/* one dim of the silu weave: g and u from the banks -> h deposited.
 * h = g*sigma(g)*u by the product form: sigma's monotone image first,
 * then the four-corner hull against u.  0 ok / 1 red */
fn pb_sigh_one(j: u64) -> u64 {
    pb_odf(1u64, j, 0u64, 0u64)
    let gls : i64 = PB_ODS
    let glm : u64 = PB_ODM
    let gle : i64 = PB_ODE
    pb_odf(1u64, j, 1u64, 1u64)
    let ghs : i64 = PB_ODS
    let ghm : u64 = PB_ODM
    let ghe : i64 = PB_ODE
    pb_odf(2u64, j, 0u64, 0u64)
    let uls : i64 = PB_ODS
    let ulm : u64 = PB_ODM
    let ule : i64 = PB_ODE
    pb_odf(2u64, j, 1u64, 1u64)
    let uhs : i64 = PB_ODS
    let uhm : u64 = PB_ODM
    let uhe : i64 = PB_ODE
    pb_sigma(gls, glm, gle, 0u64)
    let sls : i64 = PB_SGS
    let slm : u64 = PB_SGM
    let sle : i64 = PB_SGE
    pb_sigma(ghs, ghm, ghe, 1u64)
    let shs : i64 = PB_SGS
    let shm : u64 = PB_SGM
    let she : i64 = PB_SGE
    /* the sigma-monotone tooth */
    if pb_scmp(sls, slm, sle, shs, shm, she) > 0i64 { return 1u64 }
    /* silu bounds: sigma >= 0, so g's endpoints stay the extremes */
    let mut ps : i64 = sls
    let mut pm : u64 = slm
    let mut pe : i64 = sle
    if gls < 0i64 {
        ps = shs
        pm = shm
        pe = she
    }
    pb_smul(gls, glm, gle, ps, pm, pe, 0u64)
    let als : i64 = PB_SDS
    let alm : u64 = PB_SDM
    let ale : i64 = PB_SDE
    ps = shs
    pm = shm
    pe = she
    if ghs < 0i64 {
        ps = sls
        pm = slm
        pe = sle
    }
    pb_smul(ghs, ghm, ghe, ps, pm, pe, 1u64)
    let ahs : i64 = PB_SDS
    let ahm : u64 = PB_SDM
    let ahe : i64 = PB_SDE
    /* h = silu * u: the four-corner hull, directed per side */
    pb_smul(als, alm, ale, uls, ulm, ule, 0u64)
    let mut hls : i64 = PB_SDS
    let mut hlm : u64 = PB_SDM
    let mut hle : i64 = PB_SDE
    pb_smul(als, alm, ale, uhs, uhm, uhe, 0u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, hls, hlm, hle) < 0i64 {
        hls = PB_SDS
        hlm = PB_SDM
        hle = PB_SDE
    }
    pb_smul(ahs, ahm, ahe, uls, ulm, ule, 0u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, hls, hlm, hle) < 0i64 {
        hls = PB_SDS
        hlm = PB_SDM
        hle = PB_SDE
    }
    pb_smul(ahs, ahm, ahe, uhs, uhm, uhe, 0u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, hls, hlm, hle) < 0i64 {
        hls = PB_SDS
        hlm = PB_SDM
        hle = PB_SDE
    }
    pb_smul(als, alm, ale, uls, ulm, ule, 1u64)
    let mut hhs : i64 = PB_SDS
    let mut hhm : u64 = PB_SDM
    let mut hhe : i64 = PB_SDE
    pb_smul(als, alm, ale, uhs, uhm, uhe, 1u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, hhs, hhm, hhe) > 0i64 {
        hhs = PB_SDS
        hhm = PB_SDM
        hhe = PB_SDE
    }
    pb_smul(ahs, ahm, ahe, uls, ulm, ule, 1u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, hhs, hhm, hhe) > 0i64 {
        hhs = PB_SDS
        hhm = PB_SDM
        hhe = PB_SDE
    }
    pb_smul(ahs, ahm, ahe, uhs, uhm, uhe, 1u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, hhs, hhm, hhe) > 0i64 {
        hhs = PB_SDS
        hhm = PB_SDM
        hhe = PB_SDE
    }
    /* the bounds-ordered tooth */
    if pb_scmp(hls, hlm, hle, hhs, hhm, hhe) > 0i64 { return 1u64 }
    /* the interior rider */
    pb_sadd(hls, hlm, hle, hhs, hhm, hhe, 0u64)
    let ms : i64 = PB_SDS
    let mm2 : u64 = PB_SDM
    let mut me2 : i64 = PB_SDE
    if ms != 0i64 { me2 = me2 - 1i64 }
    if mb_pb_set_lo(j, hls, hlm, 0u64, 0u64, 0u64, hle) != 0u64 { return 1u64 }
    if mb_pb_set_hi(j, hhs, hhm, 0u64, 0u64, 0u64, hhe) != 0u64 { return 1u64 }
    if mb_pb_set_ex(j, ms, mm2, 0u64, 0u64, 0u64, me2) != 0u64 { return 1u64 }
    return 0u64
}

/* the loom teeth for one run: ten witness rows re-derived sequentially
 * must equal the bank limb for limb.  Returns the ok-count. */
fn pb_wit(slot: u64, bank: u64, rows: u64) -> u64 {
    let step : u64 = rows / 10u64
    let mut ok : u64 = 0u64
    let mut wi : u64 = 0u64
    while wi < 10u64 {
        let mut wr : u64 = wi * step
        if wi == 9u64 { wr = rows - 1u64 }
        if mb_pb_rwit(slot, wr) != 0u64 { return 0u64 }
        let mut wok : u64 = 1u64
        let mut wv : u64 = 0u64
        while wv < 3u64 {
            if mb_pb_w_s(wv) != pb_gs(bank, wr, wv) { wok = 0u64 }
            if mb_pb_w_e(wv) != pb_ge(bank, wr, wv) { wok = 0u64 }
            let mut kk : u64 = 0u64
            while kk < 8u64 {
                if mb_pb_w_l(wv, kk) != pb_gl(bank, wr, wv, kk) { wok = 0u64 }
                kk = kk + 1u64
            }
            wv = wv + 1u64
        }
        if wok == 1u64 { ok = ok + 1u64 }
        wi = wi + 1u64
    }
    return ok
}

/* containment (lo <= exact <= hi) census over a bank */
fn pb_cont(bank: u64, rows: u64) -> u64 {
    let mut c : u64 = 0u64
    let mut r : u64 = 0u64
    while r < rows {
        let c1 : i64 = pb_cmp(bank, r, 0u64, 2u64)
        let c2 : i64 = pb_cmp(bank, r, 2u64, 1u64)
        if c1 == 9i64 { return 0u64 - 1u64 }
        if c2 == 9i64 { return 0u64 - 1u64 }
        if c1 <= 0i64 {
            if c2 <= 0i64 { c = c + 1u64 }
        }
        r = r + 1u64
    }
    return c
}

fn pb_arm384() -> u64 {
    PB_THREP_OK = 0u64
    PB_TSAT = 0u64
    if PB_NOST_OK != 1u64 {
        pb_rs("the threpsis: fasting (no homecoming) -- the table stands ready" as u64)
        pb_rb(10u8)
        return 0u64
    }
    let fk : u64 = mb_pb_ffn_ok()
    if fk == 3u64 {
        pb_rs("the threpsis: ffn absent from the feast (named, lawful)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    if fk == 2u64 {
        pb_rs("the threpsis: refused (ffn geometry foreign -- named)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    if fk != 0u64 { return 384u64 }
    if pb_rms() != 0u64 { return 384u64 }
    let mut i : u64 = 0u64
    while i < 7168u64 {
        if pb_xhat_one(i) != 0u64 { return 384u64 }
        i = i + 1u64
    }
    mb_pb_mark(7168u64, 7168u64, 7168u64)
    let rg : u64 = mb_pb_run_par(9u64, 7168u64, 18432u64, 1u64, 3u64)
    if rg == 2u64 {
        pb_rs("the threpsis: refused (gate guard -- named)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    if rg != 0u64 { return 384u64 }
    let ru : u64 = mb_pb_run_par(10u64, 7168u64, 18432u64, 2u64, 3u64)
    if ru == 2u64 {
        pb_rs("the threpsis: refused (up guard -- named)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    if ru != 0u64 { return 384u64 }
    /* the witnesses walk while x-hat still stands deposited */
    let w1 : u64 = pb_wit(9u64, 1u64, 18432u64)
    let w2 : u64 = pb_wit(10u64, 2u64, 18432u64)
    let cg : u64 = pb_cont(1u64, 18432u64)
    let cu : u64 = pb_cont(2u64, 18432u64)
    if cg != 18432u64 { return 384u64 }
    if cu != 18432u64 { return 384u64 }
    let mut j : u64 = 0u64
    while j < 18432u64 {
        if pb_sigh_one(j) != 0u64 { return 384u64 }
        j = j + 1u64
    }
    mb_pb_mark(18432u64, 18432u64, 18432u64)
    let rd : u64 = mb_pb_run_par(11u64, 18432u64, 7168u64, 3u64, 3u64)
    if rd == 2u64 {
        pb_rs("the threpsis: refused (down guard -- named)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    if rd != 0u64 { return 384u64 }
    let w3 : u64 = pb_wit(11u64, 3u64, 7168u64)
    if w1 + w2 + w3 != 30u64 { return 384u64 }
    let cd : u64 = pb_cont(3u64, 7168u64)
    if cd != 7168u64 { return 384u64 }
    PB_TWMAX = 0i64 - 100000i64
    let mut r2 : u64 = 0u64
    while r2 < 7168u64 {
        let we : i64 = pb_width_exp(3u64, r2)
        if we == 100000i64 { return 384u64 }
        if we > PB_TWMAX { PB_TWMAX = we }
        r2 = r2 + 1u64
    }
    PB_THREP_OK = 1u64
    pb_rs("the threpsis: ffn woven by 4 weavers rows(gate/up/down)=18432/18432/7168 witness-rows=30/30 limb-exact containment(interval holds exact)=44032/44032 sigma-monotone=18432/18432 silu=product-form bounds-ordered=18432/18432 sumsq-fold=overlap saturated-endpoints=" as u64)
    pb_ru(PB_TSAT)
    pb_rs(" (named) rms4=[" as u64)
    pb_ru(PB_R4LM)
    pb_rs("e" as u64)
    pb_ri(PB_R4LE)
    pb_rs("," as u64)
    pb_ru(PB_R4HM)
    pb_rs("e" as u64)
    pb_ri(PB_R4HE)
    pb_rs("] shadow(max-width-exp2)=" as u64)
    pb_ri(PB_TWMAX)
    pb_rb(10u8)
    return 0u64
}

/* ==================== arm 385: THE PEPSIS ==================== */

var PB_PSTRAD : u64 = 0u64
var PB_PWMAX : i64 = 0i64
var PB_PCONT : u64 = 0u64
var PB_2LS : [i64; 7168]
var PB_2LM : [u64; 7168]
var PB_2LE : [i64; 7168]
var PB_2HS : [i64; 7168]
var PB_2HM : [u64; 7168]
var PB_2HE : [i64; 7168]

fn pb_arm385() -> u64 {
    if PB_THREP_OK != 1u64 {
        pb_rs("the pepsis: fasting (no nourishment) -- the river stands ready" as u64)
        pb_rb(10u8)
        return 0u64
    }
    PB_PSTRAD = 0u64
    PB_PCONT = 0u64
    PB_PWMAX = 0i64 - 100000i64
    let mut r : u64 = 0u64
    while r < 7168u64 {
        pb_odf(3u64, r, 0u64, 0u64)
        pb_sadd(PB_FLS[r], PB_FLM[r], PB_FLE[r], PB_ODS, PB_ODM, PB_ODE, 0u64)
        let fls : i64 = PB_SDS
        let flm : u64 = PB_SDM
        let fle : i64 = PB_SDE
        pb_odf(3u64, r, 1u64, 1u64)
        pb_sadd(PB_FHS[r], PB_FHM[r], PB_FHE[r], PB_ODS, PB_ODM, PB_ODE, 1u64)
        let fhs : i64 = PB_SDS
        let fhm : u64 = PB_SDM
        let fhe : i64 = PB_SDE
        /* the tight route rides the exact down point */
        pb_odf(3u64, r, 2u64, 0u64)
        pb_sadd(PB_FLS[r], PB_FLM[r], PB_FLE[r], PB_ODS, PB_ODM, PB_ODE, 0u64)
        let tls : i64 = PB_SDS
        let tlm : u64 = PB_SDM
        let tle : i64 = PB_SDE
        pb_odf(3u64, r, 2u64, 1u64)
        pb_sadd(PB_FHS[r], PB_FHM[r], PB_FHE[r], PB_ODS, PB_ODM, PB_ODE, 1u64)
        let ths : i64 = PB_SDS
        let thm : u64 = PB_SDM
        let tte : i64 = PB_SDE
        let mut okc : u64 = 1u64
        if pb_scmp(fls, flm, fle, tls, tlm, tle) > 0i64 { okc = 0u64 }
        if pb_scmp(ths, thm, tte, fhs, fhm, fhe) > 0i64 { okc = 0u64 }
        if okc == 1u64 { PB_PCONT = PB_PCONT + 1u64 }
        let mut str8 : u64 = 0u64
        if fls < 0i64 {
            if fhs >= 0i64 { str8 = 1u64 }
        }
        if fls == 0i64 { str8 = 1u64 }
        if fhs == 0i64 { str8 = 1u64 }
        if str8 == 1u64 { PB_PSTRAD = PB_PSTRAD + 1u64 }
        pb_sadd(fhs, fhm, fhe, 0i64 - fls, flm, fle, 1u64)
        if PB_SDS != 0i64 {
            let wexp : i64 = PB_SDE + 63i64
            if wexp > PB_PWMAX { PB_PWMAX = wexp }
        }
        PB_2LS[r] = fls
        PB_2LM[r] = flm
        PB_2LE[r] = fle
        PB_2HS[r] = fhs
        PB_2HM[r] = fhm
        PB_2HE[r] = fhe
        r = r + 1u64
    }
    if PB_PCONT != 7168u64 { return 385u64 }
    /* the layer scroll: the law of the nourishment sealed */
    eol_reset()
    let doc : u64 = "[ffn nourishment = certified interval] [certified interval < exact decision] [interval width = named shadow] [saturated gate = named bound] [named bound < certified interval]" as u64
    let dl : u64 = pb_slen(doc)
    if eol_read(doc, dl) < 0i64 { return 385u64 }
    if eol_lawcheck() != 0u64 { return 385u64 }
    let a1 : u64 = eol_addr()
    if a1 == 0u64 { return 385u64 }
    let fn2 : u64 = "ffn nourishment" as u64
    let xd : u64 = "exact decision" as u64
    if eol_entails(fn2, pb_slen(fn2), 0u64, xd, pb_slen(xd)) != 1u64 { return 385u64 }
    if eol_entails(xd, pb_slen(xd), 0u64, fn2, pb_slen(fn2)) != 0u64 { return 385u64 }
    let nb : u64 = "named bound" as u64
    if eol_entails(nb, pb_slen(nb), 0u64, xd, pb_slen(xd)) != 1u64 { return 385u64 }
    eol_reset()
    if eol_read(doc, dl) < 0i64 { return 385u64 }
    if eol_addr() != a1 { return 385u64 }
    PB_SCROLL2 = a1
    pb_rs("the pepsis: X'' = X' + FFN(X') dims=7168 tight-route-inside-fat=" as u64)
    pb_ru(PB_PCONT)
    pb_rs("/7168 sign-straddle=" as u64)
    pb_ru(PB_PSTRAD)
    pb_rs(" shadow(max-width-exp2)=" as u64)
    pb_ri(PB_PWMAX)
    pb_rs(" gamma4=exact-f32 eps=shared-rms sigma=standing-ladders -- the layer CLOSED: the flesh returns to the river" as u64)
    pb_rb(10u8)
    return 0u64
}

/* ==================== arm 387: THE EKLOGION ====================
 * The election core proven on exact dyadics, feast or fast.  The core
 * elects on whatever selection scores stand (in production: s + bias,
 * built by pb_router_score -- the bias CHOOSES a seat; the weights are
 * built from s alone by pb_routed_combine -- the bias never mixes; that
 * split is enforced by construction and sworn here on the core):
 *   (i)  a decisive field -- seven separated winners and one seat won
 *        ONLY through the added bias -- elects exactly those eight,
 *        decided, certain 8/8, and the gap is LIMB-EXACT (25/64);
 *   (ii) one riser overlapping the weakest winner REFUSES (decided=0)
 *        with the negative gap exact (-1/64);
 *   (iii) the decisive field re-run lands identical (the core is a
 *        function, not a mood). */
fn pb_ek_set(e: u64, lnum: u64, lsh: i64, hnum: u64, hsh: i64) -> u64 {
    pr_x_dfn2(0u64, lnum, lsh, 0u64)
    PB_SCLS[e] = 1i64
    PB_SCLM[e] = pr_x_dfm()
    PB_SCLE[e] = pr_x_dfe()
    pr_x_dfn2(0u64, hnum, hsh, 0u64)
    PB_SCHS[e] = 1i64
    PB_SCHM[e] = pr_x_dfm()
    PB_SCHE[e] = pr_x_dfe()
    return 0u64
}
fn pb_ek_field() -> u64 {
    let mut e : u64 = 0u64
    while e < 256u64 {
        pb_ek_set(e, 16u64, 0i64 - 7i64, 18u64, 0i64 - 7i64)
        e = e + 1u64
    }
    let mut k : u64 = 0u64
    while k < 7u64 {
        pb_ek_set(k, 40u64 - k, 0i64 - 6i64, 81u64 - 2u64 * k, 0i64 - 7i64)
        k = k + 1u64
    }
    /* the bias-won seat: a loser's s lifted whole by an exact bias of 1 */
    pb_ek_set(200u64, 144u64, 0i64 - 7i64, 146u64, 0i64 - 7i64)
    return 0u64
}
fn pb_arm387() -> u64 {
    pb_ek_field()
    pb_elect()
    if PB_MOE_DECIDED != 1u64 { return 387u64 }
    if PB_MOE_CERTAIN != 8u64 { return 387u64 }
    if PB_TOPUSED[200u64] != 1u8 { return 387u64 }
    let mut k : u64 = 0u64
    while k < 7u64 {
        if PB_TOPUSED[k] != 1u8 { return 387u64 }
        k = k + 1u64
    }
    /* the gap limb-exact: 34/64 - 18/128 = 25/64 = (25<<59) * 2^-65 */
    if PB_EGS != 1i64 { return 387u64 }
    if PB_EGM != (25u64 << 59u64) { return 387u64 }
    if PB_EGE != (0i64 - 65i64) { return 387u64 }
    let g1m : u64 = PB_EGM
    let g1e : i64 = PB_EGE
    /* (ii) the riser: expert 100's hi lifted over the weakest winner's lo */
    pb_ek_set(100u64, 16u64, 0i64 - 7i64, 35u64, 0i64 - 6i64)
    pb_elect()
    if PB_MOE_DECIDED != 0u64 { return 387u64 }
    if PB_TOPUSED[100u64] != 0u8 { return 387u64 }
    /* the negative gap exact: 34/64 - 35/64 = -1/64 */
    if PB_EGS != (0i64 - 1i64) { return 387u64 }
    if PB_EGM != (1u64 << 63u64) { return 387u64 }
    if PB_EGE != (0i64 - 69i64) { return 387u64 }
    /* (iii) the decisive field re-run lands identical */
    pb_ek_field()
    pb_elect()
    if PB_MOE_DECIDED != 1u64 { return 387u64 }
    if PB_MOE_CERTAIN != 8u64 { return 387u64 }
    if PB_EGM != g1m { return 387u64 }
    if PB_EGE != g1e { return 387u64 }
    pb_rs("the eklogion: election core on exact dyadics -- bias-won seat=ok decisive gap=25/64 limb-exact refusal-at-riser=ok negative-gap=-1/64 exact rerun=identical -- selection on s+bias, weights on s alone: the bias chooses, never mixes" as u64)
    pb_rb(10u8)
    return 0u64
}

/* ============ arms 388-389: THE ANABASIS (the multi-layer walk) ============
 * Layer 0 proved that a transformer block is an organ: X -> X''.  The dense
 * layers 1 and 2 are its twins -- the SAME law on new weights, with the
 * previous layer's homecoming X'' as the new input.  The forward is built
 * ENTIRELY from the standing machinery: interval matvecs (run_par against
 * a deposited interval thought), general interval RMSNorm, and the reused
 * SiLU hull.  A single token makes the softmax DEGENERATE-EXACT (one
 * position -> attention weight is the exact rational 1, and RoPE at
 * position 0 is the identity), so the attention output is o_proj(V), with
 * V the interval value read through kv_a -> kv_norm -> kv_b.  The interval
 * widths GROW with depth (each matvec re-normalizes an 8-limb sum to a
 * one-limb bound); the walk REPORTS that growth -- the straddle census and
 * the shadow per layer -- rather than pretending the machine sees through
 * three layers with no loss.  What the sign survives, it swears. */

/* the standing activation (a one-limb df interval, widest = 18432) and a
 * 7168-wide save for the two residual homecomings */
var PB_WKLS : [i64; 18432]
var PB_WKLM : [u64; 18432]
var PB_WKLE : [i64; 18432]
var PB_WKHS : [i64; 18432]
var PB_WKHM : [u64; 18432]
var PB_WKHE : [i64; 18432]
var PB_WKN : u64 = 0u64
var PB_SVLS : [i64; 7168]
var PB_SVLM : [u64; 7168]
var PB_SVLE : [i64; 7168]
var PB_SVHS : [i64; 7168]
var PB_SVHM : [u64; 7168]
var PB_SVHE : [i64; 7168]
var PB_WALK_OK : u64 = 0u64
var PB_WSTRAD : u64 = 0u64
var PB_WWMAX : i64 = 0i64

/* load layer 0's homecoming X'' (the pepsis output) into the activation */
fn pb_wk_from_x2() -> u64 {
    let mut i : u64 = 0u64
    while i < 7168u64 {
        PB_WKLS[i] = PB_2LS[i]
        PB_WKLM[i] = PB_2LM[i]
        PB_WKLE[i] = PB_2LE[i]
        PB_WKHS[i] = PB_2HS[i]
        PB_WKHM[i] = PB_2HM[i]
        PB_WKHE[i] = PB_2HE[i]
        i = i + 1u64
    }
    PB_WKN = 7168u64
    return 0u64
}

/* deposit the activation [0..n) as the standing thought (lo, hi, mid) */
fn pb_deposit(n: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < n {
        mb_pb_set_lo(i, PB_WKLS[i], PB_WKLM[i], 0u64, 0u64, 0u64, PB_WKLE[i])
        mb_pb_set_hi(i, PB_WKHS[i], PB_WKHM[i], 0u64, 0u64, 0u64, PB_WKHE[i])
        pb_sadd(PB_WKLS[i], PB_WKLM[i], PB_WKLE[i], PB_WKHS[i], PB_WKHM[i], PB_WKHE[i], 0u64)
        let ms : i64 = PB_SDS
        let mm : u64 = PB_SDM
        let mut me : i64 = PB_SDE
        if ms != 0i64 { me = me - 1i64 }
        mb_pb_set_ex(i, ms, mm, 0u64, 0u64, 0u64, me)
        i = i + 1u64
    }
    mb_pb_mark(n, n, n)
    return 0u64
}

/* normalize a bank's [0..rows) interval output into the activation */
fn pb_bank_to_wk(bank: u64, rows: u64) -> u64 {
    let mut r : u64 = 0u64
    while r < rows {
        pb_odf(bank, r, 0u64, 0u64)
        PB_WKLS[r] = PB_ODS
        PB_WKLM[r] = PB_ODM
        PB_WKLE[r] = PB_ODE
        pb_odf(bank, r, 1u64, 1u64)
        PB_WKHS[r] = PB_ODS
        PB_WKHM[r] = PB_ODM
        PB_WKHE[r] = PB_ODE
        r = r + 1u64
    }
    PB_WKN = rows
    return 0u64
}

/* extract the 16384-wide V from bank 4 (kv_b, [k128|v128] per head) */
fn pb_extract_v() -> u64 {
    let mut h : u64 = 0u64
    while h < 128u64 {
        let mut d : u64 = 0u64
        while d < 128u64 {
            let row : u64 = h * 256u64 + 128u64 + d
            let vi : u64 = h * 128u64 + d
            pb_odf(4u64, row, 0u64, 0u64)
            PB_WKLS[vi] = PB_ODS
            PB_WKLM[vi] = PB_ODM
            PB_WKLE[vi] = PB_ODE
            pb_odf(4u64, row, 1u64, 1u64)
            PB_WKHS[vi] = PB_ODS
            PB_WKHM[vi] = PB_ODM
            PB_WKHE[vi] = PB_ODE
            d = d + 1u64
        }
        h = h + 1u64
    }
    PB_WKN = 16384u64
    return 0u64
}

fn pb_save_wk(n: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < n {
        PB_SVLS[i] = PB_WKLS[i]
        PB_SVLM[i] = PB_WKLM[i]
        PB_SVLE[i] = PB_WKLE[i]
        PB_SVHS[i] = PB_WKHS[i]
        PB_SVHM[i] = PB_WKHM[i]
        PB_SVHE[i] = PB_WKHE[i]
        i = i + 1u64
    }
    return 0u64
}

/* the residual homecoming: activation += the saved interval (dir per side) */
fn pb_wk_add_saved(n: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < n {
        pb_sadd(PB_WKLS[i], PB_WKLM[i], PB_WKLE[i], PB_SVLS[i], PB_SVLM[i], PB_SVLE[i], 0u64)
        let nls : i64 = PB_SDS
        let nlm : u64 = PB_SDM
        let nle : i64 = PB_SDE
        pb_sadd(PB_WKHS[i], PB_WKHM[i], PB_WKHE[i], PB_SVHS[i], PB_SVHM[i], PB_SVHE[i], 1u64)
        PB_WKHS[i] = PB_SDS
        PB_WKHM[i] = PB_SDM
        PB_WKHE[i] = PB_SDE
        PB_WKLS[i] = nls
        PB_WKLM[i] = nlm
        PB_WKLE[i] = nle
        i = i + 1u64
    }
    return 0u64
}

/* the square bound of activation dim i (mirror of pb_sqb over PB_WK) */
fn pb_sqb_wk(i: u64, hi: u64) -> i32 {
    let ls : i64 = PB_WKLS[i]
    let hs : i64 = PB_WKHS[i]
    let mut same : u64 = 0u64
    if ls > 0i64 {
        if hs > 0i64 { same = 1u64 }
    }
    if ls < 0i64 {
        if hs < 0i64 { same = 1u64 }
    }
    let mut cm : i64 = 0i64
    if ls == 0i64 {
        if hs != 0i64 { cm = 0i64 - 1i64 }
    }
    if ls != 0i64 {
        if hs == 0i64 { cm = 1i64 }
        if hs != 0i64 { cm = pr_x_dfcmp(PB_WKLM[i], PB_WKLE[i], PB_WKHM[i], PB_WKHE[i]) }
    }
    if hi == 1u64 {
        if ls == 0i64 {
            if hs == 0i64 {
                PB_SDS = 0i64
                PB_SDM = 0u64
                PB_SDE = 0i64
                return 0i32
            }
        }
        let mut mm : u64 = PB_WKHM[i]
        let mut me : i64 = PB_WKHE[i]
        if cm > 0i64 {
            mm = PB_WKLM[i]
            me = PB_WKLE[i]
        }
        pr_x_dfmul(mm, me, mm, me, 1u64)
        PB_SDS = 1i64
        PB_SDM = pr_x_dfm()
        PB_SDE = pr_x_dfe()
        return 0i32
    }
    if same == 0u64 {
        PB_SDS = 0i64
        PB_SDM = 0u64
        PB_SDE = 0i64
        return 0i32
    }
    let mut nm : u64 = PB_WKLM[i]
    let mut ne : i64 = PB_WKLE[i]
    if cm > 0i64 {
        nm = PB_WKHM[i]
        ne = PB_WKHE[i]
    }
    pr_x_dfmul(nm, ne, nm, ne, 0u64)
    PB_SDS = 1i64
    PB_SDM = pr_x_dfm()
    PB_SDE = pr_x_dfe()
    return 0i32
}

fn pb_sqfold_wk(n: u64, rev: u64) -> i32 {
    let mut slm : u64 = 0u64
    let mut sle : i64 = 0i64
    let mut shm : u64 = 0u64
    let mut she : i64 = 0i64
    let mut t : u64 = 0u64
    while t < n {
        let mut i : u64 = t
        if rev == 1u64 { i = n - 1u64 - t }
        pb_sqb_wk(i, 0u64)
        if PB_SDS != 0i64 {
            pr_x_dfadd(slm, sle, PB_SDM, PB_SDE, 0u64)
            slm = pr_x_dfm()
            sle = pr_x_dfe()
        }
        pb_sqb_wk(i, 1u64)
        if PB_SDS != 0i64 {
            pr_x_dfadd(shm, she, PB_SDM, PB_SDE, 1u64)
            shm = pr_x_dfm()
            she = pr_x_dfe()
        }
        t = t + 1u64
    }
    if rev == 0u64 {
        PB_QFLM = slm
        PB_QFLE = sle
        PB_QFHM = shm
        PB_QFHE = she
    }
    if rev == 1u64 {
        PB_QRLM = slm
        PB_QRLE = sle
        PB_QRHM = shm
        PB_QRHE = she
    }
    return 0i32
}

/* mean/eps/sqrt/recip for a width-n rms (general form of pb_rms's finish) */
fn pb_rms_finish(n: u64) -> u64 {
    if PB_QFHM == 0u64 { return 1u64 }
    pr_x_dfn2(0u64, n, 0i64, 0u64)
    let sm : u64 = pr_x_dfm()
    let se : i64 = pr_x_dfe()
    pr_x_dfrecip(sm, se, 0u64)
    let rdm : u64 = pr_x_dfm()
    let rde : i64 = pr_x_dfe()
    pr_x_dfrecip(sm, se, 1u64)
    let rum : u64 = pr_x_dfm()
    let rue : i64 = pr_x_dfe()
    pr_x_dfmul(PB_QFLM, PB_QFLE, rdm, rde, 0u64)
    let mut mlm : u64 = pr_x_dfm()
    let mut mle : i64 = pr_x_dfe()
    pr_x_dfmul(PB_QFHM, PB_QFHE, rum, rue, 1u64)
    let mut mhm : u64 = pr_x_dfm()
    let mut mhe : i64 = pr_x_dfe()
    let em : i64 = mb_gz_eps_m()
    if em > 0i64 {
        let ee : i64 = mb_gz_eps_e()
        pr_x_dfn2(0u64, em as u64, ee, 0u64)
        let epm : u64 = pr_x_dfm()
        let epe : i64 = pr_x_dfe()
        pr_x_dfadd(mlm, mle, epm, epe, 0u64)
        mlm = pr_x_dfm()
        mle = pr_x_dfe()
        pr_x_dfadd(mhm, mhe, epm, epe, 1u64)
        mhm = pr_x_dfm()
        mhe = pr_x_dfe()
    }
    if mlm == 0u64 { return 1u64 }
    pr_x_dfsqrt(mlm, mle, 0u64)
    PB_R4LM = pr_x_dfm()
    PB_R4LE = pr_x_dfe()
    pr_x_dfsqrt(mhm, mhe, 1u64)
    PB_R4HM = pr_x_dfm()
    PB_R4HE = pr_x_dfe()
    pr_x_dfrecip(PB_R4HM, PB_R4HE, 0u64)
    PB_I4LM = pr_x_dfm()
    PB_I4LE = pr_x_dfe()
    pr_x_dfrecip(PB_R4LM, PB_R4LE, 1u64)
    PB_I4HM = pr_x_dfm()
    PB_I4HE = pr_x_dfe()
    return 0u64
}

/* x-hat_i = activation_i * normweight_i * (1/rms), in place (mirror of
 * pb_xhat_one with a general norm weight source) */
fn pb_xhat_wk_one(i: u64) -> u64 {
    let gm : i64 = mb_nw_m(i)
    let ge : i64 = mb_nw_e(i)
    let mut dead : u64 = 0u64
    if gm == 0i64 { dead = 1u64 }
    if PB_WKLS[i] == 0i64 {
        if PB_WKHS[i] == 0i64 { dead = 1u64 }
    }
    if dead == 1u64 {
        PB_WKLS[i] = 0i64
        PB_WKLM[i] = 0u64
        PB_WKLE[i] = 0i64
        PB_WKHS[i] = 0i64
        PB_WKHM[i] = 0u64
        PB_WKHE[i] = 0i64
        return 0u64
    }
    let mut gs : i64 = 1i64
    let mut gmm : u64 = gm as u64
    if gm < 0i64 {
        gs = 0i64 - 1i64
        gmm = (0i64 - gm) as u64
    }
    pr_x_dfn2(0u64, gmm, ge, 0u64)
    let gdm : u64 = pr_x_dfm()
    let gde : i64 = pr_x_dfe()
    let mut a : u64 = 0u64
    if gs < 0i64 { a = 1u64 }
    let mut es : i64 = PB_WKLS[i]
    let mut em2 : u64 = PB_WKLM[i]
    let mut ee2 : i64 = PB_WKLE[i]
    if a == 1u64 {
        es = PB_WKHS[i]
        em2 = PB_WKHM[i]
        ee2 = PB_WKHE[i]
    }
    pb_smul(es, em2, ee2, gs, gdm, gde, 0u64)
    let t1ls : i64 = PB_SDS
    let t1lm : u64 = PB_SDM
    let t1le : i64 = PB_SDE
    es = PB_WKHS[i]
    em2 = PB_WKHM[i]
    ee2 = PB_WKHE[i]
    if a == 1u64 {
        es = PB_WKLS[i]
        em2 = PB_WKLM[i]
        ee2 = PB_WKLE[i]
    }
    pb_smul(es, em2, ee2, gs, gdm, gde, 1u64)
    let t1hs : i64 = PB_SDS
    let t1hm : u64 = PB_SDM
    let t1he : i64 = PB_SDE
    let mut i4m : u64 = PB_I4LM
    let mut i4e : i64 = PB_I4LE
    if t1ls < 0i64 {
        i4m = PB_I4HM
        i4e = PB_I4HE
    }
    pb_smul(t1ls, t1lm, t1le, 1i64, i4m, i4e, 0u64)
    PB_WKLS[i] = PB_SDS
    PB_WKLM[i] = PB_SDM
    PB_WKLE[i] = PB_SDE
    i4m = PB_I4HM
    i4e = PB_I4HE
    if t1hs < 0i64 {
        i4m = PB_I4LM
        i4e = PB_I4LE
    }
    pb_smul(t1hs, t1hm, t1he, 1i64, i4m, i4e, 1u64)
    PB_WKHS[i] = PB_SDS
    PB_WKHM[i] = PB_SDM
    PB_WKHE[i] = PB_SDE
    return 0u64
}

/* general interval RMSNorm over the activation [0..n) times normweight slot */
fn pb_rms_wk(n: u64, normslot: u64) -> u64 {
    if mb_ld_normw(normslot, n) != 0u64 { return 1u64 }
    pb_sqfold_wk(n, 0u64)
    pb_sqfold_wk(n, 1u64)
    if pr_x_dfcmp(PB_QFLM, PB_QFLE, PB_QRHM, PB_QRHE) > 0i64 { return 1u64 }
    if pr_x_dfcmp(PB_QRLM, PB_QRLE, PB_QFHM, PB_QFHE) > 0i64 { return 1u64 }
    if pb_rms_finish(n) != 0u64 { return 1u64 }
    let mut i : u64 = 0u64
    while i < n {
        if pb_xhat_wk_one(i) != 0u64 { return 1u64 }
        i = i + 1u64
    }
    PB_WKN = n
    return 0u64
}

/* the attention half of a block: activation (X) -> activation (X'),
 * single token so softmax=1 exact and rope@0=identity.  2 = geometry. */
fn pb_layer_attn(lay: u64) -> u64 {
    let b : u64 = lay * 12u64
    let mut role : u64 = 0u64
    while role < 8u64 {
        if mb_g_present(b + role) != 1u64 { return 2u64 }
        role = role + 1u64
    }
    if mb_g_ne0(b + 4u64) != 7168u64 { return 2u64 }
    if mb_g_ne(b + 4u64) / 7168u64 != 576u64 { return 2u64 }
    if mb_g_ne0(b + 6u64) != 512u64 { return 2u64 }
    if mb_g_ne(b + 6u64) / 512u64 != 32768u64 { return 2u64 }
    if mb_g_ne0(b + 7u64) != 16384u64 { return 2u64 }
    pb_save_wk(7168u64)
    if pb_rms_wk(7168u64, b + 0u64) != 0u64 { return 388u64 }
    pb_deposit(7168u64)
    if mb_pb_run_par(b + 4u64, 7168u64, 576u64, 3u64, 3u64) != 0u64 { return 388u64 }
    pb_bank_to_wk(3u64, 576u64)
    PB_WKN = 512u64
    if pb_rms_wk(512u64, b + 5u64) != 0u64 { return 388u64 }
    pb_deposit(512u64)
    if mb_pb_run_par(b + 6u64, 512u64, 32768u64, 4u64, 3u64) != 0u64 { return 388u64 }
    pb_extract_v()
    pb_deposit(16384u64)
    if mb_pb_run_par(b + 7u64, 16384u64, 7168u64, 0u64, 3u64) != 0u64 { return 388u64 }
    pb_bank_to_wk(0u64, 7168u64)
    pb_wk_add_saved(7168u64)
    PB_WKN = 7168u64
    return 0u64
}

/* the dense feed-forward half: activation (X') -> activation (X'') */
fn pb_ffn_dense(lay: u64) -> u64 {
    let b : u64 = lay * 12u64
    let mut role : u64 = 8u64
    while role < 12u64 {
        if mb_g_present(b + role) != 1u64 { return 2u64 }
        role = role + 1u64
    }
    if mb_g_ne0(b + 9u64) != 7168u64 { return 2u64 }
    if mb_g_ne(b + 9u64) / 7168u64 != 18432u64 { return 2u64 }
    if mb_g_ne0(b + 11u64) != 18432u64 { return 2u64 }
    pb_save_wk(7168u64)
    if pb_rms_wk(7168u64, b + 8u64) != 0u64 { return 388u64 }
    pb_deposit(7168u64)
    if mb_pb_run_par(b + 9u64, 7168u64, 18432u64, 1u64, 3u64) != 0u64 { return 388u64 }
    if mb_pb_run_par(b + 10u64, 7168u64, 18432u64, 2u64, 3u64) != 0u64 { return 388u64 }
    let mut j : u64 = 0u64
    while j < 18432u64 {
        if pb_sigh_one(j) != 0u64 { return 388u64 }
        j = j + 1u64
    }
    mb_pb_mark(18432u64, 18432u64, 18432u64)
    if mb_pb_run_par(b + 11u64, 18432u64, 7168u64, 3u64, 3u64) != 0u64 { return 388u64 }
    pb_bank_to_wk(3u64, 7168u64)
    pb_wk_add_saved(7168u64)
    PB_WKN = 7168u64
    return 0u64
}

/* one dense transformer block: activation (X) -> activation (X'') */
fn pb_layer_dense(lay: u64) -> u64 {
    let ra : u64 = pb_layer_attn(lay)
    if ra != 0u64 { return ra }
    let rf : u64 = pb_ffn_dense(lay)
    if rf != 0u64 { return rf }
    return 0u64
}

/* the sign-straddle + shadow census of the current activation */
fn pb_wk_census() -> u64 {
    PB_WSTRAD = 0u64
    PB_WWMAX = 0i64 - 100000i64
    let mut i : u64 = 0u64
    while i < 7168u64 {
        let mut str8 : u64 = 0u64
        if PB_WKLS[i] < 0i64 {
            if PB_WKHS[i] >= 0i64 { str8 = 1u64 }
        }
        if PB_WKLS[i] == 0i64 { str8 = 1u64 }
        if PB_WKHS[i] == 0i64 { str8 = 1u64 }
        if str8 == 1u64 { PB_WSTRAD = PB_WSTRAD + 1u64 }
        pb_sadd(PB_WKHS[i], PB_WKHM[i], PB_WKHE[i], 0i64 - PB_WKLS[i], PB_WKLM[i], PB_WKLE[i], 1u64)
        if PB_SDS != 0i64 {
            let wexp : i64 = PB_SDE + 63i64
            if wexp > PB_WWMAX { PB_WWMAX = wexp }
        }
        i = i + 1u64
    }
    return 0u64
}

fn pb_arm388() -> u64 {
    PB_WALK_OK = 0u64
    if PB_THREP_OK != 1u64 {
        pb_rs("the anabasis: fasting (no layer 0) -- the stair stands" as u64)
        pb_rb(10u8)
        return 0u64
    }
    /* the dense twins must be on the table (layers 1 and 2, slots 12+, 24+) */
    if mb_g_present(12u64) != 1u64 {
        pb_rs("the anabasis: layers 1-2 absent from the feast (named, lawful)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    pb_wk_from_x2()
    let d1 : u64 = pb_layer_dense(1u64)
    if d1 == 2u64 {
        pb_rs("the anabasis: layer 1 geometry foreign (named, lawful)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    if d1 != 0u64 { return d1 }
    pb_wk_census()
    pb_rs("the anabasis: layer 1 DENSE (single-token: softmax=1 exact, rope@0=identity) X'' recomputed sign-straddle=" as u64)
    pb_ru(PB_WSTRAD)
    pb_rs("/7168 shadow(max-width-exp2)=" as u64)
    pb_ri(PB_WWMAX)
    pb_rb(10u8)
    let d2 : u64 = pb_layer_dense(2u64)
    if d2 == 2u64 {
        pb_rs("the anabasis: layer 2 geometry foreign (named, lawful)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    if d2 != 0u64 { return d2 }
    pb_wk_census()
    PB_WALK_OK = 1u64
    pb_rs("the anabasis: layer 2 DENSE X'' recomputed sign-straddle=" as u64)
    pb_ru(PB_WSTRAD)
    pb_rs("/7168 shadow(max-width-exp2)=" as u64)
    pb_ri(PB_WWMAX)
    pb_rs(" -- three real layers of R1 composed in certified intervals; what the sign survives, it swears" as u64)
    pb_rb(10u8)
    return 0u64
}

/* ============ arm 389: THE SYNODOS (the mixture of experts) ============
 * Layer 3 opens the MoE: the feed-forward is no longer one road but 256,
 * of which a router elects 8 per token, plus a shared expert always on.
 * The router is a matvec of the exact f32 gating weights against the
 * INTERVAL hidden state -- so the election itself is interval-valued, and
 * the top-8 set may or may not be DECIDABLE (if two experts' logit
 * intervals straddle, the machine refuses to pretend it knows the order).
 * The census reports the decidability honestly.  Each elected expert's
 * SwiGLU is woven by the same four weavers through the 3D expert tensor
 * (a per-expert row offset -- the law of arm 372 unchanged), gated by the
 * certified sigmoid weight (normalized, scaled by the ledger's 2.5), and
 * the shared expert added; the residual X'' = X' + MoE(X') closes the
 * first sparse layer of R1 in the same certified intervals. */
var PB_RGLS : [i64; 256]
var PB_RGLM : [u64; 256]
var PB_RGLE : [i64; 256]
var PB_RGHS : [i64; 256]
var PB_RGHM : [u64; 256]
var PB_RGHE : [i64; 256]
var PB_HLS2 : [i64; 7168]
var PB_HLM2 : [u64; 7168]
var PB_HLE2 : [i64; 7168]
var PB_HHS2 : [i64; 7168]
var PB_HHM2 : [u64; 7168]
var PB_HHE2 : [i64; 7168]
var PB_MOELS : [i64; 7168]
var PB_MOELM : [u64; 7168]
var PB_MOELE : [i64; 7168]
var PB_MOEHS : [i64; 7168]
var PB_MOEHM : [u64; 7168]
var PB_MOEHE : [i64; 7168]
var PB_TOP8 : [u64; 8]
var PB_TOPUSED : [u8; 256]
/* SYNODOS II -- the true election: scores s = sigmoid(logit) as signed
 * df intervals, the SELECTION judged on s + bias (the ledger's
 * exp_probs_b), the WEIGHTS on s alone.  The election carries its GAP
 * as a certified df: gap_lo = min(selected s+b lo) - max(unselected
 * s+b hi), rounded toward -inf; decided iff gap_lo > 0.  An undecided
 * election REFUSES the enclosure by name -- the walk never continues
 * as if it knew. */
var PB_SCLS : [i64; 256]
var PB_SCLM : [u64; 256]
var PB_SCLE : [i64; 256]
var PB_SCHS : [i64; 256]
var PB_SCHM : [u64; 256]
var PB_SCHE : [i64; 256]
var PB_EGS : i64 = 0i64
var PB_EGM : u64 = 0u64
var PB_EGE : i64 = 0i64
var PB_BIAS_ON : u64 = 0u64
var PB_ESC : u64 = 48u64
var PB_SIGLS : [i64; 8]
var PB_SIGLM : [u64; 8]
var PB_SIGLE : [i64; 8]
var PB_SIGHS : [i64; 8]
var PB_SIGHM : [u64; 8]
var PB_SIGHE : [i64; 8]
var PB_MOE_DECIDED : u64 = 0u64
var PB_MOE_CERTAIN : u64 = 0u64
var PB_MOE_OK : u64 = 0u64
var PB_MOE_CONT : u64 = 0u64
var PB_MOE_SOUND : u64 = 0u64
/* the general interval-product hull channel */
var PB_HULLS : i64 = 0i64
var PB_HULLM : u64 = 0u64
var PB_HULLE : i64 = 0i64
var PB_HUHS : i64 = 0i64
var PB_HUHM : u64 = 0u64
var PB_HUHE : i64 = 0i64

/* the 4-corner hull of two signed df intervals -> PB_HULL* / PB_HUH* */
fn pb_hull(als: i64, alm: u64, ale: i64, ahs: i64, ahm: u64, ahe: i64, bls: i64, blm: u64, ble: i64, bhs: i64, bhm: u64, bhe: i64) -> i32 {
    pb_smul(als, alm, ale, bls, blm, ble, 0u64)
    let mut ls : i64 = PB_SDS
    let mut lm : u64 = PB_SDM
    let mut le : i64 = PB_SDE
    pb_smul(als, alm, ale, bhs, bhm, bhe, 0u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, ls, lm, le) < 0i64 {
        ls = PB_SDS
        lm = PB_SDM
        le = PB_SDE
    }
    pb_smul(ahs, ahm, ahe, bls, blm, ble, 0u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, ls, lm, le) < 0i64 {
        ls = PB_SDS
        lm = PB_SDM
        le = PB_SDE
    }
    pb_smul(ahs, ahm, ahe, bhs, bhm, bhe, 0u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, ls, lm, le) < 0i64 {
        ls = PB_SDS
        lm = PB_SDM
        le = PB_SDE
    }
    PB_HULLS = ls
    PB_HULLM = lm
    PB_HULLE = le
    pb_smul(als, alm, ale, bls, blm, ble, 1u64)
    let mut hs : i64 = PB_SDS
    let mut hm : u64 = PB_SDM
    let mut he : i64 = PB_SDE
    pb_smul(als, alm, ale, bhs, bhm, bhe, 1u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, hs, hm, he) > 0i64 {
        hs = PB_SDS
        hm = PB_SDM
        he = PB_SDE
    }
    pb_smul(ahs, ahm, ahe, bls, blm, ble, 1u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, hs, hm, he) > 0i64 {
        hs = PB_SDS
        hm = PB_SDM
        he = PB_SDE
    }
    pb_smul(ahs, ahm, ahe, bhs, bhm, bhe, 1u64)
    if pb_scmp(PB_SDS, PB_SDM, PB_SDE, hs, hm, he) > 0i64 {
        hs = PB_SDS
        hm = PB_SDM
        he = PB_SDE
    }
    PB_HUHS = hs
    PB_HUHM = hm
    PB_HUHE = he
    return 0i32
}

fn pb_save_h() -> u64 {
    let mut i : u64 = 0u64
    while i < 7168u64 {
        PB_HLS2[i] = PB_WKLS[i]
        PB_HLM2[i] = PB_WKLM[i]
        PB_HLE2[i] = PB_WKLE[i]
        PB_HHS2[i] = PB_WKHS[i]
        PB_HHM2[i] = PB_WKHM[i]
        PB_HHE2[i] = PB_WKHE[i]
        i = i + 1u64
    }
    return 0u64
}

/* deposit the saved h (7168) as the standing thought */
fn pb_deposit_h() -> u64 {
    let mut i : u64 = 0u64
    while i < 7168u64 {
        mb_pb_set_lo(i, PB_HLS2[i], PB_HLM2[i], 0u64, 0u64, 0u64, PB_HLE2[i])
        mb_pb_set_hi(i, PB_HHS2[i], PB_HHM2[i], 0u64, 0u64, 0u64, PB_HHE2[i])
        pb_sadd(PB_HLS2[i], PB_HLM2[i], PB_HLE2[i], PB_HHS2[i], PB_HHM2[i], PB_HHE2[i], 0u64)
        let ms : i64 = PB_SDS
        let mm : u64 = PB_SDM
        let mut me : i64 = PB_SDE
        if ms != 0i64 { me = me - 1i64 }
        mb_pb_set_ex(i, ms, mm, 0u64, 0u64, 0u64, me)
        i = i + 1u64
    }
    mb_pb_mark(7168u64, 7168u64, 7168u64)
    return 0u64
}

/* router logit e = f32 gating row e . h (interval), endpoint-selected */
fn pb_router_dot(e: u64) -> u64 {
    if mb_moe_router_row(e) != 0u64 { return 1u64 }
    let mut ls : i64 = 0i64
    let mut lm : u64 = 0u64
    let mut le : i64 = 0i64
    let mut hs : i64 = 0i64
    let mut hm : u64 = 0u64
    let mut he : i64 = 0i64
    let mut i : u64 = 0u64
    while i < 7168u64 {
        let wm : i64 = mb_rw_m(i)
        if wm != 0i64 {
            let we : i64 = mb_rw_e(i)
            let mut ws : i64 = 1i64
            let mut wmm : u64 = wm as u64
            if wm < 0i64 {
                ws = 0i64 - 1i64
                wmm = (0i64 - wm) as u64
            }
            pr_x_dfn2(0u64, wmm, we, 0u64)
            let wdm : u64 = pr_x_dfm()
            let wde : i64 = pr_x_dfe()
            let mut a : u64 = 0u64
            if ws < 0i64 { a = 1u64 }
            let mut es : i64 = PB_HLS2[i]
            let mut em : u64 = PB_HLM2[i]
            let mut ee : i64 = PB_HLE2[i]
            if a == 1u64 {
                es = PB_HHS2[i]
                em = PB_HHM2[i]
                ee = PB_HHE2[i]
            }
            pb_smul(es, em, ee, ws, wdm, wde, 0u64)
            pb_sadd(ls, lm, le, PB_SDS, PB_SDM, PB_SDE, 0u64)
            ls = PB_SDS
            lm = PB_SDM
            le = PB_SDE
            es = PB_HHS2[i]
            em = PB_HHM2[i]
            ee = PB_HHE2[i]
            if a == 1u64 {
                es = PB_HLS2[i]
                em = PB_HLM2[i]
                ee = PB_HLE2[i]
            }
            pb_smul(es, em, ee, ws, wdm, wde, 1u64)
            pb_sadd(hs, hm, he, PB_SDS, PB_SDM, PB_SDE, 1u64)
            hs = PB_SDS
            hm = PB_SDM
            he = PB_SDE
        }
        i = i + 1u64
    }
    PB_RGLS[e] = ls
    PB_RGLM[e] = lm
    PB_RGLE[e] = le
    PB_RGHS[e] = hs
    PB_RGHM[e] = hm
    PB_RGHE[e] = he
    return 0u64
}

/* THE ELECTION CORE: elect the 8 highest-lo of the standing SELECTION
 * scores (PB_SC*), judge decidability, and CERTIFY the gap.  The set is
 * decided iff gap_lo = min(selected lo) - max(unselected hi) > 0, the
 * subtraction rounded toward -inf so the spoken gap is never flattered. */
fn pb_elect() -> u64 {
    let mut e : u64 = 0u64
    while e < 256u64 {
        PB_TOPUSED[e] = 0u8
        e = e + 1u64
    }
    let mut k : u64 = 0u64
    while k < 8u64 {
        let mut best : u64 = 256u64
        e = 0u64
        while e < 256u64 {
            if PB_TOPUSED[e] == 0u8 {
                if best == 256u64 { best = e }
                if best != e {
                    if pb_scmp(PB_SCLS[e], PB_SCLM[e], PB_SCLE[e], PB_SCLS[best], PB_SCLM[best], PB_SCLE[best]) > 0i64 { best = e }
                }
            }
            e = e + 1u64
        }
        PB_TOP8[k] = best
        PB_TOPUSED[best] = 1u8
        k = k + 1u64
    }
    /* min lo among selected */
    let mut mls : i64 = PB_SCLS[PB_TOP8[0]]
    let mut mlm : u64 = PB_SCLM[PB_TOP8[0]]
    let mut mle : i64 = PB_SCLE[PB_TOP8[0]]
    k = 1u64
    while k < 8u64 {
        let ee : u64 = PB_TOP8[k]
        if pb_scmp(PB_SCLS[ee], PB_SCLM[ee], PB_SCLE[ee], mls, mlm, mle) < 0i64 {
            mls = PB_SCLS[ee]
            mlm = PB_SCLM[ee]
            mle = PB_SCLE[ee]
        }
        k = k + 1u64
    }
    /* max hi among unselected */
    let mut xhs : i64 = 0i64
    let mut xhm : u64 = 0u64
    let mut xhe : i64 = 0i64
    let mut seen : u64 = 0u64
    e = 0u64
    while e < 256u64 {
        if PB_TOPUSED[e] == 0u8 {
            if seen == 0u64 {
                xhs = PB_SCHS[e]
                xhm = PB_SCHM[e]
                xhe = PB_SCHE[e]
                seen = 1u64
            }
            if seen == 1u64 {
                if pb_scmp(PB_SCHS[e], PB_SCHM[e], PB_SCHE[e], xhs, xhm, xhe) > 0i64 {
                    xhs = PB_SCHS[e]
                    xhm = PB_SCHM[e]
                    xhe = PB_SCHE[e]
                }
            }
        }
        e = e + 1u64
    }
    /* the certified gap, rounded toward -inf */
    pb_sadd(mls, mlm, mle, 0i64 - xhs, xhm, xhe, 0u64)
    PB_EGS = PB_SDS
    PB_EGM = PB_SDM
    PB_EGE = PB_SDE
    PB_MOE_DECIDED = 0u64
    if PB_EGS > 0i64 { PB_MOE_DECIDED = 1u64 }
    /* certain-in count: selected experts whose lo exceeds max-unselected-hi */
    PB_MOE_CERTAIN = 0u64
    k = 0u64
    while k < 8u64 {
        let ee : u64 = PB_TOP8[k]
        if pb_scmp(PB_SCLS[ee], PB_SCLM[ee], PB_SCLE[ee], xhs, xhm, xhe) > 0i64 { PB_MOE_CERTAIN = PB_MOE_CERTAIN + 1u64 }
        k = k + 1u64
    }
    return 0u64
}

/* fill the SELECTION scores for expert e from the standing router logit
 * interval: s = sigmoid(logit) endpoint-monotone, then + bias (exact
 * f32 df) under direction.  Weights stay on s alone -- the bias only
 * chooses, it never mixes. */
fn pb_router_score(e: u64) -> u64 {
    pb_sigma(PB_RGLS[e], PB_RGLM[e], PB_RGLE[e], 0u64)
    let sls : i64 = PB_SGS
    let slm : u64 = PB_SGM
    let sle : i64 = PB_SGE
    pb_sigma(PB_RGHS[e], PB_RGHM[e], PB_RGHE[e], 1u64)
    let shs : i64 = PB_SGS
    let shm : u64 = PB_SGM
    let she : i64 = PB_SGE
    if pb_scmp(sls, slm, sle, shs, shm, she) > 0i64 { return 1u64 }
    let mut bs : i64 = 0i64
    let mut bm : u64 = 0u64
    let mut be : i64 = 0i64
    if PB_BIAS_ON == 1u64 {
        let bmi : i64 = mb_bs_m(e)
        if bmi != 0i64 {
            bs = 1i64
            let mut mg : u64 = bmi as u64
            if bmi < 0i64 {
                bs = 0i64 - 1i64
                mg = (0i64 - bmi) as u64
            }
            pr_x_dfn2(0u64, mg, mb_bs_e(e), 0u64)
            bm = pr_x_dfm()
            be = pr_x_dfe()
        }
    }
    pb_sadd(sls, slm, sle, bs, bm, be, 0u64)
    PB_SCLS[e] = PB_SDS
    PB_SCLM[e] = PB_SDM
    PB_SCLE[e] = PB_SDE
    pb_sadd(shs, shm, she, bs, bm, be, 1u64)
    PB_SCHS[e] = PB_SDS
    PB_SCHM[e] = PB_SDM
    PB_SCHE[e] = PB_SDE
    return 0u64
}

fn pb_moe_clear() -> u64 {
    let mut i : u64 = 0u64
    while i < 7168u64 {
        PB_MOELS[i] = 0i64
        PB_MOELM[i] = 0u64
        PB_MOELE[i] = 0i64
        PB_MOEHS[i] = 0i64
        PB_MOEHM[i] = 0u64
        PB_MOEHE[i] = 0i64
        i = i + 1u64
    }
    return 0u64
}

/* PB_MOE += weight_interval * bank3 (the just-woven expert FFN) */
fn pb_moe_add_weighted(wls: i64, wlm: u64, wle: i64, whs: i64, whm: u64, whe: i64) -> u64 {
    let mut i : u64 = 0u64
    while i < 7168u64 {
        pb_odf(3u64, i, 0u64, 0u64)
        let bls : i64 = PB_ODS
        let blm : u64 = PB_ODM
        let ble : i64 = PB_ODE
        pb_odf(3u64, i, 1u64, 1u64)
        let bhs : i64 = PB_ODS
        let bhm : u64 = PB_ODM
        let bhe : i64 = PB_ODE
        pb_hull(wls, wlm, wle, whs, whm, whe, bls, blm, ble, bhs, bhm, bhe)
        pb_sadd(PB_MOELS[i], PB_MOELM[i], PB_MOELE[i], PB_HULLS, PB_HULLM, PB_HULLE, 0u64)
        PB_MOELS[i] = PB_SDS
        PB_MOELM[i] = PB_SDM
        PB_MOELE[i] = PB_SDE
        pb_sadd(PB_MOEHS[i], PB_MOEHM[i], PB_MOEHE[i], PB_HUHS, PB_HUHM, PB_HUHE, 1u64)
        PB_MOEHS[i] = PB_SDS
        PB_MOEHM[i] = PB_SDM
        PB_MOEHE[i] = PB_SDE
        i = i + 1u64
    }
    return 0u64
}

/* weave a SwiGLU into bank 3: deposit h, gate->b1, up->b2, silu->deposit,
 * down->b3.  is_shared=1 uses the 2D shared tensors (roles 3,4,5). */
fn pb_swiglu(e: u64, is_shared: u64) -> u64 {
    pb_deposit_h()
    if is_shared == 1u64 {
        if mb_pb_run_shexp(3u64, 7168u64, 2048u64, 1u64, 3u64) != 0u64 { return 1u64 }
        if mb_pb_run_shexp(4u64, 7168u64, 2048u64, 2u64, 3u64) != 0u64 { return 1u64 }
    }
    if is_shared == 0u64 {
        if mb_pb_run_exp(0u64, e, 7168u64, 2048u64, 1u64, 3u64) != 0u64 { return 1u64 }
        if mb_pb_run_exp(1u64, e, 7168u64, 2048u64, 2u64, 3u64) != 0u64 { return 1u64 }
    }
    let mut j : u64 = 0u64
    while j < 2048u64 {
        if pb_sigh_one(j) != 0u64 { return 1u64 }
        j = j + 1u64
    }
    mb_pb_mark(2048u64, 2048u64, 2048u64)
    if is_shared == 1u64 {
        if mb_pb_run_shexp(5u64, 2048u64, 7168u64, 3u64, 3u64) != 0u64 { return 1u64 }
    }
    if is_shared == 0u64 {
        if mb_pb_run_exp(2u64, e, 2048u64, 7168u64, 3u64, 3u64) != 0u64 { return 1u64 }
    }
    return 0u64
}

/* the routed combine: sigmoid gate the 8, normalize, scale 2.5, weave */
fn pb_routed_combine() -> u64 {
    /* sigmoids + the normalizing sum (interval) */
    let mut suml : u64 = 0u64
    let mut sule : i64 = 0i64
    let mut sumh : u64 = 0u64
    let mut suhe : i64 = 0i64
    let mut k : u64 = 0u64
    while k < 8u64 {
        let ee : u64 = PB_TOP8[k]
        pb_sigma(PB_RGLS[ee], PB_RGLM[ee], PB_RGLE[ee], 0u64)
        PB_SIGLS[k] = PB_SGS
        PB_SIGLM[k] = PB_SGM
        PB_SIGLE[k] = PB_SGE
        pb_sigma(PB_RGHS[ee], PB_RGHM[ee], PB_RGHE[ee], 1u64)
        PB_SIGHS[k] = PB_SGS
        PB_SIGHM[k] = PB_SGM
        PB_SIGHE[k] = PB_SGE
        pr_x_dfadd(suml, sule, PB_SIGLM[k], PB_SIGLE[k], 0u64)
        suml = pr_x_dfm()
        sule = pr_x_dfe()
        pr_x_dfadd(sumh, suhe, PB_SIGHM[k], PB_SIGHE[k], 1u64)
        sumh = pr_x_dfm()
        suhe = pr_x_dfe()
        k = k + 1u64
    }
    if suml == 0u64 { return 1u64 }
    pr_x_dfrecip(sumh, suhe, 0u64)
    let rsl_m : u64 = pr_x_dfm()
    let rsl_e : i64 = pr_x_dfe()
    pr_x_dfrecip(suml, sule, 1u64)
    let rsh_m : u64 = pr_x_dfm()
    let rsh_e : i64 = pr_x_dfe()
    /* scale = 2.5 (verified from the ledger bits) as an exact df */
    pr_x_dfn2(0u64, 5u64, 0i64 - 1i64, 0u64)
    let scm : u64 = pr_x_dfm()
    let sce : i64 = pr_x_dfe()
    k = 0u64
    while k < 8u64 {
        let ee : u64 = PB_TOP8[k]
        /* weight_lo = 2.5 * sig_lo * rsum_lo ; weight_hi = 2.5 * sig_hi * rsum_hi */
        pr_x_dfmul(scm, sce, PB_SIGLM[k], PB_SIGLE[k], 0u64)
        pr_x_dfmul(pr_x_dfm(), pr_x_dfe(), rsl_m, rsl_e, 0u64)
        let wlm : u64 = pr_x_dfm()
        let wle : i64 = pr_x_dfe()
        pr_x_dfmul(scm, sce, PB_SIGHM[k], PB_SIGHE[k], 1u64)
        pr_x_dfmul(pr_x_dfm(), pr_x_dfe(), rsh_m, rsh_e, 1u64)
        let whm : u64 = pr_x_dfm()
        let whe : i64 = pr_x_dfe()
        if pb_swiglu(ee, 0u64) != 0u64 { return 1u64 }
        pb_moe_add_weighted(1i64, wlm, wle, 1i64, whm, whe)
        k = k + 1u64
    }
    return 0u64
}

/* X'' = X' (saved) + PB_MOE */
fn pb_wk_from_moe_plus_sv() -> u64 {
    let mut i : u64 = 0u64
    while i < 7168u64 {
        pb_sadd(PB_SVLS[i], PB_SVLM[i], PB_SVLE[i], PB_MOELS[i], PB_MOELM[i], PB_MOELE[i], 0u64)
        PB_WKLS[i] = PB_SDS
        PB_WKLM[i] = PB_SDM
        PB_WKLE[i] = PB_SDE
        pb_sadd(PB_SVHS[i], PB_SVHM[i], PB_SVHE[i], PB_MOEHS[i], PB_MOEHM[i], PB_MOEHE[i], 1u64)
        PB_WKHS[i] = PB_SDS
        PB_WKHM[i] = PB_SDM
        PB_WKHE[i] = PB_SDE
        i = i + 1u64
    }
    PB_WKN = 7168u64
    return 0u64
}

fn pb_arm389() -> u64 {
    PB_MOE_OK = 0u64
    if PB_WALK_OK != 1u64 {
        pb_rs("the synodos: fasting (no dense walk) -- the sparse stair stands" as u64)
        pb_rb(10u8)
        return 0u64
    }
    if mb_moe_present() != 1u64 {
        pb_rs("the synodos: layer 3 MoE absent from the feast (named, lawful)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    /* the ledger's shapes for the experts + shared FFN */
    if mb_me_ne0(0u64) != 7168u64 { return 0u64 }
    if mb_me_ne(0u64) / 7168u64 / 256u64 != 2048u64 { return 0u64 }
    if mb_me_ne0(2u64) != 2048u64 { return 0u64 }
    if mb_me_ne(2u64) / 2048u64 / 256u64 != 7168u64 { return 0u64 }
    if mb_me_ne0(3u64) != 7168u64 { return 0u64 }
    if mb_me_ne(3u64) / 7168u64 != 2048u64 { return 0u64 }
    if mb_me_ne0(5u64) != 2048u64 { return 0u64 }
    if mb_me_ne(5u64) / 2048u64 != 7168u64 { return 0u64 }
    if mb_moe_scale_bits() != 1075838976u64 { return 0u64 }
    if mb_moe_used() != 8u64 { return 0u64 }
    /* PB_WK holds layer 2's X''; run layer 3 attention onto it */
    let ra : u64 = pb_layer_attn(3u64)
    if ra == 2u64 {
        pb_rs("the synodos: layer 3 attention geometry foreign (named, lawful)" as u64)
        pb_rb(10u8)
        return 0u64
    }
    if ra != 0u64 { return 389u64 }
    pb_save_wk(7168u64)
    if pb_rms_wk(7168u64, 44u64) != 0u64 { return 389u64 }
    pb_save_h()
    /* the router election: interval logits -> sigmoid scores, the
     * selection bias joined when the feast carries it (named either way),
     * the top-8 elected on s + bias with the gap CERTIFIED */
    let mut e : u64 = 0u64
    while e < 256u64 {
        if pb_router_dot(e) != 0u64 { return 389u64 }
        e = e + 1u64
    }
    PB_BIAS_ON = 0u64
    if mb_eb_present(3u64) == 1u64 {
        if mb_moe_bias_load() != 0u64 { return 389u64 }
        PB_BIAS_ON = 1u64
    }
    e = 0u64
    while e < 256u64 {
        if pb_router_score(e) != 0u64 { return 389u64 }
        e = e + 1u64
    }
    pb_elect()
    /* THE CLIMB: a straddled election asks the ladder for the next rung
     * (48 -> 58) and re-derives the whole election there; the rung is
     * returned home either way -- the schedule is law, never a mood */
    PB_ESC = 48u64
    if PB_MOE_DECIDED == 0u64 {
        if pr_x_esc(58u64) != 0u64 { return 389u64 }
        e = 0u64
        while e < 256u64 {
            if pb_router_score(e) != 0u64 {
                pr_x_esc(48u64)
                return 389u64
            }
            e = e + 1u64
        }
        pb_elect()
        pr_x_esc(48u64)
        PB_ESC = 58u64
    }
    /* the shared expert (always on), then the elected 8 */
    pb_moe_clear()
    if pb_swiglu(0u64, 1u64) != 0u64 { return 389u64 }
    let one_m : u64 = 1u64 << 63u64
    let one_e : i64 = 0i64 - 63i64
    pb_moe_add_weighted(1i64, one_m, one_e, 1i64, one_m, one_e)
    PB_MOE_CONT = pb_cont(3u64, 7168u64)
    if PB_MOE_DECIDED == 1u64 {
        if pb_routed_combine() != 0u64 { return 389u64 }
    }
    pb_wk_from_moe_plus_sv()
    pb_wk_census()
    PB_MOE_OK = 1u64
    PB_MOE_SOUND = PB_MOE_DECIDED
    pb_rs("the synodos: layer 3 MoE -- router elected top-" as u64)
    pb_ru(mb_moe_used())
    pb_rs(" of 256 (sigmoid+bias scores) bias=" as u64)
    if PB_BIAS_ON == 1u64 { pb_rs("on" as u64) }
    if PB_BIAS_ON == 0u64 { pb_rs("off" as u64) }
    pb_rs(" decided=" as u64)
    pb_ru(PB_MOE_DECIDED)
    pb_rs(" certain-in=" as u64)
    pb_ru(PB_MOE_CERTAIN)
    pb_rs("/8 esc=" as u64)
    pb_ru(PB_ESC)
    pb_rs(" gap=" as u64)
    if PB_MOE_DECIDED == 1u64 {
        pb_rs("2^" as u64)
        pb_ri(PB_EGE + 63i64)
    }
    if PB_MOE_DECIDED == 0u64 { pb_rs("straddle" as u64) }
    pb_rs(" shared-expert-FFN contained=" as u64)
    pb_ru(PB_MOE_CONT)
    pb_rs("/7168 gate=sigmoid-normalized scale=2.5 X''=X'+MoE sign-straddle=" as u64)
    pb_ru(PB_WSTRAD)
    pb_rs("/7168 shadow(max-width-exp2)=" as u64)
    pb_ri(PB_WWMAX)
    if PB_MOE_DECIDED == 1u64 {
        pb_rs(" -- the sparse layer of R1 woven in certified intervals" as u64)
    }
    if PB_MOE_DECIDED == 0u64 {
        pb_rs(" -- election undecided: the enclosure REFUSED beyond the shared expert (named); the affine stair is the door" as u64)
    }
    pb_rb(10u8)
    return 0u64
}

/* ==================== THE DIEXODOS (the way through) ====================
 * R1 walked END TO END on the deep anchor: one 896-bit center per
 * dimension, exact matvecs with one truncation per row, the norms and
 * activations through the judged deep quotient tier, the MoE elections
 * decided on centers whose ledger-certified widths sit hundreds of bits
 * below the gaps, and the head's KRISIS: the elected token with its gap,
 * spoken with the width ledger beside it.  What the ledger cannot cover,
 * the walk refuses by name. */

/* the deep save vectors: X (residual), H (the MoE's normed input), the
 * gate stash, and the MoE accumulator; each (sign, 14 limbs, exp) */
var PB_DSVM : [u64; 100352]
var PB_DSVS : [i64; 7168]
var PB_DSVE : [i64; 7168]
var PB_DHM : [u64; 100352]
var PB_DHS : [i64; 7168]
var PB_DHE : [i64; 7168]
var PB_DGM : [u64; 258048]
var PB_DGS : [i64; 18432]
var PB_DGE : [i64; 18432]
var PB_DMM : [u64; 100352]
var PB_DMS : [i64; 7168]
var PB_DME : [i64; 7168]
/* two deep scalar saves (sum-of-squares walkers, norms, weights) */
var PB_S1M : [u64; 14]
var PB_S1S : i64 = 0i64
var PB_S1E : i64 = 0i64
var PB_S2M : [u64; 14]
var PB_S2S : i64 = 0i64
var PB_S2E : i64 = 0i64
/* the router score centers as one-limb dfs (order only; cert by ledger) */
var PB_RCM : [u64; 256]
var PB_RCE : [i64; 256]
var PB_RCS : [i64; 256]
/* the coarse width ledger: a power-of-2 exponent bound over the walk */
var PB_WLED : i64 = 0i64 - 1000000i64
var PB_DX_OK : u64 = 0u64

/* ---- slot plumbing: bathys A/B from the deep stores ---- */
fn pb_a_from_x(i: u64) -> i64 {
    let mut k : u64 = 0u64
    while k < 14u64 {
        pr_bn_seta(k, mb_dz_x_l(i, k))
        k = k + 1u64
    }
    pr_bn_sete_a(mb_dz_x_e(i))
    return mb_dz_x_s(i)
}
fn pb_b_from_x(i: u64) -> i64 {
    let mut k : u64 = 0u64
    while k < 14u64 {
        pr_bn_setb(k, mb_dz_x_l(i, k))
        k = k + 1u64
    }
    pr_bn_sete_b(mb_dz_x_e(i))
    return mb_dz_x_s(i)
}
fn pb_a_from_o(i: u64) -> i64 {
    let mut k : u64 = 0u64
    while k < 14u64 {
        pr_bn_seta(k, mb_dz_o_l(i, k))
        k = k + 1u64
    }
    pr_bn_sete_a(mb_dz_o_e(i))
    return mb_dz_o_s(i)
}
fn pb_b_from_o(i: u64) -> i64 {
    let mut k : u64 = 0u64
    while k < 14u64 {
        pr_bn_setb(k, mb_dz_o_l(i, k))
        k = k + 1u64
    }
    pr_bn_sete_b(mb_dz_o_e(i))
    return mb_dz_o_s(i)
}
/* buffers: 0 = SV, 1 = H, 2 = G, 3 = M */
fn pb_a_from_buf(w: u64, i: u64) -> i64 {
    let base : u64 = i * 14u64
    let mut k : u64 = 0u64
    while k < 14u64 {
        let mut v : u64 = 0u64
        if w == 0u64 { v = PB_DSVM[base + k] }
        if w == 1u64 { v = PB_DHM[base + k] }
        if w == 2u64 { v = PB_DGM[base + k] }
        if w == 3u64 { v = PB_DMM[base + k] }
        pr_bn_seta(k, v)
        k = k + 1u64
    }
    let mut e : i64 = 0i64
    let mut s : i64 = 0i64
    if w == 0u64 { e = PB_DSVE[i]   s = PB_DSVS[i] }
    if w == 1u64 { e = PB_DHE[i]   s = PB_DHS[i] }
    if w == 2u64 { e = PB_DGE[i]   s = PB_DGS[i] }
    if w == 3u64 { e = PB_DME[i]   s = PB_DMS[i] }
    pr_bn_sete_a(e)
    return s
}
fn pb_b_from_buf(w: u64, i: u64) -> i64 {
    let base : u64 = i * 14u64
    let mut k : u64 = 0u64
    while k < 14u64 {
        let mut v : u64 = 0u64
        if w == 0u64 { v = PB_DSVM[base + k] }
        if w == 1u64 { v = PB_DHM[base + k] }
        if w == 2u64 { v = PB_DGM[base + k] }
        if w == 3u64 { v = PB_DMM[base + k] }
        pr_bn_setb(k, v)
        k = k + 1u64
    }
    let mut e : i64 = 0i64
    let mut s : i64 = 0i64
    if w == 0u64 { e = PB_DSVE[i]   s = PB_DSVS[i] }
    if w == 1u64 { e = PB_DHE[i]   s = PB_DHS[i] }
    if w == 2u64 { e = PB_DGE[i]   s = PB_DGS[i] }
    if w == 3u64 { e = PB_DME[i]   s = PB_DMS[i] }
    pr_bn_sete_b(e)
    return s
}
fn pb_buf_from_r(w: u64, i: u64, s: i64) -> u64 {
    let base : u64 = i * 14u64
    let mut s2 : i64 = s
    if pr_bn_rz() == 1u64 { s2 = 0i64 }
    let mut k : u64 = 0u64
    while k < 14u64 {
        let v : u64 = pr_bn_r(k)
        if w == 0u64 { PB_DSVM[base + k] = v }
        if w == 1u64 { PB_DHM[base + k] = v }
        if w == 2u64 { PB_DGM[base + k] = v }
        if w == 3u64 { PB_DMM[base + k] = v }
        k = k + 1u64
    }
    let e : i64 = pr_bn_re()
    if w == 0u64 { PB_DSVE[i] = e   PB_DSVS[i] = s2 }
    if w == 1u64 { PB_DHE[i] = e   PB_DHS[i] = s2 }
    if w == 2u64 { PB_DGE[i] = e   PB_DGS[i] = s2 }
    if w == 3u64 { PB_DME[i] = e   PB_DMS[i] = s2 }
    return 0u64
}
fn pb_x_from_r(i: u64, s: i64) -> u64 {
    let mut s2 : i64 = s
    if pr_bn_rz() == 1u64 { s2 = 0i64 }
    let mut k : u64 = 0u64
    while k < 14u64 {
        mb_dz_set(i, k, pr_bn_r(k))
        k = k + 1u64
    }
    mb_dz_sete(i, s2, pr_bn_re())
    return 0u64
}
fn pb_x_zero(i: u64) -> u64 {
    let mut k : u64 = 0u64
    while k < 14u64 {
        mb_dz_set(i, k, 0u64)
        k = k + 1u64
    }
    mb_dz_sete(i, 0i64, 0i64)
    return 0u64
}
/* pass-through: result <- A (add a zero B) / result <- B (add a zero A) */
fn pb_pass_a(s: i64) -> i64 {
    let mut k : u64 = 0u64
    while k < 14u64 {
        pr_bn_setb(k, 0u64)
        k = k + 1u64
    }
    pr_bn_sete_b(0i64)
    pr_bn_x_add(0u64)
    return s
}
fn pb_pass_b(s: i64) -> i64 {
    let mut k : u64 = 0u64
    while k < 14u64 {
        pr_bn_seta(k, 0u64)
        k = k + 1u64
    }
    pr_bn_sete_a(0i64)
    pr_bn_x_add(0u64)
    return s
}
fn pb_buf_from_x(w: u64, i: u64) -> u64 {
    let base : u64 = i * 14u64
    let mut k : u64 = 0u64
    while k < 14u64 {
        let v : u64 = mb_dz_x_l(i, k)
        if w == 0u64 { PB_DSVM[base + k] = v }
        if w == 1u64 { PB_DHM[base + k] = v }
        k = k + 1u64
    }
    if w == 0u64 { PB_DSVE[i] = mb_dz_x_e(i)   PB_DSVS[i] = mb_dz_x_s(i) }
    if w == 1u64 { PB_DHE[i] = mb_dz_x_e(i)   PB_DHS[i] = mb_dz_x_s(i) }
    return 0u64
}
fn pb_x_from_buf(w: u64, i: u64) -> u64 {
    let base : u64 = i * 14u64
    let mut k : u64 = 0u64
    while k < 14u64 {
        let mut v : u64 = 0u64
        if w == 0u64 { v = PB_DSVM[base + k] }
        if w == 1u64 { v = PB_DHM[base + k] }
        mb_dz_set(i, k, v)
        k = k + 1u64
    }
    if w == 0u64 { mb_dz_sete(i, PB_DSVS[i], PB_DSVE[i]) }
    if w == 1u64 { mb_dz_sete(i, PB_DHS[i], PB_DHE[i]) }
    return 0u64
}

/* zero one deep buffer range */
fn pb_dbuf_zero(w: u64, n: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < n {
        let base : u64 = i * 14u64
        let mut k : u64 = 0u64
        while k < 14u64 {
            if w == 3u64 { PB_DMM[base + k] = 0u64 }
            k = k + 1u64
        }
        if w == 3u64 { PB_DMS[i] = 0i64   PB_DME[i] = 0i64 }
        i = i + 1u64
    }
    return 0u64
}

/* THE WIDTH LEDGER fold after one deep projection.  W is the log2 of an
 * absolute bound on the error interval's half-width.  One projection maps
 * W_in -> W_out <= amp*2^-24 * W_in + fresh, where amp = max row-mass
 * Sigma|w| (at 2^-24) and fresh = one truncation at the served lsb.  In
 * log2, honoring the TACHOS floor (the fast tier truncates at limb LO, so
 * fresh = 2^(oemax + LO*64)):
 *   W_out(log2) = max(log2(amp)-24 + W_in, oemax + LO*64) + 1  */
fn pb_wled_fold() -> u64 {
    let amp : u64 = mb_dz_amp()
    let mut la : i64 = 0i64 - 24i64
    let mut t : u64 = amp
    while t != 0u64 {
        t = t >> 1u64
        la = la + 1i64
    }
    let fresh : i64 = mb_dz_oemax() + (mb_dz_lo() as i64) * 64i64
    let mut w : i64 = PB_WLED + la
    if fresh > w { w = fresh }
    PB_WLED = w + 1i64
    return 0u64
}

/* deep RMS over the thought [0..n): gamma from slot (sp 1 = output_norm)
 * -- x_i <- x_i * gamma_i / sqrt(mean(x^2) + eps).  0 ok / 1 red */
fn pb_dz_rms(n: u64, slot: u64, sp: u64) -> u64 {
    if sp == 0u64 {
        if mb_ld_normw(slot, n) != 0u64 { return 1u64 }
    }
    if sp == 1u64 {
        if mb_ld_normw_sp(1u64, n) != 0u64 { return 1u64 }
    }
    /* sumsq into S1 */
    PB_S1S = 0i64
    let mut k : u64 = 0u64
    while k < 14u64 {
        PB_S1M[k] = 0u64
        k = k + 1u64
    }
    PB_S1E = 0i64
    let mut i : u64 = 0u64
    while i < n {
        if mb_dz_x_s(i) != 0i64 {
            pb_a_from_x(i)
            pb_b_from_x(i)
            if pr_bn_x_mul(0u64) != 0u64 { return 1u64 }
            if PB_S1S == 0i64 {
                pr_bn_r_to_a()
                PB_S1S = 1i64
                k = 0u64
                while k < 14u64 {
                    PB_S1M[k] = pr_bn_r(k)
                    k = k + 1u64
                }
                PB_S1E = pr_bn_re()
            }
            if PB_S1S == 1i64 {
                /* acc += t: A <- acc, B <- t(channel) */
                pr_bn_r_to_b()
                k = 0u64
                while k < 14u64 {
                    pr_bn_seta(k, PB_S1M[k])
                    k = k + 1u64
                }
                pr_bn_sete_a(PB_S1E)
                if pr_bn_x_add(0u64) != 0u64 { return 1u64 }
                k = 0u64
                while k < 14u64 {
                    PB_S1M[k] = pr_bn_r(k)
                    k = k + 1u64
                }
                PB_S1E = pr_bn_re()
            }
        }
        i = i + 1u64
    }
    if PB_S1S == 0i64 { return 1u64 }
    /* mean: * recip(n) */
    pr_bn_from_df_a(1u64 << 63u64, 0i64)
    /* build n as a small into A then recip */
    let mut sh : u64 = 0u64
    let mut hh : u64 = n
    while (hh >> 63u64) == 0u64 {
        hh = hh << 1u64
        sh = sh + 1u64
    }
    k = 0u64
    while k < 14u64 {
        pr_bn_seta(k, 0u64)
        k = k + 1u64
    }
    pr_bn_seta(13u64, n << sh)
    pr_bn_sete_a((0i64 - 832i64) - (sh as i64))
    if pr_bn_recip(0u64) != 0u64 { return 1u64 }
    pr_bn_r_to_b()
    k = 0u64
    while k < 14u64 {
        pr_bn_seta(k, PB_S1M[k])
        k = k + 1u64
    }
    pr_bn_sete_a(PB_S1E)
    if pr_bn_x_mul(0u64) != 0u64 { return 1u64 }
    /* + eps (exact f32) */
    let em : i64 = mb_gz_eps_m()
    if em > 0i64 {
        pr_bn_r_to_a()
        let mut mg : u64 = em as u64
        let mut sh2 : u64 = 0u64
        let mut h2 : u64 = mg
        while (h2 >> 63u64) == 0u64 {
            h2 = h2 << 1u64
            sh2 = sh2 + 1u64
        }
        k = 0u64
        while k < 14u64 {
            pr_bn_setb(k, 0u64)
            k = k + 1u64
        }
        pr_bn_setb(13u64, mg << sh2)
        pr_bn_sete_b(mb_gz_eps_e() - 832i64 - (sh2 as i64))
        if pr_bn_x_add(0u64) != 0u64 { return 1u64 }
    }
    /* sqrt then recip -> S2 = 1/rms */
    pr_bn_r_to_a()
    if pr_bn_sqrt(0u64) != 0u64 { return 1u64 }
    pr_bn_r_to_a()
    if pr_bn_recip(0u64) != 0u64 { return 1u64 }
    PB_S2S = 1i64
    k = 0u64
    while k < 14u64 {
        PB_S2M[k] = pr_bn_r(k)
        k = k + 1u64
    }
    PB_S2E = pr_bn_re()
    /* xhat_i = x_i * gamma_i * (1/rms) */
    i = 0u64
    while i < n {
        let gm : i64 = mb_nw_m(i)
        let xs : i64 = mb_dz_x_s(i)
        if gm == 0i64 {
            pb_x_zero(i)
        }
        if xs == 0i64 {
            if gm != 0i64 { pb_x_zero(i) }
        }
        if gm != 0i64 {
            if xs != 0i64 {
                let mut gs : i64 = 1i64
                let mut gmm : u64 = gm as u64
                if gm < 0i64 {
                    gs = 0i64 - 1i64
                    gmm = (0i64 - gm) as u64
                }
                let mut sh3 : u64 = 0u64
                let mut h3 : u64 = gmm
                while (h3 >> 63u64) == 0u64 {
                    h3 = h3 << 1u64
                    sh3 = sh3 + 1u64
                }
                pb_a_from_x(i)
                k = 0u64
                while k < 14u64 {
                    pr_bn_setb(k, 0u64)
                    k = k + 1u64
                }
                pr_bn_setb(13u64, gmm << sh3)
                pr_bn_sete_b(mb_nw_e(i) - 832i64 - (sh3 as i64))
                if pr_bn_x_mul(0u64) != 0u64 { return 1u64 }
                pr_bn_r_to_a()
                k = 0u64
                while k < 14u64 {
                    pr_bn_setb(k, PB_S2M[k])
                    k = k + 1u64
                }
                pr_bn_sete_b(PB_S2E)
                if pr_bn_x_mul(0u64) != 0u64 { return 1u64 }
                let mut rs : i64 = xs
                if gs < 0i64 { rs = 0i64 - rs }
                pb_x_from_r(i, rs)
            }
        }
        i = i + 1u64
    }
    mb_dz_mark(n)
    return 0u64
}

/* deep sigma of the value in A (sign sa): 1/(1 + e^-z), center, dn */
fn pb_dz_sigma_deep(sa: i64) -> u64 {
    let rc : u64 = pr_bn_exp(0i64 - sa, 0u64)
    if rc == 1u64 {
        /* saturation: z >= 24 -> sigma ~ 1; z <= -24 -> sigma ~ 0 */
        let mut k : u64 = 0u64
        while k < 14u64 {
            pr_bn_seta(k, 0u64)
            pr_bn_setb(k, 0u64)
            k = k + 1u64
        }
        if sa > 0i64 {
            pr_bn_seta(13u64, 1u64 << 63u64)
            pr_bn_sete_a(0i64 - 895i64)
        }
        pr_bn_sete_b(0i64)
        pr_bn_x_add(0u64)
        return 0u64
    }
    /* 1 + e^-z */
    pr_bn_r_to_a()
    let mut k2 : u64 = 0u64
    while k2 < 14u64 {
        pr_bn_setb(k2, 0u64)
        k2 = k2 + 1u64
    }
    pr_bn_setb(13u64, 1u64 << 63u64)
    pr_bn_sete_b(0i64 - 895i64)
    if pr_bn_x_add(0u64) != 0u64 { return 1u64 }
    pr_bn_r_to_a()
    if pr_bn_recip(0u64) != 0u64 { return 1u64 }
    return 0u64
}

/* the deep attention half (single token): X -> X' in the thought */
fn pb_dz_attn(lay: u64) -> u64 {
    let b : u64 = lay * 12u64
    let mut i : u64 = 0u64
    while i < 7168u64 {
        pb_buf_from_x(0u64, i)
        i = i + 1u64
    }
    if pb_dz_rms(7168u64, b + 0u64, 0u64) != 0u64 { return 11u64 }
    let r4 : u64 = mb_dz_run(b + 4u64, 7168u64, 576u64)
    if r4 != 0u64 { return 120u64 + r4 }
    pb_wled_fold()
    /* thought <- out[0..512] (the latent; the 64 rope lanes rest at pos 0) */
    i = 0u64
    while i < 512u64 {
        let mut k : u64 = 0u64
        while k < 14u64 {
            mb_dz_set(i, k, mb_dz_o_l(i, k))
            k = k + 1u64
        }
        mb_dz_sete(i, mb_dz_o_s(i), mb_dz_o_e(i))
        i = i + 1u64
    }
    mb_dz_mark(512u64)
    if pb_dz_rms(512u64, b + 5u64, 0u64) != 0u64 { return 13u64 }
    let r6 : u64 = mb_dz_run(b + 6u64, 512u64, 32768u64)
    if r6 != 0u64 { return 140u64 + r6 }
    pb_wled_fold()
    /* extract V: thought[h*128+d] <- out[h*256+128+d] */
    let mut h : u64 = 0u64
    while h < 128u64 {
        let mut d : u64 = 0u64
        while d < 128u64 {
            let src : u64 = h * 256u64 + 128u64 + d
            let dst : u64 = h * 128u64 + d
            let mut k2 : u64 = 0u64
            while k2 < 14u64 {
                mb_dz_set(dst, k2, mb_dz_o_l(src, k2))
                k2 = k2 + 1u64
            }
            mb_dz_sete(dst, mb_dz_o_s(src), mb_dz_o_e(src))
            d = d + 1u64
        }
        h = h + 1u64
    }
    mb_dz_mark(16384u64)
    if mb_dz_run(b + 7u64, 16384u64, 7168u64) != 0u64 { return 1u64 }
    pb_wled_fold()
    /* X' = save + out -> thought */
    i = 0u64
    while i < 7168u64 {
        let so : i64 = pb_b_from_o(i)
        let ss : i64 = pb_a_from_buf(0u64, i)
        let mut rs : i64 = 0i64
        if ss == so {
            if ss != 0i64 {
                if pr_bn_x_add(0u64) != 0u64 { return 1u64 }
                rs = ss
            }
        }
        if ss != so {
            if ss == 0i64 { rs = pb_pass_b(so) }
            if so == 0i64 {
                if ss != 0i64 { rs = pb_pass_a(ss) }
            }
            if ss != 0i64 {
                if so != 0i64 {
                    let c : i64 = pr_bn_cmp()
                    if c >= 0i64 {
                        if pr_bn_x_sub(0u64) != 0u64 { return 1u64 }
                        rs = ss
                        if c == 0i64 { rs = 0i64 }
                    }
                    if c < 0i64 {
                        /* reload swapped: A <- out, B <- save */
                        pb_a_from_o(i)
                        pb_b_from_buf(0u64, i)
                        if pr_bn_x_sub(0u64) != 0u64 { return 1u64 }
                        rs = so
                    }
                }
            }
        }
        pb_x_from_r(i, rs)
        i = i + 1u64
    }
    mb_dz_mark(7168u64)
    return 0u64
}

/* the deep dense FFN half: X' -> X'' in the thought */
fn pb_dz_ffn_dense(lay: u64) -> u64 {
    let b : u64 = lay * 12u64
    let mut i : u64 = 0u64
    while i < 7168u64 {
        pb_buf_from_x(0u64, i)
        i = i + 1u64
    }
    if pb_dz_rms(7168u64, b + 8u64, 0u64) != 0u64 { return 1u64 }
    if mb_dz_run(b + 9u64, 7168u64, 18432u64) != 0u64 { return 1u64 }
    pb_wled_fold()
    /* stash gate -> G */
    i = 0u64
    while i < 18432u64 {
        let base : u64 = i * 14u64
        let mut k : u64 = 0u64
        while k < 14u64 {
            PB_DGM[base + k] = mb_dz_o_l(i, k)
            k = k + 1u64
        }
        PB_DGS[i] = mb_dz_o_s(i)
        PB_DGE[i] = mb_dz_o_e(i)
        i = i + 1u64
    }
    if mb_dz_run(b + 10u64, 7168u64, 18432u64) != 0u64 { return 1u64 }
    pb_wled_fold()
    /* silu: thought[j] = g * sigma(g) * u */
    let mut j : u64 = 0u64
    while j < 18432u64 {
        let gs : i64 = PB_DGS[j]
        let us : i64 = mb_dz_o_s(j)
        if gs == 0i64 { pb_x_zero(j) }
        if us == 0i64 {
            if gs != 0i64 { pb_x_zero(j) }
        }
        if gs != 0i64 {
            if us != 0i64 {
                pb_a_from_buf(2u64, j)
                if pb_dz_sigma_deep(gs) != 0u64 { return 1u64 }
                if pr_bn_rz() == 1u64 {
                    pb_x_zero(j)
                }
                if pr_bn_rz() == 0u64 {
                    pr_bn_r_to_b()
                    pb_a_from_buf(2u64, j)
                    if pr_bn_x_mul(0u64) != 0u64 { return 1u64 }
                    pr_bn_r_to_a()
                    pb_b_from_o(j)
                    if pr_bn_x_mul(0u64) != 0u64 { return 1u64 }
                    let mut rs : i64 = gs
                    if us < 0i64 { rs = 0i64 - rs }
                    pb_x_from_r(j, rs)
                }
            }
        }
        j = j + 1u64
    }
    mb_dz_mark(18432u64)
    if mb_dz_run(b + 11u64, 18432u64, 7168u64) != 0u64 { return 1u64 }
    pb_wled_fold()
    /* X'' = save + out */
    i = 0u64
    while i < 7168u64 {
        let so : i64 = pb_b_from_o(i)
        let ss : i64 = pb_a_from_buf(0u64, i)
        let mut rs : i64 = 0i64
        if ss == so {
            if ss != 0i64 {
                if pr_bn_x_add(0u64) != 0u64 { return 1u64 }
                rs = ss
            }
        }
        if ss != so {
            if ss == 0i64 { rs = pb_pass_b(so) }
            if so == 0i64 {
                if ss != 0i64 { rs = pb_pass_a(ss) }
            }
            if ss != 0i64 {
                if so != 0i64 {
                    let c : i64 = pr_bn_cmp()
                    if c >= 0i64 {
                        if pr_bn_x_sub(0u64) != 0u64 { return 1u64 }
                        rs = ss
                        if c == 0i64 { rs = 0i64 }
                    }
                    if c < 0i64 {
                        pb_a_from_o(i)
                        pb_b_from_buf(0u64, i)
                        if pr_bn_x_sub(0u64) != 0u64 { return 1u64 }
                        rs = so
                    }
                }
            }
        }
        pb_x_from_r(i, rs)
        i = i + 1u64
    }
    mb_dz_mark(7168u64)
    return 0u64
}

/* ==================== THE FAITHFUL ATTENTION CORE (multi-position) ==========
 * The degenerate pos-0 attention (softmax=1, output=V) skips scores entirely --
 * valid only for a single token.  Faithful decode needs the multi-position mix:
 * given the scores of a query against EVERY cached key and the cached values,
 * produce softmax(scores) . V.  This is that core -- the ONE piece the single-
 * token walk never built -- over the exact dyadic-float tier (pr_x_df*,
 * pr_x_exp_s), the same currency the MoE weighting uses.  Verified EXACTLY on
 * synthetic scores/values (pb_attn_selfprove, NO Feast): a lone position keeps
 * its value; EQUAL scores give EQUAL weights (softmax symmetry, exact); a
 * DOMINANT score wins (ordering).  The Q/K/rope/KV-cache wiring feeds these
 * buffers; the mixing math here is proven independent of the weights. */
var PB_ATSM : [u64; 64]                   /* score p: mantissa */
var PB_ATSE : [i64; 64]                   /* score p: exponent */
var PB_ATSS : [i64; 64]                   /* score p: sign (1 / -1 / 0) */
var PB_ATWM : [u64; 64]                   /* weight p: mantissa (softmax, >= 0) */
var PB_ATWE : [i64; 64]                   /* weight p: exponent */
var PB_ATVM : [u64; 8192]                 /* value [p*128+i]: mantissa */
var PB_ATVE : [i64; 8192]                 /* value [p*128+i]: exponent */
var PB_ATVS : [i64; 8192]                 /* value [p*128+i]: sign */
var PB_ATOM : [u64; 128]                  /* output i: mantissa */
var PB_ATOE : [i64; 128]                  /* output i: exponent */
var PB_ATOS : [i64; 128]                  /* output i: sign */

fn pb_attn_set_score(p: u64, s: i64, iv: u64) -> i32 {
    if p >= 64u64 { return 1i32 }
    pr_x_dfn2(0u64, iv, 0i64, 0u64)
    PB_ATSM[p] = pr_x_dfm()
    PB_ATSE[p] = pr_x_dfe()
    PB_ATSS[p] = s
    if iv == 0u64 { PB_ATSS[p] = 0i64 }
    return 0i32
}
fn pb_attn_set_v(p: u64, i: u64, s: i64, iv: u64) -> i32 {
    if p >= 64u64 { return 1i32 }
    if i >= 128u64 { return 1i32 }
    pr_x_dfn2(0u64, iv, 0i64, 0u64)
    let vi : u64 = p * 128u64 + i
    PB_ATVM[vi] = pr_x_dfm()
    PB_ATVE[vi] = pr_x_dfe()
    PB_ATVS[vi] = s
    if iv == 0u64 { PB_ATVS[vi] = 0i64 }
    return 0i32
}
fn pb_attn_o_m(i: u64) -> u64 @export { if i < 128u64 { return PB_ATOM[i] }   return 0u64 }
fn pb_attn_o_e(i: u64) -> i64 @export { if i < 128u64 { return PB_ATOE[i] }   return 0i64 }
fn pb_attn_o_s(i: u64) -> i64 @export { if i < 128u64 { return PB_ATOS[i] }   return 0i64 }

/* signed greater-than for dyadic floats (value = sign * m * 2^e) */
fn pb_df_sgt(s1: i64, m1: u64, e1: i64, s2: i64, m2: u64, e2: i64) -> u64 {
    if s1 > 0i64 {
        if s2 <= 0i64 { return 1u64 }
        if pr_x_dfcmp(m1, e1, m2, e2) > 0i64 { return 1u64 }
        return 0u64
    }
    if s1 == 0i64 {
        if s2 < 0i64 { return 1u64 }
        return 0u64
    }
    if s2 >= 0i64 { return 0u64 }
    if pr_x_dfcmp(m1, e1, m2, e2) < 0i64 { return 1u64 }
    return 0u64
}
/* a - b (>= 0 assumed, a >= b) into the df result (PR_DFM/PR_DFE) */
fn pb_df_submag(sa: i64, ma: u64, ea: i64, sb: i64, mb: u64, eb: i64) -> i32 {
    if sb == 0i64 { pr_x_dfsub(ma, ea, 0u64, 0i64, 0u64)   return 0i32 }
    if sa == 0i64 { pr_x_dfsub(mb, eb, 0u64, 0i64, 0u64)   return 0i32 }
    if sa == sb {
        if sa > 0i64 { pr_x_dfsub(ma, ea, mb, eb, 0u64) }
        if sa < 0i64 { pr_x_dfsub(mb, eb, ma, ea, 0u64) }
        return 0i32
    }
    pr_x_dfadd(ma, ea, mb, eb, 0u64)
    return 0i32
}
/* softmax over the npos scores -> the nonneg weights.  exp(z) caps at |z|>=24
 * (a score far below the max) -> that weight is 0 (negligible), by name. */
fn pb_attn_softmax(npos: u64) -> u64 @export {
    if npos == 0u64 { return 1u64 }
    if npos > 64u64 { return 1u64 }
    let mut mxm : u64 = PB_ATSM[0]
    let mut mxe : i64 = PB_ATSE[0]
    let mut mxs : i64 = PB_ATSS[0]
    let mut p : u64 = 1u64
    while p < npos {
        if pb_df_sgt(PB_ATSS[p], PB_ATSM[p], PB_ATSE[p], mxs, mxm, mxe) == 1u64 {
            mxm = PB_ATSM[p]   mxe = PB_ATSE[p]   mxs = PB_ATSS[p]
        }
        p = p + 1u64
    }
    let mut zm : u64 = 0u64
    let mut ze : i64 = 0i64
    p = 0u64
    while p < npos {
        pb_df_submag(mxs, mxm, mxe, PB_ATSS[p], PB_ATSM[p], PB_ATSE[p])
        let dm : u64 = pr_x_dfm()
        let de : i64 = pr_x_dfe()
        let rc : u64 = pr_x_exp_s(dm, de, 0i64 - 1i64, 0u64)
        if rc != 0u64 { PB_ATWM[p] = 0u64   PB_ATWE[p] = 0i64 }
        if rc == 0u64 { PB_ATWM[p] = pr_x_dfm()   PB_ATWE[p] = pr_x_dfe() }
        if PB_ATWM[p] != 0u64 {
            if zm == 0u64 { zm = PB_ATWM[p]   ze = PB_ATWE[p] }
            else {
                pr_x_dfadd(zm, ze, PB_ATWM[p], PB_ATWE[p], 0u64)
                zm = pr_x_dfm()   ze = pr_x_dfe()
            }
        }
        p = p + 1u64
    }
    if zm == 0u64 { return 1u64 }
    pr_x_dfrecip(zm, ze, 0u64)
    let rzm : u64 = pr_x_dfm()
    let rze : i64 = pr_x_dfe()
    p = 0u64
    while p < npos {
        if PB_ATWM[p] != 0u64 {
            pr_x_dfmul(PB_ATWM[p], PB_ATWE[p], rzm, rze, 0u64)
            PB_ATWM[p] = pr_x_dfm()   PB_ATWE[p] = pr_x_dfe()
        }
        p = p + 1u64
    }
    return 0u64
}
/* output[i] = sum_p weight[p] * value[p][i]  (signed accumulation, d <= 128) */
fn pb_attn_wv(npos: u64, d: u64) -> u64 @export {
    if npos > 64u64 { return 1u64 }
    if d > 128u64 { return 1u64 }
    let mut i : u64 = 0u64
    while i < d {
        let mut accm : u64 = 0u64
        let mut acce : i64 = 0i64
        let mut accs : i64 = 0i64
        let mut p : u64 = 0u64
        while p < npos {
            let wmp : u64 = PB_ATWM[p]
            if wmp != 0u64 {
                let vi : u64 = p * 128u64 + i
                let vm : u64 = PB_ATVM[vi]
                let vs : i64 = PB_ATVS[vi]
                if vm != 0u64 {
                    if vs != 0i64 {
                        pr_x_dfmul(wmp, PB_ATWE[p], vm, PB_ATVE[vi], 0u64)
                        let tm : u64 = pr_x_dfm()
                        let te : i64 = pr_x_dfe()
                        if accm == 0u64 { accm = tm   acce = te   accs = vs }
                        else {
                            if accs == vs {
                                pr_x_dfadd(accm, acce, tm, te, 0u64)
                                accm = pr_x_dfm()   acce = pr_x_dfe()
                            }
                            if accs != vs {
                                let c : i64 = pr_x_dfcmp(accm, acce, tm, te)
                                if c > 0i64 {
                                    pr_x_dfsub(accm, acce, tm, te, 0u64)
                                    accm = pr_x_dfm()   acce = pr_x_dfe()
                                }
                                if c == 0i64 { accm = 0u64   acce = 0i64   accs = 0i64 }
                                if c < 0i64 {
                                    pr_x_dfsub(tm, te, accm, acce, 0u64)
                                    accm = pr_x_dfm()   acce = pr_x_dfe()
                                    accs = vs
                                }
                            }
                        }
                    }
                }
            }
            p = p + 1u64
        }
        PB_ATOM[i] = accm
        PB_ATOE[i] = acce
        PB_ATOS[i] = accs
        i = i + 1u64
    }
    return 0u64
}
/* the signed dyadic-float DOT product -- the raw attention SCORE q.k over a
 * head.  result: sign in PB_DOTS, magnitude in the df (pr_x_dfm/dfe). */
var PB_DAM : [u64; 192]   var PB_DAE : [i64; 192]   var PB_DAS : [i64; 192]
var PB_DBM : [u64; 192]   var PB_DBE : [i64; 192]   var PB_DBS : [i64; 192]
var PB_DOTS : i64 = 0i64
fn pb_df_set_a(i: u64, s: i64, iv: u64) -> i32 {
    if i >= 192u64 { return 1i32 }
    pr_x_dfn2(0u64, iv, 0i64, 0u64)
    PB_DAM[i] = pr_x_dfm()   PB_DAE[i] = pr_x_dfe()   PB_DAS[i] = s
    if iv == 0u64 { PB_DAS[i] = 0i64 }
    return 0i32
}
fn pb_df_set_b(i: u64, s: i64, iv: u64) -> i32 {
    if i >= 192u64 { return 1i32 }
    pr_x_dfn2(0u64, iv, 0i64, 0u64)
    PB_DBM[i] = pr_x_dfm()   PB_DBE[i] = pr_x_dfe()   PB_DBS[i] = s
    if iv == 0u64 { PB_DBS[i] = 0i64 }
    return 0i32
}
fn pb_df_dot(n: u64) -> u64 {
    if n > 192u64 { return 1u64 }
    let mut accm : u64 = 0u64
    let mut acce : i64 = 0i64
    let mut accs : i64 = 0i64
    let mut i : u64 = 0u64
    while i < n {
        let am : u64 = PB_DAM[i]
        let bm : u64 = PB_DBM[i]
        if am != 0u64 {
            if bm != 0u64 {
                if PB_DAS[i] != 0i64 {
                    if PB_DBS[i] != 0i64 {
                        pr_x_dfmul(am, PB_DAE[i], bm, PB_DBE[i], 0u64)
                        let tm : u64 = pr_x_dfm()
                        let te : i64 = pr_x_dfe()
                        let mut ts : i64 = 1i64
                        if PB_DAS[i] != PB_DBS[i] { ts = 0i64 - 1i64 }
                        if accm == 0u64 { accm = tm   acce = te   accs = ts }
                        else {
                            if accs == ts {
                                pr_x_dfadd(accm, acce, tm, te, 0u64)
                                accm = pr_x_dfm()   acce = pr_x_dfe()
                            }
                            if accs != ts {
                                let c : i64 = pr_x_dfcmp(accm, acce, tm, te)
                                if c > 0i64 {
                                    pr_x_dfsub(accm, acce, tm, te, 0u64)
                                    accm = pr_x_dfm()   acce = pr_x_dfe()
                                }
                                if c == 0i64 { accm = 0u64   acce = 0i64   accs = 0i64 }
                                if c < 0i64 {
                                    pr_x_dfsub(tm, te, accm, acce, 0u64)
                                    accm = pr_x_dfm()   acce = pr_x_dfe()
                                    accs = ts
                                }
                            }
                        }
                    }
                }
            }
        }
        i = i + 1u64
    }
    PB_DOTS = accs
    pr_x_dfsub(accm, acce, 0u64, 0i64, 0u64)
    return 0u64
}

/* ==================== THE EXACT KRISIS (refuting the numerical UNDECIDED) =====
 * The argmax is an ORDER -- a discrete fact -- and the 896-bit UNDECIDED is a
 * TRUNCATION artifact: when large logit terms nearly cancel, the true difference
 * lives below the fixed-precision floor and rounds to ZERO (a false tie), while
 * the fixed tier's width bound blows up (the ancestral 2^12663 wall).  That is
 * EXACTLY R1's head: a real gap buried under truncation.  III's EXACT tier
 * (unbounded bigint, zero truncation) does not round -- it DECIDES the sign.
 * These twins prove the principle: the SAME near-cancellation the float tier
 * calls undecided, bigint decides. */

/* fixed 64-bit dyadic float: (2^100 + 2^30) - 2^100.  2^30 is below the ulp of
 * 2^100 (70 bits down) so it is LOST -> the difference rounds to 0: UNDECIDED. */
fn pb_fixed_cancel_sign() -> i64 @export {
    pr_x_dfn2(0u64, 1u64, 100i64, 0u64)
    let am : u64 = pr_x_dfm()
    let ae : i64 = pr_x_dfe()
    pr_x_dfn2(0u64, 1u64, 30i64, 0u64)
    let bm : u64 = pr_x_dfm()
    let be : i64 = pr_x_dfe()
    pr_x_dfadd(am, ae, bm, be, 0u64)          /* 2^100 + 2^30 -> rounds to 2^100 */
    let sm : u64 = pr_x_dfm()
    let se : i64 = pr_x_dfe()
    if pr_x_dfcmp(sm, se, am, ae) == 0i64 { return 0i64 }   /* the +2^30 vanished: a FALSE TIE */
    pr_x_dfsub(sm, se, am, ae, 0u64)
    if pr_x_dfm() == 0u64 { return 0i64 }
    return 1i64
}
/* EXACT bigint: (2^100 + 2^30) - 2^100 = 2^30, nonzero -> sign +1: DECIDED.
 * The +2^30 survives because bigint never truncates.  This is the order the
 * float tier could not see. */
fn pb_exact_cancel_sign() -> i64 @export {
    let ar : u64 = arena_new(65536u64)
    if ar == 0u64 { return 0i64 - 2i64 }
    let one : u64 = bigint_from_u64(ar, 1u64)
    let a : u64 = bigint_shl_bits(ar, one, 100u64)
    let b : u64 = bigint_shl_bits(ar, one, 30u64)
    let ab : u64 = bigint_add(ar, a, b)
    let res : u64 = bigint_sub(ar, ab, a)
    let mut s : i64 = 0i64
    if bigint_is_zero(res) == 0u8 { s = 1i64 }
    bigint_drop_arena(ar)   arena_drop(ar)
    return s
}

/* set a term by (sign, mantissa, exp) directly -- so a value beyond a u64 (a
 * real logit term) enters the exact path without the setter rounding it. */
fn pb_df_set_a_me(i: u64, s: i64, m: u64, e: i64) -> i32 {
    if i >= 192u64 { return 1i32 }
    PB_DAM[i] = m   PB_DAE[i] = e   PB_DAS[i] = s
    return 0i32
}
fn pb_df_set_b_me(i: u64, s: i64, m: u64, e: i64) -> i32 {
    if i >= 192u64 { return 1i32 }
    PB_DBM[i] = m   PB_DBE[i] = e   PB_DBS[i] = s
    return 0i32
}
/* THE EXACT DOT-SIGN: sign of sum_i (a_i * b_i) -- the head logit difference
 * decided EXACTLY, no truncation, no width, no false tie.  A THIN CLIENT of the
 * numera krisis kernel: each live product becomes one dyadic term
 * (sign = s_a*s_b, magnitude = m_a * m_b, exponent = e_a + e_b), and the kernel
 * decides in unbounded bigint.  -1/0/+1 in PB_EXS (and returned). */
var PB_EXS : i64 = 0i64
fn pb_exact_dot_sign(n: u64) -> i64 @export {
    if n > 192u64 { return 0i64 - 2i64 }
    kr_begin()
    let mut i : u64 = 0u64
    while i < n {
        if PB_DAM[i] != 0u64 { if PB_DBM[i] != 0u64 { if PB_DAS[i] != 0i64 { if PB_DBS[i] != 0i64 {
            let mut ts : i64 = 1i64
            if PB_DAS[i] != PB_DBS[i] { ts = 0i64 - 1i64 }
            kr_term_prod(ts, PB_DAM[i], PB_DBM[i], PB_DAE[i] + PB_DBE[i])
        } } } }
        i = i + 1u64
    }
    PB_EXS = kr_sign()
    return PB_EXS
}

/* ==================== THE EXACT KRISIS AT THE REAL HEAD SCALE (896-bit) =======
 * The head hidden is a 14-limb (896-bit) dyadic per dimension.  These carry it
 * into the EXACT tier: a bigint built from all 14 limbs (Horner), dotted with the
 * head rows in UNBOUNDED bigint -- the argmax decided with ZERO truncation, at
 * R1's real head width.  This is the exact krisis onto the real head values. */
var PB_HAM : [u64; 2688]                  /* hidden a: 192 dims * 14 limbs */
var PB_HAE : [i64; 192]                   /* hidden a: exponent per dim */
var PB_HAS : [i64; 192]                   /* hidden a: sign per dim */
fn pb_set_h14_limb(i: u64, k: u64, v: u64) -> i32 {
    if i >= 192u64 { return 1i32 }
    if k >= 14u64 { return 1i32 }
    PB_HAM[i * 14u64 + k] = v
    return 0i32
}
fn pb_set_h14(i: u64, s: i64, e: i64) -> i32 {
    if i >= 192u64 { return 1i32 }
    PB_HAS[i] = s   PB_HAE[i] = e
    return 0i32
}
/* build a bigint from the 14 little-endian limbs of hidden dim (base = i*14) */
fn pb_bi_from14(ar: u64, base: u64) -> u64 {
    let mut acc : u64 = bigint_from_u64(ar, PB_HAM[base + 13u64])
    let mut k : u64 = 13u64
    while k > 0u64 {
        k = k - 1u64
        let sh : u64 = bigint_shl_bits(ar, acc, 64u64)
        bigint_drop(acc)
        let lb : u64 = bigint_from_u64(ar, PB_HAM[base + k])
        let na : u64 = bigint_add(ar, sh, lb)
        bigint_drop(sh)   bigint_drop(lb)
        acc = na
    }
    return acc
}
/* exact sign of sum_i (hidden14_i * weight_i), weight = PB_DBM (64-bit): the
 * head logit difference decided EXACTLY over a 896-bit hidden.  A THIN CLIENT
 * of the numera krisis kernel: each live dim opens one 14-limb term
 * (sign = s_h*s_w, scal = weight mantissa, exponent = e_h + e_w).  -1/0/+1 in PB_EXS. */
fn pb_exact_dot14_sign(n: u64) -> i64 @export {
    if n > 192u64 { return 0i64 - 2i64 }
    kr_begin()
    let mut i : u64 = 0u64
    while i < n {
        if PB_HAS[i] != 0i64 { if PB_DBM[i] != 0u64 { if PB_DBS[i] != 0i64 {
            let mut ts : i64 = 1i64
            if PB_HAS[i] != PB_DBS[i] { ts = 0i64 - 1i64 }
            kr_term_open(ts, PB_DBM[i], PB_HAE[i] + PB_DBE[i])
            let mut k : u64 = 0u64
            while k < 14u64 {
                kr_term_limb(k, PB_HAM[i * 14u64 + k])
                k = k + 1u64
            }
        } } }
        i = i + 1u64
    }
    PB_EXS = kr_sign()
    return PB_EXS
}

/* ============ THE EXACT KRISIS ON THE REAL 7168-DIM R1 HEAD ==================
 * The scale-up from the 192-dim proof to R1's real head, on real values.  After
 * a walk, MB_DTM holds the real 896-bit RMSNorm'd hidden (7168 dims); mb_head_diff
 * has loaded the podium's weight difference d_i = W_ta,i - W_tb,i.  This decides
 * l_ta - l_tb = sum_i d_i * X_i EXACTLY in unbounded bigint -- the SAME algorithm
 * proven at 192 dims (pb_exact_dot14_sign, arm 20), now reading the real hidden
 * (mb_dz_x_l/s/e) and the real weight difference (mb_hdiff_at) directly, sized to
 * 7168.  No 192-cap buffers: each dim's hidden mantissa is built from its 14 limbs
 * on the fly, so the handle table never holds more than the two accumulators plus
 * one term.  Result in PB_EXS: +1 = ta genuinely wins, -1 = tb actually wins
 * (the head truncation was flipping it), 0 = a true exact tie.  This is the
 * head's contribution to the argmax decided with ZERO width -- the 2^12663 the
 * float ledger charged was truncation, and here there is none. */
var PB_RH_LIVE : u64 = 0u64                 /* live (both-nonzero) dims counted */
fn pb_rh_live() -> u64 @export { return PB_RH_LIVE }
fn pb_real_head_krisis(n: u64) -> i64 @export {
    if n > 7168u64 { return 0i64 - 2i64 }
    /* a THIN CLIENT of the numera krisis kernel: each live dim opens one 14-limb
     * term (sign = s_x * sign(d), scal = |d|, exponent = the hidden's).  The
     * weight's common 2^-24 scale drops out of the sign, so the term exponent is
     * just the hidden exponent. */
    kr_begin()
    let mut i : u64 = 0u64
    while i < n {
        let xs : i64 = mb_dz_x_s(i)
        if xs != 0i64 {
            let d : i64 = mb_hdiff_at(i)
            if d != 0i64 {
                let mut ad : u64 = d as u64
                if d < 0i64 { ad = (0i64 - d) as u64 }
                let mut ts : i64 = 1i64
                if d < 0i64 { ts = 0i64 - ts }
                if xs < 0i64 { ts = 0i64 - ts }
                kr_term_open(ts, ad, mb_dz_x_e(i))
                let mut k : u64 = 0u64
                while k < 14u64 {
                    kr_term_limb(k, mb_dz_x_l(i, k))
                    k = k + 1u64
                }
            }
        }
        i = i + 1u64
    }
    PB_EXS = kr_sign()
    PB_RH_LIVE = kr_live()
    return PB_EXS
}

/* ============ ENGINE B: the SEPARATE-LOGITS order (the second, independent engine) ==
 * No thing certifies itself.  Engine A (pb_exact_dot14_sign / pb_real_head_krisis)
 * decides sign(l_W - l_L) by summing the DIFFERENCE d_i = w_W,i - w_L,i into ONE pos/neg
 * pair.  Engine B decides the SAME order by a DIFFERENT computation: it accumulates the
 * two logits l_W = Σ w_W,i X_i and l_L = Σ w_L,i X_i SEPARATELY, then compares.  Distinct
 * intermediate bigints, distinct sign/alignment paths in the dot -- a real differential
 * oracle on the order (the hidden-mantissa construction is shared and separately proven;
 * the DDC is on the dot, which is the new code).  The trusted verdict stands ONLY where A
 * and B AGREE; disagreement REFUSES (fail-closed) rather than certify a lie. */
var PB_WA : [i64; 192]                     /* winner-row weight mantissa (common exp drops) */
var PB_WB : [i64; 192]                     /* loser-row  weight mantissa                    */
var PB_EXS2 : i64 = 0i64                   /* engine B result                               */
fn pb_set_wa(i: u64, v: i64) -> i32 { if i >= 192u64 { return 1i32 }   PB_WA[i] = v   return 0i32 }
fn pb_set_wb(i: u64, v: i64) -> i32 { if i >= 192u64 { return 1i32 }   PB_WB[i] = v   return 0i32 }
fn pb_two_logit_order(n: u64) -> i64 @export {
    if n > 192u64 { return 0i64 - 2i64 }
    let ar : u64 = arena_new(2097152u64)
    if ar == 0u64 { return 0i64 - 2i64 }
    let mut emin : i64 = 1000000i64
    let mut i : u64 = 0u64
    while i < n {
        if PB_HAS[i] != 0i64 {
            let mut nz : u64 = 0u64
            if PB_WA[i] != 0i64 { nz = 1u64 }
            if PB_WB[i] != 0i64 { nz = 1u64 }
            if nz == 1u64 { if PB_HAE[i] < emin { emin = PB_HAE[i] } }
        }
        i = i + 1u64
    }
    if emin == 1000000i64 { bigint_drop_arena(ar)   arena_drop(ar)   PB_EXS2 = 0i64   return 0i64 }
    let mut posW : u64 = bigint_from_u64(ar, 0u64)
    let mut negW : u64 = bigint_from_u64(ar, 0u64)
    let mut posL : u64 = bigint_from_u64(ar, 0u64)
    let mut negL : u64 = bigint_from_u64(ar, 0u64)
    i = 0u64
    while i < n {
        let xs : i64 = PB_HAS[i]
        if xs != 0i64 {
            let wa : i64 = PB_WA[i]
            let wb : i64 = PB_WB[i]
            let mut nz : u64 = 0u64
            if wa != 0i64 { nz = 1u64 }
            if wb != 0i64 { nz = 1u64 }
            if nz == 1u64 {
                let hb : u64 = pb_bi_from14(ar, i * 14u64)
                let sh : u64 = (PB_HAE[i] - emin) as u64
                if wa != 0i64 {
                    let mut aw : u64 = wa as u64
                    if wa < 0i64 { aw = (0i64 - wa) as u64 }
                    let prod : u64 = bigint_mul_u64(ar, hb, aw)
                    let shifted : u64 = bigint_shl_bits(ar, prod, sh)
                    let mut ts : i64 = 1i64
                    if wa < 0i64 { ts = 0i64 - ts }
                    if xs < 0i64 { ts = 0i64 - ts }
                    if ts > 0i64 { let np : u64 = bigint_add(ar, posW, shifted)   bigint_drop(posW)   posW = np }
                    if ts < 0i64 { let nn : u64 = bigint_add(ar, negW, shifted)   bigint_drop(negW)   negW = nn }
                    bigint_drop(shifted)   bigint_drop(prod)
                }
                if wb != 0i64 {
                    let mut bw : u64 = wb as u64
                    if wb < 0i64 { bw = (0i64 - wb) as u64 }
                    let prod2 : u64 = bigint_mul_u64(ar, hb, bw)
                    let shifted2 : u64 = bigint_shl_bits(ar, prod2, sh)
                    let mut ts2 : i64 = 1i64
                    if wb < 0i64 { ts2 = 0i64 - ts2 }
                    if xs < 0i64 { ts2 = 0i64 - ts2 }
                    if ts2 > 0i64 { let np2 : u64 = bigint_add(ar, posL, shifted2)   bigint_drop(posL)   posL = np2 }
                    if ts2 < 0i64 { let nn2 : u64 = bigint_add(ar, negL, shifted2)   bigint_drop(negL)   negL = nn2 }
                    bigint_drop(shifted2)   bigint_drop(prod2)
                }
                bigint_drop(hb)
            }
        }
        i = i + 1u64
    }
    /* l_W - l_L = (posW - negW) - (posL - negL) = (posW + negL) - (negW + posL) */
    let pp : u64 = bigint_add(ar, posW, negL)
    let qq : u64 = bigint_add(ar, negW, posL)
    let c : i32 = bigint_cmp(pp, qq)
    PB_EXS2 = 0i64
    if c > 0i32 { PB_EXS2 = 1i64 }
    if c < 0i32 { PB_EXS2 = 0i64 - 1i64 }
    bigint_drop_arena(ar)   arena_drop(ar)
    return PB_EXS2
}
/* engine B on the REAL head: hidden from mb_dz_x_*, the two contested rows from
 * mb_hrowa_at/mb_hrowb_at.  Separate-logits, independent of pb_real_head_krisis. */
fn pb_real_head_order_sep(n: u64) -> i64 @export {
    if n > 7168u64 { return 0i64 - 2i64 }
    let ar : u64 = arena_new(134217728u64)
    if ar == 0u64 { return 0i64 - 2i64 }
    let mut emin : i64 = 1000000i64
    let mut i : u64 = 0u64
    while i < n {
        if mb_dz_x_s(i) != 0i64 {
            let mut nz : u64 = 0u64
            if mb_hrowa_at(i) != 0i64 { nz = 1u64 }
            if mb_hrowb_at(i) != 0i64 { nz = 1u64 }
            if nz == 1u64 { let e : i64 = mb_dz_x_e(i)   if e < emin { emin = e } }
        }
        i = i + 1u64
    }
    if emin == 1000000i64 { bigint_drop_arena(ar)   arena_drop(ar)   PB_EXS2 = 0i64   return 0i64 }
    let mut posW : u64 = bigint_from_u64(ar, 0u64)
    let mut negW : u64 = bigint_from_u64(ar, 0u64)
    let mut posL : u64 = bigint_from_u64(ar, 0u64)
    let mut negL : u64 = bigint_from_u64(ar, 0u64)
    i = 0u64
    while i < n {
        let xs : i64 = mb_dz_x_s(i)
        if xs != 0i64 {
            let wa : i64 = mb_hrowa_at(i)
            let wb : i64 = mb_hrowb_at(i)
            let mut nz : u64 = 0u64
            if wa != 0i64 { nz = 1u64 }
            if wb != 0i64 { nz = 1u64 }
            if nz == 1u64 {
                let mut acc : u64 = bigint_from_u64(ar, mb_dz_x_l(i, 13u64))
                let mut k : u64 = 13u64
                while k > 0u64 {
                    k = k - 1u64
                    let s0 : u64 = bigint_shl_bits(ar, acc, 64u64)
                    bigint_drop(acc)
                    let lb : u64 = bigint_from_u64(ar, mb_dz_x_l(i, k))
                    let na : u64 = bigint_add(ar, s0, lb)
                    bigint_drop(s0)   bigint_drop(lb)
                    acc = na
                }
                let sh : u64 = (mb_dz_x_e(i) - emin) as u64
                if wa != 0i64 {
                    let mut aw : u64 = wa as u64
                    if wa < 0i64 { aw = (0i64 - wa) as u64 }
                    let prod : u64 = bigint_mul_u64(ar, acc, aw)
                    let shifted : u64 = bigint_shl_bits(ar, prod, sh)
                    let mut ts : i64 = 1i64
                    if wa < 0i64 { ts = 0i64 - ts }
                    if xs < 0i64 { ts = 0i64 - ts }
                    if ts > 0i64 { let np : u64 = bigint_add(ar, posW, shifted)   bigint_drop(posW)   posW = np }
                    if ts < 0i64 { let nn : u64 = bigint_add(ar, negW, shifted)   bigint_drop(negW)   negW = nn }
                    bigint_drop(shifted)   bigint_drop(prod)
                }
                if wb != 0i64 {
                    let mut bw : u64 = wb as u64
                    if wb < 0i64 { bw = (0i64 - wb) as u64 }
                    let prod2 : u64 = bigint_mul_u64(ar, acc, bw)
                    let shifted2 : u64 = bigint_shl_bits(ar, prod2, sh)
                    let mut ts2 : i64 = 1i64
                    if wb < 0i64 { ts2 = 0i64 - ts2 }
                    if xs < 0i64 { ts2 = 0i64 - ts2 }
                    if ts2 > 0i64 { let np2 : u64 = bigint_add(ar, posL, shifted2)   bigint_drop(posL)   posL = np2 }
                    if ts2 < 0i64 { let nn2 : u64 = bigint_add(ar, negL, shifted2)   bigint_drop(negL)   negL = nn2 }
                    bigint_drop(shifted2)   bigint_drop(prod2)
                }
                bigint_drop(acc)
            }
        }
        i = i + 1u64
    }
    let pp : u64 = bigint_add(ar, posW, negL)
    let qq : u64 = bigint_add(ar, negW, posL)
    let c : i32 = bigint_cmp(pp, qq)
    PB_EXS2 = 0i64
    if c > 0i32 { PB_EXS2 = 1i64 }
    if c < 0i32 { PB_EXS2 = 0i64 - 1i64 }
    bigint_drop_arena(ar)   arena_drop(ar)
    return PB_EXS2
}
/* THE TRUSTED VERDICT (no self-grading): the order stands ONLY where the two independent
 * engines agree.  -1000 = REFUSED (engines disagree -- one is lying; certify nothing). */
fn pb_head_order_trusted(n: u64) -> i64 @export {
    let sa : i64 = pb_real_head_krisis(n)
    let sb : i64 = pb_real_head_order_sep(n)
    if sa == sb { return sa }
    return 0i64 - 1000i64
}
fn pb_head_order_trusted_inj(n: u64) -> i64 @export {
    let sa : i64 = pb_exact_dot14_sign(n)
    let sb : i64 = pb_two_logit_order(n)
    if sa == sb { return sa }
    return 0i64 - 1000i64
}
/* inject one hidden dim (zero its 14 limbs, set one limb + sign + exp) for the pure gate */
fn pb_inj_x(i: u64, s: i64, e: i64, lk: u64, lv: u64) -> i32 {
    if i >= 192u64 { return 1i32 }
    let mut k : u64 = 0u64
    while k < 14u64 { PB_HAM[i * 14u64 + k] = 0u64   k = k + 1u64 }
    if lk < 14u64 { PB_HAM[i * 14u64 + lk] = lv }
    PB_HAS[i] = s   PB_HAE[i] = e
    return 0i32
}

/* THE RMSNORM SQRT, EXACT.  RMSNorm's 1/sqrt(mean(h^2)+eps) has an ALGEBRAIC
 * sqrt -- no transcendental, no truncation width.  bigint_isqrt gives the EXACT
 * floor(sqrt(N)); [floor, floor+1] is the tight sqrt bracket that propagates
 * through the layer (and contracts the hidden's width -- the layer's own
 * re-normalization).  This is the layer piece the exact-order pass needs on the
 * way back from the head. */
fn pb_exact_sqrt_check() -> u64 {
    let ar : u64 = arena_new(65536u64)
    if ar == 0u64 { return 1u64 }
    let mut rc : u64 = 0u64
    let four : u64 = bigint_from_u64(ar, 4u64)
    let r4 : u64 = bigint_isqrt(ar, four)
    let two : u64 = bigint_from_u64(ar, 2u64)
    if bigint_cmp(r4, two) != 0i32 { rc = 1u64 }        /* sqrt(4) = 2 EXACT */
    let nine : u64 = bigint_from_u64(ar, 9u64)
    let r9 : u64 = bigint_isqrt(ar, nine)
    let three : u64 = bigint_from_u64(ar, 3u64)
    if bigint_cmp(r9, three) != 0i32 { rc = 2u64 }      /* sqrt(9) = 3 EXACT */
    let twn : u64 = bigint_from_u64(ar, 2u64)
    let r2 : u64 = bigint_isqrt(ar, twn)
    let one : u64 = bigint_from_u64(ar, 1u64)
    if bigint_cmp(r2, one) != 0i32 { rc = 3u64 }        /* floor(sqrt(2)) = 1; bracket [1,2], 1<=2<4 */
    bigint_drop_arena(ar)   arena_drop(ar)
    return rc
}

/* THE EXP, the ONLY transcendental, TIGHTLY BRACKETED.  exp (in SiLU and the
 * attention softmax) is the sole non-algebraic operation -- it cannot be exact,
 * but III's exp ladder brackets it lo/hi to the working precision, and that
 * TINY bracket is the ONLY width the exact-order pass carries (RMSNorm then
 * contracts it).  So: matmul EXACT (bigint), RMSNorm sqrt EXACT (algebraic),
 * exp TIGHT -- the argmax decided by an order whose only slack is a bracket
 * hundreds of bits below the gap.  That is why the UNDECIDED was never real. */
fn pb_exact_exp_check() -> u64 {
    pr_x_exp_s(0u64, 0i64, 1i64, 0u64)                  /* exp(0) = 1 exactly */
    if pr_x_dfcmp(pr_x_dfm(), pr_x_dfe(), 1u64 << 63u64, 0i64 - 63i64) != 0i64 { return 1u64 }
    pr_x_exp_s(1u64 << 63u64, 0i64 - 63i64, 1i64, 0u64) /* exp(1) rounded DOWN (lo) */
    let lom : u64 = pr_x_dfm()
    let loe : i64 = pr_x_dfe()
    pr_x_exp_s(1u64 << 63u64, 0i64 - 63i64, 1i64, 1u64) /* exp(1) rounded UP (hi) */
    let him : u64 = pr_x_dfm()
    let hie : i64 = pr_x_dfe()
    if pr_x_dfcmp(lom, loe, him, hie) > 0i64 { return 2u64 }        /* lo <= hi: a valid bracket */
    pr_x_dfn2(0u64, 2u64, 0i64, 0u64)
    if pr_x_dfcmp(lom, loe, pr_x_dfm(), pr_x_dfe()) <= 0i64 { return 3u64 }   /* e > 2 */
    pr_x_dfn2(0u64, 3u64, 0i64, 0u64)
    if pr_x_dfcmp(him, hie, pr_x_dfm(), pr_x_dfe()) >= 0i64 { return 4u64 }   /* e < 3 */
    return 0u64
}

/* ==================== THE INTEGRATION: an EXACT-ORDER FORWARD PASS ===========
 * The atoms chained: a hidden value flows THROUGH a layer (matvec that nearly
 * cancels) into the NEXT layer and out to the head argmax -- carried in EXACT
 * bigint the whole way.  The residue that decides the token survives every layer
 * because nothing truncates.  The fixed float twin loses that residue at layer 1
 * and ties.  This is the exact reasoner end to end (at demo scale; the real R1
 * pass is the same engine over a serialized bigint hidden, dim by dim). */
fn pb_exact_2layer_demo() -> i64 @export {
    let ar : u64 = arena_new(1048576u64)
    if ar == 0u64 { return 0i64 - 9i64 }
    /* LAYER 1 matvec: h'0 = 2^500 + 1 - 2^500 = 1  (order: big, +small, -big --
     * the small term added while the big one dominates, then cancelled).  The
     * residue 1 SURVIVES because bigint never truncates. */
    let a : u64 = bigint_shl_bits(ar, bigint_from_u64(ar, 1u64), 500u64)
    let ap1 : u64 = bigint_add(ar, a, bigint_from_u64(ar, 1u64))
    let hp0 : u64 = bigint_sub(ar, ap1, a)
    /* LAYER 2 matvec: h''0 = 3 * h'0 -- the surviving residue PROPAGATES. */
    let hpp0 : u64 = bigint_mul_u64(ar, hp0, 3u64)
    /* HEAD argmax: token A iff h''0 > 0. */
    let zero : u64 = bigint_from_u64(ar, 0u64)
    let c : i32 = bigint_cmp(hpp0, zero)
    bigint_drop_arena(ar)   arena_drop(ar)
    if c > 0i32 { return 0i64 }        /* token A (exact: 3 > 0) */
    if c < 0i32 { return 1i64 }
    return 0i64 - 1i64
}
/* the SAME forward pass in the fixed 64-bit float tier: the +1 is lost at layer
 * 1's near-cancellation, so h'0 = 0, h''0 = 0, and the head TIES (-1). */
fn pb_fixed_2layer_demo() -> i64 @export {
    pr_x_dfn2(0u64, 1u64, 500i64, 0u64)
    let am : u64 = pr_x_dfm()
    let ae : i64 = pr_x_dfe()
    pr_x_dfn2(0u64, 1u64, 0i64, 0u64)
    let om : u64 = pr_x_dfm()
    let oe : i64 = pr_x_dfe()
    pr_x_dfadd(am, ae, om, oe, 0u64)          /* 2^500 + 1 -> 2^500 (the 1 is lost) */
    let sm : u64 = pr_x_dfm()
    let se : i64 = pr_x_dfe()
    pr_x_dfsub(sm, se, am, ae, 0u64)          /* 2^500 - 2^500 = 0 -> h'0 = 0 */
    if pr_x_dfm() == 0u64 { return 0i64 - 1i64 }   /* TIE: the residue that chose the token is gone */
    return 0i64
}

/* THE CONDITION OF MOTION (pure, no Feast): the mixing core proven exact on
 * synthetic scores/values.  0 = green; a nonzero arm code names the failure. */
fn pb_attn_selfprove() -> u64 @export {
    /* arm 1: ONE position -> a positive weight, output carries its value. */
    pb_attn_set_score(0u64, 1i64, 5u64)
    pb_attn_set_v(0u64, 0u64, 1i64, 7u64)
    if pb_attn_softmax(1u64) != 0u64 { return 1u64 }
    if PB_ATWM[0] == 0u64 { return 2u64 }
    if pb_attn_wv(1u64, 1u64) != 0u64 { return 3u64 }
    if PB_ATOS[0] != 1i64 { return 4u64 }
    if PB_ATOM[0] == 0u64 { return 5u64 }

    /* arm 2: TWO EQUAL scores -> EQUAL weights (softmax symmetry, EXACT). */
    pb_attn_set_score(0u64, 1i64, 3u64)
    pb_attn_set_score(1u64, 1i64, 3u64)
    pb_attn_set_v(0u64, 0u64, 1i64, 2u64)
    pb_attn_set_v(1u64, 0u64, 1i64, 6u64)
    if pb_attn_softmax(2u64) != 0u64 { return 6u64 }
    if pr_x_dfcmp(PB_ATWM[0], PB_ATWE[0], PB_ATWM[1], PB_ATWE[1]) != 0i64 { return 7u64 }
    if pb_attn_wv(2u64, 1u64) != 0u64 { return 8u64 }
    if PB_ATOS[0] != 1i64 { return 9u64 }

    /* arm 3: a DOMINANT score wins (softmax ordering); its value carries. */
    pb_attn_set_score(0u64, 1i64, 20u64)
    pb_attn_set_score(1u64, 0i64 - 1i64, 20u64)
    pb_attn_set_v(0u64, 0u64, 1i64, 9u64)
    pb_attn_set_v(1u64, 0u64, 1i64, 100u64)
    if pb_attn_softmax(2u64) != 0u64 { return 10u64 }
    if pb_df_sgt(1i64, PB_ATWM[0], PB_ATWE[0], 1i64, PB_ATWM[1], PB_ATWE[1]) != 1u64 { return 11u64 }
    if pb_attn_wv(2u64, 1u64) != 0u64 { return 12u64 }
    if PB_ATOS[0] != 1i64 { return 13u64 }

    /* arm 4: SYMMETRY -- swap which score dominates, the other wins. */
    pb_attn_set_score(0u64, 0i64 - 1i64, 20u64)
    pb_attn_set_score(1u64, 1i64, 20u64)
    if pb_attn_softmax(2u64) != 0u64 { return 14u64 }
    if pb_df_sgt(1i64, PB_ATWM[1], PB_ATWE[1], 1i64, PB_ATWM[0], PB_ATWE[0]) != 1u64 { return 15u64 }

    /* arm 16: the SCORE dot -- [2,3].[5,7] = 31, EXACT (integer inner product). */
    pb_df_set_a(0u64, 1i64, 2u64)   pb_df_set_a(1u64, 1i64, 3u64)
    pb_df_set_b(0u64, 1i64, 5u64)   pb_df_set_b(1u64, 1i64, 7u64)
    if pb_df_dot(2u64) != 0u64 { return 16u64 }
    if PB_DOTS != 1i64 { return 17u64 }
    let dotm : u64 = pr_x_dfm()
    let dote : i64 = pr_x_dfe()
    pr_x_dfn2(0u64, 31u64, 0i64, 0u64)
    if pr_x_dfcmp(dotm, dote, pr_x_dfm(), pr_x_dfe()) != 0i64 { return 18u64 }

    /* arm 17: an ORTHOGONAL pair -- [1,-1].[1,1] = 0, EXACT cancellation. */
    pb_df_set_a(0u64, 1i64, 1u64)   pb_df_set_a(1u64, 0i64 - 1i64, 1u64)
    pb_df_set_b(0u64, 1i64, 1u64)   pb_df_set_b(1u64, 1i64, 1u64)
    if pb_df_dot(2u64) != 0u64 { return 19u64 }
    if PB_DOTS != 0i64 { return 20u64 }

    /* arm 18: THE EXACT KRISIS refutes the numerical UNDECIDED.  The SAME
     * near-cancellation the fixed float tier calls a TIE (0 -- exactly how R1's
     * argmax reads "undecided"), III's EXACT bigint DECIDES (sign +1).  The
     * order was always there; only truncation hid it.  Not a concession -- a
     * refutation, in III's own exact arithmetic. */
    if pb_fixed_cancel_sign() != 0i64 { return 21u64 }
    if pb_exact_cancel_sign() != 1i64 { return 22u64 }

    /* arm 19: THE EXACT DOT over a whole vector -- terms 2^100, 2^30, -2^100.
     * The fixed 64-bit dot TIES (0: the 2^30 falls below the ulp); the exact
     * bigint dot DECIDES (+1: the 2^30 survives).  This is the head logit
     * difference certified exactly -- the argmax as an ORDER, decided. */
    pb_df_set_a_me(0u64, 1i64, 1u64 << 63u64, 37i64)
    pb_df_set_b_me(0u64, 1i64, 1u64 << 63u64, 0i64 - 63i64)
    pb_df_set_a_me(1u64, 1i64, 1u64 << 63u64, 0i64 - 63i64)
    pb_df_set_b_me(1u64, 1i64, 1u64 << 63u64, 0i64 - 33i64)
    pb_df_set_a_me(2u64, 0i64 - 1i64, 1u64 << 63u64, 37i64)
    pb_df_set_b_me(2u64, 1i64, 1u64 << 63u64, 0i64 - 63i64)
    if pb_df_dot(3u64) != 0u64 { return 23u64 }
    if PB_DOTS != 0i64 { return 24u64 }
    if pb_exact_dot_sign(3u64) != 1i64 { return 25u64 }

    /* arm 20: THE EXACT KRISIS AT 896-BIT HEAD SCALE.  hidden = [2^1000, 1,
     * -2^1000] as 14-limb dyadics, weights +1.  The +1 sits 1000 bits below
     * 2^1000 -- beyond the 896-bit mantissa the FLOAT head carries, so a
     * truncated head ties (0); the exact bigint keeps it -> +1.  R1's argmax
     * on real head values, decided exactly. */
    let mut z : u64 = 0u64
    while z < 42u64 { PB_HAM[z] = 0u64   z = z + 1u64 }
    PB_HAM[13u64] = 1u64 << 63u64
    pb_set_h14(0u64, 1i64, 105i64)
    PB_HAM[27u64] = 1u64 << 63u64
    pb_set_h14(1u64, 1i64, 0i64 - 895i64)
    PB_HAM[41u64] = 1u64 << 63u64
    pb_set_h14(2u64, 0i64 - 1i64, 105i64)
    pb_df_set_b_me(0u64, 1i64, 1u64 << 63u64, 0i64 - 63i64)
    pb_df_set_b_me(1u64, 1i64, 1u64 << 63u64, 0i64 - 63i64)
    pb_df_set_b_me(2u64, 1i64, 1u64 << 63u64, 0i64 - 63i64)
    if pb_exact_dot14_sign(3u64) != 1i64 { return 26u64 }

    /* arm 21: THE RMSNORM SQRT is EXACT (algebraic) -- sqrt(4)=2, sqrt(9)=3,
     * floor(sqrt(2))=1.  The layer's own normalization, with zero truncation
     * width -- the exact-order discipline pushed back into the layers. */
    if pb_exact_sqrt_check() != 0u64 { return 27u64 }

    /* arm 22: THE EXP (the ONLY transcendental) is TIGHTLY BRACKETED -- exp(0)=1
     * exact, exp(1) in (2,3) with a valid lo<=hi bracket.  matmul EXACT + sqrt
     * EXACT + exp TIGHT = the whole layer's slack is one small bracket, hundreds
     * of bits below the gap.  The exact-order forward pass, atom by atom. */
    if pb_exact_exp_check() != 0u64 { return 28u64 }

    /* arm 23: THE INTEGRATION -- a 2-layer exact-order forward pass DECIDES the
     * token (A = 0); the SAME pass in the fixed float tier TIES (-1).  The residue
     * that chose the token survives every layer in bigint and vanishes in float.
     * The exact reasoner, end to end. */
    if pb_exact_2layer_demo() != 0i64 { return 29u64 }
    if pb_fixed_2layer_demo() != (0i64 - 1i64) { return 30u64 }

    /* arms 31-33: THE TWO-ENGINE ORDER (no self-grading).  A decidable order decided by
     * the difference-sum engine (A) AND the separate-logits engine (B); they AGREE. */
    pb_inj_x(0u64, 1i64, 0i64, 13u64, 9223372036854775808u64)   /* X_0 = +2^895 > 0 */
    pb_set_wa(0u64, 5i64)   pb_set_wb(0u64, 3i64)               /* l_W = 5X, l_L = 3X */
    pb_df_set_b_me(0u64, 1i64, 2u64, 0i64)                       /* engine A diff d_0 = +2 */
    if pb_exact_dot14_sign(1u64) != 1i64 { return 31u64 }        /* engine A: +1 */
    if pb_two_logit_order(1u64) != 1i64 { return 32u64 }         /* engine B: +1 */
    if pb_head_order_trusted_inj(1u64) != 1i64 { return 33u64 }  /* agree -> +1 */

    /* arms 34-37: THE NEAR-TIE, RED->GREEN.  The float tier TIES on 2^100+2^30-2^100
     * (RED, arm 34); BOTH exact engines decide +1 and AGREE (GREEN) -- the refutation
     * proven by two independent engines, not one grading itself. */
    pb_inj_x(0u64, 1i64, 0i64, 1u64, 68719476736u64)            /* X_0 = 2^100 */
    pb_inj_x(1u64, 1i64, 0i64, 0u64, 1073741824u64)             /* X_1 = 2^30  */
    pb_inj_x(2u64, 1i64, 0i64, 1u64, 68719476736u64)            /* X_2 = 2^100 */
    pb_df_set_b_me(0u64, 1i64, 1u64, 0i64)                       /* d_0 = +1 */
    pb_df_set_b_me(1u64, 1i64, 1u64, 0i64)                       /* d_1 = +1 */
    pb_df_set_b_me(2u64, 0i64 - 1i64, 1u64, 0i64)               /* d_2 = -1 */
    pb_set_wa(0u64, 1i64)   pb_set_wb(0u64, 0i64)               /* l_W = X_0 + X_1 */
    pb_set_wa(1u64, 1i64)   pb_set_wb(1u64, 0i64)
    pb_set_wa(2u64, 0i64)   pb_set_wb(2u64, 1i64)               /* l_L = X_2 */
    if pb_fixed_cancel_sign() != 0i64 { return 34u64 }           /* RED: float ties (=0) */
    if pb_exact_dot14_sign(3u64) != 1i64 { return 35u64 }        /* engine A: +1 */
    if pb_two_logit_order(3u64) != 1i64 { return 36u64 }         /* engine B: +1 */
    if pb_head_order_trusted_inj(3u64) != 1i64 { return 37u64 }  /* agree -> +1 */

    /* arm 38: THE LYING ENGINE, CAUGHT (mandatory negative).  Forge engine A's d_0 sign
     * so A computes the WRONG order (-1); engine B (true rows) still says +1; the trusted
     * verdict REFUSES (-1000) rather than certify a lie.  Disagreement is caught. */
    pb_df_set_b_me(0u64, 0i64 - 1i64, 1u64, 0i64)               /* FORGE d_0 sign */
    if pb_head_order_trusted_inj(3u64) != (0i64 - 1000i64) { return 38u64 }  /* MUST refuse */
    pb_df_set_b_me(0u64, 1i64, 1u64, 0i64)                       /* restore */
    return 0u64
}

/* MoE accumulate: M += w (S1, positive) * out[i], i < 7168 */
fn pb_dz_moe_acc() -> u64 {
    let mut i : u64 = 0u64
    while i < 7168u64 {
        let os : i64 = mb_dz_o_s(i)
        if os != 0i64 {
            pb_a_from_o(i)
            let mut k : u64 = 0u64
            while k < 14u64 {
                pr_bn_setb(k, PB_S1M[k])
                k = k + 1u64
            }
            pr_bn_sete_b(PB_S1E)
            if pr_bn_x_mul(0u64) != 0u64 { return 1u64 }
            let ms : i64 = PB_DMS[i]
            if ms == 0i64 {
                pb_buf_from_r(3u64, i, os)
            }
            if ms != 0i64 {
                pr_bn_r_to_b()
                pb_a_from_buf(3u64, i)
                if ms == os {
                    if pr_bn_x_add(0u64) != 0u64 { return 1u64 }
                    pb_buf_from_r(3u64, i, ms)
                }
                if ms != os {
                    let c : i64 = pr_bn_cmp()
                    if c > 0i64 {
                        if pr_bn_x_sub(0u64) != 0u64 { return 1u64 }
                        pb_buf_from_r(3u64, i, ms)
                    }
                    if c == 0i64 {
                        let mut k2 : u64 = 0u64
                        while k2 < 14u64 {
                            PB_DMM[i * 14u64 + k2] = 0u64
                            k2 = k2 + 1u64
                        }
                        PB_DMS[i] = 0i64
                        PB_DME[i] = 0i64
                    }
                    if c < 0i64 {
                        pr_bn_r_to_a()
                        pb_b_from_buf(3u64, i)
                        if pr_bn_x_sub(0u64) != 0u64 { return 1u64 }
                        pb_buf_from_r(3u64, i, os)
                    }
                }
            }
        }
        i = i + 1u64
    }
    return 0u64
}

/* one deep expert FFN over the standing H: acc-ready out */
fn pb_dz_expert(e: u64, shared: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < 7168u64 {
        pb_x_from_buf(1u64, i)
        i = i + 1u64
    }
    mb_dz_mark(7168u64)
    let mut r0 : u64 = 0u64
    if shared == 1u64 { r0 = mb_dz_run_exp(3u64, 0u64, 7168u64, 2048u64) }
    if shared == 0u64 { r0 = mb_dz_run_exp(0u64, e, 7168u64, 2048u64) }
    if r0 != 0u64 { return 1u64 }
    pb_wled_fold()
    i = 0u64
    while i < 2048u64 {
        let base : u64 = i * 14u64
        let mut k : u64 = 0u64
        while k < 14u64 {
            PB_DGM[base + k] = mb_dz_o_l(i, k)
            k = k + 1u64
        }
        PB_DGS[i] = mb_dz_o_s(i)
        PB_DGE[i] = mb_dz_o_e(i)
        i = i + 1u64
    }
    let mut r1 : u64 = 0u64
    if shared == 1u64 { r1 = mb_dz_run_exp(4u64, 0u64, 7168u64, 2048u64) }
    if shared == 0u64 { r1 = mb_dz_run_exp(1u64, e, 7168u64, 2048u64) }
    if r1 != 0u64 { return 1u64 }
    pb_wled_fold()
    let mut j : u64 = 0u64
    while j < 2048u64 {
        let gs : i64 = PB_DGS[j]
        let us : i64 = mb_dz_o_s(j)
        let mut done2 : u64 = 0u64
        if gs == 0i64 {
            pb_x_zero(j)
            done2 = 1u64
        }
        if done2 == 0u64 {
            if us == 0i64 {
                pb_x_zero(j)
                done2 = 1u64
            }
        }
        if done2 == 0u64 {
            pb_a_from_buf(2u64, j)
            if pb_dz_sigma_deep(gs) != 0u64 { return 1u64 }
            if pr_bn_rz() == 1u64 { pb_x_zero(j) }
            if pr_bn_rz() == 0u64 {
                pr_bn_r_to_b()
                pb_a_from_buf(2u64, j)
                if pr_bn_x_mul(0u64) != 0u64 { return 1u64 }
                pr_bn_r_to_a()
                pb_b_from_o(j)
                if pr_bn_x_mul(0u64) != 0u64 { return 1u64 }
                let mut rs : i64 = gs
                if us < 0i64 { rs = 0i64 - rs }
                pb_x_from_r(j, rs)
            }
        }
        j = j + 1u64
    }
    mb_dz_mark(2048u64)
    let mut r2 : u64 = 0u64
    if shared == 1u64 { r2 = mb_dz_run_exp(5u64, 0u64, 2048u64, 7168u64) }
    if shared == 0u64 { r2 = mb_dz_run_exp(2u64, e, 2048u64, 7168u64) }
    if r2 != 0u64 { return 1u64 }
    pb_wled_fold()
    return 0u64
}

/* the deep router dot for expert e over the H buffer: the accumulated
 * deep logit lands in PB_S1 (sign in the return, 0 = zero) */
fn pb_dz_rdot() -> i64 {
    let mut accs : i64 = 0i64
    let mut i : u64 = 0u64
    while i < 7168u64 {
        let wm : i64 = mb_rw_m(i)
        if wm != 0i64 {
            if PB_DHS[i] != 0i64 {
                let mut ws : i64 = 1i64
                let mut wmm : u64 = wm as u64
                if wm < 0i64 {
                    ws = 0i64 - 1i64
                    wmm = (0i64 - wm) as u64
                }
                let mut sh : u64 = 0u64
                let mut hh : u64 = wmm
                while (hh >> 63u64) == 0u64 {
                    hh = hh << 1u64
                    sh = sh + 1u64
                }
                pb_a_from_buf(1u64, i)
                let mut k : u64 = 0u64
                while k < 14u64 {
                    pr_bn_setb(k, 0u64)
                    k = k + 1u64
                }
                pr_bn_setb(13u64, wmm << sh)
                pr_bn_sete_b(mb_rw_e(i) - 832i64 - (sh as i64))
                if pr_bn_x_mul(0u64) != 0u64 { return 100i64 }
                let mut ts : i64 = PB_DHS[i]
                if ws < 0i64 { ts = 0i64 - ts }
                if accs == 0i64 {
                    accs = ts
                    k = 0u64
                    while k < 14u64 {
                        PB_S1M[k] = pr_bn_r(k)
                        k = k + 1u64
                    }
                    PB_S1E = pr_bn_re()
                }
                if accs != 0i64 {
                    if accs == ts {
                        pr_bn_r_to_b()
                        k = 0u64
                        while k < 14u64 {
                            pr_bn_seta(k, PB_S1M[k])
                            k = k + 1u64
                        }
                        pr_bn_sete_a(PB_S1E)
                        if pr_bn_x_add(0u64) != 0u64 { return 100i64 }
                        k = 0u64
                        while k < 14u64 {
                            PB_S1M[k] = pr_bn_r(k)
                            k = k + 1u64
                        }
                        PB_S1E = pr_bn_re()
                    }
                    if accs != ts {
                        pr_bn_r_to_b()
                        k = 0u64
                        while k < 14u64 {
                            pr_bn_seta(k, PB_S1M[k])
                            k = k + 1u64
                        }
                        pr_bn_sete_a(PB_S1E)
                        let c : i64 = pr_bn_cmp()
                        if c > 0i64 {
                            if pr_bn_x_sub(0u64) != 0u64 { return 100i64 }
                            k = 0u64
                            while k < 14u64 {
                                PB_S1M[k] = pr_bn_r(k)
                                k = k + 1u64
                            }
                            PB_S1E = pr_bn_re()
                        }
                        if c == 0i64 {
                            accs = 0i64
                        }
                        if c < 0i64 {
                            pr_bn_r_to_a()
                            k = 0u64
                            while k < 14u64 {
                                pr_bn_setb(k, PB_S1M[k])
                                k = k + 1u64
                            }
                            pr_bn_sete_b(PB_S1E)
                            if pr_bn_x_sub(0u64) != 0u64 { return 100i64 }
                            accs = ts
                            k = 0u64
                            while k < 14u64 {
                                PB_S1M[k] = pr_bn_r(k)
                                k = k + 1u64
                            }
                            PB_S1E = pr_bn_re()
                        }
                    }
                }
            }
        }
        i = i + 1u64
    }
    return accs
}

/* the deep MoE layer: attention, the election on deep centers, the nine
 * expert weaves, the weighted return */
fn pb_dz_layer_moe(lay: u64) -> u64 {
    if pb_dz_attn(lay) != 0u64 { return 1u64 }
    let b : u64 = lay * 12u64
    let mut i : u64 = 0u64
    while i < 7168u64 {
        pb_buf_from_x(0u64, i)
        i = i + 1u64
    }
    if pb_dz_rms(7168u64, b + 8u64, 0u64) != 0u64 { return 1u64 }
    i = 0u64
    while i < 7168u64 {
        pb_buf_from_x(1u64, i)
        i = i + 1u64
    }
    if mb_me_sel(lay) != 0u64 { return 1u64 }
    PB_BIAS_ON = 0u64
    if mb_eb_present(lay) == 1u64 {
        if mb_moe_bias_load() != 0u64 { return 1u64 }
        PB_BIAS_ON = 1u64
    }
    /* the election on deep centers: sigma(row.H) + bias, order by the
     * one-limb df keys, certification by the standing ledger */
    let mut e : u64 = 0u64
    while e < 256u64 {
        if mb_moe_router_row(e) != 0u64 { return 1u64 }
        let ls : i64 = pb_dz_rdot()
        if ls == 100i64 { return 1u64 }
        let mut k : u64 = 0u64
        while k < 14u64 {
            pr_bn_seta(k, PB_S1M[k])
            k = k + 1u64
        }
        pr_bn_sete_a(PB_S1E)
        let mut sgn : i64 = ls
        if ls == 0i64 {
            k = 0u64
            while k < 14u64 {
                pr_bn_seta(k, 0u64)
                k = k + 1u64
            }
            pr_bn_sete_a(0i64)
            sgn = 1i64
        }
        if pb_dz_sigma_deep(sgn) != 0u64 { return 1u64 }
        PB_RCS[e] = 1i64
        if PB_BIAS_ON == 1u64 {
            let bmi : i64 = mb_bs_m(e)
            if bmi != 0i64 {
                let mut bs : i64 = 1i64
                let mut mg : u64 = bmi as u64
                if bmi < 0i64 {
                    bs = 0i64 - 1i64
                    mg = (0i64 - bmi) as u64
                }
                let mut sh2 : u64 = 0u64
                let mut h2 : u64 = mg
                while (h2 >> 63u64) == 0u64 {
                    h2 = h2 << 1u64
                    sh2 = sh2 + 1u64
                }
                pr_bn_r_to_a()
                k = 0u64
                while k < 14u64 {
                    pr_bn_setb(k, 0u64)
                    k = k + 1u64
                }
                pr_bn_setb(13u64, mg << sh2)
                pr_bn_sete_b(mb_bs_e(e) - 832i64 - (sh2 as i64))
                if bs > 0i64 {
                    if pr_bn_x_add(0u64) != 0u64 { return 1u64 }
                }
                if bs < 0i64 {
                    let c2 : i64 = pr_bn_cmp()
                    if c2 >= 0i64 {
                        if pr_bn_x_sub(0u64) != 0u64 { return 1u64 }
                    }
                    if c2 < 0i64 {
                        pr_bn_r_to_b()
                        k = 0u64
                        while k < 14u64 {
                            pr_bn_seta(k, 0u64)
                            k = k + 1u64
                        }
                        pr_bn_seta(13u64, mg << sh2)
                        pr_bn_sete_a(mb_bs_e(e) - 832i64 - (sh2 as i64))
                        if pr_bn_x_sub(0u64) != 0u64 { return 1u64 }
                        PB_RCS[e] = 0i64 - 1i64
                    }
                }
            }
        }
        pr_bn_to_df(0u64)
        PB_RCM[e] = pr_x_dfm()
        PB_RCE[e] = pr_x_dfe()
        if pr_bn_rz() == 1u64 { PB_RCS[e] = 0i64 }
        e = e + 1u64
    }
    /* elect the top-8 by the (sign, m, e) df order */
    let mut used : u64 = 0u64
    while used < 256u64 {
        PB_TOPUSED[used] = 0u8
        used = used + 1u64
    }
    let mut kk : u64 = 0u64
    while kk < 8u64 {
        let mut best : u64 = 256u64
        e = 0u64
        while e < 256u64 {
            if PB_TOPUSED[e] == 0u8 {
                if best == 256u64 { best = e }
                if best != e {
                    let cb : i64 = pb_scmp(PB_RCS[e], PB_RCM[e], PB_RCE[e], PB_RCS[best], PB_RCM[best], PB_RCE[best])
                    if cb > 0i64 { best = e }
                }
            }
            e = e + 1u64
        }
        PB_TOP8[kk] = best
        PB_TOPUSED[best] = 1u8
        kk = kk + 1u64
    }
    /* the weighted return: M <- shared + Sigma w_k expert_k */
    pb_dbuf_zero(3u64, 7168u64)
    if pb_dz_expert(0u64, 1u64) != 0u64 { return 1u64 }
    PB_S1S = 1i64
    let mut k3 : u64 = 0u64
    while k3 < 14u64 {
        PB_S1M[k3] = 0u64
        k3 = k3 + 1u64
    }
    PB_S1M[13u64] = 1u64 << 63u64
    PB_S1E = 0i64 - 895i64
    if pb_dz_moe_acc() != 0u64 { return 1u64 }
    /* the weights: w_k = 2.5 * sigma_k / Sigma sigma over the eight; the
     * sigma centers recovered from the score keys (minus bias) */
    let mut smm : u64 = 0u64
    let mut sme : i64 = 0i64
    kk = 0u64
    while kk < 8u64 {
        let ee : u64 = PB_TOP8[kk]
        let mut sm2 : u64 = PB_RCM[ee]
        let mut se2 : i64 = PB_RCE[ee]
        if PB_BIAS_ON == 1u64 {
            let bmi2 : i64 = mb_bs_m(ee)
            if bmi2 != 0i64 {
                let mut mg2 : u64 = bmi2 as u64
                let mut neg2 : u64 = 0u64
                if bmi2 < 0i64 {
                    mg2 = (0i64 - bmi2) as u64
                    neg2 = 1u64
                }
                pr_x_dfn2(0u64, mg2, mb_bs_e(ee), 0u64)
                let bfm : u64 = pr_x_dfm()
                let bfe : i64 = pr_x_dfe()
                if neg2 == 0u64 {
                    pr_x_dfsub(sm2, se2, bfm, bfe, 0u64)
                    sm2 = pr_x_dfm()
                    se2 = pr_x_dfe()
                }
                if neg2 == 1u64 {
                    pr_x_dfadd(sm2, se2, bfm, bfe, 0u64)
                    sm2 = pr_x_dfm()
                    se2 = pr_x_dfe()
                }
            }
        }
        PB_SIGLM[kk] = sm2
        PB_SIGLE[kk] = se2
        pr_x_dfadd(smm, sme, sm2, se2, 0u64)
        smm = pr_x_dfm()
        sme = pr_x_dfe()
        kk = kk + 1u64
    }
    if smm == 0u64 { return 1u64 }
    pr_x_dfrecip(smm, sme, 0u64)
    let rsm : u64 = pr_x_dfm()
    let rse : i64 = pr_x_dfe()
    pr_x_dfn2(0u64, 5u64, 0i64 - 1i64, 0u64)
    let scm : u64 = pr_x_dfm()
    let sce : i64 = pr_x_dfe()
    kk = 0u64
    while kk < 8u64 {
        let ee2 : u64 = PB_TOP8[kk]
        pr_x_dfmul(PB_SIGLM[kk], PB_SIGLE[kk], rsm, rse, 0u64)
        pr_x_dfmul(pr_x_dfm(), pr_x_dfe(), scm, sce, 0u64)
        let wm3 : u64 = pr_x_dfm()
        let we3 : i64 = pr_x_dfe()
        if pb_dz_expert(ee2, 0u64) != 0u64 { return 1u64 }
        PB_S1S = 1i64
        k3 = 0u64
        while k3 < 14u64 {
            PB_S1M[k3] = 0u64
            k3 = k3 + 1u64
        }
        PB_S1M[13u64] = wm3
        PB_S1E = we3 - 832i64
        if pb_dz_moe_acc() != 0u64 { return 1u64 }
        kk = kk + 1u64
    }
    /* X'' = SV + M */
    let mut i2 : u64 = 0u64
    while i2 < 7168u64 {
        let ms2 : i64 = pb_a_from_buf(3u64, i2)
        let ss2 : i64 = pb_b_from_buf(0u64, i2)
        let mut rs2 : i64 = 0i64
        let mut d3 : u64 = 0u64
        if ms2 == ss2 {
            if ms2 != 0i64 {
                if pr_bn_x_add(0u64) != 0u64 { return 1u64 }
                rs2 = ms2
                d3 = 1u64
            }
            if ms2 == 0i64 {
                pb_x_zero(i2)
                d3 = 2u64
            }
        }
        if d3 == 0u64 {
            if ms2 == 0i64 { rs2 = pb_pass_b(ss2) }
            if ss2 == 0i64 {
                if ms2 != 0i64 { rs2 = pb_pass_a(ms2) }
            }
            if ms2 != 0i64 {
                if ss2 != 0i64 {
                    let c4 : i64 = pr_bn_cmp()
                    if c4 >= 0i64 {
                        if pr_bn_x_sub(0u64) != 0u64 { return 1u64 }
                        rs2 = ms2
                        if c4 == 0i64 { rs2 = 0i64 }
                    }
                    if c4 < 0i64 {
                        pb_a_from_buf(0u64, i2)
                        pb_b_from_buf(3u64, i2)
                        if pr_bn_x_sub(0u64) != 0u64 { return 1u64 }
                        rs2 = ss2
                    }
                }
            }
        }
        if d3 != 2u64 { pb_x_from_r(i2, rs2) }
        i2 = i2 + 1u64
    }
    mb_dz_mark(7168u64)
    return 0u64
}

/* THE WAY THROUGH: embed the first breath, walk every layer, speak */
var PB_DX_TOK : u64 = 0u64
var PB_DX_GAPE : i64 = 0i64
fn pb_diexodos(nlay: u64) -> u64 @export {
    PB_DX_OK = 0u64
    PB_WLED = 0i64 - 1000000i64
    if mb_census_only() != 0u64 { return 1u64 }
    if mb_feast() == 0u64 { return 2u64 }
    let bos : u64 = mb_dz_bos()
    if bos == (0u64 - 1u64) { return 3u64 }
    if mb_dz_embed(bos) != 0u64 { return 4u64 }
    let mut lay : u64 = 0u64
    while lay < nlay {
        if lay < 3u64 {
            let ra : u64 = pb_dz_attn(lay)
            if ra != 0u64 { return 1000u64 + ra }
            if pb_dz_ffn_dense(lay) != 0u64 { return 100u64 + lay }
        }
        if lay >= 3u64 {
            if pb_dz_layer_moe(lay) != 0u64 { return 200u64 + lay }
        }
        lay = lay + 1u64
    }
    /* the head: output_norm then the krisis sweep */
    if pb_dz_rms(7168u64, 0u64, 1u64) != 0u64 { return 5u64 }
    if mb_dz_krisis(2u64, 7168u64) != 0u64 { return 6u64 }
    pb_wled_fold()
    PB_DX_TOK = mb_kr_tok()
    /* the gap: best - second on the podium centers */
    let mut gape : i64 = 0i64 - 1000000i64
    if mb_kr_s() > mb_kr_s2() { gape = mb_kr_e() + 63i64 }
    if mb_kr_s() == mb_kr_s2() {
        if mb_kr_s() != 0i64 {
            pr_x_dfsub(mb_kr_m(), mb_kr_e(), mb_kr_m2(), mb_kr_e2(), 0u64)
            if pr_x_dfm() != 0u64 { gape = pr_x_dfe() + 63i64 }
        }
    }
    PB_DX_GAPE = gape
    PB_DX_OK = 1u64
    return 0u64
}
fn pb_dx_tok() -> u64 @export { return PB_DX_TOK }
fn pb_dx_gape() -> i64 @export { return PB_DX_GAPE }
fn pb_dx_wled() -> i64 @export { return PB_WLED }
fn pb_dx_tok2() -> u64 @export { return mb_kr_tok2() }

/* THE PROMPT-DRIVEN WAY: pb_diexodos embeds the fixed BOS breath; this twin
 * embeds an ARBITRARY token so a consumer can ASK the model "given <tok> as the
 * whole context, what comes next?"  Byte-for-byte the same certified walk +
 * krisis as pb_diexodos -- only the first breath differs.  This is the one line
 * that turned the self-proving forward pass into a callable oracle: the input was
 * never fixed by the mathematics, only by pb_diexodos's hardcoded bos.  An
 * out-of-vocab token is refused by mb_dz_embed (returns 4). */
fn pb_diexodos_tok(tok: u64, nlay: u64) -> u64 @export {
    PB_DX_OK = 0u64
    PB_WLED = 0i64 - 1000000i64
    if mb_census_only() != 0u64 { return 1u64 }
    if mb_feast() == 0u64 { return 2u64 }
    if mb_dz_embed(tok) != 0u64 { return 4u64 }
    let mut lay : u64 = 0u64
    while lay < nlay {
        if lay < 3u64 {
            let ra : u64 = pb_dz_attn(lay)
            if ra != 0u64 { return 1000u64 + ra }
            if pb_dz_ffn_dense(lay) != 0u64 { return 100u64 + lay }
        }
        if lay >= 3u64 {
            if pb_dz_layer_moe(lay) != 0u64 { return 200u64 + lay }
        }
        lay = lay + 1u64
    }
    if pb_dz_rms(7168u64, 0u64, 1u64) != 0u64 { return 5u64 }
    if mb_dz_krisis(2u64, 7168u64) != 0u64 { return 6u64 }
    pb_wled_fold()
    PB_DX_TOK = mb_kr_tok()
    let mut gape : i64 = 0i64 - 1000000i64
    if mb_kr_s() > mb_kr_s2() { gape = mb_kr_e() + 63i64 }
    if mb_kr_s() == mb_kr_s2() {
        if mb_kr_s() != 0i64 {
            pr_x_dfsub(mb_kr_m(), mb_kr_e(), mb_kr_m2(), mb_kr_e2(), 0u64)
            if pr_x_dfm() != 0u64 { gape = pr_x_dfe() + 63i64 }
        }
    }
    PB_DX_GAPE = gape
    PB_DX_OK = 1u64
    return 0u64
}

/* THE HEAD-LESS WALK: the same forward pass to the RMSNorm'd hidden, but WITHOUT
 * the 129280-row head sweep (the I/O bottleneck).  Leaves the real 896-bit hidden
 * standing in MB_DTM so an exact krisis can decide any chosen token pair's logit
 * order by reading just their two head rows -- a fast real-values exact decision
 * that never streams the whole head. */
fn pb_diexodos_nohead(tok: u64, nlay: u64) -> u64 @export {
    PB_DX_OK = 0u64
    if mb_census_only() != 0u64 { return 1u64 }
    if mb_feast() == 0u64 { return 2u64 }
    if mb_dz_embed(tok) != 0u64 { return 4u64 }
    let mut lay : u64 = 0u64
    while lay < nlay {
        if lay < 3u64 {
            let ra : u64 = pb_dz_attn(lay)
            if ra != 0u64 { return 1000u64 + ra }
            if pb_dz_ffn_dense(lay) != 0u64 { return 100u64 + lay }
        }
        if lay >= 3u64 {
            if pb_dz_layer_moe(lay) != 0u64 { return 200u64 + lay }
        }
        lay = lay + 1u64
    }
    if pb_dz_rms(7168u64, 0u64, 1u64) != 0u64 { return 5u64 }
    PB_DX_OK = 1u64
    return 0u64
}

/* ==================== THE ADAPTIVE CERTIFICATION (the eskalation) ============
 * The 896-bit walk is needed ONLY where the gap is tight.  The width ledger
 * charges LO*64 bits of fresh truncation per projection, so the SAME rigorous
 * bracket holds at every limb-floor -- and a token whose gap TOWERS over the
 * width is already PROVEN at a HIGH floor (few limbs).  Always paying LO=0 is
 * the waste the code's own comment named ("the fast tier is expected to be
 * undecided; certify at limb-floor 0").  This driver refutes that for the
 * common large-gap case: it walks cheap-first and stops at the LARGEST floor
 * where gape > wled, certifying at fast-tier speed.  The eskalation CLIMB
 * (rung 48->58) lifted to the whole forward pass: prove what you can at the
 * price you must; the certified LO0 walk is the guaranteed floor, never the
 * default.  Same verdict as LO=0 (the width bracket is rigorous at every tier);
 * only the price falls. */
var PB_CERT_LO : i64 = 0i64 - 1i64        /* the floor at which PROVEN; -1 = undecided even at 0 */
var PB_CERT_PASSES : u64 = 0u64           /* forward passes spent (1..3) */
fn pb_cert_decided() -> u64 {
    let g : i64 = PB_DX_GAPE
    let w : i64 = PB_WLED
    if g == (0i64 - 1000000i64) { return 0u64 }   /* no runner-up separation */
    if g > w { return 1u64 }
    return 0u64
}
fn pb_diexodos_certified(tok: u64, nlay: u64) -> u64 @export {
    PB_CERT_LO = 0i64 - 1i64
    PB_CERT_PASSES = 0u64
    /* PASS 1: the cheap probe (one live limb) reads the gap. */
    mb_dz_set_lo(13u64)
    let rc1 : u64 = pb_diexodos_tok(tok, nlay)
    PB_CERT_PASSES = PB_CERT_PASSES + 1u64
    if rc1 != 0u64 { return rc1 }
    if pb_cert_decided() == 1u64 { PB_CERT_LO = 13i64   return 0u64 }
    /* PREDICT the floor that proves: need oemax + LO*64 < gap ->
     * LO < (gap - oemax)/64.  The probe's gap is an estimate; the re-check at
     * `need` is rigorous, and a wrong guess falls through to the LO=0 floor. */
    let g1 : i64 = PB_DX_GAPE
    let oem : i64 = mb_dz_oemax()
    let mut need : i64 = 0i64 - 1i64
    if g1 != (0i64 - 1000000i64) {
        let diff : i64 = g1 - oem
        need = (diff / 64i64) - 1i64
    }
    if need > 12i64 { need = 12i64 }
    if need >= 0i64 {
        /* PASS 2: certify at the predicted floor. */
        mb_dz_set_lo(need as u64)
        let rc2 : u64 = pb_diexodos_tok(tok, nlay)
        PB_CERT_PASSES = PB_CERT_PASSES + 1u64
        if rc2 != 0u64 { return rc2 }
        if pb_cert_decided() == 1u64 { PB_CERT_LO = need   return 0u64 }
    }
    /* PASS 3 (or 2): the guaranteed certified floor (896-bit). */
    mb_dz_set_lo(0u64)
    let rc3 : u64 = pb_diexodos_tok(tok, nlay)
    PB_CERT_PASSES = PB_CERT_PASSES + 1u64
    if rc3 != 0u64 { return rc3 }
    if pb_cert_decided() == 1u64 { PB_CERT_LO = 0i64 }
    return 0u64
}
fn pb_cert_lo() -> i64 @export { return PB_CERT_LO }
fn pb_cert_passes() -> u64 @export { return PB_CERT_PASSES }

/* THE PINNED SINGLE PASS: once the escalation has DISCOVERED the floor a model
 * proves at, every subsequent token runs ONE pass at that floor -- no probe, no
 * re-read, no escalation.  This is the steady-state of certified generation: the
 * discovery is amortized, and each token costs one walk at the pinned floor
 * ((14-lo)/14 of the 896-bit limb-work) and certifies iff the gap still towers.
 * PB_CERT_LO = lo iff PROVEN this pass, -1 iff the floor was too high (the caller
 * drops one rung).  The single-pass answer to hours-per-token. */
fn pb_diexodos_pinned(tok: u64, nlay: u64, lo: u64) -> u64 @export {
    PB_CERT_LO = 0i64 - 1i64
    PB_CERT_PASSES = 0u64
    mb_dz_set_lo(lo)
    let rc : u64 = pb_diexodos_tok(tok, nlay)
    PB_CERT_PASSES = 1u64
    if rc != 0u64 { return rc }
    if pb_cert_decided() == 1u64 { PB_CERT_LO = lo as i64 }
    return 0u64
}

/* ==================== the organ's spine ==================== */

fn pb_selfprove() -> u64 @export {
    PB_REPN = 0u64
    PB_SCROLL = 0u64
    PB_SCROLL2 = 0u64
    PB_NOST_OK = 0u64
    PB_THREP_OK = 0u64
    PB_WALK_OK = 0u64
    PB_MOE_OK = 0u64
    PB_MOE_SOUND = 0u64
    let r0 : u64 = pb_arm382()
    if r0 != 0u64 { return r0 }
    let r1 : u64 = pb_arm383()
    if r1 != 0u64 { return r1 }
    let r2 : u64 = pb_arm384()
    if r2 != 0u64 { return r2 }
    let r3 : u64 = pb_arm385()
    if r3 != 0u64 { return r3 }
    let r3b : u64 = pb_arm387()
    if r3b != 0u64 { return r3b }
    let r4 : u64 = pb_arm388()
    if r4 != 0u64 { return r4 }
    let r5 : u64 = pb_arm389()
    if r5 != 0u64 { return r5 }
    return 0u64
}

fn pb_addr() -> u64 @export { return PB_SCROLL }
fn pb_addr2() -> u64 @export { return PB_SCROLL2 }
fn pb_report_len() -> u64 @export { return PB_REPN }
fn pb_report_byte(i: u64) -> u8 @export {
    if i >= PB_REPN { return 0u8 }
    return PB_REP[i]
}

/* PROBOLE: the thought is no longer a point, and the organism knows by
 * exactly how much.  What widens is measured; what straddles is refused. */
