/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\queue.iii
 *
 * III STDLIB - omnia::queue
 *
 * Bounded FIFO over a contiguous arena buffer.  Hard capacity is
 * declared at construction; push beyond returns QUEUE_E_FULL.  Ring
 * indexing wraps via modular arithmetic on a power-of-two slot count
 * derived from the requested capacity.
 *
 * Phase B: queue_u32 only.
 *
 * Hexad: kind_compose.  Ring: R0.  K: 1.00 (deterministic).
 */

module omnia_queue

extern @abi(c-msvc-x64) fn arena_alloc1(arena_id: u64, n: u64) -> u64 from "arena.iii"

const QUEUE_INVALID : u64 = 0u64
const QUEUE_OK      : i32 = 0i32
const QUEUE_E_FULL  : i32 = -1i32
const QUEUE_E_EMPTY : i32 = -2i32
const QUEUE_E_BADID : i32 = -3i32
const QUEUE_E_OOM   : i32 = -4i32

const QUEUE_MAX_INSTANCES : u32 = 16u32

var QUEUE_ARENA : [u64; 16]
var QUEUE_BASE  : [u64; 16]
var QUEUE_CAP   : [u64; 16]      /* slot count, power of two              */
var QUEUE_HARD  : [u64; 16]      /* user-declared maximum item count       */
var QUEUE_HEAD  : [u64; 16]
var QUEUE_TAIL  : [u64; 16]
var QUEUE_LEN   : [u64; 16]
var QUEUE_LIVE  : [u8;  16]

fn queue_u32_load_le(base: u64, idx: u64) -> u32 {
    let p : *u8 = base as *u8
    let off : u64 = idx * 4u64
    let b0 : u32 = p[off + 0u64] as u32
    let b1 : u32 = p[off + 1u64] as u32
    let b2 : u32 = p[off + 2u64] as u32
    let b3 : u32 = p[off + 3u64] as u32
    return (b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32)) & 0xFFFFFFFFu32
}

fn queue_u32_store_le(base: u64, idx: u64, v: u32) -> u32 {
    let p : *u8 = base as *u8
    let off : u64 = idx * 4u64
    p[off + 0u64] = (v & 0xFFu32) as u8
    p[off + 1u64] = ((v >> 8u32) & 0xFFu32) as u8
    p[off + 2u64] = ((v >> 16u32) & 0xFFu32) as u8
    p[off + 3u64] = ((v >> 24u32) & 0xFFu32) as u8
    return 0u32
}

fn queue_slot_of(id: u64) -> u32 {
    if id == 0u64 { return 0xFFFFFFFFu32 }
    let s : u64 = id - 1u64
    if s >= (QUEUE_MAX_INSTANCES as u64) { return 0xFFFFFFFFu32 }
    let si : u32 = s as u32
    if QUEUE_LIVE[si] == 0u8 { return 0xFFFFFFFFu32 }
    return si
}

fn queue_u32_new(arena_id: u64, hard_max: u64) -> u64 @export {
    if hard_max == 0u64 { return QUEUE_INVALID }
    let mut i : u32 = 0u32
    let mut slot : u32 = 0xFFFFFFFFu32
    while i < QUEUE_MAX_INSTANCES {
        if QUEUE_LIVE[i] == 0u8 {
            if slot == 0xFFFFFFFFu32 { slot = i }
        }
        i = i + 1u32
    }
    if slot == 0xFFFFFFFFu32 { return QUEUE_INVALID }
    /* Round hard_max UP to the next power of two for ring indexing. */
    let mut cap : u64 = 1u64
    while cap < hard_max { cap = cap * 2u64 }
    let buf : u64 = arena_alloc1(arena_id, cap * 4u64)
    if buf == 0u64 { return QUEUE_INVALID }
    QUEUE_ARENA[slot] = arena_id
    QUEUE_BASE[slot]  = buf
    QUEUE_CAP[slot]   = cap
    QUEUE_HARD[slot]  = hard_max
    QUEUE_HEAD[slot]  = 0u64
    QUEUE_TAIL[slot]  = 0u64
    QUEUE_LEN[slot]   = 0u64
    QUEUE_LIVE[slot]  = 1u8
    return (slot as u64) + 1u64
}

fn queue_u32_drop(id: u64) -> i32 @export {
    let s : u32 = queue_slot_of(id)
    if s == 0xFFFFFFFFu32 { return QUEUE_E_BADID }
    QUEUE_LIVE[s] = 0u8
    QUEUE_ARENA[s] = 0u64
    QUEUE_BASE[s]  = 0u64
    QUEUE_CAP[s]   = 0u64
    QUEUE_HARD[s]  = 0u64
    QUEUE_HEAD[s]  = 0u64
    QUEUE_TAIL[s]  = 0u64
    QUEUE_LEN[s]   = 0u64
    return QUEUE_OK
}

fn queue_u32_push(id: u64, v: u32) -> i32 @export {
    let s : u32 = queue_slot_of(id)
    if s == 0xFFFFFFFFu32 { return QUEUE_E_BADID }
    if QUEUE_LEN[s] >= QUEUE_HARD[s] { return QUEUE_E_FULL }
    let cap : u64 = QUEUE_CAP[s]
    let mask : u64 = cap - 1u64
    let tail : u64 = QUEUE_TAIL[s]
    queue_u32_store_le(QUEUE_BASE[s], tail, v)
    QUEUE_TAIL[s] = (tail + 1u64) & mask
    QUEUE_LEN[s] = QUEUE_LEN[s] + 1u64
    return QUEUE_OK
}

/* Pop returns option_u32 encoding. */
fn queue_u32_pop(id: u64) -> u64 @export {
    let s : u32 = queue_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0u64 }
    if QUEUE_LEN[s] == 0u64 { return 0u64 }
    let cap : u64 = QUEUE_CAP[s]
    let mask : u64 = cap - 1u64
    let head : u64 = QUEUE_HEAD[s]
    let v : u32 = queue_u32_load_le(QUEUE_BASE[s], head)
    QUEUE_HEAD[s] = (head + 1u64) & mask
    QUEUE_LEN[s] = QUEUE_LEN[s] - 1u64
    return ((v as u64) << 1u64) | 1u64
}

fn queue_u32_peek(id: u64) -> u64 @export {
    let s : u32 = queue_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0u64 }
    if QUEUE_LEN[s] == 0u64 { return 0u64 }
    let head : u64 = QUEUE_HEAD[s]
    let v : u32 = queue_u32_load_le(QUEUE_BASE[s], head)
    return ((v as u64) << 1u64) | 1u64
}

fn queue_u32_len(id: u64) -> u64 @export {
    let s : u32 = queue_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0u64 }
    return QUEUE_LEN[s]
}

fn queue_u32_capacity(id: u64) -> u64 @export {
    let s : u32 = queue_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0u64 }
    return QUEUE_HARD[s]
}

fn queue_u32_clear(id: u64) -> i32 @export {
    let s : u32 = queue_slot_of(id)
    if s == 0xFFFFFFFFu32 { return QUEUE_E_BADID }
    QUEUE_HEAD[s] = 0u64
    QUEUE_TAIL[s] = 0u64
    QUEUE_LEN[s]  = 0u64
    return QUEUE_OK
}

/* ─── queue_u64 instantiation (lattice plan Step 0001) ──────────────
 *
 * Parallel slot table mirroring queue_u32 but with 8-byte-stride
 * payloads suitable for crystal_id, witness_id, kchain_id, etc.
 *
 * Hexad: kind_compose.  Ring: R0.  K: 1.00.
 */

extern @abi(c-msvc-x64) fn arena_alloc8(arena_id: u64, n: u64) -> u64 from "arena.iii"

const QUEUE_U64_MAX_INSTANCES : u32 = 8u32

var QUEUE64_ARENA : [u64; 8]
var QUEUE64_BASE  : [u64; 8]
var QUEUE64_CAP   : [u64; 8]
var QUEUE64_HARD  : [u64; 8]
var QUEUE64_HEAD  : [u64; 8]
var QUEUE64_TAIL  : [u64; 8]
var QUEUE64_LEN   : [u64; 8]
var QUEUE64_LIVE  : [u8;  8]

fn queue_u64_load_le(base: u64, idx: u64) -> u64 {
    let p : *u8 = base as *u8
    let off : u64 = idx * 8u64
    let b0 : u64 = p[off + 0u64] as u64
    let b1 : u64 = p[off + 1u64] as u64
    let b2 : u64 = p[off + 2u64] as u64
    let b3 : u64 = p[off + 3u64] as u64
    let b4 : u64 = p[off + 4u64] as u64
    let b5 : u64 = p[off + 5u64] as u64
    let b6 : u64 = p[off + 6u64] as u64
    let b7 : u64 = p[off + 7u64] as u64
    let lo : u64 = b0 | (b1 << 8u64) | (b2 << 16u64) | (b3 << 24u64)
    let hi : u64 = (b4 << 32u64) | (b5 << 40u64) | (b6 << 48u64) | (b7 << 56u64)
    return lo | hi
}

fn queue_u64_store_le(base: u64, idx: u64, v: u64) -> u32 {
    let p : *u8 = base as *u8
    let off : u64 = idx * 8u64
    let mut i : u64 = 0u64
    while i < 8u64 {
        p[off + i] = ((v >> (i * 8u64)) & 0xFFu64) as u8
        i = i + 1u64
    }
    return 0u32
}

fn queue_u64_slot_of(id: u64) -> u32 {
    if id == 0u64 { return 0xFFFFFFFFu32 }
    let s : u64 = id - 1u64
    if s >= (QUEUE_U64_MAX_INSTANCES as u64) { return 0xFFFFFFFFu32 }
    let si : u32 = s as u32
    if QUEUE64_LIVE[si] == 0u8 { return 0xFFFFFFFFu32 }
    return si
}

fn queue_u64_new(arena_id: u64, hard_max: u64) -> u64 @export {
    if hard_max == 0u64 { return QUEUE_INVALID }
    let mut i : u32 = 0u32
    let mut slot : u32 = 0xFFFFFFFFu32
    while i < QUEUE_U64_MAX_INSTANCES {
        if QUEUE64_LIVE[i] == 0u8 {
            if slot == 0xFFFFFFFFu32 { slot = i }
        }
        i = i + 1u32
    }
    if slot == 0xFFFFFFFFu32 { return QUEUE_INVALID }
    let mut cap : u64 = 1u64
    while cap < hard_max { cap = cap * 2u64 }
    let buf : u64 = arena_alloc8(arena_id, cap * 8u64)
    if buf == 0u64 { return QUEUE_INVALID }
    QUEUE64_ARENA[slot] = arena_id
    QUEUE64_BASE[slot]  = buf
    QUEUE64_CAP[slot]   = cap
    QUEUE64_HARD[slot]  = hard_max
    QUEUE64_HEAD[slot]  = 0u64
    QUEUE64_TAIL[slot]  = 0u64
    QUEUE64_LEN[slot]   = 0u64
    QUEUE64_LIVE[slot]  = 1u8
    return (slot as u64) + 1u64
}

fn queue_u64_drop(id: u64) -> i32 @export {
    let s : u32 = queue_u64_slot_of(id)
    if s == 0xFFFFFFFFu32 { return QUEUE_E_BADID }
    QUEUE64_LIVE[s] = 0u8
    QUEUE64_ARENA[s] = 0u64
    QUEUE64_BASE[s]  = 0u64
    QUEUE64_CAP[s]   = 0u64
    QUEUE64_HARD[s]  = 0u64
    QUEUE64_HEAD[s]  = 0u64
    QUEUE64_TAIL[s]  = 0u64
    QUEUE64_LEN[s]   = 0u64
    return QUEUE_OK
}

fn queue_u64_push(id: u64, v: u64) -> i32 @export {
    let s : u32 = queue_u64_slot_of(id)
    if s == 0xFFFFFFFFu32 { return QUEUE_E_BADID }
    if QUEUE64_LEN[s] >= QUEUE64_HARD[s] { return QUEUE_E_FULL }
    let cap : u64 = QUEUE64_CAP[s]
    let mask : u64 = cap - 1u64
    let tail : u64 = QUEUE64_TAIL[s]
    queue_u64_store_le(QUEUE64_BASE[s], tail, v)
    QUEUE64_TAIL[s] = (tail + 1u64) & mask
    QUEUE64_LEN[s] = QUEUE64_LEN[s] + 1u64
    return QUEUE_OK
}

/* Pop returns option-encoded u64: 0 = empty; (v << 1) | 1 = present.
 * Note: shifting a 64-bit value left by 1 may lose the high bit;
 * therefore queue_u64_pop returns the value via a side-table OUT
 * accessor instead of a tagged return.  (See queue_u64_pop_value below.)
 */
var QUEUE_U64_LAST_POP : u64 = 0u64
var QUEUE_U64_LAST_OK  : u8  = 0u8

fn queue_u64_pop(id: u64) -> u8 @export {
    let s : u32 = queue_u64_slot_of(id)
    if s == 0xFFFFFFFFu32 { QUEUE_U64_LAST_OK = 0u8; return 0u8 }
    if QUEUE64_LEN[s] == 0u64 { QUEUE_U64_LAST_OK = 0u8; return 0u8 }
    let cap : u64 = QUEUE64_CAP[s]
    let mask : u64 = cap - 1u64
    let head : u64 = QUEUE64_HEAD[s]
    let v : u64 = queue_u64_load_le(QUEUE64_BASE[s], head)
    QUEUE64_HEAD[s] = (head + 1u64) & mask
    QUEUE64_LEN[s] = QUEUE64_LEN[s] - 1u64
    QUEUE_U64_LAST_POP = v
    QUEUE_U64_LAST_OK = 1u8
    return 1u8
}

fn queue_u64_pop_value() -> u64 @export {
    return QUEUE_U64_LAST_POP
}

fn queue_u64_len(id: u64) -> u64 @export {
    let s : u32 = queue_u64_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0u64 }
    return QUEUE64_LEN[s]
}

fn queue_u64_empty(id: u64) -> u8 @export {
    let s : u32 = queue_u64_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 1u8 }
    if QUEUE64_LEN[s] == 0u64 { return 1u8 }
    return 0u8
}

