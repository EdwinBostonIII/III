/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\ripple.iii
 *
 * III STDLIB - omnia::ripple -- change-propagation engine for the
 * Living Sealed Lattice.
 *
 * Lattice plan Step 0016.  Builds on:
 *   omnia/crystal_deps.iii        sid_transitive_closure
 *   omnia/crystal.iii    crystal_mint, crystal_edges_*, crystal_verify
 *   sanctus/witness.iii  witness_append (full witness chain growth)
 *   sanctus/kchain.iii   kchain_compose (K-chain composition)
 *   sanctus/closure.iii  closure_byte (read prior tree_root) + closure_set (commit)
 *   sanctus/mhash.iii    mhash_begin/domain/payload/final
 *
 * Pipeline (each stage produces a crystal_id with edges to predecessors):
 *
 *   ripple_change_new   -- describes a single source-of-truth change
 *   ripple_analyze       -- plan: closure of dependents (sid_transitive_closure)
 *   ripple_execute       -- strict|fast: re-seal each dependent, append witness
 *   ripple_verify        -- every appended witness verifies, K-chain healthy
 *   ripple_commit        -- atomically updates closure tree_root, returns delta crystal
 *
 * Hexad: kind_mobius (Mobius coherence -- change propagating through topology).
 * Ring: R0.  K: 0.95 (analyse may fail; execute may abort on overflow).
 */

module omnia_ripple

extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"

