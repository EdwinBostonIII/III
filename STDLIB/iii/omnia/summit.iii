/* the two sealed scroll addresses (the probe prints them) */
var SU_AG : u64 = 0u64
var SU_AB : u64 = 0u64
fn su_addr_gravity() -> u64 @export { return SU_AG }
fn su_addr_born() -> u64 @export { return SU_AB }

fn su_strlen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { i = i + 1u64 }
    return i
}
/* exact rational value of a riza poly at n/d (Horner over py rationals) */
fn su_eval(P: u64, deg: i64, n: i64, d: i64) -> u64 {
    let t : u64 = py_rat_frac(n, d)
    let mut v : u64 = rz_c(P, deg)
    let mut k : i64 = deg - 1i64
    while k >= 0i64 {
        v = py_rat_add(py_rat_mul(v, t), rz_c(P, k))
        k = k - 1i64
    }
    return v
}
/* the separation polynomial of the crush: P = (t-1)^2 (t^2 + t + 5)
 *   = t^4 - t^3 + 4t^2 - 9t + 5  (relative kinematics with independent
 * accelerations -- the kinesis quartic regime; node at the RATIONAL t = 1
 * so both places of Q can probe it exactly) */
fn su_mkP() -> u64 {
    rz_in(0u64, 5i64)
    rz_in(1u64, 0i64 - 9i64)
    rz_in(2u64, 4i64)
    rz_in(3u64, 0i64 - 1i64)
    rz_in(4u64, 1i64)
    return rz_from_in(4i64)
}
fn su_arm280() -> u64 {
    /* THEOREM I, THE NODE: trichotomy decided, multiplicity by gcd with
     * exact reconstruction, contact kinematics derived */
    rz_reset()
    let P : u64 = su_mkP()
    let dP : u64 = rz_deriv(P)
    /* the degeneracy: gcd(P, P') = t - 1 (degree 1 -> multiplicity 2) */
    let g : u64 = rz_gcd(P, dP)
    if py_rat_cmp(rz_c(g, 1i64), py_rat_i64(1i64)) != 0i64 { return 280u64 }
    if py_rat_cmp(rz_c(g, 0i64), py_rat_i64(0i64 - 1i64)) != 0i64 { return 280u64 }
    /* exact reconstruction P = g*g*u, u = t^2 + t + 5, u(1) = 7 != 0 */
    let r1 : u64 = rz_divmod(P, g)
    if rz_eval_sign(r1, 0i64, 1i64) != 0i64 { return 280u64 }
    if rz_eval_sign(r1, 1i64, 1i64) != 0i64 { return 280u64 }
    let Q1 : u64 = rz_quot()
    let r2 : u64 = rz_divmod(Q1, g)
    if rz_eval_sign(r2, 0i64, 1i64) != 0i64 { return 280u64 }
    let u : u64 = rz_quot()
    if py_rat_cmp(rz_c(u, 0i64), py_rat_i64(5i64)) != 0i64 { return 280u64 }
    if py_rat_cmp(rz_c(u, 1i64), py_rat_i64(1i64)) != 0i64 { return 280u64 }
    if py_rat_cmp(rz_c(u, 2i64), py_rat_i64(1i64)) != 0i64 { return 280u64 }
    let R : u64 = rz_mul(rz_mul(g, g), u)
    let mut k : i64 = 0i64
    while k <= 4i64 {
        if py_rat_cmp(rz_c(R, k), rz_c(P, k)) != 0i64 { return 280u64 }
        k = k + 1i64
    }
    if py_rat_cmp(su_eval(u, 2i64, 1i64, 1i64), py_rat_i64(7i64)) != 0i64 { return 280u64 }
    /* u never vanishes on the real line (no other contact from this factor) */
    if rz_count(u, 0i64 - 100i64, 1i64, 100i64, 1i64) != 0i64 { return 280u64 }
    /* the Sturm collapse: degree 4, ONE distinct real root */
    if rz_count(P, 0i64 - 100i64, 1i64, 100i64, 1i64) != 1i64 { return 280u64 }
    /* contact kinematics: separation 0 AT the node, relative velocity 0 AT
     * the node (the MEANING of multiplicity 2), sign PERSISTS across it */
    if rz_eval_sign(P, 1i64, 1i64) != 0i64 { return 280u64 }
    if py_rat_sign(su_eval(dP, 3i64, 1i64, 1i64)) != 0i64 { return 280u64 }
    if rz_eval_sign(P, 7i64, 8i64) != 1i64 { return 280u64 }
    if rz_eval_sign(P, 9i64, 8i64) != 1i64 { return 280u64 }
    /* THE TRICHOTOMY: +e lifts contact off (miss), -e splits it into two
     * SIMPLE transversal crossings; both controls decided exactly.  The
     * exact epsilon = 1/1000 is minted by CONSTANT-POLY DIVISION (deg-0
     * divmod: quotient is the exact rational constant). */
    let Pp2 : u64 = rz_add(P, su_cq(1i64, 1000i64))
    let Pm2 : u64 = rz_add(P, su_cq(0i64 - 1i64, 1000i64))
    /* miss: no roots anywhere near the node */
    if rz_count(Pp2, 0i64, 1i64, 2i64, 1i64) != 0i64 { return 280u64 }
    /* transversal pair: two roots, sign NEGATIVE between them at t=1 */
    if rz_count(Pm2, 0i64, 1i64, 2i64, 1i64) != 2i64 { return 280u64 }
    if rz_eval_sign(Pm2, 1i64, 1i64) != (0i64 - 1i64) { return 280u64 }
    /* and both perturbed polynomials are square-free (simple contacts):
     * gcd with derivative is constant */
    let gp : u64 = rz_gcd(Pp2, rz_deriv(Pp2))
    if py_rat_sign(rz_c(gp, 1i64)) != 0i64 { return 280u64 }
    let gm : u64 = rz_gcd(Pm2, rz_deriv(Pm2))
    if py_rat_sign(rz_c(gm, 1i64)) != 0i64 { return 280u64 }
    if py_err() != 0u64 { return 280u64 }
    return 0u64
}
/* the exact rational constant n/d as a degree-0 riza poly: constant-poly
 * division -- rz_divmod of (const n) by (const d) leaves the quotient n/d */
fn su_cq(n: i64, d: i64) -> u64 {
    rz_in(0u64, n)
    let cn : u64 = rz_from_in(0i64)
    rz_in(0u64, d)
    let cd : u64 = rz_from_in(0i64)
    let rem : u64 = rz_divmod(cn, cd)
    if rz_eval_sign(rem, 0i64, 1i64) != 0i64 { return cn }
    return rz_quot()
}
fn su_arm281() -> u64 {
    /* THEOREM I, THE PLACES: multiplicity by the 5-adic valuation slope
     * (second engine), and the product formula at every probe */
    rz_reset()
    let P : u64 = su_mkP()
    /* v_5(P(1+5^k)) = 2k for k = 1,2,3: evaluate in exact i64 (Horner) */
    let mut k : u64 = 1u64
    let mut pw : i64 = 5i64
    while k <= 3u64 {
        let t : i64 = 1i64 + pw
        let mut v : i64 = 1i64
        /* Horner for t^4 - t^3 + 4t^2 - 9t + 5 */
        v = (v * t) - 1i64
        v = (v * t) + 4i64
        v = (v * t) - 9i64
        v = (v * t) + 5i64
        /* the 5-adic valuation and the unit part */
        let mut val : u64 = 0u64
        let mut m : i64 = v
        let mut going : u8 = 1u8
        while going == 1u8 {
            if (m % 5i64) == 0i64 { m = m / 5i64   val = val + 1u64 } else { going = 0u8 }
        }
        if val != (2u64 * k) { return 281u64 }
        /* unit part nonzero mod 5, and the RECONSTRUCTION (the product
         * formula for the 5-place): P(1+5^k) = 5^(2k) * unit exactly */
        if (m % 5i64) == 0i64 { return 281u64 }
        let mut back : i64 = m
        let mut j : u64 = 0u64
        while j < val { back = back * 5i64   j = j + 1u64 }
        if back != v { return 281u64 }
        /* cross-check the same value through the exact rational engine */
        let ve : u64 = su_eval(P, 4i64, t, 1i64)
        if py_rat_cmp(ve, py_rat_i64(v)) != 0i64 { return 281u64 }
        k = k + 1u64
        pw = pw * 5i64
    }
    /* full multi-place reconstruction of the k=1 probe: 1175 = 5^2 * 47,
     * 47 prime -- every place accounted, product of all places = 1 */
    let n1 : i64 = 1175i64
    let mut m2 : i64 = n1
    let mut e5 : u64 = 0u64
    let mut go2 : u8 = 1u8
    while go2 == 1u8 {
        if (m2 % 5i64) == 0i64 { m2 = m2 / 5i64   e5 = e5 + 1u64 } else { go2 = 0u8 }
    }
    if e5 != 2u64 { return 281u64 }
    if m2 != 47i64 { return 281u64 }
    /* 47 is prime (trial division to its root) */
    let mut d2 : i64 = 2i64
    while (d2 * d2) <= 47i64 {
        if (47i64 % d2) == 0i64 { return 281u64 }
        d2 = d2 + 1i64
    }
    if (25i64 * 47i64) != n1 { return 281u64 }
    if py_err() != 0u64 { return 281u64 }
    return 0u64
}
fn su_arm282() -> u64 {
    /* THEOREM I, THE TILT LEDGER: at the node the separation is EXACTLY 0,
     * the bodies stay distinct in the char-5 shadow, the sharp map carries
     * them losslessly, and the momentum-impulse ledger is exactly linear
     * THROUGH the node (finite where the continuum potential diverges) */
    rz_reset()
    /* worldlines x1 = t^2 (accelerating), x2 = 2t - 1: meet at t=1 with
     * EQUAL velocities (the graze).  masses 2 and 3. */
    /* momenta p(t) = 2*(2t) + 3*2 = 4t + 6 at t = 7/8, 1, 9/8: the
     * impulse ledger: second difference EXACTLY zero, node value finite */
    let pa : u64 = py_rat_add(py_rat_mul(py_rat_i64(4i64), py_rat_frac(7i64, 8i64)), py_rat_i64(6i64))
    let pb : u64 = py_rat_add(py_rat_mul(py_rat_i64(4i64), py_rat_i64(1i64)), py_rat_i64(6i64))
    let pc : u64 = py_rat_add(py_rat_mul(py_rat_i64(4i64), py_rat_frac(9i64, 8i64)), py_rat_i64(6i64))
    if py_rat_cmp(pb, py_rat_i64(10i64)) != 0i64 { return 282u64 }
    let d1 : u64 = py_rat_add(pb, py_rat_mul(py_rat_i64(0i64 - 1i64), pa))
    let dd : u64 = py_rat_add(pc, py_rat_mul(py_rat_i64(0i64 - 1i64), pb))
    if py_rat_cmp(d1, dd) != 0i64 { return 282u64 }
    /* geometric separation AT the node: exactly zero */
    let P : u64 = su_mkP()
    if rz_eval_sign(P, 1i64, 1i64) != 0i64 { return 282u64 }
    /* the char-5 shadow: momenta residues 4 and 6=1 (mod 5) distinct;
     * the separation residue 0 -- the collapse killed the SEPARATION,
     * never the participants */
    kd_setp(5u64)
    kd_mode(3u64, 1u64)
    let ba : u64 = kd_alloc()
    kd_seti(ba, 0u64, 4u64)
    let bb : u64 = kd_alloc()
    kd_seti(bb, 0u64, 1u64)
    let zr : u64 = kd_alloc()
    if kd_eq(ba, bb) == 1u32 { return 282u64 }
    if kd_iszero(zr) != 1u32 { return 282u64 }
    /* the product residue 4*1 = 4 */
    let pr : u64 = kd_mul(ba, bb)
    if kd_get(pr, 0u64) != 4u64 { return 282u64 }
    /* the untilted side: sharps distinct, multiplicative, zero to zero */
    kd_mode(3u64, 3u64)
    let la : u64 = kd_alloc()
    kd_seti(la, 0u64, 4u64)
    let lb : u64 = kd_alloc()
    kd_seti(lb, 0u64, 1u64)
    let sa : u64 = kd_pow(la, 125u64)
    let sb : u64 = kd_pow(lb, 125u64)
    if kd_eq(sa, sb) == 1u32 { return 282u64 }
    if kd_iszero(sa) == 1u32 { return 282u64 }
    if kd_iszero(sb) == 1u32 { return 282u64 }
    /* multiplicativity of the sharp on the ledger */
    let lp : u64 = kd_mul(la, lb)
    let sp : u64 = kd_pow(lp, 125u64)
    if kd_eq(kd_mul(sa, sb), sp) != 1u32 { return 282u64 }
    let lz : u64 = kd_alloc()
    if kd_iszero(kd_pow(lz, 125u64)) != 1u32 { return 282u64 }
    if kl_err() != 0u64 { return 282u64 }
    if py_err() != 0u64 { return 282u64 }
    return 0u64
}
/* ---- Theorem II machinery: 2-qubit exact linear algebra over pz ---- */
var SU_PSI : [u64; 4]
var SU_PS2 : [u64; 4]
var SU_MA : [u64; 4]
var SU_MB : [u64; 4]
fn su_bell() -> i32 {
    /* |Phi+> = (|00> + |11>)/sqrt2, through the kyma ring encoding */
    SU_PSI[0u64] = pz_from_zeta4(1i64, 0i64, 0i64, 0i64, 1u64)
    SU_PSI[1u64] = pz_zero()
    SU_PSI[2u64] = pz_zero()
    SU_PSI[3u64] = pz_from_zeta4(1i64, 0i64, 0i64, 0i64, 1u64)
    return 0i32
}
/* apply (MA (x) MB) to SU_PSI into SU_PS2 */
fn su_apply2() -> i32 {
    let mut i : u64 = 0u64
    while i < 2u64 {
        let mut j : u64 = 0u64
        while j < 2u64 {
            let mut acc : u64 = pz_zero()
            let mut a : u64 = 0u64
            while a < 2u64 {
                let mut b : u64 = 0u64
                while b < 2u64 {
                    let f : u64 = pz_mul(SU_MA[(i * 2u64) + a], SU_MB[(j * 2u64) + b])
                    acc = pz_add(acc, pz_mul(f, SU_PSI[(a * 2u64) + b]))
                    b = b + 1u64
                }
                a = a + 1u64
            }
            SU_PS2[(i * 2u64) + j] = acc
            j = j + 1u64
        }
        i = i + 1u64
    }
    return 0i32
}
/* correlator <Phi|(MA (x) MB)|Phi> by the FULL contraction; must be real */
fn su_corr_full() -> u64 {
    su_apply2()
    let mut acc : u64 = pz_zero()
    let mut k : u64 = 0u64
    while k < 4u64 {
        acc = pz_add(acc, pz_mul(pz_conj(SU_PSI[k]), SU_PS2[k]))
        k = k + 1u64
    }
    return acc
}
/* the half-trace identity for |Phi+>: <MA (x) MB> = (1/2) sum MA_ij MB_ij */
fn su_corr_tr() -> u64 {
    let mut acc : u64 = pz_zero()
    let mut k : u64 = 0u64
    while k < 4u64 {
        acc = pz_add(acc, pz_mul(SU_MA[k], SU_MB[k]))
        k = k + 1u64
    }
    let half : u64 = pz_from_el(py_el_from_rat(py_rat_frac(1i64, 2i64), 0u64))
    return pz_mul(half, acc)
}
/* both engines, one exact real correlator */
fn su_corr(want_err: u64) -> u64 {
    let c1 : u64 = su_corr_full()
    let c2 : u64 = su_corr_tr()
    if pz_eq(c1, c2) != 1u32 { SU_CERR = want_err }
    if pz_is_real(c1) != 1u32 { SU_CERR = want_err }
    return pz_re(c1)
}
var SU_CERR : u64 = 0u64
fn su_setA_z() -> i32 {
    SU_MA[0u64] = pz_one()   SU_MA[1u64] = pz_zero()
    SU_MA[2u64] = pz_zero()   SU_MA[3u64] = pz_from_i64(0i64 - 1i64, 0i64)
    return 0i32
}
fn su_setA_x() -> i32 {
    SU_MA[0u64] = pz_zero()   SU_MA[1u64] = pz_one()
    SU_MA[2u64] = pz_one()   SU_MA[3u64] = pz_zero()
    return 0i32
}
fn su_setB_h(sgn: i64) -> i32 {
    /* sgn=+1: (sz+sx)/sqrt2 = (h,h;h,-h); sgn=-1: (sz-sx)/sqrt2 = (h,-h;-h,-h) */
    let h : u64 = py_div(py_el_from_i64(1i64, 0u64), py_sqrt(py_el_from_i64(2i64, 0u64)))
    let hz : u64 = pz_from_el(h)
    let hn : u64 = pz_neg(hz)
    if sgn > 0i64 {
        SU_MB[0u64] = hz   SU_MB[1u64] = hz
        SU_MB[2u64] = hz   SU_MB[3u64] = hn
    } else {
        SU_MB[0u64] = hz   SU_MB[1u64] = hn
        SU_MB[2u64] = hn   SU_MB[3u64] = hn
    }
    return 0i32
}
fn su_arm283() -> u64 {
    /* THEOREM II, THE BOOLEAN REFUTATION: entanglement decided, Tsirelson
     * met exactly, the complete 16-orbit of deterministic assignments
     * derived and EXCEEDED by exact sign */
    py_reset()
    SU_CERR = 0u64
    su_bell()
    /* normalization: total weight EXACTLY 1 */
    let tot : u64 = py_add(py_add(pz_norm2(SU_PSI[0u64]), pz_norm2(SU_PSI[1u64])), py_add(pz_norm2(SU_PSI[2u64]), pz_norm2(SU_PSI[3u64])))
    if py_cmp(tot, py_el_from_i64(1i64, 0u64)) != 0i64 { return 283u64 }
    /* entanglement: det of the amplitude matrix = 1/2 != 0 */
    let det : u64 = pz_sub(pz_mul(SU_PSI[0u64], SU_PSI[3u64]), pz_mul(SU_PSI[1u64], SU_PSI[2u64]))
    if pz_is_real(det) != 1u32 { return 283u64 }
    if py_cmp(pz_re(det), py_el_from_rat(py_rat_frac(1i64, 2i64), 0u64)) != 0i64 { return 283u64 }
    /* every product state has det EXACTLY 0 (witnessed on three) */
    let mut w : u64 = 0u64
    while w < 3u64 {
        let mut a0 : i64 = 2i64
        let mut a1 : i64 = 3i64
        let mut b0 : i64 = 5i64
        let mut b1 : i64 = 0i64 - 1i64
        if w == 1u64 { a0 = 7i64   a1 = 0i64 - 2i64   b0 = 1i64   b1 = 4i64 }
        if w == 2u64 { a0 = 1i64   a1 = 1i64   b0 = 3i64   b1 = 3i64 }
        let p00 : u64 = pz_from_i64(a0 * b0, 0i64)
        let p01 : u64 = pz_from_i64(a0 * b1, 0i64)
        let p10 : u64 = pz_from_i64(a1 * b0, 0i64)
        let p11 : u64 = pz_from_i64(a1 * b1, 0i64)
        if pz_eqz(pz_sub(pz_mul(p00, p11), pz_mul(p01, p10))) != 1u32 { return 283u64 }
        w = w + 1u64
    }
    /* the four exact correlators (two engines each) */
    su_setA_z()
    su_setB_h(1i64)
    let e_ab : u64 = su_corr(283u64)
    su_setA_x()
    let e_apb : u64 = su_corr(283u64)
    su_setA_z()
    su_setB_h(0i64 - 1i64)
    let e_abp : u64 = su_corr(283u64)
    su_setA_x()
    let e_apbp : u64 = su_corr(283u64)
    if SU_CERR != 0u64 { return SU_CERR }
    /* S = E(A,B) + E(A',B) + E(A,B') - E(A',B') = 2 sqrt2 EXACTLY */
    let S : u64 = py_sub(py_add(py_add(e_ab, e_apb), e_abp), e_apbp)
    let s2 : u64 = py_sqrt(py_el_from_i64(2i64, 0u64))
    if py_cmp(S, py_mul(py_el_from_i64(2i64, 0u64), s2)) != 0i64 { return 283u64 }
    if py_cmp(py_mul(S, S), py_el_from_i64(8i64, 0u64)) != 0i64 { return 283u64 }
    /* the COMPLETE boolean orbit: all 16 deterministic assignments */
    let mut mx : i64 = 0i64
    let mut ia : i64 = 0i64
    while ia < 2i64 {
        let mut ib : i64 = 0i64
        while ib < 2i64 {
            let mut ic : i64 = 0i64
            while ic < 2i64 {
                let mut id : i64 = 0i64
                while id < 2i64 {
                    let av : i64 = (2i64 * ia) - 1i64
                    let bv : i64 = (2i64 * ib) - 1i64
                    let cv : i64 = (2i64 * ic) - 1i64
                    let dv : i64 = (2i64 * id) - 1i64
                    let mut sd : i64 = ((av * cv) + (bv * cv) + (av * dv)) - (bv * dv)
                    if sd < 0i64 { sd = 0i64 - sd }
                    if sd > mx { mx = sd }
                    id = id + 1i64
                }
                ic = ic + 1i64
            }
            ib = ib + 1i64
        }
        ia = ia + 1i64
    }
    if mx != 2i64 { return 283u64 }
    /* the strict exceedance, DECIDED by the total-sign oracle */
    if py_sign(py_sub(S, py_el_from_i64(2i64, 0u64))) != 1i64 { return 283u64 }
    if py_sign(py_sub(py_el_from_i64(4i64, 0u64), S)) != 1i64 { return 283u64 }
    if py_err() != 0u64 { return 283u64 }
    return 0u64
}
fn su_arm284() -> u64 {
    /* THEOREM II, THE SELECTION: the Born exponent surfaced by the machine
     * as the UNIQUE basis-invariant weight; swap symmetry + null weights
     * force the Bell probabilities; the frequency face counted by meris */
    py_reset()
    /* the test state (3/5)|0> + (4/5)|1>, and its EXACT Hadamard rotation:
     * (7/(5 sqrt2), -1/(5 sqrt2)) */
    let a0 : u64 = py_el_from_rat(py_rat_frac(3i64, 5i64), 0u64)
    let a1 : u64 = py_el_from_rat(py_rat_frac(4i64, 5i64), 0u64)
    let s2 : u64 = py_sqrt(py_el_from_i64(2i64, 0u64))
    let is2 : u64 = py_div(py_el_from_i64(1i64, 0u64), s2)
    let b0 : u64 = py_mul(py_add(a0, a1), is2)
    let b1 : u64 = py_mul(py_sub(a0, a1), is2)
    /* |b1| = (1/5)/sqrt2 positive magnitude */
    let m1 : u64 = py_sub(py_el_from_i64(0i64, 0u64), b1)
    if py_sign(m1) != 1i64 { return 284u64 }
    /* enumerate the candidate family w_e = |amp|^e, e = 1..4; count the
     * basis-invariant survivors and SURFACE the exponent */
    let mut e : i64 = 1i64
    let mut nhit : i64 = 0i64
    let mut ehit : i64 = 0i64
    while e <= 4i64 {
        let mut tz : u64 = py_el_from_i64(0i64, 0u64)
        let mut tx : u64 = py_el_from_i64(0i64, 0u64)
        /* powers by repeated exact multiplication */
        let mut p0 : u64 = py_el_from_i64(1i64, 0u64)
        let mut p1 : u64 = py_el_from_i64(1i64, 0u64)
        let mut q0 : u64 = py_el_from_i64(1i64, 0u64)
        let mut q1 : u64 = py_el_from_i64(1i64, 0u64)
        let mut t : i64 = 0i64
        while t < e {
            p0 = py_mul(p0, a0)
            p1 = py_mul(p1, a1)
            q0 = py_mul(q0, b0)
            q1 = py_mul(q1, m1)
            t = t + 1i64
        }
        tz = py_add(p0, p1)
        tx = py_add(q0, q1)
        if py_cmp(tz, tx) == 0i64 {
            nhit = nhit + 1i64
            ehit = e
        }
        e = e + 1i64
    }
    /* exactly ONE survivor, and the machine names it: e = 2 (Parseval) */
    if nhit != 1i64 { return 284u64 }
    if ehit != 2i64 { return 284u64 }
    /* the survivor's total is CERTAINTY in both bases */
    let n0 : u64 = py_mul(a0, a0)
    let n1 : u64 = py_mul(a1, a1)
    if py_cmp(py_add(n0, n1), py_el_from_i64(1i64, 0u64)) != 0i64 { return 284u64 }
    /* swap symmetry forces the Bell weights: X(x)X |Phi+> = |Phi+> */
    su_bell()
    su_setA_x()
    let mut k : u64 = 0u64
    while k < 4u64 { SU_MB[k] = SU_MA[k]   k = k + 1u64 }
    su_apply2()
    k = 0u64
    while k < 4u64 {
        if pz_eq(SU_PS2[k], SU_PSI[k]) != 1u32 { return 284u64 }
        k = k + 1u64
    }
    /* null amplitudes carry null weight; the two symmetric outcomes split
     * certainty: P(00) = P(11) = 1/2 EXACTLY -- derived, not assumed */
    if py_sign(pz_norm2(SU_PSI[1u64])) != 0i64 { return 284u64 }
    if py_sign(pz_norm2(SU_PSI[2u64])) != 0i64 { return 284u64 }
    let w00 : u64 = pz_norm2(SU_PSI[0u64])
    let w11 : u64 = pz_norm2(SU_PSI[3u64])
    if py_cmp(w00, w11) != 0i64 { return 284u64 }
    let half : u64 = py_el_from_rat(py_rat_frac(1i64, 2i64), 0u64)
    if py_cmp(w00, half) != 0i64 { return 284u64 }
    /* THE FREQUENCY FACE (meris): the derived p = 1/2 over n = 4 trials:
     * sum C(4,k) = 16 = 2^4, ledger sums to certainty, mean = 2 */
    let f4 : u64 = ms_fact(4i64)
    let mut cs : u64 = 0u64
    let mut me : u64 = 0u64
    let mut kk : i64 = 0i64
    while kk <= 4i64 {
        let den : u64 = ms_fact(kk) * ms_fact(4i64 - kk)
        if (f4 % den) != 0u64 { return 284u64 }
        let c : u64 = f4 / den
        cs = cs + c
        me = me + ((kk as u64) * c)
        kk = kk + 1i64
    }
    if cs != 16u64 { return 284u64 }
    if me != 32u64 { return 284u64 }
    /* mean = 32/16 = 2 = n*p exactly; ledger certainty 16/16 = 1 */
    if py_rat_cmp(py_rat_frac(me as i64, 16i64), py_rat_i64(2i64)) != 0i64 { return 284u64 }
    if py_err() != 0u64 { return 284u64 }
    return 0u64
}
fn su_arm285() -> u64 {
    /* THE SCROLLS: the derived facts read by EIDOLOS, the canonical
     * addresses minted DETERMINISTICALLY, consequences ENTAILED that are
     * nowhere in the text, reversals REFUSED (negative controls) */
    let dg : u64 = "[mult_gcd_2 = node_order] [mult_slope_2 = node_order] [graze_1 ~ zero_relvel] [miss_0 < graze_1] [graze_1 < cross_2] [product_formula = place_ledger_1]" as u64
    let db : u64 = "[chsh_classical_2 < chsh_quantum_2sqrt2] [chsh_quantum_2sqrt2 < chsh_algebraic_4] [born_exponent_2 = parseval_invariant] [parseval_invariant = frame_total_1] [bell_det_half ~ entangled]" as u64
    let lg : u64 = su_strlen(dg)
    let lb : u64 = su_strlen(db)
    /* gravity scroll: seal, and seal AGAIN -- one address */
    eol_reset()
    if eol_read(dg, lg) < 0i64 { return 285u64 }
    let a1 : u64 = eol_addr()
    if a1 == 0u64 { return 285u64 }
    /* entailed consequence NOT in the text: congruence through node_order */
    let qa : u64 = "mult_gcd_2" as u64
    let qb : u64 = "mult_slope_2" as u64
    if eol_entails(qa, su_strlen(qa), 2u64, qb, su_strlen(qb)) != 1u64 { return 285u64 }
    /* entailed BELOW transitivity: miss_0 < cross_2 */
    let qm : u64 = "miss_0" as u64
    let qc : u64 = "cross_2" as u64
    if eol_entails(qm, su_strlen(qm), 0u64, qc, su_strlen(qc)) != 1u64 { return 285u64 }
    /* the reversal REFUSES */
    if eol_entails(qc, su_strlen(qc), 0u64, qm, su_strlen(qm)) != 0u64 { return 285u64 }
    eol_reset()
    if eol_read(dg, lg) < 0i64 { return 285u64 }
    if eol_addr() != a1 { return 285u64 }
    SU_AG = a1
    /* born scroll */
    eol_reset()
    if eol_read(db, lb) < 0i64 { return 285u64 }
    let a2 : u64 = eol_addr()
    if a2 == 0u64 { return 285u64 }
    let ra : u64 = "chsh_classical_2" as u64
    let rb : u64 = "chsh_algebraic_4" as u64
    if eol_entails(ra, su_strlen(ra), 0u64, rb, su_strlen(rb)) != 1u64 { return 285u64 }
    if eol_entails(rb, su_strlen(rb), 0u64, ra, su_strlen(ra)) != 0u64 { return 285u64 }
    let sa : u64 = "born_exponent_2" as u64
    let sb : u64 = "frame_total_1" as u64
    if eol_entails(sa, su_strlen(sa), 2u64, sb, su_strlen(sb)) != 1u64 { return 285u64 }
    eol_reset()
    if eol_read(db, lb) < 0i64 { return 285u64 }
    if eol_addr() != a2 { return 285u64 }
    SU_AB = a2
    /* the two scrolls are DIFFERENT theorems: distinct addresses */
    if a1 == a2 { return 285u64 }
    return 0u64
}
fn su_selfprove() -> u64 @export {
    let a0 : u64 = su_arm280()
    if a0 != 0u64 { return a0 }
    let a1 : u64 = su_arm281()
    if a1 != 0u64 { return a1 }
    let a2 : u64 = su_arm282()
    if a2 != 0u64 { return a2 }
    let a3 : u64 = su_arm283()
    if a3 != 0u64 { return a3 }
    let a4 : u64 = su_arm284()
    if a4 != 0u64 { return a4 }
    let a5 : u64 = su_arm285()
    if a5 != 0u64 { return a5 }
    return 0u64
}
