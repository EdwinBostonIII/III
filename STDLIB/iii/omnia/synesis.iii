/* the letter of alphabet slot l: h x z s */
fn sy_cw_char(l: u64) -> u8 {
    if l == 0u64 { return 104u8 }
    if l == 1u64 { return 120u8 }
    if l == 2u64 { return 122u8 }
    return 115u8
}
/* word index -> letters into a target buffer (1 = SY_WB1, 2 = SY_WB2);
 * returns the length.  0 is the empty word, spelled i. */
fn sy_cw_letters(w: u64, which: u64) -> u64 {
    let mut n : u64 = 0u64
    if w == 0u64 {
        if which == 1u64 { SY_WB1[0u64] = 105u8 } else { SY_WB2[0u64] = 105u8 }
        return 1u64
    }
    if w < 5u64 {
        if which == 1u64 { SY_WB1[0u64] = sy_cw_char(w - 1u64) } else { SY_WB2[0u64] = sy_cw_char(w - 1u64) }
        return 1u64
    }
    if w < 21u64 {
        let t : u64 = w - 5u64
        if which == 1u64 {
            SY_WB1[0u64] = sy_cw_char(t >> 2u64)
            SY_WB1[1u64] = sy_cw_char(t & 3u64)
        } else {
            SY_WB2[0u64] = sy_cw_char(t >> 2u64)
            SY_WB2[1u64] = sy_cw_char(t & 3u64)
        }
        return 2u64
    }
    let t2 : u64 = w - 21u64
    if which == 1u64 {
        SY_WB1[0u64] = sy_cw_char(t2 >> 4u64)
        SY_WB1[1u64] = sy_cw_char((t2 >> 2u64) & 3u64)
        SY_WB1[2u64] = sy_cw_char(t2 & 3u64)
    } else {
        SY_WB2[0u64] = sy_cw_char(t2 >> 4u64)
        SY_WB2[1u64] = sy_cw_char((t2 >> 2u64) & 3u64)
        SY_WB2[2u64] = sy_cw_char(t2 & 3u64)
    }
    return 3u64
}
/* decide two chart words by RUNNING the circuits (kyma's own decider) */
fn sy_cw_decide(a: u64, b: u64) -> u64 {
    let la : u64 = sy_cw_letters(a, 1u64)
    let lb : u64 = sy_cw_letters(b, 2u64)
    return ky_wdecide((&SY_WB1) as u64, la, (&SY_WB2) as u64, lb)
}
/* append one chart marker "[word R < gate_word]" (every representative
 * carries it, so the chart scroll mentions EVERY word -- singleton classes
 * included -- and eidolos's class count can be demanded exactly) */
fn sy_cw_mark(rep: u64) -> u64 {
    let mut n : u64 = 0u64
    SY_CLB[n] = 91u8    n = n + 1u64
    SY_CLB[n] = 119u8   n = n + 1u64
    SY_CLB[n] = 111u8   n = n + 1u64
    SY_CLB[n] = 114u8   n = n + 1u64
    SY_CLB[n] = 100u8   n = n + 1u64
    SY_CLB[n] = 32u8    n = n + 1u64
    let la : u64 = sy_cw_letters(rep, 1u64)
    let mut k : u64 = 0u64
    while k < la { SY_CLB[n] = SY_WB1[k]   n = n + 1u64   k = k + 1u64 }
    SY_CLB[n] = 32u8    n = n + 1u64
    SY_CLB[n] = 60u8    n = n + 1u64
    SY_CLB[n] = 32u8    n = n + 1u64
    SY_CLB[n] = 103u8   n = n + 1u64
    SY_CLB[n] = 97u8    n = n + 1u64
    SY_CLB[n] = 116u8   n = n + 1u64
    SY_CLB[n] = 101u8   n = n + 1u64
    SY_CLB[n] = 95u8    n = n + 1u64
    SY_CLB[n] = 119u8   n = n + 1u64
    SY_CLB[n] = 111u8   n = n + 1u64
    SY_CLB[n] = 114u8   n = n + 1u64
    SY_CLB[n] = 100u8   n = n + 1u64
    SY_CLB[n] = 93u8    n = n + 1u64
    if eol_read((&SY_CLB) as u64, n) < 0i64 { return SY_SENT }
    return 0u64
}
/* append one chart claim "[word A = word REP]" to the standing scroll */
fn sy_cw_speak(w: u64, rep: u64) -> u64 {
    let mut n : u64 = 0u64
