/* STDLIB/iii/omnia/synesis.iii -- SYNESIS (the KNOWING-TOGETHER): the organ
 * that CONVENES the testimony of every summit-cluster organ into ONE scroll
 * and derives what only the union knows.
 *
 * THE UNKEPT PROMISE, KEPT: eidolos was built so that "two systems drop
 * their brackets side by side and eol_entails answers what the union KNOWS,
 * including what neither said alone" -- and until this organ, no two organs
 * of the organism ever did.  Each spoke a private sealed scroll; the union
 * closure of the fleet's knowledge was never taken.  SYNESIS takes it:
 *   - each cluster organ EXPORTS a testimony (xx_testify) -- its proven laws
 *     spoken in the one tongue, every claim mapping to a standing arm;
 *   - synesis reads all eight side by side, proves the union coherent, and
 *     mints THE ONE ADDRESS of everything the cluster knows;
 *   - the SURPLUS is derived: cross-organ theorems entailed by the union
 *     that NO single testimony entails alone (deficit = orbit_decision;
 *     work_total = faulhaber_mint; born_rule = forced_exponent; ...) --
 *     with the COMPLETE 8-drop knockout matrix as teeth: dropping each
 *     testimony kills exactly the theorems that ride it and spares the rest;
 *   - the PROVINCE MAP records which organ introduced which word, and which
 *     words are spoken jointly (the shared vocabulary IS the bridge);
 *   - THE FRONTIER: the machine enumerates its own ignorance -- every pair
 *     of subjects with no derived relation in any verb, counted exactly;
 *   - THE ABDUCTION: for a shape-found gap, the single-claim bridges that
 *     would close it are enumerated COMPLETELY over the gap's classes
 *     (scope: complete for mirror-free goal classes, asserted before use);
 *   - THE DISCHARGE: a proposed bridge whose two sides are metered fold
 *     families is DECIDED by noesis's real meter (no_meter, the complete
 *     w=8 image) -- the true bridge is admitted and SPOKEN, the false
 *     variants are REFUTED and never enter, the undecidable are counted;
 *     then the union is re-derived and entails what it could not before:
 *     notice-gap -> decide-by-computation -> know, with no author anywhere;
 *   - THE EXPLANATION: syn_why reconstructs the chain of STATED claims
 *     behind a derived entailment (why the machine knows what it knows),
 *     verified stepwise and length-checked by a SECOND independent engine;
 *   - knowledge is MONOTONE: the discharged bridge removes exactly its own
 *     gap pairs from the frontier and disconnects nothing.
 *
 * THE ARMS (truth is a CONDITION OF MOTION, arms 330..339, NO gate of its
 * own -- the summit gate compiles and drives this organ):
 *   330 THE CONVENING: eight testimonies side by side, coherent, ONE
 *       deterministic address; each testimony alone also coherent; the
 *       union claim count is the exact sum of the parts.
 *   331 THE SURPLUS: eight named cross-organ theorems entailed by the union
 *       and by NONE of the eight single testimonies; the mechanical sweep
 *       counts at least eight surplus subject pairs.
 *   332 THE KNOCKOUT MATRIX: all eight drop-one convenings -- each named
 *       theorem dies exactly when a load-bearing testimony is dropped and
 *       survives every other drop.
 *   333 THE PROVINCE MAP: provenance watermarks; the shared vocabulary
 *       derived (six joint words, each verified in its speakers, absent
 *       elsewhere); every organ also keeps a private word.
 *   334 THE FRONTIER: the unconnected subject pairs counted twice (same
 *       count); the named absence (sdiv 3, erasure 3) IS on the frontier;
 *       class-joined pairs are NOT.
 *   335 THE ABDUCTION: the complete single-claim bridge set for the named
 *       gap (twelve candidates over the two classes); the cycle-making
 *       candidate is REFUSED by law, counted.
 *   336 THE DISCHARGE: the meter decides -- [sdiv 3 = erasure 3] TRUE
 *       (image 32 = 2^(8-3), both sdiv spellings agreeing), spoken, the
 *       union re-derived, [sdiv 3 = shr 3] NOW entailed (fold-deficit
 *       invariance re-derived at the knowledge level); [sdiv 3 = erasure 4]
 *       and [sdiv 3 = umod 3] REFUTED by the same meter, never spoken;
 *       order/mirror candidates counted undecidable; the union address
 *       MOVES (knowledge grew) and re-derives deterministically.
 *   337 THE MONOTONE FRONTIER: after the discharge the frontier loses
 *       EXACTLY the three pairs the bridge closes and nothing else; no
 *       previously-connected pair disconnects.
 *   338 THE EXPLANATION: the why-chains of two surplus theorems -- pure
 *       congruence (deficit = orbit_decision) and mixed congruence-order
 *       (tower_element < algebraic_number) -- reconstructed as stated-claim
 *       chains, verified stepwise, length 2, no shorter path, and the
 *       second engine (layered distance) agrees.
 *   339 THE ONE NAME + THE SCROLL: the union's bus witness differs from
 *       every single testimony's witness (the union has MORE geometry);
 *       synesis's own law sealed by EIDOLOS with derived entailments and
 *       refused reversals, address deterministic.
 *   340 THE FLEET: every decider proven on its own ground -- kyma runs the
 *       circuits (hzh = x, ss = z, xx = i; hxh = z NOT x; unknown letters
 *       refused), meris runs BOTH partition engines (p(10) = 42), pyrgos
 *       runs the tower sign (the denesting nest56 = sum23), klisi walks its
 *       digits (depth of 48 is 4, of 0 is 64).
 *   341 THE ROUTED WALK: the whole frontier walked, every gap the fleet can
 *       read DECIDED, the truths spoken as a minimal spanning ledger
 *       (pending joins compose with standing classes), the union re-derived.
 *   342 THE GROWTH LEDGER: a new deterministic name, nothing disconnected,
 *       the residue smaller by exactly the closed pairs.
 *   343 THE FIXPOINT: re-walking the grown state speaks NOTHING -- the
 *       fleet is exhausted; the residue is undecided, not undecided-silently.
 *   344 THE KEYSTONE INSTANCE: [mul 48 = depth 4] -- true only because
 *       noesis's image meter and klisi's digit engine AGREE (deficit =
 *       valuation, instance-wise, two organs, one number).
 *   345 THE DIALECTIC SCROLL: the law sealed; the post-dialectic union left
 *       standing -- the organism rests in everything it has decided.
 *   346 THE CAYLEY CHART: the machine AUTHORS its own space -- all 85
 *       gate-words of length <= 3, pairwise decided by running circuits;
 *       the 32 operator classes EMERGE; congruence complete (3570 pairs,
 *       zero exceptions); the spanning scroll sealed and eidolos's own
 *       closure re-derives the same partition (two engines, one chart).
 *   347 THE KEYSTONE SWEEP: deficit = valuation for EVERY multiplier byte
 *       (254 two-organ agreements), the dyadic histogram DERIVED
 *       (127/64/32/16/8/4/2/1 -- the halving law), the census sealed.
 *
 * SCOPE (the eidolon law): the surplus, frontier, abduction and knockout
 * are exact over the standing testimony set; the explanation engine walks
 * congruence and order chains (mirror-reversal chains are outside its walk
 * and asserted absent from its goals).  NIH: composes eidolos (the tongue),
 * the eight testimonies, and noesis's meter.  Sibling of gnosis (knows),
 * noesis (meters), mneme (places): synesis COMPREHENDS.  Ring R-1. */
module omnia_synesis

extern @abi(c-msvc-x64) fn eol_reset() -> i32 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_read(addr: u64, len: u64) -> i64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_addr() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_entails(a_addr: u64, a_len: u64, verb: u64, b_addr: u64, b_len: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_lawcheck() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_claims() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_things() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_claim_a(i: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_claim_v(i: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_claim_b(i: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_thing_len(t: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_thing_byte(t: u64, k: u64) -> u8 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_class_of_thing(t: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_class_count() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_reaches(ci: u64, cj: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_mirror_class(ci: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_witness() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn py_testify() -> u64 from "pyrgos.iii"
extern @abi(c-msvc-x64) fn rz_testify() -> u64 from "riza.iii"
extern @abi(c-msvc-x64) fn ky_testify() -> u64 from "kyma.iii"
extern @abi(c-msvc-x64) fn ms_testify() -> u64 from "meris.iii"
extern @abi(c-msvc-x64) fn kl_testify() -> u64 from "klisi.iii"
extern @abi(c-msvc-x64) fn su_testify() -> u64 from "summit.iii"
extern @abi(c-msvc-x64) fn gn_testify() -> u64 from "gnosis.iii"
extern @abi(c-msvc-x64) fn no_testify() -> u64 from "noesis.iii"
extern @abi(c-msvc-x64) fn no_meter(kind: u64, p: u64) -> u64 from "noesis.iii"
extern @abi(c-msvc-x64) fn ky_wdecide(aptr: u64, alen: u64, bptr: u64, blen: u64) -> u64 from "kyma.iii"
extern @abi(c-msvc-x64) fn ms_pdecide(ka: u64, na: u64, kb: u64, nb: u64) -> u64 from "meris.iii"
extern @abi(c-msvc-x64) fn py_rdecide(a: u64, b: u64) -> u64 from "pyrgos.iii"
extern @abi(c-msvc-x64) fn kl_vdepth(x: u64) -> u64 from "klisi.iii"

const SY_SENT : u64 = 18446744073709551615u64
const SY_ORGS : u64 = 8u64
const SY_SCAP : u64 = 96u64              /* subject roster                     */
const SY_ACAP : u64 = 2048u64            /* subject byte arena                 */
const SY_V_BELOW : u64 = 0u64
const SY_V_REFLECT : u64 = 1u64
const SY_V_FLAT : u64 = 2u64

/* ==================== the convening state ==================== */
var SY_WM  : [u64; 9]                    /* thing watermark after testimony k  */
var SY_CWM : [u64; 9]                    /* claim watermark after testimony k  */
var SY_SO  : [u64; 96]                   /* subject byte offset (arena)        */
var SY_SL  : [u64; 96]                   /* subject byte length                */
var SY_SP  : [u64; 96]                   /* province: first speaker            */
var SY_ST  : [u64; 96]                   /* thing id on the current convening  */
var SY_SN  : u64 = 0u64
var SY_AB  : [u8; 2048]
var SY_AN  : u64 = 0u64

/* the connection bitsets (subject x subject), before/after the discharge */
var SY_CON0 : [u64; 144]
var SY_CON1 : [u64; 144]

/* named verdict counters (every refusal counted, never silent) */
var SY_RUND : u64 = 0u64                 /* meter-undecidable candidates       */
var SY_RREF : u64 = 0u64                 /* meter-refuted candidates           */
var SY_RLAW : u64 = 0u64                 /* law-refused candidates (incoherent)*/

/* the discharged bridge (canonical claim text) */
var SY_BR  : [u8; 64]
var SY_BRN : u64 = 0u64

/* the why-chain (claim indices of the standing scroll) */
var SY_WC : [u64; 32]
var SY_WN : u64 = 0u64

/* why/dist scratch (module scope: the 64-local ceiling stays far away) */
var SY_DQ : [u64; 96]                    /* BFS queue of thing ids             */
var SY_DD : [u64; 96]                    /* distance per thing                 */
var SY_DP : [u64; 96]                    /* parent claim per thing             */

/* abduction scratch (module scope, W4): the goal-class member rosters */
var SY_MA : [u64; 8]
var SY_MB : [u64; 8]

/* ==================== THE DIALECTIC (arms 340..345) ====================
 * The discharge loop generalized into a standing faculty: a DECIDER FLEET.
 * Every subject that spells a fleet vocabulary routes to the organ that owns
 * it; every frontier gap whose two sides the fleet can read is DECIDED by
 * real computation -- kyma runs the circuits, meris runs both partition
 * engines, pyrgos runs the tower sign, klisi walks its digits, noesis
 * meters images -- and the joint domain demands TWO organs agree before a
 * verdict exists.  Truths are spoken (a minimal spanning set), the union
 * re-derives, and the fixpoint proves the fleet exhausted: what remains
 * unknown is exactly what no current decider can decide. */
var SY_DOMV : [u64; 96]                  /* subject -> (dom<<16)|(kind<<8)|p   */
var SY_UFD : [u64; 96]                   /* pending-join forest (class-seeded) */
var SY_LG : [u8; 1024]                   /* the spoken-truth ledger            */
var SY_LGN : u64 = 0u64
var SY_DSP : u64 = 0u64                  /* truths spoken                      */
var SY_DRF : u64 = 0u64                  /* candidates refuted                 */
var SY_DUN : u64 = 0u64                  /* routable-but-undecided             */
var SY_RES0 : u64 = 0u64                 /* frontier before the pass           */
var SY_RES : u64 = 0u64                  /* the residue after                  */
var SY_DADDR : u64 = 0u64                /* the post-dialectic union address   */
var SY_DSCROLL : u64 = 0u64              /* the dialectic scroll               */

fn syn_spoke() -> u64 @export { return SY_DSP }
fn syn_refuted() -> u64 @export { return SY_DRF }
fn syn_undecided() -> u64 @export { return SY_DUN }
fn syn_residue() -> u64 @export { return SY_RES }
fn syn_dialectic_addr() -> u64 @export { return SY_DADDR }
fn syn_dialectic_scroll() -> u64 @export { return SY_DSCROLL }

/* ==================== THE HARVEST (arms 346..347) ====================
 * The machine AUTHORS its own knowledge space.  The chart: every gate-word
 * of length <= 3 over {h,x,z,s} plus the empty word -- 85 words the machine
 * enumerates itself -- pairwise decided by RUNNING the circuits; the
 * equivalence classes of its own operator algebra EMERGE; the spanning
 * equalities seal into a dedicated scroll (SHARDED: the standing union is
 * untouched, honoring the manifold's 64-lane boundary).  The sweep: the
 * deficit = valuation keystone decided for EVERY multiplier byte by the
 * two-organ agreement, the complete dyadic histogram derived. */
var SY_CWCLS : [u64; 85]                 /* word -> representative word        */
var SY_CWN : u64 = 0u64                  /* the class count (EMERGES)          */
var SY_WB1 : [u8; 8]
var SY_WB2 : [u8; 8]
var SY_CLB : [u8; 64]                    /* chart claim build buffer           */
var SY_CAYADDR : u64 = 0u64
var SY_SWADDR : u64 = 0u64

fn syn_cayley_addr() -> u64 @export { return SY_CAYADDR }
fn syn_cayley_classes() -> u64 @export { return SY_CWN }
fn syn_cayley_words() -> u64 @export { return 85u64 }
fn syn_sweep_addr() -> u64 @export { return SY_SWADDR }

/* sealed results */
var SY_UADDR0 : u64 = 0u64               /* the union address before discharge */
var SY_UADDR  : u64 = 0u64               /* the union address after discharge  */
var SY_SCROLL : u64 = 0u64               /* the synesis meta-scroll address    */
var SY_SURP   : u64 = 0u64               /* mechanical surplus pair count      */
var SY_SHARED : u64 = 0u64               /* words spoken by >= 2 testimonies   */
var SY_FRONT  : u64 = 0u64               /* standing frontier count            */

fn syn_addr() -> u64 @export { return SY_SCROLL }
fn syn_union_addr() -> u64 @export { return SY_UADDR }
fn syn_surplus_count() -> u64 @export { return SY_SURP }
fn syn_shared_count() -> u64 @export { return SY_SHARED }
fn syn_frontier_count() -> u64 @export { return SY_FRONT }
fn syn_bridge_len() -> u64 @export { return SY_BRN }
fn syn_bridge_byte(i: u64) -> u8 @export {
    if i < SY_BRN { return SY_BR[i] }
    return 0u8
}

fn sy_slen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut n : u64 = 0u64
    while p[n] != 0u8 { n = n + 1u64 }
    return n
}
/* the fixed convening order (the summit gate's own organ order) */
fn sy_testimony(k: u64) -> u64 {
    if k == 0u64 { return py_testify() }
    if k == 1u64 { return rz_testify() }
    if k == 2u64 { return ky_testify() }
    if k == 3u64 { return ms_testify() }
    if k == 4u64 { return kl_testify() }
    if k == 5u64 { return su_testify() }
    if k == 6u64 { return gn_testify() }
    return no_testify()
}
/* convene the testimonies selected by mask; optionally speak the discharged
 * bridge; optionally record the province watermarks.  -1 on refusal. */
fn sy_convene(mask: u64, bridge: u64, rec: u64) -> i64 {
    eol_reset()
    if rec == 1u64 { SY_WM[0u64] = 0u64   SY_CWM[0u64] = 0u64 }
    let mut k : u64 = 0u64
    while k < SY_ORGS {
        if ((mask >> k) & 1u64) == 1u64 {
            let t : u64 = sy_testimony(k)
            if eol_read(t, sy_slen(t)) < 0i64 { return -1i64 }
        }
        if rec == 1u64 {
            SY_WM[k + 1u64] = eol_things()
            SY_CWM[k + 1u64] = eol_claims()
        }
        k = k + 1u64
    }
    if bridge == 1u64 { if SY_BRN > 0u64 {
        if eol_read((&SY_BR) as u64, SY_BRN) < 0i64 { return -1i64 }
    } }
    return eol_claims() as i64
}
/* harvest the subject roster off the standing full convening: every phrase
 * thing (mentions carry a leading bracket and are skipped), with provenance
 * from the watermarks.  Returns the subject count. */
fn sy_harvest() -> u64 {
    SY_SN = 0u64
    SY_AN = 0u64
    let tn : u64 = eol_things()
    let mut t : u64 = 0u64
    while t < tn {
        let ln : u64 = eol_thing_len(t)
        if ln > 0u64 { if eol_thing_byte(t, 0u64) != 91u8 {
            if SY_SN >= SY_SCAP { return SY_SENT }
            if SY_AN + ln > SY_ACAP { return SY_SENT }
            let mut k : u64 = 0u64
            while k < ln { SY_AB[SY_AN + k] = eol_thing_byte(t, k)   k = k + 1u64 }
            SY_SO[SY_SN] = SY_AN
            SY_SL[SY_SN] = ln
            SY_ST[SY_SN] = t
            let mut pv : u64 = 0u64
            let mut w : u64 = 0u64
            while w < SY_ORGS {
                if t >= SY_WM[w] { if t < SY_WM[w + 1u64] { pv = w } }
                w = w + 1u64
            }
            SY_SP[SY_SN] = pv
            SY_AN = SY_AN + ln
            SY_SN = SY_SN + 1u64
        } }
        t = t + 1u64
    }
    return SY_SN
}
/* find the interned thing carrying exactly these bytes; SENT if absent.
 * Pure reads -- never interns, so presence tests cannot pollute a scroll. */
fn sy_thing_of(off: u64, len: u64) -> u64 {
    let tn : u64 = eol_things()
    let mut t : u64 = 0u64
    while t < tn {
        if eol_thing_len(t) == len {
            let mut k : u64 = 0u64
            let mut same : u64 = 1u64
            while k < len {
                if eol_thing_byte(t, k) != SY_AB[off + k] { same = 0u64   k = len }
                k = k + 1u64
            }
            if same == 1u64 { return t }
        }
        t = t + 1u64
    }
    return SY_SENT
}
/* subject index by zero-terminated text (arena-free lookup for the arms) */
fn sy_sub_of(s: u64) -> u64 {
    let n : u64 = sy_slen(s)
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while i < SY_SN {
        if SY_SL[i] == n {
            let mut k : u64 = 0u64
            let mut same : u64 = 1u64
            while k < n {
                if SY_AB[SY_SO[i] + k] != p[k] { same = 0u64   k = n }
                k = k + 1u64
            }
            if same == 1u64 { return i }
        }
        i = i + 1u64
    }
    return SY_SENT
}
/* entailment by zero-terminated texts on the standing scroll */
fn sy_q(a: u64, v: u64, b: u64) -> u64 {
    return eol_entails(a, sy_slen(a), v, b, sy_slen(b))
}
/* are two subjects connected under ANY verb, either direction? */
fn sy_connected(i: u64, j: u64) -> u64 {
    let ci : u64 = eol_class_of_thing(SY_ST[i])
    let cj : u64 = eol_class_of_thing(SY_ST[j])
    if ci == SY_SENT { return 0u64 }
    if cj == SY_SENT { return 0u64 }
    if ci == cj { return 1u64 }
    if eol_reaches(ci, cj) == 1u64 { return 1u64 }
    if eol_reaches(cj, ci) == 1u64 { return 1u64 }
    if eol_mirror_class(ci) == cj { return 1u64 }
    return 0u64
}
/* fill a connection bitset (which: 0 or 1) over the harvested subjects;
 * returns the UNCONNECTED pair count (i < j).  Requires a clean lawcheck. */
fn sy_con_fill(which: u64) -> u64 {
    if eol_lawcheck() != 0u64 { return SY_SENT }
    let mut w : u64 = 0u64
    while w < 144u64 {
        if which == 0u64 { SY_CON0[w] = 0u64 } else { SY_CON1[w] = 0u64 }
        w = w + 1u64
    }
    let mut unc : u64 = 0u64
    let mut i : u64 = 0u64
    while i < SY_SN {
        let mut j : u64 = i + 1u64
        while j < SY_SN {
            let c : u64 = sy_connected(i, j)
            if c == 1u64 {
                let bit : u64 = (i * SY_SCAP) + j
                if which == 0u64 {
                    SY_CON0[bit >> 6u64] = SY_CON0[bit >> 6u64] | (1u64 << (bit & 63u64))
                } else {
                    SY_CON1[bit >> 6u64] = SY_CON1[bit >> 6u64] | (1u64 << (bit & 63u64))
                }
            } else { unc = unc + 1u64 }
            j = j + 1u64
        }
        i = i + 1u64
    }
    return unc
}
fn sy_con_get(which: u64, i: u64, j: u64) -> u64 {
    let bit : u64 = (i * SY_SCAP) + j
    if which == 0u64 { return (SY_CON0[bit >> 6u64] >> (bit & 63u64)) & 1u64 }
    return (SY_CON1[bit >> 6u64] >> (bit & 63u64)) & 1u64
}

/* ==================== the family meter (the discharge) ====================
 * A subject decodes as a metered family iff it spells one of:
 *   shr K | mul M | umod K | sdiv K | erasure E
 * The meter value is the COMPLETE w=8 image of the family (noesis no_meter);
 * an erasure class carries the expected image 2^(8-E) directly. */
fn sy_word_is(off: u64, len: u64, w: u64, wl: u64) -> u64 {
    if len < wl + 2u64 { return 0u64 }
    let p : *u8 = w as *u8
    let mut k : u64 = 0u64
    while k < wl {
        if SY_AB[off + k] != p[k] { return 0u64 }
        k = k + 1u64
    }
    if SY_AB[off + wl] != 32u8 { return 0u64 }
    return 1u64
}
fn sy_num_at(off: u64, len: u64, start: u64) -> u64 {
    let mut v : u64 = 0u64
    let mut k : u64 = start
    if k >= len { return SY_SENT }
    while k < len {
        let c : u8 = SY_AB[off + k]
        if c < 48u8 { return SY_SENT }
        if c > 57u8 { return SY_SENT }
        v = (v * 10u64) + ((c - 48u8) as u64)
        k = k + 1u64
    }
    return v
}
/* decode: (kind << 8) | param, kind 1 shr | 2 mul | 3 umod | 4 sdiv |
 * 5 erasure; 0 = not a metered family */
fn sy_famparse(off: u64, len: u64) -> u64 {
    if sy_word_is(off, len, "shr" as u64, 3u64) == 1u64 {
        let n : u64 = sy_num_at(off, len, 4u64)
        if n != SY_SENT { return (1u64 << 8u64) | n }
    }
    if sy_word_is(off, len, "mul" as u64, 3u64) == 1u64 {
        let n2 : u64 = sy_num_at(off, len, 4u64)
        if n2 != SY_SENT { return (2u64 << 8u64) | n2 }
    }
    if sy_word_is(off, len, "umod" as u64, 4u64) == 1u64 {
        let n3 : u64 = sy_num_at(off, len, 5u64)
        if n3 != SY_SENT { return (3u64 << 8u64) | n3 }
    }
    if sy_word_is(off, len, "sdiv" as u64, 4u64) == 1u64 {
        let n4 : u64 = sy_num_at(off, len, 5u64)
        if n4 != SY_SENT { return (4u64 << 8u64) | n4 }
    }
    if sy_word_is(off, len, "erasure" as u64, 7u64) == 1u64 {
        let n5 : u64 = sy_num_at(off, len, 8u64)
        if n5 != SY_SENT { return (5u64 << 8u64) | n5 }
    }
    return 0u64
}
/* the exact image of a decoded family; SENT = not meterable.  The sdiv
 * family is metered through BOTH spellings (bias sequence and hardware
 * route) and they must agree -- the two-engine law inside the meter. */
fn sy_meter_of(fam: u64) -> u64 {
    let kind : u64 = fam >> 8u64
    let p : u64 = fam & 255u64
    if kind == 1u64 { return no_meter(2u64, p) }
    if kind == 2u64 { return no_meter(0u64, p) }
    if kind == 3u64 { return no_meter(3u64, (1u64 << p) - 1u64) }
    if kind == 4u64 {
        let a : u64 = no_meter(4u64, p)
        let b : u64 = no_meter(5u64, p)
        if a != b { return SY_SENT }
        return a
    }
    if kind == 5u64 { return 1u64 << (8u64 - p) }
    return SY_SENT
}
/* decide a proposed = bridge between two subjects by the meter:
 * 1 TRUE (equal images) | 0 REFUTED | 2 UNDECIDABLE -- counted. */
fn sy_decide(i: u64, j: u64) -> u64 {
    let fa : u64 = sy_famparse(SY_SO[i], SY_SL[i])
    let fb : u64 = sy_famparse(SY_SO[j], SY_SL[j])
    if fa == 0u64 { SY_RUND = SY_RUND + 1u64   return 2u64 }
    if fb == 0u64 { SY_RUND = SY_RUND + 1u64   return 2u64 }
    let ma : u64 = sy_meter_of(fa)
    let mb : u64 = sy_meter_of(fb)
    if ma == SY_SENT { SY_RUND = SY_RUND + 1u64   return 2u64 }
    if mb == SY_SENT { SY_RUND = SY_RUND + 1u64   return 2u64 }
    if ma == mb { return 1u64 }
    SY_RREF = SY_RREF + 1u64
    return 0u64
}
/* build the canonical claim text "[<a> <verb> <b>]" into the bridge buffer */
fn sy_bridge_build(i: u64, v: u64, j: u64) -> u64 {
    SY_BRN = 0u64
    SY_BR[SY_BRN] = 91u8
    SY_BRN = SY_BRN + 1u64
    let mut k : u64 = 0u64
    while k < SY_SL[i] { SY_BR[SY_BRN] = SY_AB[SY_SO[i] + k]   SY_BRN = SY_BRN + 1u64   k = k + 1u64 }
    SY_BR[SY_BRN] = 32u8
    SY_BRN = SY_BRN + 1u64
    let mut vc : u8 = 61u8
    if v == SY_V_BELOW { vc = 60u8 }
    if v == SY_V_REFLECT { vc = 126u8 }
    SY_BR[SY_BRN] = vc
    SY_BRN = SY_BRN + 1u64
    SY_BR[SY_BRN] = 32u8
    SY_BRN = SY_BRN + 1u64
    k = 0u64
    while k < SY_SL[j] { SY_BR[SY_BRN] = SY_AB[SY_SO[j] + k]   SY_BRN = SY_BRN + 1u64   k = k + 1u64 }
    SY_BR[SY_BRN] = 93u8
    SY_BRN = SY_BRN + 1u64
    return SY_BRN
}

/* ==================== the explanation (why the machine knows) ====================
 * BFS over the STATED claims of the standing scroll: = edges join both ways,
 * < edges descend one way.  The chain is the parent-claim path; the second
 * engine below re-derives the distance by layered relaxation.  Scope: the
 * walk covers congruence and order chains (mirror-reversal chains excluded
 * and asserted absent from the goals posed). */
fn sy_edge_ok(c: u64, src: u64, dirv: u64) -> u64 {
    /* does claim c leave `src`, and where to?  returns target | SENT.
     * dirv: the goal verb -- FLAT goals walk only = edges; BELOW goals walk
     * = both ways and < forward. */
    let a : u64 = eol_claim_a(c)
    let b : u64 = eol_claim_b(c)
    let v : u64 = eol_claim_v(c)
    if v == SY_V_FLAT {
        if a == src { return b }
        if b == src { return a }
        return SY_SENT
    }
    if v == SY_V_BELOW { if dirv == SY_V_BELOW {
        if a == src { return b }
    } }
    return SY_SENT
}
/* chain from thing ta to thing tb under goal verb dirv; fills SY_WC/SY_WN.
 * returns 0 found | 1 not found. */
fn sy_why(ta: u64, tb: u64, dirv: u64) -> u64 {
    let tn : u64 = eol_things()
    if tn > 96u64 { return 1u64 }
    let mut i : u64 = 0u64
    while i < tn { SY_DD[i] = SY_SENT   SY_DP[i] = SY_SENT   i = i + 1u64 }
    SY_DD[ta] = 0u64
    SY_DQ[0u64] = ta
    let mut qh : u64 = 0u64
    let mut qt : u64 = 1u64
    let cn : u64 = eol_claims()
    while qh < qt {
        let cur : u64 = SY_DQ[qh]
        qh = qh + 1u64
        let mut c : u64 = 0u64
        while c < cn {
            let nx : u64 = sy_edge_ok(c, cur, dirv)
            if nx != SY_SENT { if nx < 96u64 { if SY_DD[nx] == SY_SENT {
                SY_DD[nx] = SY_DD[cur] + 1u64
                SY_DP[nx] = c
                if qt < 96u64 { SY_DQ[qt] = nx   qt = qt + 1u64 }
            } } }
            c = c + 1u64
        }
    }
    if SY_DD[tb] == SY_SENT { return 1u64 }
    /* unwind the parent chain (reversed, then flipped in place) */
    SY_WN = 0u64
    let mut at : u64 = tb
    while at != ta {
        let pc : u64 = SY_DP[at]
        if pc == SY_SENT { return 1u64 }
        if SY_WN >= 32u64 { return 1u64 }
        SY_WC[SY_WN] = pc
        SY_WN = SY_WN + 1u64
        /* step back across claim pc */
        let a : u64 = eol_claim_a(pc)
        let b : u64 = eol_claim_b(pc)
        if a == at { at = b } else { at = a }
        if SY_DD[at] == SY_SENT { return 1u64 }
    }
    let mut lo : u64 = 0u64
    let mut hi : u64 = SY_WN
    while lo + 1u64 < hi {
        hi = hi - 1u64
        let t : u64 = SY_WC[lo]
        SY_WC[lo] = SY_WC[hi]
        SY_WC[hi] = t
        lo = lo + 1u64
    }
    return 0u64
}
/* THE SECOND ENGINE: layered relaxation distance (no queue, no parents --
 * nothing shared with the BFS but the claims themselves) */
fn sy_dist(ta: u64, tb: u64, dirv: u64) -> u64 {
    let tn : u64 = eol_things()
    if tn > 96u64 { return SY_SENT }
    let mut i : u64 = 0u64
    while i < tn { SY_DD[i] = SY_SENT   i = i + 1u64 }
    SY_DD[ta] = 0u64
    let cn : u64 = eol_claims()
    let mut round : u64 = 0u64
    while round < tn {
        let mut moved : u64 = 0u64
        let mut t : u64 = 0u64
        while t < tn {
            if SY_DD[t] == round {
                let mut c : u64 = 0u64
                while c < cn {
                    let nx : u64 = sy_edge_ok(c, t, dirv)
                    if nx != SY_SENT { if nx < 96u64 { if SY_DD[nx] == SY_SENT {
                        SY_DD[nx] = round + 1u64
                        moved = 1u64
                    } } }
                    c = c + 1u64
                }
            }
            t = t + 1u64
        }
        if moved == 0u64 { round = tn } else { round = round + 1u64 }
    }
    return SY_DD[tb]
}

/* ==================== the named surplus (the eight theorems) ==================== */
fn sy_theorem_a(n: u64) -> u64 {
    if n == 0u64 { return "deficit" as u64 }
    if n == 1u64 { return "deficit" as u64 }
    if n == 2u64 { return "orbit_decision" as u64 }
    if n == 3u64 { return "arrival_count" as u64 }
    if n == 4u64 { return "work_total" as u64 }
    if n == 5u64 { return "born_rule" as u64 }
    if n == 6u64 { return "invertible_word" as u64 }
    return "tower_element" as u64
}
fn sy_theorem_b(n: u64) -> u64 {
    if n == 0u64 { return "orbit_decision" as u64 }
    if n == 1u64 { return "inverse_refusal" as u64 }
    if n == 2u64 { return "inverse_refusal" as u64 }
    if n == 3u64 { return "newton_iteration" as u64 }
    if n == 4u64 { return "faulhaber_mint" as u64 }
    if n == 5u64 { return "forced_exponent" as u64 }
    if n == 6u64 { return "zero_heat" as u64 }
    return "algebraic_number" as u64
}
fn sy_theorem_v(n: u64) -> u64 {
    if n == 7u64 { return SY_V_BELOW }
    return SY_V_FLAT
}
/* which testimonies are load-bearing for theorem n (bitmask over organs
 * 0 py, 1 rz, 2 ky, 3 ms, 4 kl, 5 su, 6 gn, 7 no) */
fn sy_theorem_bearers(n: u64) -> u64 {
    if n == 0u64 { return 192u64 }        /* gnosis + noesis                    */
    if n == 1u64 { return 144u64 }        /* klisi + noesis                     */
    if n == 2u64 { return 80u64 }         /* klisi + gnosis                     */
    if n == 3u64 { return 80u64 }         /* klisi + gnosis                     */
    if n == 4u64 { return 72u64 }         /* meris + gnosis                     */
    if n == 5u64 { return 36u64 }         /* kyma + summit                      */
    if n == 6u64 { return 144u64 }        /* klisi + noesis                     */
    return 3u64                           /* pyrgos + riza                      */
}
fn sy_check_theorem(n: u64) -> u64 {
    return sy_q(sy_theorem_a(n), sy_theorem_v(n), sy_theorem_b(n))
}

/* ==================== the fleet's vocabulary and router ==================== */
fn sy_ab_is(off: u64, len: u64, s: u64) -> u64 {
    let n : u64 = sy_slen(s)
    if n != len { return 0u64 }
    let p : *u8 = s as *u8
    let mut k : u64 = 0u64
    while k < n {
        if SY_AB[off + k] != p[k] { return 0u64 }
        k = k + 1u64
    }
    return 1u64
}
fn sy_radname(off: u64, len: u64) -> u64 {
    if sy_ab_is(off, len, "nest56" as u64) == 1u64 { return 1u64 }
    if sy_ab_is(off, len, "sum23" as u64) == 1u64 { return 2u64 }
    if sy_ab_is(off, len, "sum25" as u64) == 1u64 { return 3u64 }
    return 0u64
}
/* the domain of a subject: 0 none | 1 fold-family | 2 digit-depth |
 * 3 gate-word | 4 partition | 5 radical -- packed (dom<<16)|(kind<<8)|param
 * (a dom-3 param is the SUBJECT INDEX: the letters live in the arena) */
fn sy_dom(i: u64) -> u64 {
    let off : u64 = SY_SO[i]
    let len : u64 = SY_SL[i]
    let f : u64 = sy_famparse(off, len)
    if f != 0u64 { return (1u64 << 16u64) | f }
    if sy_word_is(off, len, "depth" as u64, 5u64) == 1u64 {
        let n : u64 = sy_num_at(off, len, 6u64)
        if n != SY_SENT { return (2u64 << 16u64) | n }
    }
    if sy_word_is(off, len, "word" as u64, 4u64) == 1u64 {
        if len > 5u64 { return (3u64 << 16u64) | i }
    }
    if sy_word_is(off, len, "p" as u64, 1u64) == 1u64 {
        let n2 : u64 = sy_num_at(off, len, 2u64)
        if n2 != SY_SENT { return (4u64 << 16u64) | n2 }
    }
    if sy_word_is(off, len, "pcount" as u64, 6u64) == 1u64 {
        let n3 : u64 = sy_num_at(off, len, 7u64)
        if n3 != SY_SENT { return (4u64 << 16u64) | (1u64 << 8u64) | n3 }
    }
    if sy_word_is(off, len, "radical" as u64, 7u64) == 1u64 {
        let rid : u64 = sy_radname(off + 8u64, len - 8u64)
        if rid != 0u64 { return (5u64 << 16u64) | rid }
    }
    return 0u64
}
/* the deficit of a metered family from its complete image: 8 - log2(image),
 * refusing non-powers (SENT) */
fn sy_img_deficit(fam: u64) -> u64 {
    let img : u64 = sy_meter_of(fam)
    if img == SY_SENT { return SY_SENT }
    if img == 0u64 { return SY_SENT }
    let mut d : u64 = 0u64
    let mut v : u64 = img
    while (v & 1u64) == 0u64 { v = v >> 1u64   d = d + 1u64 }
    if v != 1u64 { return SY_SENT }
    if d > 8u64 { return SY_SENT }
    return 8u64 - d
}
/* decide the = bridge between subjects i and j through the fleet:
 * 1 TRUE | 0 refuted | 2 undecidable | 3 engines-disagree (an arm-fail) */
fn sy_ddecide(i: u64, j: u64) -> u64 {
    let di : u64 = SY_DOMV[i]
    let dj : u64 = SY_DOMV[j]
    let da : u64 = di >> 16u64
    let db : u64 = dj >> 16u64
    if da == 0u64 { return 2u64 }
    if db == 0u64 { return 2u64 }
    if da == db {
        if da == 1u64 { return sy_decide(i, j) }
        if da == 2u64 {
            if (di & 65535u64) == (dj & 65535u64) { return 1u64 }
            return 0u64
        }
        if da == 3u64 {
            return ky_wdecide(((&SY_AB) as u64) + SY_SO[i] + 5u64, SY_SL[i] - 5u64, ((&SY_AB) as u64) + SY_SO[j] + 5u64, SY_SL[j] - 5u64)
        }
        if da == 4u64 {
            return ms_pdecide((di >> 8u64) & 255u64, di & 255u64, (dj >> 8u64) & 255u64, dj & 255u64)
        }
        return py_rdecide(di & 255u64, dj & 255u64)
    }
    /* THE JOINT DOMAIN: a mul fold-family against a digit-depth -- noesis's
     * image meter and klisi's digit engine must AGREE on the valuation
     * before any verdict exists (disagreement is an arm-fail, never a
     * verdict).  The deficit = valuation keystone, instance-wise. */
    let mut fi : u64 = di
    let mut dpt : u64 = dj
    let mut isj : u64 = 0u64
    if da == 1u64 { if db == 2u64 { isj = 1u64 } }
    if da == 2u64 { if db == 1u64 { fi = dj   dpt = di   isj = 1u64 } }
    if isj == 0u64 { return 2u64 }
    if ((fi >> 8u64) & 255u64) != 2u64 { return 2u64 }
    let m : u64 = fi & 255u64
    let d1 : u64 = sy_img_deficit(fi & 65535u64)
    if d1 == SY_SENT { return 2u64 }
    let d2 : u64 = kl_vdepth(m)
    if d1 != d2 { return 3u64 }
    if d1 == (dpt & 255u64) { return 1u64 }
    return 0u64
}
fn sy_uf_find(x: u64) -> u64 {
    let mut r : u64 = x
    while SY_UFD[r] != r { r = SY_UFD[r] }
    return r
}
fn sy_lg_speak(i: u64, j: u64) -> u64 {
    if SY_LGN + SY_SL[i] + SY_SL[j] + 8u64 > 1024u64 { return SY_SENT }
    SY_LG[SY_LGN] = 91u8
    SY_LGN = SY_LGN + 1u64
    let mut k : u64 = 0u64
    while k < SY_SL[i] { SY_LG[SY_LGN] = SY_AB[SY_SO[i] + k]   SY_LGN = SY_LGN + 1u64   k = k + 1u64 }
    SY_LG[SY_LGN] = 32u8
    SY_LGN = SY_LGN + 1u64
    SY_LG[SY_LGN] = 61u8
    SY_LGN = SY_LGN + 1u64
    SY_LG[SY_LGN] = 32u8
    SY_LGN = SY_LGN + 1u64
    k = 0u64
    while k < SY_SL[j] { SY_LG[SY_LGN] = SY_AB[SY_SO[j] + k]   SY_LGN = SY_LGN + 1u64   k = k + 1u64 }
    SY_LG[SY_LGN] = 93u8
    SY_LGN = SY_LGN + 1u64
    SY_LG[SY_LGN] = 32u8
    SY_LGN = SY_LGN + 1u64
    return 0u64
}
/* THE ROUTED WALK.  speak=1: the discharging pass over the BASE union
 * (ledger filled, counters written); speak=0: the fixpoint re-walk over the
 * post-dialectic state (any new truth is a failure).  The pending-join
 * forest is SEEDED from the standing classes, so a truth composes with
 * standing knowledge and redundant spellings are never spoken.  0 = ok. */
fn sy_dialectic(speak: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < SY_SN {
        SY_DOMV[i] = sy_dom(i)
        SY_UFD[i] = i
        let ci : u64 = eol_class_of_thing(SY_ST[i])
        let mut k : u64 = 0u64
        while k < i {
            if eol_class_of_thing(SY_ST[k]) == ci { SY_UFD[i] = k   k = i }
            k = k + 1u64
        }
        i = i + 1u64
    }
    i = 0u64
    while i < SY_SN {
        let mut j : u64 = i + 1u64
        while j < SY_SN {
            let mut skip : u64 = 0u64
            if speak == 1u64 { if sy_con_get(0u64, i, j) == 1u64 { skip = 1u64 } }
            if speak == 0u64 { if sy_con_get(1u64, i, j) == 1u64 { skip = 1u64 } }
            if skip == 0u64 { if sy_uf_find(i) == sy_uf_find(j) { skip = 1u64 } }
            if skip == 0u64 {
                let v : u64 = sy_ddecide(i, j)
                if v == 3u64 { return 1u64 }
                if v == 1u64 {
                    if speak == 0u64 { return 2u64 }
                    if sy_lg_speak(i, j) == SY_SENT { return 3u64 }
                    let ra : u64 = sy_uf_find(i)
                    let rb : u64 = sy_uf_find(j)
                    SY_UFD[ra] = rb
                    SY_DSP = SY_DSP + 1u64
                }
                if v == 0u64 { if speak == 1u64 { SY_DRF = SY_DRF + 1u64 } }
                if v == 2u64 {
                    if (SY_DOMV[i] >> 16u64) != 0u64 { if (SY_DOMV[j] >> 16u64) != 0u64 {
                        if speak == 1u64 { SY_DUN = SY_DUN + 1u64 }
                    } }
                }
            }
            j = j + 1u64
        }
        i = i + 1u64
    }
    return 0u64
}

/* ==================== THE ARMS ==================== */
fn sy_arm330() -> u64 {
    /* THE CONVENING: eight testimonies side by side, coherent, one address,
     * deterministic; each testimony alone coherent; claim count exact */
    if sy_convene(255u64, 0u64, 1u64) < 0i64 { return 330u64 }
    if eol_lawcheck() != 0u64 { return 330u64 }
    let a1 : u64 = eol_addr()
    if a1 == 0u64 { return 330u64 }
    if SY_CWM[8u64] != 57u64 { return 330u64 }
    if sy_convene(255u64, 0u64, 1u64) < 0i64 { return 330u64 }
    if eol_addr() != a1 { return 330u64 }
    SY_UADDR0 = a1
    /* the sum of the parts: each single testimony coherent, and its claim
     * count matches its watermark span in the union */
    let mut k : u64 = 0u64
    while k < SY_ORGS {
        let c : i64 = sy_convene(1u64 << k, 0u64, 0u64)
        if c < 0i64 { return 330u64 }
        if eol_lawcheck() != 0u64 { return 330u64 }
        if eol_addr() == 0u64 { return 330u64 }
        if (c as u64) != (SY_CWM[k + 1u64] - SY_CWM[k]) { return 330u64 }
        k = k + 1u64
    }
    return 0u64
}
fn sy_arm331() -> u64 {
    /* THE SURPLUS: the eight named theorems hold in the union and in NO
     * single testimony; the mechanical sweep counts >= 8 surplus pairs */
    if sy_convene(255u64, 0u64, 1u64) < 0i64 { return 331u64 }
    let mut n : u64 = 0u64
    while n < 8u64 {
        if sy_check_theorem(n) != 1u64 { return 331u64 }
        n = n + 1u64
    }
    let mut k : u64 = 0u64
    while k < SY_ORGS {
        if sy_convene(1u64 << k, 0u64, 0u64) < 0i64 { return 331u64 }
        n = 0u64
        while n < 8u64 {
            if sy_check_theorem(n) != 0u64 { return 331u64 }
            n = n + 1u64
        }
        k = k + 1u64
    }
    /* the mechanical sweep: cross-province subject pairs entailed by the
     * union under any verb, then re-tested against every single testimony */
    if sy_convene(255u64, 0u64, 1u64) < 0i64 { return 331u64 }
    if sy_harvest() == SY_SENT { return 331u64 }
    if sy_con_fill(0u64) == SY_SENT { return 331u64 }
    let mut surp : u64 = 0u64
    let mut i : u64 = 0u64
    while i < SY_SN {
        let mut j : u64 = i + 1u64
        while j < SY_SN {
            if SY_SP[i] != SY_SP[j] { if sy_con_get(0u64, i, j) == 1u64 {
                /* connected across provinces: is it union-only?  re-derive
                 * against each single testimony by text */
                let mut single : u64 = 0u64
                let mut w : u64 = 0u64
                while w < SY_ORGS {
                    if sy_convene(1u64 << w, 0u64, 0u64) < 0i64 { return 331u64 }
                    let ea : u64 = sy_thing_of(SY_SO[i], SY_SL[i])
                    let eb : u64 = sy_thing_of(SY_SO[j], SY_SL[j])
                    if ea != SY_SENT { if eb != SY_SENT {
                        if eol_lawcheck() != 0u64 { return 331u64 }
                        let ca : u64 = eol_class_of_thing(ea)
                        let cb : u64 = eol_class_of_thing(eb)
                        let mut con : u64 = 0u64
                        if ca == cb { con = 1u64 }
                        if eol_reaches(ca, cb) == 1u64 { con = 1u64 }
                        if eol_reaches(cb, ca) == 1u64 { con = 1u64 }
                        if eol_mirror_class(ca) == cb { con = 1u64 }
                        if con == 1u64 { single = 1u64   w = SY_ORGS }
                    } }
                    w = w + 1u64
                }
                if single == 0u64 { surp = surp + 1u64 }
                /* restore the union for the next pair's class queries */
                if sy_convene(255u64, 0u64, 1u64) < 0i64 { return 331u64 }
                if eol_lawcheck() != 0u64 { return 331u64 }
            } }
            j = j + 1u64
        }
        i = i + 1u64
    }
    if surp < 8u64 { return 331u64 }
    SY_SURP = surp
    return 0u64
}
fn sy_arm332() -> u64 {
    /* THE KNOCKOUT MATRIX: drop each testimony; exactly the theorems that
     * ride it die, every other survives */
    let mut k : u64 = 0u64
    while k < SY_ORGS {
        if sy_convene(255u64 & (255u64 ^ (1u64 << k)), 0u64, 0u64) < 0i64 { return 332u64 }
        let mut n : u64 = 0u64
        while n < 8u64 {
            let dead : u64 = (sy_theorem_bearers(n) >> k) & 1u64
