}
fn sy_arm346() -> u64 {
    /* THE CAYLEY CHART: the classes of the machine's own operator algebra
     * EMERGE from complete pairwise decision over the 85 words it authored */
    let mut w : u64 = 0u64
    while w < 85u64 {
        let mut rep : u64 = SY_SENT
        let mut r : u64 = 0u64
        while r < w {
            if rep == SY_SENT { if SY_CWCLS[r] == r {
                let v : u64 = sy_cw_decide(w, r)
                if v == 2u64 { return 346u64 }
                if v == 1u64 { rep = r }
            } }
            r = r + 1u64
        }
        if rep == SY_SENT { SY_CWCLS[w] = w } else { SY_CWCLS[w] = rep }
        w = w + 1u64
    }
    let mut nc : u64 = 0u64
    w = 0u64
    while w < 85u64 {
        if SY_CWCLS[w] == w { nc = nc + 1u64 }
        w = w + 1u64
    }
    if nc < 2u64 { return 346u64 }
    if nc >= 85u64 { return 346u64 }
    /* THE EMERGED COUNT, locked as a condition of motion: the 85 words fall
     * into exactly 32 operators (2^5 -- the relations HH = XX = ZZ = I,
     * SS = Z, HZH = X and the exact anticommutation phases carve the ball;
     * derived by the machine's first run, never authored) */
    if nc != 32u64 { return 346u64 }
    SY_CWN = nc
    /* THE CONGRUENCE, complete: every pair's circuit verdict must equal the
     * class verdict -- 3570 decisions, zero exceptions */
    let mut i : u64 = 0u64
    while i < 85u64 {
        let mut j : u64 = i + 1u64
        while j < 85u64 {
            let vc : u64 = sy_cw_decide(i, j)
            if vc == 2u64 { return 346u64 }
            let mut same : u64 = 0u64
            if SY_CWCLS[i] == SY_CWCLS[j] { same = 1u64 }
            if vc != same { return 346u64 }
            j = j + 1u64
        }
        i = i + 1u64
    }
    /* the chart AGREES with the standing union's word-truths */
    /* hzh = word 21 + (0*16 + 2*4 + 0) = 29?  hzh letters h,z,h = (0,2,0):
     * w = 21 + 0*16 + 2*4 + 0 = 29; x = 2; z = 3; ss = 5 + 3*4 + 3 = 20;
     * xx = 5 + 1*4 + 1 = 10; i = 0 */
    if SY_CWCLS[29u64] != SY_CWCLS[2u64] { return 346u64 }
    if SY_CWCLS[20u64] != SY_CWCLS[3u64] { return 346u64 }
    if SY_CWCLS[10u64] != SY_CWCLS[0u64] { return 346u64 }
    if SY_CWCLS[29u64] == SY_CWCLS[3u64] { return 346u64 }
    /* THE CHART SCROLL: the spanning equalities sealed -- and eidolos's own
     * closure must re-derive the SAME class count (two engines, one chart) */
    eol_reset()
    let mut spoken : u64 = 0u64
    w = 0u64
    while w < 85u64 {
        if SY_CWCLS[w] != w {
            if sy_cw_speak(w, SY_CWCLS[w]) == SY_SENT { return 346u64 }
            spoken = spoken + 1u64
        } else {
            if sy_cw_mark(w) == SY_SENT { return 346u64 }
        }
        w = w + 1u64
    }
    if spoken != 85u64 - nc { return 346u64 }
    if eol_lawcheck() != 0u64 { return 346u64 }
    /* eidolos's OWN closure re-derives the same partition: the word classes
     * plus the one marker class -- two engines, one chart */
    if eol_class_count() != nc + 1u64 { return 346u64 }
    let a1 : u64 = eol_addr()
    if a1 == 0u64 { return 346u64 }
    /* the chart KNOWS: hzh = x entailed; hzh = z refused */
    if sy_q("word hzh" as u64, SY_V_FLAT, "word x" as u64) != 1u64 { return 346u64 }
    if sy_q("word hzh" as u64, SY_V_FLAT, "word z" as u64) != 0u64 { return 346u64 }
    /* determinism: the chart re-derives to the same name */
    eol_reset()
    w = 0u64
    while w < 85u64 {
        if SY_CWCLS[w] != w {
            if sy_cw_speak(w, SY_CWCLS[w]) == SY_SENT { return 346u64 }
        } else {
            if sy_cw_mark(w) == SY_SENT { return 346u64 }
        }
        w = w + 1u64
    }
    if eol_addr() != a1 { return 346u64 }
    SY_CAYADDR = a1
    return 0u64
}
