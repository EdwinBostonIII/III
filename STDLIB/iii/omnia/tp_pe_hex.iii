module omnia_tp_pe_hex

extern @abi(c-msvc-x64) fn tp_raw_hex(src: u64, src_len: u64, dst_buf: u64, dst_cap: u64) -> u64 from "tp_raw_hex.iii"

fn tp_pe_hex(src: u64, src_len: u64, dst_buf: u64, dst_cap: u64) -> u64 @export {
    return tp_raw_hex(src, src_len, dst_buf, dst_cap)
}
