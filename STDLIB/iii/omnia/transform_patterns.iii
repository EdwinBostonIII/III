extern @abi(c-msvc-x64) fn pattern_register(slot: u32, template: u64) -> u8 from "pattern_table.iii"

/* The 24 codec entry-point names -- extern declarations let us take their address */
extern @abi(c-msvc-x64) fn tp_iii_to_asm(src: u64, src_len: u64, dst_buf: u64, dst_cap: u64) -> u64 from "tp_iii_to_asm.iii"
extern @abi(c-msvc-x64) fn tp_iii_to_babel_json(src: u64, src_len: u64, dst_buf: u64, dst_cap: u64) -> u64 from "tp_iii_to_babel_json.iii"
