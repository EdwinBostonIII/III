/* STDLIB/iii/omnia/xii_cost_monotone.iii -- THE COST-MONOTONICITY GATE (harmony item 27).
 *
 * The XII rewrite system's TERMINATION argument is the MPO weight order (xii_canon_weight,
 * DOCS/III-XII.md S9.3): every rewrite is supposed to take a term DOWNHILL (or level) in summed
 * K-cost -- an optimizer that could rewrite a term UPHILL would not be an optimizer, and a single
 * cost-increasing rule breaks the termination proof everything else stands on.  That promise was
 * prose.  This gate makes it MECHANICAL, the exact sibling of the capability-preservation gate
 * (omnia/xii_cap_preserve, harmony item 4): for EVERY live rule, fired on its own joinability
 * witness, weight(RHS) <= weight(LHS).  The LHS weight is SNAPSHOTTED before apply (the arena
 * mutates in place); rule-fire detection is xii_rewrite_last_rule_fired (the documented idiom).
 *
 * Composes only the already-exported XII organs.  Compiler-UNREFERENCED -> LIBNATIVE.
 * Hexad: kind_seal (a preservation gate).  Ring: R0.  NIH. */
module omnia_xii_cost_monotone

extern @abi(c-msvc-x64) fn xrp_rule_count() -> u32 from "xii_rule_patterns.iii"
extern @abi(c-msvc-x64) fn xrp_rid_at(slot: u32) -> u32 from "xii_rule_patterns.iii"
extern @abi(c-msvc-x64) fn xjn_build_rule_witness(slot: u32) -> u32 from "xii_joinability.iii"
extern @abi(c-msvc-x64) fn xii_canon_weight(t: u32) -> u32 from "xii_canonicalise.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_apply_specific(rule_id: u32, t: u32) -> u32 from "xii_rewrite.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_last_rule_fired() -> u32 from "xii_rewrite.iii"
extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, subform: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_fusion2(kind: u8, child_a: u32, child_b: u32) -> u32 from "xii_term.iii"

const XCM_K_FORM   : u8 = 0u8     /* XII_KIND_K01_FORM */
const XCM_F_THEN   : u8 = 19u8    /* F.THEN fusion (kinds 18..23 are the six fusions) */

/* THE GATE.  1 iff every rule that fires on its own joinability witness is cost-monotone
 * (weight(RHS) <= weight(LHS) under the MPO the termination proof uses).  0 = a rule rewrote
 * UPHILL -- the optimizer manufactured cost, the termination argument is broken: refuse. */
fn xcm_gate() -> u32 @export {
    let n : u32 = xrp_rule_count()
    let mut slot : u32 = 0u32
    while slot < n {
        let rid : u32 = xrp_rid_at(slot)
        xii_term_arena_reset()
        let lhs : u32 = xjn_build_rule_witness(slot)
        let lw : u32 = xii_canon_weight(lhs)                 /* SNAPSHOT before apply (arena mutates) */
        let rhs : u32 = xii_rewrite_apply_specific(rid, lhs)
        if xii_rewrite_last_rule_fired() == rid {            /* only rules that actually fired */
            let rw : u32 = xii_canon_weight(rhs)
            if rw > lw { return 0u32 }                       /* VIOLATION: an uphill rewrite */
        }
        slot = slot + 1u32
    }
    return 1u32
}

/* SELFTEST.  99 iff (1) the gate holds across every live rule, AND (2) it has TEETH: the weight
 * order genuinely DISCRIMINATES -- a fabricated F.THEN(FORM, FORM) expansion strictly outweighs
 * its FORM leaf, so an uphill rewrite (leaf -> composite) WOULD be caught. */
fn xcm_selftest() -> u64 @export {
    if xcm_gate() != 1u32 { return 1u64 }
    xii_term_arena_reset()
    let leaf : u32 = xii_term_make_basis(XCM_K_FORM, 0u32)
    let leaf2 : u32 = xii_term_make_basis(XCM_K_FORM, 0u32)
    let comp : u32 = xii_term_make_fusion2(XCM_F_THEN, leaf, leaf2)
    let wl : u32 = xii_canon_weight(leaf)
    let wc : u32 = xii_canon_weight(comp)
    if wc <= wl { return 2u64 }                              /* the order must discriminate */
    return 99u64
}
