/* Aggregate runner for the third extension batch. */
fn _cp_extended_class_check() -> u32 {
    let mut fails : u32 = 0u32
    if _cp_200_compose_null_r17_vs_r38() == 0u8 { fails = fails + 1u32 }
    if _cp_201_compose_null_r37_vs_r38() == 0u8 { fails = fails + 1u32 }
