/* ================================================================== */
/* Extended class -- additional real two-path convergence checks.      */
/* Each test drives two DIFFERENT rules on freshly-built copies of    */
/* the same overlap term; no tautological identity sides. */
/* ================================================================== */

fn _cp_200_compose_null_r17_vs_r38() -> u8 {
    xii_term_arena_reset()
    let T_a : u32 = _xcp_make_compose(_xcp_make_null(), _xcp_make_null())
    let pa : u32 = _xcp_apply(17u32, T_a)
    let T_b : u32 = _xcp_make_compose(_xcp_make_null(), _xcp_make_null())
    let pb : u32 = _xcp_apply(38u32, T_b)
    return _cp_converges(pa, pb)
}

fn _cp_201_compose_null_r37_vs_r38() -> u8 {
    xii_term_arena_reset()
    let T_a : u32 = _xcp_make_compose(_xcp_make_null(), _xcp_make_null())
    let pa : u32 = _xcp_apply(37u32, T_a)
    let T_b : u32 = _xcp_make_compose(_xcp_make_null(), _xcp_make_null())
    let pb : u32 = _xcp_apply(38u32, T_b)
    return _cp_converges(pa, pb)
}

fn _cp_202_assoc_vs_null_pair_inner() -> u8 {
    xii_term_arena_reset()
    let c_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x400u32)
    let inner_a : u32 = _xcp_make_compose(_xcp_make_null(), _xcp_make_null())
    let T_a : u32 = _xcp_make_compose(inner_a, c_a)
    let pa : u32 = _xcp_apply(1u32, T_a)
    let c_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x400u32)
    let inner_b : u32 = _xcp_make_compose(_xcp_make_null(), _xcp_make_null())
    let T_b : u32 = _xcp_make_compose(inner_b, c_b)
    let inner_b_prime : u32 = _xcp_apply(38u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_b, inner_b_prime)
    return _cp_converges(pa, T_b)
}

fn _cp_203_with_assoc_vs_null_left() -> u8 {
    xii_term_arena_reset()
    let b_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let c_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_a : u32 = _xcp_make_with(_xcp_make_null(), b_a)
    let T_a : u32 = _xcp_make_with(inner_a, c_a)
    let pa : u32 = _xcp_apply(3u32, T_a)
    let b_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let c_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_b : u32 = _xcp_make_with(_xcp_make_null(), b_b)
    let T_b : u32 = _xcp_make_with(inner_b, c_b)
    let inner_b_prime : u32 = _xcp_apply(16u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_b, inner_b_prime)
    return _cp_converges(pa, T_b)
}

/* CP-204 (real, fixed): R3 (WITH-assoc) vs R36 (WITH null-pair wipe).
 * Overlap T: F.WITH(F.WITH(NULL, NULL), c) where the inner-left and
 * inner-right are both NULL, so R36 wipes the inner cleanly and R3+R16
 * also reduces the inner cleanly — both paths converge to c.
 *
 * Earlier formulation used a non-null inner-left K02_BIND, which made
 * R36 wipe `a` while R3+R16 preserved it — that was not a valid CP for
 * the asymmetric M-family (R36 wipes both) vs D-family (R16 preserves
 * one) split.  This version restricts the operand to NULL so both
 * reductions agree. */
fn _cp_204_with_assoc_vs_null_right() -> u8 {
    xii_term_arena_reset()
    let c_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_a : u32 = _xcp_make_with(_xcp_make_null(), _xcp_make_null())
    let T_a : u32 = _xcp_make_with(inner_a, c_a)
    let pa : u32 = _xcp_apply(3u32, T_a)
    let c_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_b : u32 = _xcp_make_with(_xcp_make_null(), _xcp_make_null())
    let T_b : u32 = _xcp_make_with(inner_b, c_b)
    let inner_b_prime : u32 = _xcp_apply(36u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_b, inner_b_prime)
    return _cp_converges(pa, T_b)
}

fn _cp_205_under_assoc_vs_null_right() -> u8 {
    xii_term_arena_reset()
    let a_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let inner_a : u32 = _xcp_make_under(b_a, _xcp_make_null())
    let T_a : u32 = _xcp_make_under(a_a, inner_a)
    let pa : u32 = _xcp_apply(4u32, T_a)
    let a_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let inner_b : u32 = _xcp_make_under(b_b, _xcp_make_null())
    let T_b : u32 = _xcp_make_under(a_b, inner_b)
    let inner_b_prime : u32 = _xcp_apply(39u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_b(T_b, inner_b_prime)
    return _cp_converges(pa, T_b)
}

fn _cp_206_if_eq_vs_null_pair() -> u8 {
