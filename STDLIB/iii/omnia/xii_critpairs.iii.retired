 * Path B (R26 inner): K07_SEAL; root F.THEN(K07_SEAL, K12_NULL);
 *              canon R22 -> K07_SEAL.
 * Both converge to K07_SEAL.  Earlier version used K02_BIND as trailing
 * element — neither R21 nor R22 could fire, leaving paths divergent. */
fn _cp_257_then_seal_prefix_assoc_outer() -> u8 {
    xii_term_arena_reset()
    let s_a : u32 = _xcp_make_basis(XCP_K07_SEAL, 0xCCu32)
    let inner_a : u32 = _xcp_make_then(_xcp_make_null(), s_a)
    let c_a : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let T_a : u32 = _xcp_make_then(inner_a, c_a)
    let pa : u32 = _xcp_apply(2u32, T_a)
    let s_b : u32 = _xcp_make_basis(XCP_K07_SEAL, 0xCCu32)
    let inner_b : u32 = _xcp_make_then(_xcp_make_null(), s_b)
    let c_b : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let T_b : u32 = _xcp_make_then(inner_b, c_b)
    let inner_b_prime : u32 = _xcp_apply(26u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_b, inner_b_prime)
    return _cp_converges(pa, T_b)
}

