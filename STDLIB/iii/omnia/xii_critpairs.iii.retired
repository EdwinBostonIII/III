    if _cp_207_if_true_vs_eq_branches() == 0u8 { fails = fails + 1u32 }
    if _cp_208_if_false_vs_eq_branches() == 0u8 { fails = fails + 1u32 }
    if _cp_209_query_idemp_vs_assoc() == 0u8 { fails = fails + 1u32 }
    if _cp_210_reflect_idemp_vs_assoc() == 0u8 { fails = fails + 1u32 }
    if _cp_211_govern_idemp_vs_assoc() == 0u8 { fails = fails + 1u32 }
