/* CP-275 (real, fixed): R31 (K04_MEAN chain merge) vs R2 (THEN assoc).
 *
 * K04_MEAN subform encoding (per match_R031 in xii_rewrite.iii):
 *   low 9 bits = lhs; bits 9..17 = rhs; bits 18..26 = equiv_kind.
 *   K04_MEAN(equiv=1, lhs=1, rhs=2) = (1<<18) | (2<<9) | 1 = 0x40401.
 *
 * R31 fires on F.THEN(K04_MEAN(a,b), K04_MEAN(b,c)) (matching equiv kind
 * and rhs_of_first == lhs_of_second).
 *
 * Overlap T: F.THEN(F.THEN(MEAN(1,2), MEAN(2,3)), MEAN(3,4)) — 3-chain.
 * Path A (R2): F.THEN(m1, F.THEN(m2, m3)); canon: inner R31 -> MEAN(2,4);
 *              outer R31 -> MEAN(1,4) = 0x40801.
 * Path B (R31 inner): MEAN(1,3); root F.THEN(MEAN(1,3), MEAN(3,4));
 *              canon R31 -> MEAN(1,4) = 0x40801.
 * Both converge to K04_MEAN(equiv=1, lhs=1, rhs=4) = 0x40801.
 *
 * Earlier subforms 0x4160A / 0x4180B used non-chainable lhs/rhs values
 * (rhs of m1 = 22; lhs of m2 = 11) so R31 refused to fire. */
fn _cp_275_then_mean_chain_assoc() -> u8 {
    xii_term_arena_reset()
    let m1_a : u32 = _xcp_make_basis(3u8, 0x40401u32)
    let m2_a : u32 = _xcp_make_basis(3u8, 0x40602u32)
    let m3_a : u32 = _xcp_make_basis(3u8, 0x40803u32)
    let inner_a : u32 = _xcp_make_then(m1_a, m2_a)
    let T_a : u32 = _xcp_make_then(inner_a, m3_a)
    let pa : u32 = _xcp_apply(2u32, T_a)
    let m1_b : u32 = _xcp_make_basis(3u8, 0x40401u32)
    let m2_b : u32 = _xcp_make_basis(3u8, 0x40602u32)
    let m3_b : u32 = _xcp_make_basis(3u8, 0x40803u32)
    let inner_b : u32 = _xcp_make_then(m1_b, m2_b)
    let T_b : u32 = _xcp_make_then(inner_b, m3_b)
    let inner_b_prime : u32 = _xcp_apply(31u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_b, inner_b_prime)
    return _cp_converges(pa, T_b)
}

fn _cp_276_compose_form_null_right() -> u8 {
