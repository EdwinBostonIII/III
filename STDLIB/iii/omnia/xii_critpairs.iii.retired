/* CP-273 (real, fixed): R24 (K17_LIFT chain transitivity) vs R2 (THEN assoc).
 * Overlap T: F.THEN(F.THEN(K17_LIFT(0x21), K17_LIFT(0x32)), K17_LIFT(0x43))
 *
 * LIFT subform encoding (per match_R024 in xii_rewrite.iii):
 *   low 4 bits = from_ring; next 4 bits = to_ring.
 *   So K17_LIFT(from=1, to=2) = (2<<4)|1 = 0x21.
 *   And K17_LIFT(from=2, to=3) = 0x32.  K17_LIFT(from=3, to=4) = 0x43.
 *
 * Path A (R2): F.THEN(0x21, F.THEN(0x32, 0x43));
 *              canon: inner R24 (to=3 == from=3) -> K17_LIFT(0x42);
 *              outer R24 (to=2 == from=2) -> K17_LIFT(0x41).
 * Path B (R24 on inner): F.THEN(0x21, 0x32) -> K17_LIFT(0x31);
 *              root F.THEN(K17_LIFT(0x31), K17_LIFT(0x43));
 *              canon R24 (to=3 == from=3) -> K17_LIFT(0x41).
 * Both converge to K17_LIFT(0x41) = K17_LIFT(from=1, to=4).
 *
 * Earlier version used subforms 0x12, 0x23 (low 4 bits ≠ high 4 bits of
 * the previous lift's "to" ring) so R24's chain side condition failed. */
fn _cp_273_compose_lift_chain_with_assoc() -> u8 {
    xii_term_arena_reset()
    let l1_a : u32 = _xcp_make_basis(16u8, 0x21u32)
    let l2_a : u32 = _xcp_make_basis(16u8, 0x32u32)
    let l3_a : u32 = _xcp_make_basis(16u8, 0x43u32)
    let inner_a : u32 = _xcp_make_then(l1_a, l2_a)
    let T_a : u32 = _xcp_make_then(inner_a, l3_a)
    let pa : u32 = _xcp_apply(2u32, T_a)
    let l1_b : u32 = _xcp_make_basis(16u8, 0x21u32)
    let l2_b : u32 = _xcp_make_basis(16u8, 0x32u32)
    let l3_b : u32 = _xcp_make_basis(16u8, 0x43u32)
    let inner_b : u32 = _xcp_make_then(l1_b, l2_b)
    let T_b : u32 = _xcp_make_then(inner_b, l3_b)
    let inner_b_prime : u32 = _xcp_apply(24u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_b, inner_b_prime)
    return _cp_converges(pa, T_b)
}

