fn _cp_266_compose_form_form_assoc_then_sort() -> u8 {
    xii_term_arena_reset()
    let f1_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x400u32)
    let f2_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
