/* CP-209 (real, fixed): R33 (QUERY idempotence) vs R1 (compose assoc).
 * Overlap T: F.COMPOSE(F.COMPOSE(K09_QUERY($t), K09_QUERY($t)), K09_QUERY($t))
 * Path A (R1): F.COMPOSE(Q, F.COMPOSE(Q, Q)); canon: inner R33 -> Q;
 *              outer R33 -> Q.
 * Path B (R33 on inner): inner -> Q; root F.COMPOSE(Q, Q); canon R33 -> Q.
 * Both converge to K09_QUERY($t).
 *
 * Earlier version used a foreign trailing kernel (K02_BIND) which kept
 * the outer composite from triggering R33 after R1 reassoc.  Three
 * matching K09_QUERY kernels make this a valid CP. */
fn _cp_209_query_idemp_vs_assoc() -> u8 {
    xii_term_arena_reset()
    let q_a1 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let q_a2 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let q_a3 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let inner_a : u32 = _xcp_make_compose(q_a1, q_a2)
    let T_a : u32 = _xcp_make_compose(inner_a, q_a3)
    let pa : u32 = _xcp_apply(1u32, T_a)
    let q_b1 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let q_b2 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let q_b3 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let inner_b : u32 = _xcp_make_compose(q_b1, q_b2)
    let T_b : u32 = _xcp_make_compose(inner_b, q_b3)
    let inner_b_prime : u32 = _xcp_apply(33u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_b, inner_b_prime)
    return _cp_converges(pa, T_b)
}

/* CP-210 (real, fixed): R34 (REFLECT idempotence) vs R1 (compose assoc).
 * Three matching K18_REFLECT kernels — parallel to CP-209. */
fn _cp_210_reflect_idemp_vs_assoc() -> u8 {
    xii_term_arena_reset()
