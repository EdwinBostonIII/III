/* CP-222 (real): R25 (K17_LIFT(r,r) -> TRIVIAL) vs R24 (LIFT chain
 * transitivity).  Overlap T: F.THEN(K17_LIFT(1,1), K17_LIFT(1,3)).
 * LIFT subform = (to<<4)|from : l1 = 0x11 (from=1,to=1), l2 = 0x31
 * (from=1,to=3) so to_a(1)==from_b(1) and R24 chains.
 * Path A: R25 on child_a -> F.THEN(LIFT_TRIVIAL, LIFT(1,3)); canonicalise
 *         applies R43 (THEN trivial-lift left identity) -> LIFT(1,3).
 * Path B: R24 on the whole THEN -> LIFT(1,3) (subform 0x31).
 * Both converge to K17_LIFT(1,3).  R43/R44 + R24 TRIVIAL guard make this
 * a joinable critical pair (categorical identity law). */
fn _cp_222_lift_trivial_vs_chain() -> u8 {
    xii_term_arena_reset()
    let l1_a : u32 = _xcp_make_basis(16u8, 0x11u32)
    let l2_a : u32 = _xcp_make_basis(16u8, 0x31u32)
    let T_a : u32 = _xcp_make_then(l1_a, l2_a)
    let l1_a_prime : u32 = _xcp_apply(25u32, l1_a)
    if l1_a_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_a, l1_a_prime)
    let l1_b : u32 = _xcp_make_basis(16u8, 0x11u32)
    let l2_b : u32 = _xcp_make_basis(16u8, 0x31u32)
    let T_b : u32 = _xcp_make_then(l1_b, l2_b)
    let pb : u32 = _xcp_apply(24u32, T_b)
    return _cp_converges(T_a, pb)
}

