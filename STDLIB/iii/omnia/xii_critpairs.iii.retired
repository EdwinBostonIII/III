/* CP-286 (real): R13 (Loop unit collapse, count==1) vs R41 (Loop
 * null-body wipe).  Overlap T: F.LOOP(K06_NULL, 1) -- both rules match.
 * Path A: R13 -> child_a (K06_NULL).
 * Path B: R41 -> child_a (K06_NULL).
 * Both converge to NULL.  R41 (Knuth-Bendix completion) closes the
 * formerly empty redex set for a null loop body; this is the genuine
 * R13/R41 critical pair (distinct rules, shared ancestor). */
fn _cp_286_loop_with_null_body() -> u8 {
    xii_term_arena_reset()
    let T_a : u32 = xii_term_make_loop(_xcp_make_null(), 1u64)
    let pa : u32 = _xcp_apply(13u32, T_a)
    if pa == XCP_NULL_REF { return 0u8 }
    let T_b : u32 = xii_term_make_loop(_xcp_make_null(), 1u64)
    let pb : u32 = _xcp_apply(41u32, T_b)
    if pb == XCP_NULL_REF { return 0u8 }
    return _cp_converges(pa, pb)
}

