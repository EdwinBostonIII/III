/* ------------------------------------------------------------------ */
/* Class C7: Witness/SEAL fold overlaps (10 pairs)                     */
/* ------------------------------------------------------------------ */

/* CP-106: R027 (compose SEAL+PROVE) vs R017 (compose null-right) at extended
 * Overlap T: F.COMPOSE(F.COMPOSE(K07_SEAL($a), K08_PROVE($a)), NULL)
 * Path A: apply R027 to the inner -> K07_SEAL($a); root becomes
 *         F.COMPOSE(K07_SEAL($a), NULL); canonicalise via R017 -> K07_SEAL.
 * Path B: apply R017 at root -> F.COMPOSE(K07_SEAL($a), K08_PROVE($a));
 *         canonicalise via R027 -> K07_SEAL. */
fn _cp_106() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let s_a : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x123u32)
    let p_a : u32 = _xcp_make_basis(XCP_K08_PROVE, 0x123u32)
    let inner_a : u32 = _xcp_make_compose(s_a, p_a)
    let T_a : u32 = _xcp_make_compose(inner_a, _xcp_make_null())
    let inner_a_prime : u32 = _xcp_apply(27u32, inner_a)
    if inner_a_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_a, inner_a_prime)
    let pa : u32 = T_a

    /* Path B. */
    let s_b : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x123u32)
    let p_b : u32 = _xcp_make_basis(XCP_K08_PROVE, 0x123u32)
    let inner_b : u32 = _xcp_make_compose(s_b, p_b)
    let T_b : u32 = _xcp_make_compose(inner_b, _xcp_make_null())
    let pb : u32 = _xcp_apply(17u32, T_b)

    return _cp_converges(pa, pb)
}

fn _cp_c7_class_check() -> u32 {
    let mut fails : u32 = 0u32
    if _cp_106() == 0u8 { fails = fails + 1u32 }
    if _cp_107_real() == 0u8 { fails = fails + 1u32 }
    return fails
}

/* CP-107 (real): R035 (THEN(K11_GOVERN(p), K11_GOVERN(p)) -> K11_GOVERN(p))
 * vs R022 (THEN(a, K12_THEN_NULL) -> a)
 * Overlap T: F.THEN(F.THEN(K11_GOVERN(p), K11_GOVERN(p)), K12_THEN_NULL)
 * Path A: apply R022 at root -> F.THEN(K11_GOVERN(p), K11_GOVERN(p));
 *         canonicalise via R035 -> K11_GOVERN(p).
 * Path B: apply R035 to inner -> K11_GOVERN(p); root becomes
 *         F.THEN(K11_GOVERN(p), K12_THEN_NULL); canonicalise via R022 ->
 *         K11_GOVERN(p).
 * Both converge to K11_GOVERN(p). */
fn _cp_107_real() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let g_a1 : u32 = _xcp_make_basis(10u8, 0x222u32)
    let g_a2 : u32 = _xcp_make_basis(10u8, 0x222u32)
    let inner_a : u32 = _xcp_make_then(g_a1, g_a2)
    let then_null_a : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let T_a : u32 = _xcp_make_then(inner_a, then_null_a)
    let pa : u32 = _xcp_apply(22u32, T_a)

    /* Path B. */
    let g_b1 : u32 = _xcp_make_basis(10u8, 0x222u32)
    let g_b2 : u32 = _xcp_make_basis(10u8, 0x222u32)
    let inner_b : u32 = _xcp_make_then(g_b1, g_b2)
    let then_null_b : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let T_b : u32 = _xcp_make_then(inner_b, then_null_b)
    let inner_b_prime : u32 = _xcp_apply(35u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_b, inner_b_prime)
    let pb : u32 = T_b

    return _cp_converges(pa, pb)
}

