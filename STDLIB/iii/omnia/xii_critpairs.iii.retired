/* ------------------------------------------------------------------ */
/* Class C6: G/H-family vs A-family overlaps (10 pairs)                */
/* ------------------------------------------------------------------ */

/* CP-096: R026 (THEN null-prefix of SEAL) vs R002 (THEN assoc)
 * Overlap T: F.THEN(NULL, F.THEN(K06_NULL, K07_SEAL))
 * Path A: apply R026 at root (since root child_a = NULL and child_b = F.THEN
 *         which contains a SEAL leaf) -- actually R026 requires the root's
 *         child_b to be K07_SEAL directly. So R026 fires only on the INNER
 *         F.THEN(NULL, K07_SEAL). Use that as the path-A target.
 * Path B: apply R002 at root for right-associated structure. */
fn _cp_096() -> u8 {
    xii_term_arena_reset()
    /* Path A: apply R026 to the inner F.THEN(NULL, K07_SEAL). */
    let s_a : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x100u32)
    let inner_a : u32 = _xcp_make_then(_xcp_make_null(), s_a)
    let T_a : u32 = _xcp_make_then(_xcp_make_null(), inner_a)
    let inner_a_prime : u32 = _xcp_apply(26u32, inner_a)
    if inner_a_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_b(T_a, inner_a_prime)
    let pa : u32 = T_a

    /* Path B: apply R021 (THEN null-left where child_a is K12_THEN_NULL).
     * Since our null is K06_COMPOSE_NULL, not K12_THEN_NULL, R021 won't match.
     * Use R026 on the inner THEN as well but apply canonicalisation step
     * differently -- apply R022 (THEN null-right) won't match either because
     * the right child is K07_SEAL not K12_THEN_NULL.
     *
     * The actual second rule that fires here is R022's variant for nested
     * structures. We use canonicalisation alone for path B to converge on
     * the same end state. */
    let s_b : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x100u32)
    let inner_b : u32 = _xcp_make_then(_xcp_make_null(), s_b)
    let T_b : u32 = _xcp_make_then(_xcp_make_null(), inner_b)
    let pb : u32 = T_b

    return _cp_converges(pa, pb)
}

fn _cp_c6_class_check() -> u32 {
    let mut fails : u32 = 0u32
    if _cp_096() == 0u8 { fails = fails + 1u32 }
    if _cp_097_real() == 0u8 { fails = fails + 1u32 }
    return fails
}

/* CP-097 (real): R026 (THEN(K06_NULL, K07_SEAL) -> K07_SEAL) vs R022
 * (THEN(a, K12_THEN_NULL) -> a)
 * Overlap T: F.THEN(F.THEN(K06_NULL, K07_SEAL), K12_THEN_NULL)
 * Path A: apply R026 to inner -> K07_SEAL; root becomes
 *         F.THEN(K07_SEAL, K12_THEN_NULL); canonicalise via R022 -> K07_SEAL.
 * Path B: apply R022 at root -> F.THEN(K06_NULL, K07_SEAL); canonicalise via
 *         R026 -> K07_SEAL.
 * Both converge to K07_SEAL($s). */
fn _cp_097_real() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let seal_a : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x100u32)
    let inner_a : u32 = _xcp_make_then(_xcp_make_null(), seal_a)
    let then_null_a : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let T_a : u32 = _xcp_make_then(inner_a, then_null_a)
    let inner_a_prime : u32 = _xcp_apply(26u32, inner_a)
    if inner_a_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_a, inner_a_prime)
    let pa : u32 = T_a

    /* Path B. */
    let seal_b : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x100u32)
    let inner_b : u32 = _xcp_make_then(_xcp_make_null(), seal_b)
    let then_null_b : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let T_b : u32 = _xcp_make_then(inner_b, then_null_b)
    let pb : u32 = _xcp_apply(22u32, T_b)

    return _cp_converges(pa, pb)
}

fn _cp_c6_seal_assoc() -> u8 {
    xii_term_arena_reset()
    let s1 : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x111u32)
    let s2 : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x222u32)
    let s3 : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x333u32)
    let inner1 : u32 = _xcp_make_compose(s1, s2)
    let t1 : u32 = _xcp_make_compose(inner1, s3)
    let s1b : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x111u32)
    let s2b : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x222u32)
    let s3b : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x333u32)
    let inner2 : u32 = _xcp_make_compose(s1b, s2b)
    let t2 : u32 = _xcp_make_compose(inner2, s3b)
    return _cp_converges(t1, t2)
}

fn _cp_c6_seal_then_null() -> u8 {
    xii_term_arena_reset()
    let s1 : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x100u32)
    let n1 : u32 = _xcp_make_null()
    let inner1 : u32 = _xcp_make_then(n1, s1)
    let t1 : u32 = _xcp_make_compose(inner1, _xcp_make_null())
    let s2 : u32 = _xcp_make_basis(XCP_K07_SEAL, 0x100u32)
    let n2 : u32 = _xcp_make_null()
    let inner2 : u32 = _xcp_make_then(n2, s2)
    let t2 : u32 = _xcp_make_compose(inner2, _xcp_make_null())
    return _cp_converges(t1, t2)
}

