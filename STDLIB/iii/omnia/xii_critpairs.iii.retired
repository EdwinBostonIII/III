/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\xii_critpairs.iii
 *
 * III STDLIB - omnia::xii_critpairs
 *
 * Critical-pair convergence verification for the 40 reduction rules.
 * Per DOCS/III-XII.md S9.2 + S26.15.
 *
 * The 40 rules form 117 critical pairs across 7 classes:
 *   C1 (24 pairs): Null-position overlaps
 *   C2 (12 pairs): A-family vs Null-family
 *   C3 (32 pairs): B-family vs internal-fusion overlaps
 *   C4 (12 pairs): LOOP-family overlaps
 *   C5 (15 pairs): IF-family vs L-family
 *   C6 (10 pairs): G/H-family vs A-family
 *   C7 (10 pairs): Witness/SEAL fold overlaps
 *
 * For each pair (R_i, R_j), we construct an overlapping term, apply both
 * possible reduction orders, then canonicalise each branch fully. Both
 * branches must reach the same canonical form (struct_eq).
 *
 * Theorem CRY-XII-CONF-001 (S9.2): the system is confluent iff all 117
 * pairs converge. The Newman lemma + termination (CRY-XII-TERM-001)
 * gives confluence from local-convergence.
 *
 * !! FALSIFIED (2026-05-26) -- this hand-117 enumeration is INCOMPLETE and its CRY-XII-CONF-001
 * confluence claim is FALSE. The live engine xii_joinability.iii (mig4 Step 4) dynamically
 * enumerated 218 critical pairs and found 35 GENUINE non-joins -- all SUBTERM overlaps (assoc
 * R001-R004 x B-family lift R005-R012), the class these hand-built witnesses never construct.
 * XII is NOT globally confluent (see DOCS/III-XII.md S9.2 verification update). Determinism is
 * preserved by termination + the single sealed rule order = a deterministic total function, NOT by
 * confluence. This module is SUPERSEDED by xii_joinability and slated for retirement once the
 * tracked confluence redesign (canonical associativity + lift-as-distinct-phase) lands. Any
 * "all 117 converge" verdict it reports is an artifact of its incomplete hand witnesses.
 *
 * Hexad: kind_essence. Ring: R0. K: 1.0.
 *
 * NIH: libc only.
 */

module omnia_xii_critpairs

extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_fusion2(kind: u8, a: u32, b: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_if(p: u32, t: u32, e: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_loop(body: u32, count: u64) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_kind(idx: u32) -> u8 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_a(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_b(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_set_child_a(idx: u32, ref: u32) -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_set_child_b(idx: u32, ref: u32) -> i32 from "xii_term.iii"

extern @abi(c-msvc-x64) fn xii_canonicalise(t: u32) -> u32 from "xii_canonicalise.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_apply_one(t: u32) -> u32 from "xii_rewrite.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_apply_specific(rule_id: u32, t: u32) -> u32 from "xii_rewrite.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_struct_eq(a: u32, b: u32) -> u8 from "xii_rewrite.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_null_form() -> u32 from "xii_rewrite.iii"

const XCP_K01_FORM     : u8 = 0u8
const XCP_K02_BIND     : u8 = 1u8
const XCP_K06_COMPOSE  : u8 = 5u8
const XCP_K07_SEAL     : u8 = 6u8
const XCP_K08_PROVE    : u8 = 7u8
const XCP_K09_QUERY    : u8 = 8u8
const XCP_K10_GRANT    : u8 = 9u8
const XCP_K11_GOVERN   : u8 = 10u8
const XCP_K12_THEN     : u8 = 11u8
const XCP_K18_REFLECT  : u8 = 17u8
const XCP_FCOMPOSE     : u8 = 18u8
const XCP_FTHEN        : u8 = 19u8
const XCP_FWITH        : u8 = 20u8
const XCP_FUNDER       : u8 = 21u8
const XCP_FIF          : u8 = 22u8
const XCP_FLOOP        : u8 = 23u8

const XCP_NULL_REF     : u32 = 0xFFFFFFFFu32

/* Constructor helpers */

fn _xcp_make_null() -> u32 {
    return xii_term_make_basis(XCP_K06_COMPOSE, xii_rewrite_null_form())
}

fn _xcp_make_basis(kind: u8, sub: u32) -> u32 {
    return xii_term_make_basis(kind, sub)
}

fn _xcp_make_compose(a: u32, b: u32) -> u32 {
    return xii_term_make_fusion2(XCP_FCOMPOSE, a, b)
}

fn _xcp_make_then(a: u32, b: u32) -> u32 {
    return xii_term_make_fusion2(XCP_FTHEN, a, b)
}

fn _xcp_make_with(a: u32, b: u32) -> u32 {
    return xii_term_make_fusion2(XCP_FWITH, a, b)
}

fn _xcp_make_under(a: u32, b: u32) -> u32 {
    return xii_term_make_fusion2(XCP_FUNDER, a, b)
}

/* Real critical-pair convergence helper.
 *
 * Given two PRE-REDUCED intermediate terms `t_a` and `t_b` (each produced
 * by applying a specific rule to a fresh copy of the same overlap term),
 * canonicalise each path independently and check that both reach the same
 * canonical form via xii_rewrite_struct_eq.
 *
 * This is the genuine confluence test: distinct reduction paths must
 * converge on the same canonical form (Newman + termination ⇒ confluence).
 *
 * Returns:
 *   1u8 if both paths converge (struct_eq holds)
 *   0u8 if convergence fails OR either path's rule did not fire
 *      (caller passed XCP_NULL_REF for a non-matching rule). */
fn _cp_converges(t_a: u32, t_b: u32) -> u8 {
    if t_a == XCP_NULL_REF { return 0u8 }
    if t_b == XCP_NULL_REF { return 0u8 }
    let c_a : u32 = xii_canonicalise(t_a)
    let c_b : u32 = xii_canonicalise(t_b)
    return xii_rewrite_struct_eq(c_a, c_b)
}

/* Apply a specific rule to t; XCP_NULL_REF if rule does not match. */
fn _xcp_apply(rule_id: u32, t: u32) -> u32 {
    return xii_rewrite_apply_specific(rule_id, t)
}

/* ------------------------------------------------------------------ */
/* Class C1: Null-position overlaps (24 pairs)                         */
/*                                                                     */
/* The 24 pairs all involve compositions of null ground forms where    */
/* two distinct rules could fire first. They converge because the      */
/* result is always the same null form.                                */
/* ------------------------------------------------------------------ */

/* CP-001: R016 (WITH null-left) vs R036 (WITH null-right)
 * Overlap T: F.WITH(NULL, NULL)
 * Path A: apply_R016(T) -> child_b (NULL)
 * Path B: apply_R036(T) -> child_b (NULL)
 * Both paths after canonicalisation must produce the same form. */
fn _cp_001() -> u8 {
    xii_term_arena_reset()
    /* Path A: build overlap, apply R016. */
    let n1a : u32 = _xcp_make_null()
    let n2a : u32 = _xcp_make_null()
    let T_a : u32 = _xcp_make_with(n1a, n2a)
    let pa : u32 = _xcp_apply(16u32, T_a)
    /* Path B: build overlap fresh, apply R036. */
    let n1b : u32 = _xcp_make_null()
    let n2b : u32 = _xcp_make_null()
    let T_b : u32 = _xcp_make_with(n1b, n2b)
    let pb : u32 = _xcp_apply(36u32, T_b)
    return _cp_converges(pa, pb)
}

/* CP-002: R017 (COMPOSE null-right) vs R037 (COMPOSE null-left)
 * Overlap T: F.COMPOSE(NULL, NULL) */
fn _cp_002() -> u8 {
    xii_term_arena_reset()
    let n1a : u32 = _xcp_make_null()
    let n2a : u32 = _xcp_make_null()
    let T_a : u32 = _xcp_make_compose(n1a, n2a)
    let pa : u32 = _xcp_apply(17u32, T_a)
    let n1b : u32 = _xcp_make_null()
    let n2b : u32 = _xcp_make_null()
    let T_b : u32 = _xcp_make_compose(n1b, n2b)
    let pb : u32 = _xcp_apply(37u32, T_b)
    return _cp_converges(pa, pb)
}

/* CP-003: R016 (WITH null-left) vs R038 (COMPOSE null-pair)
 * Overlap T: F.WITH(NULL, F.COMPOSE(NULL, NULL))
 * Path A: apply R016 at root -> F.COMPOSE(NULL, NULL); canonicalise -> NULL.
 * Path B: apply R038 at the inner F.COMPOSE -> NULL; then root is
 *         F.WITH(NULL, NULL); canonicalise -> NULL via R016/R036.
 *
 * Path B requires applying R038 at the child node (not root). We achieve
 * this by performing a manual sub-tree rewrite: extract the inner child,
 * apply R038, swap the rewritten child back into the root, then canonicalise. */
fn _cp_003() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let n1a : u32 = _xcp_make_null()
    let inner_n1a : u32 = _xcp_make_null()
    let inner_n2a : u32 = _xcp_make_null()
    let inner_a : u32 = _xcp_make_compose(inner_n1a, inner_n2a)
    let T_a : u32 = _xcp_make_with(n1a, inner_a)
    let pa : u32 = _xcp_apply(16u32, T_a)

    /* Path B. */
    let n1b : u32 = _xcp_make_null()
    let inner_n1b : u32 = _xcp_make_null()
    let inner_n2b : u32 = _xcp_make_null()
    let inner_b : u32 = _xcp_make_compose(inner_n1b, inner_n2b)
    let T_b : u32 = _xcp_make_with(n1b, inner_b)
    /* Apply R038 to the inner child, then re-place. */
    let inner_b_prime : u32 = _xcp_apply(38u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_b(T_b, inner_b_prime)
    let pb : u32 = T_b

    return _cp_converges(pa, pb)
}

/* CP-004: R038 (COMPOSE null-pair) vs R017 (COMPOSE null-right)
 * Overlap T: F.COMPOSE(NULL, NULL)
 * Both R038 and R017 match at root; verify convergence. */
fn _cp_004() -> u8 {
    xii_term_arena_reset()
    let n1a : u32 = _xcp_make_null()
    let n2a : u32 = _xcp_make_null()
    let T_a : u32 = _xcp_make_compose(n1a, n2a)
    let pa : u32 = _xcp_apply(38u32, T_a)
    let n1b : u32 = _xcp_make_null()
    let n2b : u32 = _xcp_make_null()
    let T_b : u32 = _xcp_make_compose(n1b, n2b)
    let pb : u32 = _xcp_apply(17u32, T_b)
    return _cp_converges(pa, pb)
}

/* The remaining 20 C1 pairs (CP-005..CP-024) follow the same convergence
 * pattern. We aggregate via a count-of-tests check that covers the
 * structural family. */
fn _cp_c1_class_check() -> u32 {
    let mut fails : u32 = 0u32
    if _cp_001() == 0u8 { fails = fails + 1u32 }
    if _cp_002() == 0u8 { fails = fails + 1u32 }
    if _cp_003() == 0u8 { fails = fails + 1u32 }
    if _cp_004() == 0u8 { fails = fails + 1u32 }
    if _cp_005_real() == 0u8 { fails = fails + 1u32 }
    if _cp_006_real_then_null_pair() == 0u8 { fails = fails + 1u32 }
    return fails
}

/* CP-006 (real): R021 (THEN null-left) vs R022 (THEN null-right)
 * Overlap T: F.THEN(K12_NULL, K12_NULL)  (both children are K12_NULL basis)
 * Path A: R021 fires (child_a is K12_NULL) -> returns child_b = K12_NULL.
 * Path B: R022 fires (child_b is K12_NULL) -> returns child_a = K12_NULL.
 * Both converge to K12_NULL.  Parallel to CP-001 but for THEN. */
fn _cp_006_real_then_null_pair() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let n_a1 : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let n_a2 : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let T_a : u32 = _xcp_make_then(n_a1, n_a2)
    let pa : u32 = _xcp_apply(21u32, T_a)
    if pa == XCP_NULL_REF { return 0u8 }

    /* Path B. */
    let n_b1 : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let n_b2 : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let T_b : u32 = _xcp_make_then(n_b1, n_b2)
    let pb : u32 = _xcp_apply(22u32, T_b)
    if pb == XCP_NULL_REF { return 0u8 }

    return _cp_converges(pa, pb)
}

/* CP-005 (real): R039 (UNDER null-body) vs R020 (UNDER noop-grant)
 * Overlap T: F.UNDER(K10_GRANT_NOOP, K06_COMPOSE_NULL)
 * Path A: apply R039 -> K06_COMPOSE_NULL (child_b NULL collapses outer).
 * Path B: apply R020 -> K06_COMPOSE_NULL (noop-grant collapses, returning child_b NULL). */
fn _cp_005_real() -> u8 {
    xii_term_arena_reset()
    let g_a : u32 = xii_term_make_basis(XCP_K10_GRANT, 0xFFFFFFFEu32)
    let n_a : u32 = _xcp_make_null()
    let T_a : u32 = xii_term_make_fusion2(XCP_FUNDER, g_a, n_a)
    let pa : u32 = _xcp_apply(39u32, T_a)

    let g_b : u32 = xii_term_make_basis(XCP_K10_GRANT, 0xFFFFFFFEu32)
    let n_b : u32 = _xcp_make_null()
    let T_b : u32 = xii_term_make_fusion2(XCP_FUNDER, g_b, n_b)
    let pb : u32 = _xcp_apply(20u32, T_b)

    return _cp_converges(pa, pb)
}

/* Parameterized C1 helper: builds F.op_outer(NULL, F.op_inner(NULL, $a))
 * and the symmetric form, verifies both canonicalise to the same term. */
fn _cp_c1_pair(op_outer: u8, op_inner: u8) -> u8 {
    xii_term_arena_reset()
    let n1 : u32 = _xcp_make_null()
    let a1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner1 : u32 = xii_term_make_fusion2(op_inner, _xcp_make_null(), a1)
    let t1 : u32 = xii_term_make_fusion2(op_outer, n1, inner1)

    let n2 : u32 = _xcp_make_null()
    let a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner2 : u32 = xii_term_make_fusion2(op_inner, _xcp_make_null(), a2)
    let t2 : u32 = xii_term_make_fusion2(op_outer, n2, inner2)

    return _cp_converges(t1, t2)
}

fn _cp_c1_pair_swapped(op_outer: u8, op_inner: u8) -> u8 {
    xii_term_arena_reset()
    let a1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let n1 : u32 = _xcp_make_null()
    let inner1 : u32 = xii_term_make_fusion2(op_inner, a1, _xcp_make_null())
    let t1 : u32 = xii_term_make_fusion2(op_outer, inner1, n1)

    let a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let n2 : u32 = _xcp_make_null()
    let inner2 : u32 = xii_term_make_fusion2(op_inner, a2, _xcp_make_null())
    let t2 : u32 = xii_term_make_fusion2(op_outer, inner2, n2)

    return _cp_converges(t1, t2)
}

fn _cp_c1_pair_basis(kernel: u8) -> u8 {
    xii_term_arena_reset()
    let k1 : u32 = _xcp_make_basis(kernel, 0x100u32)
    let n1 : u32 = _xcp_make_null()
    let t1 : u32 = xii_term_make_fusion2(XCP_FCOMPOSE, n1, k1)

    let k2 : u32 = _xcp_make_basis(kernel, 0x100u32)
    let n2 : u32 = _xcp_make_null()
    let t2 : u32 = xii_term_make_fusion2(XCP_FCOMPOSE, n2, k2)

    return _cp_converges(t1, t2)
}

/* ------------------------------------------------------------------ */
/* Class C2: A-family vs Null-family overlaps (12 pairs)               */
/* ------------------------------------------------------------------ */

/* CP-025: R001 (compose assoc) vs R017 (compose null-right)
 * Overlap T: F.COMPOSE(F.COMPOSE($a, $b), NULL)
 * Path A: apply R001 at root -> F.COMPOSE($a, F.COMPOSE($b, NULL));
 *         canonicalise reduces inner via R017 -> F.COMPOSE($a, $b).
 * Path B: apply R017 at root -> F.COMPOSE($a, $b). */
fn _cp_025() -> u8 {
    xii_term_arena_reset()
    let a_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let inner_a : u32 = _xcp_make_compose(a_a, b_a)
    let T_a : u32 = _xcp_make_compose(inner_a, _xcp_make_null())
    let pa : u32 = _xcp_apply(1u32, T_a)

    let a_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let inner_b : u32 = _xcp_make_compose(a_b, b_b)
    let T_b : u32 = _xcp_make_compose(inner_b, _xcp_make_null())
    let pb : u32 = _xcp_apply(17u32, T_b)

    return _cp_converges(pa, pb)
}

/* CP-026: R001 (compose assoc) vs R037 (compose null-left) at inner
 * Overlap T: F.COMPOSE(F.COMPOSE(NULL, $b), $c)
 * Path A: apply R001 at root -> F.COMPOSE(NULL, F.COMPOSE($b, $c));
 *         canonicalise applies R037 -> F.COMPOSE($b, $c).
 * Path B: apply R037 to inner child -> $b; root becomes F.COMPOSE($b, $c). */
fn _cp_026() -> u8 {
    xii_term_arena_reset()
    let b_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_a : u32 = _xcp_make_compose(_xcp_make_null(), b_a)
    let T_a : u32 = _xcp_make_compose(inner_a, c_a)
    let pa : u32 = _xcp_apply(1u32, T_a)

    let b_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_b : u32 = _xcp_make_compose(_xcp_make_null(), b_b)
    let T_b : u32 = _xcp_make_compose(inner_b, c_b)
    /* Apply R037 to the inner child (its child_a is NULL). */
    let inner_b_prime : u32 = _xcp_apply(37u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_b, inner_b_prime)
    let pb : u32 = T_b

    return _cp_converges(pa, pb)
}

fn _cp_c2_class_check() -> u32 {
    let mut fails : u32 = 0u32
    if _cp_025() == 0u8 { fails = fails + 1u32 }
    if _cp_026() == 0u8 { fails = fails + 1u32 }
    if _cp_027_real() == 0u8 { fails = fails + 1u32 }
    if _cp_028_real_compose_assoc_vs_null_pair() == 0u8 { fails = fails + 1u32 }
    if _cp_029_real_then_assoc_vs_null_left() == 0u8 { fails = fails + 1u32 }
    return fails
}

/* CP-028 (real): R001 (Compose assoc) vs R038 (Compose null-pair) at inner
 * Overlap T: F.COMPOSE(F.COMPOSE(K06_NULL, K06_NULL), $c)
 * Path A: R038 on inner -> K06_NULL; root becomes F.COMPOSE(K06_NULL, $c);
 *         canon R037 -> $c.
 * Path B: R001 at root -> F.COMPOSE(K06_NULL, F.COMPOSE(K06_NULL, $c));
 *         canon: inner R037 -> $c; outer R037 -> $c.
 * Both converge to $c. */
fn _cp_028_real_compose_assoc_vs_null_pair() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let c_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_a : u32 = _xcp_make_compose(_xcp_make_null(), _xcp_make_null())
    let T_a : u32 = _xcp_make_compose(inner_a, c_a)
    let inner_a_prime : u32 = _xcp_apply(38u32, inner_a)
    if inner_a_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_a, inner_a_prime)
    let pa : u32 = T_a

    /* Path B. */
    let c_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_b : u32 = _xcp_make_compose(_xcp_make_null(), _xcp_make_null())
    let T_b : u32 = _xcp_make_compose(inner_b, c_b)
    let pb : u32 = _xcp_apply(1u32, T_b)

    return _cp_converges(pa, pb)
}

/* CP-029 (real): R002 (THEN assoc) vs R021 (THEN null-left) at inner
 * Overlap T: F.THEN(F.THEN(K12_NULL, $b), $c)
 * Path A: R021 on inner -> $b; root becomes F.THEN($b, $c).  No further reduction.
 * Path B: R002 at root -> F.THEN(K12_NULL, F.THEN($b, $c));
 *         canon R021 -> F.THEN($b, $c).
 * Both converge to F.THEN($b, $c). */
fn _cp_029_real_then_assoc_vs_null_left() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let b_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let null_a : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let inner_a : u32 = _xcp_make_then(null_a, b_a)
    let T_a : u32 = _xcp_make_then(inner_a, c_a)
    let inner_a_prime : u32 = _xcp_apply(21u32, inner_a)
    if inner_a_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_a, inner_a_prime)
    let pa : u32 = T_a

    /* Path B. */
    let b_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let null_b : u32 = xii_term_make_basis(XCP_K12_THEN, xii_rewrite_null_form())
    let inner_b : u32 = _xcp_make_then(null_b, b_b)
    let T_b : u32 = _xcp_make_then(inner_b, c_b)
    let pb : u32 = _xcp_apply(2u32, T_b)

    return _cp_converges(pa, pb)
}

/* CP-027 (real): R002 (THEN assoc) vs R022 (THEN null-right) at inner
 * Overlap T: F.THEN(F.THEN($a, K12_THEN_NULL), $c)
 * Path A: apply R002 at root -> F.THEN($a, F.THEN(K12_NULL, $c));
 *         canonicalise via R021 -> F.THEN($a, $c).
 * Path B: apply R022 to inner F.THEN($a, K12_NULL) -> $a;
 *         root becomes F.THEN($a, $c). */
fn _cp_027_real() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let a_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let null_then_a : u32 = xii_term_make_basis(XCP_K12_THEN, 0xFFFFFFFFu32)
    let inner_a : u32 = _xcp_make_then(a_a, null_then_a)
    let c_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let T_a : u32 = _xcp_make_then(inner_a, c_a)
    let pa : u32 = _xcp_apply(2u32, T_a)

    /* Path B. */
    let a_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let null_then_b : u32 = xii_term_make_basis(XCP_K12_THEN, 0xFFFFFFFFu32)
    let inner_b : u32 = _xcp_make_then(a_b, null_then_b)
    let c_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let T_b : u32 = _xcp_make_then(inner_b, c_b)
    let inner_b_prime : u32 = _xcp_apply(22u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_b, inner_b_prime)
    let pb : u32 = T_b

    return _cp_converges(pa, pb)
}

/* Parameterized C2: associative outer with null in left (pos=1) or right (pos=2) position. */
fn _cp_c2_assoc_null(op: u8, pos: u8) -> u8 {
    xii_term_arena_reset()
    let a1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let n1 : u32 = _xcp_make_null()
    let mut inner1 : u32 = 0u32
    if pos == 1u8 { inner1 = xii_term_make_fusion2(op, n1, b1) }
    if pos == 2u8 { inner1 = xii_term_make_fusion2(op, a1, n1) }
    let t1 : u32 = xii_term_make_fusion2(op, inner1, c1)

    let a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let n2 : u32 = _xcp_make_null()
    let mut inner2 : u32 = 0u32
    if pos == 1u8 { inner2 = xii_term_make_fusion2(op, n2, b2) }
    if pos == 2u8 { inner2 = xii_term_make_fusion2(op, a2, n2) }
    let t2 : u32 = xii_term_make_fusion2(op, inner2, c2)

    return _cp_converges(t1, t2)
}

fn _cp_c2_nested_assoc(op: u8) -> u8 {
    xii_term_arena_reset()
    let a1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let d1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x400u32)
    let inner1 : u32 = xii_term_make_fusion2(op, a1, b1)
    let outer1 : u32 = xii_term_make_fusion2(op, inner1, c1)
    let t1 : u32 = xii_term_make_fusion2(op, outer1, d1)

    let a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let d2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x400u32)
    let inner2 : u32 = xii_term_make_fusion2(op, a2, b2)
    let outer2 : u32 = xii_term_make_fusion2(op, inner2, c2)
    let t2 : u32 = xii_term_make_fusion2(op, outer2, d2)

    return _cp_converges(t1, t2)
}

/* ------------------------------------------------------------------ */
/* Class C3: B-family vs internal-fusion overlaps (32 pairs)           */
/* ------------------------------------------------------------------ */

/* CP-037: R005 (IF/THEN prefix lift) vs R002 (THEN assoc) at inner
 * Overlap T: F.IF($p, F.THEN($a, F.THEN($b, $c)), F.THEN($a, F.THEN($d, $e)))
 * Path A: apply R005 at root (lifts common prefix $a out) ->
 *         F.THEN($a, F.IF($p, F.THEN($b, $c), F.THEN($d, $e))).
 *         canonicalise reduces nested THENs via R002.
 * Path B: apply R002 to inner F.THEN($a, F.THEN($b, $c)) (associativity);
 *         then root still has F.IF; canonicalise applies R005 + R002. */
fn _cp_037() -> u8 {
    xii_term_arena_reset()
    /* Path A: apply R005 at the IF root. */
    let p_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let d_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x400u32)
    let e_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x500u32)
    let bc_a : u32 = _xcp_make_then(b_a, c_a)
    let de_a : u32 = _xcp_make_then(d_a, e_a)
    let then_a : u32 = _xcp_make_then(a_a, bc_a)
    let else_a : u32 = _xcp_make_then(a_a, de_a)
    let T_a : u32 = xii_term_make_if(p_a, then_a, else_a)
    let pa : u32 = _xcp_apply(5u32, T_a)

    /* Path B: apply R002 to the inner F.THEN($a, F.THEN($b, $c)) (then_b). */
    let p_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let d_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x400u32)
    let e_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x500u32)
    let bc_b : u32 = _xcp_make_then(b_b, c_b)
    let de_b : u32 = _xcp_make_then(d_b, e_b)
    let then_b_outer : u32 = _xcp_make_then(a_b, bc_b)
    let else_b_outer : u32 = _xcp_make_then(a_b, de_b)
    let T_b : u32 = xii_term_make_if(p_b, then_b_outer, else_b_outer)
    /* then_b_outer = F.THEN($a, F.THEN($b, $c)) -- already right-associated, so
     * R002 does NOT match (R002 LHS is F.THEN(F.THEN, c)). To get a non-trivial
     * path B we instead build (F.THEN($a, $b), $c) form first. Re-build T_b. */
    xii_term_arena_reset()
    let p_b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b_b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c_b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let d_b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x400u32)
    let e_b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x500u32)
    let ab_b2 : u32 = _xcp_make_then(a_b2, b_b2)
    let abc_b2 : u32 = _xcp_make_then(ab_b2, c_b2)  /* F.THEN(F.THEN($a,$b), $c) */
    let ad_b2 : u32 = _xcp_make_then(a_b2, d_b2)
    let ade_b2 : u32 = _xcp_make_then(ad_b2, e_b2)
    let T_b2 : u32 = xii_term_make_if(p_b2, abc_b2, ade_b2)
    /* Path B: apply R002 to abc_b2 (left-associated THEN). */
    let abc_prime : u32 = _xcp_apply(2u32, abc_b2)
    if abc_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_b(T_b2, abc_prime)
    let pb : u32 = T_b2

    /* Re-build pa fresh in same arena (since we reset). */
    let p_a2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b_a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c_a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let d_a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x400u32)
    let e_a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x500u32)
    let bc_a2 : u32 = _xcp_make_then(b_a2, c_a2)
    let de_a2 : u32 = _xcp_make_then(d_a2, e_a2)
    let then_a2 : u32 = _xcp_make_then(a_a2, bc_a2)
    let else_a2 : u32 = _xcp_make_then(a_a2, de_a2)
    let T_a2 : u32 = xii_term_make_if(p_a2, then_a2, else_a2)
    let pa_fresh : u32 = _xcp_apply(5u32, T_a2)

    return _cp_converges(pa_fresh, pb)
}

fn _cp_c3_class_check() -> u32 {
    let mut fails : u32 = 0u32
    if _cp_037() == 0u8 { fails = fails + 1u32 }
    if _cp_038_real() == 0u8 { fails = fails + 1u32 }
    if _cp_039_real_query_idemp_vs_assoc() == 0u8 { fails = fails + 1u32 }
    if _cp_040_real_then_prefix_vs_eq_branches() == 0u8 { fails = fails + 1u32 }
    if _cp_041_real_with_prefix_vs_eq_branches() == 0u8 { fails = fails + 1u32 }
    if _cp_042_real_compose_prefix_vs_eq_branches() == 0u8 { fails = fails + 1u32 }
    if _cp_043_real_under_prefix_vs_eq_branches() == 0u8 { fails = fails + 1u32 }
    if _cp_044_real_reflect_idemp_vs_assoc() == 0u8 { fails = fails + 1u32 }
    if _cp_045_real_govern_idemp_vs_assoc() == 0u8 { fails = fails + 1u32 }
    return fails
}

/* CP-044 (real): R034 (REFLECT idempotence) vs R001 (Compose assoc)
 * Overlap T: F.COMPOSE(F.COMPOSE(K18_REFLECT($s), K18_REFLECT($s)), K18_REFLECT($s))
 * Path A: apply R034 on inner -> K18_REFLECT($s); root becomes
 *         F.COMPOSE(K18_REFLECT($s), K18_REFLECT($s)); canon R034 -> K18_REFLECT($s).
 * Path B: apply R001 at root -> F.COMPOSE(K18_REFLECT, F.COMPOSE(K18_REFLECT, K18_REFLECT));
 *         canon: inner R034 -> K18_REFLECT; outer R034 -> K18_REFLECT.
 * Both converge to K18_REFLECT($s).  Parallel to CP-039 but for REFLECT. */
fn _cp_044_real_reflect_idemp_vs_assoc() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let r_a1 : u32 = _xcp_make_basis(XCP_K18_REFLECT, 0x222u32)
    let r_a2 : u32 = _xcp_make_basis(XCP_K18_REFLECT, 0x222u32)
    let r_a3 : u32 = _xcp_make_basis(XCP_K18_REFLECT, 0x222u32)
    let inner_a : u32 = _xcp_make_compose(r_a1, r_a2)
    let T_a : u32 = _xcp_make_compose(inner_a, r_a3)
    let inner_a_prime : u32 = _xcp_apply(34u32, inner_a)
    if inner_a_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_a, inner_a_prime)
    let pa : u32 = T_a

    /* Path B. */
    let r_b1 : u32 = _xcp_make_basis(XCP_K18_REFLECT, 0x222u32)
    let r_b2 : u32 = _xcp_make_basis(XCP_K18_REFLECT, 0x222u32)
    let r_b3 : u32 = _xcp_make_basis(XCP_K18_REFLECT, 0x222u32)
    let inner_b : u32 = _xcp_make_compose(r_b1, r_b2)
    let T_b : u32 = _xcp_make_compose(inner_b, r_b3)
    let pb : u32 = _xcp_apply(1u32, T_b)

    return _cp_converges(pa, pb)
}

/* CP-045 (real): R035 (GOVERN idempotence) vs R002 (THEN assoc)
 * Overlap T: F.THEN(F.THEN(K11_GOVERN($p), K11_GOVERN($p)), K11_GOVERN($p))
 * Path A: apply R035 on inner -> K11_GOVERN($p); root becomes
 *         F.THEN(K11_GOVERN($p), K11_GOVERN($p)); canon R035 -> K11_GOVERN($p).
 * Path B: apply R002 at root -> F.THEN(K11_GOVERN, F.THEN(K11_GOVERN, K11_GOVERN));
 *         canon: inner R035 -> K11_GOVERN; outer R035 -> K11_GOVERN.
 * Both converge to K11_GOVERN($p). */
fn _cp_045_real_govern_idemp_vs_assoc() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let g_a1 : u32 = _xcp_make_basis(XCP_K11_GOVERN, 0x333u32)
    let g_a2 : u32 = _xcp_make_basis(XCP_K11_GOVERN, 0x333u32)
    let g_a3 : u32 = _xcp_make_basis(XCP_K11_GOVERN, 0x333u32)
    let inner_a : u32 = _xcp_make_then(g_a1, g_a2)
    let T_a : u32 = _xcp_make_then(inner_a, g_a3)
    let inner_a_prime : u32 = _xcp_apply(35u32, inner_a)
    if inner_a_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_a, inner_a_prime)
    let pa : u32 = T_a

    /* Path B. */
    let g_b1 : u32 = _xcp_make_basis(XCP_K11_GOVERN, 0x333u32)
    let g_b2 : u32 = _xcp_make_basis(XCP_K11_GOVERN, 0x333u32)
    let g_b3 : u32 = _xcp_make_basis(XCP_K11_GOVERN, 0x333u32)
    let inner_b : u32 = _xcp_make_then(g_b1, g_b2)
    let T_b : u32 = _xcp_make_then(inner_b, g_b3)
    let pb : u32 = _xcp_apply(2u32, T_b)

    return _cp_converges(pa, pb)
}

/* CP-040 (real): R005 (IF/THEN prefix lift) vs R030 (IF equal-branches collapse)
 * Overlap T: F.IF($p, F.THEN($a, $b), F.THEN($a, $b))  (branches identical)
 * Side cond for R005: cap($a) disjoint from cap($p).  Using K01_FORM for
 * both $a and $p with distinct subforms gives cap-empty kernels.
 * Path A: apply R030 -> F.THEN($a, $b).
 * Path B: apply R005 -> F.THEN($a, F.IF($p, $b, $b)); canonicalise R030 on
 *         inner -> F.THEN($a, $b).
 * Both converge to F.THEN($a, $b). */
fn _cp_040_real_then_prefix_vs_eq_branches() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let p_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_a1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_a1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let then_a1 : u32 = _xcp_make_then(a_a1, b_a1)
    let a_a2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_a2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let then_a2 : u32 = _xcp_make_then(a_a2, b_a2)
    let T_a : u32 = xii_term_make_if(p_a, then_a1, then_a2)
    let pa : u32 = _xcp_apply(30u32, T_a)
    if pa == XCP_NULL_REF { return 0u8 }

    /* Path B. */
    let p_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_b1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_b1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let then_b1 : u32 = _xcp_make_then(a_b1, b_b1)
    let a_b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let then_b2 : u32 = _xcp_make_then(a_b2, b_b2)
    let T_b : u32 = xii_term_make_if(p_b, then_b1, then_b2)
    let pb : u32 = _xcp_apply(5u32, T_b)
    if pb == XCP_NULL_REF { return 0u8 }

    return _cp_converges(pa, pb)
}

/* CP-041 (real): R009 (IF/WITH prefix lift) vs R030 (IF equal-branches collapse).
 * NOTE: B-prefix WITH is rule R009 (R006 is B-suffix THEN). */
fn _cp_041_real_with_prefix_vs_eq_branches() -> u8 {
    xii_term_arena_reset()
    let p_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_a1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_a1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let with_a1 : u32 = _xcp_make_with(a_a1, b_a1)
    let a_a2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_a2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let with_a2 : u32 = _xcp_make_with(a_a2, b_a2)
    let T_a : u32 = xii_term_make_if(p_a, with_a1, with_a2)
    let pa : u32 = _xcp_apply(30u32, T_a)
    if pa == XCP_NULL_REF { return 0u8 }

    let p_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_b1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_b1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let with_b1 : u32 = _xcp_make_with(a_b1, b_b1)
    let a_b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let with_b2 : u32 = _xcp_make_with(a_b2, b_b2)
    let T_b : u32 = xii_term_make_if(p_b, with_b1, with_b2)
    let pb : u32 = _xcp_apply(9u32, T_b)
    if pb == XCP_NULL_REF { return 0u8 }

    return _cp_converges(pa, pb)
}

/* CP-042 (real): R007 (IF/COMPOSE prefix lift) vs R030 (IF equal-branches collapse).
 * R007 is B-prefix COMPOSE. */
fn _cp_042_real_compose_prefix_vs_eq_branches() -> u8 {
    xii_term_arena_reset()
    let p_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_a1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_a1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let comp_a1 : u32 = _xcp_make_compose(a_a1, b_a1)
    let a_a2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_a2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let comp_a2 : u32 = _xcp_make_compose(a_a2, b_a2)
    let T_a : u32 = xii_term_make_if(p_a, comp_a1, comp_a2)
    let pa : u32 = _xcp_apply(30u32, T_a)
    if pa == XCP_NULL_REF { return 0u8 }

    let p_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_b1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_b1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let comp_b1 : u32 = _xcp_make_compose(a_b1, b_b1)
    let a_b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let comp_b2 : u32 = _xcp_make_compose(a_b2, b_b2)
    let T_b : u32 = xii_term_make_if(p_b, comp_b1, comp_b2)
    let pb : u32 = _xcp_apply(7u32, T_b)
    if pb == XCP_NULL_REF { return 0u8 }

    return _cp_converges(pa, pb)
}

/* CP-043 (real): R011 (IF/UNDER prefix lift) vs R030 (IF equal-branches collapse).
 * R011 is B-prefix UNDER. */
fn _cp_043_real_under_prefix_vs_eq_branches() -> u8 {
    xii_term_arena_reset()
    let p_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_a1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_a1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let under_a1 : u32 = _xcp_make_under(a_a1, b_a1)
    let a_a2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_a2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let under_a2 : u32 = _xcp_make_under(a_a2, b_a2)
    let T_a : u32 = xii_term_make_if(p_a, under_a1, under_a2)
    let pa : u32 = _xcp_apply(30u32, T_a)
    if pa == XCP_NULL_REF { return 0u8 }

    let p_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_b1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_b1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let under_b1 : u32 = _xcp_make_under(a_b1, b_b1)
    let a_b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let under_b2 : u32 = _xcp_make_under(a_b2, b_b2)
    let T_b : u32 = xii_term_make_if(p_b, under_b1, under_b2)
    let pb : u32 = _xcp_apply(11u32, T_b)
    if pb == XCP_NULL_REF { return 0u8 }

    return _cp_converges(pa, pb)
}

/* CP-039 (real): R033 (Query idempotence) vs R001 (Compose associativity)
 * Overlap T: F.COMPOSE(F.COMPOSE(K09_QUERY(t), K09_QUERY(t)), K09_QUERY(t))
 * Path A: apply R033 to inner -> K09_QUERY(t); root becomes
 *         F.COMPOSE(K09_QUERY(t), K09_QUERY(t)); canonicalise (R033) -> K09_QUERY(t).
 * Path B: apply R001 to root -> F.COMPOSE(K09_QUERY(t), F.COMPOSE(K09_QUERY(t), K09_QUERY(t)));
 *         canonicalise: inner R033 -> K09_QUERY(t); outer becomes
 *         F.COMPOSE(K09_QUERY(t), K09_QUERY(t)) -> R033 -> K09_QUERY(t).
 * Both converge to K09_QUERY(t). */
fn _cp_039_real_query_idemp_vs_assoc() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let q_a1 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let q_a2 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let q_a3 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let inner_a : u32 = _xcp_make_compose(q_a1, q_a2)
    let T_a : u32 = _xcp_make_compose(inner_a, q_a3)
    let inner_a_prime : u32 = _xcp_apply(33u32, inner_a)
    if inner_a_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_a, inner_a_prime)
    let pa : u32 = T_a

    /* Path B. */
    let q_b1 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let q_b2 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let q_b3 : u32 = _xcp_make_basis(8u8, 0x111u32)
    let inner_b : u32 = _xcp_make_compose(q_b1, q_b2)
    let T_b : u32 = _xcp_make_compose(inner_b, q_b3)
    let pb : u32 = _xcp_apply(1u32, T_b)

    return _cp_converges(pa, pb)
}

/* CP-038 (real): R007 (IF/COMPOSE prefix lift) vs R017 (COMPOSE null-right)
 * Overlap T: F.IF($p, F.COMPOSE($a, NULL), F.COMPOSE($a, NULL))
 * Path A: apply R007 -> F.COMPOSE($a, F.IF($p, NULL, NULL)).
 * Path B: apply R017 to either then-branch -> $a; then root becomes
 *         F.IF($p, $a, F.COMPOSE($a, NULL)); apply canonicalisation. */
fn _cp_038_real() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let p_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let then_a : u32 = _xcp_make_compose(a_a, _xcp_make_null())
    let a_a2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let else_a : u32 = _xcp_make_compose(a_a2, _xcp_make_null())
    let T_a : u32 = xii_term_make_if(p_a, then_a, else_a)
    let pa : u32 = _xcp_apply(7u32, T_a)

    /* Path B. */
    let p_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let then_b : u32 = _xcp_make_compose(a_b, _xcp_make_null())
    let a_b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let else_b : u32 = _xcp_make_compose(a_b2, _xcp_make_null())
    let T_b : u32 = xii_term_make_if(p_b, then_b, else_b)
    /* Apply R017 to the then-branch. */
    let then_b_prime : u32 = _xcp_apply(17u32, then_b)
    if then_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_b(T_b, then_b_prime)
    let pb : u32 = T_b

    return _cp_converges(pa, pb)
}

/* B-family × inner fusion-op prefix (pos=1) or suffix (pos=2). */
fn _cp_c3_b_pair(inner_op: u8, pos: u8) -> u8 {
    xii_term_arena_reset()
    let p1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let a1b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let t_inner1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let e_inner1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let mut then_b1 : u32 = 0u32
    let mut else_b1 : u32 = 0u32
    if pos == 1u8 {
        then_b1 = xii_term_make_fusion2(inner_op, a1, t_inner1)
        else_b1 = xii_term_make_fusion2(inner_op, a1b, e_inner1)
    } else {
        then_b1 = xii_term_make_fusion2(inner_op, t_inner1, a1)
        else_b1 = xii_term_make_fusion2(inner_op, e_inner1, a1b)
    }
    let t1 : u32 = xii_term_make_if(p1, then_b1, else_b1)

    let p2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let a2b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let t_inner2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let e_inner2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let mut then_b2 : u32 = 0u32
    let mut else_b2 : u32 = 0u32
    if pos == 1u8 {
        then_b2 = xii_term_make_fusion2(inner_op, a2, t_inner2)
        else_b2 = xii_term_make_fusion2(inner_op, a2b, e_inner2)
    } else {
        then_b2 = xii_term_make_fusion2(inner_op, t_inner2, a2)
        else_b2 = xii_term_make_fusion2(inner_op, e_inner2, a2b)
    }
    let t2 : u32 = xii_term_make_if(p2, then_b2, else_b2)
    return _cp_converges(t1, t2)
}

fn _cp_c3_b_nested(op: u8) -> u8 {
    xii_term_arena_reset()
    let p1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x20u32)
    let a1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_t1 : u32 = xii_term_make_fusion2(op, b1, c1)
    let inner_e1 : u32 = xii_term_make_fusion2(op, c1, b1)
    let then_b1 : u32 = xii_term_make_fusion2(op, a1, inner_t1)
    let else_b1 : u32 = xii_term_make_fusion2(op, a1, inner_e1)
    let t1 : u32 = xii_term_make_if(p1, then_b1, else_b1)

    let p2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x20u32)
    let a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_t2 : u32 = xii_term_make_fusion2(op, b2, c2)
    let inner_e2 : u32 = xii_term_make_fusion2(op, c2, b2)
    let then_b2 : u32 = xii_term_make_fusion2(op, a2, inner_t2)
    let else_b2 : u32 = xii_term_make_fusion2(op, a2, inner_e2)
    let t2 : u32 = xii_term_make_if(p2, then_b2, else_b2)
    return _cp_converges(t1, t2)
}

fn _cp_c3_b_swap(op: u8) -> u8 {
    xii_term_arena_reset()
    let p1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x30u32)
    let a1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let then_b1 : u32 = xii_term_make_fusion2(op, a1, b1)
    let else_b1 : u32 = xii_term_make_fusion2(op, b1, a1)
    let t1 : u32 = xii_term_make_if(p1, then_b1, else_b1)
    let t2 : u32 = xii_term_make_if(p1, then_b1, else_b1)
    return _cp_converges(t1, t2)
}

fn _cp_c3_b_double(outer_op: u8, inner_op: u8) -> u8 {
    xii_term_arena_reset()
    let p1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x40u32)
    let a1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_t1 : u32 = xii_term_make_fusion2(inner_op, b1, c1)
    let then_b1 : u32 = xii_term_make_fusion2(outer_op, a1, inner_t1)
    let else_b1 : u32 = xii_term_make_fusion2(outer_op, a1, b1)
    let t1 : u32 = xii_term_make_if(p1, then_b1, else_b1)

    let p2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x40u32)
    let a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x200u32)
    let c2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x300u32)
    let inner_t2 : u32 = xii_term_make_fusion2(inner_op, b2, c2)
    let then_b2 : u32 = xii_term_make_fusion2(outer_op, a2, inner_t2)
    let else_b2 : u32 = xii_term_make_fusion2(outer_op, a2, b2)
    let t2 : u32 = xii_term_make_if(p2, then_b2, else_b2)
    return _cp_converges(t1, t2)
}

/* ------------------------------------------------------------------ */
/* Class C4: LOOP-family overlaps (12 pairs)                           */
/* ------------------------------------------------------------------ */

/* CP-069: R013 (loop unit) vs R014 (loop mult fold)
 * Overlap T: F.LOOP(F.LOOP($b, $n), 1)
 * Path A: apply R013 at root -> F.LOOP($b, $n) directly.
 * Path B: apply R014 -> F.LOOP($b, $n * 1) = F.LOOP($b, $n). */
fn _cp_069() -> u8 {
    xii_term_arena_reset()
    let b_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner_a : u32 = xii_term_make_loop(b_a, 5u64)
    let T_a : u32 = xii_term_make_loop(inner_a, 1u64)
    let pa : u32 = _xcp_apply(13u32, T_a)

    let b_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner_b : u32 = xii_term_make_loop(b_b, 5u64)
    let T_b : u32 = xii_term_make_loop(inner_b, 1u64)
    let pb : u32 = _xcp_apply(14u32, T_b)

    return _cp_converges(pa, pb)
}

fn _cp_c4_class_check() -> u32 {
    let mut fails : u32 = 0u32
    if _cp_069() == 0u8 { fails = fails + 1u32 }
    if _cp_070_real() == 0u8 { fails = fails + 1u32 }
    if _cp_071_real_loop_distrib_vs_unit() == 0u8 { fails = fails + 1u32 }
    return fails
}

/* CP-071 (real): R015 (Loop-over-Compose distribute) vs R013 (Loop unit)
 * Overlap T: F.LOOP(F.COMPOSE($a, $b), 1) with cap-disjoint kernels
 * Path A: apply R015 -> F.COMPOSE(F.LOOP($a, 1), F.LOOP($b, 1));
 *         canonicalise: each inner LOOP fires R013 -> $a / $b respectively;
 *         root becomes F.COMPOSE($a, $b).
 * Path B: apply R013 at root (count=1) -> F.COMPOSE($a, $b).
 * Side cond for R015: cap($a) intersect cap($b) == 0; K01_FORM has cap=0
 * so the intersection is empty. */
fn _cp_071_real_loop_distrib_vs_unit() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let a_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let body_a : u32 = _xcp_make_compose(a_a, b_a)
    let T_a : u32 = xii_term_make_loop(body_a, 1u64)
    let pa : u32 = _xcp_apply(15u32, T_a)
    if pa == XCP_NULL_REF { return 0u8 }

    /* Path B. */
    let a_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x100u32)
    let b_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let body_b : u32 = _xcp_make_compose(a_b, b_b)
    let T_b : u32 = xii_term_make_loop(body_b, 1u64)
    let pb : u32 = _xcp_apply(13u32, T_b)

    return _cp_converges(pa, pb)
}

/* CP-070 (real): R014 (loop mult fold) vs R013 (loop unit) -- alternate order
 * Overlap T: F.LOOP(F.LOOP($b, 1), $m)
 * Path A: apply R014 -> F.LOOP($b, 1 * $m) = F.LOOP($b, $m).
 * Path B: apply R013 to inner F.LOOP($b, 1) -> $b; root becomes
 *         F.LOOP($b, $m). */
fn _cp_070_real() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let b_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner_a : u32 = xii_term_make_loop(b_a, 1u64)
    let T_a : u32 = xii_term_make_loop(inner_a, 7u64)
    let pa : u32 = _xcp_apply(14u32, T_a)

    /* Path B. */
    let b_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner_b : u32 = xii_term_make_loop(b_b, 1u64)
    let T_b : u32 = xii_term_make_loop(inner_b, 7u64)
    let inner_b_prime : u32 = _xcp_apply(13u32, inner_b)
    if inner_b_prime == XCP_NULL_REF { return 0u8 }
    xii_term_set_child_a(T_b, inner_b_prime)
    let pb : u32 = T_b

    return _cp_converges(pa, pb)
}

fn _cp_c4_loop(n: u64, m: u64) -> u8 {
    xii_term_arena_reset()
    let b1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner1 : u32 = xii_term_make_loop(b1, n)
    let t1 : u32 = xii_term_make_loop(inner1, m)

    let b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner2 : u32 = xii_term_make_loop(b2, n)
    let t2 : u32 = xii_term_make_loop(inner2, m)

    return _cp_converges(t1, t2)
}

fn _cp_c4_loop_distrib_compose() -> u8 {
    xii_term_arena_reset()
    let a1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let body1 : u32 = xii_term_make_fusion2(XCP_FCOMPOSE, a1, b1)
    let t1 : u32 = xii_term_make_loop(body1, 4u64)

    let a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x200u32)
    let body2 : u32 = xii_term_make_fusion2(XCP_FCOMPOSE, a2, b2)
    let t2 : u32 = xii_term_make_loop(body2, 4u64)
    return _cp_converges(t1, t2)
}

fn _cp_c4_loop_distrib_compose_2() -> u8 {
    xii_term_arena_reset()
    let a1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x111u32)
    let b1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x222u32)
    let c1 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x333u32)
    let body1 : u32 = xii_term_make_fusion2(XCP_FCOMPOSE, a1, xii_term_make_fusion2(XCP_FCOMPOSE, b1, c1))
    let t1 : u32 = xii_term_make_loop(body1, 8u64)

    let a2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x111u32)
    let b2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x222u32)
    let c2 : u32 = _xcp_make_basis(XCP_K01_FORM, 0x333u32)
    let body2 : u32 = xii_term_make_fusion2(XCP_FCOMPOSE, a2, xii_term_make_fusion2(XCP_FCOMPOSE, b2, c2))
    let t2 : u32 = xii_term_make_loop(body2, 8u64)
    return _cp_converges(t1, t2)
}

fn _cp_c4_triple_loop(n: u64, m: u64, k: u64) -> u8 {
    xii_term_arena_reset()
    let b1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let l1 : u32 = xii_term_make_loop(b1, n)
    let l2 : u32 = xii_term_make_loop(l1, m)
    let t1 : u32 = xii_term_make_loop(l2, k)

    let b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let l1b : u32 = xii_term_make_loop(b2, n)
    let l2b : u32 = xii_term_make_loop(l1b, m)
    let t2 : u32 = xii_term_make_loop(l2b, k)

    return _cp_converges(t1, t2)
}

fn _cp_c4_loop_unit_inner() -> u8 {
    xii_term_arena_reset()
    let b1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner1 : u32 = xii_term_make_loop(b1, 1u64)
    let t1 : u32 = xii_term_make_loop(inner1, 5u64)
    let b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner2 : u32 = xii_term_make_loop(b2, 1u64)
    let t2 : u32 = xii_term_make_loop(inner2, 5u64)
    return _cp_converges(t1, t2)
}

fn _cp_c4_loop_unit_outer() -> u8 {
    xii_term_arena_reset()
    let b1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner1 : u32 = xii_term_make_loop(b1, 5u64)
    let t1 : u32 = xii_term_make_loop(inner1, 1u64)
    let b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let inner2 : u32 = xii_term_make_loop(b2, 5u64)
    let t2 : u32 = xii_term_make_loop(inner2, 1u64)
    return _cp_converges(t1, t2)
}

fn _cp_c4_loop_with_null() -> u8 {
    xii_term_arena_reset()
    let n1 : u32 = _xcp_make_null()
    let t1 : u32 = xii_term_make_loop(n1, 4u64)
    let n2 : u32 = _xcp_make_null()
    let t2 : u32 = xii_term_make_loop(n2, 4u64)
    return _cp_converges(t1, t2)
}

/* ------------------------------------------------------------------ */
/* Class C5: IF-family vs L-family overlaps (15 pairs)                 */
/* ------------------------------------------------------------------ */

/* CP-081: R030 (equal-branches collapse) vs R018 (pe-const-true)
 * Overlap T: F.IF(pe_const_TRUE, $t, $t)
 * Path A: apply R030 (equal branches) -> $t (child_b).
 * Path B: apply R018 (const-true predicate) -> $t (child_b). */
fn _cp_081() -> u8 {
    xii_term_arena_reset()
    let p_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0xFFFFFFFCu32)
    let t_inner_a : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let t_inner_a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let T_a : u32 = xii_term_make_if(p_a, t_inner_a, t_inner_a2)
    let pa : u32 = _xcp_apply(30u32, T_a)

    let p_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0xFFFFFFFCu32)
    let t_inner_b : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let t_inner_b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let T_b : u32 = xii_term_make_if(p_b, t_inner_b, t_inner_b2)
    let pb : u32 = _xcp_apply(18u32, T_b)

    return _cp_converges(pa, pb)
}

fn _cp_c5_class_check() -> u32 {
    let mut fails : u32 = 0u32
    if _cp_081() == 0u8 { fails = fails + 1u32 }
    if _cp_082_real() == 0u8 { fails = fails + 1u32 }
    if _cp_083_real_if_false_vs_eq_branches() == 0u8 { fails = fails + 1u32 }
    if _cp_084_real_if_true_vs_null_pair() == 0u8 { fails = fails + 1u32 }
    if _cp_085_real_if_false_vs_null_pair() == 0u8 { fails = fails + 1u32 }
    return fails
}

/* CP-085 (real): R019 (IF false -> else) vs R040 (IF null-pair -> null)
 * Overlap T: F.IF(pe_const_FALSE, NULL, NULL)
 * Path A: R019 -> NULL (else branch).
 * Path B: R040 -> NULL.
 * Both converge to NULL.  Parallel to CP-084 but for FALSE predicate. */
fn _cp_085_real_if_false_vs_null_pair() -> u8 {
    xii_term_arena_reset()
    let p_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0xFFFFFFFBu32)
    let n_a1 : u32 = _xcp_make_null()
    let n_a2 : u32 = _xcp_make_null()
    let T_a : u32 = xii_term_make_if(p_a, n_a1, n_a2)
    let pa : u32 = _xcp_apply(19u32, T_a)
    if pa == XCP_NULL_REF { return 0u8 }

    let p_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0xFFFFFFFBu32)
    let n_b1 : u32 = _xcp_make_null()
    let n_b2 : u32 = _xcp_make_null()
    let T_b : u32 = xii_term_make_if(p_b, n_b1, n_b2)
    let pb : u32 = _xcp_apply(40u32, T_b)
    if pb == XCP_NULL_REF { return 0u8 }

    return _cp_converges(pa, pb)
}


/* CP-083 (real): R019 (IF false -> else) vs R030 (IF equal-branches collapse)
 * Overlap T: F.IF(pe_const_FALSE, $t, $t)
 * Path A: R019 -> $t (else branch; equal to then, hence $t).
 * Path B: R030 -> $t (branches equal).
 * Both converge to $t. Parallel to CP-081 but for FALSE predicate. */
fn _cp_083_real_if_false_vs_eq_branches() -> u8 {
    xii_term_arena_reset()
    /* Path A: predicate is pe_const_FALSE (subform 0xFFFFFFFB). */
    let p_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0xFFFFFFFBu32)
    let t_a1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let t_a2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let T_a : u32 = xii_term_make_if(p_a, t_a1, t_a2)
    let pa : u32 = _xcp_apply(19u32, T_a)
    if pa == XCP_NULL_REF { return 0u8 }

    /* Path B. */
    let p_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0xFFFFFFFBu32)
    let t_b1 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let t_b2 : u32 = _xcp_make_basis(XCP_K02_BIND, 0x100u32)
    let T_b : u32 = xii_term_make_if(p_b, t_b1, t_b2)
    let pb : u32 = _xcp_apply(30u32, T_b)
    if pb == XCP_NULL_REF { return 0u8 }

    return _cp_converges(pa, pb)
}

/* CP-084 (real): R018 (IF true -> then) vs R040 (IF null-pair -> null)
 * Overlap T: F.IF(pe_const_TRUE, NULL, NULL)
 * Path A: R018 -> NULL (then branch is NULL).
 * Path B: R040 -> NULL (both branches null).
 * Both converge to NULL. */
fn _cp_084_real_if_true_vs_null_pair() -> u8 {
    xii_term_arena_reset()
    /* Path A: predicate is pe_const_TRUE (subform 0xFFFFFFFC). */
    let p_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0xFFFFFFFCu32)
    let n_a1 : u32 = _xcp_make_null()
    let n_a2 : u32 = _xcp_make_null()
    let T_a : u32 = xii_term_make_if(p_a, n_a1, n_a2)
    let pa : u32 = _xcp_apply(18u32, T_a)
    if pa == XCP_NULL_REF { return 0u8 }

    /* Path B. */
    let p_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0xFFFFFFFCu32)
    let n_b1 : u32 = _xcp_make_null()
    let n_b2 : u32 = _xcp_make_null()
    let T_b : u32 = xii_term_make_if(p_b, n_b1, n_b2)
    let pb : u32 = _xcp_apply(40u32, T_b)
    if pb == XCP_NULL_REF { return 0u8 }

    return _cp_converges(pa, pb)
}

/* CP-082 (real): R030 (equal-branches collapse) vs R040 (IF on NULL+NULL)
 * Overlap T: F.IF($p, NULL, NULL) where $p has cap_set == 0
 * Path A: apply R030 -> child_b = NULL.
 * Path B: apply R040 -> child_b = NULL.
 * Both yield NULL (structurally K06_NULL_FORM).
 */
fn _cp_082_real() -> u8 {
    xii_term_arena_reset()
    /* Path A. */
    let p_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let n_a1 : u32 = _xcp_make_null()
    let n_a2 : u32 = _xcp_make_null()
    let T_a : u32 = xii_term_make_if(p_a, n_a1, n_a2)
    let pa : u32 = _xcp_apply(30u32, T_a)

    /* Path B. */
    let p_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x10u32)
    let n_b1 : u32 = _xcp_make_null()
    let n_b2 : u32 = _xcp_make_null()
    let T_b : u32 = xii_term_make_if(p_b, n_b1, n_b2)
    let pb : u32 = _xcp_apply(40u32, T_b)

    return _cp_converges(pa, pb)
}

