/* CP-213 (real): R13 (Loop unit) vs R15 (Loop-over-Compose distribute)
 * Overlap T: F.LOOP(F.COMPOSE($a, $b), 1) with cap-disjoint $a, $b
 * Path A: R13 (count=1) -> F.COMPOSE($a, $b).
 * Path B: R15 -> F.COMPOSE(F.LOOP($a, 1), F.LOOP($b, 1)); inner LOOPs
 *         each canonicalise via R13 -> $a / $b; outer -> F.COMPOSE($a, $b).
 * Side cond for R15: cap($a) intersect cap($b) == 0.  K01_FORM is
 * cap-empty so the side condition holds.  (Previous version used
 * K02_BIND which has caps -> R15 refuses to fire -> CP fails). */
fn _cp_213_loop_unit_vs_distrib() -> u8 {
    xii_term_arena_reset()
    let a_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x111u32)
    let b_a : u32 = _xcp_make_basis(XCP_K01_FORM, 0x222u32)
    let inner_a : u32 = _xcp_make_compose(a_a, b_a)
    let T_a : u32 = xii_term_make_loop(inner_a, 1u64)
    let pa : u32 = _xcp_apply(13u32, T_a)
    let a_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x111u32)
    let b_b : u32 = _xcp_make_basis(XCP_K01_FORM, 0x222u32)
    let inner_b : u32 = _xcp_make_compose(a_b, b_b)
    let T_b : u32 = xii_term_make_loop(inner_b, 1u64)
    let pb : u32 = _xcp_apply(15u32, T_b)
    return _cp_converges(pa, pb)
}

