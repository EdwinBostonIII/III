/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\xii_curated_crypto.iii
 *
 * III STDLIB - omnia::xii_curated_crypto
 *
 * Curated per-target machine-code bytes for additional cryptographic
 * Horizon patterns (H001..H024 subset). Companion to xii_curated_payloads.iii.
 *
 * Each registered (horizon_id, target) override is a real, sealed sequence
 * of machine-code bytes hand-curated for the target's ISA. All sequences
 * are constant-time-safe where the pattern's ct_kind > 0.
 *
 * Currently curated additional:
 *   H003 chacha20_block      on target 1 (x86_avx2)
 *   H003 chacha20_block      on target 3 (arm64_neon)
 *   H004 chacha20_round_pair on target 1
 *   H005 poly1305_block      on target 1 (PCLMULQDQ-backed)
 *   H007 aes_gcm_encrypt     on target 1 (AES-NI + PCLMULQDQ)
 *   H016 blake2s_block       on target 1
 *   H017 hmac_sha256         on target 1 (composition)
 *
 * Hexad: kind_substance. Ring: R0. K: per-pattern.
 *
 * NIH: libc only. Sealed bytes are real curated machine code.
 */

module omnia_xii_curated_crypto

extern @abi(c-msvc-x64) fn xii_emit_gen_override(horizon_id: u8, target: u8, payload: *u8, size: u16) -> i32 from "xii_emit_gen.iii"

/* ------------------------------------------------------------------ */
/* H003 chacha20_block on x86_avx2 (target 1)                          */
/* ------------------------------------------------------------------ */

/* ChaCha20 quarter-round using AVX2 VPADD + VPROL + VPXOR.
 *
 *  c5 fd 6f 07          vmovdqa  ymm0, [rdi]      (state rows 0-1)
 *  c5 fd 6f 4f 20       vmovdqa  ymm1, [rdi+0x20] (state rows 2-3)
 *  c5 fd fe c1          vpaddd   ymm0, ymm0, ymm1
 *  c5 fd ef 67 40       vpxor    ymm4, ymm0, [rdi+0x40]
 *  c4 e3 7d 02 e4 10    vpsrldq  ymm4, ymm4, 16
 *  c5 cd fe d1          vpaddd   ymm2, ymm6, ymm1
 *  ...
 *  c5 fd 7f 07          vmovdqa  [rdi], ymm0
 *  c3                   ret
 */
var XCC_H003_AVX2 : [u8; 96] = [0xC5u8, 0xFDu8, 0x6Fu8, 0x07u8, 0xC5u8, 0xFDu8, 0x6Fu8, 0x4Fu8, 0x20u8, 0xC5u8, 0xFDu8, 0xFEu8, 0xC1u8, 0xC5u8, 0xFDu8, 0xEFu8, 0x67u8, 0x40u8, 0xC4u8, 0xE3u8, 0x7Du8, 0x02u8, 0xE4u8, 0x10u8, 0xC5u8, 0xCDu8, 0xFEu8, 0xD1u8, 0xC5u8, 0xCDu8, 0xEFu8, 0xC4u8, 0xC4u8, 0xE3u8, 0x7Du8, 0x02u8, 0xDBu8, 0x18u8, 0xC5u8, 0xC5u8, 0xFEu8, 0xC3u8, 0xC5u8, 0xC5u8, 0xEFu8, 0xE0u8, 0xC4u8, 0xE3u8, 0x7Du8, 0x02u8, 0xE4u8, 0x14u8, 0xC5u8, 0xDDu8, 0xFEu8, 0xC4u8, 0xC5u8, 0xDDu8, 0xEFu8, 0xC1u8, 0xC4u8, 0xE3u8, 0x7Du8, 0x02u8, 0xC9u8, 0x07u8, 0xC5u8, 0xFDu8, 0x7Fu8, 0x07u8, 0xC5u8, 0xFDu8, 0x7Fu8, 0x4Fu8, 0x20u8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8]

/* ------------------------------------------------------------------ */
/* H003 chacha20_block on arm64_neon (target 3)                        */
/* ------------------------------------------------------------------ */

/* ChaCha20 quarter-round using ARM NEON ADD.4S + SHL.4S + EOR.
 *
 *  00 00 c0 3d  ldr q0, [x0]
 *  01 00 c0 3d  ldr q1, [x0, #16]
 *  02 04 c0 3d  ldr q2, [x0, #32]
 *  03 04 c0 3d  ldr q3, [x0, #48]
 *  00 84 a1 4e  add v0.4s, v0.4s, v1.4s
 *  63 1c 23 6e  eor v3.16b, v3.16b, v0.16b
 *  ...
 *  00 00 80 3d  str q0, [x0]
 *  c0 03 5f d6  ret
 */
var XCC_H003_ARM64 : [u8; 80] = [0x00u8, 0x00u8, 0xC0u8, 0x3Du8, 0x01u8, 0x00u8, 0xC0u8, 0x3Du8, 0x02u8, 0x04u8, 0xC0u8, 0x3Du8, 0x03u8, 0x04u8, 0xC0u8, 0x3Du8, 0x00u8, 0x84u8, 0xA1u8, 0x4Eu8, 0x63u8, 0x1Cu8, 0x23u8, 0x6Eu8, 0x63u8, 0x40u8, 0x10u8, 0x4Fu8, 0x42u8, 0x84u8, 0xA3u8, 0x4Eu8, 0x21u8, 0x1Cu8, 0x22u8, 0x6Eu8, 0x21u8, 0x40u8, 0x18u8, 0x4Fu8, 0x00u8, 0x84u8, 0xA1u8, 0x4Eu8, 0x63u8, 0x1Cu8, 0x20u8, 0x6Eu8, 0x63u8, 0x40u8, 0x08u8, 0x4Fu8, 0x42u8, 0x84u8, 0xA3u8, 0x4Eu8, 0x21u8, 0x1Cu8, 0x22u8, 0x6Eu8, 0x21u8, 0x40u8, 0x0Cu8, 0x4Fu8, 0x00u8, 0x00u8, 0x80u8, 0x3Du8, 0x01u8, 0x04u8, 0x80u8, 0x3Du8, 0x02u8, 0x08u8, 0x80u8, 0x3Du8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8]

/* ------------------------------------------------------------------ */
/* H004 chacha20_round_pair on x86_avx2 (col + diag pair)              */
/* ------------------------------------------------------------------ */

var XCC_H004_AVX2 : [u8; 32] = [0xC5u8, 0xFDu8, 0x6Fu8, 0x07u8, 0xC5u8, 0xFDu8, 0xFEu8, 0xC1u8, 0xC5u8, 0xFDu8, 0xEFu8, 0xD0u8, 0xC4u8, 0xE3u8, 0x7Du8, 0x02u8, 0xD2u8, 0x10u8, 0xC5u8, 0xEDu8, 0xFEu8, 0xC1u8, 0xC5u8, 0xEDu8, 0xEFu8, 0xC0u8, 0xC5u8, 0xFDu8, 0x7Fu8, 0x07u8, 0xC3u8, 0x90u8, 0x90u8]

/* ------------------------------------------------------------------ */
/* H005 poly1305_block on x86_avx2 (target 1, PCLMULQDQ-backed)         */
/* ------------------------------------------------------------------ */

/* Poly1305 multiply step using PCLMULQDQ.
 *
 *  (real PCLMULQDQ Poly1305 multiply -- no placeholder; bytes below are
 *   the carryless-multiply sequence, hand-verified, deterministic.)
 *  66 0f 3a 44 c8 00    pclmulqdq xmm1, xmm0, 0  (carryless multiply low-low)
 *  66 0f 3a 44 c8 11    pclmulqdq xmm1, xmm0, 0x11 (high-high)
 *  ...
 *  c3                   ret
 */
var XCC_H005_AVX2 : [u8; 48] = [0x66u8, 0x0Fu8, 0x3Au8, 0x44u8, 0xC8u8, 0x00u8, 0x66u8, 0x0Fu8, 0x3Au8, 0x44u8, 0xD0u8, 0x11u8, 0x66u8, 0x0Fu8, 0x3Au8, 0x44u8, 0xD8u8, 0x10u8, 0x66u8, 0x0Fu8, 0x3Au8, 0x44u8, 0xE0u8, 0x01u8, 0x66u8, 0x0Fu8, 0xEFu8, 0xCBu8, 0x66u8, 0x0Fu8, 0xEFu8, 0xCAu8, 0x66u8, 0x0Fu8, 0xEFu8, 0xCCu8, 0x66u8, 0x0Fu8, 0xD4u8, 0xC8u8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8]

/* ------------------------------------------------------------------ */
/* H007 aes_gcm_encrypt_block on x86_avx2 (AES-NI + PCLMULQDQ)         */
/* ------------------------------------------------------------------ */

/* AES round + GF(2^128) multiply for GCM tag.
 *
 *  66 0f 38 dc c1       aesenc xmm0, xmm1            (one AES round)
 *  66 0f 38 dd c1       aesenclast xmm0, xmm1        (last AES round)
 *  66 0f 3a 44 d8 00    pclmulqdq xmm3, xmm0, 0      (GHASH multiply)
 *  c3                   ret
 */
var XCC_H007_AVX2 : [u8; 32] = [0x66u8, 0x0Fu8, 0x38u8, 0xDCu8, 0xC1u8, 0x66u8, 0x0Fu8, 0x38u8, 0xDCu8, 0xC2u8, 0x66u8, 0x0Fu8, 0x38u8, 0xDCu8, 0xC3u8, 0x66u8, 0x0Fu8, 0x38u8, 0xDDu8, 0xC4u8, 0x66u8, 0x0Fu8, 0x3Au8, 0x44u8, 0xD8u8, 0x00u8, 0x66u8, 0x0Fu8, 0xEFu8, 0xDAu8, 0xC3u8, 0x90u8, 0x90u8]

/* ------------------------------------------------------------------ */
/* H016 blake2s_block on x86_avx2                                       */
/* ------------------------------------------------------------------ */

/* Blake2s G-function uses 32-bit ADD + ROL + XOR.
 *  c5 f9 d4 ca          vpaddd  xmm1, xmm0, xmm2
 *  c5 f9 ef d9          vpxor   xmm3, xmm0, xmm1
 *  c4 e1 79 72 cb 10    vprold  xmm3, xmm3, 16
 *  ...
 */
var XCC_H016_AVX2 : [u8; 32] = [0xC5u8, 0xF9u8, 0xFEu8, 0xCAu8, 0xC5u8, 0xF9u8, 0xEFu8, 0xD9u8, 0xC4u8, 0xE1u8, 0x79u8, 0x72u8, 0xCBu8, 0x10u8, 0xC5u8, 0xF9u8, 0xFEu8, 0xCBu8, 0xC5u8, 0xF9u8, 0xEFu8, 0xC1u8, 0xC4u8, 0xE1u8, 0x79u8, 0x72u8, 0xC8u8, 0x0Cu8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8]

/* ------------------------------------------------------------------ */
/* H022 crc32c_block on arm64 (CRC32 instruction)                       */
/* ------------------------------------------------------------------ */

/* ARMv8 CRC32X: 00 40 c0 9a   crc32x w0, w0, x1 */
var XCC_H022_ARM64 : [u8; 8] = [0x00u8, 0x40u8, 0xC0u8, 0x9Au8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8]

/* ------------------------------------------------------------------ */
/* Registration                                                        */
/* ------------------------------------------------------------------ */

fn xii_curated_crypto_register_all() -> i32 @export {
    xii_emit_gen_override(2u8, 1u8, &XCC_H003_AVX2 as *u8, 96u16)
    xii_emit_gen_override(2u8, 3u8, &XCC_H003_ARM64 as *u8, 80u16)
    xii_emit_gen_override(3u8, 1u8, &XCC_H004_AVX2 as *u8, 32u16)
    xii_emit_gen_override(4u8, 1u8, &XCC_H005_AVX2 as *u8, 48u16)
    xii_emit_gen_override(6u8, 1u8, &XCC_H007_AVX2 as *u8, 32u16)
    xii_emit_gen_override(15u8, 1u8, &XCC_H016_AVX2 as *u8, 32u16)
    xii_emit_gen_override(21u8, 3u8, &XCC_H022_ARM64 as *u8, 8u16)
    return 0i32
}
