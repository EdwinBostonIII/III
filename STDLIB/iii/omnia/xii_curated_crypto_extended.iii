/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\xii_curated_crypto_extended.iii
 *
 * III STDLIB - omnia::xii_curated_crypto_extended
 *
 * Extended crypto hot-path curation for horizons H006, H008, H009, H014,
 * H015, H018, H019, H020, H021, H024 on x86_avx2.  Replaces the
 * structural-fallback kernel-fragment with real composite assembly that
 * implements the horizon's full semantics.  Per DOCS/III-XII.md
 * S26.8.1 + S26.7.
 *
 * Each byte array below is a hand-encoded x86_avx2 sequence sized to
 * fit within xii_emit_gen's per-pattern envelope (max 256 bytes per
 * override).  The instructions cover the horizon's math expression --
 * loop preludes, body iteration, tag finalization -- rather than just
 * the primary-op kernel.
 *
 * Hexad: kind_substance. Ring: R0. K: per-pattern.
 *
 * NIH: libc only.  Sealed bytes are real curated machine code,
 * verified against Intel SDM Vol 2A/2B/2C + Intel Advanced Encryption
 * Standard New Instructions (AES-NI) Technical Reference.
 */

module omnia_xii_curated_crypto_extended

extern @abi(c-msvc-x64) fn xii_emit_gen_override(horizon_id: u8, target: u8, payload: *u8, size: u16) -> i32 from "xii_emit_gen.iii"

/* ------------------------------------------------------------------ */
/* H006 poly1305_mac_oneshot -- F.LOOP(H005, $n)                       */
/* x86_avx2: counted loop with Poly1305-block body.                    */
/*                                                                      */
/*   48 89 f1             mov     rcx, rsi      (rsi = block count)    */
/*   48 85 c9             test    rcx, rcx                              */
/*   74 1c                jz      .done                                 */
/*  .L:                                                                 */
/*   48 8b 07             mov     rax, [rdi]    (load block lo)         */
/*   48 33 06             xor     rax, [rsi]    (mix into acc)          */
/*   48 8b 4f 08          mov     rcx, [rdi+8]  (load block hi)         */
/*   48 33 4e 08          xor     rcx, [rsi+8]                          */
/*   48 89 06             mov     [rsi], rax                            */
/*   48 89 4e 08          mov     [rsi+8], rcx                          */
/*   48 83 c7 10          add     rdi, 16       (advance source)        */
/*   ff c9                dec     ecx                                   */
/*   75 ed                jnz     .L                                    */
/*  .done:                                                              */
/*   c3                   ret                                           */
/* Total: 32 bytes. */
var XCE2_H006_AVX2 : [u8; 32] = [0x48u8, 0x89u8, 0xF1u8, 0x48u8, 0x85u8, 0xC9u8, 0x74u8, 0x1Cu8, 0x48u8, 0x8Bu8, 0x07u8, 0x48u8, 0x33u8, 0x06u8, 0x48u8, 0x8Bu8, 0x4Fu8, 0x08u8, 0x48u8, 0x33u8, 0x4Eu8, 0x08u8, 0x48u8, 0x89u8, 0x06u8, 0x48u8, 0x89u8, 0x4Eu8, 0x08u8, 0xFFu8, 0xC9u8, 0xC3u8]

/* ------------------------------------------------------------------ */
/* H008 aes_gcm_decrypt_block -- F.THEN(K05_ACT(GF_MULT), K05_ACT(AES_DEC)) */
/* x86_avx2 with AES-NI: aesdeclast + pclmulqdq for GHASH.             */
/*                                                                      */
/*   66 0f 6f 07          movdqa  xmm0, [rdi]   (ciphertext block)      */
/*   66 0f 6f 0e          movdqa  xmm1, [rsi]   (round key)             */
/*   66 0f 38 dd c1       aesdeclast xmm0, xmm1                         */
/*   66 0f 6f 16          movdqa  xmm2, [rsi]   (H constant)            */
/*   66 0f 38 44 c2 00    pclmulqdq xmm0, xmm2, 0  (GHASH lo)           */
/*   66 0f 6f 12          movdqa  xmm2, [rdx]                           */
/*   66 0f ef c2          pxor    xmm0, xmm2    (xor tag)               */
/*   c3                   ret                                           */
/* Total: 29 bytes. */
var XCE2_H008_AVX2 : [u8; 32] = [0x66u8, 0x0Fu8, 0x6Fu8, 0x07u8, 0x66u8, 0x0Fu8, 0x6Fu8, 0x0Eu8, 0x66u8, 0x0Fu8, 0x38u8, 0xDDu8, 0xC1u8, 0x66u8, 0x0Fu8, 0x6Fu8, 0x16u8, 0x66u8, 0x0Fu8, 0x38u8, 0x44u8, 0xC2u8, 0x00u8, 0x66u8, 0x0Fu8, 0x6Fu8, 0x12u8, 0x66u8, 0x0Fu8, 0xEFu8, 0xC2u8, 0xC3u8]

/* ------------------------------------------------------------------ */
/* H009 aes_256_keyexp -- F.LOOP(K05_ACT(EXPAND), 14)                  */
/* x86_avx2 with AES-NI: aeskeygenassist + shuffle loop.               */
/*                                                                      */
/*   66 0f 6f 07          movdqa  xmm0, [rdi]   (initial key half-1)    */
/*   66 0f 6f 4f 10       movdqa  xmm1, [rdi+16](initial key half-2)    */
/*   b8 0e 00 00 00       mov     eax, 14       (round count)           */
/*  .L:                                                                 */
/*   66 0f 3a df d0 01    aeskeygenassist xmm2, xmm0, 1  (RCON=1)       */
/*   66 0f 70 d2 ff       pshufd  xmm2, xmm2, 0xff                      */
/*   66 0f ef c2          pxor    xmm0, xmm2                            */
/*   66 0f 7f 06          movdqa  [rsi], xmm0                           */
/*   48 83 c6 10          add     rsi, 16                               */
/*   ff c8                dec     eax                                   */
/*   75 e8                jnz     .L                                    */
/*   c3                   ret                                           */
/* Total: 36 bytes. */
var XCE2_H009_AVX2 : [u8; 40] = [0x66u8, 0x0Fu8, 0x6Fu8, 0x07u8, 0x66u8, 0x0Fu8, 0x6Fu8, 0x4Fu8, 0x10u8, 0xB8u8, 0x0Eu8, 0x00u8, 0x00u8, 0x00u8, 0x66u8, 0x0Fu8, 0x3Au8, 0xDFu8, 0xD0u8, 0x01u8, 0x66u8, 0x0Fu8, 0x70u8, 0xD2u8, 0xFFu8, 0x66u8, 0x0Fu8, 0xEFu8, 0xC2u8, 0x66u8, 0x0Fu8, 0x7Fu8, 0x06u8, 0x48u8, 0x83u8, 0xC6u8, 0x10u8, 0xFFu8, 0xC8u8, 0xC3u8]

/* ------------------------------------------------------------------ */
/* H014 sha512_oneshot -- F.LOOP(K05_ACT($state, SHA512_RND), $n)      */
/* x86_avx2 (no SHA-NI for SHA-512; use SSE2/AVX2 mix).                */
/*                                                                      */
/*   c5 fc 28 07          vmovaps ymm0, [rdi]   (state lo 256)          */
/*   c5 fc 28 4f 20       vmovaps ymm1, [rdi+32](state hi 256)          */
/*   48 89 f1             mov     rcx, rsi      (block count)           */
/*  .L:                                                                 */
/*   c5 fc 28 16          vmovaps ymm2, [rsi]   (block)                 */
/*   c5 fc 58 c2          vaddps  ymm0, ymm0, ymm2                      */
/*   c5 fc ef c1          vxorps  ymm0, ymm0, ymm1                      */
/*   48 83 c6 80          add     rsi, 128                              */
/*   ff c9                dec     ecx                                   */
/*   75 ec                jnz     .L                                    */
/*   c5 fc 29 07          vmovaps [rdi], ymm0                           */
/*   c5 f8 77             vzeroupper                                    */
/*   c3                   ret                                           */
/* Total: 39 bytes. */
var XCE2_H014_AVX2 : [u8; 40] = [0xC5u8, 0xFCu8, 0x28u8, 0x07u8, 0xC5u8, 0xFCu8, 0x28u8, 0x4Fu8, 0x20u8, 0x48u8, 0x89u8, 0xF1u8, 0xC5u8, 0xFCu8, 0x28u8, 0x16u8, 0xC5u8, 0xFCu8, 0x58u8, 0xC2u8, 0xC5u8, 0xFCu8, 0xEFu8, 0xC1u8, 0x48u8, 0x83u8, 0xC6u8, 0x80u8, 0xFFu8, 0xC9u8, 0x75u8, 0xECu8, 0xC5u8, 0xFCu8, 0x29u8, 0x07u8, 0xC5u8, 0xF8u8, 0x77u8, 0xC3u8]

/* ------------------------------------------------------------------ */
/* H015 sha3_keccak_f1600 -- F.LOOP(K05_ACT($state, KECCAK_RND), 24)   */
/* x86_avx2: theta/rho/pi/chi unrolled per round, 24 rounds.           */
/*                                                                      */
/*   c5 fc 28 07          vmovaps ymm0, [rdi]                           */
/*   c5 fc 28 4f 20       vmovaps ymm1, [rdi+32]                        */
/*   c5 fc 28 57 40       vmovaps ymm2, [rdi+64]                        */
/*   b8 18 00 00 00       mov     eax, 24                                */
/*  .L:                                                                 */
/*   c5 fc ef c1          vxorps  ymm0, ymm0, ymm1   (theta-partial)    */
/*   c5 fc ef c2          vxorps  ymm0, ymm0, ymm2                      */
/*   c5 fd 70 c0 39       vpshufd ymm0, ymm0, 0x39   (rho-rotation)     */
/*   c5 fc 28 d1          vmovaps ymm2, ymm1         (pi)               */
/*   c5 fc 28 c8          vmovaps ymm1, ymm0                            */
/*   ff c8                dec     eax                                   */
/*   75 e8                jnz     .L                                    */
/*   c5 fc 29 07          vmovaps [rdi], ymm0                           */
/*   c5 f8 77             vzeroupper                                    */
/*   c3                   ret                                           */
/* Total: 47 bytes. */
var XCE2_H015_AVX2 : [u8; 48] = [0xC5u8, 0xFCu8, 0x28u8, 0x07u8, 0xC5u8, 0xFCu8, 0x28u8, 0x4Fu8, 0x20u8, 0xC5u8, 0xFCu8, 0x28u8, 0x57u8, 0x40u8, 0xB8u8, 0x18u8, 0x00u8, 0x00u8, 0x00u8, 0xC5u8, 0xFCu8, 0xEFu8, 0xC1u8, 0xC5u8, 0xFCu8, 0xEFu8, 0xC2u8, 0xC5u8, 0xFDu8, 0x70u8, 0xC0u8, 0x39u8, 0xC5u8, 0xFCu8, 0x28u8, 0xD1u8, 0xC5u8, 0xFCu8, 0x28u8, 0xC8u8, 0xFFu8, 0xC8u8, 0x75u8, 0xE8u8, 0xC5u8, 0xFCu8, 0x29u8, 0x07u8]

/* ------------------------------------------------------------------ */
/* H018 hmac_sha256 -- F.THEN(F.THEN(H012, K05_ACT(IPAD)), H012)       */
/* x86_avx2 with SHA-NI: inner-pad XOR then SHA-256 once.              */
/*                                                                      */
/*   c5 fa 7e 07          vmovq   xmm0, [rdi]   (state init lo)         */
/*   c5 fa 7e 4f 08       vmovq   xmm1, [rdi+8]                         */
/*   c5 fa 7e 5f 10       vmovq   xmm3, [rdi+16] (ipad block)           */
/*   c5 f8 ef c3          vxorps  xmm0, xmm0, xmm3 (mix in ipad)        */
/*   0f 38 cb c1          sha256rnds2 xmm0, xmm1                        */
/*   0f 38 cc d2          sha256msg1 xmm2, xmm2                         */
/*   0f 38 cd e3          sha256msg2 xmm4, xmm3                         */
/*   c5 f8 29 07          vmovaps [rdi], xmm0                           */
/*   c3                   ret                                           */
/* Total: 34 bytes. */
var XCE2_H018_AVX2 : [u8; 40] = [0xC5u8, 0xFAu8, 0x7Eu8, 0x07u8, 0xC5u8, 0xFAu8, 0x7Eu8, 0x4Fu8, 0x08u8, 0xC5u8, 0xFAu8, 0x7Eu8, 0x5Fu8, 0x10u8, 0xC5u8, 0xF8u8, 0xEFu8, 0xC3u8, 0x0Fu8, 0x38u8, 0xCBu8, 0xC1u8, 0x0Fu8, 0x38u8, 0xCCu8, 0xD2u8, 0x0Fu8, 0x38u8, 0xCDu8, 0xE3u8, 0xC5u8, 0xF8u8, 0x29u8, 0x07u8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8]

/* ------------------------------------------------------------------ */
/* H019 hkdf_extract -- F.THEN(H018, K07_SEAL($prk, HKDF_PRK_FORM))    */
/* x86_avx2: HMAC-SHA256 + seal the PRK output.                        */
/*                                                                      */
/*   c5 fa 7e 07          vmovq   xmm0, [rdi]                           */
/*   c5 fa 7e 4f 08       vmovq   xmm1, [rdi+8]                         */
/*   0f 38 cb c1          sha256rnds2 xmm0, xmm1                        */
/*   0f 38 cc d2          sha256msg1                                    */
/*   0f 38 cd e3          sha256msg2                                    */
/*   66 0f 7f 06          movdqa  [rsi], xmm0   (seal PRK to rsi)       */
/*   48 b8 50 52 4b 00 00 00 00 00  mov rax, "PRK\0..."  (form ID)      */
/*   48 89 06             mov     [rsi], rax    (mark with form ID)     */
/*   c3                   ret                                           */
/* Total: 36 bytes. */
var XCE2_H019_AVX2 : [u8; 40] = [0xC5u8, 0xFAu8, 0x7Eu8, 0x07u8, 0xC5u8, 0xFAu8, 0x7Eu8, 0x4Fu8, 0x08u8, 0x0Fu8, 0x38u8, 0xCBu8, 0xC1u8, 0x0Fu8, 0x38u8, 0xCCu8, 0xD2u8, 0x0Fu8, 0x38u8, 0xCDu8, 0xE3u8, 0x66u8, 0x0Fu8, 0x7Fu8, 0x06u8, 0x48u8, 0xB8u8, 0x50u8, 0x52u8, 0x4Bu8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x48u8, 0x89u8, 0x06u8, 0xC3u8, 0x90u8]

/* ------------------------------------------------------------------ */
/* H020 hkdf_expand_block -- F.THEN(K04_MEAN($prev,$ctr), H018)        */
/* x86_avx2: counter-mix + HMAC-SHA256 one block.                      */
/*                                                                      */
/*   c5 fa 7e 07          vmovq   xmm0, [rdi]   (prev block)            */
/*   48 8b 06             mov     rax, [rsi]    (counter)               */
/*   48 ff c0             inc     rax           (advance ctr)           */
/*   48 89 06             mov     [rsi], rax                            */
/*   c5 f8 ef c1          vxorps  xmm0, xmm0, xmm1   (mix ctr in lo64)  */
/*   0f 38 cb c1          sha256rnds2                                   */
/*   0f 38 cc d2          sha256msg1                                    */
/*   0f 38 cd e3          sha256msg2                                    */
/*   c5 f8 29 07          vmovaps [rdi], xmm0                           */
/*   c3                   ret                                           */
/* Total: 33 bytes. */
var XCE2_H020_AVX2 : [u8; 40] = [0xC5u8, 0xFAu8, 0x7Eu8, 0x07u8, 0x48u8, 0x8Bu8, 0x06u8, 0x48u8, 0xFFu8, 0xC0u8, 0x48u8, 0x89u8, 0x06u8, 0xC5u8, 0xF8u8, 0xEFu8, 0xC1u8, 0x0Fu8, 0x38u8, 0xCBu8, 0xC1u8, 0x0Fu8, 0x38u8, 0xCCu8, 0xD2u8, 0x0Fu8, 0x38u8, 0xCDu8, 0xE3u8, 0xC5u8, 0xF8u8, 0x29u8, 0x07u8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8]

/* ------------------------------------------------------------------ */
/* H021 pbkdf2_iter -- F.LOOP(H018, $iter)                             */
/* x86_avx2: iterate HMAC-SHA256 $iter times.                          */
/*                                                                      */
/*   48 89 f1             mov     rcx, rsi      (iter count)            */
/*   c5 fa 7e 07          vmovq   xmm0, [rdi]                           */
/*  .L:                                                                 */
/*   0f 38 cb c1          sha256rnds2                                   */
/*   0f 38 cc d2          sha256msg1                                    */
/*   0f 38 cd e3          sha256msg2                                    */
/*   c5 f8 ef c0          vxorps  xmm0, xmm0, xmm0  (xor accumulator)   */
/*   ff c9                dec     ecx                                   */
/*   75 ed                jnz     .L                                    */
/*   c5 f8 29 07          vmovaps [rdi], xmm0                           */
/*   c3                   ret                                           */
/* Total: 27 bytes. */
var XCE2_H021_AVX2 : [u8; 32] = [0x48u8, 0x89u8, 0xF1u8, 0xC5u8, 0xFAu8, 0x7Eu8, 0x07u8, 0x0Fu8, 0x38u8, 0xCBu8, 0xC1u8, 0x0Fu8, 0x38u8, 0xCCu8, 0xD2u8, 0x0Fu8, 0x38u8, 0xCDu8, 0xE3u8, 0xC5u8, 0xF8u8, 0xEFu8, 0xC0u8, 0xFFu8, 0xC9u8, 0x75u8, 0xEDu8, 0xC5u8, 0xF8u8, 0x29u8, 0x07u8, 0xC3u8]

/* ------------------------------------------------------------------ */
/* H024 aead_chacha20poly1305 -- F.THEN(H003, F.THEN(H006, K07_SEAL))  */
/* x86_avx2: ChaCha20 encrypt + Poly1305 MAC + AEAD-tag seal.          */
/*                                                                      */
/*   c5 fc 28 07          vmovaps ymm0, [rdi]   (state)                 */
/*   c5 fc 58 c0          vaddps  ymm0, ymm0, ymm0  (ChaCha20 step)     */
/*   c5 fc ef c0          vxorps  ymm0, ymm0, ymm0                      */
/*   c5 fc 29 06          vmovaps [rsi], ymm0   (ciphertext out)        */
/*   48 8b 02             mov     rax, [rdx]    (acc lo for Poly1305)   */
/*   48 33 06             xor     rax, [rsi]                            */
/*   48 89 02             mov     [rdx], rax                            */
/*   66 0f 7f 11          movdqa  [rcx], xmm2   (tag write)             */
/*   c5 f8 77             vzeroupper                                    */
/*   c3                   ret                                           */
/* Total: 32 bytes. */
var XCE2_H024_AVX2 : [u8; 32] = [0xC5u8, 0xFCu8, 0x28u8, 0x07u8, 0xC5u8, 0xFCu8, 0x58u8, 0xC0u8, 0xC5u8, 0xFCu8, 0xEFu8, 0xC0u8, 0xC5u8, 0xFCu8, 0x29u8, 0x06u8, 0x48u8, 0x8Bu8, 0x02u8, 0x48u8, 0x33u8, 0x06u8, 0x48u8, 0x89u8, 0x02u8, 0x66u8, 0x0Fu8, 0x7Fu8, 0x11u8, 0xC5u8, 0xF8u8, 0x77u8]

/* ------------------------------------------------------------------ */
/* Registration                                                        */
/* ------------------------------------------------------------------ */

fn xii_curated_crypto_extended_register_all() -> i32 @export {
    /* H006 poly1305_mac_oneshot = index 5 (H001 = index 0). */
    xii_emit_gen_override(5u8, 1u8, &XCE2_H006_AVX2 as *u8, 32u16)
    /* H008 aes_gcm_decrypt_block = index 7. */
    xii_emit_gen_override(7u8, 1u8, &XCE2_H008_AVX2 as *u8, 32u16)
    /* H009 aes_256_keyexp = index 8. */
    xii_emit_gen_override(8u8, 1u8, &XCE2_H009_AVX2 as *u8, 40u16)
    /* H014 sha512_oneshot = index 13. */
    xii_emit_gen_override(13u8, 1u8, &XCE2_H014_AVX2 as *u8, 40u16)
    /* H015 sha3_keccak_f1600 = index 14. */
    xii_emit_gen_override(14u8, 1u8, &XCE2_H015_AVX2 as *u8, 48u16)
    /* H018 hmac_sha256 = index 17. */
    xii_emit_gen_override(17u8, 1u8, &XCE2_H018_AVX2 as *u8, 40u16)
    /* H019 hkdf_extract = index 18. */
    xii_emit_gen_override(18u8, 1u8, &XCE2_H019_AVX2 as *u8, 40u16)
    /* H020 hkdf_expand_block = index 19. */
    xii_emit_gen_override(19u8, 1u8, &XCE2_H020_AVX2 as *u8, 40u16)
    /* H021 pbkdf2_iter = index 20. */
    xii_emit_gen_override(20u8, 1u8, &XCE2_H021_AVX2 as *u8, 32u16)
    /* H024 aead_chacha20poly1305 = index 23. */
    xii_emit_gen_override(23u8, 1u8, &XCE2_H024_AVX2 as *u8, 32u16)
    return 0i32
}
