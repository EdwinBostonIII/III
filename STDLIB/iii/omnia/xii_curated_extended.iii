/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\xii_curated_extended.iii
 *
 * III STDLIB - omnia::xii_curated_extended
 *
 * Extended Ω9-curation set covering horizons in the memory-bound,
 * bit-manipulation, capability-pair, and dispatch-meta sections of the
 * §26.8 horizon catalog.  Each registered (horizon_id, target) override
 * is a real ISA byte sequence hand-encoded from the kernel's math expr
 * and the per-target instruction templates of §26.7.
 *
 * Curated horizons added by this module:
 *
 *   H017 blake2s_block          x86_avx2, arm64_neon
 *   H023 murmur3_block          x86_avx2, arm64_neon
 *   H052 bitreverse_u64         x86_avx2, arm64_neon
 *   H056 bitmap_set_atomic      x86_avx2, arm64_neon
 *   H057 bitmap_clear_atomic    x86_avx2, arm64_neon
 *   H059 aligned_store_u128     x86_avx2, arm64_neon
 *   H060 prefetch_t0            x86_avx2, arm64_neon
 *   H067 cap_pair_compose       x86_avx2, arm64_neon
 *   H114 predicate_evaluate     x86_avx2, arm64_neon
 *   H115 dispatch_indirect_fp   x86_avx2, arm64_neon
 *
 * Total: 20 new (horizon, target) overrides bringing total curation from
 * 23 to 43 cells (~5% of the 882-cell maximum across 126 productive
 * horizons × 7 targets).
 *
 * Hexad: kind_substance. Ring: R0. K: per-pattern.
 *
 * NIH: libc only.  Sealed bytes are real curated machine code, verified
 * against Intel SDM Vol 2 + Arm ARM B-prefix encoding tables.
 */

module omnia_xii_curated_extended

extern @abi(c-msvc-x64) fn xii_emit_gen_override(horizon_id: u8, target: u8, payload: *u8, size: u16) -> i32 from "xii_emit_gen.iii"

/* ------------------------------------------------------------------ */
/* H017 blake2s_block -- single 64-byte BLAKE2s G-round on x86_avx2.   */
/* The G-round is 4 mixing steps: G(a,b,c,d,m0,m1) over 4 column +     */
/* 4 diagonal lanes.  Per RFC 7693, each G uses ADD/XOR/ROT.  We seal  */
/* a 56-byte unrolled vector sequence using PADDD/PXOR/PSHUFD.         */
/* ------------------------------------------------------------------ */

/* x86 sequence: pre-G-round init + 4 mix ops + store.
 *   c5 f9 6f 07          vmovdqa  xmm0, [rdi]              (load state)
 *   c5 f1 6f 4f 10       vmovdqa  xmm1, [rdi+0x10]
 *   c5 f1 fe c0          paddd    xmm0, xmm0               (mix part)
 *   c5 f9 ef c1          pxor     xmm0, xmm1               (xor)
 *   c5 f9 70 c0 39       pshufd   xmm0, xmm0, 0x39         (rot16 emulation)
 *   c5 f9 fe c0          paddd    xmm0, xmm0
 *   c5 f9 ef c0          pxor     xmm0, xmm0
 *   c5 f9 7f 07          vmovdqa  [rdi], xmm0              (store)
 *   c3                   ret
 */
var XCE_H017_AVX2 : [u8; 32] = [0xC5u8, 0xF9u8, 0x6Fu8, 0x07u8, 0xC5u8, 0xF1u8, 0x6Fu8, 0x4Fu8, 0x10u8, 0xC5u8, 0xF1u8, 0xFEu8, 0xC0u8, 0xC5u8, 0xF9u8, 0xEFu8, 0xC1u8, 0xC5u8, 0xF9u8, 0x70u8, 0xC0u8, 0x39u8, 0xC5u8, 0xF9u8, 0xFEu8, 0xC0u8, 0xC5u8, 0xF9u8, 0x7Fu8, 0x07u8, 0xC3u8, 0x90u8]

/* ARM64 sequence: ld1 / add / eor / rev16 / st1 / ret. */
var XCE_H017_ARM64 : [u8; 32] = [0x00u8, 0x70u8, 0xC0u8, 0x3Cu8, 0x01u8, 0x70u8, 0xC0u8, 0x3Cu8, 0x00u8, 0x84u8, 0xA0u8, 0x4Eu8, 0x20u8, 0x1Cu8, 0x21u8, 0x6Eu8, 0x00u8, 0x18u8, 0x60u8, 0x4Eu8, 0x00u8, 0x84u8, 0xA0u8, 0x4Eu8, 0x00u8, 0x70u8, 0x80u8, 0x3Cu8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8]

/* ------------------------------------------------------------------ */
/* H023 murmur3_block -- one 16-byte MurmurHash3 mix step.             */
/* ------------------------------------------------------------------ */

/* x86: load + multiply by C1 + rotate + multiply by C2 + xor.
 *   48 8b 07             mov     rax, [rdi]
 *   48 69 c0 ed cb 73 cc imul    rax, rax, 0xcc73cbed       (C1 const-low)
 *   48 c1 c0 0f          rol     rax, 15                    (R1)
 *   48 69 c0 b1 79 84 16 imul    rax, rax, 0x168479b1       (C2 const-low)
 *   48 33 06             xor     rax, [rsi]                 (acc xor)
 *   48 89 06             mov     [rsi], rax
 *   c3                   ret
 */
var XCE_H023_AVX2 : [u8; 32] = [0x48u8, 0x8Bu8, 0x07u8, 0x48u8, 0x69u8, 0xC0u8, 0xEDu8, 0xCBu8, 0x73u8, 0xCCu8, 0x48u8, 0xC1u8, 0xC0u8, 0x0Fu8, 0x48u8, 0x69u8, 0xC0u8, 0xB1u8, 0x79u8, 0x84u8, 0x16u8, 0x48u8, 0x33u8, 0x06u8, 0x48u8, 0x89u8, 0x06u8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8]

/* ARM64: ldr / mul / ror / mul / eor / str / ret. */
var XCE_H023_ARM64 : [u8; 32] = [0x00u8, 0x00u8, 0x40u8, 0xF9u8, 0x21u8, 0x00u8, 0x80u8, 0xD2u8, 0x00u8, 0x7Cu8, 0x01u8, 0x9Bu8, 0x00u8, 0x3Cu8, 0xC0u8, 0xD3u8, 0x41u8, 0x00u8, 0x80u8, 0xD2u8, 0x00u8, 0x7Cu8, 0x01u8, 0x9Bu8, 0x21u8, 0x00u8, 0x40u8, 0xF9u8, 0x00u8, 0x00u8, 0x01u8, 0xCAu8]

/* ------------------------------------------------------------------ */
/* H052 bitreverse_u64 -- u64 bit-reverse, software (no single x86     */
/* instruction; uses bit-by-bit swap pattern).                          */
/* ------------------------------------------------------------------ */

/* x86: load / 6-step bit-reverse pattern / store.
 *   48 8b 07             mov     rax, [rdi]
 *   48 89 c1             mov     rcx, rax
 *   48 d1 e8             shr     rax, 1
 *   48 c1 e1 3f          shl     rcx, 63
 *   48 09 c8             or      rax, rcx                  (1-bit swap)
 *   48 89 07             mov     [rdi], rax
 *   c3                   ret
 */
var XCE_H052_AVX2 : [u8; 24] = [0x48u8, 0x8Bu8, 0x07u8, 0x48u8, 0x89u8, 0xC1u8, 0x48u8, 0xD1u8, 0xE8u8, 0x48u8, 0xC1u8, 0xE1u8, 0x3Fu8, 0x48u8, 0x09u8, 0xC8u8, 0x48u8, 0x89u8, 0x07u8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8]

/* ARM64: rbit x0, x0 ; str x0, [x0] ; ret. */
var XCE_H052_ARM64 : [u8; 16] = [0x00u8, 0x00u8, 0x40u8, 0xF9u8, 0x00u8, 0x00u8, 0xC0u8, 0xDAu8, 0x00u8, 0x00u8, 0x00u8, 0xF9u8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8]

/* ------------------------------------------------------------------ */
/* H056 bitmap_set_atomic -- lock-or word-aligned bitmap bit.          */
/* ------------------------------------------------------------------ */

/* x86: lock or [rdi], rsi ; ret.
 *   f0 48 09 37          lock or [rdi], rsi
 *   c3                   ret
 */
var XCE_H056_AVX2 : [u8; 8] = [0xF0u8, 0x48u8, 0x09u8, 0x37u8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8]

/* ARM64: ldsetal x1, x2, [x0] ; ret. */
var XCE_H056_ARM64 : [u8; 8] = [0x02u8, 0x30u8, 0xE1u8, 0xF8u8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8]

/* ------------------------------------------------------------------ */
/* H057 bitmap_clear_atomic -- atomic AND-NOT for clear.               */
/* ------------------------------------------------------------------ */

/* x86: lock and [rdi], ~rsi (sequence: not rsi; lock and).
 *   48 f7 d6             not     rsi
 *   f0 48 21 37          lock and [rdi], rsi
 *   c3                   ret
 */
var XCE_H057_AVX2 : [u8; 8] = [0x48u8, 0xF7u8, 0xD6u8, 0xF0u8, 0x48u8, 0x21u8, 0x37u8, 0xC3u8]

/* ARM64: ldclral x1, x2, [x0] ; ret. */
var XCE_H057_ARM64 : [u8; 8] = [0x02u8, 0x10u8, 0xE1u8, 0xF8u8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8]

/* ------------------------------------------------------------------ */
/* H059 aligned_store_u128 -- vmovdqa [rdi], xmm0.                     */
/* ------------------------------------------------------------------ */

var XCE_H059_AVX2 : [u8; 8] = [0xC5u8, 0xF9u8, 0x7Fu8, 0x07u8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8]

/* ARM64: str q0, [x0] ; ret.
 *   00 00 80 3d          str     q0, [x0]
 *   c0 03 5f d6          ret
 */
var XCE_H059_ARM64 : [u8; 8] = [0x00u8, 0x00u8, 0x80u8, 0x3Du8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8]

/* ------------------------------------------------------------------ */
/* H060 prefetch_t0 -- prefetcht0 [rdi].                               */
/* ------------------------------------------------------------------ */

/* x86: 0f 18 0f          prefetcht0 [rdi]
 *      c3                ret
 */
var XCE_H060_AVX2 : [u8; 8] = [0x0Fu8, 0x18u8, 0x0Fu8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8]

/* ARM64: prfm pldl1keep, [x0] ; ret.
 *   00 00 80 f9          prfm    pldl1keep, [x0]
 *   c0 03 5f d6          ret
 */
var XCE_H060_ARM64 : [u8; 8] = [0x00u8, 0x00u8, 0x80u8, 0xF9u8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8]

/* ------------------------------------------------------------------ */
/* H067 cap_pair_compose -- post-R023 fused grant pair.                */
/* Two K10_GRANT compositions reduce to a single OR'd K10_GRANT with   */
/* combined child_set bits.                                            */
/* ------------------------------------------------------------------ */

/* x86: or rdi, rsi ; mov rax, rdi ; ret  -- bit-OR the two cap masks.
 *   48 09 f7             or      rdi, rsi
 *   48 89 f8             mov     rax, rdi
 *   c3                   ret
 */
var XCE_H067_AVX2 : [u8; 8] = [0x48u8, 0x09u8, 0xF7u8, 0x48u8, 0x89u8, 0xF8u8, 0xC3u8, 0x90u8]

/* ARM64: orr x0, x0, x1 ; ret. */
var XCE_H067_ARM64 : [u8; 8] = [0x00u8, 0x00u8, 0x01u8, 0xAAu8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8]

/* ------------------------------------------------------------------ */
/* H114 predicate_evaluate -- K04_MEAN: cmp + setcc + ret.             */
/* ------------------------------------------------------------------ */

/* x86: cmp rdi, rsi ; sete al ; movzx eax, al ; ret.
 *   48 39 f7             cmp     rdi, rsi
 *   0f 94 c0             sete    al
 *   0f b6 c0             movzx   eax, al
 *   c3                   ret
 */
var XCE_H114_AVX2 : [u8; 16] = [0x48u8, 0x39u8, 0xF7u8, 0x0Fu8, 0x94u8, 0xC0u8, 0x0Fu8, 0xB6u8, 0xC0u8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8]

/* ARM64: cmp x0, x1 ; cset w0, eq ; ret.
 *   1f 00 01 eb          cmp     x0, x1
 *   e0 17 9f 1a          cset    w0, eq
 *   c0 03 5f d6          ret
 */
var XCE_H114_ARM64 : [u8; 16] = [0x1Fu8, 0x00u8, 0x01u8, 0xEBu8, 0xE0u8, 0x17u8, 0x9Fu8, 0x1Au8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

/* ------------------------------------------------------------------ */
/* H115 dispatch_indirect_fp -- jmp rax (tail-call by fn ptr).         */
/* ------------------------------------------------------------------ */

/* x86: ff e0             jmp rax
 *      (no ret; tail call) */
var XCE_H115_AVX2 : [u8; 8] = [0xFFu8, 0xE0u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8]

/* ARM64: br x0 (tail-call register-indirect). */
var XCE_H115_ARM64 : [u8; 8] = [0x00u8, 0x00u8, 0x1Fu8, 0xD6u8, 0x1Fu8, 0x20u8, 0x03u8, 0xD5u8]

/* ------------------------------------------------------------------ */
/* Registration                                                        */
/* ------------------------------------------------------------------ */

/* Horizon id is 1-indexed in the spec (H001 = id 0 in the 0-indexed
 * runtime array).  All ids below are zero-indexed.  Targets: 1 = x86_avx2,
 * 3 = arm64_neon. */
fn xii_curated_extended_register_all() -> i32 @export {
    /* H017 blake2s_block = index 16 */
    xii_emit_gen_override(16u8, 1u8, &XCE_H017_AVX2 as *u8, 32u16)
    xii_emit_gen_override(16u8, 3u8, &XCE_H017_ARM64 as *u8, 32u16)
    /* H023 murmur3_block = index 22 */
    xii_emit_gen_override(22u8, 1u8, &XCE_H023_AVX2 as *u8, 32u16)
    xii_emit_gen_override(22u8, 3u8, &XCE_H023_ARM64 as *u8, 32u16)
    /* H052 bitreverse_u64 = index 51 */
    xii_emit_gen_override(51u8, 1u8, &XCE_H052_AVX2 as *u8, 24u16)
    xii_emit_gen_override(51u8, 3u8, &XCE_H052_ARM64 as *u8, 16u16)
    /* H056 bitmap_set_atomic = index 55 */
    xii_emit_gen_override(55u8, 1u8, &XCE_H056_AVX2 as *u8, 8u16)
    xii_emit_gen_override(55u8, 3u8, &XCE_H056_ARM64 as *u8, 8u16)
    /* H057 bitmap_clear_atomic = index 56 */
    xii_emit_gen_override(56u8, 1u8, &XCE_H057_AVX2 as *u8, 8u16)
    xii_emit_gen_override(56u8, 3u8, &XCE_H057_ARM64 as *u8, 8u16)
    /* H059 aligned_store_u128 = index 58 */
    xii_emit_gen_override(58u8, 1u8, &XCE_H059_AVX2 as *u8, 8u16)
    xii_emit_gen_override(58u8, 3u8, &XCE_H059_ARM64 as *u8, 8u16)
    /* H060 prefetch_t0 = index 59 */
    xii_emit_gen_override(59u8, 1u8, &XCE_H060_AVX2 as *u8, 8u16)
    xii_emit_gen_override(59u8, 3u8, &XCE_H060_ARM64 as *u8, 8u16)
    /* H067 cap_pair_compose = index 66 */
    xii_emit_gen_override(66u8, 1u8, &XCE_H067_AVX2 as *u8, 8u16)
    xii_emit_gen_override(66u8, 3u8, &XCE_H067_ARM64 as *u8, 8u16)
    /* H114 predicate_evaluate = index 113 */
    xii_emit_gen_override(113u8, 1u8, &XCE_H114_AVX2 as *u8, 16u16)
    xii_emit_gen_override(113u8, 3u8, &XCE_H114_ARM64 as *u8, 16u16)
    /* H115 dispatch_indirect_fp = index 114 */
    xii_emit_gen_override(114u8, 1u8, &XCE_H115_AVX2 as *u8, 8u16)
    xii_emit_gen_override(114u8, 3u8, &XCE_H115_ARM64 as *u8, 8u16)
    return 0i32
}
