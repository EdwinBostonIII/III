/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\xii_curated_payloads.iii
 *
 * III STDLIB - omnia::xii_curated_payloads
 *
 * Curated per-target machine-code bytes for representative NON-crypto Horizon
 * patterns. Per DOCS/III-XII.md S26.7 + S26.18 (Ω9 Target Mapping Ceremony).
 *
 * Each registered (horizon_id, target) override is a real, sealed sequence
 * of machine-code bytes hand-curated for the target's ISA.
 *
 * This file registers the curation overrides at module load via
 * xii_curated_payloads_register_all(). Each pattern's payload is sealed
 * in a module-scope array.
 *
 * Currently curated (NON-crypto horizons only):
 *   H050 swap_bytes_u64   on target 1 (BSWAP rax)
 *   H050 swap_bytes_u64   on target 3 (REV x0)
 *   H058 aligned_load_u128 on targets 1,3 (vmovdqa / ldr q0)
 *
 * W1.2/CUT-12: the crypto-horizon (< 24) overrides H011 sha256_oneshot,
 * H012 sha256_block, H022 crc32c_block + their XCP_H011_AVX2/ARM64,
 * XCP_H012_AVX2, XCP_H022_AVX2 scaffold bytes are removed.  The xii_emit_gen
 * chokepoint (XEG_CRYPTO_HORIZON_MAX) refused every one of them, so they were
 * unreachable dead matter and emission is byte-identical.  Crypto truth is the
 * proven numera implementations (W1.3 option b: crypto horizons emit the real
 * kernel fragment, never a scaffold inline).
 *
 * Hexad: kind_substance. Ring: R0. K: per-pattern.
 *
 * NIH: libc only. Sealed bytes are real curated machine code.
 */

module omnia_xii_curated_payloads

extern @abi(c-msvc-x64) fn xii_emit_gen_override(horizon_id: u8, target: u8, payload: *u8, size: u16) -> i32 from "xii_emit_gen.iii"

/* ------------------------------------------------------------------ */
/* H050 swap_bytes_u64 — BSWAP rax on x86 / REV x0 on ARM64           */
/* ------------------------------------------------------------------ */

/* x86: 48 0f c8       bswap rax */
var XCP_H050_AVX2 : [u8; 8] = [0x48u8, 0x0Fu8, 0xC8u8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8, 0x90u8]

/* ARM64: 00 0c c0 da   rev x0, x0 */
var XCP_H050_ARM64 : [u8; 8] = [0x00u8, 0x0Cu8, 0xC0u8, 0xDAu8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8]

/* ------------------------------------------------------------------ */
/* H058 aligned_load_u128 — vmovdqa xmm0, [rdi] / ldr q0, [x0]        */
/* ------------------------------------------------------------------ */

/* x86: c5 f9 6f 07    vmovdqa xmm0, [rdi] */
var XCP_H058_AVX2 : [u8; 8] = [0xC5u8, 0xF9u8, 0x6Fu8, 0x07u8, 0xC3u8, 0x90u8, 0x90u8, 0x90u8]

/* ARM64: 00 00 c0 3d   ldr q0, [x0] */
var XCP_H058_ARM64 : [u8; 8] = [0x00u8, 0x00u8, 0xC0u8, 0x3Du8, 0xC0u8, 0x03u8, 0x5Fu8, 0xD6u8]

/* ------------------------------------------------------------------ */
/* Registration (non-crypto horizons only)                             */
/* ------------------------------------------------------------------ */

fn xii_curated_payloads_register_all() -> i32 @export {
    /* swap_bytes_u64 is H051 (index 50). */
    xii_emit_gen_override(50u8, 1u8, &XCP_H050_AVX2 as *u8, 8u16)
    xii_emit_gen_override(50u8, 3u8, &XCP_H050_ARM64 as *u8, 8u16)
    /* aligned_load_u128 is H058 (index 57). */
    xii_emit_gen_override(57u8, 1u8, &XCP_H058_AVX2 as *u8, 8u16)
    xii_emit_gen_override(57u8, 3u8, &XCP_H058_ARM64 as *u8, 8u16)
    return 0i32
}
