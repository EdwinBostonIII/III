fn _a_shift_sub() -> u32 { XHC_NM[0u32]=0x53u8 XHC_NM[1u32]=0x48u8 XHC_NM[2u32]=0x49u8 XHC_NM[3u32]=0x46u8 XHC_NM[4u32]=0x54u8 XHC_NM[5u32]=0x5Fu8 XHC_NM[6u32]=0x53u8 XHC_NM[7u32]=0x55u8 XHC_NM[8u32]=0x42u8 let v:u32=_xhc_r(XHP_ACT,9u32,XHW_ACT) return v }
