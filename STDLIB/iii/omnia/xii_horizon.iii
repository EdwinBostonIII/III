fn _s_m_audit() -> u32 { XHC_NM[0u32]=0x4Du8 XHC_NM[1u32]=0x5Fu8 XHC_NM[2u32]=0x41u8 XHC_NM[3u32]=0x55u8 XHC_NM[4u32]=0x44u8 XHC_NM[5u32]=0x49u8 XHC_NM[6u32]=0x54u8 XHC_NM[7u32]=0x5Fu8 XHC_NM[8u32]=0x46u8 XHC_NM[9u32]=0x4Fu8 XHC_NM[10u32]=0x52u8 XHC_NM[11u32]=0x4Du8 let v:u32=_xhc_r(XHP_SEAL,12u32,XHW_SEAL) return v }
