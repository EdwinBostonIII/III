}

/* Construct the canonical TEMPLATE algebra term for productive pattern
 * H(id+1) per S26.8, with S26.18 SHA-resolved named subforms and free
 * $variable operands. Guard/reserved cells return XHR_NULL_REF.
 * See DOCS/XII-HORIZON-CONSTRUCT.md. */
fn xii_horizon_construct(id: u32) -> u32 @export {
    if XII_HORIZON_INIT_DONE == 0u8 { xii_horizon_init() }
    if id >= XHR_TOTAL_PATTERNS { return XHR_NULL_REF }
    if xii_horizon_is_productive(id) != 1u8 { return XHR_NULL_REF }
    let t : u32 = _hc(id, 0u32)
    return t
}
