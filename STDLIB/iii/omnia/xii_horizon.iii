fn _f_not_all_ones() -> u32 { XHC_NM[0u32]=0x4Eu8 XHC_NM[1u32]=0x4Fu8 XHC_NM[2u32]=0x54u8 XHC_NM[3u32]=0x5Fu8 XHC_NM[4u32]=0x41u8 XHC_NM[5u32]=0x4Cu8 XHC_NM[6u32]=0x4Cu8 XHC_NM[7u32]=0x5Fu8 XHC_NM[8u32]=0x4Fu8 XHC_NM[9u32]=0x4Eu8 XHC_NM[10u32]=0x45u8 XHC_NM[11u32]=0x53u8 let v:u32=_xhc_r(XHP_FORM,12u32,XHW_FORM) return v }
fn _f_kdf() -> u32 { XHC_NM[0u32]=0x4Bu8 XHC_NM[1u32]=0x44u8 XHC_NM[2u32]=0x46u8 XHC_NM[3u32]=0x5Fu8 XHC_NM[4u32]=0x46u8 XHC_NM[5u32]=0x4Fu8 XHC_NM[6u32]=0x52u8 XHC_NM[7u32]=0x4Du8 let v:u32=_xhc_r(XHP_FORM,8u32,XHW_FORM) return v }
fn _f_anchor_inv() -> u32 { XHC_NM[0u32]=0x41u8 XHC_NM[1u32]=0x4Eu8 XHC_NM[2u32]=0x43u8 XHC_NM[3u32]=0x48u8 XHC_NM[4u32]=0x4Fu8 XHC_NM[5u32]=0x52u8 XHC_NM[6u32]=0x5Fu8 XHC_NM[7u32]=0x49u8 XHC_NM[8u32]=0x4Eu8 XHC_NM[9u32]=0x56u8 let v:u32=_xhc_r(XHP_FORM,10u32,XHW_FORM) return v }
fn _f_expected_cap() -> u32 { XHC_NM[0u32]=0x45u8 XHC_NM[1u32]=0x58u8 XHC_NM[2u32]=0x50u8 XHC_NM[3u32]=0x45u8 XHC_NM[4u32]=0x43u8 XHC_NM[5u32]=0x54u8 XHC_NM[6u32]=0x45u8 XHC_NM[7u32]=0x44u8 XHC_NM[8u32]=0x5Fu8 XHC_NM[9u32]=0x43u8 XHC_NM[10u32]=0x41u8 XHC_NM[11u32]=0x50u8 let v:u32=_xhc_r(XHP_FORM,12u32,XHW_FORM) return v }
fn _f_pat_pred() -> u32 { XHC_NM[0u32]=0x50u8 XHC_NM[1u32]=0x41u8 XHC_NM[2u32]=0x54u8 XHC_NM[3u32]=0x54u8 XHC_NM[4u32]=0x45u8 XHC_NM[5u32]=0x52u8 XHC_NM[6u32]=0x4Eu8 XHC_NM[7u32]=0x5Fu8 XHC_NM[8u32]=0x50u8 XHC_NM[9u32]=0x52u8 XHC_NM[10u32]=0x45u8 XHC_NM[11u32]=0x44u8 XHC_NM[12u32]=0x49u8 XHC_NM[13u32]=0x43u8 XHC_NM[14u32]=0x41u8 XHC_NM[15u32]=0x54u8 XHC_NM[16u32]=0x45u8 XHC_NM[17u32]=0x5Fu8 XHC_NM[18u32]=0x46u8 XHC_NM[19u32]=0x4Fu8 XHC_NM[20u32]=0x52u8 XHC_NM[21u32]=0x4Du8 let v:u32=_xhc_r(XHP_FORM,22u32,XHW_FORM) return v }
fn _f_resolver_ident() -> u32 { XHC_NM[0u32]=0x52u8 XHC_NM[1u32]=0x45u8 XHC_NM[2u32]=0x53u8 XHC_NM[3u32]=0x4Fu8 XHC_NM[4u32]=0x4Cu8 XHC_NM[5u32]=0x56u8 XHC_NM[6u32]=0x45u8 XHC_NM[7u32]=0x52u8 XHC_NM[8u32]=0x5Fu8 XHC_NM[9u32]=0x49u8 XHC_NM[10u32]=0x44u8 XHC_NM[11u32]=0x45u8 XHC_NM[12u32]=0x4Eu8 XHC_NM[13u32]=0x54u8 let v:u32=_xhc_r(XHP_FORM,14u32,XHW_FORM) return v }

/* ---- helpers: kinds, null, lift ---- */
fn _hb(k: u8, s: u32) -> u32 { let t:u32=xii_term_make_basis(k,s) return t }
fn _hf(k: u8, a: u32, b: u32) -> u32 { let t:u32=xii_term_make_fusion2(k,a,b) return t }
fn _hnull() -> u32 { let t:u32=xii_term_make_basis(XHK_K06,XHC_NULL_GROUND) return t }
fn _hlift(fr: u32, to: u32) -> u32 { let s:u32=fr|(to<<4u32) let t:u32=xii_term_make_basis(XHK_K17,s) return t }
fn _hfree(k: u8) -> u32 { let t:u32=xii_term_make_basis(k,0u32) return t }

/* Per-pattern builders. id is 0-based (id 0 == H001). Nested H-refs use
 * recursion via _hc(ref0) where ref0 is the 0-based id. depth guards
 * runaway (spec is a DAG; refs point to lower ids). */
fn _hc(id: u32, depth: u32) -> u32 {
    if depth > XHC_MAX_DEPTH { return XHR_NULL_REF }
    let d1 : u32 = depth + 1u32
    /* H001 ed25519_sign: THEN(K04_MEAN, COMPOSE(K07_SEAL, K08_PROVE)) */
    if id == 0u32 { let m:u32=_hfree(XHK_K04) let sl:u32=_hfree(XHK_K07) let pr:u32=_hfree(XHK_K08) let c:u32=_hf(XHK_FCOMPOSE,sl,pr) let r:u32=_hf(XHK_FTHEN,m,c) return r }
    if id == 1u32 { let m:u32=_hfree(XHK_K04) let pr:u32=_hfree(XHK_K08) let r:u32=_hf(XHK_FTHEN,m,pr) return r }
    if id == 2u32 { let cl:u32=_hb(XHK_K05,_a_col()) let dg:u32=_hb(XHK_K05,_a_diag()) let bd:u32=_hf(XHK_FCOMPOSE,cl,dg) let r:u32=xii_term_make_loop(bd,10u64) return r }
    if id == 3u32 { let cl:u32=_hb(XHK_K05,_a_col()) let dg:u32=_hb(XHK_K05,_a_diag()) let r:u32=_hf(XHK_FCOMPOSE,cl,dg) return r }
    if id == 4u32 { let m:u32=_hfree(XHK_K04) let ac:u32=_hb(XHK_K05,_a_poly_mult()) let r:u32=_hf(XHK_FTHEN,m,ac) return r }
    if id == 5u32 { let bd:u32=_hc(4u32,d1) let r:u32=xii_term_make_loop(bd,0u64) return r }
    if id == 6u32 { let en:u32=_hb(XHK_K05,_a_aes_enc()) let gf:u32=_hb(XHK_K05,_a_gf_mult()) let r:u32=_hf(XHK_FCOMPOSE,en,gf) return r }
    if id == 7u32 { let gf:u32=_hb(XHK_K05,_a_gf_mult()) let de:u32=_hb(XHK_K05,_a_aes_dec()) let r:u32=_hf(XHK_FTHEN,gf,de) return r }
    if id == 8u32 { let ex:u32=_hb(XHK_K05,_a_expand()) let r:u32=xii_term_make_loop(ex,14u64) return r }
    if id == 9u32 { let ld:u32=_hb(XHK_K05,_a_ladder()) let r:u32=xii_term_make_loop(ld,255u64) return r }
    if id == 10u32 { let h10:u32=_hc(9u32,d1) let m:u32=_hb(XHK_K04,_f_kdf()) let r:u32=_hf(XHK_FTHEN,h10,m) return r }
    if id == 11u32 { let rn:u32=_hb(XHK_K05,_a_sha256_rnd()) let r:u32=xii_term_make_loop(rn,0u64) return r }
    if id == 12u32 { let r:u32=_hb(XHK_K05,_a_sha256_64()) return r }
    if id == 13u32 { let rn:u32=_hb(XHK_K05,_a_sha512_rnd()) let r:u32=xii_term_make_loop(rn,0u64) return r }
    if id == 14u32 { let rn:u32=_hb(XHK_K05,_a_keccak_rnd()) let r:u32=xii_term_make_loop(rn,24u64) return r }
    if id == 15u32 { let h15:u32=_hc(14u32,d1) let r:u32=xii_term_make_loop(h15,0u64) return r }
    if id == 16u32 { let r:u32=_hb(XHK_K05,_a_blake2s()) return r }
    if id == 17u32 { let h12a:u32=_hc(11u32,d1) let ip:u32=_hb(XHK_K05,_a_ipad()) let inr:u32=_hf(XHK_FTHEN,h12a,ip) let h12b:u32=_hc(11u32,d1) let r:u32=_hf(XHK_FTHEN,inr,h12b) return r }
    if id == 18u32 { let h18:u32=_hc(17u32,d1) let sl:u32=_hb(XHK_K07,_s_hkdf_prk()) let r:u32=_hf(XHK_FTHEN,h18,sl) return r }
    if id == 19u32 { let m:u32=_hfree(XHK_K04) let h18:u32=_hc(17u32,d1) let r:u32=_hf(XHK_FTHEN,m,h18) return r }
    if id == 20u32 { let h18:u32=_hc(17u32,d1) let r:u32=xii_term_make_loop(h18,0u64) return r }
    if id == 21u32 { let r:u32=_hb(XHK_K05,_a_crc32c()) return r }
    if id == 22u32 { let r:u32=_hb(XHK_K05,_a_murmur3()) return r }
    if id == 23u32 { let h3:u32=_hc(2u32,d1) let h6:u32=_hc(5u32,d1) let sl:u32=_hb(XHK_K07,_s_aead()) let inr:u32=_hf(XHK_FTHEN,h6,sl) let r:u32=_hf(XHK_FTHEN,h3,inr) return r }
    /* H025..H029: LOOP(COMPOSE(K09_QUERY(READ_*), K05_ACT(op)), $n) */
    if id == 24u32 { let q:u32=_hb(XHK_K09,_q_read_u64()) let ac:u32=_hb(XHK_K05,_a_add()) let bd:u32=_hf(XHK_FCOMPOSE,q,ac) let r:u32=xii_term_make_loop(bd,0u64) return r }
    if id == 25u32 { let q:u32=_hb(XHK_K09,_q_read_u64()) let ac:u32=_hb(XHK_K05,_a_xor()) let bd:u32=_hf(XHK_FCOMPOSE,q,ac) let r:u32=xii_term_make_loop(bd,0u64) return r }
    if id == 26u32 { let q:u32=_hb(XHK_K09,_q_read_u32()) let ac:u32=_hb(XHK_K05,_a_max_ct()) let bd:u32=_hf(XHK_FCOMPOSE,q,ac) let r:u32=xii_term_make_loop(bd,0u64) return r }
    if id == 27u32 { let q:u32=_hb(XHK_K09,_q_read_u32()) let ac:u32=_hb(XHK_K05,_a_min_ct()) let bd:u32=_hf(XHK_FCOMPOSE,q,ac) let r:u32=xii_term_make_loop(bd,0u64) return r }
    if id == 28u32 { let q:u32=_hb(XHK_K09,_q_read_u64()) let ac:u32=_hb(XHK_K05,_a_popcnt()) let bd:u32=_hf(XHK_FCOMPOSE,q,ac) let r:u32=xii_term_make_loop(bd,0u64) return r }
    if id == 29u32 { let qa:u32=_hfree(XHK_K09) let qb:u32=_hfree(XHK_K09) let qc:u32=_hf(XHK_FCOMPOSE,qa,qb) let mu:u32=_hb(XHK_K05,_a_mul()) let ad:u32=_hb(XHK_K05,_a_add()) let mc:u32=_hf(XHK_FCOMPOSE,mu,ad) let bd:u32=_hf(XHK_FCOMPOSE,qc,mc) let r:u32=xii_term_make_loop(bd,0u64) return r }
    if id == 30u32 { let h30:u32=_hc(29u32,d1) let in1:u32=xii_term_make_loop(h30,0u64) let r:u32=xii_term_make_loop(in1,0u64) return r }
    if id == 31u32 { let h30:u32=_hc(29u32,d1) let r:u32=xii_term_make_loop(h30,0u64) return r }
    if id == 32u32 { let ap:u32=_hb(XHK_K05,_a_add_pair()) let tw:u32=_hb(XHK_K05,_a_mul_twiddle()) let r:u32=_hf(XHK_FCOMPOSE,ap,tw) return r }
    if id == 33u32 { let h33:u32=_hc(32u32,d1) let r:u32=xii_term_make_loop(h33,0u64) return r }
    if id == 34u32 { let mr:u32=_hb(XHK_K05,_a_mul_recip()) let sd:u32=_hb(XHK_K05,_a_shift_down()) let r:u32=_hf(XHK_FCOMPOSE,mr,sd) return r }
    if id == 35u32 { let ss:u32=_hb(XHK_K05,_a_shift_sub()) let r:u32=xii_term_make_loop(ss,64u64) return r }
    if id == 36u32 { let mm:u32=_hb(XHK_K05,_a_mul_mod_p()) let sq:u32=_hb(XHK_K05,_a_sq_mod_p()) let bd:u32=_hf(XHK_FCOMPOSE,mm,sq) let r:u32=xii_term_make_loop(bd,256u64) return r }
    if id == 37u32 { let mb:u32=_hb(XHK_K05,_a_mult_barrett()) let sm:u32=_hb(XHK_K05,_a_sub_mod()) let r:u32=_hf(XHK_FCOMPOSE,mb,sm) return r }
    if id == 38u32 { let mn:u32=_hb(XHK_K05,_a_mult_mont()) let sm:u32=_hb(XHK_K05,_a_sub_mod()) let r:u32=_hf(XHK_FCOMPOSE,mn,sm) return r }
    if id == 39u32 { let m:u32=_hb(XHK_K04,_f_le()) let nl:u32=_hnull() let er:u32=_hb(XHK_K05,_a_raise()) let r:u32=xii_term_make_if(m,nl,er) return r }
    if id == 40u32 { let m:u32=_hb(XHK_K04,_f_ge()) let bd:u32=_hfree(XHK_K02) let nl:u32=_hnull() let r:u32=xii_term_make_if(m,bd,nl) return r }
    if id == 41u32 { let ac:u32=_hb(XHK_K05,_a_add()) let mo:u32=_hb(XHK_K04,_f_overflow()) let bd:u32=_hfree(XHK_K02) let nl:u32=_hnull() let iff:u32=xii_term_make_if(mo,bd,nl) let r:u32=_hf(XHK_FTHEN,ac,iff) return r }
    /* H043..H060 memory-bound */
    if id == 42u32 { let q:u32=_hb(XHK_K09,_q_read()) let bn:u32=_hb(XHK_K02,_a_write()) let bd:u32=_hf(XHK_FCOMPOSE,q,bn) let r:u32=xii_term_make_loop(bd,0u64) return r }
    if id == 43u32 { let cv:u32=_hfree(XHK_K03) let nl:u32=_hnull() let r:u32=_hf(XHK_FTHEN,cv,nl) return r }
    if id == 44u32 { let qa:u32=_hb(XHK_K09,_q_read()) let qb:u32=_hb(XHK_K09,_q_read()) let xo:u32=_hb(XHK_K05,_a_xor_or()) let inr:u32=_hf(XHK_FCOMPOSE,qb,xo) let bd:u32=_hf(XHK_FCOMPOSE,qa,inr) let r:u32=xii_term_make_loop(bd,0u64) return r }
    if id == 45u32 { let bn:u32=_hb(XHK_K02,_a_zero_write()) let r:u32=xii_term_make_loop(bn,0u64) return r }
    if id == 46u32 { let bn:u32=_hb(XHK_K02,_a_value_write()) let r:u32=xii_term_make_loop(bn,0u64) return r }
    if id == 47u32 { let mn:u32=_hb(XHK_K04,_f_nonzero()) let ir:u32=_hb(XHK_K05,_a_return()) let nl:u32=_hnull() let iff:u32=xii_term_make_if(mn,ir,nl) let r:u32=xii_term_make_loop(iff,0u64) return r }
    if id == 48u32 { let q:u32=_hb(XHK_K09,_q_index()) let bn:u32=_hb(XHK_K02,_a_write()) let bd:u32=_hf(XHK_FCOMPOSE,q,bn) let r:u32=xii_term_make_loop(bd,0u64) return r }
    if id == 49u32 { let q:u32=_hfree(XHK_K09) let bn:u32=_hb(XHK_K02,_a_index_write()) let bd:u32=_hf(XHK_FCOMPOSE,q,bn) let r:u32=xii_term_make_loop(bd,0u64) return r }
    if id == 50u32 { let r:u32=_hb(XHK_K05,_a_bswap64()) return r }
    if id == 51u32 { let r:u32=_hb(XHK_K05,_a_brev64()) return r }
    if id == 52u32 { let h51:u32=_hc(50u32,d1) let r:u32=xii_term_make_loop(h51,0u64) return r }
    if id == 53u32 { let q:u32=_hb(XHK_K09,_q_read()) let pa:u32=_hb(XHK_K05,_a_popcnt_add()) let bd:u32=_hf(XHK_FCOMPOSE,q,pa) let r:u32=xii_term_make_loop(bd,0u64) return r }
