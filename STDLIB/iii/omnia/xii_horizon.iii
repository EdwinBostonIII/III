fn _a_keccak_rnd() -> u32 { XHC_NM[0u32]=0x4Bu8 XHC_NM[1u32]=0x45u8 XHC_NM[2u32]=0x43u8 XHC_NM[3u32]=0x43u8 XHC_NM[4u32]=0x41u8 XHC_NM[5u32]=0x4Bu8 XHC_NM[6u32]=0x5Fu8 XHC_NM[7u32]=0x52u8 XHC_NM[8u32]=0x4Eu8 XHC_NM[9u32]=0x44u8 let v:u32=_xhc_r(XHP_ACT,10u32,XHW_ACT) return v }
fn _a_blake2s() -> u32 { XHC_NM[0u32]=0x42u8 XHC_NM[1u32]=0x4Cu8 XHC_NM[2u32]=0x41u8 XHC_NM[3u32]=0x4Bu8 XHC_NM[4u32]=0x45u8 XHC_NM[5u32]=0x32u8 XHC_NM[6u32]=0x53u8 XHC_NM[7u32]=0x5Fu8 XHC_NM[8u32]=0x4Du8 XHC_NM[9u32]=0x49u8 XHC_NM[10u32]=0x58u8 let v:u32=_xhc_r(XHP_ACT,11u32,XHW_ACT) return v }
fn _a_ipad() -> u32 { XHC_NM[0u32]=0x49u8 XHC_NM[1u32]=0x50u8 XHC_NM[2u32]=0x41u8 XHC_NM[3u32]=0x44u8 let v:u32=_xhc_r(XHP_ACT,4u32,XHW_ACT) return v }
fn _a_crc32c() -> u32 { XHC_NM[0u32]=0x43u8 XHC_NM[1u32]=0x52u8 XHC_NM[2u32]=0x43u8 XHC_NM[3u32]=0x33u8 XHC_NM[4u32]=0x32u8 XHC_NM[5u32]=0x43u8 XHC_NM[6u32]=0x5Fu8 XHC_NM[7u32]=0x36u8 XHC_NM[8u32]=0x34u8 let v:u32=_xhc_r(XHP_ACT,9u32,XHW_ACT) return v }
fn _a_murmur3() -> u32 { XHC_NM[0u32]=0x4Du8 XHC_NM[1u32]=0x55u8 XHC_NM[2u32]=0x52u8 XHC_NM[3u32]=0x4Du8 XHC_NM[4u32]=0x55u8 XHC_NM[5u32]=0x52u8 XHC_NM[6u32]=0x33u8 XHC_NM[7u32]=0x5Fu8 XHC_NM[8u32]=0x4Du8 XHC_NM[9u32]=0x49u8 XHC_NM[10u32]=0x58u8 let v:u32=_xhc_r(XHP_ACT,11u32,XHW_ACT) return v }
fn _a_add() -> u32 { XHC_NM[0u32]=0x41u8 XHC_NM[1u32]=0x44u8 XHC_NM[2u32]=0x44u8 let v:u32=_xhc_r(XHP_ACT,3u32,XHW_ACT) return v }
fn _a_xor() -> u32 { XHC_NM[0u32]=0x58u8 XHC_NM[1u32]=0x4Fu8 XHC_NM[2u32]=0x52u8 let v:u32=_xhc_r(XHP_ACT,3u32,XHW_ACT) return v }
fn _a_max_ct() -> u32 { XHC_NM[0u32]=0x4Du8 XHC_NM[1u32]=0x41u8 XHC_NM[2u32]=0x58u8 XHC_NM[3u32]=0x5Fu8 XHC_NM[4u32]=0x43u8 XHC_NM[5u32]=0x54u8 let v:u32=_xhc_r(XHP_ACT,6u32,XHW_ACT) return v }
fn _a_min_ct() -> u32 { XHC_NM[0u32]=0x4Du8 XHC_NM[1u32]=0x49u8 XHC_NM[2u32]=0x4Eu8 XHC_NM[3u32]=0x5Fu8 XHC_NM[4u32]=0x43u8 XHC_NM[5u32]=0x54u8 let v:u32=_xhc_r(XHP_ACT,6u32,XHW_ACT) return v }
