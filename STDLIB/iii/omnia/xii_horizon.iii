fn _a_mul() -> u32 { XHC_NM[0u32]=0x4Du8 XHC_NM[1u32]=0x55u8 XHC_NM[2u32]=0x4Cu8 let v:u32=_xhc_r(XHP_ACT,3u32,XHW_ACT) return v }
