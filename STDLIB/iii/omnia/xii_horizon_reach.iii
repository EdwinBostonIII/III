/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\omnia\xii_horizon_reach.iii
 *
 * III STDLIB - omnia::xii_horizon_reach
 *
 * Sealed 18-byte (144-bit) productive-flag bitmap for the 144 Horizon
 * patterns. Per DOCS/III-XII.md S10.3 + S26.8.10.
 *
 * Bit i is set iff Horizon pattern (i+1) is productive:
 *   H001..H126 productive  -> bits 0..125 = 1
 *   H127..H144 guard/reserved -> bits 126..143 = 0
 *
 * Byte layout (LSB = lowest H-id in each byte):
 *   bytes  0..14 : 0xFF each (H001..H120 all productive)
 *   byte  15     : 0x3F (H121..H126 productive [bits 0..5]; H127..H128 guard [bits 6,7])
 *   bytes 16..17 : 0x00 each (H129..H144 guard/reserved)
 *
 * Sealed: xii_horizon_reach.mhash := SHA-256(18-byte sequence above).
 *
 * Hexad: kind_form. Ring: R0. K: 1.0.
 *
 * NIH: libc only.
 */

module omnia_xii_horizon_reach

const XHR_BITMAP_LEN : u32 = 18u32
const XHR_BIT_COUNT  : u32 = 144u32

/* iiis-1 parser: array initializers must be single-line. */
var XII_HORIZON_REACH_BITMAP : [u8; 18] = [0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0x3Fu8, 0x00u8, 0x00u8]

fn xii_horizon_reach_bit(id: u32) -> u8 @export {
    if id >= XHR_BIT_COUNT { return 0u8 }
    let byte_idx : u32 = id >> 3u32
    let bit_in_byte : u8 = ((id & 7u32) as u8)
    let b : u8 = XII_HORIZON_REACH_BITMAP[byte_idx]
    let mask : u8 = 1u8 << bit_in_byte
    let v : u8 = b & mask
    if v != 0u8 { return 1u8 }
    return 0u8
}

fn xii_horizon_reach_bitmap_ptr() -> u64 @export {
    return &XII_HORIZON_REACH_BITMAP as u64
}

fn xii_horizon_reach_bitmap_len() -> u32 @export {
    return XHR_BITMAP_LEN
}

/* Verify productive count matches expected 126. */
fn xii_horizon_reach_productive_count() -> u32 @export {
    let mut count : u32 = 0u32
    let mut i : u32 = 0u32
    while i < XHR_BIT_COUNT {
        if xii_horizon_reach_bit(i) == 1u8 { count = count + 1u32 }
        i = i + 1u32
    }
    return count
}
