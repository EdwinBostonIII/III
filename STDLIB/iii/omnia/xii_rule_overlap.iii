/* STDLIB/iii/omnia/xii_rule_overlap.iii -- mig4 Step 2: the LHS unifier + critical-overlap
 * predicates.  Consumes Step 1's structural descriptor table (omnia/xii_rule_patterns,
 * via the xrp_*_at accessors) and decides, for a pair of rules, whether they can fire on a
 * common redex -- a candidate critical pair that Step 3 enumerates and Step 4 checks for
 * joinability.  Per DOCS/III-MIG4-STEP1-SPEC.md sec 7.
 *
 * Two forms of overlap, at the depth-1 structural representation:
 *   ROOT overlap (position epsilon): rule i and rule j unify at the root -- same root kind
 *     AND each child-constraint pair unifies, where ANY is a free pattern variable (unifies
 *     with anything) and two DISTINCT concrete kinds do NOT unify.  A common redex then
 *     matches both LHSs -> both rules can rewrite it -> critical pair.  (This is exactly the
 *     shape of the documented cascade pre-emptions: R038/R037, R038/R017, R040/R030,
 *     R041/R013.)
 *   SUBTERM overlap (position = a child slot of rule j): rule i's root pattern unifies with
 *     a NON-variable child of rule j.  At depth-1 a child constraint "kind K" denotes a term
 *     of root kind K with free grandchildren, so rule i (root r_i, free children) unifies
 *     with it iff r_i == K.  A child constrained to ANY is a free variable -> no overlap
 *     there (overlap requires a non-variable subterm -- the standard KB side-condition).
 *
 * Soundness: because Step 1's structural pattern is a SUPERSET of the real matcher (guards
 * dropped), this overlap relation is itself an over-approximation -- it reports AT LEAST
 * every real critical pair, so Step 3 never misses one and Step 4 discharges the spurious
 * ones (a guard makes them non-unifiable on concrete instances, or they join trivially).
 *
 * Hexad: kind_sensitivity.  Ring: R0.  K: 1.00.  NIH: xii_rule_patterns accessors only.
 * Determinism: integer-only; ==/!= and UNSIGNED < compares; single-line fns; no recursion;
 * no u64 div/mod; no pointer math (pure accessor calls).
 */
module omnia_xii_rule_overlap

extern @abi(c-msvc-x64) fn xrp_rule_count() -> u32 from "xii_rule_patterns.iii"
extern @abi(c-msvc-x64) fn xrp_rid_at(slot: u32) -> u32 from "xii_rule_patterns.iii"
extern @abi(c-msvc-x64) fn xrp_root_at(slot: u32) -> u32 from "xii_rule_patterns.iii"
extern @abi(c-msvc-x64) fn xrp_ca_at(slot: u32) -> u32 from "xii_rule_patterns.iii"
extern @abi(c-msvc-x64) fn xrp_cb_at(slot: u32) -> u32 from "xii_rule_patterns.iii"
extern @abi(c-msvc-x64) fn xrp_cc_at(slot: u32) -> u32 from "xii_rule_patterns.iii"

const XRO_ANY  : u64 = 255u64            /* the free-variable / unconstrained child marker */
const XRO_SENT : u32 = 0xFFFFFFFFu32

/* Two child-kind constraints unify iff either is the free variable ANY, or they are equal. */
fn xro_kind_unify(a: u64, b: u64) -> u8 {
    if a == XRO_ANY { return 1u8 }
    if b == XRO_ANY { return 1u8 }
    if a == b { return 1u8 }
    return 0u8
}

/* The table slot holding rule_id, or XRO_SENT if none. */
fn xro_slot_of_rid(rid: u32) -> u32 @export {
    let n : u64 = xrp_rule_count() as u64
    let mut s : u64 = 0u64
    while s < n {
        if xrp_rid_at(s as u32) == rid { return s as u32 }
        s = s + 1u64
    }
    return XRO_SENT
}

/* child-kind constraint at position pos (0=ca, 1=cb, else cc) of the rule in slot. */
fn xro_child_at(slot: u32, pos: u32) -> u64 {
    if pos == 0u32 { return xrp_ca_at(slot) as u64 }
    if pos == 1u32 { return xrp_cb_at(slot) as u64 }
    return xrp_cc_at(slot) as u64
}

/* ROOT overlap: rule slot_i and rule slot_j unify at the root. */
fn xro_root_overlap(slot_i: u32, slot_j: u32) -> u8 @export {
    let ri : u64 = xrp_root_at(slot_i) as u64
    let rj : u64 = xrp_root_at(slot_j) as u64
    if ri != rj { return 0u8 }
    if xro_kind_unify(xrp_ca_at(slot_i) as u64, xrp_ca_at(slot_j) as u64) == 0u8 { return 0u8 }
    if xro_kind_unify(xrp_cb_at(slot_i) as u64, xrp_cb_at(slot_j) as u64) == 0u8 { return 0u8 }
    if xro_kind_unify(xrp_cc_at(slot_i) as u64, xrp_cc_at(slot_j) as u64) == 0u8 { return 0u8 }
    return 1u8
}

/* SUBTERM overlap: rule slot_i's root can rewrite rule slot_j's child at pos (pos's
 * constraint is a concrete kind == rule i's root kind; an ANY child is a variable -> no). */
fn xro_subterm_overlap(slot_i: u32, slot_j: u32, pos: u32) -> u8 @export {
    let cj : u64 = xro_child_at(slot_j, pos)
    if cj == XRO_ANY { return 0u8 }
    let ri : u64 = xrp_root_at(slot_i) as u64
    if ri == cj { return 1u8 }
    return 0u8
}

/* Total candidate critical overlaps over the whole table: unordered root pairs (i<j) that
 * overlap, plus ordered subterm triples (i,j,pos) -- i==j included (a rule can overlap its
 * own child, e.g. R014's FLOOP rewriting its FLOOP child_a).  Deterministic. */
fn xro_count_overlaps() -> u32 @export {
    let n : u64 = xrp_rule_count() as u64
    let mut cnt : u64 = 0u64
    let mut i : u64 = 0u64
    while i < n {
        let mut j : u64 = i + 1u64
        while j < n {
            if xro_root_overlap(i as u32, j as u32) == 1u8 { cnt = cnt + 1u64 }
            j = j + 1u64
        }
        i = i + 1u64
    }
    let mut a : u64 = 0u64
    while a < n {
        let mut b : u64 = 0u64
        while b < n {
            let mut p : u64 = 0u64
            while p < 3u64 {
                if xro_subterm_overlap(a as u32, b as u32, p as u32) == 1u8 { cnt = cnt + 1u64 }
                p = p + 1u64
            }
            b = b + 1u64
        }
        a = a + 1u64
    }
    return cnt as u32
}

fn xro_selftest() -> u64 @export {
    /* unification primitive */
    if xro_kind_unify(255u64, 5u64) != 1u8 { return 1u64 }
    if xro_kind_unify(5u64, 255u64) != 1u8 { return 2u64 }
    if xro_kind_unify(5u64, 5u64) != 1u8 { return 3u64 }
    if xro_kind_unify(5u64, 18u64) != 0u8 { return 4u64 }
    if xro_kind_unify(255u64, 255u64) != 1u8 { return 5u64 }

    let s13 : u32 = xro_slot_of_rid(13u32)   /* R013 FLOOP    all ANY             */
    let s14 : u32 = xro_slot_of_rid(14u32)   /* R014 FLOOP    ca=FLOOP            */
    let s30 : u32 = xro_slot_of_rid(30u32)   /* R030 FIF      all ANY             */
    let s32 : u32 = xro_slot_of_rid(32u32)   /* R032 FCOMPOSE ca=cb=K01           */
    let s33 : u32 = xro_slot_of_rid(33u32)   /* R033 FCOMPOSE ca=cb=K09           */
    let s37 : u32 = xro_slot_of_rid(37u32)   /* R037 FCOMPOSE ca=K06              */
    let s38 : u32 = xro_slot_of_rid(38u32)   /* R038 FCOMPOSE ca=cb=K06           */
    let s40 : u32 = xro_slot_of_rid(40u32)   /* R040 FIF      cb=cc=K06           */
    let s41 : u32 = xro_slot_of_rid(41u32)   /* R041 FLOOP    ca=K06              */
    /* route-S: R001-R004 (associativity) RETIRED. The live FLOOP family carries the identical
     * fusion-child overlap structure the assoc rules used to (R014 ca=FLOOP, root FLOOP), so the
     * detector is exercised on the SAME code paths with rules that still exist. */
    if s14 == XRO_SENT { return 6u64 }
    if s41 == XRO_SENT { return 7u64 }

    /* ROOT overlaps == the documented joining pre-emptions (each candidate yields the same
     * normal form; the cascade priority is only a tie-break -- spec sec 4). */
    if xro_root_overlap(s37, s38) != 1u8 { return 10u64 }   /* R038 with R037 */
    if xro_root_overlap(s30, s40) != 1u8 { return 11u64 }   /* R040 with R030 */
    if xro_root_overlap(s13, s41) != 1u8 { return 12u64 }   /* R041 with R013 */
    /* ROOT non-overlaps */
    if xro_root_overlap(s37, s30) != 0u8 { return 13u64 }   /* FCOMPOSE root vs FIF root -> disjoint */
    if xro_root_overlap(s32, s33) != 0u8 { return 14u64 }   /* both FCOMPOSE; ca K01 vs K09 */
    /* the VACUOUS pre-emption finding: R041 body=K06 is disjoint from R014 body=FLOOP, so
     * the documented R041<R014 ordering can never both-apply -- no real critical pair. */
    if xro_root_overlap(s14, s41) != 0u8 { return 15u64 }

    /* SUBTERM overlaps (the FLOOP family is the live witness of a rule rewriting a fusion-kind child). */
    if xro_subterm_overlap(s13, s14, 0u32) != 1u8 { return 20u64 }  /* R013 (root FLOOP) rewrites R014's ca=FLOOP */
    if xro_subterm_overlap(s14, s14, 0u32) != 1u8 { return 21u64 }  /* R014 self-overlaps its own FLOOP ca */
    if xro_subterm_overlap(s37, s14, 0u32) != 0u8 { return 22u64 }  /* R037 (root FCOMPOSE) cannot rewrite a FLOOP ca */
    if xro_subterm_overlap(s37, s13, 0u32) != 0u8 { return 23u64 }  /* R013 ca=ANY is a variable -> no overlap */

    /* enumeration is deterministic + non-empty (it contains the overlaps proven above) */
    let c1 : u32 = xro_count_overlaps()
    let c2 : u32 = xro_count_overlaps()
    if c1 != c2 { return 30u64 }
    if c1 == 0u32 { return 31u64 }

    return 99u64
}
