/* STDLIB/iii/omnia/xii_termination.iii -- mig4 Step 5: the termination / measure-decrease gate.
 * Newman's lemma: local confluence (Step 4, xii_joinability: root overlaps all join) + TERMINATION
 * => the XII canonicaliser is a confluent normaliser on the reorderable set.  This module verifies
 * the termination half: every rule application strictly decreases a well-founded measure.
 *
 * THE MEASURE MUST BE CONTEXT-CLOSED (the soundness core).  The rewrite relation rewrites SUBTERMS,
 * so a rule l->r fires in a context C[.]; termination requires a well-founded order > with
 * C[l] > C[r] for EVERY context C -- i.e. the measure's decrease on the bare redex must PROPAGATE to
 * every context.  An ADDITIVE measure (m(f(c1,c2)) = m_self + m(c1) + m(c2)) has this property:
 * m(C[l]) - m(C[r]) = m(l) - m(r) regardless of C.  A MAX-based measure does NOT: the prior
 * implementation used xii_canon_weight = w_self + max(child weights) + 1 as tier 1, which is
 * unsound here -- when a rule fires as a subterm with a heavier sibling, the max masks the change
 * (w(C[l]) = w(C[r])) and the weight decrease evaporates.  Concretely R015 (loop-over-compose
 * distribute) DECREASED canon_weight yet INCREASES node_count by 1; in C = FCOMPOSE(HeavyX, .) the
 * weight is masked and node_count rises, so the step does NOT decrease the old lex triple -- the gate
 * over-certified (found by audit; probe: R015 class was DEC_W).
 *
 * So this gate uses ONLY context-closed (additive) tiers, in lexicographic order:
 *   tier 1  LOOPBODY  -- sum over FLOOP nodes of node_count(body): "structure trapped inside loops".
 *                       R015 maps loop body (1+sa+sb) -> (sa+sb): a strict decrease of 1, at ANY
 *                       count (count-INDEPENDENT -- no count=1 edge case), and additive => context-
 *                       closed.  This is the tier that certifies loop-distribution soundly.
 *   tier 2  NODE_COUNT -- total nodes (additive): collapses/branch-lifts/trit-eval strictly shrink it.
 *   tier 3  PENALTY    -- mis-nest count (additive); vacuous post-route-S, retained for generality.
 * Three bounded-below naturals, every tier additive => the lexicographic order is a genuine reduction
 * order, well-founded under SUBTERM rewriting.  GREEN iff some rule fired and EVERY firing rule
 * strictly decreases the triple (zero INC_L, INC_N, STUCK); NO_WITNESS (the sentinel did not fire the
 * rule's guard, e.g. R032/R042) is tallied honestly, NEVER counted as terminating.
 *
 * The gate builds each rule's guard-firing redex (xjn_build_rule_witness -- the same sentinel Step 4
 * uses), applies the rule ONCE, and classifies the one-step delta on the context-closed triple.
 *
 * Hexad: kind_sensitivity.  Ring: R0.  K: 1.00.  NIH: Steps 1/2/4 + xii_term/xii_rewrite only (the
 * max-based xii_canon_weight is no longer used here -- it is not context-closed).  Determinism:
 * integer-only; ==/!= and UNSIGNED < ; single-line fns; masked indices; recursion only in the
 * additive measure walks.
 */
module omnia_xii_termination

extern @abi(c-msvc-x64) fn xrp_rule_count() -> u32 from "xii_rule_patterns.iii"
extern @abi(c-msvc-x64) fn xrp_rid_at(slot: u32) -> u32 from "xii_rule_patterns.iii"
extern @abi(c-msvc-x64) fn xro_slot_of_rid(rid: u32) -> u32 from "xii_rule_overlap.iii"
extern @abi(c-msvc-x64) fn xjn_build_rule_witness(slot: u32) -> u32 from "xii_joinability.iii"
extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_kind(idx: u32) -> u8 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_a(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_b(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_c(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_fusion2(kind: u8, a: u32, b: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_loop(body: u32, count: u64) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_apply_specific(rule_id: u32, t: u32) -> u32 from "xii_rewrite.iii"
extern @abi(c-msvc-x64) fn xii_rewrite_last_rule_fired() -> u32 from "xii_rewrite.iii"

const XTM_N        : u32 = 49u32
const XTM_NULL_REF : u32 = 0xFFFFFFFFu32
const XTM_MASK     : u64 = 0xFFFFFFFFu64
const XTM_SENT     : u32 = 0xFFFFFFFFu32
/* one-step delta classes (context-closed lexicographic triple: loopbody, node_count, penalty) */
const XTM_NOWIT : u8 = 0u8   /* the sentinel redex did not fire this rule */
const XTM_DECL  : u8 = 1u8   /* loopbody strictly decreased (loop-structure progress; certifies R015) */
const XTM_DECN  : u8 = 2u8   /* loopbody equal, node_count strictly decreased (SHRINK/DEDUP) */
const XTM_DECP  : u8 = 3u8   /* loopbody+node_count equal, penalty strictly decreased (RE-NEST; vacuous) */
const XTM_INCL  : u8 = 4u8   /* loopbody INCREASED -- a termination violation */
const XTM_INCN  : u8 = 5u8   /* loopbody equal, node_count INCREASED -- a violation */
const XTM_STUCK : u8 = 6u8   /* all three components flat -- the triple is insufficient */
/* XII kinds */
const XTM_FCOMPOSE : u8 = 18u8
const XTM_FTHEN    : u8 = 19u8
const XTM_FWITH    : u8 = 20u8
const XTM_FUNDER   : u8 = 21u8
const XTM_FIF      : u8 = 22u8
const XTM_FLOOP    : u8 = 23u8
const XTM_TVAL     : u8 = 24u8

var XTM_CLS   : [u8;  49]
var XTM_L0    : [u64; 49]   /* tier-1 = loopbody, before */
var XTM_L1    : [u64; 49]   /* tier-1 = loopbody, after  */
var XTM_N0    : [u64; 49]
var XTM_N1    : [u64; 49]
var XTM_P0    : [u64; 49]
var XTM_P1    : [u64; 49]
var XTM_FIRED : u32 = 0u32

/* node_count: total nodes in the term (the DEDUP measure + the loop-body weight).  Additive. */
fn _xtm_nodes(t: u32) -> u64 {
    if t == XTM_NULL_REF { return 0u64 }
    let kind : u8 = xii_term_get_kind(t)
    if kind <= 17u8 { return 1u64 }
    if kind == XTM_TVAL { return 1u64 }
    let a : u32 = xii_term_get_child_a(t)
    let b : u32 = xii_term_get_child_b(t)
    let mut n : u64 = 1u64 + _xtm_nodes(a) + _xtm_nodes(b)
    if kind == XTM_FIF { n = n + _xtm_nodes(xii_term_get_child_c(t)) }
    return n
}

/* LOOPBODY: sum over every FLOOP node of node_count(its body) -- the total structure trapped inside
 * loops.  ADDITIVE over subterms => context-closed.  Loop-over-compose distribute (R015) moves a
 * COMPOSE out of a loop body, decreasing this by exactly 1 at ANY count; loop fold (R014) collapses a
 * nested loop body, decreasing it; no rule moves structure INTO a loop body (verified by the gate). */
fn _xtm_loopbody(t: u32) -> u64 {
    if t == XTM_NULL_REF { return 0u64 }
    let kind : u8 = xii_term_get_kind(t)
    if kind <= 17u8 { return 0u64 }
    if kind == XTM_TVAL { return 0u64 }
    let a : u32 = xii_term_get_child_a(t)
    let b : u32 = xii_term_get_child_b(t)
    let mut s : u64 = 0u64
    if kind == XTM_FLOOP { s = _xtm_nodes(a) }
    s = s + _xtm_loopbody(a) + _xtm_loopbody(b)
    if kind == XTM_FIF { s = s + _xtm_loopbody(xii_term_get_child_c(t)) }
    return s
}

/* assoc_penalty: count of associative nodes nested in their rule's NON-canonical direction (RE-NEST).
 * Additive.  Vacuous post-route-S (the constructor canonicalises), retained for generality. */
fn _xtm_penalty(t: u32) -> u64 {
    if t == XTM_NULL_REF { return 0u64 }
    let kind : u8 = xii_term_get_kind(t)
    if kind <= 17u8 { return 0u64 }
    if kind == XTM_TVAL { return 0u64 }
    let a : u32 = xii_term_get_child_a(t)
    let b : u32 = xii_term_get_child_b(t)
    let mut p : u64 = 0u64
    if kind == XTM_FCOMPOSE { if a != XTM_NULL_REF { if xii_term_get_kind(a) == XTM_FCOMPOSE { p = 1u64 } } }
    if kind == XTM_FTHEN    { if a != XTM_NULL_REF { if xii_term_get_kind(a) == XTM_FTHEN    { p = 1u64 } } }
    if kind == XTM_FWITH    { if a != XTM_NULL_REF { if xii_term_get_kind(a) == XTM_FWITH    { p = 1u64 } } }
    if kind == XTM_FUNDER   { if b != XTM_NULL_REF { if xii_term_get_kind(b) == XTM_FUNDER   { p = 1u64 } } }
    p = p + _xtm_penalty(a) + _xtm_penalty(b)
    if kind == XTM_FIF { p = p + _xtm_penalty(xii_term_get_child_c(t)) }
    return p
}

/* the lexicographic strict-decrease predicate on the triple (loopbody, node_count, penalty):
 * 1 iff tier1 down, OR tier1 equal & tier2 down, OR tier1+tier2 equal & tier3 down.  UNSIGNED. */
fn _xtm_lex3(l0: u64, n0: u64, p0: u64, l1: u64, n1: u64, p1: u64) -> u8 {
    if l1 < l0 { return 1u8 }
    if l1 > l0 { return 0u8 }
    if n1 < n0 { return 1u8 }
    if n1 > n0 { return 0u8 }
    if p1 < p0 { return 1u8 }
    return 0u8
}

/* classify one rule's single-step delta on its guard-firing sentinel redex; records the six measures.
 * Measures BEFORE apply (apply mutates the redex in place). */
fn xtm_classify_one(slot: u32) -> u8 {
    xii_term_arena_reset()
    let w0r : u32 = xjn_build_rule_witness(slot)
    if w0r == XTM_NULL_REF { return XTM_NOWIT }
    /* Rebuild FLOOP witnesses at count=2 so loop rules fire on a real (non-degenerate) loop; R013
     * (the count==1 collapse) then NO_WITNESSes here.  Note: LOOPBODY is count-independent, so the
     * loop measure is identical at count=1 and count=2 -- this rebuild only governs which rule fires. */
    let mut w : u32 = w0r
    if xii_term_get_kind(w) == XTM_FLOOP { w = xii_term_make_loop(xii_term_get_child_a(w), 2u64) }
    if w == XTM_NULL_REF { return XTM_NOWIT }
    let rid : u32 = xrp_rid_at(slot)
    let l0 : u64 = _xtm_loopbody(w)
    let n0 : u64 = _xtm_nodes(w)
    let p0 : u64 = _xtm_penalty(w)
    let r : u32 = xii_rewrite_apply_specific(rid, w)
    if xii_rewrite_last_rule_fired() != rid { return XTM_NOWIT }
    if r == XTM_NULL_REF { return XTM_NOWIT }
    let l1 : u64 = _xtm_loopbody(r)
    let n1 : u64 = _xtm_nodes(r)
    let p1 : u64 = _xtm_penalty(r)
    let s : u64 = (slot as u64) & XTM_MASK
    XTM_L0[s] = l0
    XTM_L1[s] = l1
    XTM_N0[s] = n0
    XTM_N1[s] = n1
    XTM_P0[s] = p0
    XTM_P1[s] = p1
    if l1 > l0 { return XTM_INCL }
    if l1 < l0 { return XTM_DECL }
    if n1 > n0 { return XTM_INCN }
    if n1 < n0 { return XTM_DECN }
    if p1 < p0 { return XTM_DECP }
    return XTM_STUCK
}

/* classify all rules; record class per slot; return the count that fired. */
fn xtm_classify_all() -> u32 @export {
    let n : u64 = xrp_rule_count() as u64
    let mut i : u64 = 0u64
    let mut fired : u32 = 0u32
    while i < n {
        let c : u8 = xtm_classify_one(i as u32)
        XTM_CLS[i & XTM_MASK] = c
        if c != XTM_NOWIT { fired = fired + 1u32 }
        i = i + 1u64
    }
    XTM_FIRED = fired
    return fired
}

/* number of slots in delta-class c (call after xtm_classify_all). */
fn xtm_count_cls(c: u8) -> u64 @export {
    let n : u64 = xrp_rule_count() as u64
    let mut k : u64 = 0u64
    let mut acc : u64 = 0u64
    while k < n {
        if XTM_CLS[k] == c { acc = acc + 1u64 }
        k = k + 1u64
    }
    return acc
}

fn xtm_fired_count() -> u64 @export { return (XTM_FIRED as u64) & XTM_MASK }

/* firing rules that do NOT strictly decrease the lexicographic triple (INC_L, INC_N, or STUCK). */
fn xtm_anomaly_count() -> u64 @export { return xtm_count_cls(XTM_INCL) + xtm_count_cls(XTM_INCN) + xtm_count_cls(XTM_STUCK) }

/* rule-id of the first anomaly, or 0 if none -- the diagnosable handle. */
fn xtm_first_anomaly_rid() -> u32 @export {
    let n : u64 = xrp_rule_count() as u64
    let mut k : u64 = 0u64
    while k < n {
        let c : u8 = XTM_CLS[k]
        if c == XTM_INCL { return xrp_rid_at(k as u32) }
        if c == XTM_INCN { return xrp_rid_at(k as u32) }
        if c == XTM_STUCK { return xrp_rid_at(k as u32) }
        k = k + 1u64
    }
    return 0u32
}

/* the delta-class of a specific rule by rule-id (call after xtm_classify_all); 255 = unknown rid. */
fn xtm_class_of_rid(rid: u32) -> u8 @export {
    let slot : u32 = xro_slot_of_rid(rid)
    if slot == XTM_SENT { return 255u8 }
    if slot >= XTM_N { return 255u8 }
    return XTM_CLS[(slot as u64) & XTM_MASK]
}

/* probe a recorded measure for a rule by rule-id: which 0=l0 1=l1 2=n0 3=n1 4=p0 5=p1. */
fn xtm_probe_rid(rid: u32, which: u32) -> u64 @export {
    let slot : u32 = xro_slot_of_rid(rid)
    if slot >= XTM_N { return 0xFFFFFFFFFFFFFFFFu64 }
    let s : u64 = (slot as u64) & XTM_MASK
    if which == 0u32 { return XTM_L0[s] }
    if which == 1u32 { return XTM_L1[s] }
    if which == 2u32 { return XTM_N0[s] }
    if which == 3u32 { return XTM_N1[s] }
    if which == 4u32 { return XTM_P0[s] }
    return XTM_P1[s]
}

/* THE GATE.  GREEN(1) iff some rule fired AND every firing rule strictly decreases the context-closed
 * lexicographic triple (loopbody, node_count, penalty) -- zero INC_L, INC_N, STUCK.  Because every
 * tier is additive, this is a genuine reduction order: the certified decrease holds in every context. */
fn xtm_gate() -> u32 @export {
    let fired : u32 = xtm_classify_all()
    if fired == 0u32 { return 0u32 }
    if xtm_anomaly_count() != 0u64 { return 0u32 }
    return 1u32
}

/* KAT: 99 = all pass; a distinct code per failed check.
 * Proves: the lex-triple comparator strict-decreases in component order (1-4); the gate is GREEN over
 * the live set with the CONTEXT-CLOSED measure (5); THE FIX -- R015 (loop-over-compose distribute) is
 * now certified by LOOPBODY (DEC_L), with loopbody strictly DOWN and node_count strictly UP, exactly
 * the profile the old max-based gate mishandled (6-8); reproducible (9); and the gate has TEETH -- a
 * tier-1, tier-2, and fully-flat non-decrease are each rejected by the same arithmetic (10-12). */
fn xtm_selftest() -> u64 @export {
    /* (1-4) the lex-triple comparator: strict-decrease only, in component order. */
    if _xtm_lex3(100u64, 9u64, 5u64, 99u64, 99u64, 99u64) != 1u8 { return 1u64 }   /* tier1 down dominates */
    if _xtm_lex3(100u64, 9u64, 5u64, 100u64, 8u64, 99u64) != 1u8 { return 2u64 }   /* eq t1, t2 down */
    if _xtm_lex3(100u64, 9u64, 5u64, 100u64, 9u64, 4u64) != 1u8 { return 3u64 }    /* eq t1+t2, t3 down */
    if _xtm_lex3(100u64, 9u64, 5u64, 100u64, 9u64, 5u64) != 0u8 { return 4u64 }    /* identical: NOT a decrease */

    /* (5) the gate is GREEN over the live rule set with the context-closed measure. */
    if xtm_gate() != 1u32 { return 5u64 }

    /* (6-8) THE FIX: R015 is certified by the context-closed LOOPBODY tier (DEC_L), NOT by the removed
     * max-based canon_weight.  loopbody strictly decreased (l1 < l0) AND node_count strictly increased
     * (n1 > n0) -- precisely the DEC_W-with-node_count-increase profile that the old gate over-certified
     * and that breaks under a heavier sibling.  Now sound: loopbody is additive => context-closed. */
    if xtm_class_of_rid(15u32) != XTM_DECL { return 6u64 }
    if xtm_probe_rid(15u32, 0u32) <= xtm_probe_rid(15u32, 1u32) { return 7u64 }   /* loopbody l1 < l0 */
    if xtm_probe_rid(15u32, 3u32) <= xtm_probe_rid(15u32, 2u32) { return 8u64 }   /* node_count n1 > n0 */

    /* (9) reproducible: re-run, anomaly count stays zero, fired count unchanged + non-zero. */
    let f0 : u64 = xtm_fired_count()
    if xtm_gate() != 1u32 { return 9u64 }
    if xtm_anomaly_count() != 0u64 { return 9u64 }
    if xtm_fired_count() != f0 { return 9u64 }
    if f0 == 0u64 { return 9u64 }

    /* (10-12) the gate has TEETH (prove-the-negative): a tier-1 increase, tier-2 increase, and fully-
     * flat delta are each rejected by the SAME triple arithmetic the gate uses. */
    if _xtm_lex3(50u64, 3u64, 1u64, 60u64, 3u64, 1u64) != 0u8 { return 10u64 }   /* loopbody increase rejected */
    if _xtm_lex3(50u64, 3u64, 1u64, 50u64, 4u64, 1u64) != 0u8 { return 11u64 }   /* node_count increase rejected */
    if _xtm_lex3(50u64, 3u64, 1u64, 50u64, 3u64, 1u64) != 0u8 { return 12u64 }   /* flat rejected */

    return 99u64
}

/* xii_termination EMBODIES the termination half of XII's confluence: every rewrite rule strictly
 * decreases the well-founded, CONTEXT-CLOSED lexicographic triple (loopbody, node_count, penalty).
 * Every tier is additive over subterms, so a certified decrease on the bare redex propagates to every
 * context -- a genuine reduction order under subterm rewriting (the max-based canon_weight that the
 * prior version used as tier 1 is NOT context-closed and over-certified loop-over-compose distribute;
 * it is removed).  With Step-4 local confluence on root overlaps, this is the Newman half that makes
 * the canonicaliser a terminating, confluent normaliser on the reorderable set -- and the gate proves
 * itself RED on a fabricated loopbody-increase, node duplication, or stuck delta. */
