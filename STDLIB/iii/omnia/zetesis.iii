/* STDLIB/iii/omnia/zetesis.iii -- ZETESIS (the SEEKING): the organ that ASKS.
 *
 * The organism derives truth (the summit organs), comprehends its union
 * (synesis), places its knowledge (mneme), meters its cost (noesis) and
 * mirrors before paying (katoptron).  What it never owned was the faculty
 * that until now lived OUTSIDE it: choosing the next question, and
 * remembering having asked.  ZETESIS is that faculty, made exact.
 *
 * LAW I -- THE MIRROR OF THOUGHT (katoptron's law lifted to knowledge):
 * a candidate bridge over the union is a THOUGHT the machine has not yet
 * paid for.  The manifold (mneme's five frozen verbs) SIMULATES the thought
 * -- classes merge, edges replay, the mirror-reversing involution runs to
 * fixpoint on bit-rows -- and predicts the resulting frontier, or predicts
 * REFUSAL.  The scroll (eidolos) then actually LEARNS the claim and counts
 * for real.  Over the COMPLETE candidate space (every unordered class pair
 * x every verb shape: join, under, over) the two engines must agree pair by
 * pair, refusal by refusal, count by count -- the machine knows what a
 * thought is worth, and whether it is lawful, before thinking it.  And
 * knowledge-monotonicity (a lawful bridge never widens the frontier) is
 * checked as a free theorem at every candidate.
 *
 * LAW II -- THE CHOSEN QUESTION: yields ranked; the maximal-yield lawful
 * bridge EMERGES (content order breaks ties, so the choice is a theorem,
 * not a preference) -- the machine's own next question, spoken as a claim.
 *
 * LAW III -- THE AUTOBIOGRAPHY: the epistemic event (epoch, union name,
 * chosen question, yield, frontier) is appended CONTENT-ADDRESSED to the
 * machine's own durable journal, in its own tongue.  Every remembered event
 * is re-verified at every reading (its stored address must re-derive from
 * its text: a tampered memory is a RED memory); any remembered epoch that
 * saw the SAME union must agree with the present EXACTLY (determinism
 * across time, self-checked); an absent journal is a lawful BIRTH (epoch
 * one, an empty past).  Appending is idempotent -- the event's address is
 * its identity -- so the double-run rite stays byte-deterministic, and any
 * line-union merge of two journals is correct (the fold is order- and
 * duplicate-invariant: the event-primary law applied to knowing itself).
 *
 * THE ARMS (truth is a CONDITION OF MOTION, arms 350..353, NO gate of its
 * own -- the summit gate compiles and drives this organ):
 *   350 THE MIRROR OF THOUGHT: the union re-convened (address == the live
 *       syn_union_addr: one knowledge, one name, now THREE organs); the
 *       base frontier re-counted and equal to synesis's standing count;
 *       the manifold's base world agrees; then the COMPLETE sweep -- every
 *       candidate's simulated frontier equals its actually-learned
 *       frontier, refusals agree, monotonicity holds, zero disagreements.
 *   351 THE CHOSEN QUESTION: the argmax emerges deterministically; the
 *       question is real (yield >= 1 -- joining two frontier classes must
 *       close at least one pair) and the choice discriminates (a lawful
 *       zero-yield candidate exists: redundant knowledge buys nothing).
 *   352 THE AUTOBIOGRAPHY: the journal read, every line's address
 *       re-derived, the same-union consistency law enforced, the current
 *       event found-or-appended (idempotent), the epoch derived; crafted
 *       tampered lines are REFUSED in-arm (wrong address, wrong text).
 *   353 THE SCROLL: the seeking law sealed by EIDOLOS -- derived
 *       entailments, refused reversals, deterministic address.
 *   354 THE VERDICT: the chosen question submitted to the organism's WHOLE
 *       standing decision capability -- the metered lane (noesis images,
 *       the discharge's vocabulary, third driver of the one meter) and the
 *       JOINT lane (two organs, one invariant: noesis's image vs klisi's
 *       refusal boundary, the fleet's law).  The chosen question is
 *       UNDECIDED (machine-checked: no lane claims it) -- the deficit is
 *       NAMED; the refutable tier is answered NO with image witnesses; the
 *       best decidable truth is found by yield.
 *   355 THE SPOKEN ANSWER: the decided truth is spoken into the union --
 *       the name moves, the frontier drops by EXACTLY the mirror's
 *       predicted yield (the prophecy realized) -- and the whole episode
 *       (asked, undecided, refuted, spoken, bought) is remembered as the
 *       ANSWER event under the same journal laws.
 *
 * SCOPE (the eidolon law): the candidate space is complete over the
 * convened union's class pairs and the three claim shapes; richer bridges
 * (new vocabulary, multi-claim theories) belong to the dialectic's future
 * deciders, and the journal caps name their shard boundaries honestly.
 * NIH: composes mneme (the five frozen verbs -- THE COUPLING), synesis
 * (frozen first-bite exports), eidolos (the tongue), numera/idfold, and
 * the same msvcrt file idiom doxa proved.  Sibling line: gnosis KNOWS,
 * noesis METERS, mneme PLACES, katoptron MIRRORS, synesis COMPREHENDS --
 * zetesis ASKS.  Ring R-1. */
module omnia_zetesis

extern @abi(c-msvc-x64) fn eol_reset() -> i32 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_read(addr: u64, len: u64) -> i64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_addr() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_lawcheck() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_entails(a_addr: u64, a_len: u64, verb: u64, b_addr: u64, b_len: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_claims() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_things() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_claim_a(i: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_claim_v(i: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_claim_b(i: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_class_count() -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_class_root(i: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_class_of_thing(t: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_mirror_class(ci: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_reaches(ci: u64, cj: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_thing_len(t: u64) -> u64 from "eidolos.iii"
extern @abi(c-msvc-x64) fn eol_thing_byte(t: u64, k: u64) -> u8 from "eidolos.iii"
extern @abi(c-msvc-x64) fn py_testify() -> u64 from "pyrgos.iii"
extern @abi(c-msvc-x64) fn rz_testify() -> u64 from "riza.iii"
extern @abi(c-msvc-x64) fn ky_testify() -> u64 from "kyma.iii"
extern @abi(c-msvc-x64) fn ms_testify() -> u64 from "meris.iii"
extern @abi(c-msvc-x64) fn kl_testify() -> u64 from "klisi.iii"
extern @abi(c-msvc-x64) fn su_testify() -> u64 from "summit.iii"
extern @abi(c-msvc-x64) fn gn_testify() -> u64 from "gnosis.iii"
extern @abi(c-msvc-x64) fn no_testify() -> u64 from "noesis.iii"
extern @abi(c-msvc-x64) fn syn_union_addr() -> u64 from "synesis.iii"
extern @abi(c-msvc-x64) fn syn_frontier_count() -> u64 from "synesis.iii"
extern @abi(c-msvc-x64) fn syn_bridge_len() -> u64 from "synesis.iii"
extern @abi(c-msvc-x64) fn syn_bridge_byte(i: u64) -> u8 from "synesis.iii"
extern @abi(c-msvc-x64) fn mn_reset() -> i32 from "mneme.iii"
extern @abi(c-msvc-x64) fn mn_put(id: u64) -> u64 from "mneme.iii"
extern @abi(c-msvc-x64) fn mn_link(i: u64, j: u64) -> u64 from "mneme.iii"
extern @abi(c-msvc-x64) fn mn_fold() -> i32 from "mneme.iii"
extern @abi(c-msvc-x64) fn mn_ent(i: u64, j: u64) -> u64 from "mneme.iii"
extern @abi(c-msvc-x64) fn no_meter(kind: u64, p: u64) -> u64 from "noesis.iii"
extern @abi(c-msvc-x64) fn kl_inv2_u64(v: u64) -> u64 from "klisi.iii"
extern @abi(c-msvc-x64) fn kl_err() -> u64 from "klisi.iii"
extern @abi(c-msvc-x64) fn kd_setp(p: u64) -> i32 from "klisi.iii"
extern @abi(c-msvc-x64) fn kd_mode(k: u64, m: u64) -> i32 from "klisi.iii"
extern @abi(c-msvc-x64) fn idfold_bytes(ptr: u64, n: u64) -> u64 from "idfold.iii"
extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fread(buf: u64, sz: u64, n: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(stream: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn fputs(s: u64, stream: u64) -> i32 from "msvcrt"

const ZT_SENT : u64 = 18446744073709551615u64
const ZT_ERR : u64 = 18446744073709551614u64

var ZT_UST : [u64; 128]                   /* subject thing ids (base convening) */
var ZT_USC : [u64; 128]                   /* subject base class                 */
var ZT_USN : u64 = 0u64
var ZT_CMIR : [u64; 64]                  /* base class -> mirror class | SENT  */
var ZT_RID : [u64; 64]                   /* base class -> content identity     */
var ZT_EA : [u64; 64]                    /* base order edges (class pairs)     */
var ZT_EB : [u64; 64]
var ZT_EN : u64 = 0u64
var ZT_NC : u64 = 0u64                   /* base class count                   */
var ZT_BR : [u8; 64]                     /* the discharged bridge bytes        */
var ZT_TB : [u8; 128]                    /* root byte scratch                  */
var ZT_UF : [u64; 64]                    /* class union-find (candidate world) */
var ZT_WMIR : [u64; 64]                  /* world root class -> partner root   */
var ZT_LNC : [u64; 64]                   /* class -> world lane                */
var ZT_LMIR : [u64; 64]                  /* lane -> partner lane | SENT        */
var ZT_NL : u64 = 0u64                   /* world lane count                   */
var ZT_YLD : [u64; 6144]                 /* per-candidate: SENT | yield        */
var ZT_NCAND : u64 = 0u64
var ZT_F0 : u64 = 0u64                   /* base frontier (scroll engine)      */
var ZT_F0M : u64 = 0u64                  /* base frontier (manifold engine)    */
var ZT_PICK : u64 = 0u64
var ZT_Q : [u8; 192]                     /* the chosen question claim text     */
var ZT_QN : u64 = 0u64
var ZT_CT : [u8; 192]                    /* candidate claim scratch            */
var ZT_CTN : u64 = 0u64
var ZT_EV : [u8; 384]                    /* the epoch event text               */
var ZT_EVN : u64 = 0u64
var ZT_UN : [u8; 48]                     /* the union hi:lo needle             */
var ZT_UNN : u64 = 0u64
var ZT_JB : [u8; 16384]                  /* journal bytes                      */
var ZT_LINE : [u8; 512]                  /* append/craft scratch               */
var ZT_EPOCH : u64 = 0u64
var ZT_YIELDV : u64 = 0u64
var ZT_SCROLL : u64 = 0u64

fn zt_addr() -> u64 @export { return ZT_SCROLL }
fn zt_epoch() -> u64 @export { return ZT_EPOCH }
fn zt_yield() -> u64 @export { return ZT_YIELDV }
fn zt_question_len() -> u64 @export { return ZT_QN }
fn zt_question_byte(i: u64) -> u8 @export {
    if i < ZT_QN { return ZT_Q[i] }
    return 0u8
}
fn zt_slen(s: u64) -> u64 {
    let p : *u8 = s as *u8
    let mut n : u64 = 0u64
    while p[n] != 0u8 { n = n + 1u64 }
    return n
}
fn zt_testimony(k: u64) -> u64 {
    if k == 0u64 { return py_testify() }
    if k == 1u64 { return rz_testify() }
    if k == 2u64 { return ky_testify() }
    if k == 3u64 { return ms_testify() }
    if k == 4u64 { return kl_testify() }
    if k == 5u64 { return su_testify() }
    if k == 6u64 { return gn_testify() }
    return no_testify()
}
fn zt_convene() -> u64 {
    /* the SAME eight testimonies + the discharged bridge, side by side */
    eol_reset()
    let mut k : u64 = 0u64
    while k < 8u64 {
        let t : u64 = zt_testimony(k)
        if eol_read(t, zt_slen(t)) < 0i64 { return 1u64 }
        k = k + 1u64
    }
    let bn : u64 = syn_bridge_len()
    if bn == 0u64 { return 2u64 }
    if bn > 64u64 { return 2u64 }
    let mut i : u64 = 0u64
    while i < bn { ZT_BR[i] = syn_bridge_byte(i)   i = i + 1u64 }
    if eol_read((&ZT_BR) as u64, bn) < 0i64 { return 2u64 }
    if eol_lawcheck() != 0u64 { return 3u64 }
    return 0u64
}
fn zt_root_id(c: u64) -> u64 {
    let rt : u64 = eol_class_root(c)
    let ln : u64 = eol_thing_len(rt)
    if ln == 0u64 { return 0u64 }
    if ln > 128u64 { return 0u64 }
    let mut k : u64 = 0u64
    while k < ln { ZT_TB[k] = eol_thing_byte(rt, k)   k = k + 1u64 }
    return idfold_bytes((&ZT_TB) as u64, ln)
}
fn zt_harvest() -> u64 {
    /* base facts off the standing convening: classes, identities, mirror
     * partners, stated order edges, subjects with their classes */
    ZT_NC = eol_class_count()
    if ZT_NC == 0u64 { return 1u64 }
    if ZT_NC > 64u64 { return 2u64 }                     /* the shard boundary */
    let mut c : u64 = 0u64
    while c < ZT_NC {
        ZT_RID[c] = zt_root_id(c)
        if ZT_RID[c] == 0u64 { return 3u64 }
        ZT_CMIR[c] = eol_mirror_class(c)
        c = c + 1u64
    }
    ZT_EN = 0u64
    let cn : u64 = eol_claims()
    let mut i : u64 = 0u64
    while i < cn {
        if eol_claim_v(i) == 0u64 {
            if ZT_EN >= 64u64 { return 4u64 }
            let ca : u64 = eol_class_of_thing(eol_claim_a(i))
            let cb : u64 = eol_class_of_thing(eol_claim_b(i))
            if ca == ZT_SENT { return 4u64 }
            if cb == ZT_SENT { return 4u64 }
            ZT_EA[ZT_EN] = ca
            ZT_EB[ZT_EN] = cb
            ZT_EN = ZT_EN + 1u64
        }
        i = i + 1u64
    }
    ZT_USN = 0u64
    let tn : u64 = eol_things()
    let mut t : u64 = 0u64
    while t < tn {
        if eol_thing_len(t) > 0u64 { if eol_thing_byte(t, 0u64) != 91u8 {
            if ZT_USN >= 128u64 { return 5u64 }
            let cl : u64 = eol_class_of_thing(t)
            if cl == ZT_SENT { return 5u64 }
            ZT_UST[ZT_USN] = t
            ZT_USC[ZT_USN] = cl
            ZT_USN = ZT_USN + 1u64
        } }
        t = t + 1u64
    }
    return 0u64
}
fn zt_front_eol() -> u64 {
    /* the frontier on the STANDING scroll, by the connection predicate the
     * whole cluster shares: same class, reach either way, or mirror */
    let mut unc : u64 = 0u64
    let mut i : u64 = 0u64
    while i < ZT_USN {
        let mut j : u64 = i + 1u64
        while j < ZT_USN {
            let ci : u64 = eol_class_of_thing(ZT_UST[i])
            let cj : u64 = eol_class_of_thing(ZT_UST[j])
            let mut con : u64 = 0u64
            if ci == cj { con = 1u64 }
            if eol_reaches(ci, cj) == 1u64 { con = 1u64 }
            if eol_reaches(cj, ci) == 1u64 { con = 1u64 }
            if eol_mirror_class(ci) == cj { con = 1u64 }
            if con == 0u64 { unc = unc + 1u64 }
            j = j + 1u64
        }
        i = i + 1u64
    }
    return unc
}
fn zt_find(x: u64) -> u64 {
    let mut r : u64 = x
    while ZT_UF[r] != r { r = ZT_UF[r] }
    return r
}
fn zt_union(a: u64, b: u64) -> u64 {
    let ra : u64 = zt_find(a)
    let rb : u64 = zt_find(b)
    if ra == rb { return 0u64 }
    if ra < rb { ZT_UF[rb] = ra } else { ZT_UF[ra] = rb }
    return 1u64
}
fn zt_world(shape: u64, p: u64, q: u64) -> u64 {
    /* build the candidate world in the MANIFOLD (mneme's frozen verbs):
     * shape 0 = join p q | 1 = p under q | 2 = q under p | 3 = no candidate.
     * SENT = the world is predicted REFUSED; 0 = built and folded. */
    let mut c : u64 = 0u64
    while c < ZT_NC { ZT_UF[c] = c   c = c + 1u64 }
    if shape == 0u64 { zt_union(p, q) }
    /* the second-mirror-is-equality law, replayed at world level */
    let mut guard : u64 = 0u64
    let mut changed : u64 = 1u64
    while changed == 1u64 {
        changed = 0u64
        guard = guard + 1u64
        if guard > 70u64 { return ZT_ERR }
        c = 0u64
        while c < ZT_NC { ZT_WMIR[c] = ZT_SENT   c = c + 1u64 }
        c = 0u64
        while c < ZT_NC {
            if ZT_CMIR[c] != ZT_SENT {
                let r : u64 = zt_find(c)
                let mr : u64 = zt_find(ZT_CMIR[c])
                if ZT_WMIR[r] == ZT_SENT { ZT_WMIR[r] = mr } else {
                    if ZT_WMIR[r] != mr { zt_union(ZT_WMIR[r], mr)   changed = 1u64 }
                }
            }
            c = c + 1u64
        }
    }
    /* lanes for the world's roots, in root order */
    mn_reset()
    let mut nl : u64 = 0u64
    c = 0u64
    while c < ZT_NC {
        if zt_find(c) == c {
            if mn_put(ZT_RID[c]) != nl { return ZT_ERR }
            ZT_LNC[c] = nl
            nl = nl + 1u64
        }
        c = c + 1u64
    }
    ZT_NL = nl
    c = 0u64
    while c < ZT_NC { ZT_LNC[c] = ZT_LNC[zt_find(c)]   c = c + 1u64 }
    let mut x : u64 = 0u64
    while x < nl { ZT_LMIR[x] = ZT_SENT   x = x + 1u64 }
    c = 0u64
    while c < ZT_NC {
        if zt_find(c) == c { if ZT_WMIR[c] != ZT_SENT {
            ZT_LMIR[ZT_LNC[c]] = ZT_LNC[zt_find(ZT_WMIR[c])]
        } }
        c = c + 1u64
    }
    /* the stated order edges; an edge into its own class is the refusal */
    let mut e : u64 = 0u64
    while e < ZT_EN {
        let la : u64 = ZT_LNC[ZT_EA[e]]
        let lb : u64 = ZT_LNC[ZT_EB[e]]
        if la == lb { return ZT_SENT }
        if mn_link(la, lb) != 1u64 { return ZT_ERR }
        e = e + 1u64
    }
    if shape == 1u64 {
        let la1 : u64 = ZT_LNC[p]
        let lb1 : u64 = ZT_LNC[q]
        if la1 == lb1 { return ZT_SENT }
        if mn_link(la1, lb1) != 1u64 { return ZT_ERR }
    }
    if shape == 2u64 {
        let la2 : u64 = ZT_LNC[q]
        let lb2 : u64 = ZT_LNC[p]
        if la2 == lb2 { return ZT_SENT }
        if mn_link(la2, lb2) != 1u64 { return ZT_ERR }
    }
    mn_fold()
    /* the order-reversing involution on the manifold's rows, to fixpoint */
    guard = 0u64
    changed = 1u64
    while changed == 1u64 {
        changed = 0u64
        guard = guard + 1u64
        if guard > 130u64 { return ZT_ERR }
        x = 0u64
        while x < nl {
            if ZT_LMIR[x] != ZT_SENT {
                let mut y : u64 = 0u64
                while y < nl {
                    if x != y { if ZT_LMIR[y] != ZT_SENT {
                        if mn_ent(x, y) == 1u64 {
                            if mn_ent(ZT_LMIR[y], ZT_LMIR[x]) == 0u64 {
                                if mn_link(ZT_LMIR[y], ZT_LMIR[x]) != 1u64 { return ZT_ERR }
                                changed = 1u64
                            }
                        }
                    } }
                    y = y + 1u64
                }
            }
            x = x + 1u64
        }
        if changed == 1u64 { mn_fold() }
    }
    /* mutual reach between distinct lanes = a class under itself = refused */
    x = 0u64
    while x < nl {
        let mut y2 : u64 = x + 1u64
        while y2 < nl {
            if mn_ent(x, y2) == 1u64 { if mn_ent(y2, x) == 1u64 { return ZT_SENT } }
            y2 = y2 + 1u64
        }
        x = x + 1u64
    }
    return 0u64
}
fn zt_world_front() -> u64 {
    /* the frontier of the SIMULATED world, off the manifold's rows */
    let mut unc : u64 = 0u64
    let mut i : u64 = 0u64
    while i < ZT_USN {
        let mut j : u64 = i + 1u64
        while j < ZT_USN {
            let li : u64 = ZT_LNC[ZT_USC[i]]
            let lj : u64 = ZT_LNC[ZT_USC[j]]
            let mut con : u64 = 0u64
            if li == lj { con = 1u64 }
            if mn_ent(li, lj) == 1u64 { con = 1u64 }
            if mn_ent(lj, li) == 1u64 { con = 1u64 }
            if ZT_LMIR[li] == lj { con = 1u64 }
            if con == 0u64 { unc = unc + 1u64 }
            j = j + 1u64
        }
        i = i + 1u64
    }
    return unc
}
/* candidate claim text: [rootbytes(a) verb rootbytes(b)] */
fn zt_cput(c: u8) -> i32 {
    if ZT_CTN < 192u64 { ZT_CT[ZT_CTN] = c   ZT_CTN = ZT_CTN + 1u64 }
    return 0i32
}
fn zt_cput_root(c: u64) -> i32 {
    let rt : u64 = eol_class_root(c)
    let ln : u64 = eol_thing_len(rt)
    let mut k : u64 = 0u64
    while k < ln { zt_cput(eol_thing_byte(rt, k))   k = k + 1u64 }
    return 0i32
}
fn zt_cand_text(shape: u64, p: u64, q: u64) -> i32 {
    ZT_CTN = 0u64
    zt_cput(91u8)
    let mut a : u64 = p
    let mut b : u64 = q
    if shape == 2u64 { a = q   b = p }
    zt_cput_root(a)
    zt_cput(32u8)
    if shape == 0u64 { zt_cput(61u8) } else { zt_cput(60u8) }
    zt_cput(32u8)
    zt_cput_root(b)
    zt_cput(93u8)
    return 0i32
}
fn zt_confirm(shape: u64, p: u64, q: u64) -> u64 {
    /* the SCROLL engine actually learns the candidate and counts for real:
     * SENT = refused by law; ZT_ERR = broken machinery; else the frontier */
    if zt_convene() != 0u64 { return ZT_ERR }
    zt_cand_text(shape, p, q)
    if eol_read((&ZT_CT) as u64, ZT_CTN) < 0i64 { return ZT_ERR }
    if eol_lawcheck() != 0u64 { return ZT_SENT }
    return zt_front_eol()
}
fn zt_arm350() -> u64 {
    /* THE MIRROR OF THOUGHT: the complete candidate sweep, two engines */
    if syn_union_addr() == 0u64 { return 350u64 }
    if zt_convene() != 0u64 { return 350u64 }
    if eol_addr() != syn_union_addr() { return 350u64 }
    if zt_harvest() != 0u64 { return 350u64 }
    ZT_F0 = zt_front_eol()
    if ZT_F0 != syn_frontier_count() { return 350u64 }
    /* the base world: the manifold agrees before any thought is priced */
    if zt_world(3u64, 0u64, 0u64) != 0u64 { return 350u64 }
    ZT_F0M = zt_world_front()
    if ZT_F0M != ZT_F0 { return 350u64 }
    /* every unordered class pair, every shape: predict, learn, compare */
    let mut cid : u64 = 0u64
    let mut p : u64 = 0u64
    while p < ZT_NC {
        let mut q : u64 = p + 1u64
        while q < ZT_NC {
            let mut s : u64 = 0u64
            while s < 3u64 {
                let w : u64 = zt_world(s, p, q)
                if w == ZT_ERR { return 350u64 }
                let mut pv : u64 = ZT_SENT
                if w == 0u64 { pv = zt_world_front() }
                let cv : u64 = zt_confirm(s, p, q)
                if cv == ZT_ERR { return 350u64 }
                if pv != cv { return 350u64 }
                if pv != ZT_SENT {
                    if pv > ZT_F0 { return 350u64 }        /* monotone knowledge */
                    ZT_YLD[cid] = ZT_F0 - pv
                } else {
                    ZT_YLD[cid] = ZT_SENT
                }
                cid = cid + 1u64
                s = s + 1u64
            }
            q = q + 1u64
        }
        p = p + 1u64
    }
    ZT_NCAND = cid
    if cid != ((ZT_NC * (ZT_NC - 1u64)) / 2u64) * 3u64 { return 350u64 }
    return 0u64
}
fn zt_arm351() -> u64 {
    /* THE CHOSEN QUESTION: the argmax emerges; the choice discriminates */
    let mut best : u64 = 0u64
    let mut besti : u64 = ZT_SENT
    let mut zero_seen : u64 = 0u64
    let mut i : u64 = 0u64
    while i < ZT_NCAND {
        if ZT_YLD[i] != ZT_SENT {
            if ZT_YLD[i] == 0u64 { zero_seen = 1u64 }
            if ZT_YLD[i] > best { best = ZT_YLD[i]   besti = i }
        }
        i = i + 1u64
    }
    if besti == ZT_SENT { return 351u64 }
    if best < 1u64 { return 351u64 }
    if zero_seen != 1u64 { return 351u64 }
    ZT_PICK = besti
    ZT_YIELDV = best
    /* decode the pick and speak the question (the standing scroll is the
     * base convening from the last confirm loop; re-convene for clean roots) */
    if zt_convene() != 0u64 { return 351u64 }
    let mut pr : u64 = 0u64
    let mut qr : u64 = 0u64
    let mut left : u64 = besti / 3u64
    let sh : u64 = besti % 3u64
    let mut p : u64 = 0u64
    let mut going : u64 = 1u64
    while going == 1u64 {
        let row : u64 = (ZT_NC - 1u64) - p
        if left < row { pr = p   qr = (p + 1u64) + left   going = 0u64 } else {
            left = left - row
            p = p + 1u64
            if p >= ZT_NC { return 351u64 }
        }
    }
    zt_cand_text(sh, pr, qr)
    if ZT_CTN == 0u64 { return 351u64 }
    if ZT_CTN > 160u64 { return 351u64 }
    ZT_QN = ZT_CTN
    let mut k : u64 = 0u64
    while k < ZT_CTN { ZT_Q[k] = ZT_CT[k]   k = k + 1u64 }
    return 0u64
}
/* ==================== the autobiography ==================== */
var ZT_LTO : u64 = 0u64                  /* verified line: text offset in ZT_JB */
var ZT_LTN : u64 = 0u64                  /* verified line: text length          */
fn zt_vline(buf: u64, off: u64, len: u64) -> u64 {
    /* verify one journal line "addr text": the address must RE-DERIVE from
     * the text.  Returns the address (nonzero) or 0 = a lying memory. */
    let pb : *u8 = buf as *u8
    let mut i : u64 = off
    let stop : u64 = off + len
    let mut ad : u64 = 0u64
    let mut nd : u64 = 0u64
    let mut going : u64 = 1u64
    while going == 1u64 {
        if i >= stop { return 0u64 }
        let c : u8 = pb[i]
        if c == 32u8 { going = 0u64 } else {
            if c < 48u8 { return 0u64 }
            if c > 57u8 { return 0u64 }
            ad = (ad * 10u64) + ((c - 48u8) as u64)
            nd = nd + 1u64
            i = i + 1u64
        }
    }
    if nd == 0u64 { return 0u64 }
    if ad == 0u64 { return 0u64 }
    i = i + 1u64
    if i >= stop { return 0u64 }
    ZT_LTO = i
    ZT_LTN = stop - i
    eol_reset()
    if eol_read(buf + i, ZT_LTN) < 0i64 { return 0u64 }
    if eol_addr() != ad { return 0u64 }
    return ad
}
fn zt_lput(c: u8) -> i32 {
    if ZT_EVN < 384u64 { ZT_EV[ZT_EVN] = c   ZT_EVN = ZT_EVN + 1u64 }
    return 0i32
}
fn zt_lputs(s: u64) -> i32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { zt_lput(p[i])   i = i + 1u64 }
    return 0i32
}
fn zt_lput_u64(v: u64) -> i32 {
    if v >= 10u64 { zt_lput_u64(v / 10u64) }
    zt_lput((48u64 + (v % 10u64)) as u8)
    return 0i32
}
fn zt_nput(c: u8) -> i32 {
    if ZT_UNN < 48u64 { ZT_UN[ZT_UNN] = c   ZT_UNN = ZT_UNN + 1u64 }
    return 0i32
}
fn zt_nput_u64(v: u64) -> i32 {
    if v >= 10u64 { zt_nput_u64(v / 10u64) }
    zt_nput((48u64 + (v % 10u64)) as u8)
    return 0i32
}
fn zt_event_build() -> i32 {
    /* the epoch event, spoken in the one tongue: the union's split name
     * (hi:lo -- the measure envelope is 18 digits, a u64 name is not),
     * the chosen question MENTIONED, its yield, the standing frontier */
    let u : u64 = syn_union_addr()
    let hi : u64 = u / 1000000000u64
    let lo : u64 = u % 1000000000u64
    /* the needle for the same-union law, anchored on both sides (the
     * leading bracket keeps the QUESTION event and the ANSWER event from
     * ever cross-matching: "[union" vs "[answered union") */
    ZT_UNN = 0u64
    zt_nput(91u8)
    zt_nput(117u8)
    zt_nput(110u8)
    zt_nput(105u8)
    zt_nput(111u8)
    zt_nput(110u8)
    zt_nput(32u8)
    zt_nput_u64(hi)
    zt_nput(58u8)
    zt_nput_u64(lo)
    zt_nput(32u8)
    ZT_EVN = 0u64
    zt_lputs("[union " as u64)
    zt_lput_u64(hi)
    zt_lput(58u8)
    zt_lput_u64(lo)
    zt_lputs(" = standing knowledge] [" as u64)
    let mut k : u64 = 0u64
    while k < ZT_QN { zt_lput(ZT_Q[k])   k = k + 1u64 }
    zt_lputs(" = chosen question] [chosen question = yield " as u64)
    zt_lput_u64(ZT_YIELDV)
    zt_lputs("] [standing knowledge = frontier " as u64)
    zt_lput_u64(ZT_F0)
    zt_lputs("]" as u64)
    return 0i32
}
fn zt_has_needle(buf: u64, off: u64, len: u64) -> u64 {
    /* does the line text contain the union needle? */
    if ZT_UNN == 0u64 { return 0u64 }
    if len < ZT_UNN { return 0u64 }
    let pb : *u8 = buf as *u8
    let mut i : u64 = off
    let stop : u64 = (off + len) - ZT_UNN
    while i <= stop {
        let mut k : u64 = 0u64
        let mut same : u64 = 1u64
        while k < ZT_UNN {
            if pb[i + k] != ZT_UN[k] { same = 0u64   k = ZT_UNN }
            k = k + 1u64
        }
        if same == 1u64 { return 1u64 }
        i = i + 1u64
    }
    return 0u64
}
fn zt_arm352() -> u64 {
    /* THE AUTOBIOGRAPHY: read, verify every remembered event, enforce the
     * same-union consistency law, find-or-append the present, derive epoch */
    zt_event_build()
    if ZT_EVN == 0u64 { return 352u64 }
    if ZT_EVN >= 380u64 { return 352u64 }
    ZT_EPOCH = zt_journal()
    if ZT_EPOCH == 0u64 { return 352u64 }
    return 0u64
}
fn zt_arm353() -> u64 {
    /* THE SCROLL: the seeking law sealed */
    eol_reset()
    let doc : u64 = "[question = priced thought] [priced thought = confirmed thought] [confirmed thought < standing knowledge] [journal = remembered fold] [memory = monotone log]" as u64
    let dl : u64 = zt_slen(doc)
    if eol_read(doc, dl) < 0i64 { return 353u64 }
    let a1 : u64 = eol_addr()
    if a1 == 0u64 { return 353u64 }
    /* DERIVED (absent from the text): the question sits under the standing
     * knowledge -- what is asked is bounded by what is known */
    let qa : u64 = "question" as u64
    let qb : u64 = "standing knowledge" as u64
    if eol_entails(qa, zt_slen(qa), 0u64, qb, zt_slen(qb)) != 1u64 { return 353u64 }
    /* the reversal REFUSES: knowledge does not sit under the question */
    if eol_entails(qb, zt_slen(qb), 0u64, qa, zt_slen(qa)) != 0u64 { return 353u64 }
    /* cross-class refusal: the journal is not the question */
    if eol_entails("journal" as u64, 7u64, 2u64, qa, zt_slen(qa)) != 0u64 { return 353u64 }
    eol_reset()
    if eol_read(doc, dl) < 0i64 { return 353u64 }
    if eol_addr() != a1 { return 353u64 }
    ZT_SCROLL = a1
    return 0u64
}
/* ==================== THE JOURNAL ENGINE (shared) ==================== */
fn zt_journal() -> u64 {
    /* the current event (ZT_EV, needle ZT_UN) is named twice, teeth-checked,
     * verified against every remembered line, found-or-appended.  Returns
     * the epoch (1-based line position); 0 = a broken or lying memory. */
    if ZT_EVN == 0u64 { return 0u64 }
    if ZT_EVN >= 380u64 { return 0u64 }
    eol_reset()
    if eol_read((&ZT_EV) as u64, ZT_EVN) < 0i64 { return 0u64 }
    let ea : u64 = eol_addr()
    if ea == 0u64 { return 0u64 }
    eol_reset()
    if eol_read((&ZT_EV) as u64, ZT_EVN) < 0i64 { return 0u64 }
    if eol_addr() != ea { return 0u64 }
    /* teeth: wrong address refused; right address with rotted text refused */
    let mut ln : u64 = 0u64
    let mut tv : u64 = ea + 1u64
    var digs : [u8; 24]
    let mut nd : u64 = 0u64
    while tv > 0u64 { digs[nd] = (48u64 + (tv % 10u64)) as u8   tv = tv / 10u64   nd = nd + 1u64 }
    let mut di : u64 = nd
    while di > 0u64 { ZT_LINE[ln] = digs[di - 1u64]   ln = ln + 1u64   di = di - 1u64 }
    ZT_LINE[ln] = 32u8
    ln = ln + 1u64
    let mut k : u64 = 0u64
    while k < ZT_EVN { ZT_LINE[ln + k] = ZT_EV[k]   k = k + 1u64 }
    if zt_vline((&ZT_LINE) as u64, 0u64, ln + ZT_EVN) != 0u64 { return 0u64 }
    tv = ea
    nd = 0u64
    while tv > 0u64 { digs[nd] = (48u64 + (tv % 10u64)) as u8   tv = tv / 10u64   nd = nd + 1u64 }
    ln = 0u64
    di = nd
    while di > 0u64 { ZT_LINE[ln] = digs[di - 1u64]   ln = ln + 1u64   di = di - 1u64 }
    ZT_LINE[ln] = 32u8
    ln = ln + 1u64
    k = 0u64
    while k < ZT_EVN { ZT_LINE[ln + k] = ZT_EV[k]   k = k + 1u64 }
    ZT_LINE[ln] = 120u8
    if zt_vline((&ZT_LINE) as u64, 0u64, ln + ZT_EVN) != 0u64 { return 0u64 }
    /* the journal file */
    let jp : u64 = "STDLIB/data/zetesis.jrnl" as u64
    let mut jn : u64 = 0u64
    let fh : u64 = fopen(jp, "rb" as u64)
    if fh != 0u64 {
        jn = fread((&ZT_JB) as u64, 1u64, 16384u64, fh)
        fclose(fh)
        if jn >= 16384u64 { return 0u64 }
    }
    let mut kc : u64 = 0u64
    let mut present : u64 = 0u64
    let mut presi : u64 = 0u64
    let mut off : u64 = 0u64
    while off < jn {
        let mut stop : u64 = off
        let mut going : u64 = 1u64
        while going == 1u64 {
            if stop >= jn { going = 0u64 } else {
                if ZT_JB[stop] == 10u8 { going = 0u64 } else { stop = stop + 1u64 }
            }
        }
        let llen : u64 = stop - off
        if llen == 0u64 { return 0u64 }
        if zt_vline((&ZT_JB) as u64, off, llen) == 0u64 { return 0u64 }
        kc = kc + 1u64
        if zt_has_needle((&ZT_JB) as u64, ZT_LTO, ZT_LTN) == 1u64 {
            if ZT_LTN != ZT_EVN { return 0u64 }
            let mut b : u64 = 0u64
            while b < ZT_LTN {
                if ZT_JB[ZT_LTO + b] != ZT_EV[b] { return 0u64 }
                b = b + 1u64
            }
            present = 1u64
            presi = kc
        }
        off = stop + 1u64
    }
    if present == 1u64 { return presi }
    tv = ea
    nd = 0u64
    while tv > 0u64 { digs[nd] = (48u64 + (tv % 10u64)) as u8   tv = tv / 10u64   nd = nd + 1u64 }
    ln = 0u64
    di = nd
    while di > 0u64 { ZT_LINE[ln] = digs[di - 1u64]   ln = ln + 1u64   di = di - 1u64 }
    ZT_LINE[ln] = 32u8
    ln = ln + 1u64
    k = 0u64
    while k < ZT_EVN { ZT_LINE[ln] = ZT_EV[k]   ln = ln + 1u64   k = k + 1u64 }
    ZT_LINE[ln] = 10u8
    ln = ln + 1u64
    ZT_LINE[ln] = 0u8
    let fa : u64 = fopen(jp, "ab" as u64)
    if fa == 0u64 { return 0u64 }
    fputs((&ZT_LINE) as u64, fa)
    fclose(fa)
    return kc + 1u64
}

/* ==================== THE VERDICT AND THE SPOKEN ANSWER (arms 354..355) ====
 * The chosen question is submitted to the organism's WHOLE standing decision
 * capability.  The metered lane (the discharge's shared vocabulary, synesis
 * arm 336 -- one meter, now three drivers) decides joins of fold families by
 * noesis's complete w=8 images; the JOINT lane (the fleet's law, synesis
 * 344..345) decides [mul M = depth D] only when TWO organs derive the same
 * invariant -- noesis's image against klisi's own refusal boundary.  What no
 * lane can decide is UNDECIDED: the named deficit.  The best decidable truth
 * is SPOKEN, the union grows, the mirror's predicted yield is REALIZED, and
 * the whole episode -- asked, undecided, refuted tier, spoken truth -- is
 * remembered in the journal as the ANSWER event. */
var ZT_FPV : u64 = 0u64
var ZT_DP : u64 = 0u64
var ZT_DQ : u64 = 0u64
var ZT_DS : u64 = 0u64
var ZT_ANS : u64 = 0u64                  /* the answered candidate | SENT      */
var ZT_AQ : [u8; 192]                    /* the answered claim text            */
var ZT_AQN : u64 = 0u64
var ZT_REF : u64 = 0u64                  /* refuted-with-witness count         */
var ZT_DECN : u64 = 0u64                 /* decidable candidate count          */
var ZT_UNDEC : u64 = 0u64                /* 1 = the chosen question undecided  */
var ZT_REALV : u64 = 0u64                /* realized frontier drop             */
var ZT_F2 : u64 = 0u64                   /* the grown frontier                 */
var ZT_EP2 : u64 = 0u64                  /* the answer epoch                   */
fn zt_ans_len() -> u64 @export { return ZT_AQN }
fn zt_ans_byte(i: u64) -> u8 @export {
    if i < ZT_AQN { return ZT_AQ[i] }
    return 0u8
}
fn zt_realized() -> u64 @export { return ZT_REALV }
fn zt_epoch2() -> u64 @export { return ZT_EP2 }
fn zt_undecided() -> u64 @export { return ZT_UNDEC }
fn zt_nputs(s: u64) -> i32 {
    let p : *u8 = s as *u8
    let mut i : u64 = 0u64
    while p[i] != 0u8 { zt_nput(p[i])   i = i + 1u64 }
    return 0i32
}
fn zt_famparse(c: u64) -> u64 {
    /* is class c's root a metered word?  "shr K | mul M | umod K | sdiv K |
     * erasure E" (the discharge's vocabulary) or "depth D" (the joint lane).
     * kinds 1..6 in that order; 0 = not metered.  Value left in ZT_FPV. */
    let rt : u64 = eol_class_root(c)
    let lnr : u64 = eol_thing_len(rt)
    if lnr == 0u64 { return 0u64 }
    if lnr > 64u64 { return 0u64 }
    let mut k : u64 = 0u64
    while k < lnr { ZT_TB[k] = eol_thing_byte(rt, k)   k = k + 1u64 }
    let mut sp : u64 = ZT_SENT
    k = 0u64
    while k < lnr {
        if ZT_TB[k] == 32u8 { if sp == ZT_SENT { sp = k } }
        k = k + 1u64
    }
    if sp == ZT_SENT { return 0u64 }
    let mut v : u64 = 0u64
    let mut ndg : u64 = 0u64
    k = sp + 1u64
    while k < lnr {
        let c2 : u8 = ZT_TB[k]
        if c2 < 48u8 { return 0u64 }
        if c2 > 57u8 { return 0u64 }
        v = (v * 10u64) + ((c2 - 48u8) as u64)
        ndg = ndg + 1u64
        if ndg > 6u64 { return 0u64 }
        k = k + 1u64
    }
    if ndg == 0u64 { return 0u64 }
    ZT_FPV = v
    if sp == 3u64 {
        if ZT_TB[0u64] == 115u8 { if ZT_TB[1u64] == 104u8 { if ZT_TB[2u64] == 114u8 { return 1u64 } } }
        if ZT_TB[0u64] == 109u8 { if ZT_TB[1u64] == 117u8 { if ZT_TB[2u64] == 108u8 { return 2u64 } } }
    }
    if sp == 4u64 {
        if ZT_TB[0u64] == 117u8 { if ZT_TB[1u64] == 109u8 { if ZT_TB[2u64] == 111u8 { if ZT_TB[3u64] == 100u8 { return 3u64 } } } }
        if ZT_TB[0u64] == 115u8 { if ZT_TB[1u64] == 100u8 { if ZT_TB[2u64] == 105u8 { if ZT_TB[3u64] == 118u8 { return 4u64 } } } }
    }
    if sp == 7u64 {
        if ZT_TB[0u64] == 101u8 { if ZT_TB[1u64] == 114u8 { if ZT_TB[2u64] == 97u8 { if ZT_TB[3u64] == 115u8 {
        if ZT_TB[4u64] == 117u8 { if ZT_TB[5u64] == 114u8 { if ZT_TB[6u64] == 101u8 { return 5u64 } } } } } } }
    }
    if sp == 5u64 {
        if ZT_TB[0u64] == 100u8 { if ZT_TB[1u64] == 101u8 { if ZT_TB[2u64] == 112u8 { if ZT_TB[3u64] == 116u8 {
        if ZT_TB[4u64] == 104u8 { return 6u64 } } } } }
    }
    return 0u64
}
fn zt_fam_img(kind: u64, v: u64) -> u64 {
    /* the COMPLETE w=8 image of the family, by noesis's meter */
    if kind == 1u64 { if v >= 8u64 { return ZT_SENT }   return no_meter(2u64, v) }
    if kind == 2u64 { return no_meter(0u64, v) }
    if kind == 3u64 { if v >= 8u64 { return ZT_SENT }   return no_meter(3u64, (1u64 << v) - 1u64) }
    if kind == 4u64 { if v == 0u64 { return ZT_SENT }   if v >= 8u64 { return ZT_SENT }   return no_meter(4u64, v) }
    if kind == 5u64 { if v > 8u64 { return ZT_SENT }   return 1u64 << (8u64 - v) }
    return ZT_SENT
}
fn zt_kl_bound(m: u64) -> u64 {
    /* klisi's OWN valuation of m: shift right until the inverse faculty
     * stops refusing -- the refusal boundary IS the organ's verdict */
    if m == 0u64 { return ZT_SENT }
    let mut x : u64 = m
    let mut k : u64 = 0u64
    let mut going : u64 = 1u64
    let mut r : u64 = ZT_SENT
    while going == 1u64 {
        if kl_inv2_u64(x) != 0u64 { r = k   going = 0u64 } else {
            if kl_err() != 2u64 { return ZT_SENT }
            kd_mode(0u64, 64u64)
            x = x >> 1u64
            k = k + 1u64
            if k > 63u64 { return ZT_SENT }
        }
    }
    return r
}
fn zt_log2(v: u64) -> u64 {
    if v == 0u64 { return ZT_SENT }
    let mut k : u64 = 0u64
    let mut x : u64 = v
    while (x & 1u64) == 0u64 { x = x >> 1u64   k = k + 1u64 }
    if x != 1u64 { return ZT_SENT }
    return k
}
fn zt_joint(m: u64, d: u64) -> u64 {
    /* TWO organs, one invariant: noesis's image and klisi's refusal boundary
     * must agree with EACH OTHER before either may speak about d */
    let img : u64 = no_meter(0u64, m)
    let lv : u64 = zt_log2(img)
    if lv == ZT_SENT { return ZT_ERR }
    let mv : u64 = 8u64 - lv
    let kv : u64 = zt_kl_bound(m)
    if kv == ZT_SENT { return ZT_ERR }
    if mv != kv { return ZT_ERR }
    if mv == d { return 1u64 }
    return 2u64
}
fn zt_decide(shape: u64, p: u64, q: u64) -> u64 {
    /* verdicts: 0 undecided | 1 true | 2 refuted | ZT_ERR broken machinery.
     * Order candidates are outside the meter (synesis 336: counted
     * undecidable); the joint lane covers (mul M, depth D) only. */
    if shape != 0u64 { return 0u64 }
    let fa : u64 = zt_famparse(p)
    let va : u64 = ZT_FPV
    let fb : u64 = zt_famparse(q)
    let vb : u64 = ZT_FPV
    if fa == 0u64 { return 0u64 }
    if fb == 0u64 { return 0u64 }
    if fa == 2u64 { if fb == 6u64 { return zt_joint(va, vb) } }
    if fb == 2u64 { if fa == 6u64 { return zt_joint(vb, va) } }
    if fa == 6u64 { return 0u64 }
    if fb == 6u64 { return 0u64 }
    let ia : u64 = zt_fam_img(fa, va)
    let ib : u64 = zt_fam_img(fb, vb)
    if ia == ZT_SENT { return 0u64 }
    if ib == ZT_SENT { return 0u64 }
    if ia == ib { return 1u64 }
    return 2u64
}
fn zt_decode(cid: u64) -> u64 {
    let mut left : u64 = cid / 3u64
    ZT_DS = cid % 3u64
    let mut p : u64 = 0u64
    let mut going : u64 = 1u64
    while going == 1u64 {
        let row : u64 = (ZT_NC - 1u64) - p
        if left < row { ZT_DP = p   ZT_DQ = (p + 1u64) + left   going = 0u64 } else {
            left = left - row
            p = p + 1u64
            if p >= ZT_NC { return 1u64 }
        }
    }
    return 0u64
}
fn zt_arm354() -> u64 {
    /* THE VERDICT: the chosen question through every standing decider; the
     * refutable tier answered NO with image witnesses; the best decidable
     * truth found */
    kd_setp(2u64)
    kd_mode(0u64, 64u64)
    if zt_convene() != 0u64 { return 354u64 }
    /* the chosen question is UNDECIDED -- machine-checked, not assumed:
     * neither side parses as a metered word, no lane claims it */
    if zt_decode(ZT_PICK) != 0u64 { return 354u64 }
    if zt_decide(ZT_DS, ZT_DP, ZT_DQ) != 0u64 { return 354u64 }
    ZT_UNDEC = 1u64
    ZT_DECN = 0u64
    ZT_REF = 0u64
    ZT_ANS = ZT_SENT
    let mut best : u64 = 0u64
    let mut i : u64 = 0u64
    while i < ZT_NCAND {
        if ZT_YLD[i] != ZT_SENT {
            if zt_decode(i) != 0u64 { return 354u64 }
            let vd : u64 = zt_decide(ZT_DS, ZT_DP, ZT_DQ)
            if vd == ZT_ERR { return 354u64 }
            if vd != 0u64 {
                ZT_DECN = ZT_DECN + 1u64
                if vd == 2u64 { ZT_REF = ZT_REF + 1u64 }
                if vd == 1u64 {
                    if ZT_ANS == ZT_SENT { ZT_ANS = i   best = ZT_YLD[i] } else {
                        if ZT_YLD[i] > best { ZT_ANS = i   best = ZT_YLD[i] }
                    }
                }
            }
        }
        i = i + 1u64
    }
    /* the tier is REAL: refutations with witnesses exist, and a truth
     * exists for the machine to speak */
    if ZT_REF < 2u64 { return 354u64 }
    if ZT_ANS == ZT_SENT { return 354u64 }
    if zt_decode(ZT_ANS) != 0u64 { return 354u64 }
    zt_cand_text(ZT_DS, ZT_DP, ZT_DQ)
    if ZT_CTN == 0u64 { return 354u64 }
    if ZT_CTN > 160u64 { return 354u64 }
    ZT_AQN = ZT_CTN
    let mut k : u64 = 0u64
    while k < ZT_CTN { ZT_AQ[k] = ZT_CT[k]   k = k + 1u64 }
    return 0u64
}
fn zt_event2_build() -> i32 {
    /* the ANSWER event: the episode remembered -- what was asked and could
     * not be decided, what was refuted, what was spoken, what it bought */
    let u : u64 = syn_union_addr()
    let hi : u64 = u / 1000000000u64
    let lo : u64 = u % 1000000000u64
    ZT_UNN = 0u64
    zt_nputs("[answered union " as u64)
    zt_nput_u64(hi)
    zt_nput(58u8)
    zt_nput_u64(lo)
    zt_nput(32u8)
    ZT_EVN = 0u64
    zt_lputs("[answered union " as u64)
    zt_lput_u64(hi)
    zt_lput(58u8)
    zt_lput_u64(lo)
    zt_lputs(" = answer scene] [" as u64)
    let mut k : u64 = 0u64
    while k < ZT_QN { zt_lput(ZT_Q[k])   k = k + 1u64 }
    zt_lputs(" = undecided question] [undecided question = missing decider] [" as u64)
    k = 0u64
    while k < ZT_AQN { zt_lput(ZT_AQ[k])   k = k + 1u64 }
    zt_lputs(" = spoken truth] [spoken truth = realized " as u64)
    zt_lput_u64(ZT_REALV)
    zt_lputs("] [refuted tier = witness count " as u64)
    zt_lput_u64(ZT_REF)
    zt_lputs("] [answer scene = grown frontier " as u64)
    zt_lput_u64(ZT_F2)
    zt_lputs("]" as u64)
    return 0i32
}
fn zt_arm355() -> u64 {
    /* THE SPOKEN ANSWER: the union grows by the decided truth, the mirror's
     * prophecy is REALIZED, and the episode is remembered */
    if zt_convene() != 0u64 { return 355u64 }
    if eol_read((&ZT_AQ) as u64, ZT_AQN) < 0i64 { return 355u64 }
    if eol_lawcheck() != 0u64 { return 355u64 }
    let ga : u64 = eol_addr()
    if ga == 0u64 { return 355u64 }
    if ga == syn_union_addr() { return 355u64 }
    ZT_F2 = zt_front_eol()
    if ZT_F2 > ZT_F0 { return 355u64 }
    ZT_REALV = ZT_F0 - ZT_F2
    if ZT_REALV != ZT_YLD[ZT_ANS] { return 355u64 }
    if ZT_REALV < 1u64 { return 355u64 }
    zt_event2_build()
    ZT_EP2 = zt_journal()
    if ZT_EP2 == 0u64 { return 355u64 }
    return 0u64
}
fn zt_selfprove() -> u64 @export {
    let a0 : u64 = zt_arm350()
    if a0 != 0u64 { return a0 }
    let a1 : u64 = zt_arm351()
    if a1 != 0u64 { return a1 }
    let a2 : u64 = zt_arm352()
    if a2 != 0u64 { return a2 }
    let a3 : u64 = zt_arm353()
    if a3 != 0u64 { return a3 }
    let a4 : u64 = zt_arm354()
    if a4 != 0u64 { return a4 }
    let a5 : u64 = zt_arm355()
    if a5 != 0u64 { return a5 }
    /* the prime returns to the tilt's home before the next organ speaks */
    kd_setp(5u64)
    return 0u64
}

/* ZETESIS: the machine now chooses its own next question by exact
 * derivation, knows what the thought will be worth before paying for it,
 * and remembers having asked in a memory that verifies itself.  What was
 * outside the organism is now an organ. */
