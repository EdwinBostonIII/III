/* STDLIB/iii/omnia/zonos_walk.iii -- ZONOS CARRIED THROUGH THE WALK: the width stays BOUNDED where the
 * naive interval EXPLODES.  (The Frontier-B claim, realized additively -- no touch to the sibling's walk.)
 *
 * The ANABASIS/SYNODOS walk carries a per-dim INTERVAL; its width grows layer over layer (2^-39 -> 2^-26
 * -> 2^-12 dense, then the MoE straddle) because CORRELATED error is charged as INDEPENDENT.  Here the SAME
 * hidden is carried as ZONOS affine forms through the SAME width-creating structure (a mixing matmul with
 * cancellation -- a centering / conservation step, present in every layer): the shared upstream uncertainty
 * CANCELS in ZONOS (its coefficient sums to ~0), so the ZONOS radius stays BOUNDED while the interval radius
 * grows geometrically.  Each step degrades to an interval via the hull (the seam), so exact ⊆ zonos ⊆ interval
 * every step.  This is the mechanism that keeps the deep walk decidable -- measured, both ways, side by side.
 *
 * NIH: composes zonos.iii (affine forms) + peras df (the interval radius).  Additive; the walk is untouched. */
module zonos_walk

extern @abi(c-msvc-x64) fn zn_reset() -> i32 from "zonos.iii"
extern @abi(c-msvc-x64) fn zn_center(f: u64, cs: i64, cm: u64, ce: i64) -> i32 from "zonos.iii"
extern @abi(c-msvc-x64) fn zn_push_ex(f: u64, id: u64, s: i64, m: u64, e: i64) -> i32 from "zonos.iii"
extern @abi(c-msvc-x64) fn zn_add(dst: u64, a: u64, b: u64) -> i32 from "zonos.iii"
extern @abi(c-msvc-x64) fn zn_scale(dst: u64, a: u64, ks: i64, km: u64, ke: i64) -> i32 from "zonos.iii"
extern @abi(c-msvc-x64) fn zn_copy(dst: u64, src: u64) -> i32 from "zonos.iii"
extern @abi(c-msvc-x64) fn zn_condense(dst: u64, a: u64, keep: u64) -> i32 from "zonos.iii"
extern @abi(c-msvc-x64) fn zn_add_noise(f: u64, rm: u64, re: i64) -> u64 from "zonos.iii"
extern @abi(c-msvc-x64) fn zn_rad_of(f: u64) -> i32 from "zonos.iii"
extern @abi(c-msvc-x64) fn zn_radm_v() -> u64 from "zonos.iii"
extern @abi(c-msvc-x64) fn zn_rade_v() -> i64 from "zonos.iii"
extern @abi(c-msvc-x64) fn pr_x_dfm() -> u64 from "peras.iii"
extern @abi(c-msvc-x64) fn pr_x_dfe() -> i64 from "peras.iii"
extern @abi(c-msvc-x64) fn pr_x_dfn2(hi: u64, lo: u64, eb: i64, up: u64) -> i32 from "peras.iii"
extern @abi(c-msvc-x64) fn pr_x_dfadd(ma: u64, ea: i64, mb: u64, eb: i64, up: u64) -> i32 from "peras.iii"
extern @abi(c-msvc-x64) fn pr_x_dfmul(ma: u64, ea: i64, mb: u64, eb: i64, up: u64) -> i32 from "peras.iii"
extern @abi(c-msvc-x64) fn pr_x_dfcmp(ma: u64, ea: i64, mb: u64, eb: i64) -> i64 from "peras.iii"

/* the mixing matrix W (4x4): sign, mantissa, exponent per entry.  Centering W = I - (1/4)J. */
var ZW_WS : [i64; 16]   var ZW_WM : [u64; 16]   var ZW_WE : [i64; 16]
/* per-dim interval radius (df magnitude) -- the naive walk's shadow */
var ZW_IVM : [u64; 4]   var ZW_IVE : [i64; 4]
var ZW_SHARED : u64 = 100u64                /* the shared upstream noise symbol */
var ZW_RESM : u64 = 1u64                     /* fresh transcendental residual per step: 2^-10 */
var ZW_RESE : i64 = 0i64 - 10i64
var ZW_ZM : u64 = 0u64   var ZW_ZE : i64 = 0i64   /* last max zonos radius */
var ZW_IM : u64 = 0u64   var ZW_IE : i64 = 0i64   /* last max interval radius */

fn zw_setw(i: u64, s: i64, m: u64, e: i64) -> i32 { if i >= 16u64 { return 1i32 }   ZW_WS[i] = s   ZW_WM[i] = m   ZW_WE[i] = e   return 0i32 }
/* the centering mixing: diagonal 3/4, off-diagonal -1/4 (shared noise coefficient sums to 0 -> cancels) */
fn zw_center_weights() -> i32 @export {
    let mut i : u64 = 0u64
    while i < 4u64 {
        let mut j : u64 = 0u64
        while j < 4u64 {
            if i == j { zw_setw(i * 4u64 + j, 1i64, 3u64, 0i64 - 2i64) }       /* +3/4 */
            if i != j { zw_setw(i * 4u64 + j, 0i64 - 1i64, 1u64, 0i64 - 2i64) } /* -1/4 */
            j = j + 1u64
        }
        i = i + 1u64
    }
    return 0i32
}
/* initialise: 4 dims, centers 1..4, each carrying the SAME shared noise (coeff 1) = correlated width 1. */
fn zw_init(shared: u64) -> i32 @export {
    zn_reset()
    let mut j : u64 = 0u64
    while j < 4u64 {
        zn_center(j, 1i64, j + 1u64, 0i64)
        if shared == 1u64 { zn_push_ex(j, ZW_SHARED, 1i64, 1u64, 0i64) }        /* correlated */
        if shared != 1u64 { zn_push_ex(j, 200u64 + j, 1i64, 1u64, 0i64) }       /* independent (negative arm) */
        ZW_IVM[j] = 1u64   ZW_IVE[j] = 0i64
        j = j + 1u64
    }
    return 0i32
}
/* one layer step: ZONOS matmul h'_i = Sum_j W_ij h_j (+ fresh residual, + condense); interval radius the
 * naive way: ivr'_i = Sum_j |W_ij| ivr_j (+ residual). */
fn zw_step() -> i32 @export {
    /* ZONOS: h'_i into forms 4..7 */
    let mut i : u64 = 0u64
    while i < 4u64 {
        zn_center(9u64, 0i64, 0u64, 0i64)                  /* acc = 0 */
        let mut j : u64 = 0u64
        while j < 4u64 {
            let idx : u64 = i * 4u64 + j
            zn_scale(8u64, j, ZW_WS[idx], ZW_WM[idx], ZW_WE[idx])   /* t = W_ij * h_j */
            zn_add(10u64, 9u64, 8u64)                       /* acc + t */
            zn_copy(9u64, 10u64)
            j = j + 1u64
        }
        zn_copy(4u64 + i, 9u64)
        i = i + 1u64
    }
    /* copy back, condense (bound the symbol count = the height reduction), add the fresh residual */
    i = 0u64
    while i < 4u64 {
        zn_condense(i, 4u64 + i, 3u64)
        zn_add_noise(i, ZW_RESM, ZW_RESE)
        i = i + 1u64
    }
    /* interval: ivr'_i = Sum_j |W_ij| ivr_j + residual (df, rounded up) */
    let mut ni_m : [u64; 4]
    let mut ni_e : [i64; 4]
    i = 0u64
    while i < 4u64 {
        let mut sm : u64 = 0u64
        let mut se : i64 = 0i64
        let mut has : u64 = 0u64
        let mut j : u64 = 0u64
        while j < 4u64 {
            let idx : u64 = i * 4u64 + j
            pr_x_dfmul(ZW_WM[idx], ZW_WE[idx], ZW_IVM[j], ZW_IVE[j], 1u64)      /* |W_ij| * ivr_j */
            let tm : u64 = pr_x_dfm()   let te : i64 = pr_x_dfe()
            if has == 1u64 { pr_x_dfadd(sm, se, tm, te, 1u64)   sm = pr_x_dfm()   se = pr_x_dfe() }
            if has == 0u64 { sm = tm   se = te   has = 1u64 }
            j = j + 1u64
        }
        pr_x_dfadd(sm, se, ZW_RESM, ZW_RESE, 1u64)          /* + residual */
        ni_m[i] = pr_x_dfm()   ni_e[i] = pr_x_dfe()
        i = i + 1u64
    }
    i = 0u64
    while i < 4u64 { ZW_IVM[i] = ni_m[i]   ZW_IVE[i] = ni_e[i]   i = i + 1u64 }
    return 0i32
}
/* the max ZONOS radius over the 4 dims (df) into ZW_ZM/ZW_ZE */
fn zw_zrad() -> i32 @export {
    let mut mm : u64 = 0u64   let mut me : i64 = 0i64
    let mut i : u64 = 0u64
    while i < 4u64 {
        zn_rad_of(i)
        let rm : u64 = zn_radm_v()   let re : i64 = zn_rade_v()
        if pr_x_dfcmp(rm, re, mm, me) > 0i64 { mm = rm   me = re }
        i = i + 1u64
    }
    ZW_ZM = mm   ZW_ZE = me   return 0i32
}
/* the max interval radius over the 4 dims (df) into ZW_IM/ZW_IE */
fn zw_irad() -> i32 @export {
    let mut mm : u64 = 0u64   let mut me : i64 = 0i64
    let mut i : u64 = 0u64
    while i < 4u64 {
        if pr_x_dfcmp(ZW_IVM[i], ZW_IVE[i], mm, me) > 0i64 { mm = ZW_IVM[i]   me = ZW_IVE[i] }
        i = i + 1u64
    }
    ZW_IM = mm   ZW_IE = me   return 0i32
}
fn zw_zm() -> u64 @export { return ZW_ZM }
fn zw_ze() -> i64 @export { return ZW_ZE }
fn zw_im() -> u64 @export { return ZW_IM }
fn zw_ie() -> i64 @export { return ZW_IE }

/* compare a df value (m,e) against a RAW literal (rm*2^re) -- df mantissas are normalized */
fn zw_cmp_raw(m: u64, e: i64, rm: u64, re: i64) -> i64 {
    pr_x_dfn2(0u64, rm, re, 0u64)
    return pr_x_dfcmp(m, e, pr_x_dfm(), pr_x_dfe())
}

/* ================= THE GATE: ZONOS bounded where the interval explodes ================= */
fn zw_selfprove() -> u64 @export {
    zw_center_weights()
    /* CORRELATED carry: 8 layer steps.  Interval radius must GROW past 1; ZONOS must stay BOUNDED (< 1). */
    zw_init(1u64)
    let mut s : u64 = 0u64
    while s < 8u64 {
        zw_step()
        /* CONTAINMENT (the seam): zonos radius <= interval radius at every step */
        zw_zrad()   zw_irad()
        if pr_x_dfcmp(ZW_ZM, ZW_ZE, ZW_IM, ZW_IE) > 0i64 { return 1u64 }
        s = s + 1u64
    }
    /* after 8 steps: interval EXPLODED (radius > 4), ZONOS BOUNDED (radius < 1) */
    zw_irad()
    if zw_cmp_raw(ZW_IM, ZW_IE, 4u64, 0i64) < 0i64 { return 2u64 }      /* interval must exceed 4 (RED: explosion) */
    zw_zrad()
    if zw_cmp_raw(ZW_ZM, ZW_ZE, 1u64, 0i64) > 0i64 { return 3u64 }      /* ZONOS must stay under 1 (GREEN: bounded) */

    /* NEGATIVE (no false win): with INDEPENDENT initial noise, the shared cancellation does NOT apply, so
     * ZONOS stays COMPARABLE to the interval (>= interval/4) -- the win comes from real correlation, not the code. */
    zw_init(0u64)
    zw_step()
    zw_zrad()   zw_irad()
    pr_x_dfn2(0u64, 1u64, 0i64 - 2i64, 0u64)                            /* normalize 1/4 */
    let qm : u64 = pr_x_dfm()   let qe : i64 = pr_x_dfe()
    pr_x_dfmul(ZW_IM, ZW_IE, qm, qe, 0u64)                              /* interval/4 */
    if pr_x_dfcmp(ZW_ZM, ZW_ZE, pr_x_dfm(), pr_x_dfe()) < 0i64 { return 4u64 }
    return 0u64
}
