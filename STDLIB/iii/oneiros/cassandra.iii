/* STDLIB/iii/oneiros/cassandra.iii -- THERMODYNAMIC BRANCH PREDICTION by
 * least-action epistemic superposition, WITHOUT forking the universe.
 *
 * THE STATE-EXPLOSION PROBLEM (why naive superposition is theater): to hold N
 * divergent futures you would fork N copies of the whole engine state -- and a
 * chain of ambiguities multiplies to 2^depth copies.  Exponential.  Unshippable.
 *
 * THE SCHRODINGER'S-COLORS SOLUTION (the aether_lens principle: the value is
 * DERIVED from the geometry at observation, never STORED per outcome): do not
 * duplicate the universe.  Hold ONE accumulator (the shared pre-admix state) and
 * a set of orthogonal COLOR tags -- each color a candidate reversible action
 * (bit-flip delta).  The colors are kept GF(2)-INDEPENDENT, so a set of K of
 * them SPANS 2^K distinct timelines -- yet only K words are stored, and EACH
 * timeline's state is DERIVED on demand as admix(acc ^ XOR-of-a-color-subset),
 * never materialized.  Orthogonality is the anti-explosion bound: a u64 carries
 * at most 64 independent directions, so the window is HARD-CAPPED at 64 -- a
 * dependent or 65th color is REFUSED, counted, never silently dropped.
 *
 * THE COLLAPSE (the thermodynamic filter, no rewind): when the true pulse is
 * OBSERVED, III solves which color-subset it is (a GF(2) linear solve over the
 * stored colors) -- that timeline SURVIVES, every other color ANNIHILATES.
 * Because no timeline was ever committed to the real stream (they were only
 * ever DERIVED), there is NOTHING TO REWIND: the false futures simply cease to
 * be.  This is strictly cheaper than the Lagrangian coupling's provisional-
 * commit-then-reverse (aether/lagrangian): cassandra never pays a reversal.
 *
 * THE PROVISIONAL TRUTH (Principle of Least Action): to keep the pipeline full
 * before observation, III speculates on the LEAST-ACTION color -- minimum
 * popcount = minimum bits flipped = minimum Landauer energy -- derived, not
 * committed.  If observation confirms it, the speculation was free; if not, it
 * annihilates with the other false colors at zero rewind cost.
 *
 * NIH: composes aether/lagrangian (the reversible engine: lg_apply/lg_action) +
 * aether/admix (the proven bijection).  Its truth is a CONDITION OF ITS MOTION:
 * cass_selfproof re-proves colors-are-orthogonal, 2^K-derivation, least-action,
 * and no-rewind collapse every time it is asked to predict.  Hexad: kind_mobius.
 * Ring R0. */
module oneiros_cassandra

extern @abi(c-msvc-x64) fn adx_init() -> u32 from "admix.iii"
extern @abi(c-msvc-x64) fn adx_ready() -> u8 from "admix.iii"
extern @abi(c-msvc-x64) fn admix(x: u64) -> u64 from "admix.iii"
extern @abi(c-msvc-x64) fn lg_apply(state: u64, d: u64) -> u64 from "lagrangian.iii"
extern @abi(c-msvc-x64) fn lg_action(d: u64) -> u64 from "lagrangian.iii"
extern @abi(c-msvc-x64) fn lg_noise(seed: u64, i: u64) -> u64 from "lagrangian.iii"

const CASS_MAX : u64 = 64u64             /* the orthogonality ceiling = u64 dimension */

var CASS_ACC   : u64 = 0u64              /* the shared pre-admix accumulator          */
var CASS_COLOR : [u64; 64]               /* the independent color set (a GF(2) basis) */
var CASS_NC    : u64 = 0u64
var CASS_REFUSED_DEP : u64 = 0u64        /* dependent colors refused (counted)        */
var CASS_REFUSED_FULL : u64 = 0u64       /* colors past the 64-dim ceiling (counted)  */
var CASS_ANNIHILATED : u64 = 0u64        /* false timelines annihilated at collapse   */
var CASS_REWINDS : u64 = 0u64            /* MUST stay 0 -- derive-don't-store pays none */

fn cass_reset(acc: u64) -> i32 @export {
    CASS_ACC = acc
    CASS_NC = 0u64
    CASS_REFUSED_DEP = 0u64
    CASS_REFUSED_FULL = 0u64
    CASS_ANNIHILATED = 0u64
    CASS_REWINDS = 0u64
    return 0i32
}
/* reduce v against the current color basis (each color used as a pivot on its
 * highest set bit); returns the residue (0 iff v is in the span) */
fn cass_reduce(v: u64) -> u64 {
    let mut r : u64 = v
    let mut i : u64 = 0u64
    while i < CASS_NC {
        let c : u64 = CASS_COLOR[i]
        /* pivot bit = highest set bit of c */
        let mut hb : u64 = 63u64
        let mut found : u64 = 0u64
        let mut b : u64 = 64u64
        while b > 0u64 {
            b = b - 1u64
            if found == 0u64 { if ((c >> b) & 1u64) == 1u64 { hb = b   found = 1u64 } }
        }
        if ((r >> hb) & 1u64) == 1u64 { r = r ^ c }
        i = i + 1u64
    }
    return r
}
/* admit a candidate timeline as an orthogonal color; the basis is kept in
 * row-echelon form (each new color reduced, then used to clear that pivot from
 * earlier colors so the basis stays reduced -- makes the collapse solve exact).
 * 1 admitted | 0 refused (dependent or ceiling). */
fn cass_add_color(delta: u64) -> u64 @export {
    if CASS_NC >= CASS_MAX { CASS_REFUSED_FULL = CASS_REFUSED_FULL + 1u64   return 0u64 }
    let red : u64 = cass_reduce(delta)
    if red == 0u64 { CASS_REFUSED_DEP = CASS_REFUSED_DEP + 1u64   return 0u64 }
    /* back-reduce existing colors by `red` on red's pivot, keep reduced form */
    let mut hb : u64 = 0u64
    let mut found : u64 = 0u64
    let mut b : u64 = 64u64
    while b > 0u64 {
        b = b - 1u64
        if found == 0u64 { if ((red >> b) & 1u64) == 1u64 { hb = b   found = 1u64 } }
    }
    let mut i : u64 = 0u64
    while i < CASS_NC {
        if ((CASS_COLOR[i] >> hb) & 1u64) == 1u64 { CASS_COLOR[i] = CASS_COLOR[i] ^ red }
        i = i + 1u64
    }
    CASS_COLOR[CASS_NC] = red
    CASS_NC = CASS_NC + 1u64
    return 1u64
}
fn cass_count() -> u64 @export { return CASS_NC }
fn cass_refused_dep() -> u64 @export { return CASS_REFUSED_DEP }
fn cass_refused_full() -> u64 @export { return CASS_REFUSED_FULL }
fn cass_annihilated() -> u64 @export { return CASS_ANNIHILATED }
fn cass_rewinds() -> u64 @export { return CASS_REWINDS }

/* the XOR-combination of the colors selected by `mask` (bit j -> color j) */
fn cass_combo(mask: u64) -> u64 @export {
    let mut acc : u64 = 0u64
    let mut j : u64 = 0u64
    while j < CASS_NC {
        if ((mask >> j) & 1u64) == 1u64 { acc = acc ^ CASS_COLOR[j] }
        j = j + 1u64
    }
    return acc
}
/* DERIVE the timeline selected by `mask` -- admix(acc ^ combo), on demand, never
 * stored.  2^CASS_NC distinct timelines are reachable from CASS_NC stored words. */
fn cass_derive(mask: u64) -> u64 @export {
    return admix(CASS_ACC ^ cass_combo(mask))
}
/* the least-action provisional truth: the single color (mask with one bit) of
 * minimum popcount -- least bits flipped, least Landauer energy.  Returns the
 * color index (or CASS_NC if empty). */
fn cass_least_action() -> u64 @export {
    if CASS_NC == 0u64 { return 0u64 }
    let mut best : u64 = 0u64
    let mut bestc : u64 = lg_action(CASS_COLOR[0u64])
    let mut i : u64 = 1u64
    while i < CASS_NC {
        let c : u64 = lg_action(CASS_COLOR[i])
        if c < bestc { bestc = c   best = i }
        i = i + 1u64
    }
    return best
}
/* solve which color-subset XORs to `target`; returns the mask, or the sentinel
 * (all ones) if target is OUTSIDE the span (an unforeseen observation).  Because
 * the basis is in reduced echelon form, greedily clearing each pivot recovers
 * the exact mask. */
const CASS_SENT : u64 = 18446744073709551615u64
fn cass_solve(target: u64) -> u64 @export {
    let mut r : u64 = target
    let mut mask : u64 = 0u64
    let mut i : u64 = 0u64
    while i < CASS_NC {
        let c : u64 = CASS_COLOR[i]
        let mut hb : u64 = 0u64
        let mut found : u64 = 0u64
        let mut b : u64 = 64u64
        while b > 0u64 {
            b = b - 1u64
            if found == 0u64 { if ((c >> b) & 1u64) == 1u64 { hb = b   found = 1u64 } }
        }
        if ((r >> hb) & 1u64) == 1u64 { r = r ^ c   mask = mask | (1u64 << i) }
        i = i + 1u64
    }
    if r != 0u64 { return CASS_SENT }
    return mask
}
/* THE COLLAPSE (thermodynamic filter): observe the true pulse; the timeline it
 * selects survives, every other color annihilates.  Returns the collapsed state
 * = admix(acc ^ true_delta) if the observation is in span, else CASS_SENT (an
 * unforeseen future -- honestly refused, not hallucinated).  No rewind: nothing
 * was committed, so the false futures cost nothing to discard. */
fn cass_observe(true_delta: u64) -> u64 @export {
    let mask : u64 = cass_solve(true_delta)
    if mask == CASS_SENT { return CASS_SENT }
    /* the surviving timeline; all other reachable timelines annihilate */
    let mut survivors : u64 = 1u64
    let total : u64 = 1u64 << CASS_NC
    CASS_ANNIHILATED = CASS_ANNIHILATED + (total - survivors)
    let collapsed : u64 = cass_derive(mask)
    /* the accumulator advances to the observed reality (the chain continues) */
    CASS_ACC = CASS_ACC ^ true_delta
    CASS_NC = 0u64                      /* colors consumed; the superposition is spent */
    return collapsed
}

/* ==================== THE SELF-PROOF ====================
 * Re-proven as a condition of predicting.  0 = proven.
 *   10 not-ready  11 colors-not-orthogonal  12 derivation-not-2^K-distinct
 *   13 least-action-wrong  14 collapse-inexact  15 rewind-paid (must be 0)
 *   16 ceiling-not-enforced  17 out-of-span-not-refused */
var CASS_SEEN : [u8; 256]
fn cass_selfproof() -> u64 @export {
    if adx_ready() == 0u8 { adx_init() }
    if adx_ready() == 0u8 { return 10u64 }
    /* build 3 independent colors -> 2^3 = 8 timelines */
    cass_reset(0x9E3779B97F4A7C15u64)
    if cass_add_color(0x1u64) != 1u64 { return 11u64 }
    if cass_add_color(0x2u64) != 1u64 { return 11u64 }
    if cass_add_color(0x4u64) != 1u64 { return 11u64 }
    /* arm 11: a DEPENDENT color (0x3 = 0x1 ^ 0x2) is refused */
    if cass_add_color(0x3u64) != 0u64 { return 11u64 }
    if cass_refused_dep() != 1u64 { return 11u64 }
    if cass_count() != 3u64 { return 11u64 }
    /* arm 12: all 2^3 derived timelines are DISTINCT (genuine superposition) */
    let mut m : u64 = 0u64
    while m < 256u64 { CASS_SEEN[m] = 0u8   m = m + 1u64 }
    m = 0u64
    while m < 8u64 {
        let s : u64 = cass_derive(m)
        let h : u64 = s & 255u64
        /* collision on the low byte is possible but the FULL states must differ;
         * check pairwise fully for the 8 */
        let mut n : u64 = 0u64
        while n < m {
            if cass_derive(n) == s { return 12u64 }
            n = n + 1u64
        }
        m = m + 1u64
    }
    /* arm 13: least-action picks the min-popcount color.  0x1,0x2,0x4 all weight
     * 1; add a heavier decoy and a lighter... all are weight 1 here, so add a
     * fresh set to test ordering */
    cass_reset(0xABCDu64)
    cass_add_color(0xF0u64)              /* weight 4 */
    cass_add_color(0x8u64)               /* weight 1 -- the least action */
    cass_add_color(0xC00u64)             /* weight 2 */
    if cass_least_action() != 1u64 { return 13u64 }
    /* arm 14+15: collapse is exact and pays NO rewind.  Observe a true pulse that
     * is the XOR of colors 0 and 2 (0xF0 ^ 0xC00 = 0xCF0). */
    let target : u64 = 0xF0u64 ^ 0xC00u64
    let want : u64 = cass_derive(cass_solve(target))
    let got : u64 = cass_observe(target)
    if got != want { return 14u64 }
    if cass_rewinds() != 0u64 { return 15u64 }
    /* arm 17: an OUT-OF-SPAN observation is refused, not hallucinated */
    cass_reset(0x1234u64)
    cass_add_color(0x1u64)
    cass_add_color(0x2u64)
    if cass_observe(0x8u64) != CASS_SENT { return 17u64 }
    /* arm 16: the 64-dim ceiling is enforced -- a 65th independent color refused */
    cass_reset(0x55u64)
    let mut k : u64 = 0u64
    while k < 64u64 { cass_add_color(1u64 << k)   k = k + 1u64 }
    if cass_count() != 64u64 { return 16u64 }
    if cass_add_color(0x123456789ABCDEFu64) != 0u64 { return 16u64 }   /* would be 65th */
    if cass_refused_full() != 1u64 { return 16u64 }
    return 0u64
}
fn cass_selfproof_ok() -> u8 @export {
    if cass_selfproof() == 0u64 { return 1u8 }
    return 0u8
}
