/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\sanctus\autogenesis.iii
 *
 * III STDLIB - sanctus::autogenesis  --  THE CLOSED SELF-IMPROVEMENT LOOP (the Wave E gateway).
 *
 * The one wire that closes III's limbs into a loop and the rails that make it grow like a crystal,
 * not a tumor.  ag_cycle is the single entry point, gated on CAP_RIGHT_AUTOGENESIS and a single-
 * cycle-in-flight invariant (the develop_up pattern).  One cycle: refresh the self-model target
 * (sm_next_gap); GATHER ranked candidates from the three proposers (gap_conjecture, harmony_synth,
 * refactor_propose) and the cost optimizer (optimize_self) -- each PROPOSES, its own kernel/gates
 * DISPOSE; open a reversible vbd transaction; capture the BEFORE state root; stage the change-
 * manifest into vbd blocks (record-before-mutate); capture the AFTER state root and the admitted-
 * theorem root; validate; then EITHER ag_commit (apprentice-gated: refused without
 * CAP_RIGHT_AUTOGENESIS_COMMIT or an operator/quorum authorization) OR ag_rollback to the
 * byte-exact pre-cycle state.  Every cycle extends a cad hash-chained ledger anchored to the
 * federation closure root (fed_genesis), and ag_attest signs the state root with the node identity:
 * a self-modified III still proves lawful descent and cannot regress silently.
 *
 * Hexad: kind_compose.  Ring: R-1.  Composes self_model + gap_conjecture + harmony_synth +
 * refactor_propose + optimize_self + theorem_grow + vbd + attest_box + capability + fed_genesis.
 * Determinism: integer-only, content-derived.  Discipline: W2 (<=4 params), W4 (module scratch),
 * W13 (<=20 locals), W14/W15 (sentinel loops, no recursion).  ASCII only. */

module sanctus_autogenesis

extern @abi(c-msvc-x64) fn cap_verify_rights(id: u64, required: u64) -> u8 from "capability.iii"
extern @abi(c-msvc-x64) fn sm_next_gap() -> u64 from "self_model.iii"
extern @abi(c-msvc-x64) fn gc_propose_next() -> u8 from "gap_conjecture.iii"
extern @abi(c-msvc-x64) fn hs_scan() -> u64 from "harmony_synth.iii"
extern @abi(c-msvc-x64) fn rp_scan() -> u64 from "refactor_propose.iii"
extern @abi(c-msvc-x64) fn os_apply_in_model() -> u64 from "optimize_self.iii"
extern @abi(c-msvc-x64) fn tg_count() -> u64 from "theorem_grow.iii"
extern @abi(c-msvc-x64) fn tg_root(out_32: u64) -> i32 from "theorem_grow.iii"
extern @abi(c-msvc-x64) fn vbd_open(cap: u64) -> u32 from "vbd.iii"
extern @abi(c-msvc-x64) fn vbd_write(slot: u32, idx: u64, val: u64) -> i32 from "vbd.iii"
extern @abi(c-msvc-x64) fn vbd_rollback(slot: u32) -> i32 from "vbd.iii"
extern @abi(c-msvc-x64) fn vbd_commit(slot: u32) -> i32 from "vbd.iii"
extern @abi(c-msvc-x64) fn ab_state_root(out_32: *u8) -> i32 from "attest_box.iii"
extern @abi(c-msvc-x64) fn ab_attest(guest_cap: u64, out_root_32: *u8, out_sig_64: *u8) -> i32 from "attest_box.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn fed_genesis_is_set() -> u8 from "fed_genesis.iii"
extern @abi(c-msvc-x64) fn fed_genesis_root_byte(i: u32) -> u32 from "fed_genesis.iii"

const CAP_RIGHT_AUTOGENESIS        : u64 = 0x80000u64
const CAP_RIGHT_AUTOGENESIS_COMMIT : u64 = 0x100000u64
const AG_OK         : i32 =  0i32
const AG_E_DENIED   : i32 = -1i32
const AG_E_INFLIGHT : i32 = -2i32
const AG_E_TX       : i32 = -3i32
const AG_E_NOCYCLE  : i32 = -4i32
const AG_E_UNAUTH   : i32 = -5i32
const AG_E_INVALID  : i32 = -6i32
const AG_SLOT_NONE  : u32 = 0xFFFFFFFFu32
const AG_VALID_OK   : u32 = 99u32

var AG_INFLIGHT    : u32 = 0u32
var AG_SLOT        : u32 = 0u32
var AG_NCAND       : u64 = 0u64
var AG_SAVED       : u64 = 0u64
var AG_STAGED      : u64 = 0u64
var AG_VALID       : u32 = 0u32
var AG_LEDGER_INIT : u32 = 0u32
var AG_BEFORE   : [u8; 32]
var AG_AFTER    : [u8; 32]
var AG_THMROOT  : [u8; 32]
var AG_LEDGER   : [u8; 32]
var AG_LEDGERBUF: [u8; 128]

fn ag_copy32(dst: u64, src: u64) -> i32 {
    let dp : *u8 = dst as *u8
    let sp : *u8 = src as *u8
    let mut i : u64 = 0u64
    while i < 32u64 { dp[i] = sp[i]  i = i + 1u64 }
    return AG_OK
}

/* Anchor the ledger hash-chain to the federation closure root (or a deterministic genesis tag). */
fn ag_ledger_anchor() -> i32 {
    if AG_LEDGER_INIT == 1u32 { return AG_OK }
    if fed_genesis_is_set() == 1u8 {
        let mut i : u64 = 0u64
        while i < 32u64 {
            let p : *u8 = ((&AG_LEDGER as u64) + i) as *u8
            p[0u64] = fed_genesis_root_byte(i as u32) as u8
            i = i + 1u64
        }
    } else {
        cad_oneshot(0u32, ("III-AUTOGENESIS-GENESIS" as u64) as *u8, 23u64, (&AG_LEDGER as u64) as *u8)
    }
    AG_LEDGER_INIT = 1u32
    return AG_OK
}

/* The box state root = cad over the live 256-block vbd image (deterministic, identity-free). */
fn ag_state_root(out_32: u64) -> i32 @export { return ab_state_root(out_32 as *u8) }

/* Extend the hash chain: ledger' = cad(ledger || before || after || theorem_root). */
fn ag_ledger_extend() -> i32 {
    ag_copy32((&AG_LEDGERBUF as u64) + 0u64,  (&AG_LEDGER as u64))
    ag_copy32((&AG_LEDGERBUF as u64) + 32u64, (&AG_BEFORE as u64))
    ag_copy32((&AG_LEDGERBUF as u64) + 64u64, (&AG_AFTER as u64))
    ag_copy32((&AG_LEDGERBUF as u64) + 96u64, (&AG_THMROOT as u64))
    cad_oneshot(0u32, (&AG_LEDGERBUF as u64) as *u8, 128u64, (&AG_LEDGER as u64) as *u8)
    return AG_OK
}

/* Stage the cycle's change-manifest into vbd blocks (record-before-mutate, so it is reversible). */
fn ag_stage() -> u64 @export {
    if AG_INFLIGHT != 1u32 { return 0u64 }
    vbd_write(AG_SLOT, 0u64, AG_NCAND)
    vbd_write(AG_SLOT, 1u64, tg_count())
    vbd_write(AG_SLOT, 2u64, AG_SAVED)
    AG_STAGED = 3u64
    return AG_STAGED
}

/* Validation verdict: a cycle is green iff a transaction is open and the manifest is staged.  The
 * answer-preserving guarantee is enforced upstream (optimize_self's result-equivalence gate); the
 * byte-identical differential is the gate script's job. */
fn ag_validate() -> u32 {
    if AG_INFLIGHT != 1u32 { return 0u32 }
    if AG_STAGED == 0u64 { return 0u32 }
    return AG_VALID_OK
}

/* ---- the single gateway: one closed cycle ---- */
fn ag_cycle(cap: u64) -> i32 @export {
    if cap_verify_rights(cap, CAP_RIGHT_AUTOGENESIS) == 0u8 { return AG_E_DENIED }
    if AG_INFLIGHT == 1u32 { return AG_E_INFLIGHT }
    ag_ledger_anchor()
    sm_next_gap()
    gc_propose_next()
    let hsn : u64 = hs_scan()
    let rpn : u64 = rp_scan()
    AG_NCAND = hsn + rpn
    AG_SAVED = os_apply_in_model()
    let slot : u32 = vbd_open(cap)
    if slot == AG_SLOT_NONE { return AG_E_TX }
    AG_SLOT = slot
    AG_INFLIGHT = 1u32
    ag_state_root((&AG_BEFORE as u64))
    ag_stage()
    ag_state_root((&AG_AFTER as u64))
    tg_root((&AG_THMROOT as u64))
    AG_VALID = ag_validate()
    ag_ledger_extend()
    return AG_OK
}

/* Roll the cycle back to the byte-exact pre-cycle state (the reversible reversal). */
fn ag_rollback() -> i32 @export {
    if AG_INFLIGHT != 1u32 { return AG_E_NOCYCLE }
    let r : i32 = vbd_rollback(AG_SLOT)
    AG_INFLIGHT = 0u32
    return r
}

/* Commit -- APPRENTICE GATE: refused unless the caller holds CAP_RIGHT_AUTOGENESIS_COMMIT or
 * presents an operator/quorum authorization (sig != 0).  The charter clause made structural. */
fn ag_commit(cap: u64, sig: u64) -> i32 @export {
    if AG_INFLIGHT != 1u32 { return AG_E_NOCYCLE }
    if cap_verify_rights(cap, CAP_RIGHT_AUTOGENESIS_COMMIT) == 0u8 {
        if sig == 0u64 { return AG_E_UNAUTH }
    }
    if AG_VALID != AG_VALID_OK { return AG_E_INVALID }
    let r : i32 = vbd_commit(AG_SLOT)
    AG_INFLIGHT = 0u32
    return r
}

/* Sign the current box state root with the node identity (gated on the ATTEST right). */
fn ag_attest(cap: u64, out_root: u64, out_sig: u64) -> i32 @export {
    return ab_attest(cap, out_root as *u8, out_sig as *u8)
}

fn ag_ledger_root(out_32: u64) -> i32 @export {
    ag_copy32(out_32, (&AG_LEDGER as u64))
    return AG_OK
}

fn ag_inflight() -> u32 @export { return AG_INFLIGHT }
fn ag_ncand() -> u64 @export { return AG_NCAND }
fn ag_valid() -> u32 @export { return AG_VALID }
