/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\sanctus\calculus_v1.iii
 *
 * III SANCTUS - sanctus::calculus_v1
 *
 * THE INTENT CALCULUS, v1.0 -- the sealed 19-primitive specification.
 *
 * This module supersedes FROZEN SPEC III-RES-FROZEN-001 (which declared
 * "the III resolution primitive admits no patterns post-boot" and froze
 * the 67 boot patterns). The Intent Calculus v1.0 reframes the system
 * around 19 derived irreducible primitives, sanctions sealed evolution
 * via omnia/governance.iii, and binds the substrate to a single
 * machine-checkable identity.
 *
 * The 19 primitives:
 *
 *   Hexad    (1-7):   form bind convey mean act compose seal
 *   Meta     (8-11):  prove query grant govern
 *   Compose  (12-15): then with under if
 *   Special  (16-18): loop lift reflect
 *   IDSG     (19):    abstract            (Intent Geometry generaliser)
 *
 * Each primitive is irreducible against the other 18 (proven in
 * sanctus/irreducibility_proof.iii). Each is necessary -- at least one
 * intent in the existing 67 boot patterns requires it. Together they
 * span the full taxonomy.
 *
 * Hexad: kind_origin (Crown). Ring: R0. K: 1.00.
 *
 * No FP. No telemetry. No mutation post-init. The metadata tables are
 * write-once (BSS initialised by calculus_init() at first call; the
 * CALCULUS_INIT flag prevents re-initialisation).
 */

module sanctus_calculus_v1

extern @abi(c-msvc-x64) fn mhash_begin() -> i32 from "mhash.iii"
extern @abi(c-msvc-x64) fn mhash_domain(d: u64, dl: u64) -> i32 from "mhash.iii"
extern @abi(c-msvc-x64) fn mhash_payload(p: u64, pl: u64) -> i32 from "mhash.iii"
extern @abi(c-msvc-x64) fn mhash_final(out: u64) -> i32 from "mhash.iii"
extern @abi(c-msvc-x64) fn intent_verify(p: u64) -> u8 from "intent.iii"
extern @abi(c-msvc-x64) fn intent_goal_kind(p: u64) -> u8 from "intent.iii"

/* -------------------------------------------------------------- */
/* Public surface                                                  */
/* -------------------------------------------------------------- */

const CALCULUS_VERSION_MAJOR  : u32 = 1u32
const CALCULUS_VERSION_MINOR  : u32 = 0u32
const CALCULUS_PRIMITIVE_COUNT : u32 = 19u32

const CALCULUS_OK             : i32 =  0i32
const CALCULUS_E_BAD_PID      : i32 = -1i32
const CALCULUS_E_NOT_INITED   : i32 = -2i32
const CALCULUS_E_BAD_INTENT   : i32 = -3i32

/* Hexad ids (must match verba/intent.iii INTENT_HEXAD_*). */
const CALC_HEXAD_FORM       : u8 = 1u8
const CALC_HEXAD_SUBSTANCE  : u8 = 2u8
const CALC_HEXAD_PASSAGE    : u8 = 3u8
const CALC_HEXAD_ESSENCE    : u8 = 4u8
const CALC_HEXAD_MOTION     : u8 = 5u8
const CALC_HEXAD_COMPOSE    : u8 = 6u8
const CALC_HEXAD_ORIGIN     : u8 = 7u8

/* Domain bytes (16) for the calculus root mhash. */
var CALC_DOM_ROOT : [u8; 16] = [73u8, 73u8, 73u8, 95u8, 67u8, 65u8, 76u8, 67u8, 95u8, 86u8, 49u8, 95u8, 82u8, 79u8, 79u8, 84u8]
/* "III_CALC_V1_ROOT" */

/* -------------------------------------------------------------- */
/* Per-primitive metadata tables (BSS)                             */
/*                                                                 */
/* Indexed by (primitive_id - 1), so slot 0 is PRIMITIVE_FORM (=1).*/
/* -------------------------------------------------------------- */

var CALC_HEXAD     : [u8;  19]
var CALC_K_COST    : [u64; 19]
var CALC_ARG_MASK  : [u64; 19]
var CALC_RING_MIN  : [u8;  19]
var CALC_INIT      : u8 = 0u8
var CALC_ROOT_MHASH : [u8; 32]

/* Fill table -- called once by calculus_init().  Internal 5-arg helper.
 * The copy-each-param-to-a-local idiom below was the iiis-0 single-use
 * parameter-spill workaround (Win64 register args not spilled when used
 * once); that bug is fixed -- Stage 3.9, corpus 277 (the prologue now
 * unconditionally spills all params) -- so the copies are redundant though
 * harmless and are left in place (Mandate 20: do not churn working code). */
fn _calc_set(idx: u32, hexad: u8, k_cost: u64, arg_mask: u64, ring_min: u8) -> i32 {
    let l_idx     : u32 = idx
    let l_hexad   : u8  = hexad
    let l_k       : u64 = k_cost
    let l_mask    : u64 = arg_mask
    let l_ring    : u8  = ring_min
    CALC_HEXAD[l_idx]    = l_hexad
    CALC_K_COST[l_idx]   = l_k
    CALC_ARG_MASK[l_idx] = l_mask
    CALC_RING_MIN[l_idx] = l_ring
    return CALCULUS_OK
}

/* Compute and store CALC_ROOT_MHASH = SHA-256("III_CALC_V1_ROOT" ||
 * count_le4 || hexad[0..19] || k_cost[0..19]_le8 || arg_mask[0..19]_le8 ||
 * ring_min[0..19]).
 * Deterministic -- same primitive metadata always produces the same root. */
var CALC_ROOT_BUF4 : [u8; 4]
var CALC_ROOT_BUF8 : [u8; 8]

fn _calc_compute_root() -> i32 {
    mhash_begin()
    mhash_domain((&CALC_DOM_ROOT) as u64, 16u64)
    /* Count */
    let cnt : u32 = CALCULUS_PRIMITIVE_COUNT
    CALC_ROOT_BUF4[0] = (cnt & 0xFFu32) as u8
    CALC_ROOT_BUF4[1] = ((cnt >> 8u32) & 0xFFu32) as u8
    CALC_ROOT_BUF4[2] = ((cnt >> 16u32) & 0xFFu32) as u8
    CALC_ROOT_BUF4[3] = ((cnt >> 24u32) & 0xFFu32) as u8
    mhash_payload((&CALC_ROOT_BUF4) as u64, 4u64)
    /* Hexad bytes (19) */
    mhash_payload((&CALC_HEXAD) as u64, 19u64)
    /* K-cost u64 LE (18 * 8 = 144 bytes) */
    let mut i : u32 = 0u32
    while i < CALCULUS_PRIMITIVE_COUNT {
        let k : u64 = CALC_K_COST[i]
        let mut b : u32 = 0u32
        while b < 8u32 {
            CALC_ROOT_BUF8[b] = ((k >> ((b & 0x7u32) * 8u32)) & 0xFFu64) as u8
            b = b + 1u32
        }
        mhash_payload((&CALC_ROOT_BUF8) as u64, 8u64)
        i = i + 1u32
    }
    /* arg_mask u64 LE (144 bytes) */
    i = 0u32
    while i < CALCULUS_PRIMITIVE_COUNT {
        let m : u64 = CALC_ARG_MASK[i]
        let mut b : u32 = 0u32
        while b < 8u32 {
            CALC_ROOT_BUF8[b] = ((m >> ((b & 0x7u32) * 8u32)) & 0xFFu64) as u8
            b = b + 1u32
        }
        mhash_payload((&CALC_ROOT_BUF8) as u64, 8u64)
        i = i + 1u32
    }
    /* ring_min bytes (19) */
    mhash_payload((&CALC_RING_MIN) as u64, 19u64)
    mhash_final((&CALC_ROOT_MHASH) as u64)
    return CALCULUS_OK
}

/* -------------------------------------------------------------- */
/* calculus_init() -- one-shot population of the metadata tables. */
/*                                                                 */
/* Idempotent: subsequent calls are no-ops. Called from           */
/* omnia/resolution_init.iii at boot.                              */
/* -------------------------------------------------------------- */

fn calculus_init() -> i32 @export {
    if CALC_INIT == 1u8 { return CALCULUS_OK }
    /* Hexad-7 primitives (1..7) */
    /* p001 form     -- HEXAD_FORM      K=0.98 args(form_id) ring R0 */
    _calc_set(0u32,  CALC_HEXAD_FORM,      980000000u64, 0x1u64, 2u8)
    /* p002 bind     -- HEXAD_SUBSTANCE  K=0.95 args(arena, size)    R0 */
    _calc_set(1u32,  CALC_HEXAD_SUBSTANCE, 950000000u64, 0x3u64, 2u8)
    /* p003 convey   -- HEXAD_PASSAGE    K=0.90 args(src, dst, len)  R0 */
    _calc_set(2u32,  CALC_HEXAD_PASSAGE,   900000000u64, 0x7u64, 2u8)
    /* p004 mean     -- HEXAD_ESSENCE    K=1.00 args(form, assert)   R0 */
    _calc_set(3u32,  CALC_HEXAD_ESSENCE,  1000000000u64, 0x3u64, 2u8)
    /* p005 act      -- HEXAD_MOTION     K=0.90 args(state, trans)   R0 */
    _calc_set(4u32,  CALC_HEXAD_MOTION,    900000000u64, 0x3u64, 2u8)
    /* p006 compose  -- HEXAD_COMPOSE    K=0.98 args(left, right)    R0 */
    _calc_set(5u32,  CALC_HEXAD_COMPOSE,   980000000u64, 0x3u64, 2u8)
    /* p007 seal     -- HEXAD_ORIGIN     K=1.00 args(val, seal_id)   R0 */
    _calc_set(6u32,  CALC_HEXAD_ORIGIN,   1000000000u64, 0x3u64, 2u8)

    /* Meta primitives (8..11) */
    /* p008 prove    -- HEXAD_ESSENCE    K=1.00 args(left, right)    R0 */
    _calc_set(7u32,  CALC_HEXAD_ESSENCE,  1000000000u64, 0x3u64, 2u8)
    /* p009 query    -- HEXAD_ESSENCE    K=1.00 args(kind, id)       R0 */
    _calc_set(8u32,  CALC_HEXAD_ESSENCE,  1000000000u64, 0x3u64, 2u8)
    /* p010 grant    -- HEXAD_ORIGIN     K=0.95 args(parent, atten)  R0 */
    _calc_set(9u32,  CALC_HEXAD_ORIGIN,    950000000u64, 0x3u64, 2u8)
    /* p011 govern   -- HEXAD_ORIGIN     K=0.95 args(proposer, chg)  R-2 */
    _calc_set(10u32, CALC_HEXAD_ORIGIN,    950000000u64, 0x3u64, 0u8)

    /* Composition operators (12..15) */
    /* p012 then     -- HEXAD_COMPOSE    K=1.00 args(left, right)    R0 */
    _calc_set(11u32, CALC_HEXAD_COMPOSE,  1000000000u64, 0x3u64, 2u8)
    /* p013 with     -- HEXAD_COMPOSE    K=1.00 args(left, right)    R0 */
    _calc_set(12u32, CALC_HEXAD_COMPOSE,  1000000000u64, 0x3u64, 2u8)
    /* p014 under    -- HEXAD_COMPOSE    K=1.00 args(ctx, body)      R0 */
    _calc_set(13u32, CALC_HEXAD_COMPOSE,  1000000000u64, 0x3u64, 2u8)
    /* p015 if       -- HEXAD_COMPOSE    K=1.00 args(guard, body)    R0 */
    _calc_set(14u32, CALC_HEXAD_COMPOSE,  1000000000u64, 0x3u64, 2u8)

    /* Special primitives (16..18) */
    /* p016 loop     -- HEXAD_COMPOSE    K=0.95 args(body, max, k_d) R0 */
    _calc_set(15u32, CALC_HEXAD_COMPOSE,   950000000u64, 0x7u64, 2u8)
    /* p017 lift     -- HEXAD_ORIGIN     K=0.90 args(val, ring)      R-1 */
    _calc_set(16u32, CALC_HEXAD_ORIGIN,    900000000u64, 0x3u64, 1u8)
    /* p018 reflect  -- HEXAD_ESSENCE    K=1.00 args(scope)          R0 */
    _calc_set(17u32, CALC_HEXAD_ESSENCE,  1000000000u64, 0x1u64, 2u8)

    /* IDSG primitive (19) */
    /* p019 abstract -- HEXAD_COMPOSE    K=1.00 args(concrete, seed) R0
     * Generalises a sealed concrete intent into an abstract pattern.
     * Closes the Self-Reformatter loop: govern -> abstract -> seal. */
    _calc_set(18u32, CALC_HEXAD_COMPOSE, 1000000000u64, 0x3u64, 2u8)

    _calc_compute_root()
    CALC_INIT = 1u8
    return CALCULUS_OK
}

/* -------------------------------------------------------------- */
/* Public accessors                                                */
/* -------------------------------------------------------------- */

fn calculus_primitive_hexad(p_id: u32) -> u8 @export {
    let l_pid : u32 = p_id
    if CALC_INIT != 1u8 { return 0u8 }
    if l_pid == 0u32 { return 0u8 }
    if l_pid > CALCULUS_PRIMITIVE_COUNT { return 0u8 }
    return CALC_HEXAD[l_pid - 1u32]
}

fn calculus_primitive_k_cost(p_id: u32) -> u64 @export {
    let l_pid : u32 = p_id
    if CALC_INIT != 1u8 { return 0u64 }
    if l_pid == 0u32 { return 0u64 }
    if l_pid > CALCULUS_PRIMITIVE_COUNT { return 0u64 }
    return CALC_K_COST[l_pid - 1u32]
}

fn calculus_primitive_param_schema(p_id: u32) -> u64 @export {
    let l_pid : u32 = p_id
    if CALC_INIT != 1u8 { return 0u64 }
    if l_pid == 0u32 { return 0u64 }
    if l_pid > CALCULUS_PRIMITIVE_COUNT { return 0u64 }
    return CALC_ARG_MASK[l_pid - 1u32]
}

fn calculus_primitive_ring_min(p_id: u32) -> u8 @export {
    let l_pid : u32 = p_id
    if CALC_INIT != 1u8 { return 0u8 }
    if l_pid == 0u32 { return 0u8 }
    if l_pid > CALCULUS_PRIMITIVE_COUNT { return 0u8 }
    return CALC_RING_MIN[l_pid - 1u32]
}

fn calculus_primitive_count() -> u32 @export {
    return CALCULUS_PRIMITIVE_COUNT
}

fn calculus_version_major() -> u32 @export { return CALCULUS_VERSION_MAJOR }
fn calculus_version_minor() -> u32 @export { return CALCULUS_VERSION_MINOR }

/* Emit the 32-byte sealed root mhash into out_32 (caller-owned). */
fn calculus_root_mhash(out_32: u64) -> i32 @export {
    if CALC_INIT != 1u8 { return CALCULUS_E_NOT_INITED }
    let dst : *u8 = out_32 as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        dst[i] = CALC_ROOT_MHASH[i as u32]
        i = i + 1u64
    }
    return CALCULUS_OK
}

/* Per-byte accessor for callers that prefer not to provide a buffer. */
fn calculus_root_mhash_byte(i: u32) -> u32 @export {
    if CALC_INIT != 1u8 { return 0x100u32 }
    if i >= 32u32 { return 0x100u32 }
    return CALC_ROOT_MHASH[i] as u32
}

/* -------------------------------------------------------------- */
/* calculus_verify_completeness                                    */
/*                                                                 */
/* Replays a buffer of u64 intent_ids; for each, asserts the       */
/* intent's goal_kind is in [1, 19]. Returns 1 if all valid,       */
/* 0 if any intent_id fails verification or has out-of-range       */
/* goal_kind. Also rejects any intent that fails intent_verify.    */
/* -------------------------------------------------------------- */

fn calculus_verify_completeness(intents_ptr: u64, count: u32) -> u8 @export {
    if CALC_INIT != 1u8 { return 0u8 }
    if intents_ptr == 0u64 {
        if count != 0u32 { return 0u8 }
        return 1u8
    }
    let mut i : u32 = 0u32
    while i < count {
        let off : u64 = ((i as u64) & 0xFFFFFFFFu64) * 8u64
        let pp  : *u64 = (intents_ptr + off) as *u64
        let intent : u64 = pp[0u64]
        if intent_verify(intent) != 1u8 { return 0u8 }
        let gk : u8 = intent_goal_kind(intent)
        if gk == 0u8 { return 0u8 }
        if gk > 19u8 { return 0u8 }
        i = i + 1u32
    }
    return 1u8
}

/* Bool: has the calculus been initialised? */
fn calculus_is_initialised() -> u8 @export {
    return CALC_INIT
}
