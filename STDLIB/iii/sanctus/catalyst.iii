/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\sanctus\catalyst.iii
 *
 * III STDLIB - sanctus::catalyst -- 8-gate causal-DAG hypothesis synthesis.
 *
 * Lattice plan Phase 14j Step 0187.  The catalyst is the gate-keeper
 * for vocabulary evolution: a proposed change (new modifier, new
 * token, new pattern) must demonstrate ALL 8 catalyst gates before
 * the promote pipeline accepts it into the sealed vocabulary.  This
 * is the core mechanism of \"hardcoded dynamism\": changes don't
 * happen via runtime mutation; they happen via hypotheses that pass
 * 8 hand-engineered tests, then get sealed into the next closure_root.
 *
 * Gates (FROZEN SPEC §D14):
 *   G_STATIC       (0x01): change is structurally axiom-compatible
 *   G_DYNAMIC      (0x02): change preserves all M1-M22 dynamic invariants
 *   G_KCHAIN       (0x04): K-chain composition doesn't underflow
 *   G_WITNESS      (0x08): change can be replayed from witness chain
 *   G_RIPPLE       (0x10): ripple_analyze finds no contradictions
 *   G_DUAL_USE     (0x20): satisfies both consumer + audit requirements
 *   G_CONSERVATIVE (0x40): reversible (revoke path exists)
 *   G_UNIQUE       (0x80): no name collisions with existing vocabulary
 *
 * 64-slot hypothesis registry; each slot = (hyp_id, fired bitmask).
 * Hypotheses are tracked by u64 ID; the gate-firing protocol is
 * driven externally -- the catalyst module is purely the arbiter.
 *
 * Public surface:
 *   catalyst_register(hyp_id)                          -> i32
 *   catalyst_set_gate(hyp_id, gate_bit, fired)         -> i32
 *   catalyst_gate_fired(hyp_id, gate_bit)              -> u8
 *   catalyst_collapsed_state(hyp_id)                   -> u32
 *   catalyst_promotable(hyp_id)                        -> u8
 *   catalyst_count()                                   -> u32
 *   catalyst_clear_all()                               -> i32
 *
 * Hexad: kind_origin (Crown).  Ring: R0.  K: 1.00.
 */

module sanctus_catalyst

const CAT_OK             : i32 =  0i32
const CAT_E_BADID        : i32 = -1i32
const CAT_E_FULL         : i32 = -2i32
const CAT_E_BADGATE      : i32 = -3i32
const CAT_E_NOT_REG      : i32 = -4i32

const CAT_SLOTS          : u32 = 64u32

const CAT_GATE_STATIC       : u32 = 0x01u32
const CAT_GATE_DYNAMIC      : u32 = 0x02u32
const CAT_GATE_KCHAIN       : u32 = 0x04u32
const CAT_GATE_WITNESS      : u32 = 0x08u32
const CAT_GATE_RIPPLE       : u32 = 0x10u32
const CAT_GATE_DUAL_USE     : u32 = 0x20u32
const CAT_GATE_CONSERVATIVE : u32 = 0x40u32
const CAT_GATE_UNIQUE       : u32 = 0x80u32
const CAT_GATE_ALL          : u32 = 0xFFu32

var CAT_LIVE   : [u8;  64]
var CAT_HYP_ID : [u64; 64]
var CAT_FIRED  : [u32; 64]

fn _cat_lookup(hyp_id: u64) -> u32 {
    let id_l : u64 = hyp_id
    if id_l == 0u64 { return 0xFFFFFFFFu32 }
    let mut s : u32 = 0u32
    while s < CAT_SLOTS {
        if CAT_LIVE[s] == 1u8 {
            if CAT_HYP_ID[s] == id_l { return s }
        }
        s = s + 1u32
    }
    return 0xFFFFFFFFu32
}

fn _cat_first_free() -> u32 {
    let mut s : u32 = 0u32
    while s < CAT_SLOTS {
        if CAT_LIVE[s] == 0u8 { return s }
        s = s + 1u32
    }
    return 0xFFFFFFFFu32
}

fn _cat_valid_gate(g: u32) -> u8 {
    let g_l : u32 = g
    if g_l == CAT_GATE_STATIC       { return 1u8 }
    if g_l == CAT_GATE_DYNAMIC      { return 1u8 }
    if g_l == CAT_GATE_KCHAIN       { return 1u8 }
    if g_l == CAT_GATE_WITNESS      { return 1u8 }
    if g_l == CAT_GATE_RIPPLE       { return 1u8 }
    if g_l == CAT_GATE_DUAL_USE     { return 1u8 }
    if g_l == CAT_GATE_CONSERVATIVE { return 1u8 }
    if g_l == CAT_GATE_UNIQUE       { return 1u8 }
    return 0u8
}

fn catalyst_register(hyp_id: u64) -> i32 @export {
    let id_l : u64 = hyp_id
    if id_l == 0u64 { return CAT_E_BADID }
    /* Refuse duplicate registration. */
    if _cat_lookup(id_l) != 0xFFFFFFFFu32 { return CAT_E_BADID }
    let s : u32 = _cat_first_free()
    if s == 0xFFFFFFFFu32 { return CAT_E_FULL }
    CAT_LIVE[s]   = 1u8
    CAT_HYP_ID[s] = id_l
    CAT_FIRED[s]  = 0u32
    return CAT_OK
}

fn catalyst_set_gate(hyp_id: u64, gate_bit: u32, fired: u8) -> i32 @export {
    let id_l : u64 = hyp_id
    let g_l  : u32 = gate_bit
    let f_l  : u8  = fired
    if id_l == 0u64 { return CAT_E_BADID }
    if _cat_valid_gate(g_l) == 0u8 { return CAT_E_BADGATE }
    let s : u32 = _cat_lookup(id_l)
    if s == 0xFFFFFFFFu32 { return CAT_E_NOT_REG }
    if f_l == 1u8 {
        CAT_FIRED[s] = CAT_FIRED[s] | g_l
    }
    if f_l == 0u8 {
        let inv : u32 = (g_l ^ 0xFFFFFFFFu32) & 0xFFFFFFFFu32
        CAT_FIRED[s] = CAT_FIRED[s] & inv
    }
    return CAT_OK
}

fn catalyst_gate_fired(hyp_id: u64, gate_bit: u32) -> u8 @export {
    let id_l : u64 = hyp_id
    let g_l  : u32 = gate_bit
    if id_l == 0u64 { return 0u8 }
    if _cat_valid_gate(g_l) == 0u8 { return 0u8 }
    let s : u32 = _cat_lookup(id_l)
    if s == 0xFFFFFFFFu32 { return 0u8 }
    if (CAT_FIRED[s] & g_l) != 0u32 { return 1u8 }
    return 0u8
}

fn catalyst_collapsed_state(hyp_id: u64) -> u32 @export {
    let id_l : u64 = hyp_id
    if id_l == 0u64 { return 0u32 }
    let s : u32 = _cat_lookup(id_l)
    if s == 0xFFFFFFFFu32 { return 0u32 }
    return CAT_FIRED[s] & CAT_GATE_ALL
}

fn catalyst_promotable(hyp_id: u64) -> u8 @export {
    let id_l : u64 = hyp_id
    if id_l == 0u64 { return 0u8 }
    let bits : u32 = catalyst_collapsed_state(id_l)
    if bits == CAT_GATE_ALL { return 1u8 }
    return 0u8
}

fn catalyst_count() -> u32 @export {
    let mut count : u32 = 0u32
    let mut s : u32 = 0u32
    while s < CAT_SLOTS {
        if CAT_LIVE[s] == 1u8 { count = count + 1u32 }
        s = s + 1u32
    }
    return count
}

fn catalyst_clear_all() -> i32 @export {
    let mut s : u32 = 0u32
    while s < CAT_SLOTS {
        CAT_LIVE[s]   = 0u8
        CAT_HYP_ID[s] = 0u64
        CAT_FIRED[s]  = 0u32
        s = s + 1u32
    }
    return CAT_OK
}
