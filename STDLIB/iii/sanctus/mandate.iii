/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\sanctus\mandate.iii
 *
 * III STDLIB - sanctus::mandate
 *
 * Runtime mandate audit.  Of the 21 project mandates, the following
 * subset has runtime semantics:
 *
 *   M1   K-chain integrity
 *   M5   No partial implementations (Phase D: trivially true)
 *   M9   Working code (we're executing => satisfied)
 *   M10  Cross-file harmony (linker resolved => satisfied)
 *   M14  Holistic review (caller-supplied mhash match)
 *   M15  K-threshold floor
 *
 * Process-time mandates (M2, M3, M4, M6, M7, M8, M11, M12, M13, M16,
 * M17, M18, M19, M20, M21) are enforced at code-review time, not at
 * runtime - the audit reports them as set under the assumption the
 * code reviewer signed off.  In a violation the code wouldn't pass
 * review and wouldn't compile here.
 *
 * Returns a u32 bitmask: bit N set ⇔ mandate (N+1) satisfied.
 *
 * Hexad: kind_origin (Crown).  Ring: R0.  K: 1.00.
 */

module sanctus_mandate

extern @abi(c-msvc-x64) fn kchain_is_underflow(id: u64) -> u8 from "kchain.iii"
extern @abi(c-msvc-x64) fn kchain_current(id: u64) -> u64 from "kchain.iii"
extern @abi(c-msvc-x64) fn kchain_floor(id: u64) -> u64 from "kchain.iii"
extern @abi(c-msvc-x64) fn kchain_is_live(id: u64) -> u8 from "kchain.iii"

/* Precomputed bitmask for the 15 process-time mandates that are
 * always considered satisfied because they were enforced before this
 * code linked.  Bits set: 1, 2, 3, 5, 6, 7, 10, 11, 12, 15, 16, 17,
 * 18, 19, 20 (representing M2, M3, M4, M6, M7, M8, M11, M12, M13,
 * M16, M17, M18, M19, M20, M21). */
const MANDATE_PROCESS_BITS : u32 = 0x001F9CEEu32

/* M22 (Resolution Determinism, FROZEN SPEC §13, ADR-RES-010) extends the mask. */
const MANDATE_M22_BIT  : u32 = 0x00200000u32
const MANDATE_ALL_MASK : u32 = 0x003FFFFFu32

/* M1: K-chain integrity.  W4.2 (ENHANCE-17): a NONZERO chain id must name a LIVE chain to
 * be satisfied.  Pre-fix, a dead/unknown id passed: kchain_is_underflow reports a dead id as
 * "not underflowing" (0), which was read as satisfied -- a green light over a chain that does
 * not exist.  Now a dead chain is NOT satisfied (the `kchain_id == 0` "no chain to check"
 * convention is preserved as the only trivially-satisfied case). */
fn mandate_check_m1(kchain_id: u64) -> u8 @export {
    if kchain_id == 0u64 { return 1u8 }
    if kchain_is_live(kchain_id) == 0u8 { return 0u8 }
    if kchain_is_underflow(kchain_id) == 0u8 { return 1u8 }
    return 0u8
}

/* M5: no partial implementations - always 1 in shipped stdlib. */
fn mandate_check_m5() -> u8 @export {
    return 1u8
}

/* M9: working code - if we're running, we're working. */
fn mandate_check_m9() -> u8 @export {
    return 1u8
}

/* M10: cross-file harmony - linker satisfied us. */
fn mandate_check_m10() -> u8 @export {
    return 1u8
}

/* M14: caller asserts whether the closure mhash matched build-time. */
fn mandate_check_m14_via_match(matched: u8) -> u8 @export {
    if matched == 1u8 { return 1u8 }
    return 0u8
}

/* M15: K-floor.  W4.2: a dead/unknown nonzero chain is NOT satisfied (made explicit; a dead
 * chain reads current=0 which is already below floor, but the liveness check states intent). */
fn mandate_check_m15(kchain_id: u64) -> u8 @export {
    if kchain_id == 0u64 { return 1u8 }
    if kchain_is_live(kchain_id) == 0u8 { return 0u8 }
    let cur : u64 = kchain_current(kchain_id)
    let flr : u64 = kchain_floor(kchain_id)
    if cur >= flr { return 1u8 }
    return 0u8
}

/* M22: Resolution Determinism -- implementation in sanctus/mandate_m22.iii
 * supplies the bit contribution; mandate_audit() OR-combines below. */
extern @abi(c-msvc-x64) fn mandate_audit_m22_contribution() -> u32 from "mandate_m22.iii"

/* Combined runtime audit. */
fn mandate_audit(kchain_id: u64, mhash_matched: u8) -> u32 @export {
    let mut bits : u32 = MANDATE_PROCESS_BITS
    let bit_m1  : u32 = 0x00000001u32
    let bit_m5  : u32 = 0x00000010u32
    let bit_m9  : u32 = 0x00000100u32
    let bit_m10 : u32 = 0x00000200u32
    let bit_m14 : u32 = 0x00002000u32
    let bit_m15 : u32 = 0x00004000u32
    if mandate_check_m1(kchain_id) == 1u8 { bits = bits | bit_m1 }
    if mandate_check_m5() == 1u8 { bits = bits | bit_m5 }
    if mandate_check_m9() == 1u8 { bits = bits | bit_m9 }
    if mandate_check_m10() == 1u8 { bits = bits | bit_m10 }
    if mandate_check_m14_via_match(mhash_matched) == 1u8 { bits = bits | bit_m14 }
    if mandate_check_m15(kchain_id) == 1u8 { bits = bits | bit_m15 }
    bits = bits | mandate_audit_m22_contribution()
    return bits & MANDATE_ALL_MASK
}

fn mandate_all_mask() -> u32 @export {
    return MANDATE_ALL_MASK
}

fn mandate_process_mask() -> u32 @export {
    return MANDATE_PROCESS_BITS
}
