/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\sanctus\promote.iii
 *
 * III STDLIB - sanctus::promote -- vocabulary promotion pipeline.
 *
 * Lattice plan Phase 14n Step 0198.  Takes a hypothesis_id whose 8
 * catalyst gates have ALL fired, and registers a new vocabulary entry
 * (a sealed addition to the language's modifier/token/pattern set).
 * Refuses promotion when:
 *   (a) hypothesis is not registered with the catalyst
 *   (b) hypothesis is not promotable (some gate is still unfired)
 *   (c) the proposed vocabulary slot is already occupied
 *
 * 64-slot vocabulary registry; each slot = (vocab_id, hyp_id,
 * name_hash_32, active flag).  Append-only -- once promoted, an entry
 * stays in the slot table even when later demoted (active flag
 * tracks lifecycle).
 *
 * Public surface:
 *   promote_register(hyp_id, name_hash_32_ptr)              -> u64
 *   promote_vocabulary_count()                              -> u32
 *   promote_vocabulary_active_count()                       -> u32
 *   promote_is_active(vocab_id)                             -> u8
 *   promote_hyp_id(vocab_id)                                -> u64
 *   promote_name_byte(vocab_id, i)                          -> u32
 *   promote_set_active(vocab_id, active)                    -> i32
 *   promote_clear_all()                                     -> i32
 *
 * Hexad: kind_origin.  Ring: R0.  K: 0.99.
 */

module sanctus_promote

extern @abi(c-msvc-x64) fn catalyst_promotable(hyp_id: u64) -> u8 from "catalyst.iii"

const PRM_OK             : i32 =  0i32
const PRM_E_NULL         : i32 = -1i32
const PRM_E_NOT_PROM     : i32 = -2i32
const PRM_E_FULL         : i32 = -3i32
const PRM_E_BADID        : i32 = -4i32

const PRM_SLOTS          : u32 = 64u32

var PRM_LIVE      : [u8;  64]
var PRM_HYP_ID    : [u64; 64]
var PRM_NAME_HASH : [u8;  2048]   /* 64 * 32 bytes */
var PRM_ACTIVE    : [u8;  64]
var PRM_USED      : u32 = 0u32

fn _prm_slot_of(vocab_id: u64) -> u32 {
    let id_l : u64 = vocab_id
    if id_l == 0u64 { return 0xFFFFFFFFu32 }
    /* Reject vocab_id beyond the issuable range: the mask below would WRAP an
     * out-of-range id (e.g. 65 -> slot 0) onto a live slot, aliasing data.  [audit promote-1] */
    if id_l > (PRM_SLOTS as u64) { return 0xFFFFFFFFu32 }
    let s : u64 = (id_l - 1u64) & 0x3Fu64
    let s_u32 : u32 = s as u32
    if s_u32 >= PRM_SLOTS { return 0xFFFFFFFFu32 }
    if PRM_LIVE[s_u32] == 0u8 { return 0xFFFFFFFFu32 }
    return s_u32
}

fn promote_register(hyp_id: u64, name_hash_32_ptr: u64) -> u64 @export {
    let h_l : u64 = hyp_id
    let n_l : u64 = name_hash_32_ptr
    if h_l == 0u64 { return 0u64 }
    if n_l == 0u64 { return 0u64 }
    if catalyst_promotable(h_l) != 1u8 { return 0u64 }
    if PRM_USED >= PRM_SLOTS { return 0u64 }
    let s : u32 = PRM_USED
    PRM_LIVE[s]   = 1u8
    PRM_HYP_ID[s] = h_l
    PRM_ACTIVE[s] = 1u8
    let dst_off : u64 = (s as u64) * 32u64
    let dp : *u8 = (&PRM_NAME_HASH as u64 + dst_off) as *u8
    let sp : *u8 = n_l as *u8
    let mut i : u64 = 0u64
    while i < 32u64 {
        dp[i] = sp[i]
        i = i + 1u64
    }
    PRM_USED = PRM_USED + 1u32
    return (s as u64) + 1u64
}

fn promote_vocabulary_count() -> u32 @export {
    return PRM_USED
}

fn promote_vocabulary_active_count() -> u32 @export {
    let mut count : u32 = 0u32
    let mut s : u32 = 0u32
    while s < PRM_USED {
        if PRM_LIVE[s] == 1u8 {
            if PRM_ACTIVE[s] == 1u8 { count = count + 1u32 }
        }
        s = s + 1u32
    }
    return count
}

fn promote_is_active(vocab_id: u64) -> u8 @export {
    let s : u32 = _prm_slot_of(vocab_id)
    if s == 0xFFFFFFFFu32 { return 0u8 }
    return PRM_ACTIVE[s]
}

fn promote_hyp_id(vocab_id: u64) -> u64 @export {
    let s : u32 = _prm_slot_of(vocab_id)
    if s == 0xFFFFFFFFu32 { return 0u64 }
    return PRM_HYP_ID[s]
}

fn promote_name_byte(vocab_id: u64, i: u32) -> u32 @export {
    let i_l : u32 = i
    let s : u32 = _prm_slot_of(vocab_id)
    if s == 0xFFFFFFFFu32 { return 0x100u32 }
    if i_l >= 32u32 { return 0x100u32 }
    return PRM_NAME_HASH[(s as u64) * 32u64 + (i_l as u64)] as u32
}

fn promote_set_active(vocab_id: u64, active: u8) -> i32 @export {
    let a_l : u8 = active
    let s : u32 = _prm_slot_of(vocab_id)
    if s == 0xFFFFFFFFu32 { return PRM_E_BADID }
    if a_l > 1u8 { return PRM_E_BADID }
    PRM_ACTIVE[s] = a_l
    return PRM_OK
}

fn promote_clear_all() -> i32 @export {
    let mut s : u32 = 0u32
    while s < PRM_SLOTS {
        PRM_LIVE[s]   = 0u8
        PRM_HYP_ID[s] = 0u64
        PRM_ACTIVE[s] = 0u8
        s = s + 1u32
    }
    let mut i : u32 = 0u32
    while i < 2048u32 {
        PRM_NAME_HASH[i] = 0u8
        i = i + 1u32
    }
    PRM_USED = 0u32
    return PRM_OK
}
