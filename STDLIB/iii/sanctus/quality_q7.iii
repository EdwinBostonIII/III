/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\sanctus\quality_q7.iii
 *
 * III STDLIB - sanctus::quality_q7
 *
 * Q7: Resolution Determinism gate.
 * FROZEN SPEC §1.2.7, §Z.D.1; ADR-RES-011.
 *
 * Verifies:
 *   (a) resolver source contains no forbidden behaviour (build-time lint).
 *   (b) witness chain replays byte-equal.
 *   (c) registry sealed.
 *   (d) coefficient-table mhash matches sealed value.
 *
 * Returns 1 (green) iff all four checks pass.
 *
 * Hexad: kind_origin (Crown). Ring: R0. K: 1.00.
 */

module sanctus_quality_q7

extern @abi(c-msvc-x64) fn pattern_registry_is_sealed() -> u8 from "pattern_table.iii"
extern @abi(c-msvc-x64) fn seal_resolver_verify() -> u8 from "seal_resolver.iii"
/* Q7-c specifically requires the per-entry byte-equal mhash check from
 * sanctus/resolver_replay.iii (FROZEN SPEC §V.G0005), not the broader
 * registry-sealed audit gate from omnia/resolver_replay.iii. */
extern @abi(c-msvc-x64) fn sanctus_resolver_replay_check_chain() -> u8 from "resolver_replay.iii"

const Q7_BIT : u32 = 0x40u32

/* (a) build-time assertion that the resolver source lint ran clean. */
var g_resolver_lint_passed : u8 = 0u8
/* (a') CUT-15: the REAL forbidden-behaviour lint's verdict.  1 iff the last
 * quality_run_resolver_lint() found a forbidden construct.  Defaults to 0 (no
 * violation seen) so the build-asserted positive path is unchanged. */
var g_resolver_lint_violation : u8 = 0u8

/* CUT-15 (W4.2): the forbidden-behaviour profile for the Resolution-Determinism
 * gate.  The resolver MUST be a pure, content-addressed function -- no floating
 * point, no hardware randomness, no wall-clock, no observational adaptation.  The
 * lint rejects source bearing any of these byte tokens.  (Stored as length-explicit
 * byte arrays -- no NUL-terminator dependency.) */
var Q7_TOK_F64    : [u8; 3]  = [102u8, 54u8, 52u8]                                   /* "f64"   */
var Q7_TOK_F32    : [u8; 3]  = [102u8, 51u8, 50u8]                                   /* "f32"   */
var Q7_TOK_RDTSC  : [u8; 5]  = [114u8, 100u8, 116u8, 115u8, 99u8]                    /* "rdtsc" */
var Q7_TOK_RDRAND : [u8; 6]  = [114u8, 100u8, 114u8, 97u8, 110u8, 100u8]             /* "rdrand"*/
var Q7_TOK_SRAND  : [u8; 5]  = [115u8, 114u8, 97u8, 110u8, 100u8]                    /* "srand" */
var Q7_TOK_CLOCK  : [u8; 5]  = [99u8, 108u8, 111u8, 99u8, 107u8]                     /* "clock" */

fn quality_set_resolver_lint_passed() -> i32 @export {
    g_resolver_lint_passed = 1u8
    return 0i32
}

fn quality_resolver_lint_passed() -> u8 @export {
    return g_resolver_lint_passed
}

/* 1u8 iff the `patlen`-byte pattern occurs as a substring of buf[0..len). */
fn _q7_contains(buf: u64, len: u32, pat: u64, patlen: u32) -> u8 {
    if patlen == 0u32 { return 0u8 }
    if patlen > len { return 0u8 }
    let last : u32 = len - patlen
    let mut i : u32 = 0u32
    while i <= last {
        let mut k : u32 = 0u32
        let mut hit : u8 = 1u8
        while k < patlen {
            let bp : *u8 = (buf + ((i as u64) + (k as u64))) as *u8
            let pp : *u8 = (pat + (k as u64)) as *u8
            if bp[0u64] != pp[0u64] { hit = 0u8  k = patlen }
            k = k + 1u32
        }
        if hit == 1u8 { return 1u8 }
        i = i + 1u32
    }
    return 0u8
}

/* CUT-15: the REAL forbidden-behaviour lint.  Scans the supplied resolver source
 * bytes for any forbidden token; returns 1 (clean) iff none present, 0 otherwise,
 * and records the verdict so quality_check_q7_resolution() consults it.  Unlike the
 * old bare flag, check (a) now DEPENDS on real bytes and can REJECT. */
fn quality_run_resolver_lint(src: u64, len: u32) -> u8 @export {
    if src == 0u64 { g_resolver_lint_violation = 1u8  return 0u8 }
    let mut bad : u8 = 0u8
    if _q7_contains(src, len, (&Q7_TOK_F64)    as u64, 3u32) == 1u8 { bad = 1u8 }
    if _q7_contains(src, len, (&Q7_TOK_F32)    as u64, 3u32) == 1u8 { bad = 1u8 }
    if _q7_contains(src, len, (&Q7_TOK_RDTSC)  as u64, 5u32) == 1u8 { bad = 1u8 }
    if _q7_contains(src, len, (&Q7_TOK_RDRAND) as u64, 6u32) == 1u8 { bad = 1u8 }
    if _q7_contains(src, len, (&Q7_TOK_SRAND)  as u64, 5u32) == 1u8 { bad = 1u8 }
    if _q7_contains(src, len, (&Q7_TOK_CLOCK)  as u64, 5u32) == 1u8 { bad = 1u8 }
    g_resolver_lint_violation = bad
    if bad == 1u8 { return 0u8 }
    return 1u8
}

/* 1u8 iff the last lint run found a forbidden construct (diagnostics + falsifier). */
fn quality_resolver_lint_violation() -> u8 @export {
    return g_resolver_lint_violation
}

fn quality_check_q7_resolution() -> u8 @export {
    /* (a) the build asserted the source lint ran ... */
    if g_resolver_lint_passed == 0u8 { return 0u8 }
    /* (a') ... AND no real forbidden-behaviour lint has flagged a violation. */
    if g_resolver_lint_violation != 0u8 { return 0u8 }
    if sanctus_resolver_replay_check_chain() == 0u8 { return 0u8 }
    if pattern_registry_is_sealed() == 0u8 { return 0u8 }
    if seal_resolver_verify() == 0u8 { return 0u8 }
    return 1u8
}

/* Inject corruption hook for negative tests (corpus 47).
 * Production builds elide this via the build system's release-strip pass. */
fn witness_inject_corruption_for_test() -> i32 @export {
    g_resolver_lint_passed = 0u8
    return 0i32
}
