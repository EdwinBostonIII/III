/* sovereign_witness.iii -- Sovereign Witness SW-2/3/4 (DOCS/III-SOVEREIGN-WITNESS-ARCHITECTURE.md).
 *
 * The analyzer's heart, property-complete for ONE sound property: AFFINE-ACCESS SAFETY. Over a frozen
 * legacy_artifact (a captured TRACE of memory-access descriptors), prove for every affine access
 *   forall i in [0,count):  base + i*stride  is wrap-free AND < bound
 * -- the EXACT vulnerability class scans 5/6 hardened in III's own body, now PROVED about an external
 * captured program. Verdicts: PROVEN / REFUTED_BOUNDS(+first violating i) / REFUTED_WRAP(+first wrapping
 * i) / ABSTAIN (a record kind the analyzer cannot soundly reason about) / MALFORMED.
 *
 * SOUNDNESS DISCIPLINE (the architecture's load-bearing rule): the check is a closed form done in u64
 * with explicit overflow detection -- sound across the FULL u64 range, no i64-fidelity gap. It NEVER
 * emits PROVEN on a wrapping access (the forbidden unfalsifiable false claim); a u64 wrap is REFUTED_WRAP
 * even when the wrapped value happens to fall below bound (the scan-6 trap). SMT is deliberately NOT used
 * here -- constant stride makes the extreme address a closed form (i=count-1); SMT's authority is search
 * (non-constant stride / disjunctive paths), reserved for the properties that need it.
 *
 * The gate's teeth are RE-DERIVATION from the sealed bytes (sw_admit re-reads via la_byte + re-runs the
 * analysis + compares), not a structural proof check -- a forged verdict cannot survive re-derivation.
 * Composes the REAL organs legacy_artifact (frozen bytes) + cad (seal the witness) only. */
module sovereign_witness

extern @abi(c-msvc-x64) fn la_byte(h: u64, i: u64) -> u8 from "legacy_artifact.iii"
extern @abi(c-msvc-x64) fn la_len(h: u64) -> u64 from "legacy_artifact.iii"
extern @abi(c-msvc-x64) fn la_digest(h: u64, out32: u64) -> i32 from "legacy_artifact.iii"
extern @abi(c-msvc-x64) fn cad_oneshot(suite: u32, msg: *u8, len: u64, out: *u8) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_begin(suite: u32) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_payload(payload: u64, payload_len: u64) -> i32 from "cad.iii"
extern @abi(c-msvc-x64) fn cad_final(out_32: u64) -> i32 from "cad.iii"
/* III's OWN in-line affine-safety analyzer -- the inward cross-validation oracle. */
extern @abi(c-msvc-x64) fn ac_in_bounds(a: u32, b: u32, n: u32, size: u32) -> u32 from "affine_check.iii"

/* verdicts */
const SW_PROVEN         : u32 = 0u32
const SW_REFUTED_BOUNDS : u32 = 1u32
const SW_REFUTED_WRAP   : u32 = 2u32
const SW_ABSTAIN        : u32 = 3u32
const SW_MALFORMED      : u32 = 4u32

/* record kinds */
const SW_KIND_AFFINE : u64 = 1u64
const SW_KIND_OPAQUE : u64 = 2u64

const SW_U64_MAX  : u64 = 0xFFFFFFFFFFFFFFFFu64
const SW_REC_U64S : u64 = 5u64          /* {kind, base, stride, count, bound} */
const SW_REC_BYTES: u64 = 40u64         /* 5 * 8 */
const SW_HDR_BYTES: u64 = 8u64          /* leading record_count (u64 LE) */
const SW_CAD_SUITE: u32 = 0u32          /* sha256 */
const SW_PROP_AFFINE : u8 = 1u8         /* property id: affine-access safety */

/* the witness record we content-address: artifact_digest(32) || prop(1) || verdict(1) || viol_rec(8) || viol_i(8) */
var SW_WREC : [u8; 64]

/* read a little-endian u64 from the frozen artifact at byte offset off, through the OOB-bounded
 * la_byte (past-len bytes read as 0; callers bound off+8 <= la_len before trusting the value). */
fn sw_rd_u64(h: u64, off: u64) -> u64 {
    let mut v : u64 = 0u64
    let mut k : u64 = 0u64
    while k < 8u64 {
        let b : u64 = la_byte(h, off + k) as u64
        v = v | (b << (8u64 * k))
        k = k + 1u64
    }
    return v
}

/* THE SOUND PROCEDURE. Decides affine-access safety for one descriptor; writes the counterexample
 * index to *out_ce on a refutation (0 otherwise). Closed-form, u64-exact, overflow-aware. */
fn sw_prove_affine(base: u64, stride: u64, count: u64, bound: u64, out_ce: u64) -> u32 @export {
    let cep : *u64 = out_ce as *u64
    cep[0u64] = 0u64
    if count == 0u64 { return SW_PROVEN }          /* no accesses -> vacuously safe */
    let cm1 : u64 = count - 1u64

    /* Does the extreme access i=cm1 wrap u64? (base + i*stride is monotonic until it wraps.) */
    let mut wrapped : u8 = 0u8
    if stride != 0u64 {
        let lim : u64 = SW_U64_MAX / stride
        if cm1 > lim { wrapped = 1u8 }             /* cm1*stride itself overflows */
    }
    if wrapped == 0u8 {
        let p : u64 = cm1 * stride                 /* safe: cm1 <= U64_MAX/stride, or stride==0 -> 0 */
        let avail : u64 = SW_U64_MAX - base
        if p > avail { wrapped = 1u8 }             /* base + p overflows */
    }
    if wrapped == 1u8 {
        /* first wrapping i = floor((U64_MAX - base)/stride) + 1 (stride != 0 here, and result < count). */
        let avail2 : u64 = SW_U64_MAX - base
        let iw : u64 = (avail2 / stride) + 1u64
        cep[0u64] = iw
        return SW_REFUTED_WRAP
    }

    /* No wrap in [0,count): the max address is exact. */
    let max_addr : u64 = base + (cm1 * stride)
    if max_addr >= bound {
        if base >= bound {                         /* the very first access is OOB */
            cep[0u64] = 0u64
            return SW_REFUTED_BOUNDS
        }
        /* base < bound, max >= bound, stride > 0 (else max==base<bound): first i with base+i*stride >= bound. */
        let delta : u64 = bound - base
        let mut iv : u64 = delta / stride
        let rem : u64 = delta % stride
        if rem != 0u64 { iv = iv + 1u64 }          /* ceil(delta/stride) */
        cep[0u64] = iv
        return SW_REFUTED_BOUNDS
    }
    return SW_PROVEN
}

/* LIFT + ANALYZE: walk the trace records (all reads OOB-bounded), aggregate the verdict.
 * Dominance: REFUTED > ABSTAIN > PROVEN. Writes the first violation (record idx, i) to the out
 * pointers. MALFORMED if the header/declared count does not fit the sealed bytes. */
fn sw_analyze(h: u64, out_viol_rec: u64, out_viol_i: u64) -> u32 @export {
    let rp : *u64 = out_viol_rec as *u64
    let ip : *u64 = out_viol_i as *u64
    rp[0u64] = 0u64
    ip[0u64] = 0u64
    let len : u64 = la_len(h)
    if len < SW_HDR_BYTES { return SW_MALFORMED }
    let nrec : u64 = sw_rd_u64(h, 0u64)
    let fits : u64 = (len - SW_HDR_BYTES) / SW_REC_BYTES
    if nrec > fits { return SW_MALFORMED }         /* declared count exceeds the bytes -> refuse */

    let mut agg : u32 = SW_PROVEN
    let mut i : u64 = 0u64
    while i < nrec {
        let off    : u64 = SW_HDR_BYTES + (i * SW_REC_BYTES)
        let kind   : u64 = sw_rd_u64(h, off)
        let base   : u64 = sw_rd_u64(h, off + 8u64)
        let stride : u64 = sw_rd_u64(h, off + 16u64)
        let count  : u64 = sw_rd_u64(h, off + 24u64)
        let bound  : u64 = sw_rd_u64(h, off + 32u64)
        if kind == SW_KIND_AFFINE {
            let ce : u64 = 0u64
            let v : u32 = sw_prove_affine(base, stride, count, bound, &ce as u64)
            if v != SW_PROVEN {
                rp[0u64] = i
                ip[0u64] = ce
                return v                           /* first refutation dominates */
            }
        } else {
            agg = SW_ABSTAIN                        /* a kind we cannot soundly reason about -> abstain (never PROVEN) */
        }
        i = i + 1u64
    }
    return agg
}

/* WITNESS: analyze, then content-address { artifact_digest || prop || verdict || viol_rec || viol_i }
 * into out_witness_digest (32 bytes). Returns the verdict. The witness is sealed + tamper-evident:
 * any change to the artifact bytes changes artifact_digest -> a different witness digest. */
fn sw_witness(h: u64, out_witness_digest: u64) -> u32 @export {
    let vrec : u64 = 0u64
    let vi   : u64 = 0u64
    let verdict : u32 = sw_analyze(h, &vrec as u64, &vi as u64)

    la_digest(h, &SW_WREC as u64)                  /* bytes 0..31 = artifact digest (0 if unsealed) */
    SW_WREC[32u64] = SW_PROP_AFFINE
    SW_WREC[33u64] = (verdict & 0xFFu32) as u8
    let mut k : u64 = 0u64
    while k < 8u64 {
        SW_WREC[34u64 + k] = ((vrec >> (8u64 * k)) & 0xFFu64) as u8
        SW_WREC[42u64 + k] = ((vi   >> (8u64 * k)) & 0xFFu64) as u8
        k = k + 1u64
    }
    cad_oneshot(SW_CAD_SUITE, &SW_WREC as *u8, 50u64, out_witness_digest as *u8)
    return verdict
}

/* ADMIT (the gate's teeth): re-derive the verdict + violation from the sealed bytes and confirm they
 * match the CLAIM. Returns 99 (ADMIT) iff the claim is exactly what re-derivation produces, else 0
 * (REJECT). A forged witness -- any verdict/violation that re-derivation does not reproduce -- is
 * rejected. This is the soundness anchor AND the forged-witness prove-the-negative. */
fn sw_admit(h: u64, claim_verdict: u32, claim_viol_rec: u64, claim_viol_i: u64) -> u32 @export {
    let vrec : u64 = 0u64
    let vi   : u64 = 0u64
    let v : u32 = sw_analyze(h, &vrec as u64, &vi as u64)
    if v != claim_verdict { return 0u32 }
    if vrec != claim_viol_rec { return 0u32 }
    if vi != claim_viol_i { return 0u32 }
    return 99u32
}

/* ================= SW-5: bounded, pure, host-effect-free REPLAY (FR-8) =================
 * The sandbox forward-execution over the FROZEN artifact: no host effect, only arena writes + a cad
 * seal. Closes the refute->reproduce loop (sw_analyze REFUTES at i; sw_replay reproduces the exact
 * unsafe address) and content-addresses the bounded forward state. */
const SW_REPLAY_HORIZON : u64 = 65536u64
var SW_RADDR : [u64; 1]   /* scratch for the streamed address (module var -> a stable address) */

/* The EXACT address access i lands on: base + i*stride in FULL u64 wrap arithmetic (the address the
 * hardware would compute, wrapped and all). Writes it to *out_addr; returns 1 if the computation
 * wrapped u64 (the access escaped [base, 2^64)), else 0. Pure. */
fn sw_replay_at(base: u64, stride: u64, i: u64, out_addr: u64) -> u32 @export {
    let ap : *u64 = out_addr as *u64
    let mut wrapped : u32 = 0u32
    if stride != 0u64 {
        let lim : u64 = SW_U64_MAX / stride
        if i > lim { wrapped = 1u32 }
    }
    if wrapped == 0u32 {
        let prod : u64 = i * stride
        let avail : u64 = SW_U64_MAX - base
        if prod > avail { wrapped = 1u32 }
    }
    ap[0u64] = base + (i * stride)            /* full u64 wrap arithmetic */
    return wrapped
}

/* REPRODUCE: replay access i of record record_idx over the frozen artifact and classify it exactly as
 * the analyzer would, writing the concrete address to *out_addr. SW_REFUTED_WRAP if it wrapped;
 * SW_REFUTED_BOUNDS if addr >= bound; SW_PROVEN if safe; SW_MALFORMED on a bad record index. This is
 * the forensic confirmation that the analyzer's counterexample is real. */
fn sw_replay_violation(h: u64, record_idx: u64, i: u64, out_addr: u64) -> u32 @export {
    let len : u64 = la_len(h)
    if len < SW_HDR_BYTES { return SW_MALFORMED }
    let nrec : u64 = sw_rd_u64(h, 0u64)
    if record_idx >= nrec { return SW_MALFORMED }
    let fits : u64 = (len - SW_HDR_BYTES) / SW_REC_BYTES
    if nrec > fits { return SW_MALFORMED }
    let off    : u64 = SW_HDR_BYTES + (record_idx * SW_REC_BYTES)
    let base   : u64 = sw_rd_u64(h, off + 8u64)
    let stride : u64 = sw_rd_u64(h, off + 16u64)
    let bound  : u64 = sw_rd_u64(h, off + 32u64)
    let wrapped : u32 = sw_replay_at(base, stride, i, out_addr)
    if wrapped == 1u32 { return SW_REFUTED_WRAP }
    let ap : *u64 = out_addr as *u64
    let addr : u64 = ap[0u64]
    if addr >= bound { return SW_REFUTED_BOUNDS }
    return SW_PROVEN
}

/* Content-address the BOUNDED forward state = the sequence of addresses touched by access 0..count-1
 * of record record_idx, sealed via cad. ABSTAIN if count exceeds the replay horizon (cannot soundly
 * enumerate). Deterministic: identical record bytes -> identical state digest. */
fn sw_replay_seq(h: u64, record_idx: u64, out_state_digest: u64) -> u32 @export {
    let len : u64 = la_len(h)
    if len < SW_HDR_BYTES { return SW_MALFORMED }
    let nrec : u64 = sw_rd_u64(h, 0u64)
    if record_idx >= nrec { return SW_MALFORMED }
    let off    : u64 = SW_HDR_BYTES + (record_idx * SW_REC_BYTES)
    let base   : u64 = sw_rd_u64(h, off + 8u64)
    let stride : u64 = sw_rd_u64(h, off + 16u64)
    let count  : u64 = sw_rd_u64(h, off + 24u64)
    if count > SW_REPLAY_HORIZON { return SW_ABSTAIN }
    cad_begin(SW_CAD_SUITE)
    let mut i : u64 = 0u64
    while i < count {
        sw_replay_at(base, stride, i, &SW_RADDR as u64)
        cad_payload(&SW_RADDR as u64, 8u64)
        i = i + 1u64
    }
    cad_final(out_state_digest)
    return SW_PROVEN
}

/* ================= second sound property: ALIGNMENT SAFETY =================
 * The sibling of bounds-safety: every access base+i*stride must be aligned to `align` (a power of two),
 * or some architectures fault / lose atomicity. Decidable + sound by a direct mod check; the first
 * misaligned access is the counterexample. */
const SW_REFUTED_ALIGN : u32 = 5u32
const SW_PROP_ALIGN     : u8  = 2u8

fn sw_is_pow2(x: u64) -> u32 {
    if x == 0u64 { return 0u32 }
    if (x & (x - 1u64)) == 0u64 { return 1u32 }
    return 0u32
}

/* PROVEN if every access is aligned; REFUTED_ALIGN(+first misaligned i) otherwise; ABSTAIN if align is
 * not a power of two (cannot reason cheaply -> never a false PROVEN). An aligned base with an aligned
 * stride keeps every access aligned: (base + i*stride) mod align = (0 + i*0) mod align = 0. */
fn sw_prove_aligned(base: u64, stride: u64, count: u64, align: u64, out_ce: u64) -> u32 @export {
    let cep : *u64 = out_ce as *u64
    cep[0u64] = 0u64
    if sw_is_pow2(align) == 0u32 { return SW_ABSTAIN }
    if count == 0u64 { return SW_PROVEN }
    let mask : u64 = align - 1u64
    if (base & mask) != 0u64 { cep[0u64] = 0u64 ; return SW_REFUTED_ALIGN }   /* access 0 (= base) misaligned */
    if (stride & mask) != 0u64 {
        if count > 1u64 { cep[0u64] = 1u64 ; return SW_REFUTED_ALIGN }        /* access 1 (= base+stride) is the first misaligned */
    }
    return SW_PROVEN
}

/* ============================================================================
 *  INWARD CROSS-VALIDATION -- the external-trace witness checked against III's OWN in-line analyzer.
 *  sw_prove_affine decides affine-access safety in CLOSED FORM over external traces (u64, wrap-aware);
 *  numera::affine_check::ac_in_bounds decides the SAME property for an in-line access by EXHAUSTIVE u32 scan.
 *  Two sound procedures with NO shared code must agree on PROVEN-vs-REFUTED for every in-range affine access
 *  -- differential verification that turns the witness inward against the substrate's own analysis (the
 *  vulnerability class scans 5/6 hardened in III's own body), the granular analyzer validating the sovereign.
 * ============================================================================ */

/* 1 iff the closed-form witness verdict and the exhaustive affine_check agree on a*i+b < size, i in [0,n). */
fn sw_xv_agree(a: u32, b: u32, n: u32, size: u32) -> u64 @export {
    let ce : u64 = 0u64
    let v : u32 = sw_prove_affine(b as u64, a as u64, n as u64, size as u64, &ce as u64)   /* base=b, stride=a */
    let mut witness_safe : u32 = 0u32
    if v == SW_PROVEN { witness_safe = 1u32 }
    let inline_safe : u32 = ac_in_bounds(a, b, n, size)
    if witness_safe == inline_safe { return 1u64 }
    return 0u64
}

/* THE INWARD CROSS-VALIDATION KAT -- 99 = the closed-form witness and the exhaustive affine_check agree on
 * affine-access safety for every in-range access (a*i+b < size), PROVEN and REFUTED alike, AND the witness
 * genuinely distinguishes safe from unsafe (never a vacuous all-PROVEN):
 *   (2,1,12,32) safe ; (3,2,8,16) refuted ; (1,0,31,32) safe ; (5,3,10,64) safe ; (4,0,20,50) refuted. */
fn sw_crossval_affine_kat() -> u64 @export {
    if sw_xv_agree(2u32, 1u32, 12u32, 32u32) != 1u64 { return 1u64 }
    if sw_xv_agree(3u32, 2u32, 8u32, 16u32) != 1u64 { return 2u64 }
    if sw_xv_agree(1u32, 0u32, 31u32, 32u32) != 1u64 { return 3u64 }
    if sw_xv_agree(5u32, 3u32, 10u32, 64u32) != 1u64 { return 4u64 }
    if sw_xv_agree(4u32, 0u32, 20u32, 50u32) != 1u64 { return 5u64 }
    /* the witness genuinely distinguishes: a safe access is PROVEN, an unsafe one is not */
    let ce : u64 = 0u64
    if sw_prove_affine(1u64, 2u64, 12u64, 32u64, &ce as u64) != SW_PROVEN { return 6u64 }
    if sw_prove_affine(2u64, 3u64, 8u64, 16u64, &ce as u64) == SW_PROVEN { return 7u64 }
    return 99u64
}
