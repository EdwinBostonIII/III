/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\sanctus\witness.iii
 *
 * III STDLIB - sanctus::witness
 *
 * Append-only witness chain.  Each entry records (mhash[32], cap_id,
 * epoch, k_fixed) for a single sealed event.  Entries are linked via
 * the running root hash: root_n = sha256(root_{n-1} || entry_n).  The
 * witness chain root attests the entire sequence.
 *
 * Phase C: chain stored in module-scope buffer (4096 entries × 56
 * bytes = 224 KB).  Phase D rotates older entries to PFS via Sanctum
 * slot 8 (Phoenix bookmark).
 *
 * Hexad: kind_origin (Crown).  Ring: R-1.  K: 1.00.
 */

module sanctus_witness

extern @abi(c-msvc-x64) fn sha256_init() -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn sha256_update_byte(b: u32) -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn sha256_finalize_internal() -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn sha256_digest_byte(i: u32) -> u32 from "sha256.iii"

const WITNESS_MAX_ENTRIES : u32 = 1024u32

/* Entry layout (56 bytes):
 *   off  type  field
 *    0   u8[32]  mhash
 *   32   u64     cap_id
 *   40   u64     epoch
 *   48   u64     k_fixed
 */
const WITNESS_ENTRY_BYTES : u32 = 56u32

var WITNESS_ENTRIES : [u8; 57344]    /* 1024 × 56                    */
var WITNESS_ROOT    : [u8; 32]        /* running root hash             */
var WITNESS_COUNT   : u32 = 0u32
var WITNESS_INIT    : u8 = 0u8

const WITNESS_OK         : i32 = 0i32
const WITNESS_E_FULL     : i32 = -1i32
const WITNESS_E_BADIDX   : i32 = -2i32

/* --- Entry-byte accessors --- */

fn witness_load_byte(entry_idx: u32, byte_off: u32) -> u8 {
    let abs_off : u32 = entry_idx * WITNESS_ENTRY_BYTES + byte_off
    return WITNESS_ENTRIES[abs_off]
}

fn witness_store_byte(entry_idx: u32, byte_off: u32, v: u8) -> u32 {
    let abs_off : u32 = entry_idx * WITNESS_ENTRY_BYTES + byte_off
    WITNESS_ENTRIES[abs_off] = v
    return 0u32
}

fn witness_store_u64_le(entry_idx: u32, byte_off: u32, v: u64) -> u32 {
    let mut i : u32 = 0u32
    while i < 8u32 {
        let shift : u64 = (i as u64) * 8u64
        let b : u8 = ((v >> shift) & 0xFFu64) as u8
        witness_store_byte(entry_idx, byte_off + i, b)
        i = i + 1u32
    }
    return 0u32
}

fn witness_load_u64_le(entry_idx: u32, byte_off: u32) -> u64 {
    let mut v : u64 = 0u64
    let mut i : u32 = 0u32
    while i < 8u32 {
        let b : u64 = witness_load_byte(entry_idx, byte_off + i) as u64
        let shift : u64 = (i as u64) * 8u64
        v = v | (b << shift)
        i = i + 1u32
    }
    return v
}

/* --- Init: zero the running root --- */

fn witness_init() -> u32 @export {
    if WITNESS_INIT == 1u8 { return 0u32 }
    let mut i : u32 = 0u32
    while i < 32u32 {
        WITNESS_ROOT[i] = 0u8
        i = i + 1u32
    }
    WITNESS_COUNT = 0u32
    WITNESS_INIT = 1u8
    return 0u32
}

/* --- Update root: root_new = sha256(root_old || entry) --- */

fn witness_update_root(entry_idx: u32) -> u32 {
    sha256_init()
    /* Feed previous root */
    let mut i : u32 = 0u32
    while i < 32u32 {
        sha256_update_byte(WITNESS_ROOT[i] as u32)
        i = i + 1u32
    }
    /* Feed entry bytes */
    let mut j : u32 = 0u32
    while j < WITNESS_ENTRY_BYTES {
        sha256_update_byte(witness_load_byte(entry_idx, j) as u32)
        j = j + 1u32
    }
    sha256_finalize_internal()
    let mut k : u32 = 0u32
    while k < 32u32 {
        WITNESS_ROOT[k] = (sha256_digest_byte(k) & 0xFFu32) as u8
        k = k + 1u32
    }
    return 0u32
}

/* --- Append: caller provides 32-byte mhash + cap + epoch + k --- */

fn witness_append(mhash_ptr: u64, cap_id: u64, epoch: u64) -> i32 @export {
    witness_init()
    if WITNESS_COUNT >= WITNESS_MAX_ENTRIES { return WITNESS_E_FULL }
    let idx : u32 = WITNESS_COUNT
    /* Copy mhash bytes */
    let mp : *u8 = mhash_ptr as *u8
    let mut i : u32 = 0u32
    while i < 32u32 {
        let v : u8 = mp[i as u64]
        witness_store_byte(idx, i, v)
        i = i + 1u32
    }
    witness_store_u64_le(idx, 32u32, cap_id)
    witness_store_u64_le(idx, 40u32, epoch)
    witness_store_u64_le(idx, 48u32, 0u64)
    witness_update_root(idx)
    WITNESS_COUNT = WITNESS_COUNT + 1u32
    return WITNESS_OK
}

/* Append with explicit K (fixed-point × 1e9). */
fn witness_append_k(mhash_ptr: u64, cap_id: u64, k_fixed: u64) -> i32 @export {
    witness_init()
    if WITNESS_COUNT >= WITNESS_MAX_ENTRIES { return WITNESS_E_FULL }
    let idx : u32 = WITNESS_COUNT
    let mp : *u8 = mhash_ptr as *u8
    let mut i : u32 = 0u32
    while i < 32u32 {
        let v : u8 = mp[i as u64]
        witness_store_byte(idx, i, v)
        i = i + 1u32
    }
    witness_store_u64_le(idx, 32u32, cap_id)
    witness_store_u64_le(idx, 40u32, 0u64)
    witness_store_u64_le(idx, 48u32, k_fixed)
    witness_update_root(idx)
    WITNESS_COUNT = WITNESS_COUNT + 1u32
    return WITNESS_OK
}

/* --- Queries --- */

fn witness_count() -> u32 @export {
    return WITNESS_COUNT
}

/* Free witness slots remaining before the chain is full.  Authoritative headroom query --
 * lets a caller pre-flight a batch of N appends (all-or-nothing) instead of discovering
 * WITNESS_E_FULL mid-batch and leaving a partial record.  WITNESS_COUNT never exceeds the
 * cap (every append guards it), so the subtraction cannot underflow; the guard is belt-and-braces. */
fn witness_remaining() -> u32 @export {
    if WITNESS_COUNT >= WITNESS_MAX_ENTRIES { return 0u32 }
    return WITNESS_MAX_ENTRIES - WITNESS_COUNT
}

fn witness_root_byte(i: u32) -> u32 @export {
    if i >= 32u32 { return 0x100u32 }
    return WITNESS_ROOT[i] as u32
}

fn witness_entry_mhash_byte(idx: u32, i: u32) -> u32 @export {
    if idx >= WITNESS_COUNT { return 0x100u32 }
    if i >= 32u32 { return 0x100u32 }
    return witness_load_byte(idx, i) as u32
}

fn witness_entry_cap(idx: u32) -> u64 @export {
    if idx >= WITNESS_COUNT { return 0u64 }
    return witness_load_u64_le(idx, 32u32)
}

fn witness_entry_epoch(idx: u32) -> u64 @export {
    if idx >= WITNESS_COUNT { return 0u64 }
    return witness_load_u64_le(idx, 40u32)
}

fn witness_entry_k(idx: u32) -> u64 @export {
    if idx >= WITNESS_COUNT { return 0u64 }
    return witness_load_u64_le(idx, 48u32)
}

/* --- Verify: replay the chain from a fresh zero root and compare --- */

var WITNESS_SAVED_ROOT : [u8; 32]
var WITNESS_REPLAY_ROOT : [u8; 32]

fn witness_replay_update(entry_idx: u32) -> u32 {
    sha256_init()
    let mut i : u32 = 0u32
    while i < 32u32 {
        sha256_update_byte(WITNESS_REPLAY_ROOT[i] as u32)
        i = i + 1u32
    }
    let mut j : u32 = 0u32
    while j < WITNESS_ENTRY_BYTES {
        sha256_update_byte(witness_load_byte(entry_idx, j) as u32)
        j = j + 1u32
    }
    sha256_finalize_internal()
    let mut k : u32 = 0u32
    while k < 32u32 {
        WITNESS_REPLAY_ROOT[k] = (sha256_digest_byte(k) & 0xFFu32) as u8
        k = k + 1u32
    }
    return 0u32
}

fn witness_verify_chain() -> u8 @export {
    /* Save current root and replay the chain from zero. */
    let mut i : u32 = 0u32
    while i < 32u32 {
        WITNESS_SAVED_ROOT[i] = WITNESS_ROOT[i]
        WITNESS_REPLAY_ROOT[i] = 0u8
        i = i + 1u32
    }
    let mut idx : u32 = 0u32
    while idx < WITNESS_COUNT {
        witness_replay_update(idx)
        idx = idx + 1u32
    }
    let mut j : u32 = 0u32
    while j < 32u32 {
        if WITNESS_SAVED_ROOT[j] != WITNESS_REPLAY_ROOT[j] { return 0u8 }
        j = j + 1u32
    }
    return 1u8
}

/* ─── witness_append_ripple (lattice plan Step 0020) ────────────────
 *
 * Append a witness record reserved for ripple events.  Uses the
 * dedicated cap_id range 0xFFFFFF00 (so verifiers can distinguish
 * "ripple-event" witnesses from cycle witnesses without parsing the
 * record body) and stores the ripple_result crystal_id in the
 * k_fixed slot as a traceability side-channel.
 *
 * Returns WITNESS_OK or whatever witness_append_k returns on overflow.
 */

const WITNESS_RIPPLE_CAP_BASE : u64 = 0xFFFFFF00u64

fn witness_append_ripple(mhash_ptr: u64, ripple_result: u64) -> i32 @export {
    return witness_append_k(mhash_ptr, WITNESS_RIPPLE_CAP_BASE, ripple_result)
}

/* ─── witness_append_resolution (FROZEN SPEC §3.2 sanctus/witness.iii,
 * step R0026) ──────────────────────────────────────────────────────
 *
 * Append a witness for a resolve() call. The intent_id is stored in
 * the k_fixed slot's high 32 bits as a side-channel; the low 32 bits
 * carry the K-value.  This preserves the existing 56-byte entry layout
 * while making the intent_id recoverable on read-back.
 *
 * Returns WITNESS_OK or witness_append_k's return code.
 */
const WITNESS_RESOLVE_CAP_BASE : u64 = 0xFFFFFE00u64

fn witness_append_resolution(mhash_ptr: u64, cap_id: u64, k_fixed: u64, intent_id: u64) -> i32 @export {
    /* Pack: intent_id in high 32 bits, k_fixed in low 32 bits. */
    let k_low : u64 = k_fixed & 0xFFFFFFFFu64
    let i_high : u64 = (intent_id & 0xFFFFFFFFu64) << 32u64
    let combined : u64 = k_low | i_high
    return witness_append_k(mhash_ptr, cap_id, combined)
}
