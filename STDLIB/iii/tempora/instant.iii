/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\tempora\instant.iii
 *
 * III STDLIB - tempora::instant  (P4.2: C-SEPARATED, deterministic)
 *
 * Sealed monotonic instant backed by a DETERMINISTIC LOGICAL counter -- no OS
 * clock, no kernel32, no msvcrt.  Each instant carries a u64 logical tick +
 * per-process epoch + cap_id + a 16-byte seal = sha256(tick || epoch || cap).
 *
 * Why logical, not wall-clock: III is fully deterministic, and real wall-clock
 * time is a nondeterminism source that must not drive deterministic logic.  The
 * former Win32 GetTickCount64 backing was exactly such a leak.  A monotonic
 * counter preserves ordering + sealing + tamper-evidence (everything consumers
 * actually need) while being bit-identical/reproducible.  Genuine wall-clock, if
 * ever required, is a separate explicitly-typed nondeterministic effect.
 *
 * The sha256 used here goes through the internal-finalize / digest-byte pair
 * because we cannot legally pass a pointer to module-scope INSTANT_SEAL under
 * the iiis-2 address-of-global quirk (W3).
 *
 * APOTHEOSIS S.7 (ADR-S7a): liveness + slot dispatch are DELEGATED to the one
 * handle organ (memoria/tempaloc.iii).  The former private INSTANT_LIVE table
 * is gone; an instant id is now a tempaloc handle tagged TYPE_INSTANT, so it
 * can no longer be confused with a region/deadline id.  instant keeps only its
 * own DATA arrays (tick/epoch/cap/seal), indexed by the local slot tempaloc
 * returns -- tempaloc's INSTANT sub-range scans low-to-high exactly as the old
 * INSTANT_LIVE scan did, so allocation order is unchanged.
 *
 * Hexad: kind_motion.  Ring: R-1.  K: 1.00 (deterministic logical clock).
 */

module tempora_instant

extern @abi(c-msvc-x64) fn cap_verify_rights(id: u64, required: u64) -> u8 from "capability.iii"
extern @abi(c-msvc-x64) fn sha256_init() -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn sha256_update_byte(b: u32) -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn sha256_finalize_internal() -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn sha256_digest_byte(i: u32) -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn tempaloc_alloc(type_tag: u64) -> u64 from "tempaloc.iii"
extern @abi(c-msvc-x64) fn tempaloc_slot_of(handle: u64, expected_type: u64) -> u32 from "tempaloc.iii"
extern @abi(c-msvc-x64) fn tempaloc_free(handle: u64, expected_type: u64) -> i32 from "tempaloc.iii"

const INSTANT_INVALID : u64 = 0u64

/* From capability.iii: bit 8 = time_read */
const INSTANT_RIGHT_TIME : u64 = 0x0100u64

const INSTANT_MAX_INSTANCES : u32 = 256u32

/* Must match tempaloc.iii TEMPALOC_TYPE_INSTANT. */
const INSTANT_TYPE : u64 = 2u64

var INSTANT_TICK  : [u64; 256]
var INSTANT_EPOCH : [u64; 256]
var INSTANT_CAP   : [u64; 256]
var INSTANT_SEAL  : [u8;  4096]   /* 256 instants × 16 bytes */

var INSTANT_PROCESS_EPOCH : u64 = 0u64
var INSTANT_EPOCH_INITED  : u8 = 0u8

/* The deterministic logical clock: a strictly-monotonic per-process counter.
 * Each read advances it by one, so successive instants are strictly ordered. */
var INSTANT_LOGICAL : u64 = 0u64

fn instant_logical_next() -> u64 {
    INSTANT_LOGICAL = INSTANT_LOGICAL + 1u64
    return INSTANT_LOGICAL
}

fn instant_slot_of(id: u64) -> u32 {
    return tempaloc_slot_of(id, INSTANT_TYPE)
}

fn instant_init_epoch() -> u32 {
    if INSTANT_EPOCH_INITED == 1u8 { return 0u32 }
    INSTANT_PROCESS_EPOCH = instant_logical_next()
    INSTANT_EPOCH_INITED = 1u8
    return 0u32
}

/* Compute the 16-byte seal for a slot.  Stored at INSTANT_SEAL[slot*16..]. */
fn instant_seal_compute(slot: u32) -> u32 {
    let tick : u64 = INSTANT_TICK[slot]
    let epoch : u64 = INSTANT_EPOCH[slot]
    let cap : u64 = INSTANT_CAP[slot]
    sha256_init()
    let mut i : u32 = 0u32
    while i < 8u32 {
        let shift : u64 = (i as u64) * 8u64
        sha256_update_byte(((tick >> shift) & 0xFFu64) as u32)
        i = i + 1u32
    }
    let mut j : u32 = 0u32
    while j < 8u32 {
        let shift : u64 = (j as u64) * 8u64
        sha256_update_byte(((epoch >> shift) & 0xFFu64) as u32)
        j = j + 1u32
    }
    let mut k : u32 = 0u32
    while k < 8u32 {
        let shift : u64 = (k as u64) * 8u64
        sha256_update_byte(((cap >> shift) & 0xFFu64) as u32)
        k = k + 1u32
    }
    sha256_finalize_internal()
    let off : u32 = slot * 16u32
    let mut p : u32 = 0u32
    while p < 16u32 {
        INSTANT_SEAL[off + p] = (sha256_digest_byte(p) & 0xFFu32) as u8
        p = p + 1u32
    }
    return 0u32
}

fn instant_now_sealed(time_cap: u64) -> u64 @export {
    if cap_verify_rights(time_cap, INSTANT_RIGHT_TIME) == 0u8 { return INSTANT_INVALID }
    instant_init_epoch()
    let id : u64 = tempaloc_alloc(INSTANT_TYPE)
    if id == 0u64 { return INSTANT_INVALID }
    let s : u32 = tempaloc_slot_of(id, INSTANT_TYPE)
    if s == 0xFFFFFFFFu32 { return INSTANT_INVALID }
    let tick : u64 = instant_logical_next()
    INSTANT_TICK[s]  = tick
    INSTANT_EPOCH[s] = INSTANT_PROCESS_EPOCH
    INSTANT_CAP[s]   = time_cap
    instant_seal_compute(s)
    return id
}

fn instant_tick(id: u64) -> u64 @export {
    let s : u32 = instant_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0u64 }
    return INSTANT_TICK[s]
}

fn instant_epoch(id: u64) -> u64 @export {
    let s : u32 = instant_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0u64 }
    return INSTANT_EPOCH[s]
}

fn instant_seal_byte(id: u64, i: u32) -> u32 @export {
    let s : u32 = instant_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0x100u32 }
    if i >= 16u32 { return 0x100u32 }
    let off : u32 = s * 16u32
    return INSTANT_SEAL[off + i] as u32
}

/* Verify the cached seal still matches a recomputation.  Tampering with
 * INSTANT_TICK/EPOCH/CAP for a slot is detected here. */
fn instant_verify(id: u64) -> u8 @export {
    let s : u32 = instant_slot_of(id)
    if s == 0xFFFFFFFFu32 { return 0u8 }
    let tick : u64 = INSTANT_TICK[s]
    let epoch : u64 = INSTANT_EPOCH[s]
    let cap : u64 = INSTANT_CAP[s]
    sha256_init()
    let mut i : u32 = 0u32
    while i < 8u32 {
        let shift : u64 = (i as u64) * 8u64
        sha256_update_byte(((tick >> shift) & 0xFFu64) as u32)
        i = i + 1u32
    }
    let mut j : u32 = 0u32
    while j < 8u32 {
        let shift : u64 = (j as u64) * 8u64
        sha256_update_byte(((epoch >> shift) & 0xFFu64) as u32)
        j = j + 1u32
    }
    let mut k : u32 = 0u32
    while k < 8u32 {
        let shift : u64 = (k as u64) * 8u64
        sha256_update_byte(((cap >> shift) & 0xFFu64) as u32)
        k = k + 1u32
    }
    sha256_finalize_internal()
    let off : u32 = s * 16u32
    let mut p : u32 = 0u32
    while p < 16u32 {
        let stored : u8 = INSTANT_SEAL[off + p]
        let fresh : u32 = sha256_digest_byte(p) & 0xFFu32
        if (stored as u32) != fresh { return 0u8 }
        p = p + 1u32
    }
    return 1u8
}

fn instant_diff_ticks(later: u64, earlier: u64) -> u64 @export {
    let sl : u32 = instant_slot_of(later)
    let se : u32 = instant_slot_of(earlier)
    if sl == 0xFFFFFFFFu32 { return 0u64 }
    if se == 0xFFFFFFFFu32 { return 0u64 }
    let tl : u64 = INSTANT_TICK[sl]
    let te : u64 = INSTANT_TICK[se]
    if tl < te { return 0u64 }
    return tl - te
}

fn instant_drop(id: u64) -> i32 @export {
    let s : u32 = instant_slot_of(id)
    if s == 0xFFFFFFFFu32 { return -1i32 }
    INSTANT_TICK[s]  = 0u64
    INSTANT_EPOCH[s] = 0u64
    INSTANT_CAP[s]   = 0u64
    tempaloc_free(id, INSTANT_TYPE)
    return 0i32
}
