/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\verba\csv.iii
 *
 * III STDLIB - verba::csv
 *
 * RFC 4180 CSV parser.  Comma-separated, CRLF (or LF) row terminators,
 * double-quote field quoting with embedded "" → ".
 *
 * Public API:
 *   csv_parse(arena:u64, raw_base:u64, raw_len:u64) -> u64
 *      Returns 1-indexed table id, 0 on failure.
 *   csv_row_count(id:u64) -> u64
 *   csv_field_count(id:u64, row:u64) -> u64
 *   csv_field_base(id:u64, row:u64, col:u64) -> u64
 *   csv_field_len(id:u64, row:u64, col:u64) -> u64
 *   csv_drop(id:u64) -> i32
 *
 * Storage: parallel slot arrays for tables; per-cell parallel arrays
 * indexed by (row * MAX_COLS + col).
 *
 * Hexad: kind_form.  Ring: R3.  K: 0.95.
 */

module verba_csv

const CSV_OK : i32 = 0i32
const CSV_E_BADID : i32 = -1i32
const CSV_E_TOOMANY : i32 = -2i32

const CSV_TABLE_MAX : u32 = 16u32
const CSV_ROW_MAX   : u64 = 1024u64
const CSV_COL_MAX   : u64 = 32u64
const CSV_CELL_MAX  : u64 = 32768u64    /* 1024 * 32 */

var CSV_ROW_COUNT : [u64; 16]
var CSV_LIVE      : [u8;  16]

/* Per-cell storage: row r col c -> index (r * 32 + c) within a table.
 * Tables are indexed 0..CSV_TABLE_MAX-1; the per-cell arrays are
 * sized for table 0..15 with row 0..1023 col 0..31. */
var CSV_FIELD_BASE : [u64; 524288]   /* 16 * 1024 * 32 */
var CSV_FIELD_LEN  : [u64; 524288]
var CSV_COL_COUNT  : [u64; 16384]    /* 16 * 1024 -- col count per row */

fn csv_alloc_slot() -> u32 {
    let mut i : u32 = 0u32
    while i < CSV_TABLE_MAX {
        if CSV_LIVE[i] == 0u8 {
            CSV_LIVE[i] = 1u8
            CSV_ROW_COUNT[i] = 0u64
            return i
        }
        i = i + 1u32
    }
    return CSV_TABLE_MAX
}

fn csv_resolve(id: u64) -> u32 {
    if id == 0u64 { return CSV_TABLE_MAX }
    let idx_u64 : u64 = id - 1u64
    if idx_u64 >= (CSV_TABLE_MAX as u64) { return CSV_TABLE_MAX }
    let idx : u32 = idx_u64 as u32
    if CSV_LIVE[idx] == 0u8 { return CSV_TABLE_MAX }
    return idx
}

fn csv_field_index(table_idx: u32, row: u64, col: u64) -> u64 {
    return (table_idx as u64) * 1024u64 * 32u64 + row * 32u64 + col
}

fn csv_row_col_index(table_idx: u32, row: u64) -> u64 {
    return (table_idx as u64) * 1024u64 + row
}

/* arena is accepted for API symmetry with the other verba parsers but is currently UNUSED:
 * csv_parse stores into fixed module-scope tables (CSV_*), not arena memory.  Reserved for a
 * future arena-backed table; kept in the signature so call sites do not churn. */
fn csv_parse(arena: u64, raw_base: u64, raw_len: u64) -> u64 @export {
    let table : u32 = csv_alloc_slot()
    if table >= CSV_TABLE_MAX { return 0u64 }
    let p : *u8 = raw_base as *u8
    let mut pos : u64 = 0u64
    let mut row : u64 = 0u64
    let mut col : u64 = 0u64
    while pos < raw_len {
        if row >= CSV_ROW_MAX {
            CSV_LIVE[table] = 0u8
            return 0u64
        }
        if col >= CSV_COL_MAX {
            CSV_LIVE[table] = 0u8
            return 0u64
        }
        let b : u32 = p[pos] as u32
        let mut field_start : u64 = pos
        let mut field_len : u64 = 0u64
        let mut quoted : u8 = 0u8
        if b == 34u32 {
            /* Quoted field */
            quoted = 1u8
            pos = pos + 1u64
            field_start = pos
            /* Allocate temp buffer for unescaped content; for simplicity
             * we point to raw bytes and accept that "" sequences will
             * appear as " in the spans (consumer can handle). */
            let mut going : u8 = 1u8
            while going == 1u8 {
                if pos >= raw_len { going = 0u8 }
                if going == 1u8 {
                    if p[pos] == 34u8 {
                        /* A quote: "" is an escaped quote (consume both, keep going);
                         * a LONE quote -- including one at the final byte -- is the
                         * closing quote.  The prior FSM mis-split `"ab""cd"` and never
                         * closed a quote at end-of-buffer.  [audit H-CSV-1/2] */
                        let mut esc : u8 = 0u8
                        if pos + 1u64 < raw_len { if p[pos + 1u64] == 34u8 { esc = 1u8 } }
                        if esc == 1u8 { pos = pos + 2u64 } else { going = 0u8 }
                    } else {
                        pos = pos + 1u64
                    }
                }
            }
            field_len = pos - field_start
            if pos < raw_len {
                if p[pos] == 34u8 { pos = pos + 1u64 }   /* skip closing quote */
            }
        } else {
            /* Unquoted field: until ',' or CR/LF or EOF */
            let mut going : u8 = 1u8
            while going == 1u8 {
                if pos >= raw_len { going = 0u8 }
                if going == 1u8 {
                    let c : u32 = p[pos] as u32
                    if c == 44u32 { going = 0u8 }      /* , */
                    if c == 13u32 { going = 0u8 }      /* CR */
                    if c == 10u32 { going = 0u8 }      /* LF */
                    if going == 1u8 { pos = pos + 1u64 }
                }
            }
            field_len = pos - field_start
        }
        /* Store field */
        let fi : u64 = csv_field_index(table, row, col)
        CSV_FIELD_BASE[fi] = raw_base + field_start
        CSV_FIELD_LEN[fi]  = field_len
        col = col + 1u64
        let rc_idx : u64 = csv_row_col_index(table, row)
        CSV_COL_COUNT[rc_idx] = col
        /* Look at separator */
        if pos < raw_len {
            let s : u32 = p[pos] as u32
            if s == 44u32 {
                pos = pos + 1u64
                /* Continue same row, next column */
            }
            if s == 13u32 {
                pos = pos + 1u64
                if pos < raw_len {
                    if p[pos] == 10u8 { pos = pos + 1u64 }
                }
                row = row + 1u64
                col = 0u64
            }
            if s == 10u32 {
                pos = pos + 1u64
                row = row + 1u64
                col = 0u64
            }
        }
    }
    /* If last field didn't end with newline, count the row anyway */
    if col > 0u64 {
        row = row + 1u64
    }
    CSV_ROW_COUNT[table] = row
    return (table as u64) + 1u64
}

fn csv_row_count(id: u64) -> u64 @export {
    let idx : u32 = csv_resolve(id)
    if idx == CSV_TABLE_MAX { return 0u64 }
    return CSV_ROW_COUNT[idx]
}

fn csv_field_count(id: u64, row: u64) -> u64 @export {
    let idx : u32 = csv_resolve(id)
    if idx == CSV_TABLE_MAX { return 0u64 }
    if row >= CSV_ROW_COUNT[idx] { return 0u64 }
    return CSV_COL_COUNT[csv_row_col_index(idx, row)]
}

fn csv_field_base(id: u64, row: u64, col: u64) -> u64 @export {
    let idx : u32 = csv_resolve(id)
    if idx == CSV_TABLE_MAX { return 0u64 }
    /* BATCH 4 at-scale: bound row,col on untrusted input (was UNGUARDED -> csv_field_index could
     * exceed CSV_FIELD_BASE[524288] -> OOB read).  Mirrors csv_field_count's guarding so the getter
     * is consistent with its sibling: 0 for any non-existent field, never an out-of-bounds read. */
    if row >= CSV_ROW_COUNT[idx] { return 0u64 }
    if col >= CSV_COL_COUNT[csv_row_col_index(idx, row)] { return 0u64 }
    return CSV_FIELD_BASE[csv_field_index(idx, row, col)]
}

fn csv_field_len(id: u64, row: u64, col: u64) -> u64 @export {
    let idx : u32 = csv_resolve(id)
    if idx == CSV_TABLE_MAX { return 0u64 }
    /* BATCH 4 at-scale: same bounds guard as csv_field_base (was UNGUARDED -> OOB read). */
    if row >= CSV_ROW_COUNT[idx] { return 0u64 }
    if col >= CSV_COL_COUNT[csv_row_col_index(idx, row)] { return 0u64 }
    return CSV_FIELD_LEN[csv_field_index(idx, row, col)]
}

/* Copy a field span into out_ptr, collapsing each escaped "" to a single " (RFC 4180
 * quoted-field unescaping).  csv_parse stores the RAW span (it explicitly punts the
 * "" -> " collapse to the consumer); this is that consumer.  Returns the unescaped
 * byte count, 0 for an empty/absent field, or -1 on bad id / out-of-range / out_cap
 * overflow.  Same bounds guards as csv_field_base/_len. */
fn csv_field_unescaped(id: u64, row: u64, col: u64, out_ptr: u64, out_cap: u64) -> i64 @export {
    let idx : u32 = csv_resolve(id)
    if idx == CSV_TABLE_MAX { return -1i64 }
    if row >= CSV_ROW_COUNT[idx] { return -1i64 }
    if col >= CSV_COL_COUNT[csv_row_col_index(idx, row)] { return -1i64 }
    let fi : u64 = csv_field_index(idx, row, col)
    let base : u64 = CSV_FIELD_BASE[fi]
    let len : u64 = CSV_FIELD_LEN[fi]
    if base == 0u64 { return 0i64 }
    let sp : *u8 = base as *u8
    let op : *u8 = out_ptr as *u8
    let mut i : u64 = 0u64
    let mut wr : u64 = 0u64
    while i < len {
        let c : u8 = sp[i]
        let mut step : u64 = 1u64
        if c == 0x22u8 {
            if (i + 1u64) < len { if sp[i + 1u64] == 0x22u8 { step = 2u64 } }
        }
        if wr >= out_cap { return -1i64 }
        op[wr] = c
        wr = wr + 1u64
        i = i + step
    }
    return wr as i64
}

fn csv_drop(id: u64) -> i32 @export {
    let idx : u32 = csv_resolve(id)
    if idx == CSV_TABLE_MAX { return CSV_E_BADID }
    CSV_LIVE[idx] = 0u8
    return CSV_OK
}
