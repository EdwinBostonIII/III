/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\verba\glyph_crystal.iii
 *
 * III STDLIB - verba::glyph_crystal -- Glyph V3 form for sealed crystal_id.
 *
 * Lattice plan Phase 14h Step 0177.  Encodes a crystal reference:
 *   payload[ 0.. 7]  crystal_id          (u64 LE)
 *   payload[ 8..15]  parent_crystal_id   (u64 LE; 0 if no parent)
 *   payload[16..19]  error_code          (u32 LE)
 *   payload[20..23]  edge_count          (u32 LE; informational)
 *   payload[24..51]  reserved (28 bytes, zero-padded)
 *
 * payload_len = 24.
 *
 * Public surface:
 *   glyph_crystal_form_id()                                                 -> u32 (0x40)
 *   glyph_crystal_pack(crystal_id, parent_id, error_code, edge_count, out)  -> i32
 *   glyph_crystal_unpack_id(in_192)                                         -> u64
 *   glyph_crystal_unpack_parent(in_192)                                     -> u64
 *   glyph_crystal_unpack_error_code(in_192)                                 -> u32
 *   glyph_crystal_unpack_edge_count(in_192)                                 -> u32
 *   glyph_crystal_validate(in_192)                                          -> u8
 *
 * Hexad: kind_form.  Ring: R3.  K: 1.00.
 */

module verba_glyph_crystal

extern @abi(c-msvc-x64) fn gv3_zero(p_192: u64) -> i32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_write_u32_le(p: u64, v: u32) -> i32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_write_u64_le(p: u64, v: u64) -> i32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_read_u32_le(p: u64) -> u32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_read_u64_le(p: u64) -> u64 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_compute_mhash(p_192: u64) -> i32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_validate(p_192: u64) -> u8 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_form_id(p_192: u64) -> u32 from "glyph_core.iii"

const GV3_FORM_CRYSTAL : u32 = 0x40u32

fn glyph_crystal_form_id() -> u32 @export { return GV3_FORM_CRYSTAL }

/* 4-u64-arg signature = composition-dispatch ABI: glyph_crystal_pack is
 * registered in iii_compositions.def and invoked via the prespec
 * fn(a,b,c,d:u64) trampoline, so it must take <=4 u64 args -- do NOT widen.
 * packed_err_edge = (error_code << 32) | edge_count; use
 * glyph_crystal_pack_meta to construct safely.  (The iiis-0 5+-arg trap
 * this also dodged is fixed -- Stage 3.9, corpus 277 -- but the packing
 * remains the composition ABI.) */
fn glyph_crystal_pack(crystal_id: u64, parent_id: u64, packed_err_edge: u64, out_192: u64) -> i32 @export {
    let c_l  : u64 = crystal_id
    let p_l  : u64 = parent_id
    let pe_l : u64 = packed_err_edge
    let o_l  : u64 = out_192
    let ec_l : u32 = ((pe_l >> 32u64) & 0xFFFFFFFFu64) as u32
    let nc_l : u32 = (pe_l & 0xFFFFFFFFu64) as u32
    if o_l == 0u64 { return -1i32 }
    gv3_zero(o_l)
    gv3_write_u32_le(o_l + 0u64, GV3_FORM_CRYSTAL)
    gv3_write_u32_le(o_l + 4u64, 24u32)
    gv3_write_u64_le(o_l + 8u64,        c_l)
    gv3_write_u64_le(o_l + 16u64,       p_l)
    gv3_write_u32_le(o_l + 24u64,       ec_l)
    gv3_write_u32_le(o_l + 28u64,       nc_l)
    gv3_compute_mhash(o_l)
    return 0i32
}

/* Convenience packer for callers building packed_err_edge inline. */
fn glyph_crystal_pack_meta(error_code: u32, edge_count: u32) -> u64 @export {
    let l_e : u64 = ((error_code as u64) & 0xFFFFFFFFu64) << 32u64
    let l_c : u64 = (edge_count as u64) & 0xFFFFFFFFu64
    return l_e | l_c
}

fn glyph_crystal_unpack_id(in_192: u64) -> u64 @export {
    let i_l : u64 = in_192
    if i_l == 0u64 { return 0u64 }
    if gv3_form_id(i_l) != GV3_FORM_CRYSTAL { return 0u64 }
    if gv3_validate(i_l) != 1u8 { return 0u64 }
    return gv3_read_u64_le(i_l + 8u64)
}

fn glyph_crystal_unpack_parent(in_192: u64) -> u64 @export {
    let i_l : u64 = in_192
    if i_l == 0u64 { return 0u64 }
    if gv3_form_id(i_l) != GV3_FORM_CRYSTAL { return 0u64 }
    if gv3_validate(i_l) != 1u8 { return 0u64 }
    return gv3_read_u64_le(i_l + 16u64)
}

fn glyph_crystal_unpack_error_code(in_192: u64) -> u32 @export {
    let i_l : u64 = in_192
    if i_l == 0u64 { return 0u32 }
    if gv3_form_id(i_l) != GV3_FORM_CRYSTAL { return 0u32 }
    if gv3_validate(i_l) != 1u8 { return 0u32 }
    return gv3_read_u32_le(i_l + 24u64)
}

fn glyph_crystal_unpack_edge_count(in_192: u64) -> u32 @export {
    let i_l : u64 = in_192
    if i_l == 0u64 { return 0u32 }
    if gv3_form_id(i_l) != GV3_FORM_CRYSTAL { return 0u32 }
    if gv3_validate(i_l) != 1u8 { return 0u32 }
    return gv3_read_u32_le(i_l + 28u64)
}

fn glyph_crystal_validate(in_192: u64) -> u8 @export {
    let i_l : u64 = in_192
    if i_l == 0u64 { return 0u8 }
    if gv3_form_id(i_l) != GV3_FORM_CRYSTAL { return 0u8 }
    return gv3_validate(i_l)
}
