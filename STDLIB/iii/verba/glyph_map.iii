/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\verba\glyph_map.iii
 *
 * III STDLIB - verba::glyph_map -- Glyph V3 form for homogeneous map.
 *
 * Lattice plan Phase 14h Step 0173.  Tightly-packed homogeneous map of
 * fixed-size keys to fixed-size values.  Inline storage only (≤ 140
 * bytes of pairs) for stage-0.
 *
 * Payload layout (form_id = 0x31):
 *   payload[0..3]    key_form_id   (u32 LE)
 *   payload[4..7]    val_form_id   (u32 LE)
 *   payload[8..11]   pair_count    (u32 LE)
 *   payload[12..151] packed (key, value) pairs (no inter-pair padding)
 *
 * payload_len = 12 + pair_count * (key_size + val_size).
 *
 * Public surface:
 *   glyph_map_form_id()                                                   -> u32 (0x31)
 *   glyph_map_pack(k_form, v_form, count, k_size, v_size, src, out)       -> i32
 *   glyph_map_unpack_count(in_192)                                        -> u32
 *   glyph_map_unpack_key_form(in_192)                                     -> u32
 *   glyph_map_unpack_val_form(in_192)                                     -> u32
 *   glyph_map_unpack_pairs(in_192, dst, dst_cap)                          -> i32
 *   glyph_map_validate(in_192)                                            -> u8
 *
 * Hexad: kind_form.  Ring: R3.  K: 1.00.
 */

module verba_glyph_map

extern @abi(c-msvc-x64) fn gv3_zero(p_192: u64) -> i32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_write_u32_le(p: u64, v: u32) -> i32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_read_u32_le(p: u64) -> u32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_compute_mhash(p_192: u64) -> i32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_validate(p_192: u64) -> u8 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_form_id(p_192: u64) -> u32 from "glyph_core.iii"
extern @abi(c-msvc-x64) fn gv3_payload_len(p_192: u64) -> u32 from "glyph_core.iii"

const GV3_FORM_MAP : u32 = 0x31u32

fn glyph_map_form_id() -> u32 @export { return GV3_FORM_MAP }

/* 4-u64-arg signature = composition-dispatch ABI: glyph_map_pack is
 * registered in iii_compositions.def and invoked via the prespec
 * fn(a,b,c,d:u64) trampoline, so it must take <=4 u64 args -- do NOT widen
 * (the trampoline passes 4 u64s; extra typed params would read garbage).
 * The original 6 meta-fields (key_form, val_form, pair_count, key_size,
 * val_size) are packed into 2 u64s:
 *   packed_forms = (val_form_id << 32) | key_form_id
 *   packed_sizes = (val_size << 48) | (key_size << 32) | pair_count
 *     pair_count fits in 32 bits; key_size + val_size in 16 each.
 * The pack body is inlined here.  (The iiis-0 5+-arg trap this also dodged
 * is independently fixed -- Stage 3.9, corpus 277 -- but the packing
 * remains the composition ABI.) */
fn glyph_map_pack(packed_forms: u64, packed_sizes: u64, src_packed_ptr: u64, out_192: u64) -> i32 @export {
    let pf   : u64 = packed_forms
    let ps   : u64 = packed_sizes
    let s_l  : u64 = src_packed_ptr
    let o_l  : u64 = out_192
    let kf_l : u32 = (pf & 0xFFFFFFFFu64) as u32
    let vf_l : u32 = ((pf >> 32u64) & 0xFFFFFFFFu64) as u32
    let pc_l : u32 = (ps & 0xFFFFFFFFu64) as u32
    let ks_l : u32 = ((ps >> 32u64) & 0xFFFFu64) as u32
    let vs_l : u32 = ((ps >> 48u64) & 0xFFFFu64) as u32
    if o_l == 0u64 { return -1i32 }
    if ks_l == 0u32 { return -2i32 }
    if vs_l == 0u32 { return -2i32 }
    if (ks_l + vs_l) > 140u32 { return -2i32 }
    if s_l == 0u64 {
        if pc_l != 0u32 { return -1i32 }
    }
    let pair_size : u32 = ks_l + vs_l
    let total : u64 = (pc_l as u64) * (pair_size as u64)
    if total > 140u64 { return -3i32 }
    gv3_zero(o_l)
    gv3_write_u32_le(o_l + 0u64,  GV3_FORM_MAP)
    gv3_write_u32_le(o_l + 4u64,  12u32 + (total as u32))
    gv3_write_u32_le(o_l + 8u64,  kf_l)
    gv3_write_u32_le(o_l + 12u64, vf_l)
    gv3_write_u32_le(o_l + 16u64, pc_l)
    if s_l != 0u64 {
        let sp : *u8 = s_l as *u8
        let dp : *u8 = (o_l + 20u64) as *u8
        let mut i : u64 = 0u64
        while i < total {
            dp[i] = sp[i]
            i = i + 1u64
        }
    }
    gv3_compute_mhash(o_l)
    return 0i32
}

/* Convenience packers. */
fn glyph_map_pack_forms(key_form_id: u32, val_form_id: u32) -> u64 @export {
    let l_k : u64 = (key_form_id as u64) & 0xFFFFFFFFu64
    let l_v : u64 = ((val_form_id as u64) & 0xFFFFFFFFu64) << 32u64
    return l_k | l_v
}

fn glyph_map_pack_sizes(pair_count: u32, key_size: u32, val_size: u32) -> u64 @export {
    let l_c : u64 = (pair_count as u64) & 0xFFFFFFFFu64
    let l_k : u64 = ((key_size as u64) & 0xFFFFu64) << 32u64
    let l_v : u64 = ((val_size as u64) & 0xFFFFu64) << 48u64
    return l_c | l_k | l_v
}

fn glyph_map_unpack_count(in_192: u64) -> u32 @export {
    let i_l : u64 = in_192
    if i_l == 0u64 { return 0u32 }
    if gv3_form_id(i_l) != GV3_FORM_MAP { return 0u32 }
    if gv3_validate(i_l) != 1u8 { return 0u32 }
    return gv3_read_u32_le(i_l + 16u64)
}

fn glyph_map_unpack_key_form(in_192: u64) -> u32 @export {
    let i_l : u64 = in_192
    if i_l == 0u64 { return 0u32 }
    if gv3_form_id(i_l) != GV3_FORM_MAP { return 0u32 }
    if gv3_validate(i_l) != 1u8 { return 0u32 }
    return gv3_read_u32_le(i_l + 8u64)
}

fn glyph_map_unpack_val_form(in_192: u64) -> u32 @export {
    let i_l : u64 = in_192
    if i_l == 0u64 { return 0u32 }
    if gv3_form_id(i_l) != GV3_FORM_MAP { return 0u32 }
    if gv3_validate(i_l) != 1u8 { return 0u32 }
    return gv3_read_u32_le(i_l + 12u64)
}

fn glyph_map_unpack_pairs(in_192: u64, dst_ptr: u64, dst_cap_bytes: u32) -> i32 @export {
    let i_l : u64 = in_192
    let d_l : u64 = dst_ptr
    let c_l : u32 = dst_cap_bytes
    if i_l == 0u64 { return -1i32 }
    if d_l == 0u64 { return -1i32 }
    if gv3_form_id(i_l) != GV3_FORM_MAP { return -2i32 }
    if gv3_validate(i_l) != 1u8 { return -3i32 }
    let plen : u32 = gv3_payload_len(i_l)
    if plen < 12u32 { return -4i32 }
    let pair_bytes : u32 = plen - 12u32
    if pair_bytes > c_l { return -5i32 }
    let sp : *u8 = (i_l + 20u64) as *u8
    let dp : *u8 = d_l as *u8
    let mut k : u64 = 0u64
    let n : u64 = (pair_bytes as u64) & 0xFFFFFFFFu64
    while k < n {
        dp[k] = sp[k]
        k = k + 1u64
    }
    return pair_bytes as i32
}

fn glyph_map_validate(in_192: u64) -> u8 @export {
    let i_l : u64 = in_192
    if i_l == 0u64 { return 0u8 }
    if gv3_form_id(i_l) != GV3_FORM_MAP { return 0u8 }
    return gv3_validate(i_l)
}
