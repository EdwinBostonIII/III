/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\verba\nl_lex.iii
 *
 * III STDLIB - verba::nl_lex (Phase E.1 of Intent Calculus v1.0)
 *
 * Deterministic lexer for the HIP NL surface. Maps a sealed lexicon
 * (~120 seed words; expandable to ~3000) to typed tokens. No
 * statistics. No fallbacks. A token is exactly one of:
 *
 *   NL_TOK_VERB / NOUN / ADJ / ADV / PREP / DET / ROLE
 *   NL_TOK_NUMBER       (integer literal in source)
 *   NL_TOK_STRING_LIT   ("..." or '...')
 *   NL_TOK_IDENT        (anything in word position not in lexicon)
 *   NL_TOK_PUNCT        (. , ; : ! ? ( ) [ ] { } -)
 *   NL_TOK_EOL          (end of utterance: '\n' or end of input)
 *
 * Token packing (u64):
 *   bits  0..7   : type
 *   bits  8..31  : word_id  (24 bits = 16M)
 *   bits 32..47  : span_start (u16, byte offset into source)
 *   bits 48..63  : span_end_exclusive (u16)
 *
 * Lookup: open-addressed hash table (4096 slots, FNV-1a 64-bit key).
 *
 * Hexad: kind_form (data artifact). Ring: R3. K: 1.00.
 */

module verba_nl_lex

const NL_TOK_VOID       : u8 =  0u8
const NL_TOK_VERB       : u8 =  1u8
const NL_TOK_NOUN       : u8 =  2u8
const NL_TOK_ADJ        : u8 =  3u8
const NL_TOK_ADV        : u8 =  4u8
const NL_TOK_PREP       : u8 =  5u8
const NL_TOK_DET        : u8 =  6u8
const NL_TOK_NUMBER     : u8 =  7u8
const NL_TOK_STRING_LIT : u8 =  8u8
const NL_TOK_IDENT      : u8 =  9u8
const NL_TOK_ROLE       : u8 = 10u8
const NL_TOK_PUNCT      : u8 = 11u8
const NL_TOK_EOL        : u8 = 12u8

const NL_LEXICON_CAP    : u32 = 4096u32
const NL_LEXICON_MASK   : u64 = 0xFFFu64    /* (CAP - 1) for index */
const NL_FNV_OFFSET     : u64 = 0xcbf29ce484222325u64
const NL_FNV_PRIME      : u64 = 0x100000001b3u64

const NL_LEX_OK         : i32 =  0i32
const NL_LEX_E_NULL     : i32 = -1i32
const NL_LEX_E_FULL     : i32 = -2i32
const NL_LEX_E_OVERFLOW : i32 = -3i32

/* Open-addressed hash table:
 *   NL_LEX_HASH[i]    : 0 = empty, otherwise FNV-1a key
 *   NL_LEX_TYPE[i]    : token type byte
 *   NL_LEX_WORD_ID[i] : monotonic word id
 */
var NL_LEX_HASH    : [u64; 4096]
var NL_LEX_TYPE    : [u8;  4096]
var NL_LEX_WORD_ID : [u32; 4096]
var NL_LEX_USED    : u32 = 0u32
var NL_LEX_INITED  : u8  = 0u8

/* ---------------- helpers ---------------- */

fn _nl_to_lower(b: u8) -> u8 {
    let l_b : u8 = b
    if l_b >= 65u8 {
        if l_b <= 90u8 { return l_b + 32u8 }
    }
    return l_b
}

fn _nl_is_digit(b: u8) -> u8 {
    let l_b : u8 = b
    if l_b >= 48u8 {
        if l_b <= 57u8 { return 1u8 }
    }
    return 0u8
}

fn _nl_is_alpha(b: u8) -> u8 {
    let l_b : u8 = b
    if l_b >= 65u8 {
        if l_b <= 90u8 { return 1u8 }
    }
    if l_b >= 97u8 {
        if l_b <= 122u8 { return 1u8 }
    }
    return 0u8
}

fn _nl_is_word_char(b: u8) -> u8 {
    let l_b : u8 = b
    if _nl_is_alpha(l_b) == 1u8 { return 1u8 }
    if l_b == 95u8 { return 1u8 }    /* '_' as word-internal */
    return 0u8
}

fn _nl_is_space(b: u8) -> u8 {
    let l_b : u8 = b
    if l_b == 32u8 { return 1u8 }
    if l_b == 9u8  { return 1u8 }
    if l_b == 13u8 { return 1u8 }
    return 0u8
}

fn _nl_is_punct(b: u8) -> u8 {
    let l_b : u8 = b
    if l_b == 46u8 { return 1u8 }   /* . */
    if l_b == 44u8 { return 1u8 }   /* , */
    if l_b == 59u8 { return 1u8 }   /* ; */
    if l_b == 58u8 { return 1u8 }   /* : */
    if l_b == 33u8 { return 1u8 }   /* ! */
    if l_b == 63u8 { return 1u8 }   /* ? */
    if l_b == 40u8 { return 1u8 }   /* ( */
    if l_b == 41u8 { return 1u8 }   /* ) */
    if l_b == 91u8 { return 1u8 }   /* [ */
    if l_b == 93u8 { return 1u8 }   /* ] */
    if l_b == 123u8 { return 1u8 }  /* { */
    if l_b == 125u8 { return 1u8 }  /* } */
    if l_b == 45u8 { return 1u8 }   /* - */
    return 0u8
}

/* FNV-1a over (lower-cased) bytes [start, end). */
fn _nl_fnv_lower(src: u64, start: u32, end: u32) -> u64 {
    let s_l : u64 = src
    let mut h : u64 = NL_FNV_OFFSET
    let mut i : u32 = start
    while i < end {
        let bp : *u8 = (s_l + (i as u64)) as *u8
        let bv : u8  = _nl_to_lower(bp[0u64])
        h = h ^ ((bv as u64) & 0xFFu64)
        h = h * NL_FNV_PRIME
        i = i + 1u32
    }
    return h
}

/* ---------------- registration ---------------- */

fn nl_lex_register_hash(hash: u64, type_id: u8, word_id: u32) -> i32 @export {
    let h_l : u64 = hash
    let t_l : u8  = type_id
    let w_l : u32 = word_id
    if h_l == 0u64 { return NL_LEX_E_NULL }
    if NL_LEX_USED >= NL_LEXICON_CAP { return NL_LEX_E_FULL }
    let mut idx : u32 = (h_l & NL_LEXICON_MASK) as u32
    let mut probes : u32 = 0u32
    while probes < NL_LEXICON_CAP {
        if NL_LEX_HASH[idx] == 0u64 {
            NL_LEX_HASH[idx]    = h_l
            NL_LEX_TYPE[idx]    = t_l
            NL_LEX_WORD_ID[idx] = w_l
            NL_LEX_USED = NL_LEX_USED + 1u32
            return NL_LEX_OK
        }
        if NL_LEX_HASH[idx] == h_l {
            /* Update in place. */
            NL_LEX_TYPE[idx]    = t_l
            NL_LEX_WORD_ID[idx] = w_l
            return NL_LEX_OK
        }
        idx = (idx + 1u32) & 0xFFFu32
        probes = probes + 1u32
    }
    return NL_LEX_E_FULL
}

fn nl_lex_lookup_hash(hash: u64) -> u64 @export {
    let h_l : u64 = hash
    if h_l == 0u64 { return 0u64 }
    let mut idx : u32 = (h_l & NL_LEXICON_MASK) as u32
    let mut probes : u32 = 0u32
    while probes < NL_LEXICON_CAP {
        let cur : u64 = NL_LEX_HASH[idx]
        if cur == 0u64 { return 0u64 }
        if cur == h_l {
            /* Pack (type << 24) | word_id. */
            let t_l : u64 = (NL_LEX_TYPE[idx] as u64) & 0xFFu64
            let w_l : u64 = (NL_LEX_WORD_ID[idx] as u64) & 0xFFFFFFu64
            return (t_l << 24u64) | w_l
        }
        idx = (idx + 1u32) & 0xFFFu32
        probes = probes + 1u32
    }
    return 0u64
}

fn nl_lex_used() -> u32 @export {
    return NL_LEX_USED
}

fn nl_lex_capacity() -> u32 @export {
    return NL_LEXICON_CAP
}

fn nl_lex_reset() -> i32 @export {
    let mut i : u32 = 0u32
    while i < NL_LEXICON_CAP {
        NL_LEX_HASH[i] = 0u64
        NL_LEX_TYPE[i] = 0u8
        NL_LEX_WORD_ID[i] = 0u32
        i = i + 1u32
    }
    NL_LEX_USED = 0u32
    NL_LEX_INITED = 0u8
    return NL_LEX_OK
}

/* ---------------- token packing ---------------- */

fn nl_token_pack(type_id: u8, word_id: u32, span_start: u32, span_end: u32) -> u64 @export {
    let t_l : u64 = (type_id as u64) & 0xFFu64
    let w_l : u64 = ((word_id as u64) & 0xFFFFFFu64) << 8u64
    let s_l : u64 = ((span_start as u64) & 0xFFFFu64) << 32u64
    let e_l : u64 = ((span_end as u64) & 0xFFFFu64) << 48u64
    return t_l | w_l | s_l | e_l
}

fn nl_token_type(tok: u64) -> u8 @export {
    return (tok & 0xFFu64) as u8
}

fn nl_token_word_id(tok: u64) -> u32 @export {
    return ((tok >> 8u64) & 0xFFFFFFu64) as u32
}

fn nl_token_span_start(tok: u64) -> u32 @export {
    return ((tok >> 32u64) & 0xFFFFu64) as u32
}

fn nl_token_span_end(tok: u64) -> u32 @export {
    return ((tok >> 48u64) & 0xFFFFu64) as u32
}

/* ---------------- tokenize ---------------- */

/* Token-emit helper: writes one token at out_tokens[idx]. Returns the
 * new token count (idx + 1), or 0xFFFFFFFFu32 on overflow. */
fn _nl_emit(out_tokens_ptr: u64, idx: u32, max_tokens: u32, tok: u64) -> u32 {
    let o_l : u64 = out_tokens_ptr
    let i_l : u32 = idx
    let m_l : u32 = max_tokens
    if i_l >= m_l { return 0xFFFFFFFFu32 }
    let pp : *u64 = (o_l + ((i_l as u64) * 8u64)) as *u64
    pp[0u64] = tok
    return i_l + 1u32
}

/* Consume a "..."-delimited string literal starting at byte i (which
 * must point to the opening quote). Returns the new byte position. */
fn _nl_scan_string(src_ptr: u64, i: u32, src_len: u32) -> u32 {
    let s_l : u64 = src_ptr
    let n_l : u32 = src_len
    let mut j : u32 = i + 1u32
    let mut going : u8 = 1u8
    while going == 1u8 {
        if j >= n_l {
            going = 0u8
        } else {
            let bx : *u8 = (s_l + (j as u64)) as *u8
            if bx[0u64] == 34u8 {
                going = 0u8
            } else {
                j = j + 1u32
            }
        }
    }
    if j < n_l { j = j + 1u32 }   /* consume closing quote */
    return j
}

/* Consume a digit run starting at i. Returns packed (new_i << 32) | value. */
fn _nl_scan_number(src_ptr: u64, i: u32, src_len: u32) -> u64 {
    let s_l : u64 = src_ptr
    let n_l : u32 = src_len
    let mut j : u32 = i
    let mut v : u32 = 0u32
    let mut going : u8 = 1u8
    while going == 1u8 {
        if j >= n_l {
            going = 0u8
        } else {
            let bd : *u8 = (s_l + (j as u64)) as *u8
            let dv : u8  = bd[0u64]
            if _nl_is_digit(dv) == 0u8 {
                going = 0u8
            } else {
                v = (v * 10u32) + ((dv - 48u8) as u32)
                j = j + 1u32
            }
        }
    }
    let new_i : u64 = (j as u64) & 0xFFFFFFFFu64
    let val_l : u64 = ((v as u64) & 0xFFFFFFu64) << 32u64
    return new_i | val_l
}

/* Consume a word run starting at i. Returns the new byte position. */
fn _nl_scan_word(src_ptr: u64, i: u32, src_len: u32) -> u32 {
    let s_l : u64 = src_ptr
    let n_l : u32 = src_len
    let mut j : u32 = i
    let mut going : u8 = 1u8
    while going == 1u8 {
        if j >= n_l {
            going = 0u8
        } else {
            let bw : *u8 = (s_l + (j as u64)) as *u8
            if _nl_is_word_char(bw[0u64]) == 0u8 {
                going = 0u8
            } else {
                j = j + 1u32
            }
        }
    }
    return j
}

/* nl_lex_tokenize: scans source [0..src_len); emits tokens into
 * out_tokens_ptr (must hold at least max_tokens u64 slots). Writes
 * the actual token count via out_count_ptr (u32 *).
 *
 * 4-arg signature (iiis-0 5+arg trap):
 *   packed_lens = (max_tokens << 32) | src_len
 *
 * Returns NL_LEX_OK on success; NL_LEX_E_OVERFLOW if max_tokens
 * exhausted. */
fn nl_lex_tokenize(src_ptr: u64, packed_lens: u64, out_tokens_ptr: u64, out_count_ptr: u64) -> i32 @export {
    let s_l : u64 = src_ptr
    let pl  : u64 = packed_lens
    let n_l : u32 = (pl & 0xFFFFFFFFu64) as u32
    let mt  : u32 = ((pl >> 32u64) & 0xFFFFFFFFu64) as u32
    let o_l : u64 = out_tokens_ptr
    let oc  : u64 = out_count_ptr
    if s_l == 0u64 { return NL_LEX_E_NULL }
    if o_l == 0u64 { return NL_LEX_E_NULL }
    if oc  == 0u64 { return NL_LEX_E_NULL }

    let mut i : u32 = 0u32
    let mut tcount : u32 = 0u32
    while i < n_l {
        let bp : *u8 = (s_l + (i as u64)) as *u8
        let b  : u8  = bp[0u64]

        if b == 10u8 {
            let tok : u64 = nl_token_pack(NL_TOK_EOL, 0u32, i, i + 1u32)
            tcount = _nl_emit(o_l, tcount, mt, tok)
            if tcount == 0xFFFFFFFFu32 { return NL_LEX_E_OVERFLOW }
            i = i + 1u32
        } else if _nl_is_space(b) == 1u8 {
            i = i + 1u32
        } else if b == 34u8 {
            let start_idx : u32 = i
            let end_idx : u32 = _nl_scan_string(s_l, i, n_l)
            let tok : u64 = nl_token_pack(NL_TOK_STRING_LIT, 0u32, start_idx, end_idx)
            tcount = _nl_emit(o_l, tcount, mt, tok)
            if tcount == 0xFFFFFFFFu32 { return NL_LEX_E_OVERFLOW }
            i = end_idx
        } else if _nl_is_punct(b) == 1u8 {
            let tok : u64 = nl_token_pack(NL_TOK_PUNCT, b as u32, i, i + 1u32)
            tcount = _nl_emit(o_l, tcount, mt, tok)
            if tcount == 0xFFFFFFFFu32 { return NL_LEX_E_OVERFLOW }
            i = i + 1u32
        } else if _nl_is_digit(b) == 1u8 {
            let nstart : u32 = i
            let packed : u64 = _nl_scan_number(s_l, i, n_l)
            let new_i : u32 = (packed & 0xFFFFFFFFu64) as u32
            let val   : u32 = ((packed >> 32u64) & 0xFFFFFFu64) as u32
            let tok : u64 = nl_token_pack(NL_TOK_NUMBER, val, nstart, new_i)
            tcount = _nl_emit(o_l, tcount, mt, tok)
            if tcount == 0xFFFFFFFFu32 { return NL_LEX_E_OVERFLOW }
            i = new_i
        } else if _nl_is_word_char(b) == 1u8 {
            let wstart : u32 = i
            let wend : u32 = _nl_scan_word(s_l, i, n_l)
            let h : u64 = _nl_fnv_lower(s_l, wstart, wend)
            let lookup : u64 = nl_lex_lookup_hash(h)
            let mut t_id : u8 = NL_TOK_IDENT
            let mut w_id : u32 = 0u32
            if lookup != 0u64 {
                t_id = ((lookup >> 24u64) & 0xFFu64) as u8
                w_id = (lookup & 0xFFFFFFu64) as u32
            }
            let tok : u64 = nl_token_pack(t_id, w_id, wstart, wend)
            tcount = _nl_emit(o_l, tcount, mt, tok)
            if tcount == 0xFFFFFFFFu32 { return NL_LEX_E_OVERFLOW }
            i = wend
        } else {
            i = i + 1u32
        }
    }

    /* Trailing EOL marker. */
    let tok_end : u64 = nl_token_pack(NL_TOK_EOL, 0u32, n_l, n_l)
    let after : u32 = _nl_emit(o_l, tcount, mt, tok_end)
    if after != 0xFFFFFFFFu32 { tcount = after }

    let cnt_p : *u32 = oc as *u32
    cnt_p[0u64] = tcount
    return NL_LEX_OK
}

/* ---------------- sealed lexicon init ---------------- */

/* Convenience packer for nl_lex_tokenize callers. */
fn nl_lex_pack_lens(src_len: u32, max_tokens: u32) -> u64 @export {
    let s_l : u64 = (src_len as u64) & 0xFFFFFFFFu64
    let m_l : u64 = ((max_tokens as u64) & 0xFFFFFFFFu64) << 32u64
    return s_l | m_l
}

fn nl_lex_init_all() -> i32 @export {
    if NL_LEX_INITED == 1u8 { return NL_LEX_OK }
    /* === VERB === */
    nl_lex_register_hash(0x2d1ff318d40c162fu64, 1u8, 1u32)   /* send */
    nl_lex_register_hash(0xd4e26318faaa79f7u64, 1u8, 2u32)   /* get */
    nl_lex_register_hash(0x77f370195699cdeeu64, 1u8, 3u32)   /* put */
    nl_lex_register_hash(0x4ce6531fbfddd605u64, 1u8, 4u32)   /* read */
    nl_lex_register_hash(0xb93a12b0d06caefcu64, 1u8, 5u32)   /* write */
    nl_lex_register_hash(0x44ee54ad76b0bd8eu64, 1u8, 6u32)   /* store */
    nl_lex_register_hash(0xce0eecad70f271e9u64, 1u8, 7u32)   /* load */
    nl_lex_register_hash(0x740cb4d2322f6882u64, 1u8, 8u32)   /* encrypt */
    nl_lex_register_hash(0x4c5f6d0e704b8ddau64, 1u8, 9u32)   /* decrypt */
    nl_lex_register_hash(0x2e3d9ecc741a7811u64, 1u8, 10u32)  /* hash */
    nl_lex_register_hash(0x4e0f7f18e637a364u64, 1u8, 11u32)  /* sign */
    nl_lex_register_hash(0x2d582147c78edbe4u64, 1u8, 12u32)  /* verify */
    nl_lex_register_hash(0xeb0e9ed12f553762u64, 1u8, 13u32)  /* allocate */
    nl_lex_register_hash(0xf84f97b4633670e9u64, 1u8, 14u32)  /* open */
    nl_lex_register_hash(0x9ec2699513c0f9c3u64, 1u8, 15u32)  /* close */
    nl_lex_register_hash(0x54cb3aded715c1b9u64, 1u8, 16u32)  /* connect */
    nl_lex_register_hash(0x5926cb82738c446bu64, 1u8, 17u32)  /* disconnect */
    nl_lex_register_hash(0xdc8acb313473c026u64, 1u8, 18u32)  /* listen */
    nl_lex_register_hash(0x7e5f7abe09509b09u64, 1u8, 19u32)  /* accept */
    nl_lex_register_hash(0x0c4e87a7a1f6fd8cu64, 1u8, 20u32)  /* parse */
    nl_lex_register_hash(0x64db608eefff5c72u64, 1u8, 21u32)  /* format */
    nl_lex_register_hash(0x56d12ea086274034u64, 1u8, 22u32)  /* compare */
    nl_lex_register_hash(0x0bf903911984eee4u64, 1u8, 23u32)  /* copy */
    nl_lex_register_hash(0x0d0f17a2c3f687b4u64, 1u8, 24u32)  /* move */
    nl_lex_register_hash(0xf3fe6b5fdb85d50au64, 1u8, 25u32)  /* delete */
    nl_lex_register_hash(0xf74e5feadea773fdu64, 1u8, 26u32)  /* create */
    nl_lex_register_hash(0x2fce30cb8e3c8185u64, 1u8, 27u32)  /* destroy */
    nl_lex_register_hash(0x2d08d918d3f90b20u64, 1u8, 28u32)  /* seal */
    nl_lex_register_hash(0x3cba013d62284d47u64, 1u8, 29u32)  /* unseal */
    nl_lex_register_hash(0x32bc902977d5212du64, 1u8, 30u32)  /* grant */
    nl_lex_register_hash(0x20ca489515cc42f3u64, 1u8, 31u32)  /* revoke */
    nl_lex_register_hash(0xf94d91246d8f61ddu64, 1u8, 32u32)  /* prove */
    nl_lex_register_hash(0xb1068f146c4596c3u64, 1u8, 33u32)  /* query */
    nl_lex_register_hash(0x62836442b3557916u64, 1u8, 34u32)  /* govern */
    nl_lex_register_hash(0x247a08a06a19f5f3u64, 1u8, 35u32)  /* compose */
    nl_lex_register_hash(0x95d7d72cdaba594au64, 1u8, 36u32)  /* reflect */
    nl_lex_register_hash(0xdec34c9bd0b6d2eeu64, 1u8, 37u32)  /* bind */
    nl_lex_register_hash(0x042612761674dd4du64, 1u8, 38u32)  /* convey */
    nl_lex_register_hash(0x42f406a2e307ef94u64, 1u8, 39u32)  /* mean */
    nl_lex_register_hash(0xe723b5190545606bu64, 1u8, 40u32)  /* act */
    nl_lex_register_hash(0x7f625478d788e11bu64, 1u8, 41u32)  /* free */
    /* === NOUN === */
    nl_lex_register_hash(0x6828a99c1e3216ffu64, 2u8, 42u32)  /* byte */
    nl_lex_register_hash(0x2f2ec0474f1c4fe4u64, 2u8, 43u32)  /* bytes */
    nl_lex_register_hash(0xd86c0af0b398153bu64, 2u8, 44u32)  /* buffer */
    nl_lex_register_hash(0xb45b6cbd15f67d33u64, 2u8, 45u32)  /* handle */
    nl_lex_register_hash(0xaad01178f02a6a23u64, 2u8, 46u32)  /* file */
    nl_lex_register_hash(0x546401b5d2a8d2a4u64, 2u8, 47u32)  /* message */
    nl_lex_register_hash(0x3dc94a19365b10ecu64, 2u8, 48u32)  /* key */
    nl_lex_register_hash(0x484cd7c41eb765cdu64, 2u8, 49u32)  /* signature */
    nl_lex_register_hash(0x7c0ea75a95a79411u64, 2u8, 50u32)  /* packet */
    nl_lex_register_hash(0x4f6a36d8e8907985u64, 2u8, 51u32)  /* stream */
    nl_lex_register_hash(0xa5013e9ad5caeda4u64, 2u8, 52u32)  /* channel */
    nl_lex_register_hash(0x10f2dcb841372d0cu64, 2u8, 53u32)  /* socket */
    nl_lex_register_hash(0xc7f597ea639b1b59u64, 2u8, 54u32)  /* connection */
    nl_lex_register_hash(0x86c8946e5047dea7u64, 2u8, 55u32)  /* capability */
    nl_lex_register_hash(0xd053586f9c8e048bu64, 2u8, 56u32)  /* intent */
    nl_lex_register_hash(0x0b7a1e4bea695f89u64, 2u8, 57u32)  /* pattern */
