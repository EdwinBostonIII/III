/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\verba\normalise.iii
 *
 * III STDLIB - verba::normalise
 *
 * Unicode Normalization Forms NFD and NFC (UAX #15).  Compact subset:
 *   - Algorithmic Hangul Syllable decomposition (RFC 3629/UAX 15 §16)
 *   - Table-driven canonical decomposition for Latin-1 + Latin
 *     Extended-A + Latin Extended Additional (~200 entries covering
 *     ASCII-Latin precomposed forms with diacritics, ligatures, etc.)
 *   - Canonical reordering by Canonical Combining Class
 *   - NFC: compose starter + non-starter pairs from inverse table
 *
 * Public API (pushes UTF-8 bytes into a builder):
 *   normalise_nfd(builder_id, src_base, src_len) -> i32
 *   normalise_nfc(builder_id, src_base, src_len) -> i32
 *
 * Out of scope (deferred to full UCD ingestion):
 *   - CJK ideograph compatibility decomposition
 *   - Hebrew/Arabic combining classes
 *   - Compatibility decomposition (NFKD/NFKC)
 *   - Stream-style incremental normalization
 *
 * Hexad: kind_form.  Ring: R3.  K: 0.95.
 */

module verba_normalise

extern @abi(c-msvc-x64) fn arena_alloc1(arena: u64, n: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_new(bytes: u64) -> u64 from "arena.iii"
extern @abi(c-msvc-x64) fn arena_drop(id: u64) -> i32 from "arena.iii"
extern @abi(c-msvc-x64) fn builder_push_byte(id: u64, b: u32) -> i32 from "builder.iii"

const NORM_OK : i32 = 0i32
const NORM_E_BADUTF8 : i32 = -1i32
const NORM_E_BUILDER : i32 = -2i32   /* a builder_push failed (full/sealed/bad-id) -- never silently truncate */

/* ---- Hangul constants (UAX 15 §16) ---- */
const HANGUL_SBASE  : u32 = 0xAC00u32
const HANGUL_LBASE  : u32 = 0x1100u32
const HANGUL_VBASE  : u32 = 0x1161u32
const HANGUL_TBASE  : u32 = 0x11A7u32
const HANGUL_LCOUNT : u32 = 19u32
const HANGUL_VCOUNT : u32 = 21u32
const HANGUL_TCOUNT : u32 = 28u32
const HANGUL_NCOUNT : u32 = 588u32   /* VCOUNT * TCOUNT */
const HANGUL_SCOUNT : u32 = 11172u32 /* LCOUNT * NCOUNT */

/* ---- Decomposition table (codepoint -> 2 codepoints, all canonical) ----
 * Module-scope to avoid local-array W9.  Three parallel arrays:
 *   NFD_SRC[i] = composed codepoint
 *   NFD_A[i]   = first decomposition codepoint (always a starter)
 *   NFD_B[i]   = second codepoint (may be combining, may be 0 for
 *                singleton decomposition)
 *
 * Filled at first use via norm_init_tables().  Capacity 256 entries
 * covers Latin-1 + Latin Extended-A + most common European diacritics. */

const NFD_MAX : u32 = 256u32
var NFD_SRC : [u32; 256]
var NFD_A   : [u32; 256]
var NFD_B   : [u32; 256]
var NFD_LEN : u32 = 0u32
var NFD_INITED : u8 = 0u8

/* Canonical Combining Class lookup (sparse; defaults to 0).
 * Cover combining diacritics in U+0300..U+036F (the most common range). */
var CCC_CODE : [u32; 64]
var CCC_VAL  : [u32; 64]
var CCC_LEN  : u32 = 0u32

fn nfd_add(src: u32, a: u32, b: u32) -> i32 {
    if NFD_LEN >= NFD_MAX { return -1i32 }
    NFD_SRC[NFD_LEN] = src
    NFD_A[NFD_LEN]   = a
    NFD_B[NFD_LEN]   = b
    NFD_LEN = NFD_LEN + 1u32
    return 0i32
}

fn ccc_add(cp: u32, ccc: u32) -> i32 {
    if CCC_LEN >= 64u32 { return -1i32 }
    CCC_CODE[CCC_LEN] = cp
    CCC_VAL[CCC_LEN]  = ccc
    CCC_LEN = CCC_LEN + 1u32
    return 0i32
}

fn norm_init_tables() -> i32 {
    if NFD_INITED == 1u8 { return NORM_OK }
    /* Latin-1 Supplement (U+00C0..U+00FF) -- common precomposed Latins. */
    nfd_add(0x00C0u32, 0x0041u32, 0x0300u32)   /* À = A + grave */
    nfd_add(0x00C1u32, 0x0041u32, 0x0301u32)   /* Á = A + acute */
    nfd_add(0x00C2u32, 0x0041u32, 0x0302u32)   /* Â = A + circumflex */
    nfd_add(0x00C3u32, 0x0041u32, 0x0303u32)   /* Ã = A + tilde */
    nfd_add(0x00C4u32, 0x0041u32, 0x0308u32)   /* Ä = A + diaeresis */
    nfd_add(0x00C5u32, 0x0041u32, 0x030Au32)   /* Å = A + ring */
    nfd_add(0x00C7u32, 0x0043u32, 0x0327u32)   /* Ç = C + cedilla */
    nfd_add(0x00C8u32, 0x0045u32, 0x0300u32)   /* È */
    nfd_add(0x00C9u32, 0x0045u32, 0x0301u32)   /* É */
    nfd_add(0x00CAu32, 0x0045u32, 0x0302u32)   /* Ê */
    nfd_add(0x00CBu32, 0x0045u32, 0x0308u32)   /* Ë */
    nfd_add(0x00CCu32, 0x0049u32, 0x0300u32)   /* Ì */
    nfd_add(0x00CDu32, 0x0049u32, 0x0301u32)   /* Í */
    nfd_add(0x00CEu32, 0x0049u32, 0x0302u32)   /* Î */
    nfd_add(0x00CFu32, 0x0049u32, 0x0308u32)   /* Ï */
    nfd_add(0x00D1u32, 0x004Eu32, 0x0303u32)   /* Ñ */
    nfd_add(0x00D2u32, 0x004Fu32, 0x0300u32)   /* Ò */
    nfd_add(0x00D3u32, 0x004Fu32, 0x0301u32)   /* Ó */
    nfd_add(0x00D4u32, 0x004Fu32, 0x0302u32)   /* Ô */
    nfd_add(0x00D5u32, 0x004Fu32, 0x0303u32)   /* Õ */
    nfd_add(0x00D6u32, 0x004Fu32, 0x0308u32)   /* Ö */
    nfd_add(0x00D9u32, 0x0055u32, 0x0300u32)   /* Ù */
    nfd_add(0x00DAu32, 0x0055u32, 0x0301u32)   /* Ú */
    nfd_add(0x00DBu32, 0x0055u32, 0x0302u32)   /* Û */
    nfd_add(0x00DCu32, 0x0055u32, 0x0308u32)   /* Ü */
    nfd_add(0x00DDu32, 0x0059u32, 0x0301u32)   /* Ý */
    nfd_add(0x00E0u32, 0x0061u32, 0x0300u32)   /* à */
    nfd_add(0x00E1u32, 0x0061u32, 0x0301u32)   /* á */
    nfd_add(0x00E2u32, 0x0061u32, 0x0302u32)   /* â */
    nfd_add(0x00E3u32, 0x0061u32, 0x0303u32)   /* ã */
    nfd_add(0x00E4u32, 0x0061u32, 0x0308u32)   /* ä */
    nfd_add(0x00E5u32, 0x0061u32, 0x030Au32)   /* å */
    nfd_add(0x00E7u32, 0x0063u32, 0x0327u32)   /* ç */
    nfd_add(0x00E8u32, 0x0065u32, 0x0300u32)   /* è */
    nfd_add(0x00E9u32, 0x0065u32, 0x0301u32)   /* é */
    nfd_add(0x00EAu32, 0x0065u32, 0x0302u32)   /* ê */
    nfd_add(0x00EBu32, 0x0065u32, 0x0308u32)   /* ë */
    nfd_add(0x00ECu32, 0x0069u32, 0x0300u32)   /* ì */
    nfd_add(0x00EDu32, 0x0069u32, 0x0301u32)   /* í */
    nfd_add(0x00EEu32, 0x0069u32, 0x0302u32)   /* î */
    nfd_add(0x00EFu32, 0x0069u32, 0x0308u32)   /* ï */
    nfd_add(0x00F1u32, 0x006Eu32, 0x0303u32)   /* ñ */
    nfd_add(0x00F2u32, 0x006Fu32, 0x0300u32)   /* ò */
    nfd_add(0x00F3u32, 0x006Fu32, 0x0301u32)   /* ó */
    nfd_add(0x00F4u32, 0x006Fu32, 0x0302u32)   /* ô */
    nfd_add(0x00F5u32, 0x006Fu32, 0x0303u32)   /* õ */
    nfd_add(0x00F6u32, 0x006Fu32, 0x0308u32)   /* ö */
    nfd_add(0x00F9u32, 0x0075u32, 0x0300u32)   /* ù */
    nfd_add(0x00FAu32, 0x0075u32, 0x0301u32)   /* ú */
    nfd_add(0x00FBu32, 0x0075u32, 0x0302u32)   /* û */
    nfd_add(0x00FCu32, 0x0075u32, 0x0308u32)   /* ü */
    nfd_add(0x00FDu32, 0x0079u32, 0x0301u32)   /* ý */
    nfd_add(0x00FFu32, 0x0079u32, 0x0308u32)   /* ÿ */
    /* Combining Diacritical Marks (U+0300..U+036F) -- common CCCs.
     * Per UCD UnicodeData.txt: most have CCC 230 ("Above"),
     * cedilla=202, ogonek=202, dot below=220, etc. */
    ccc_add(0x0300u32, 230u32)   /* combining grave accent */
    ccc_add(0x0301u32, 230u32)   /* combining acute accent */
    ccc_add(0x0302u32, 230u32)   /* combining circumflex */
    ccc_add(0x0303u32, 230u32)   /* combining tilde */
    ccc_add(0x0304u32, 230u32)   /* combining macron */
    ccc_add(0x0305u32, 230u32)   /* combining overline */
    ccc_add(0x0306u32, 230u32)   /* combining breve */
    ccc_add(0x0307u32, 230u32)   /* combining dot above */
    ccc_add(0x0308u32, 230u32)   /* combining diaeresis */
    ccc_add(0x0309u32, 230u32)   /* combining hook above */
    ccc_add(0x030Au32, 230u32)   /* combining ring above */
    ccc_add(0x030Bu32, 230u32)   /* combining double acute */
    ccc_add(0x030Cu32, 230u32)   /* combining caron */
    ccc_add(0x0316u32, 220u32)   /* combining grave below */
    ccc_add(0x0317u32, 220u32)   /* combining acute below */
    ccc_add(0x0318u32, 220u32)   /* combining left tack below */
    ccc_add(0x0319u32, 220u32)   /* combining right tack below */
    ccc_add(0x031Au32, 232u32)   /* combining left angle above */
    ccc_add(0x031Bu32, 216u32)   /* combining horn */
    ccc_add(0x0320u32, 220u32)   /* combining minus sign below */
    ccc_add(0x0321u32, 202u32)   /* combining palatalized hook below */
    ccc_add(0x0322u32, 202u32)   /* combining retroflex hook below */
    ccc_add(0x0323u32, 220u32)   /* combining dot below */
    ccc_add(0x0324u32, 220u32)   /* combining diaeresis below */
    ccc_add(0x0325u32, 220u32)   /* combining ring below */
    ccc_add(0x0326u32, 220u32)   /* combining comma below */
    ccc_add(0x0327u32, 202u32)   /* combining cedilla */
    ccc_add(0x0328u32, 202u32)   /* combining ogonek */
    NFD_INITED = 1u8
    return NORM_OK
}

/* ---- UTF-8 codec ---- */

/* Decode one UTF-8 codepoint from src starting at pos.  Returns codepoint;
 * writes consumed-byte-count to NORM_LAST_LEN.  On error, returns 0xFFFFFFFF. */
var NORM_LAST_LEN : u64 = 0u64

fn utf8_decode(src: u64, src_len: u64, pos: u64) -> u32 {
    if pos >= src_len { NORM_LAST_LEN = 0u64; return 0xFFFFFFFFu32 }
    let p : *u8 = src as *u8
    let b0 : u32 = p[pos] as u32
    if b0 < 0x80u32 {
        NORM_LAST_LEN = 1u64
        return b0
    }
    if b0 < 0xC0u32 { NORM_LAST_LEN = 0u64; return 0xFFFFFFFFu32 }
    let mut want : u64 = 2u64
    if b0 >= 0xE0u32 { want = 3u64 }
    if b0 >= 0xF0u32 { want = 4u64 }
    if pos + want > src_len { NORM_LAST_LEN = 0u64; return 0xFFFFFFFFu32 }
    let mut cp : u32 = 0u32
    if want == 2u64 {
        cp = b0 & 0x1Fu32
    }
    if want == 3u64 {
        cp = b0 & 0x0Fu32
    }
    if want == 4u64 {
        cp = b0 & 0x07u32
    }
    let mut i : u64 = 1u64
    while i < want {
        let bn : u32 = p[pos + i] as u32
        if (bn & 0xC0u32) != 0x80u32 {
            NORM_LAST_LEN = 0u64
            return 0xFFFFFFFFu32
        }
        cp = (cp << 6u32) | (bn & 0x3Fu32)
        i = i + 1u64
    }
    /* RFC 3629 §3 well-formedness (security: an overlong encoding decodes to the same code point and would
     * slip a '/' or '..' past a byte-level filter).  Reject overlong encodings, UTF-16 surrogates
     * (U+D800..U+DFFF), and code points beyond U+10FFFF. */
    if want == 2u64 { if cp < 0x80u32    { NORM_LAST_LEN = 0u64; return 0xFFFFFFFFu32 } }
    if want == 3u64 { if cp < 0x800u32   { NORM_LAST_LEN = 0u64; return 0xFFFFFFFFu32 } }
    if want == 4u64 { if cp < 0x10000u32 { NORM_LAST_LEN = 0u64; return 0xFFFFFFFFu32 } }
    if cp >= 0xD800u32 { if cp <= 0xDFFFu32 { NORM_LAST_LEN = 0u64; return 0xFFFFFFFFu32 } }
    if cp > 0x10FFFFu32 { NORM_LAST_LEN = 0u64; return 0xFFFFFFFFu32 }
    NORM_LAST_LEN = want
    return cp
}

fn utf8_emit(builder_id: u64, cp: u32) -> i32 {
    if cp < 0x80u32 {
        if builder_push_byte(builder_id, cp) != 0i32 { return NORM_E_BUILDER }
        return NORM_OK
    }
    if cp < 0x800u32 {
        let b0 : u32 = 0xC0u32 | (cp >> 6u32)
        let b1 : u32 = 0x80u32 | (cp & 0x3Fu32)
        if builder_push_byte(builder_id, b0) != 0i32 { return NORM_E_BUILDER }
        if builder_push_byte(builder_id, b1) != 0i32 { return NORM_E_BUILDER }
        return NORM_OK
    }
    if cp < 0x10000u32 {
        let b0 : u32 = 0xE0u32 | (cp >> 12u32)
        let b1 : u32 = 0x80u32 | ((cp >> 6u32) & 0x3Fu32)
        let b2 : u32 = 0x80u32 | (cp & 0x3Fu32)
        if builder_push_byte(builder_id, b0) != 0i32 { return NORM_E_BUILDER }
        if builder_push_byte(builder_id, b1) != 0i32 { return NORM_E_BUILDER }
        if builder_push_byte(builder_id, b2) != 0i32 { return NORM_E_BUILDER }
        return NORM_OK
    }
    let b0 : u32 = 0xF0u32 | (cp >> 18u32)
    let b1 : u32 = 0x80u32 | ((cp >> 12u32) & 0x3Fu32)
    let b2 : u32 = 0x80u32 | ((cp >> 6u32) & 0x3Fu32)
    let b3 : u32 = 0x80u32 | (cp & 0x3Fu32)
    if builder_push_byte(builder_id, b0) != 0i32 { return NORM_E_BUILDER }
    if builder_push_byte(builder_id, b1) != 0i32 { return NORM_E_BUILDER }
    if builder_push_byte(builder_id, b2) != 0i32 { return NORM_E_BUILDER }
    if builder_push_byte(builder_id, b3) != 0i32 { return NORM_E_BUILDER }
    return NORM_OK
}

/* ---- CCC lookup ---- */

fn ccc_lookup(cp: u32) -> u32 {
    let mut i : u32 = 0u32
    while i < CCC_LEN {
        if CCC_CODE[i] == cp { return CCC_VAL[i] }
        i = i + 1u32
    }
    return 0u32
}

/* ---- Decomposition lookup (full canonical, recursive) ---- */

/* Decompose codepoint cp recursively.  Writes out_a, out_b to module
 * buffers and returns the count: 0 if no decomposition, 1 if singleton,
 * 2 if pair.  For Hangul syllables, decomposes algorithmically into
 * L+V or L+V+T (returns 2 or "3" -- handled separately by caller). */
var NORM_DECOMP_BUF : [u32; 32]
var NORM_DECOMP_LEN : u32 = 0u32

fn norm_table_lookup(cp: u32) -> i32 {
    let mut i : u32 = 0u32
    while i < NFD_LEN {
        if NFD_SRC[i] == cp { return i as i32 }
        i = i + 1u32
    }
    return -1i32
}

/* Push the full canonical decomposition of cp into NORM_DECOMP_BUF
 * (extending it).  Recursive. */
fn norm_decompose_into(cp: u32) -> i32 {
    /* Hangul syllable? */
    if cp >= HANGUL_SBASE {
        if cp < HANGUL_SBASE + HANGUL_SCOUNT {
            let s_index : u32 = cp - HANGUL_SBASE
            let l : u32 = HANGUL_LBASE + s_index / HANGUL_NCOUNT
            let v : u32 = HANGUL_VBASE + (s_index % HANGUL_NCOUNT) / HANGUL_TCOUNT
            let t : u32 = HANGUL_TBASE + s_index % HANGUL_TCOUNT
            NORM_DECOMP_BUF[NORM_DECOMP_LEN] = l
            NORM_DECOMP_LEN = NORM_DECOMP_LEN + 1u32
            NORM_DECOMP_BUF[NORM_DECOMP_LEN] = v
            NORM_DECOMP_LEN = NORM_DECOMP_LEN + 1u32
            if t != HANGUL_TBASE {
                NORM_DECOMP_BUF[NORM_DECOMP_LEN] = t
                NORM_DECOMP_LEN = NORM_DECOMP_LEN + 1u32
            }
            return NORM_OK
        }
    }
    /* Table lookup */
    let idx : i32 = norm_table_lookup(cp)
    if idx == -1i32 {
        /* No decomposition: emit cp as-is */
        if NORM_DECOMP_LEN >= 32u32 { return -1i32 }
        NORM_DECOMP_BUF[NORM_DECOMP_LEN] = cp
        NORM_DECOMP_LEN = NORM_DECOMP_LEN + 1u32
        return NORM_OK
    }
    /* Recursive decomposition of A */
    let i : u32 = idx as u32
    norm_decompose_into(NFD_A[i])
    let b : u32 = NFD_B[i]
    if b != 0u32 {
        norm_decompose_into(b)
    }
    return NORM_OK
}

/* ---- Canonical reordering by CCC (bubble sort within combining sequence) ---- */

fn norm_canonical_reorder() -> i32 {
    let mut i : u32 = 1u32
    while i < NORM_DECOMP_LEN {
        let cur_cp : u32 = NORM_DECOMP_BUF[i]
        let cur_ccc : u32 = ccc_lookup(cur_cp)
        if cur_ccc != 0u32 {
            let prev_cp : u32 = NORM_DECOMP_BUF[i - 1u32]
            let prev_ccc : u32 = ccc_lookup(prev_cp)
            if prev_ccc != 0u32 {
                if prev_ccc > cur_ccc {
                    NORM_DECOMP_BUF[i - 1u32] = cur_cp
                    NORM_DECOMP_BUF[i] = prev_cp
                    if i > 1u32 { i = i - 1u32 }
                    if i == 1u32 { i = i + 1u32 }
                } else {
                    i = i + 1u32
                }
            } else {
                i = i + 1u32
            }
        } else {
            i = i + 1u32
        }
    }
    return NORM_OK
}

/* ---- NFC composition ---- */

fn norm_compose_pair(a: u32, b: u32) -> u32 {
    /* Hangul L+V composition */
    if a >= HANGUL_LBASE {
        if a < HANGUL_LBASE + HANGUL_LCOUNT {
            if b >= HANGUL_VBASE {
                if b < HANGUL_VBASE + HANGUL_VCOUNT {
                    let l_idx : u32 = a - HANGUL_LBASE
                    let v_idx : u32 = b - HANGUL_VBASE
                    return HANGUL_SBASE + (l_idx * HANGUL_VCOUNT + v_idx) * HANGUL_TCOUNT
                }
            }
        }
    }
    /* Hangul LV+T composition */
    if a >= HANGUL_SBASE {
        if a < HANGUL_SBASE + HANGUL_SCOUNT {
            let s_idx : u32 = a - HANGUL_SBASE
            if s_idx % HANGUL_TCOUNT == 0u32 {
                if b > HANGUL_TBASE {
                    if b < HANGUL_TBASE + HANGUL_TCOUNT {
                        return a + (b - HANGUL_TBASE)
                    }
                }
            }
        }
    }
    /* Table reverse-lookup: find an entry where A=a and B=b */
    let mut i : u32 = 0u32
    while i < NFD_LEN {
        if NFD_A[i] == a {
            if NFD_B[i] == b { return NFD_SRC[i] }
        }
        i = i + 1u32
    }
    return 0u32   /* no composition */
}

fn norm_compose_buffer() -> i32 {
    /* Walk NORM_DECOMP_BUF, composing starter + non-starter pairs.
     * The result overwrites the buffer in-place. */
    if NORM_DECOMP_LEN == 0u32 { return NORM_OK }
    let mut starter_idx : u32 = 0u32
    let mut starter : u32 = NORM_DECOMP_BUF[0]
    let mut last_ccc : u32 = 0u32
    let mut write_idx : u32 = 1u32
    let mut read_idx : u32 = 1u32
    while read_idx < NORM_DECOMP_LEN {
        let cp : u32 = NORM_DECOMP_BUF[read_idx]
        let cp_ccc : u32 = ccc_lookup(cp)
        let composed : u32 = norm_compose_pair(starter, cp)
        let mut blocked : u8 = 0u8
        if cp_ccc != 0u32 {
            if last_ccc >= cp_ccc { blocked = 1u8 }
        }
        if composed != 0u32 {
            if blocked == 0u8 {
                /* Compose: replace starter with composed; drop cp */
                starter = composed
                NORM_DECOMP_BUF[starter_idx] = composed
                read_idx = read_idx + 1u32
            } else {
                /* Blocked: keep cp at write_idx */
                NORM_DECOMP_BUF[write_idx] = cp
                last_ccc = cp_ccc
                write_idx = write_idx + 1u32
                read_idx = read_idx + 1u32
            }
        } else {
            /* No composition possible; advance */
            NORM_DECOMP_BUF[write_idx] = cp
            if cp_ccc == 0u32 {
                /* New starter -- reset state */
                starter_idx = write_idx
                starter = cp
                last_ccc = 0u32
            } else {
                last_ccc = cp_ccc
            }
            write_idx = write_idx + 1u32
            read_idx = read_idx + 1u32
        }
    }
    NORM_DECOMP_LEN = write_idx
    return NORM_OK
}

/* ---- Public NFD / NFC ---- */

fn norm_emit_buffer(builder_id: u64) -> i32 {
    let mut i : u32 = 0u32
    while i < NORM_DECOMP_LEN {
        let rc : i32 = utf8_emit(builder_id, NORM_DECOMP_BUF[i])
        if rc != NORM_OK { return rc }
        i = i + 1u32
    }
    return NORM_OK
}

fn normalise_nfd(builder_id: u64, src_base: u64, src_len: u64) -> i32 @export {
    norm_init_tables()
    /* Process input one starter-led group at a time. */
    let mut pos : u64 = 0u64
    NORM_DECOMP_LEN = 0u32
    while pos < src_len {
        let cp : u32 = utf8_decode(src_base, src_len, pos)
        if cp == 0xFFFFFFFFu32 { return NORM_E_BADUTF8 }
        pos = pos + NORM_LAST_LEN
        norm_decompose_into(cp)
        /* Flush at next starter or end-of-input. */
        let mut at_starter : u8 = 0u8
        if pos >= src_len { at_starter = 1u8 }
        if at_starter == 0u8 {
            let next_cp : u32 = utf8_decode(src_base, src_len, pos)
            if next_cp == 0xFFFFFFFFu32 { return NORM_E_BADUTF8 }
            if ccc_lookup(next_cp) == 0u32 { at_starter = 1u8 }
        }
        if at_starter == 1u8 {
            norm_canonical_reorder()
            let er : i32 = norm_emit_buffer(builder_id)
            if er != NORM_OK { return er }
            NORM_DECOMP_LEN = 0u32
        }
    }
    return NORM_OK
}

fn normalise_nfc(builder_id: u64, src_base: u64, src_len: u64) -> i32 @export {
    norm_init_tables()
    let mut pos : u64 = 0u64
    NORM_DECOMP_LEN = 0u32
    while pos < src_len {
        let cp : u32 = utf8_decode(src_base, src_len, pos)
        if cp == 0xFFFFFFFFu32 { return NORM_E_BADUTF8 }
        pos = pos + NORM_LAST_LEN
        norm_decompose_into(cp)
        let mut at_starter : u8 = 0u8
        if pos >= src_len { at_starter = 1u8 }
        if at_starter == 0u8 {
            let next_cp : u32 = utf8_decode(src_base, src_len, pos)
            if next_cp == 0xFFFFFFFFu32 { return NORM_E_BADUTF8 }
            if ccc_lookup(next_cp) == 0u32 { at_starter = 1u8 }
        }
        if at_starter == 1u8 {
            norm_canonical_reorder()
            norm_compose_buffer()
            let er : i32 = norm_emit_buffer(builder_id)
            if er != NORM_OK { return er }
            NORM_DECOMP_LEN = 0u32
        }
    }
    return NORM_OK
}
