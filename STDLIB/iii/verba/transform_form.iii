/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\iii\verba\transform_form.iii
 *
 * III STDLIB - verba::transform_form
 *
 * Runtime text-to-transform parser. Reads a string like:
 *   "src=1, dst=3, input=0xDEADBEEF"
 * and invokes transform() with the parsed values.
 *
 * Hardcoded dynamicism: no parse.c modification, no identifier conflicts,
 * full surface syntax via deterministic hand-rolled parsing.
 *
 * Hexad: kind_form. Ring: R0. K: 0.95.
 */

module verba_transform_form

extern @abi(c-msvc-x64) fn transform(src_form: u32, dst_form: u32, src_handle: u64, ctx: u64) -> u64 from "transform.iii"

const TF_MAX_KEY_LEN : u32 = 16u32

var TF_KEY_BUF : [u8; 16]
var TF_KEY_LEN : u32 = 0u32
var TF_PARSED_VAL : u64 = 0u64

var TF_SRC_FORM : u32 = 0u32
var TF_DST_FORM : u32 = 0u32
var TF_INPUT : u64 = 0u64

fn tf_is_alpha_under(c: u8) -> u8 {
    if c == 95u8 { return 1u8 }
    if c >= 97u8 {
        if c <= 122u8 { return 1u8 }
    }
    if c >= 65u8 {
        if c <= 90u8 { return 1u8 }
    }
    return 0u8
}

fn tf_is_alnum_under(c: u8) -> u8 {
    if tf_is_alpha_under(c) == 1u8 { return 1u8 }
    if c >= 48u8 {
        if c <= 57u8 { return 1u8 }
    }
    return 0u8
}

fn tf_is_ws(c: u8) -> u8 {
    if c == 32u8 { return 1u8 }
    if c == 9u8 { return 1u8 }
    if c == 10u8 { return 1u8 }
    if c == 13u8 { return 1u8 }
    return 0u8
}

fn tf_skip_ws(src: u64, off: u64, len: u64) -> u64 {
    let mut o : u64 = off
    while o < len {
        let bp : *u8 = (src + o) as *u8
        if tf_is_ws(bp[0u64]) == 0u8 { return o }
        o = o + 1u64
    }
    return o
}

fn tf_advance_past_comma(src: u64, off: u64, len: u64) -> u64 {
    let mut o : u64 = off
    while o < len {
        let bp : *u8 = (src + o) as *u8
        if bp[0u64] == 44u8 { return o + 1u64 }
        o = o + 1u64
    }
    return len
}

fn tf_read_key(src: u64, off: u64, len: u64) -> u64 {
    TF_KEY_LEN = 0u32
    let mut o : u64 = off
    while o < len {
        let bp : *u8 = (src + o) as *u8
        let c : u8 = bp[0u64]
        if tf_is_alnum_under(c) == 0u8 { return o }
        if TF_KEY_LEN >= TF_MAX_KEY_LEN { return o }
        TF_KEY_BUF[TF_KEY_LEN] = c
        TF_KEY_LEN = TF_KEY_LEN + 1u32
        o = o + 1u64
    }
    return o
}

fn tf_hex_digit(c: u8) -> u32 {
    if c >= 48u8 {
        if c <= 57u8 { return (c - 48u8) as u32 }
    }
    if c >= 97u8 {
        if c <= 102u8 { return (c - 87u8) as u32 }
    }
    if c >= 65u8 {
        if c <= 70u8 { return (c - 55u8) as u32 }
    }
    return 0xFFFFFFFFu32
}

fn tf_parse_value(src: u64, off: u64, len: u64) -> u64 {
    TF_PARSED_VAL = 0u64
    let mut o : u64 = off
    if o >= len { return o }
    let bp0 : *u8 = (src + o) as *u8
    if bp0[0u64] == 48u8 {
        if (o + 1u64) < len {
            let bp1 : *u8 = (src + o + 1u64) as *u8
            if bp1[0u64] == 120u8 {
                o = o + 2u64
                while o < len {
                    let bp : *u8 = (src + o) as *u8
                    let d : u32 = tf_hex_digit(bp[0u64])
                    if d == 0xFFFFFFFFu32 { return o }
                    if (TF_PARSED_VAL >> 60u64) != 0u64 { return o }   /* [overflow] next <<4 would drop high bits; stop at the 17th hex digit */
                    TF_PARSED_VAL = (TF_PARSED_VAL << 4u64) | (d as u64 & 0xFu64)
                    o = o + 1u64
                }
                return o
            }
        }
    }
    while o < len {
        let bp : *u8 = (src + o) as *u8
        let c : u8 = bp[0u64]
        if c < 48u8 { return o }
        if c > 57u8 { return o }
        /* [overflow] two-stage guard (matches verba::semver/parse): a lone `> MAX/10` misses the exact
         * boundary value==MAX/10 && digit>5 (decimals 2^64..2^64+3 wrap to 0..3). *10 then +digit, reject on either wrap. */
        if TF_PARSED_VAL > 1844674407370955161u64 { return o }
        let v10 : u64 = TF_PARSED_VAL * 10u64
        let nv  : u64 = v10 + ((c - 48u8) as u64 & 0xFFu64)
        if nv < v10 { return o }
        TF_PARSED_VAL = nv
        o = o + 1u64
    }
    return o
}

fn tf_key_eq_3(a: u8, b: u8, c: u8) -> u8 {
    if TF_KEY_LEN != 3u32 { return 0u8 }
    if TF_KEY_BUF[0u32] != a { return 0u8 }
    if TF_KEY_BUF[1u32] != b { return 0u8 }
    if TF_KEY_BUF[2u32] != c { return 0u8 }
    return 1u8
}

fn tf_key_eq_5(a: u8, b: u8, c: u8, d: u8, e: u8) -> u8 {
    if TF_KEY_LEN != 5u32 { return 0u8 }
    if TF_KEY_BUF[0u32] != a { return 0u8 }
    if TF_KEY_BUF[1u32] != b { return 0u8 }
    if TF_KEY_BUF[2u32] != c { return 0u8 }
    if TF_KEY_BUF[3u32] != d { return 0u8 }
    if TF_KEY_BUF[4u32] != e { return 0u8 }
    return 1u8
}

fn tf_apply_field() -> i32 {
    /* "src" (3) */
    if tf_key_eq_3(115u8, 114u8, 99u8) == 1u8 {
        TF_SRC_FORM = (TF_PARSED_VAL & 0xFFFFFFFFu64) as u32
        return 0i32
    }
    /* "dst" (3) */
    if tf_key_eq_3(100u8, 115u8, 116u8) == 1u8 {
        TF_DST_FORM = (TF_PARSED_VAL & 0xFFFFFFFFu64) as u32
        return 0i32
    }
    /* "input" (5) */
    if tf_key_eq_5(105u8, 110u8, 112u8, 117u8, 116u8) == 1u8 {
        TF_INPUT = TF_PARSED_VAL
        return 0i32
    }
    return 0i32
}

/* Parse text spec, populate TF_SRC_FORM/TF_DST_FORM/TF_INPUT, then call transform(). */
fn transform_form_invoke(src: u64, len: u64, ctx: u64) -> u64 @export {
    if src == 0u64 { return 0u64 }
    if len == 0u64 { return 0u64 }
    TF_SRC_FORM = 0u32
    TF_DST_FORM = 0u32
    TF_INPUT = 0u64
    let mut o : u64 = tf_skip_ws(src, 0u64, len)
    while o < len {
        o = tf_read_key(src, o, len)
        if TF_KEY_LEN == 0u32 {
            o = o + 1u64
        }
        if TF_KEY_LEN > 0u32 {
            o = tf_skip_ws(src, o, len)
            if o < len {
                let bp : *u8 = (src + o) as *u8
                if bp[0u64] == 61u8 {
                    o = o + 1u64
                    o = tf_skip_ws(src, o, len)
                    o = tf_parse_value(src, o, len)
                    tf_apply_field()
                }
            }
        }
        o = tf_advance_past_comma(src, o, len)
        o = tf_skip_ws(src, o, len)
    }
    return transform(TF_SRC_FORM, TF_DST_FORM, TF_INPUT, ctx)
}

fn transform_form_src_form() -> u32 @export { return TF_SRC_FORM }
fn transform_form_dst_form() -> u32 @export { return TF_DST_FORM }
fn transform_form_input() -> u64 @export { return TF_INPUT }
