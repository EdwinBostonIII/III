extern @abi(c-msvc-x64) fn h13_selftest() -> u64 from "h13_charter.iii"

fn chk(code: u64, idx: u64) -> u64 {
    if code != 99u64 { return idx }
    return 0u64
}

fn main() -> u64 {
    let mut r : u64 = 0u64
    r = chk(xjn_selftest(), 7u64);    if r != 0u64 { return r }
    r = chk(xcc_selftest(), 8u64);    if r != 0u64 { return r }
    r = chk(xtm_selftest(), 9u64);    if r != 0u64 { return r }
    r = chk(sat_selftest(), 13u64);    if r != 0u64 { return r }
    r = chk(smt_selftest(), 14u64);    if r != 0u64 { return r }
    r = chk(gb_selftest(), 15u64);    if r != 0u64 { return r }
    r = chk(eg_selftest(), 16u64);    if r != 0u64 { return r }
    r = chk(cat_laws_charter_selftest(), 17u64);    if r != 0u64 { return r }
    r = chk(cl_selftest(), 18u64);    if r != 0u64 { return r }
    r = chk(keccak256_kat(), 22u64);    if r != 0u64 { return r }
    r = chk(rsa_pss_selftest(), 23u64);    if r != 0u64 { return r }
    r = chk(galois_selftest(), 24u64);    if r != 0u64 { return r }
    r = chk(ntt_selftest(), 25u64);    if r != 0u64 { return r }
    r = chk(zk_stark_kat(), 26u64);    if r != 0u64 { return r }
    r = chk(zk_air_stark_selftest(), 27u64);    if r != 0u64 { return r }
    r = chk(zk_snark_kat(), 28u64);    if r != 0u64 { return r }
    r = chk(zkf_pairing_selftest(), 29u64);    if r != 0u64 { return r }
    r = chk(typecheck_selftest(), 32u64);    if r != 0u64 { return r }
    r = chk(ccl_beta_kat(), 33u64);    if r != 0u64 { return r }
    r = chk(hs_selftest(), 34u64);    if r != 0u64 { return r }
    r = chk(sov_isa_kat(), 36u64);    if r != 0u64 { return r }
    r = chk(h1_selftest(), 37u64);    if r != 0u64 { return r }
    r = chk(h2_selftest(), 38u64);    if r != 0u64 { return r }
    r = chk(h3_selftest(), 39u64);    if r != 0u64 { return r }
    r = chk(h4_selftest(), 40u64);    if r != 0u64 { return r }
    r = chk(h5_selftest(), 41u64);    if r != 0u64 { return r }
    r = chk(h6_selftest(), 42u64);    if r != 0u64 { return r }
    r = chk(h9_selftest(), 45u64);    if r != 0u64 { return r }
    r = chk(h10_selftest(), 46u64);    if r != 0u64 { return r }
    r = chk(h11_selftest(), 47u64);    if r != 0u64 { return r }
    r = chk(h12_selftest(), 48u64);    if r != 0u64 { return r }
    r = chk(h13_selftest(), 49u64);    if r != 0u64 { return r }
    return 99u64
}
