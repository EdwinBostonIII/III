/* Independence proof #1 — TOOLCHAIN.
 * A pure III program (zero stdlib, zero externs) that computes Sum(0..99)=4950
 * and a small Collatz check, returning 99 iff both hold. Driven through iiis-2
 * ALONE (its own compile + its own link.iii PE emitter, no gcc) to prove III's
 * toolchain stands on its own — only libc/Windows at the process boundary. */
module indep_toolchain

fn collatz_steps(n0: u64) -> u64 {
    let mut n : u64 = n0
    let mut steps : u64 = 0u64
    while n != 1u64 {
        if (n & 1u64) == 0u64 { n = n / 2u64 } else { n = 3u64 * n + 1u64 }
        steps = steps + 1u64
    }
    return steps
}

fn main() -> u64 {
    let mut acc : u64 = 0u64
    let mut i : u64 = 0u64
    while i < 100u64 {
        acc = acc + i
        i = i + 1u64
    }
    /* Gauss: 0+1+...+99 = 4950 */
    if acc != 4950u64 { return 1u64 }
    /* Collatz(27) takes 111 steps — a classic deterministic witness. */
    if collatz_steps(27u64) != 111u64 { return 2u64 }
    return 99u64
}
