/* Falsifier for the sf_* consolidation: co-link zk_stark + zk_air (the exact
 * module pair whose duplicate L_sf_* globals previously made co-linking impossible)
 * and run a thorough cross-section of BOTH modules' selftests. Links + 99 ⇒ the
 * collision is gone AND the consolidation is behavior-preserving. */
module indep_zkcolink
extern @abi(c-msvc-x64) fn zk_stark_kat() -> u64 from "zk_stark.iii"
extern @abi(c-msvc-x64) fn zk_stark_merkle_selftest() -> u64 from "zk_stark.iii"
extern @abi(c-msvc-x64) fn zk_stark_ntt_selftest() -> u64 from "zk_stark.iii"
extern @abi(c-msvc-x64) fn zk_stark_lde_selftest() -> u64 from "zk_stark.iii"
extern @abi(c-msvc-x64) fn zk_air_stark_selftest() -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn zk_air_merkle_selftest() -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn zk_air_fs_selftest() -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_proof_seal_kat() -> u64 from "zk_air.iii"

fn main() -> u64 {
    if zk_stark_kat() != 99u64 { return 1u64 }
    if zk_stark_merkle_selftest() != 99u64 { return 2u64 }
    if zk_stark_ntt_selftest() != 99u64 { return 3u64 }
    if zk_stark_lde_selftest() != 99u64 { return 4u64 }
    if zk_air_stark_selftest() != 99u64 { return 5u64 }
    if zk_air_merkle_selftest() != 99u64 { return 6u64 }
    if zk_air_fs_selftest() != 99u64 { return 7u64 }
    if air_proof_seal_kat() != 99u64 { return 8u64 }
    return 99u64
}
