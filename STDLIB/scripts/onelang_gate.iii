/* STDLIB/scripts/onelang_gate.iii -- the H13 one-language gate, in III.
 *
 * This is the .iii SUPERSESSION of scripts/verify_sha256_dedup.sh (and the C
 * cartographer's fact-extraction): run from the repo root, it walks "." with the
 * sanctus/onelang self-audit (over the aether/fs directory organ), writes a
 * human-readable census to ./onelang_census.txt, and EXITS with the verdict --
 *   0 = PURE       (only the bootstrap C trust root + harness survive)
 *   1 = ACCOUNTED  (every C classified; dead-reference retire targets remain)
 *   2 = VIOLATION  (an unaccounted GAP .c exists, or the walk overflowed)
 * No bash, no C: III audits its own one-language property, by itself.
 *
 * Build (from STDLIB/build/iii, the dir holding libiii_native.a):
 *   ../../../COMPILED/iiis-2.exe ../../scripts/onelang_gate.iii --compile-only --out onelang_gate.o
 *   gcc onelang_gate.o libiii_native.a -lws2_32 -lkernel32 -o onelang_gate.exe
 * Run from the repo root so "." is the III tree.
 */
module onelang_gate

extern @abi(c-msvc-x64) fn onelang_audit(cap: u64, root: u64) -> u64 from "onelang.iii"
extern @abi(c-msvc-x64) fn onelang_verdict() -> u32 from "onelang.iii"
extern @abi(c-msvc-x64) fn onelang_n_files() -> u64 from "onelang.iii"
extern @abi(c-msvc-x64) fn onelang_n_bootstrap() -> u64 from "onelang.iii"
extern @abi(c-msvc-x64) fn onelang_n_harness() -> u64 from "onelang.iii"
extern @abi(c-msvc-x64) fn onelang_n_dead() -> u64 from "onelang.iii"
extern @abi(c-msvc-x64) fn onelang_n_gap() -> u64 from "onelang.iii"
extern @abi(c-msvc-x64) fn onelang_n_dirs() -> u64 from "onelang.iii"
extern @abi(c-msvc-x64) fn onelang_overflow() -> u8 from "onelang.iii"
extern @abi(c-msvc-x64) fn cap_env_init() -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn cap_attenuate(parent: u64, mask: u64, exp: u64) -> u64 from "capability.iii"
extern @abi(c-msvc-x64) fn fs_open(cap: u64, path: u64, mode: u32) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_write(h: u64, buf: u64, n: u64) -> u64 from "fs.iii"
extern @abi(c-msvc-x64) fn fs_close(h: u64) -> i32 from "fs.iii"

var GD_DIGS    : [u8; 24]
var GATE_REPORT: [u8; 512]
var GATE_LEN   : u64 = 0u64
var GATE_DOT   : [u8; 4]
var GATE_PATH  : [u8; 32]

/* u64 -> decimal at out_addr; returns digit count.  Division for the quotient
 * (pure loop, no intervening call -> outside the modulo-after-call trap);
 * remainder via subtraction (no `%`).  Digits collected LSB-first, then reversed. */
fn u64_to_dec(v_in: u64, out_addr: u64) -> u64 {
    let o : *u8 = out_addr as *u8
    let mut v : u64 = v_in
    if v == 0u64 { o[0u64] = 0x30u8   return 1u64 }
    let mut nd : u64 = 0u64
    while v > 0u64 {
        let q : u64 = v / 10u64
        let r : u64 = v - q * 10u64
        GD_DIGS[nd] = (0x30u64 + r) as u8
        nd = nd + 1u64
        v = q
    }
    let mut i : u64 = 0u64
    while i < nd { o[i] = GD_DIGS[nd - 1u64 - i]   i = i + 1u64 }
    return nd
}

/* append n literal bytes from src into GATE_REPORT (length-explicit). */
fn rep_lit(src_addr: u64, n: u64) {
    let d : *u8 = (&GATE_REPORT as u64) as *u8
    let s : *u8 = src_addr as *u8
    let mut i : u64 = 0u64
    while i < n { d[GATE_LEN + i] = s[i]   i = i + 1u64 }
    GATE_LEN = GATE_LEN + n
}

/* append the decimal form of v into GATE_REPORT. */
fn rep_dec(v: u64) {
    let k : u64 = u64_to_dec(v, (&GATE_REPORT as u64) + GATE_LEN)
    GATE_LEN = GATE_LEN + k
}

fn main() -> u64 {
    let env : u64 = cap_env_init()
    let cap : u64 = cap_attenuate(env, 0x0Eu64, 0u64)   /* read|write|create */
    GATE_DOT[0u64] = 0x2Eu8   /* '.' */
    GATE_DOT[1u64] = 0u8
    onelang_audit(cap, (&GATE_DOT as u64))
    let verdict : u32 = onelang_verdict()

    GATE_LEN = 0u64
    rep_lit(("onelang  files=" as u64), 15u64) ; rep_dec(onelang_n_files())
    rep_lit((" boot=" as u64), 6u64)           ; rep_dec(onelang_n_bootstrap())
    rep_lit((" harn=" as u64), 6u64)           ; rep_dec(onelang_n_harness())
    rep_lit((" dead=" as u64), 6u64)           ; rep_dec(onelang_n_dead())
    rep_lit((" gap=" as u64), 5u64)            ; rep_dec(onelang_n_gap())
    rep_lit((" dirs=" as u64), 6u64)           ; rep_dec(onelang_n_dirs())
    rep_lit((" overflow=" as u64), 10u64)      ; rep_dec(onelang_overflow() as u64)
    rep_lit((" verdict=" as u64), 9u64)        ; rep_dec(verdict as u64)
    let d : *u8 = (&GATE_REPORT as u64) as *u8
    d[GATE_LEN] = 0x0Au8   /* '\n' */
    GATE_LEN = GATE_LEN + 1u64

    /* write the census report to ./onelang_census.txt */
    GATE_PATH[0u64]  = 0x2Eu8  /* . */
    GATE_PATH[1u64]  = 0x2Fu8  /* / */
    GATE_PATH[2u64]  = 0x6Fu8  /* o */
    GATE_PATH[3u64]  = 0x6Eu8  /* n */
    GATE_PATH[4u64]  = 0x65u8  /* e */
    GATE_PATH[5u64]  = 0x6Cu8  /* l */
    GATE_PATH[6u64]  = 0x61u8  /* a */
    GATE_PATH[7u64]  = 0x6Eu8  /* n */
    GATE_PATH[8u64]  = 0x67u8  /* g */
    GATE_PATH[9u64]  = 0x5Fu8  /* _ */
    GATE_PATH[10u64] = 0x63u8  /* c */
    GATE_PATH[11u64] = 0x65u8  /* e */
    GATE_PATH[12u64] = 0x6Eu8  /* n */
    GATE_PATH[13u64] = 0x73u8  /* s */
    GATE_PATH[14u64] = 0x75u8  /* u */
    GATE_PATH[15u64] = 0x73u8  /* s */
    GATE_PATH[16u64] = 0x2Eu8  /* . */
    GATE_PATH[17u64] = 0x74u8  /* t */
    GATE_PATH[18u64] = 0x78u8  /* x */
    GATE_PATH[19u64] = 0x74u8  /* t */
    GATE_PATH[20u64] = 0u8
    let h : u64 = fs_open(cap, (&GATE_PATH as u64), 2u32)
    if h != 0u64 {
        fs_write(h, (&GATE_REPORT as u64), GATE_LEN)
        fs_close(h)
    }
    return verdict as u64
}
