    while go==1u32 { if cp(Q_RP)==1u32 {go=0u32} else { if TK[C as u64]==0u32 {go=0u32} else {   /* [quals] type [*] NAME */
        if ispat(C,Q_DOT)==1u32 { CUR_VAPTR=LN as i32  LN=LN+1u32  params=params+1u32  let mut gd:u32=1u32  while gd==1u32 { if cp(Q_DOT)==1u32 {C=C+1u32} else {gd=0u32} }  go=0u32 }   /* `...` -> hidden va-ptr param (slot CUR_VAPTR; the caller passes VA_BUF) */
        else {
