    let mut pp:u32=0u32                                              /* &-taken PARAMS: prescan_addrof runs AFTER the param loop, so spill them now + entry-store the incoming slot value (enables &param, e.g. update(s,&v,1)) */
    while pp<params {
        let lm:i64=LMEM[pp as u64]  let taken:u32=adn_has(LO[pp as u64], LL[pp as u64])   /* bind before the compare (iiis array-elem-ordering hygiene) */
        if lm<0i64 { if taken==1u32 {
            let psz:i64=LSZ[pp as u64]  let m:u64=MTOP
            LMEM[pp as u64]=m as i64  econst(m as i64)  eu8(0x10u32, pp)  estore(psz)  MTOP=m+8u64
        } }
        let svt:i32=LVT[pp as u64]  if svt>=0i32 { econst(LVB[pp as u64])  eu8(0x10u32, pp)  eb(0x83u32) }   /* struct-VALUE param: STORE64 the incoming packed slot into its frame region (LVB) */
        pp=pp+1u32
    }
    prescan_labels(C)  eat(Q_LB)
    let mut lo:u32=0u32  while lo<LBLN { let idx:u32=LBLN-1u32-lo  eb(0x40u32)  BLKD=BLKD+1i64  LBLBD[idx as u64]=BLKD  lo=lo+1u32 }   /* open a goto-block per top-level label (label[0] = innermost, closes first) */
    let mut gb:u32=1u32  while gb==1u32 { if cp(Q_RB)==1u32 {gb=0u32} else { if TK[C as u64]==0u32 {gb=0u32} else { pstmt() } } }   /* the body (label `L:` closes its block; goto -> BR to it) */
    eat(Q_RB)
    if ENDED_RET==0u32 { econst(0i64)  eb(0x60u32) }          /* default `return 0` ONLY for void/fall-through fns (return-ending fns stay byte-identical -> byte-DDC preserved) */
    mb(params)  mb(1u32)  mb((BL & 0xFFu64) as u32)  mb(((BL >> 8u64) & 0xFFu64) as u32)
    let mut i:u64=0u64  while i<BL { mb(BD[i] as u32)  i=i+1u64 }
}

fn pc(c: u32) { putchar((c & 0xFFu32) as i32) }
fn pstr(s: u64) { let mut i:u64=0u64  let mut go:u32=1u32  while go==1u32 { let p:*u8=(s+i) as *u8  let b:u32=p[0u64] as u32  if b==126u32 {go=0u32} else { pc(b)  i=i+1u64 } } }
var DB : [u8; 24]
fn pdec(v0: u64) { if v0==0u64 { pc(48u32)  return }  let mut v:u64=v0  let mut n:u32=0u32  while v>0u64 { DB[n as u64]=(48u64+(v%10u64)) as u8  n=n+1u32  v=v/10u64 }  while n>0u32 { n=n-1u32  pc(DB[n as u64] as u32) } }
fn emit_module() {
    let total:u64=ML+1u64
    pstr("module gen_svir\nvar SVIR : [u8; ~" as u64)  pdec(total)  pstr("] = [\n~" as u64)
    pdec(FN as u64)  pstr("u8~" as u64)
    let mut i:u64=0u64  while i<ML { pc(44u32)  pdec(MO[i] as u64)  pstr("u8~" as u64)  i=i+1u64 }
    pstr("\n]\nfn svir_ptr() -> u64 @export { return &SVIR as u64 }\nfn svir_len() -> u64 @export { return ~" as u64)
    pdec(total)  pstr("u64 }\n~" as u64)
}

fn bb(base:u64, i:u64) -> u32 { let p:*u8=(base+i) as *u8  return p[0u64] as u32 }
fn src_emit(b:u32) { if SLEN<1048575u64 { let p:*u8=((&SRC as u64)+SLEN) as *u8  p[0u64]=(b & 0xFFu32) as u8  SLEN=SLEN+1u64 } }
fn read_into(ib:u64) -> u64 { let f:u64=fopen(&IPATH as u64, &MODE_RB as u64)  if f==0u64 {return 0u64}  let n:u64=fread(ib, 1u64, 131071u64, f)  fclose(f)  return n }   /* into one 131072 IBUFS level */
fn path_seen() -> u32 { let mut e:u32=0u32  while e<PN { if PLEN[e as u64]==IPLEN { let mut k:u64=0u64  let mut eq:u32=1u32  while k<IPLEN { let ip:*u8=((&IPATH as u64)+k) as *u8  let pp:*u8=((&PATHBUF as u64)+POFF[e as u64]+k) as *u8  if ip[0u64]!=pp[0u64] {eq=0u32}  k=k+1u64 }  if eq==1u32 {return 1u32} }  e=e+1u32 }  return 0u32 }
fn path_add() { if PN<256u32 { if (PBE+IPLEN)<8192u64 { POFF[PN as u64]=PBE  PLEN[PN as u64]=IPLEN  let mut k:u64=0u64  while k<IPLEN { let ip:*u8=((&IPATH as u64)+k) as *u8  let pp:*u8=((&PATHBUF as u64)+PBE+k) as *u8  pp[0u64]=ip[0u64]  k=k+1u64 }  PBE=PBE+IPLEN  PN=PN+1u32 } } }
/* does (base)[i0..] begin (after ws) with `#include "` ?  (local "..." -> 1 ; system <...> -> 0, lexer skips it) */
fn is_inc2(base:u64, i0:u64, len:u64) -> u32 {
    let mut k:u64=i0  let mut g:u32=1u32  while g==1u32 { if k>=len {g=0u32} else { let ch:u32=bb(base,k)  if ch==32u32 {k=k+1u64} else { if ch==9u32 {k=k+1u64} else {g=0u32} } } }
    if k>=len { return 0u32 }  if bb(base,k)!=35u32 { return 0u32 }  k=k+1u64
    let mut g2:u32=1u32  while g2==1u32 { if k>=len {g2=0u32} else { let ch:u32=bb(base,k)  if ch==32u32 {k=k+1u64} else { if ch==9u32 {k=k+1u64} else {g2=0u32} } } }
    if (k+7u64) > len { return 0u32 }
    if bb(base,k)!=105u32 { return 0u32 }  if bb(base,k+1u64)!=110u32 { return 0u32 }  if bb(base,k+2u64)!=99u32 { return 0u32 }  if bb(base,k+3u64)!=108u32 { return 0u32 }
    if bb(base,k+4u64)!=117u32 { return 0u32 }  if bb(base,k+5u64)!=100u32 { return 0u32 }  if bb(base,k+6u64)!=101u32 { return 0u32 }
    let mut k2:u64=k+7u64  let mut hq:u32=0u32  let mut g3:u32=1u32
    while g3==1u32 { if k2>=len {g3=0u32} else { let ch:u32=bb(base,k2)  if ch==10u32 {g3=0u32} else { if ch==34u32 {hq=1u32 g3=0u32} else {k2=k2+1u64} } } }
    return hq
}
/* recursively flatten (base)[0..len) -> SRC, inlining `#include "f"` (resolved vs main's dir), each file ONCE. */
fn flatten_buf(base:u64, len:u64, depth:u32) {
    if depth>=8u32 { return }
    let mut i:u64=0u64  let mut atls:u32=1u32
    while i < len {
        if atls==1u32 { if is_inc2(base,i,len)==1u32 {
            let mut k:u64=i  let mut g:u32=1u32  while g==1u32 { if k>=len {g=0u32} else { if bb(base,k)==34u32 {g=0u32} else {k=k+1u64} } }  k=k+1u64
            let mut d:u64=DIRLEN  let mut g2:u32=1u32  while g2==1u32 { if k>=len {g2=0u32} else { let ch:u32=bb(base,k)  if ch==34u32 {g2=0u32} else { let ip:*u8=((&IPATH as u64)+d) as *u8  ip[0u64]=(ch & 0xFFu32) as u8  d=d+1u64  k=k+1u64 } } }
            let ipe:*u8=((&IPATH as u64)+d) as *u8  ipe[0u64]=0u8  IPLEN=d
            if path_seen()==0u32 {
                path_add()
                let ib:u64 = (&IBUFS as u64) + (depth as u64)*131072u64
                let n:u64 = read_into(ib)
                flatten_buf(ib, n, depth+1u32)  src_emit(10u32)
            }
            let mut g3:u32=1u32  while g3==1u32 { if i>=len {g3=0u32} else { if bb(base,i)==10u32 {g3=0u32} else {i=i+1u64} } }  if i<len { i=i+1u64 }
        } else { let ch:u32=bb(base,i)  src_emit(ch)  if ch==10u32 {atls=1u32} else {atls=0u32}  i=i+1u64 } }
        else { let ch:u32=bb(base,i)  src_emit(ch)  if ch==10u32 {atls=1u32} else {atls=0u32}  i=i+1u64 }
    }
}
/* ---- preprocessor: conditional compilation (#ifdef/#ifndef/#if 0/#else/#endif + #undef) ---------------------
 * The seed uses ONLY definedness conditionals (40 #ifdef, 23 #ifndef, 1 `#if 0`; zero #elif).  A single in-place
 * compacting pass over the flattened SRC strips inactive branches BEFORE lex; the defined-set is built from
 * #define (which lex still consumes for numeric -> named constants).  No-op for conditional-free files. */
var PPDBUF : [u8; 131072]  var PPD_OFF : [u32; 8192]  var PPD_LEN : [u32; 8192]  var PPD_N : u32 = 0u32  var PPD_BE : u32 = 0u32   /* defined-name set (copied bytes; offsets stable across compaction) */
var PPCSTK : [u32; 64]  var PPCSP : u32 = 0u32                                                       /* conditional stack: 1=active 0=inactive */
fn pp_wsb(c:u32) -> u32 { if c==32u32 {return 1u32}  if c==9u32 {return 1u32}  return 0u32 }
fn pp_kw(o:u64, s:u64, n:u64) -> u32 { let mut k:u64=0u64  while k<n { let q:*u8=(s+k) as *u8  if sb(o+k)!=(q[0u64] as u32) {return 0u32}  k=k+1u64 }  if idc(sb(o+n))==1u32 {return 0u32}  return 1u32 }
fn pp_active() -> u32 { if PPCSP==0u32 {return 1u32}  return PPCSTK[(PPCSP-1u32) as u64] }
fn pp_push(a:u32) { if PPCSP<64u32 { PPCSTK[PPCSP as u64]=a  PPCSP=PPCSP+1u32 } }
fn pp_pop() { if PPCSP>0u32 { PPCSP=PPCSP-1u32 } }
fn pp_skipws(o:u64, le:u64) -> u64 { let mut p:u64=o  let mut g:u32=1u32  while g==1u32 { if p>=le {g=0u32} else { if pp_wsb(sb(p))==1u32 {p=p+1u64} else {g=0u32} } }  return p }
fn pp_namelen(o:u64) -> u64 { let mut l:u64=0u64  let mut g:u32=1u32  while g==1u32 { if idc(sb(o+l))==1u32 {l=l+1u64} else {g=0u32} }  return l }
fn ppdef_add(o:u64, l:u64) { if PPD_N<8192u32 { if (PPD_BE+(l as u32))<131072u32 { PPD_OFF[PPD_N as u64]=PPD_BE  PPD_LEN[PPD_N as u64]=l as u32  let mut k:u64=0u64  while k<l { let p:*u8=((&PPDBUF as u64)+(PPD_BE as u64)+k) as *u8  p[0u64]=sb(o+k) as u8  k=k+1u64 }  PPD_BE=PPD_BE+(l as u32)  PPD_N=PPD_N+1u32 } } }
fn ppdef_has(o:u64, l:u64) -> u32 { if l==0u64 {return 0u32}  let mut e:u32=0u32  while e<PPD_N { if PPD_LEN[e as u64]==(l as u32) { let mut k:u64=0u64  let mut eq:u32=1u32  while k<l { let p:*u8=((&PPDBUF as u64)+(PPD_OFF[e as u64] as u64)+k) as *u8  if (p[0u64] as u32)!=sb(o+k) {eq=0u32}  k=k+1u64 }  if eq==1u32 {return 1u32} }  e=e+1u32 }  return 0u32 }
fn ppdef_del(o:u64, l:u64) { let mut e:u32=0u32  while e<PPD_N { if PPD_LEN[e as u64]==(l as u32) { let mut k:u64=0u64  let mut eq:u32=1u32  while k<l { let p:*u8=((&PPDBUF as u64)+(PPD_OFF[e as u64] as u64)+k) as *u8  if (p[0u64] as u32)!=sb(o+k) {eq=0u32}  k=k+1u64 }  if eq==1u32 { PPD_LEN[e as u64]=0u32 } }  e=e+1u32 } }   /* #undef -> len 0, never matches */
fn preprocess() {
    PPD_N=0u32  PPD_BE=0u32  PPCSP=0u32
    let mut ri:u64=0u64  let mut wi:u64=0u64
    while ri<SLEN {
        let ls:u64=ri
        let mut le:u64=ri  let mut fe:u32=1u32  while fe==1u32 { if le>=SLEN {fe=0u32} else { if sb(le)==10u32 {le=le+1u64  fe=0u32} else {le=le+1u64} } }
        let ds:u64=pp_skipws(ls, le)
        let mut isdir:u32=0u32  if ds<le { if sb(ds)==35u32 {isdir=1u32} }
        let mut copy:u32=pp_active()
        if isdir==1u32 {
            copy=0u32
            let dk:u64=pp_skipws(ds+1u64, le)
            let pa:u32=pp_active()
            if pp_kw(dk,"ifdef" as u64,5u64)==1u32 { let no:u64=pp_skipws(dk+5u64,le)  let nl:u64=pp_namelen(no)  if pa==1u32 { pp_push(ppdef_has(no,nl)) } else { pp_push(0u32) } }
            else { if pp_kw(dk,"ifndef" as u64,6u64)==1u32 { let no:u64=pp_skipws(dk+6u64,le)  let nl:u64=pp_namelen(no)  if pa==1u32 { if ppdef_has(no,nl)==1u32 {pp_push(0u32)} else {pp_push(1u32)} } else { pp_push(0u32) } }
            else { if pp_kw(dk,"if" as u64,2u64)==1u32 { let vo:u64=pp_skipws(dk+2u64,le)  let mut act:u32=1u32  if sb(vo)==48u32 { if idc(sb(vo+1u64))==0u32 {act=0u32} }  if pa==1u32 { pp_push(act) } else { pp_push(0u32) } }   /* only `#if 0` matters in the seed */
            else { if pp_kw(dk,"endif" as u64,5u64)==1u32 { pp_pop() }
            else { if pp_kw(dk,"else" as u64,4u64)==1u32 { if PPCSP>0u32 { let top:u32=PPCSTK[(PPCSP-1u32) as u64]  let mut par:u32=1u32  if PPCSP>1u32 { par=PPCSTK[(PPCSP-2u32) as u64] }  if par==1u32 { if top==1u32 {PPCSTK[(PPCSP-1u32) as u64]=0u32} else {PPCSTK[(PPCSP-1u32) as u64]=1u32} } } }
            else { if pp_kw(dk,"define" as u64,6u64)==1u32 { if pa==1u32 { let no:u64=pp_skipws(dk+6u64,le)  let nl:u64=pp_namelen(no)  ppdef_add(no,nl)  copy=1u32 } }   /* keep the #define line for lex (numeric -> named const) */
            else { if pp_kw(dk,"undef" as u64,5u64)==1u32 { if pa==1u32 { let no:u64=pp_skipws(dk+5u64,le)  let nl:u64=pp_namelen(no)  ppdef_del(no,nl) } }
            else { copy=pa } } } } } } }   /* unknown # (e.g. residual #include/#error/#pragma) -> copy if active so lex skips it */
        }
        if copy==1u32 { let mut c:u64=ls  while c<le { let p:*u8=((&SRC as u64)+wi) as *u8  p[0u64]=sb(c) as u8  wi=wi+1u64  c=c+1u64 } }
        ri=le
    }
    SLEN=wi
}
fn main(argc: i32, argv: u64) -> u64 {
    if argc < 2i32 { return 2u64 }
    let pp : *u64 = argv as *u64
    let f : u64 = fopen(pp[1u64], &MODE_RB as u64)
    if f == 0u64 { return 3u64 }
    RLEN = fread(&RAW as u64, 1u64, 1048575u64, f)
    fclose(f)
    /* main file's directory (up to & incl the last / or \) -> IPATH prefix, so includes resolve beside it */
    let mp:*u8 = pp[1u64] as *u8  let mut j:u64=0u64  let mut last:u64=0u64
    let mut gg:u32=1u32  while gg==1u32 { let ch:u32=mp[j] as u32  if ch==0u32 {gg=0u32} else { if ch==47u32 {last=j+1u64} if ch==92u32 {last=j+1u64}  j=j+1u64 } }
    let mut dd:u64=0u64  while dd<last { let ip:*u8=((&IPATH as u64)+dd) as *u8  ip[0u64]=mp[dd]  dd=dd+1u64 }  DIRLEN=last
    SLEN=0u64  flatten_buf(&RAW as u64, RLEN, 0u32)
    preprocess()                                                   /* strip inactive #ifdef/#ifndef/#if-0 branches before lex */
    lex()  prescan()  prescan_str()  prescan_arr()  prescan_struct()  prescan_enum()  prescan_structarr()   /* struct ARRAYS last: needs STSZ (prescan_struct) + enum consts (prescan_enum) + MTOP after scalar arrays */
    if argc>=3i32 {   /* DEBUG: `ccsv file.c <any-2nd-arg>` -> print each registered fn's index + name (FNO/FNL into SRC), then exit -- maps SVIR fn-index to source */
        let mut fk:u32=0u32  while fk<FN { pdec(fk as u64)  pc(58u32)  pc(32u32)  let mut ci:u32=0u32  while ci<FNL[fk as u64] { pc(sb((FNO[fk as u64]+ci) as u64))  ci=ci+1u32 }  pc(10u32)  fk=fk+1u32 }
        return 0u64
    }
    ML=0u64
    let mut k:u32=0u32
    while k<FN { cfn(k)  k=k+1u32 }
    if DEND > 0u64 {                                                /* append the SVIR data section [u16 len][bytes] (strings + array inits) */
        mb((DEND & 0xFFu64) as u32)  mb(((DEND >> 8u64) & 0xFFu64) as u32)
        let mut d:u64=0u64  while d<DEND { mb(SDAT[d] as u32)  d=d+1u64 }
    }
    if LOVF==1u32 { pstr("// FATAL ccsv: a function exceeds the 256 SVIR-local cap -- needs LEB-encoded local indices (the silent slot-256->0 collision is refused).\n!!!CCSV_LOCAL_OVERFLOW!!!\n" as u64)  return 7u64 }   /* LOUD: emit unparseable iii + nonzero exit, never silently-corrupt SVIR */
    emit_module()
    return 0u64
}
