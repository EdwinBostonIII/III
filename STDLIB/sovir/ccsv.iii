fn emit_realloc() {   /* [p, newsize] -> new ptr (header-based: copy min(oldsize,newsize); the old block leaks -- bump heap) */
    let tnw:u32=LN  if LN<255u32 {LN=LN+1u32}  let tp:u32=LN  if LN<255u32 {LN=LN+1u32}  let tr:u32=LN  if LN<255u32 {LN=LN+1u32}  let tc:u32=LN  if LN<255u32 {LN=LN+1u32}  let ti:u32=LN  if LN<255u32 {LN=LN+1u32}
    eu8(0x11u32,tnw)  eu8(0x11u32,tp)                                                                     /* tnw=newsize (top), tp=p */
    eu8(0x10u32,tnw)  emit_malloc()  eu8(0x11u32,tr)                                                      /* tr = malloc(newsize) */
    eu8(0x10u32,tp)  econst(0i64)  eb(0x31u32)  eb(0x42u32)                                               /* if p != 0 */
        eu8(0x10u32,tp)  econst(8i64)  eb(0x21u32)  eb(0x82u32)  eu8(0x11u32,tc)                          /* tc = *(p-8) = old size */
        eu8(0x10u32,tc)  eu8(0x10u32,tnw)  eb(0x34u32)  eb(0x42u32)  eb(0x43u32)  eu8(0x10u32,tnw)  eu8(0x11u32,tc)  eb(0x44u32)   /* tc = min(oldsize, newsize) */
        econst(0i64)  eu8(0x11u32,ti)
        eb(0x40u32)  eb(0x41u32)                                                                          /* copy tc bytes p->newp */
        eu8(0x10u32,ti)  eu8(0x10u32,tc)  eb(0x33u32)  eu8(0x51u32,1u32)                                  /* if i>=tc break */
        eu8(0x10u32,tr)  eu8(0x10u32,ti)  eb(0x20u32)  eu8(0x10u32,tp)  eu8(0x10u32,ti)  eb(0x20u32)  eb(0x80u32)  eb(0x81u32)   /* newp[i] = p[i] */
        eu8(0x10u32,ti)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ti)  eu8(0x50u32,0u32)
        eb(0x44u32)  eb(0x44u32)
