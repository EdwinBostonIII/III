fn prescan_arr() {   /* `[quals] type NAME[NUM] [= { v0, ... }] ;` -> base in SVIR linear memory (after strings) + init data */
    AN=0u32  MTOP=DLEN  DEND=0u64  if DLEN>16u64 {DEND=DLEN}  let mut t:u32=0u32  let mut pd:u32=0u32  let mut bd:u32=0u32   /* the [0..15] NULL reserve is implicit zeros (linear mem is zero-init) -> only emit a data section when REAL data (strings DLEN>16 / array inits) sits above it; keeps no-data modules data-section-free (cross-language DDC) */
    while t<NT {
        if ispat(t,Q_LP)==1u32 {pd=pd+1u32}  if ispat(t,Q_RP)==1u32 { if pd>0u32 {pd=pd-1u32} }   /* paren depth: params live at pd>0, NOT global arrays */
        if ispat(t,Q_LB)==1u32 {bd=bd+1u32}  if ispat(t,Q_RB)==1u32 { if bd>0u32 {bd=bd-1u32} }   /* brace depth: a SCALAR global lives at bd==0 (outside any fn body); struct bodies are jumped past, so their braces don't count */
        let mut isst:u32=0u32  if kw(t,"struct" as u64,6u32)==1u32 {isst=1u32}  if kw(t,"union" as u64,5u32)==1u32 {isst=1u32}
        let mut adv:u32=1u32
        if isst==1u32 {                                            /* struct/union body -> SKIP (fields are NOT global arrays) */
            let mut sq:u32=t+1u32  if TK[sq as u64]==1u32 { sq=sq+1u32 }   /* optional tag */
            if ispat(sq,Q_LB)==1u32 { let mut d:u32=0u32  let mut sg:u32=1u32  while sg==1u32 { if sq>=NT {sg=0u32} else { if ispat(sq,Q_LB)==1u32 {d=d+1u32}  if ispat(sq,Q_RB)==1u32 {d=d-1u32}  sq=sq+1u32  if d==0u32 {sg=0u32} } }  t=sq  adv=0u32 }
        } else {
        let mut isd:u32=0u32  if isqual(t)==1u32 {isd=1u32}  if dtype(t)==1u32 {isd=1u32}
        if pd>0u32 {isd=0u32}                                       /* inside a param list -> the array param decays to a pointer, not a global array */
        if isd==1u32 {
            let mut q:u32=t  let mut g0:u32=1u32  while g0==1u32 { if isqual(q)==1u32 {q=q+1u32} else {g0=0u32} }   /* skip quals */
            if dtype(q)==1u32 {
                let mut nt:u32=q+1u32  let mut pelem:u32=0u32  let mut gpp:u32=1u32  while gpp==1u32 { if ispat(nt,Q_MUL)==1u32 { pelem=1u32  nt=nt+1u32 } else { if isqual(nt)==1u32 { nt=nt+1u32 } else {gpp=0u32} } }   /* `type *[const] NAME[]` -> pointer elements (8B) ; skip `*` runs + quals after (`char *const`) */
                if TK[nt as u64]==1u32 { if ispat(nt+1u32,Q_LBR)==1u32 {                                             /* NAME [ NUM | empty ] [= {...}] */
                    let mut esz:i64=aesz_of(q)  if pelem==1u32 {esz=8i64}  let eszu:u64=esz as u64  let base:u64=MTOP
                    let mut n:u64=0u64  let mut brc:u32=0u32  let mut have:u32=0u32  let mut strt:u32=0u32  let mut arow_v:i64=0i64
                    let mut szok:u32=0u32  if TK[(nt+2u32) as u64]==2u32 { n=TV[(nt+2u32) as u64] as u64  szok=1u32 } else { if TK[(nt+2u32) as u64]==1u32 { let nci:i32=cidx(nt+2u32)  if nci>=0i32 { n=CNV[nci as u64] as u64  szok=1u32 } } }   /* [NAMED_CONST] size (enum/#define) -> cidx; needs prescan_enum BEFORE prescan_arr (moved) */
                    if szok==1u32 { n=n+0u64                                                              /* [NUM] or [NAMED_CONST] */
                        if ispat(nt+4u32,Q_LBR)==1u32 { let cdim:u64=TV[(nt+5u32) as u64] as u64  arow_v=(cdim as i64)*esz  n=n*cdim }   /* `T NAME[R][C]` TRUE 2D array -> contiguous: row stride C*esz, total R*C elems (Step D) */
                        else { if ispat(nt+4u32,Q_ASN)==1u32 { if ispat(nt+5u32,Q_LB)==1u32 { brc=nt+6u32  have=1u32 } else { if TK[(nt+5u32) as u64]==4u32 { strt=nt+5u32 } } } } }
                    else { if ispat(nt+2u32,Q_RBR)==1u32 { if ispat(nt+3u32,Q_ASN)==1u32 {
                        if ispat(nt+4u32,Q_LB)==1u32 {   /* [] = { ... } -> size from init count */
                            brc=nt+5u32  have=1u32  let mut cq:u32=brc  let mut cg2:u32=1u32
                            while cg2==1u32 { if ispat(cq,Q_RB)==1u32 {cg2=0u32} else { if TK[cq as u64]==0u32 {cg2=0u32} else { if ispat(cq,Q_COM)==1u32 {cq=cq+1u32} else { n=n+1u64  cq=cq+1u32 } } } }
                        } else { if TK[(nt+4u32) as u64]==4u32 { strt=nt+4u32  n=(TL[(nt+4u32) as u64] as u64)+1u64 } }   /* `char[] = "string"` -> alias the string literal */
                    } } }
                    if strt>0u32 { base=TV[strt as u64] as u64 }   /* char[] = "..." : ALIAS the string literal's data section bytes (no new storage / copy) */
                    if n>0u64 {
                        AO[AN as u64]=TO[nt as u64]  AL[AN as u64]=TL[nt as u64]  AB[AN as u64]=base  AVT[AN as u64]=0i32-1i32  AW[AN as u64]=type_mask(q)  AESZ[AN as u64]=esz  ALEN[AN as u64]=n  ASGN[AN as u64]=type_signed(q)  AROW[AN as u64]=arow_v  AN=AN+1u32
                        if strt==0u32 { MTOP=MTOP+(n*eszu) }   /* a string-aliased array owns no storage */
                        if have==1u32 {
                            let mut p:u32=brc  let mut idx:u64=0u64  let mut gg:u32=1u32
                            while gg==1u32 {
                                if ispat(p,Q_RB)==1u32 {gg=0u32} else { if TK[p as u64]==0u32 {gg=0u32}
                                else { if ispat(p,Q_LBR)==1u32 { p=p+1u32  let mut di:u64=idx  if TK[p as u64]==2u32 {di=TV[p as u64] as u64} else { let dci:i32=cidx(p)  if dci>=0i32 {di=CNV[dci as u64] as u64} }  idx=di  p=p+1u32  if ispat(p,Q_RB)==1u32 {p=p+1u32}  if ispat(p,Q_ASN)==1u32 {p=p+1u32} }   /* designated `[Di] =` -> store the NEXT value at index Di (enum/#define designator via cidx) */
                                       if TK[p as u64]==2u32 { data_putn(esz, base + idx*eszu, TV[p as u64])  idx=idx+1u64  p=p+1u32 }            /* numeric */
                                       else { if TK[p as u64]==4u32 { data_putn(esz, base + idx*eszu, TV[p as u64])  idx=idx+1u64  p=p+1u32 }    /* string literal -> its address */
                                              else { let ci:i32=cidx(p)  if ci>=0i32 { data_putn(esz, base + idx*eszu, CNV[ci as u64])  idx=idx+1u64 }  p=p+1u32 } }
                                       if ispat(p,Q_COM)==1u32 {p=p+1u32} } }
                            }
                            let de:u64=base + idx*eszu  if de > DEND { DEND=de }
                        }
                    }
                    let mut ccp:u32=nt+1u32  let mut gsk:u32=1u32  while gsk==1u32 { if ispat(ccp,Q_LBR)==1u32 { ccp=ccp+1u32  let mut gx2:u32=1u32  while gx2==1u32 { if ispat(ccp,Q_RBR)==1u32 {gx2=0u32} else { if TK[ccp as u64]==0u32 {gx2=0u32} else {ccp=ccp+1u32} } }  ccp=ccp+1u32 } else {gsk=0u32} }   /* `T a[N], b[M], c[K]` : comma-continued SAME-TYPE array declarators -> register b,c,.. with q's elem type (ccp now past a's [..]) */
                    let mut gmore2:u32=1u32  while gmore2==1u32 {
                        if ispat(ccp,Q_COM)==1u32 { let cnm:u32=ccp+1u32
                            if TK[cnm as u64]==1u32 { if ispat(cnm+1u32,Q_LBR)==1u32 { if TK[(cnm+2u32) as u64]==2u32 {
                                let cnn:u64=TV[(cnm+2u32) as u64] as u64
                                AO[AN as u64]=TO[cnm as u64]  AL[AN as u64]=TL[cnm as u64]  AB[AN as u64]=MTOP  AVT[AN as u64]=0i32-1i32  AW[AN as u64]=type_mask(q)  AESZ[AN as u64]=esz  ALEN[AN as u64]=cnn  ASGN[AN as u64]=type_signed(q)  MTOP=MTOP+(cnn*eszu)  AN=AN+1u32
                                ccp=cnm+4u32
                            } else {gmore2=0u32} } else {gmore2=0u32} } else {gmore2=0u32} }
                        else {gmore2=0u32} }
                } else {   /* file-scope SCALAR global: `[quals] type [*] NAME [= const] ;` (bd==0, not a typedef) */
                    let mut istd:u32=0u32  if kw(t,"typedef" as u64,7u32)==1u32 {istd=1u32}  if t>=1u32 { if kw(t-1u32,"typedef" as u64,7u32)==1u32 {istd=1u32} }
                    if bd==0u32 { if istd==0u32 {
                        let nx:u32=nt+1u32  let mut issc:u32=0u32
                        if ispat(nx,Q_SEMI)==1u32 {issc=1u32}  if ispat(nx,Q_ASN)==1u32 {issc=1u32}  if ispat(nx,Q_COM)==1u32 {issc=1u32}
                        if issc==1u32 {
                            let mut sz2:i64=aesz_of(q)  if pelem==1u32 {sz2=8i64}  let base2:u64=MTOP
                            AO[AN as u64]=TO[nt as u64]  AL[AN as u64]=TL[nt as u64]  AB[AN as u64]=base2  AVT[AN as u64]=0i32-1i32  AISC[AN as u64]=1u32  ALEN[AN as u64]=1u64
                            if pelem==1u32 { AW[AN as u64]=0i64  AESZ[AN as u64]=8i64  ASGN[AN as u64]=0u32  let mut sd:u32=q+1u32  let mut pdepth:u32=0u32  while ispat(sd,Q_MUL)==1u32 {pdepth=pdepth+1u32  sd=sd+1u32}  if pdepth>=2u32 { APSZ[AN as u64]=8i64  APSG[AN as u64]=0u32 } else { APSZ[AN as u64]=aesz_of(q)  APSG[AN as u64]=type_signed(q) } } else { AW[AN as u64]=type_mask(q)  AESZ[AN as u64]=sz2  ASGN[AN as u64]=type_signed(q) }   /* APSZ/APSG: pointee width+sign (8 for multi-level ptr) */
                            MTOP=MTOP+(sz2 as u64)  AN=AN+1u32
                            if ispat(nx,Q_ASN)==1u32 { if TK[(nt+2u32) as u64]==2u32 { data_putn(sz2, base2, TV[(nt+2u32) as u64])  let de:u64=base2+(sz2 as u64)  if de>DEND {DEND=de} }   /* = numeric */
                                else { if ispat(nt+2u32,Q_AND)==1u32 { let av:i64=abase(nt+3u32)  if av>=0i64 { data_putn(sz2, base2, av)  let de:u64=base2+(sz2 as u64)  if de>DEND {DEND=de} } }   /* = &GLOBAL : a pointer initialized to another global's ADDRESS (was DROPPED -> ptr stayed 0) */
                                    else { let ci:i32=cidx(nt+2u32)  if ci>=0i32 { data_putn(sz2, base2, CNV[ci as u64])  let de:u64=base2+(sz2 as u64)  if de>DEND {DEND=de} }   /* = named const */
                                        else { let av2:i64=abase(nt+2u32)  if av2>=0i64 { data_putn(sz2, base2, av2)  let de:u64=base2+(sz2 as u64)  if de>DEND {DEND=de} } } } } }   /* = BARE_GLOBAL (array/var decays to its address) */
                        }
                    } }
                } } }
            }
        }
        if adv==1u32 { t=t+1u32 }
    }
}
/* register a struct/union type: parse `int|char [*] field ;` entries from after_brace to the }, offsets cumulative
 * (struct) or all-0 (union).  is_union -> size 8 (max i64/ptr field). */
var ANON_TOK:[u32;512]  var ANON_IDX:[i32;512]  var ANON_N:u32=0u32   /* ANONYMOUS aggregate field `union{..}u` / `struct{..}f`: its `{` token -> the implicit struct-table index (append-only; brace tokens are unique) */
fn anon_lookup(bt:u32) -> i32 { let mut k:u32=0u32  while k<ANON_N { if ANON_TOK[k as u64]==bt {return ANON_IDX[k as u64]}  k=k+1u32 }  return 0i32-1i32 }
fn match_rb(body:u32) -> u32 { let mut q:u32=body  let mut d:i32=0i32  let mut g:u32=1u32   /* the `}` that matches the brace whose body starts at `body` (depth-aware, unlike find_rb) */
    while g==1u32 { if ispat(q,Q_LB)==1u32 {d=d+1i32} else { if ispat(q,Q_RB)==1u32 { if d==0i32 {g=0u32} else {d=d-1i32} } }  if TK[q as u64]==0u32 {g=0u32}  if g==1u32 {q=q+1u32} }  return q }
fn pre_register_anons(body:u32) {   /* register each ANONYMOUS aggregate in this body DEPTH-FIRST (lower STN, fields contiguous) BEFORE the enclosing struct claims its slot -- so its field range stays contiguous */
    let mut q:u32=body  let mut g:u32=1u32
    while g==1u32 {
        if ispat(q,Q_RB)==1u32 {g=0u32} else { if TK[q as u64]==0u32 {g=0u32}
        else {
            let mut isa:u32=0u32  let mut isu:u32=0u32
            if kw(q,"struct" as u64,6u32)==1u32 { if ispat(q+1u32,Q_LB)==1u32 {isa=1u32} }
            if kw(q,"union" as u64,5u32)==1u32 { if ispat(q+1u32,Q_LB)==1u32 {isa=1u32  isu=1u32} }
            if isa==1u32 { let bt:u32=q+1u32  reg_type(bt, q+2u32, isu)   /* recurses: pre-registers ITS anons, then itself */
                if ANON_N<512u32 { ANON_TOK[ANON_N as u64]=bt  ANON_IDX[ANON_N as u64]=(STN as i32)-1i32  ANON_N=ANON_N+1u32 }
                let rb:u32=match_rb(q+2u32)  q=rb+1u32   /* past the anon `}` -> the field name */
                let mut g2:u32=1u32  while g2==1u32 { if ispat(q,Q_SEMI)==1u32 {g2=0u32} else { if TK[q as u64]==0u32 {g2=0u32} else {q=q+1u32} } }  if ispat(q,Q_SEMI)==1u32 {q=q+1u32}
            } else { let mut g3:u32=1u32  while g3==1u32 { if ispat(q,Q_SEMI)==1u32 {g3=0u32} else { if ispat(q,Q_RB)==1u32 {g3=0u32} else { if TK[q as u64]==0u32 {g3=0u32} else {q=q+1u32} } } }  if ispat(q,Q_SEMI)==1u32 {q=q+1u32} }   /* skip a normal field */
        } }
    }
}
fn reg_fields(si:u32) {   /* fill slot si's fields from its stored body (STBODY/STUNION); RE-RUNNABLE so prescan_struct's fixpoint resolves forward-referenced embedded-struct SIZES (BUG-B: a struct embedding another struct that is registered LATER was sized as int(4)) */
    let after_brace:u32=STBODY[si as u64]  let is_union:u32=STUNION[si as u64]
    STFB[si as u64]=SFN
    let mut q:u32=after_brace  let mut off:u64=0u64  let mut nf:u32=0u32  let mut maxal:u64=1u64  let mut maxsz:u64=0u64  let mut g:u32=1u32   /* maxsz = largest member size (union size = max member, not the old hardcoded 8) */
    while g==1u32 {
        if ispat(q,Q_RB)==1u32 {g=0u32} else { if TK[q as u64]==0u32 {g=0u32}
        else { let mut gqf:u32=1u32  let mut sawspec:u32=0u32  let mut specsz:i64=4i64  while gqf==1u32 { if isqual(q)==1u32 { if kw(q,"unsigned" as u64,8u32)==1u32 {sawspec=1u32}  if kw(q,"signed" as u64,6u32)==1u32 {sawspec=1u32}  if kw(q,"long" as u64,4u32)==1u32 {sawspec=1u32  specsz=8i64}  if kw(q,"short" as u64,5u32)==1u32 {sawspec=1u32  specsz=2i64}  q=q+1u32 } else {gqf=0u32} }   /* BUG-A fix: skip leading field qualifiers so `const uint8_t *src` registers `src` (8B ptr), not `uint8_t` (4B int).  ALSO track a bare type-SPECIFIER (`unsigned`/`signed`/`long`/`short` w/ NO following dtype -> IS the type: 4B/4B/8B/2B), else the seed's `unsigned ring_mask` (sema) loses the field + mis-offsets the rest. */
              let mut scl:u32=dtype(q)  let mut sesz:i64=0i64  let mut smask:i64=0i64  let mut ssgn:u32=0u32  let mut sq:u32=q+1u32
              if scl==1u32 { sesz=type_size(q)  smask=type_mask(q)  ssgn=type_signed(q) }
              else { if sawspec==1u32 { if ispat(q,Q_MUL)==0u32 { if TK[(q) as u64]==1u32 { scl=1u32  sesz=specsz  smask=0i64  ssgn=0u32  sq=q } } } }   /* bare type-SPECIFIER field: skipquals ATE the `unsigned`/`signed`/`long`/`short`, so q is the NAME (sq=q) and the size came from specsz (the seed's sema `unsigned ring_mask`=4B); `unsigned int` etc. still hit dtype(q) above */
              if scl==1u32 {
            let mut esz:i64=sesz  let mut fmask:i64=smask  let mut fsgn:u32=ssgn  let mut fq:u32=sq  if ispat(fq,Q_MUL)==1u32 { while ispat(fq,Q_MUL)==1u32 { fq=fq+1u32 }  esz=8i64  fmask=0i64  fsgn=0u32 }  else { if ispat(fq,Q_LP)==1u32 { if ispat(fq+1u32,Q_MUL)==1u32 { fq=fq+2u32  esz=8i64  fmask=0i64  fsgn=0u32 } } }   /* `TYPE *field` / `TYPE **field` (consume ALL `*` -- a DOUBLE-ptr field `const uint8_t **string_payloads` was registered with the 2nd `*` AS the name, so `ast->string_payloads` could not be found -> the assign mis-compiled, iii_ast_create rc=8) -> 8B ptr ; ALSO `TYPE (*field)[N]` POINTER-TO-ARRAY field -> 8B ptr (name after `(*`) -- the seed's ast `uint8_t (*small_mhash)[32]`, else mis-sized as TYPE(1B) + every later field mis-offset */
            let mut isarr:u32=0u32  if ispat(fq+1u32,Q_LBR)==1u32 { isarr=1u32 }
            let al:u64=esz as u64  if is_union==0u32 { let r:u64=off & (al - 1u64)  if r!=0u64 { off=off+(al-r) } }   /* C natural alignment: align off up to the element/scalar size */
            if al>maxal { maxal=al }
            SFO[SFN as u64]=TO[fq as u64]  SFL[SFN as u64]=TL[fq as u64]  SFOFF[SFN as u64]=off  SFEL[SFN as u64]=esz  SFAR[SFN as u64]=isarr  SFMASK[SFN as u64]=fmask  SFSGN[SFN as u64]=fsgn  SFPT[SFN as u64]=0i32-1i32
            let mut fsz:u64=esz as u64                                                          /* scalar field size */
            if isarr==1u32 { if TK[(fq+2u32) as u64]==2u32 { fsz=(TV[(fq+2u32) as u64] as u64)*(esz as u64) } }   /* array field: NUM*elem */
            SFSZ[SFN as u64]=fsz as i64                                                            /* total field bytes (sizeof(p->field)) */
            if fsz>maxsz {maxsz=fsz}
            SFN=SFN+1u32  nf=nf+1u32
            if is_union==0u32 { off=off+fsz }
            let mut g2:u32=1u32  while g2==1u32 { if ispat(q,Q_SEMI)==1u32 {g2=0u32} else { if TK[q as u64]==0u32 {g2=0u32} else {q=q+1u32} } }  q=q+1u32
        } else {
            /* struct-typed field: `struct TAG [*]f ;` / `union TAG [*]f ;` / `TypedefName [*]f ;` (the dtype branch only handles scalar fields) */
            let mut isanf:u32=0u32
            if kw(q,"struct" as u64,6u32)==1u32 { if ispat(q+1u32,Q_LB)==1u32 {isanf=1u32} }
            if kw(q,"union" as u64,5u32)==1u32 { if ispat(q+1u32,Q_LB)==1u32 {isanf=1u32} }
            if isanf==1u32 {   /* ANONYMOUS `union{..}NAME` / `struct{..}NAME` field -> the pre-registered implicit type (anon_lookup) */
                let bt:u32=q+1u32  let aidx:i32=anon_lookup(bt)  let arb:u32=match_rb(q+2u32)  let nm:u32=arb+1u32
                let mut aesz:i64=8i64  if aidx>=0i32 { aesz=STSZ[aidx as u64] as i64 }
                if is_union==0u32 { let r:u64=off & 7u64  if r!=0u64 { off=off+(8u64-r) } }  if 8u64>maxal {maxal=8u64}
                SFO[SFN as u64]=TO[nm as u64]  SFL[SFN as u64]=TL[nm as u64]  SFOFF[SFN as u64]=off  SFEL[SFN as u64]=aesz  SFAR[SFN as u64]=0u32  SFMASK[SFN as u64]=0i64  SFSGN[SFN as u64]=0u32  SFPT[SFN as u64]=aidx
                let afsz:u64=aesz as u64  if afsz>maxsz {maxsz=afsz}
                SFN=SFN+1u32  nf=nf+1u32  if is_union==0u32 { off=off+afsz }
                q=nm+1u32  let mut ga:u32=1u32  while ga==1u32 { if ispat(q,Q_SEMI)==1u32 {ga=0u32} else { if TK[q as u64]==0u32 {ga=0u32} else {q=q+1u32} } }  q=q+1u32
            } else {
            let mut isstf:u32=0u32  let mut tnameb:u32=q  let mut styi:i32=0i32-1i32
            if kw(q,"struct" as u64,6u32)==1u32 { if TK[(q+1u32) as u64]==1u32 { isstf=1u32  styi=stidx(q+1u32)  tnameb=q+2u32 } }
            else { if kw(q,"union" as u64,5u32)==1u32 { if TK[(q+1u32) as u64]==1u32 { isstf=1u32  styi=stidx(q+1u32)  tnameb=q+2u32 } }
                   else { if TK[q as u64]==1u32 { let ts:i32=stidx(q)  if ts>=0i32 { isstf=1u32  styi=ts  tnameb=q+1u32 } } } }
            if isstf==1u32 {
                let mut esz:i64=8i64  let mut fq:u32=tnameb
                if ispat(fq,Q_MUL)==1u32 { fq=fq+1u32  esz=8i64 }                                      /* struct-pointer field -> 8 bytes */
                else { if styi>=0i32 { esz=STSZ[styi as u64] as i64 } }                                /* embedded struct -> its size */
                let mut isarr:u32=0u32  if ispat(fq+1u32,Q_LBR)==1u32 { isarr=1u32 }
