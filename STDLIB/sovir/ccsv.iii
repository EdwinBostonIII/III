    eb(0x40u32)  eb(0x41u32)                                                       /* BLOCK LOOP : walk fmt */
    eu8(0x10u32,tf)  eb(0x80u32)  eu8(0x11u32,tc)                                  /* tc = *tf */
    eu8(0x10u32,tc)  econst(0i64)  eb(0x30u32)  eu8(0x51u32,1u32)                  /* if tc==0 -> break */
    eu8(0x10u32,tc)  econst(37i64)  eb(0x30u32)  eb(0x42u32)                       /* if tc=='%' */
