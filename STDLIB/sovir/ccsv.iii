            else { if pp_kw(dk,"ifndef" as u64,6u64)==1u32 { let no:u64=pp_skipws(dk+6u64,le)  let nl:u64=pp_namelen(no)  if pa==1u32 { if ppdef_has(no,nl)==1u32 {pp_push(0u32)} else {pp_push(1u32)} } else { pp_push(0u32) } }
            else { if pp_kw(dk,"if" as u64,2u64)==1u32 { let vo:u64=pp_skipws(dk+2u64,le)  let mut act:u32=1u32  if sb(vo)==48u32 { if idc(sb(vo+1u64))==0u32 {act=0u32} }  if pa==1u32 { pp_push(act) } else { pp_push(0u32) } }   /* only `#if 0` matters in the seed */
            else { if pp_kw(dk,"endif" as u64,5u64)==1u32 { pp_pop() }
