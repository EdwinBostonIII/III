/* ccsv.iii -- the FOUNDATION of the non-gcc C compiler: compiles the C integer core -> SVIR, thence to a
 * SOVEREIGN x86 PE (svir_x86 -> sovas -> sovld) with NO gcc in the artifact path.  This is the seed-DDC's
 * missing input begun: an independent C front-end whose backend is III's own sovereign toolchain, not gcc.
 *
 * Subset (C's integer core, == SVIR's): int NAME(int p, ...) { ... } ; int x = e ; x = e ; if (e) {} else {} ;
 *   while (e) {} ; return e ; calls ; + - * / % & | ^ << >> == != < > <= >= , parens, int literals, locals.
 *   All ints are i64.  Reads argv[1] (a .c file); emits a .iii module wrapping SVIR v1 bytes (DOCS/SVIR-V1-
 *   CANONICAL.md), consumed by svir_x86/svir_wasm.  main() is SVIR func 0.
 * HONEST SCOPE: this compiles the integer core; the 26k-line iiis-0 seed uses full C (structs, pointers,
 * preprocessor, ...) -- the long road this foundation begins.  Demonstrates: a C program -> sovereign x86 (no
 * gcc) AND a mini-DDC (ccsv build vs gcc build agree on behaviour). */
module ccsv

extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fread(buf: u64, size: u64, n: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(stream: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

var SRC : [u8; 65536]
var SLEN : u64 = 0u64
var MODE_RB : [u8; 3] = [114u8, 98u8, 0u8]
var RAW : [u8; 65536]  var RLEN : u64 = 0u64        /* the main file, pre-flatten */
var IBUFS : [u8; 262144]                            /* 8 include levels x 32768 (depth-indexed; recursion-safe) */
var IPATH : [u8; 512]  var DIRLEN : u64 = 0u64  var IPLEN : u64 = 0u64   /* resolved include path = main's dir + "filename" */
var PATHBUF : [u8; 8192]  var POFF : [u64; 256]  var PLEN : [u64; 256]  var PN : u32 = 0u32  var PBE : u64 = 0u64   /* include-once set */
var TK : [u32; 8192]  var TV : [i64; 8192]  var TO : [u32; 8192]  var TL : [u32; 8192]  var NT : u32 = 0u32  var C : u32 = 0u32

const Q_LP:i64=1i64 const Q_RP:i64=2i64 const Q_LB:i64=3i64 const Q_RB:i64=4i64 const Q_SEMI:i64=7i64 const Q_ASN:i64=8i64
const Q_EQ:i64=10i64 const Q_NE:i64=11i64 const Q_LT:i64=12i64 const Q_GT:i64=13i64 const Q_LE:i64=14i64 const Q_GE:i64=15i64
const Q_ADD:i64=16i64 const Q_SUB:i64=17i64 const Q_MUL:i64=18i64 const Q_DIV:i64=19i64 const Q_MOD:i64=20i64
const Q_AND:i64=21i64 const Q_OR:i64=22i64 const Q_XOR:i64=23i64 const Q_SHL:i64=24i64 const Q_SHR:i64=25i64 const Q_COM:i64=6i64
const Q_LBR:i64=26i64 const Q_RBR:i64=27i64 const Q_DOT:i64=28i64 const Q_ARROW:i64=29i64 const Q_INC:i64=30i64 const Q_DEC:i64=31i64 const Q_NOT:i64=32i64 const Q_QUEST:i64=33i64 const Q_COLON:i64=34i64

fn sp(c: u32) -> u32 { if c==32u32 {return 1u32} if c==9u32 {return 1u32} if c==10u32 {return 1u32} if c==13u32 {return 1u32} return 0u32 }
fn dg(c: u32) -> u32 { if c>=48u32 { if c<=57u32 {return 1u32} } return 0u32 }
fn hx(c: u32) -> u32 { if c>=48u32 { if c<=57u32 {return 1u32} }  if c>=97u32 { if c<=102u32 {return 1u32} }  if c>=65u32 { if c<=70u32 {return 1u32} }  return 0u32 }
fn hv(c: u32) -> i64 { if c<=57u32 {return (c-48u32) as i64}  if c>=97u32 {return ((c-97u32)+10u32) as i64}  return ((c-65u32)+10u32) as i64 }
fn idc(c: u32) -> u32 { if c==95u32 {return 1u32} if c>=48u32 { if c<=57u32 {return 1u32} } if c>=65u32 { if c<=90u32 {return 1u32} } if c>=97u32 { if c<=122u32 {return 1u32} } return 0u32 }
fn ids(c: u32) -> u32 { if c==95u32 {return 1u32} if c>=65u32 { if c<=90u32 {return 1u32} } if c>=97u32 { if c<=122u32 {return 1u32} } return 0u32 }
fn sb(i: u64) -> u32 { let p : *u8 = ((&SRC as u64) + i) as *u8  return p[0u64] as u32 }
fn pt(k: u32, v: i64, o: u32, l: u32) { if NT < 8192u32 { TK[NT as u64]=k  TV[NT as u64]=v  TO[NT as u64]=o  TL[NT as u64]=l  NT=NT+1u32 } }

fn lex() {
    NT = 0u32
    let mut i : u64 = 0u64
    while i < SLEN {
        let c : u32 = sb(i)  let c2 : u32 = sb(i+1u64)  let mut done : u32 = 0u32
        if sp(c)==1u32 { i=i+1u64  done=1u32 }
        if done==0u32 { if c==35u32 {   /* #define NAME <number> -> a named constant ; other # directives -> skip the line */
            i=i+1u64
            let mut g0:u32=1u32  while g0==1u32 { if i>=SLEN {g0=0u32} else { let w0:u32=sb(i)  if w0==32u32 {i=i+1u64} else { if w0==9u32 {i=i+1u64} else {g0=0u32} } } }
            let dwo:u64=i  let mut g1:u32=1u32  while g1==1u32 { if i>=SLEN {g1=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g1=0u32} } }
            let dwl:u64=i-dwo  let mut isdef:u32=0u32
            if dwl==6u64 { if sb(dwo)==100u32 { if sb(dwo+1u64)==101u32 { if sb(dwo+2u64)==102u32 { if sb(dwo+3u64)==105u32 { if sb(dwo+4u64)==110u32 { if sb(dwo+5u64)==101u32 { isdef=1u32 } } } } } } }
            if isdef==1u32 {
                let mut g2:u32=1u32  while g2==1u32 { if i>=SLEN {g2=0u32} else { let w2:u32=sb(i)  if w2==32u32 {i=i+1u64} else { if w2==9u32 {i=i+1u64} else {g2=0u32} } } }
                let no:u64=i  let mut g3:u32=1u32  while g3==1u32 { if i>=SLEN {g3=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g3=0u32} } }
                let nl:u64=i-no
                let mut g4:u32=1u32  while g4==1u32 { if i>=SLEN {g4=0u32} else { let w4:u32=sb(i)  if w4==32u32 {i=i+1u64} else { if w4==9u32 {i=i+1u64} else {g4=0u32} } } }
                if i<SLEN { if dg(sb(i))==1u32 {
                    let mut v:i64=0i64  let mut g5:u32=1u32  while g5==1u32 { if i>=SLEN {g5=0u32} else { if dg(sb(i))==1u32 { v=(v*10i64)+((sb(i)-48u32) as i64)  i=i+1u64 } else {g5=0u32} } }
                    cadd(no as u32, nl as u32, v)
                } }
            }
            let mut g6:u32=1u32  while g6==1u32 { if i>=SLEN {g6=0u32} else { if sb(i)==10u32 {g6=0u32} else {i=i+1u64} } }
            done=1u32
        } }
        if done==0u32 { if c==39u32 {   /* 'x' char literal -> a NUM token with the ASCII value (incl \n \t \0 \r \\ \') */
            let mut v:i64=0i64  let mut j:u64=i+1u64
            if sb(j)==92u32 { let e:u32=sb(j+1u64)
                if e==110u32 {v=10i64} else { if e==116u32 {v=9i64} else { if e==48u32 {v=0i64} else { if e==114u32 {v=13i64} else { v=e as i64 } } } }
                j=j+2u64
            } else { v=sb(j) as i64  j=j+1u64 }
            if sb(j)==39u32 { j=j+1u64 }
            pt(2u32,v,0u32,0u32)  i=j  done=1u32
        } }
        if done==0u32 { if c==34u32 {   /* "..." string literal -> a STRING token (kind 4) over the raw span between quotes */
            let o:u64=i+1u64  let mut j:u64=o  let mut g:u32=1u32
            while g==1u32 { if j>=SLEN {g=0u32} else { let cc:u32=sb(j)  if cc==34u32 {g=0u32} else { if cc==92u32 {j=j+2u64} else {j=j+1u64} } } }
            pt(4u32, 0i64, o as u32, (j-o) as u32)  i=j+1u64  done=1u32
        } }
        if done==0u32 { if c==47u32 { if c2==47u32 { i=i+2u64  let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if sb(i)==10u32 {g=0u32} else {i=i+1u64} } }  done=1u32 }
                                      else { if c2==42u32 { i=i+2u64  let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if sb(i)==42u32 { if sb(i+1u64)==47u32 {i=i+2u64 g=0u32} else {i=i+1u64} } else {i=i+1u64} } }  done=1u32 } } } }
        if done==0u32 { if ids(c)==1u32 { let o:u64=i  let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g=0u32} } }  pt(1u32,0i64,o as u32,(i-o) as u32)  done=1u32 } }
        if done==0u32 { if dg(c)==1u32 {
            let mut v:i64=0i64  let mut ishex:u32=0u32
            if c==48u32 { let cn:u32=sb(i+1u64)  if cn==120u32 {ishex=1u32}  if cn==88u32 {ishex=1u32} }   /* 0x / 0X */
            if ishex==1u32 { i=i+2u64  let mut gh:u32=1u32  while gh==1u32 { if i>=SLEN {gh=0u32} else { let hc:u32=sb(i)  if hx(hc)==1u32 { v=(v*16i64)+hv(hc)  i=i+1u64 } else {gh=0u32} } } }
            else { let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if dg(sb(i))==1u32 { v=(v*10i64)+((sb(i)-48u32) as i64)  i=i+1u64 } else {g=0u32} } } }
            let mut g2:u32=1u32  while g2==1u32 { if i>=SLEN {g2=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g2=0u32} } }   /* skip u/l/U/L suffix */
            pt(2u32,v,0u32,0u32)  done=1u32
        } }
        if done==0u32 {
            let mut adv : u32 = 0u32
            if c==61u32 { if c2==61u32 { pt(3u32,Q_EQ,0u32,0u32) adv=2u32 } else { pt(3u32,Q_ASN,0u32,0u32) adv=1u32 } }
            if c==33u32 { if c2==61u32 { pt(3u32,Q_NE,0u32,0u32) adv=2u32 } else { adv=1u32 } }
            if c==60u32 { if c2==61u32 { pt(3u32,Q_LE,0u32,0u32) adv=2u32 } else { if c2==60u32 { pt(3u32,Q_SHL,0u32,0u32) adv=2u32 } else { pt(3u32,Q_LT,0u32,0u32) adv=1u32 } } }
            if c==62u32 { if c2==61u32 { pt(3u32,Q_GE,0u32,0u32) adv=2u32 } else { if c2==62u32 { pt(3u32,Q_SHR,0u32,0u32) adv=2u32 } else { pt(3u32,Q_GT,0u32,0u32) adv=1u32 } } }
            if c==38u32 { pt(3u32,Q_AND,0u32,0u32) adv=1u32 }
            if c==124u32 { pt(3u32,Q_OR,0u32,0u32) adv=1u32 }
            if c==40u32 { pt(3u32,Q_LP,0u32,0u32) adv=1u32 }
            if c==41u32 { pt(3u32,Q_RP,0u32,0u32) adv=1u32 }
            if c==123u32 { pt(3u32,Q_LB,0u32,0u32) adv=1u32 }
            if c==125u32 { pt(3u32,Q_RB,0u32,0u32) adv=1u32 }
            if c==91u32 { pt(3u32,Q_LBR,0u32,0u32) adv=1u32 }
            if c==93u32 { pt(3u32,Q_RBR,0u32,0u32) adv=1u32 }
            if c==46u32 { pt(3u32,Q_DOT,0u32,0u32) adv=1u32 }
            if c==59u32 { pt(3u32,Q_SEMI,0u32,0u32) adv=1u32 }
            if c==44u32 { pt(3u32,Q_COM,0u32,0u32) adv=1u32 }
            if c==43u32 { if c2==43u32 { pt(3u32,Q_INC,0u32,0u32) adv=2u32 } else { pt(3u32,Q_ADD,0u32,0u32) adv=1u32 } }   /* ++ or + */
            if c==45u32 { if c2==62u32 { pt(3u32,Q_ARROW,0u32,0u32) adv=2u32 } else { if c2==45u32 { pt(3u32,Q_DEC,0u32,0u32) adv=2u32 } else { pt(3u32,Q_SUB,0u32,0u32) adv=1u32 } } }   /* -> or -- or - */
            if c==42u32 { pt(3u32,Q_MUL,0u32,0u32) adv=1u32 }
            if c==47u32 { pt(3u32,Q_DIV,0u32,0u32) adv=1u32 }
            if c==37u32 { pt(3u32,Q_MOD,0u32,0u32) adv=1u32 }
            if c==94u32 { pt(3u32,Q_XOR,0u32,0u32) adv=1u32 }
            if c==126u32 { pt(3u32,Q_NOT,0u32,0u32) adv=1u32 }   /* ~ (bitwise NOT) */
            if c==63u32 { pt(3u32,Q_QUEST,0u32,0u32) adv=1u32 }   /* ? (ternary) */
            if c==58u32 { pt(3u32,Q_COLON,0u32,0u32) adv=1u32 }   /* : (ternary) */
            if adv==0u32 { adv=1u32 }
            i = i + (adv as u64)
        }
    }
    pt(0u32,0i64,0u32,0u32)
}

fn neq(o1: u32, l1: u32, o2: u32, l2: u32) -> u32 { if l1!=l2 {return 0u32}  let mut j:u32=0u32  while j<l1 { if sb((o1+j) as u64)!=sb((o2+j) as u64) {return 0u32}  j=j+1u32 }  return 1u32 }
fn kw(t: u32, s: u64, n: u32) -> u32 { if TK[t as u64]!=1u32 {return 0u32}  if TL[t as u64]!=n {return 0u32}  let mut j:u32=0u32  while j<n { let p:*u8=(s+(j as u64)) as *u8  if sb((TO[t as u64]+j) as u64)!=(p[0u64] as u32) {return 0u32}  j=j+1u32 }  return 1u32 }
/* a C scalar base-type keyword (all map to i64 in SVIR): int/char/void + the <stdint.h> fixed-width typedefs. */
fn dtype(t: u32) -> u32 {
    if kw(t,"int" as u64,3u32)==1u32 {return 1u32}  if kw(t,"char" as u64,4u32)==1u32 {return 1u32}  if kw(t,"void" as u64,4u32)==1u32 {return 1u32}
    if kw(t,"uint32_t" as u64,8u32)==1u32 {return 1u32}  if kw(t,"uint64_t" as u64,8u32)==1u32 {return 1u32}  if kw(t,"uint16_t" as u64,8u32)==1u32 {return 1u32}  if kw(t,"uint8_t" as u64,7u32)==1u32 {return 1u32}
    if kw(t,"int32_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int64_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int16_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int8_t" as u64,6u32)==1u32 {return 1u32}
    if kw(t,"size_t" as u64,6u32)==1u32 {return 1u32}  if kw(t,"ssize_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"bool" as u64,4u32)==1u32 {return 1u32}  if kw(t,"uintptr_t" as u64,9u32)==1u32 {return 1u32}  if kw(t,"intptr_t" as u64,8u32)==1u32 {return 1u32}
    return 0u32
}
/* a C type qualifier / storage class (no-op for ccsv's i64-everything model). */
fn isqual(t: u32) -> u32 {
    if kw(t,"static" as u64,6u32)==1u32 {return 1u32}  if kw(t,"const" as u64,5u32)==1u32 {return 1u32}  if kw(t,"unsigned" as u64,8u32)==1u32 {return 1u32}  if kw(t,"signed" as u64,6u32)==1u32 {return 1u32}
    if kw(t,"long" as u64,4u32)==1u32 {return 1u32}  if kw(t,"short" as u64,5u32)==1u32 {return 1u32}  if kw(t,"volatile" as u64,8u32)==1u32 {return 1u32}  if kw(t,"register" as u64,8u32)==1u32 {return 1u32}  if kw(t,"inline" as u64,6u32)==1u32 {return 1u32}
    return 0u32
}
fn skipquals() { let mut g:u32=1u32  while g==1u32 { if isqual(C)==1u32 { C=C+1u32 } else {g=0u32} } }
fn cp(p: i64) -> u32 { if TK[C as u64]==3u32 { if TV[C as u64]==p {return 1u32} }  return 0u32 }
fn eat(p: i64) -> u32 { if cp(p)==1u32 { C=C+1u32  return 1u32 }  return 0u32 }
fn ispat(t: u32, p: i64) -> u32 { if TK[t as u64]==3u32 { if TV[t as u64]==p {return 1u32} }  return 0u32 }

var FNO : [u32; 256]  var FNL : [u32; 256]  var FNP : [u32; 256]  var FNT : [u32; 256]  var FRM : [i64; 256]  var FN : u32 = 0u32  var CUR_RMASK : i64 = 0i64  var ENDED_RET : u32 = 0u32   /* FRM=per-fn return width-mask ; ENDED_RET=last stmt was a return */
fn fidx(t: u32) -> i32 { let mut k:u32=0u32  while k<FN { if neq(FNO[k as u64],FNL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return k as i32}  k=k+1u32 }  return 0i32-1i32 }
var LO : [u32; 256]  var LL : [u32; 256]  var LN : u32 = 0u32  var LCH : [u32; 256]  var LPT : [i32; 256]  var LW : [i64; 256]   /* LCH=char* ; LPT=struct-ptr type ; LW=width AND-mask (0=full i64) */
fn lidx(t: u32) -> i32 { let mut k:u32=0u32  while k<LN { if neq(LO[k as u64],LL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return k as i32}  k=k+1u32 }  return 0i32-1i32 }
/* the width AND-mask for a fixed-width C type token (uintN_t/intN_t -> 2^N-1 ; else 0 = full i64). */
fn type_mask(t:u32) -> i64 {
    if kw(t,"uint32_t" as u64,8u32)==1u32 {return 4294967295i64}  if kw(t,"int32_t" as u64,7u32)==1u32 {return 4294967295i64}
    if kw(t,"uint16_t" as u64,8u32)==1u32 {return 65535i64}  if kw(t,"int16_t" as u64,7u32)==1u32 {return 65535i64}
    if kw(t,"uint8_t" as u64,7u32)==1u32 {return 255i64}  if kw(t,"int8_t" as u64,6u32)==1u32 {return 255i64}
    return 0i64
}
fn emit_lset(slot:u32) { let m:i64=LW[slot as u64]  if m!=0i64 { econst(m)  eb(0x25u32) }  eu8(0x11u32, slot) }   /* [AND width-mask] ; LOCAL_SET (32-bit wraparound) */
fn lpt(t: u32) -> i32 { let li:i32=lidx(t)  if li<0i32 {return 0i32-1i32}  return LPT[li as u64] }
fn ladd(t: u32) -> u32 { let ex:i32=lidx(t)  if ex>=0i32 { return ex as u32 }  let s:u32=LN  if LN<256u32 { LO[LN as u64]=TO[t as u64]  LL[LN as u64]=TL[t as u64]  LN=LN+1u32 }  return s }   /* re-declared name (no block scope) reuses its slot -- fixes multiple `for(int t..)` aliasing */
/* global C arrays: `int NAME[NUM];` -> a cumulative base offset in SVIR linear memory (NAME[i] -> LOAD8/STORE8). */
var AO : [u32; 64]  var AL : [u32; 64]  var AB : [u64; 64]  var AW : [i64; 64]  var AESZ : [i64; 64]  var ALEN : [u64; 64]  var AN : u32 = 0u32  var MTOP : u64 = 0u64   /* AW=elem width-mask ; AESZ=elem byte size (char/uint8_t=1, else 8) ; ALEN=element count (for sizeof) */
fn abase(t: u32) -> i64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AB[k as u64] as i64}  k=k+1u32 }  return 0i64-1i64 }
fn awmask(t: u32) -> i64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AW[k as u64]}  k=k+1u32 }  return 0i64 }
fn aesize(t: u32) -> i64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AESZ[k as u64]}  k=k+1u32 }  return 8i64 }
fn aesz_of(ty: u32) -> i64 { if kw(ty,"char" as u64,4u32)==1u32 {return 1i64}  if kw(ty,"uint8_t" as u64,7u32)==1u32 {return 1i64}  if kw(ty,"int8_t" as u64,6u32)==1u32 {return 1i64}  return 8i64 }   /* element byte size from the declared type */
fn byc(ty: u32) -> u32 { if aesz_of(ty)==1i64 {return 1u32}  return 0u32 }   /* is a byte type (char/uint8_t/int8_t)? -> byte pointer (stride-1 LOAD8/STORE8) */
/* struct types: NAME + a flattened field list (field name -> byte offset).  Struct vars reuse AO/AL/AB (base in
 * mem) + AVT (struct type index of that entry, -1 for plain arrays). */
var STNO:[u32;32]  var STNL:[u32;32]  var STFB:[u32;32]  var STNF:[u32;32]  var STSZ:[u64;32]  var STN:u32=0u32
var SFO:[u32;256]  var SFL:[u32;256]  var SFOFF:[u64;256]  var SFEL:[i64;256]  var SFN:u32=0u32  var AVT:[i32;64]   /* SFEL = field element byte size (array-field indexing) */
/* named integer constants: enum members + object-like #define <number>.  Resolved in eprim -> econst. */
var CNO:[u32;1024]  var CNL:[u32;1024]  var CNV:[i64;1024]  var CN:u32=0u32
fn cadd(o:u32, l:u32, v:i64) { if CN<1024u32 { CNO[CN as u64]=o  CNL[CN as u64]=l  CNV[CN as u64]=v  CN=CN+1u32 } }
fn cidx(t:u32)->i32 { let mut k:u32=0u32  while k<CN { if neq(CNO[k as u64],CNL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return k as i32}  k=k+1u32 }  return 0i32-1i32 }
fn stidx(t:u32)->i32 { let mut k:u32=0u32  while k<STN { if neq(STNO[k as u64],STNL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return k as i32}  k=k+1u32 }  return 0i32-1i32 }
fn avtype(t:u32)->i32 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AVT[k as u64]}  k=k+1u32 }  return 0i32-1i32 }
fn fieldoff(sti:i32, ft:u32)->i64 { if sti<0i32 {return 0i64-1i64}  let b:u32=STFB[sti as u64]  let n:u32=STNF[sti as u64]  let mut k:u32=0u32  while k<n { let fi:u32=b+k  if neq(SFO[fi as u64],SFL[fi as u64],TO[ft as u64],TL[ft as u64])==1u32 {return SFOFF[fi as u64] as i64}  k=k+1u32 }  return 0i64-1i64 }
fn fieldelem(sti:i32, ft:u32)->i64 { if sti<0i32 {return 8i64}  let b:u32=STFB[sti as u64]  let n:u32=STNF[sti as u64]  let mut k:u32=0u32  while k<n { let fi:u32=b+k  if neq(SFO[fi as u64],SFL[fi as u64],TO[ft as u64],TL[ft as u64])==1u32 {return SFEL[fi as u64]}  k=k+1u32 }  return 8i64 }   /* element size of a (possibly array) field */
/* string literals: a BYTE-PACKED region at the START of svir_mem (real C layout), emitted as a SVIR DATA SECTION
 * (initialised linear memory -- no main-entry STORE init).  char *s = "..."; s[i] -> LOAD8 at s+i (stride 1, via
 * the char* flag LCH).  Each STRING token's TV becomes its byte address; arrays/structs follow (prescan_arr MTOP=DLEN). */
var SDAT:[u8;65536]  var DLEN:u64=0u64  var DEND:u64=0u64   /* SDAT = the SVIR data section: byte-packed strings [0..DLEN] + array initializers; DEND = total initialised extent */
fn sbyte(v:u32) { if DLEN<65535u64 { SDAT[DLEN]=(v & 0xFFu32) as u8  DLEN=DLEN+1u64 } }
fn data_put64(off:u64, v:i64) { let mut b:u64=0u64  while b<8u64 { if (off+b)<65536u64 { let p:*u8=((&SDAT as u64)+off+b) as *u8  p[0u64]=(((v as u64) >> (8u64*b)) & 0xFFu64) as u8 }  b=b+1u64 } }   /* 8-byte LE store into the data section */
fn data_put8(off:u64, v:i64) { if off<65536u64 { let p:*u8=((&SDAT as u64)+off) as *u8  p[0u64]=((v as u64) & 0xFFu64) as u8 } }   /* 1-byte store (byte-array initializer) */
fn prescan_str() {
    DLEN=0u64  let mut t:u32=0u32
    while t<NT {
        if TK[t as u64]==4u32 {
            TV[t as u64]=DLEN as i64                          /* address = byte offset in the packed region */
            let o:u32=TO[t as u64]  let l:u32=TL[t as u64]  let mut k:u32=0u32
            while k<l {
                let cc:u32=sb((o+k) as u64)
                if cc==92u32 { let e:u32=sb((o+k+1u32) as u64)   /* escape \n \t \0 \r (\\ \" -> literal) */
                    if e==110u32 {sbyte(10u32)} else { if e==116u32 {sbyte(9u32)} else { if e==48u32 {sbyte(0u32)} else { if e==114u32 {sbyte(13u32)} else {sbyte(e)} } } }
                    k=k+2u32
                } else { sbyte(cc)  k=k+1u32 }
            }
            sbyte(0u32)                                      /* NUL terminator */
        }
        t=t+1u32
    }
}

var BD : [u8; 16384]  var BL : u64 = 0u64
fn eb(b: u32) { if BL<16384u64 { BD[BL]=(b & 0xFFu32) as u8  BL=BL+1u64 } }
fn econst(v: i64) { eb(0x01u32)  let mut k:u32=0u32  while k<8u32 { eb(((v as u64) >> (8u64*(k as u64))) as u32)  k=k+1u32 } }
fn eu8(o: u32, a: u32) { eb(o)  eb(a) }
var MO : [u8; 32768]  var ML : u64 = 0u64
fn mb(b: u32) { if ML<32768u64 { MO[ML]=(b & 0xFFu32) as u8  ML=ML+1u64 } }

fn prec(p: i64) -> u32 {
    if p==Q_MUL {return 9u32} if p==Q_DIV {return 9u32} if p==Q_MOD {return 9u32}
    if p==Q_ADD {return 8u32} if p==Q_SUB {return 8u32}  if p==Q_SHL {return 7u32} if p==Q_SHR {return 7u32}
    if p==Q_LT {return 6u32} if p==Q_GT {return 6u32} if p==Q_LE {return 6u32} if p==Q_GE {return 6u32}
    if p==Q_EQ {return 5u32} if p==Q_NE {return 5u32}  if p==Q_AND {return 4u32} if p==Q_XOR {return 3u32} if p==Q_OR {return 2u32}
    return 0u32
}
fn opc(p: i64) -> u32 {
    if p==Q_MUL {return 0x22u32} if p==Q_DIV {return 0x23u32} if p==Q_MOD {return 0x24u32}
    if p==Q_ADD {return 0x20u32} if p==Q_SUB {return 0x21u32}  if p==Q_SHL {return 0x28u32} if p==Q_SHR {return 0x29u32}
    if p==Q_LT {return 0x32u32} if p==Q_GT {return 0x35u32} if p==Q_LE {return 0x34u32} if p==Q_GE {return 0x33u32}
    if p==Q_EQ {return 0x30u32} if p==Q_NE {return 0x31u32}  if p==Q_AND {return 0x25u32} if p==Q_XOR {return 0x27u32} if p==Q_OR {return 0x26u32}
    return 0u32
}

fn alen(t: u32) -> u64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return ALEN[k as u64]}  k=k+1u32 }  return 0u64 }
/* sizeof( type | TypedefName | struct/union X [*] | array | array[i] | struct-var | scalar ).  CCSV-consistent
 * sizes (int/uint32_t=8, char/uint8_t=1, ptr=8, struct=STSZ, array=count*elem) -- see GAP-MAP §4 re: vs C. */
fn esizeof() {
    let mut hasp:u32=0u32  if cp(Q_LP)==1u32 { C=C+1u32  hasp=1u32 }
    let mut sz:i64=8i64
    if dtype(C)==1u32 { if byc(C)==1u32 {sz=1i64} else {sz=8i64}  C=C+1u32  let mut g:u32=1u32  while g==1u32 { if cp(Q_MUL)==1u32 {sz=8i64  C=C+1u32} else {g=0u32} } }
    else { if kw(C,"struct" as u64,6u32)==1u32 { C=C+1u32  let si:i32=stidx(C)  if si>=0i32 {sz=STSZ[si as u64] as i64}  C=C+1u32  let mut g2:u32=1u32  while g2==1u32 { if cp(Q_MUL)==1u32 {sz=8i64  C=C+1u32} else {g2=0u32} } }
           else { if kw(C,"union" as u64,5u32)==1u32 { C=C+1u32  let si:i32=stidx(C)  if si>=0i32 {sz=STSZ[si as u64] as i64}  C=C+1u32  let mut g3:u32=1u32  while g3==1u32 { if cp(Q_MUL)==1u32 {sz=8i64  C=C+1u32} else {g3=0u32} } }
                  else { if TK[C as u64]==1u32 {
                      let ti:i32=stidx(C)
                      if ti>=0i32 { sz=STSZ[ti as u64] as i64  C=C+1u32  let mut g4:u32=1u32  while g4==1u32 { if cp(Q_MUL)==1u32 {sz=8i64  C=C+1u32} else {g4=0u32} } }
                      else { let vt:i32=avtype(C)  let ab:i64=abase(C)
                          if vt>=0i32 { sz=STSZ[vt as u64] as i64  C=C+1u32 }
                          else { if ab>=0i64 {
                              if ispat(C+1u32,Q_LBR)==1u32 { sz=aesize(C)  C=C+2u32  let mut g5:u32=1u32  while g5==1u32 { if cp(Q_RBR)==1u32 {g5=0u32} else { if TK[C as u64]==0u32 {g5=0u32} else {C=C+1u32} } }  eat(Q_RBR) }
                              else { sz=(alen(C) as i64)*aesize(C)  C=C+1u32 } }
                          else { sz=8i64  C=C+1u32 } } }
                  } else { C=C+1u32 } } } }
    if hasp==1u32 { eat(Q_RP) }
    econst(sz)
}
fn is_type_start(t:u32) -> u32 {   /* does token t begin a type (for cast / decl disambiguation)? */
    if dtype(t)==1u32 {return 1u32}  if isqual(t)==1u32 {return 1u32}
    if kw(t,"struct" as u64,6u32)==1u32 {return 1u32}  if kw(t,"union" as u64,5u32)==1u32 {return 1u32}
    if TK[t as u64]==1u32 { if stidx(t)>=0i32 {return 1u32} }   /* typedef name */
    return 0u32
}
/* parse a cast type `[quals] base [*]...` at C, return its narrowing AND-mask (0 = none / pointer / int). */
fn cast_mask() -> i64 {
    skipquals()  let mut m:i64=0i64
    if kw(C,"struct" as u64,6u32)==1u32 { C=C+2u32 } else { if kw(C,"union" as u64,5u32)==1u32 { C=C+2u32 } else { if dtype(C)==1u32 { m=type_mask(C)  C=C+1u32 } else { if TK[C as u64]==1u32 { C=C+1u32 } } } }
    let mut g:u32=1u32  while g==1u32 { if cp(Q_MUL)==1u32 { m=0i64  C=C+1u32 } else {g=0u32} }   /* pointer cast -> no narrowing */
    return m
}
fn eprim() {
    if cp(Q_MUL)==1u32 { C=C+1u32                                  /* *p : pointer deref */
        if TK[C as u64]==1u32 { let dli:i32=lidx(C)  if dli>=0i32 { if LCH[dli as u64]==1u32 { eu8(0x10u32,dli as u32)  C=C+1u32  eb(0x80u32)  return } } }   /* char* -> LOAD8 */
        eprim()  eb(0x82u32)  return                              /* int* -> LOAD64 */
    }
    if cp(Q_AND)==1u32 {                                            /* &arr[i] / &arr : address-of (no load) */
        C=C+1u32
        if TK[C as u64]==1u32 { let at:u32=C  let ab:i64=abase(at)
            if ab>=0i64 {
                if ispat(C+1u32,Q_LBR)==1u32 { C=C+2u32  ebin(0u32)  eat(Q_RBR)  let sz:i64=aesize(at)  if sz==1i64 { if ab>0i64 { econst(ab)  eb(0x20u32) } } else { econst(8i64)  eb(0x22u32)  if ab>0i64 { econst(ab)  eb(0x20u32) } }  return }   /* &arr[i] : i*esz (+base) */
                C=C+1u32  econst(ab)  return
            }
        }
        return
    }
    if cp(Q_NOT)==1u32 { C=C+1u32  eprim()  econst(0i64-1i64)  eb(0x27u32)  return }   /* ~x = x XOR -1 (correct for any width; svir_wasm c_leb_s64 now encodes negatives) */
    if cp(Q_LP)==1u32 {
        if is_type_start(C+1u32)==1u32 { C=C+1u32  let cm:i64=cast_mask()  eat(Q_RP)  eprim()  if cm!=0i64 { econst(cm)  eb(0x25u32) }  return }   /* (TYPE)expr cast: i64-noop except narrowing -> AND-mask */
        C=C+1u32  ebin(0u32)  eat(Q_RP)  return
    }
    if TK[C as u64]==2u32 { econst(TV[C as u64])  C=C+1u32  return }
    if TK[C as u64]==4u32 { econst(TV[C as u64])  C=C+1u32  return }   /* "str" -> its address in the string region */
    if TK[C as u64]==1u32 {
        let t : u32 = C  C=C+1u32
        if kw(t,"sizeof" as u64,6u32)==1u32 { esizeof()  return }    /* sizeof(...) */
        if cp(Q_LP)==1u32 {                                          /* call (or the putchar builtin) */
            C=C+1u32  let mut ac:u32=0u32  if cp(Q_RP)==0u32 { ebin(0u32)  ac=1u32  while cp(Q_COM)==1u32 { C=C+1u32  ebin(0u32)  ac=ac+1u32 } }  eat(Q_RP)
            if kw(t,"putchar" as u64,7u32)==1u32 { eb(0x71u32)  econst(0i64) }    /* putchar(c) -> PRINT_CHAR ; push 0 as the (C) return */
            else { let fi:i32=fidx(t)  if fi>=0i32 { eb(0x70u32)  eb(fi as u32)  eb(ac) } }
            return
        }
        if cp(Q_LBR)==1u32 {                                         /* NAME[i] : array load (8-byte C int cell) */
            let ab:i64=abase(t)
            if ab>=0i64 { C=C+1u32  ebin(0u32)  eat(Q_RBR)  let sz:i64=aesize(t)
                if sz==1i64 { if ab>0i64 { econst(ab)  eb(0x20u32) }  eb(0x80u32) }                          /* byte array: i (+base) ; LOAD8 */
                else { econst(8i64)  eb(0x22u32)  if ab>0i64 { econst(ab)  eb(0x20u32) }  eb(0x82u32) }      /* cell array: i*8 (+base) ; LOAD64 */
                return }
            let pli:i32=lidx(t)  if pli>=0i32 { eu8(0x10u32,pli as u32)  C=C+1u32  ebin(0u32)  eat(Q_RBR)
                if LCH[pli as u64]==1u32 { eb(0x20u32)  eb(0x80u32) }                       /* char* p[i]=*(p+i), LOAD8 */
                else { econst(8i64)  eb(0x22u32)  eb(0x20u32)  eb(0x82u32) }                 /* int* p[i]=*(p+i*8), LOAD64 */
                return }
        }
        if cp(Q_DOT)==1u32 {                                         /* v.field [/ v.field[i]] : struct field load */
            let vt:i32=avtype(t)  if vt>=0i32 { C=C+1u32  let ft:u32=C  C=C+1u32  let foff:i64=fieldoff(vt,ft)  let vb:i64=abase(t)
                if cp(Q_LBR)==1u32 { C=C+1u32  ebin(0u32)  eat(Q_RBR)  let fe:i64=fieldelem(vt,ft)  econst(fe)  eb(0x22u32)  econst(vb+foff)  eb(0x20u32)  if fe==1i64 {eb(0x80u32)} else {eb(0x82u32)}  return }
                econst(vb + foff)  eb(0x82u32)  return }
        }
        if cp(Q_ARROW)==1u32 {                                       /* p->field [/ p->field[i]] : struct-pointer field load */
            let ptt:i32=lpt(t)  if ptt>=0i32 { C=C+1u32  let ft:u32=C  C=C+1u32  let foff:i64=fieldoff(ptt,ft)
                if cp(Q_LBR)==1u32 { C=C+1u32  ebin(0u32)  eat(Q_RBR)  let fe:i64=fieldelem(ptt,ft)  econst(fe)  eb(0x22u32)  eu8(0x10u32,lidx(t) as u32)  eb(0x20u32)  if foff>0i64 {econst(foff) eb(0x20u32)}  if fe==1i64 {eb(0x80u32)} else {eb(0x82u32)}  return }
                eu8(0x10u32, lidx(t) as u32)  if foff>0i64 { econst(foff)  eb(0x20u32) }  eb(0x82u32)  return }
        }
        let ad:i64=abase(t)  if ad>=0i64 { econst(ad)  return }               /* bare array name -> &arr[0] (array->pointer decay) */
        let ci:i32=cidx(t)  if ci>=0i32 { econst(CNV[ci as u64])  return }   /* enum member / #define constant */
        let li:i32=lidx(t)  if li>=0i32 { eu8(0x10u32, li as u32) }  return
    }
    C=C+1u32
}
fn ebin(minp: u32) {
    eprim()  let mut go:u32=1u32
    while go==1u32 {
        if TK[C as u64]!=3u32 { go=0u32 }
        else { let p:i64=TV[C as u64]  let pr:u32=prec(p)
            if pr==0u32 { go=0u32 } else { if pr<minp { go=0u32 } else { C=C+1u32  ebin(pr+1u32)  eb(opc(p)) } } }
    }
    if minp==0u32 { if cp(Q_QUEST)==1u32 {            /* cond ? a : b (lowest prec, right-assoc) */
        let tmp:u32=LN  if LN<255u32 { LN=LN+1u32 }   /* fresh temp local carries the value across the join */
        C=C+1u32  eb(0x42u32)                         /* cond ; IF (void block) */
        ebin(0u32)  eu8(0x11u32,tmp)                  /* then: a ; LOCAL_SET tmp */
        eb(0x43u32)  eat(Q_COLON)                     /* ELSE */
        ebin(0u32)  eu8(0x11u32,tmp)                  /* else: b ; LOCAL_SET tmp */
        eb(0x44u32)  eu8(0x10u32,tmp)                 /* END ; LOCAL_GET tmp -> result */
    } }
}

fn for_init() {   /* the for-loop's init clause (no trailing ;): `int i = 0` or `i = 0` or an expression */
    skipquals()
    if dtype(C)==1u32 { let tym:i64=type_mask(C)  C=C+1u32  let nt:u32=C  C=C+1u32  eat(Q_ASN)  ebin(0u32)  let s:u32=ladd(nt)  LW[s as u64]=tym  emit_lset(s)  return }
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_ASN)==1u32 { let nt:u32=C  C=C+2u32  ebin(0u32)  let li:i32=lidx(nt)  if li>=0i32 { emit_lset(li as u32) }  return } }
    ebin(0u32)  eb(0x72u32)
}
fn emit_for_incr() {   /* the for-loop's incr clause (no trailing ;): i++ / i-- / i = e / expr */
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_INC)==1u32 { let nt:u32=C  let li:i32=lidx(nt)  if li>=0i32 { eu8(0x10u32,li as u32)  econst(1i64)  eb(0x20u32)  emit_lset(li as u32) }  C=C+2u32  return } }
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_DEC)==1u32 { let nt:u32=C  let li:i32=lidx(nt)  if li>=0i32 { eu8(0x10u32,li as u32)  econst(1i64)  eb(0x21u32)  emit_lset(li as u32) }  C=C+2u32  return } }
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_ASN)==1u32 { let nt:u32=C  C=C+2u32  ebin(0u32)  let li:i32=lidx(nt)  if li>=0i32 { emit_lset(li as u32) }  return } }
    ebin(0u32)  eb(0x72u32)
}
/* the lvalue ADDRESS is already on the stack; consume `= rhs` or `op= rhs` and emit the store (esz=elem byte size,
 * mask=width mask or 0).  Compound uses a fresh temp so the address is computed once: SET tmp; GET(store-addr);
 * GET;LOAD(cur val); rhs; OP; [mask]; STORE. */
fn emit_av(esz:i64, mask:i64) {
    let op:i64=TV[C as u64]
    if op==Q_ASN { C=C+1u32  ebin(0u32)  if mask!=0i64 {econst(mask)  eb(0x25u32)}  if esz==1i64 {eb(0x81u32)} else {eb(0x83u32)} }
    else {
        C=C+2u32  let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}
        eu8(0x11u32,tmp)  eu8(0x10u32,tmp)  eu8(0x10u32,tmp)
        if esz==1i64 {eb(0x80u32)} else {eb(0x82u32)}
        ebin(0u32)  eb(opc(op))  if mask!=0i64 {econst(mask)  eb(0x25u32)}
        if esz==1i64 {eb(0x81u32)} else {eb(0x83u32)}
    }
}
fn pstmt() {
    ENDED_RET=0u32                                                 /* cleared each statement; the return handler sets it */
    if isqual(C)==1u32 { skipquals() }                             /* leading qualifiers on a local decl -> skip */
    if cp(Q_MUL)==1u32 {                                            /* *p = e ;  (pointer deref store) */
        C=C+1u32  let mut ischp:u32=0u32
        if TK[C as u64]==1u32 { let dli:i32=lidx(C)  if dli>=0i32 { if LCH[dli as u64]==1u32 {ischp=1u32} } }
        eprim()  eat(Q_ASN)  ebin(0u32)  if ischp==1u32 { eb(0x81u32) } else { eb(0x83u32) }  eat(Q_SEMI)  return
    }
    if kw(C,"struct" as u64,6u32)==1u32 {
        let sti:i32=stidx(C+1u32)
        if TK[(C+2u32) as u64]==3u32 { if TV[(C+2u32) as u64]==Q_MUL {   /* struct Name *p [= e] ; -> struct-pointer local */
            C=C+3u32  let nt:u32=C  C=C+1u32  let s:u32=ladd(nt)  if sti>=0i32 { LPT[s as u64]=sti }
            if cp(Q_ASN)==1u32 { C=C+1u32  ebin(0u32)  eu8(0x11u32,s) }
            eat(Q_SEMI)  return
        } }
        let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } }  eat(Q_SEMI)  return   /* struct Name v ; -> value (registered by prescan_struct); skip */
    }
    if kw(C,"union" as u64,5u32)==1u32 {                            /* union Name u ; (local) -> registered by prescan; skip */
        let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } }  eat(Q_SEMI)  return
    }
    if kw(C,"typedef" as u64,7u32)==1u32 {                          /* local typedef def -> registered by prescan; skip */
        let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } }  eat(Q_SEMI)  return
    }
    if kw(C,"enum" as u64,4u32)==1u32 {                             /* local enum def -> registered by prescan_enum; skip */
        let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } }  eat(Q_SEMI)  return
    }
    if TK[C as u64]==1u32 { if TK[(C+1u32) as u64]==3u32 { if TV[(C+1u32) as u64]==Q_MUL { let stc:i32=stidx(C)  if stc>=0i32 {   /* TypedefName *p [= e] ; -> struct-pointer local */
        C=C+2u32  let nt:u32=C  C=C+1u32  let s:u32=ladd(nt)  LPT[s as u64]=stc
        if cp(Q_ASN)==1u32 { C=C+1u32  ebin(0u32)  eu8(0x11u32,s) }
        eat(Q_SEMI)  return
    } } } }
    if TK[C as u64]==1u32 { if TK[(C+1u32) as u64]==1u32 { let stc:i32=stidx(C)  if stc>=0i32 {   /* TypedefName v ; (local) -> registered by prescan; skip */
        let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } }  eat(Q_SEMI)  return
    } } }
    if dtype(C)==1u32 {                                            /* int/char decl (int x ; int *p ; char *s ; int arr[N] ; uint32_t u ;) */
        let isc:u32=byc(C)  let tym:i64=type_mask(C)
        C=C+1u32  let mut isp:u32=0u32  if cp(Q_MUL)==1u32 { C=C+1u32  isp=1u32 }    /* `int/char *p` -> pointer local (an i64 address) */
        let nt:u32=C
        if ispat(C+1u32, Q_LBR)==1u32 {                             /* int NAME[NUM]; local array -> registered by prescan_arr; skip the decl */
            C=C+1u32  let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } }  eat(Q_SEMI)  return
        }
        C=C+1u32
        if cp(Q_ASN)==1u32 { C=C+1u32  ebin(0u32)  let s:u32=ladd(nt)  if isc==1u32 { if isp==1u32 { LCH[s as u64]=1u32 } }  if isp==0u32 { LW[s as u64]=tym }  emit_lset(s)  eat(Q_SEMI)  return }   /* int x = e ; (mask if a fixed-width type) */
        let s2:u32=ladd(nt)  if isc==1u32 { if isp==1u32 { LCH[s2 as u64]=1u32 } }  if isp==0u32 { LW[s2 as u64]=tym }  eat(Q_SEMI)  return    /* int x ; (uninit, mask recorded for later assigns) */
    }
    if kw(C,"return" as u64,6u32)==1u32 { C=C+1u32  ebin(0u32)  if CUR_RMASK!=0i64 { econst(CUR_RMASK)  eb(0x25u32) }  eb(0x60u32)  ENDED_RET=1u32  eat(Q_SEMI)  return }   /* mask return to the declared width */
    if kw(C,"if" as u64,2u32)==1u32 {
        C=C+1u32  eat(Q_LP)  ebin(0u32)  eat(Q_RP)  eb(0x42u32)  pblock()
        if kw(C,"else" as u64,4u32)==1u32 { C=C+1u32  eb(0x43u32)  pblock() }
        eb(0x44u32)  return
    }
    if kw(C,"while" as u64,5u32)==1u32 {
        C=C+1u32  eat(Q_LP)  eb(0x40u32)  eb(0x41u32)  ebin(0u32)  econst(0i64)  eb(0x30u32)  eu8(0x51u32,1u32)  eat(Q_RP)
        pblock()  eu8(0x50u32,0u32)  eb(0x44u32)  eb(0x44u32)  return
    }
    if kw(C,"for" as u64,3u32)==1u32 {                              /* for (init; cond; incr) body */
        C=C+1u32  eat(Q_LP)
        if cp(Q_SEMI)==0u32 { for_init() }  eat(Q_SEMI)
        eb(0x40u32)  eb(0x41u32)                                    /* BLOCK LOOP */
        if cp(Q_SEMI)==0u32 { ebin(0u32) } else { econst(1i64) }    /* cond (empty = true) */
        econst(0i64)  eb(0x30u32)  eu8(0x51u32,1u32)  eat(Q_SEMI)   /* cond==0 -> BR_IF 1 (break) */
        let incrC:u32=C                                            /* incr is emitted AFTER the body */
        let mut gI:u32=1u32  while gI==1u32 { if cp(Q_RP)==1u32 {gI=0u32} else { if TK[C as u64]==0u32 {gI=0u32} else {C=C+1u32} } }  eat(Q_RP)
        pblock()                                                   /* body */
        let after:u32=C
        C=incrC  emit_for_incr()                                   /* replay the incr */
        eb(0x50u32)  eb(0u32)  eb(0x44u32)  eb(0x44u32)            /* BR 0 ; END END */
        C=after  return
    }
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_INC)==1u32 {          /* i++ ; */
        let nt:u32=C  let li:i32=lidx(nt)  if li>=0i32 { eu8(0x10u32,li as u32)  econst(1i64)  eb(0x20u32)  emit_lset(li as u32) }  C=C+2u32  eat(Q_SEMI)  return
    } }
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_DEC)==1u32 {          /* i-- ; */
        let nt:u32=C  let li:i32=lidx(nt)  if li>=0i32 { eu8(0x10u32,li as u32)  econst(1i64)  eb(0x21u32)  emit_lset(li as u32) }  C=C+2u32  eat(Q_SEMI)  return
    } }
    if TK[C as u64]==1u32 { if TK[(C+1u32) as u64]==3u32 { if TV[(C+1u32) as u64]==Q_DOT {   /* v.field[/[i]] = e ; (struct field store) */
        let nt:u32=C  let vt:i32=avtype(nt)
        if vt>=0i32 { let ft:u32=C+2u32  let foff:i64=fieldoff(vt,ft)  let vb:i64=abase(nt)  let fe:i64=fieldelem(vt,ft)
            if ispat(C+3u32,Q_LBR)==1u32 { C=C+4u32  ebin(0u32)  eat(Q_RBR)  econst(fe)  eb(0x22u32)  econst(vb+foff)  eb(0x20u32)  emit_av(fe, 0i64)  eat(Q_SEMI)  return }
            C=C+3u32  econst(vb+foff)  emit_av(fe, 0i64)  eat(Q_SEMI)  return }
    } } }
    if TK[C as u64]==1u32 { if TK[(C+1u32) as u64]==3u32 { if TV[(C+1u32) as u64]==Q_ARROW {   /* p->field[/[i]] = e ; (struct-ptr field store) */
        let nt:u32=C  let ptt:i32=lpt(nt)
        if ptt>=0i32 { let ft:u32=C+2u32  let foff:i64=fieldoff(ptt,ft)  let pl:i32=lidx(nt)  let fe:i64=fieldelem(ptt,ft)
            if ispat(C+3u32,Q_LBR)==1u32 { C=C+4u32  ebin(0u32)  eat(Q_RBR)  econst(fe)  eb(0x22u32)  eu8(0x10u32,pl as u32)  eb(0x20u32)  if foff>0i64 {econst(foff) eb(0x20u32)}  emit_av(fe, 0i64)  eat(Q_SEMI)  return }
            C=C+3u32  eu8(0x10u32, pl as u32)  if foff>0i64 { econst(foff)  eb(0x20u32) }  emit_av(fe, 0i64)  eat(Q_SEMI)  return }
    } } }
    if TK[C as u64]==1u32 { if TK[(C+1u32) as u64]==3u32 { if TV[(C+1u32) as u64]==Q_LBR {   /* NAME[i] = e ; */
        let nt:u32=C  let ab:i64=abase(nt)
        if ab>=0i64 { C=C+2u32  ebin(0u32)  eat(Q_RBR)  let sz:i64=aesize(nt)  let am:i64=awmask(nt)   /* NAME[i] [op]= e */
            if sz==1i64 { if ab>0i64 { econst(ab)  eb(0x20u32) } }                                       /* byte array: i (+base) */
            else { econst(8i64)  eb(0x22u32)  if ab>0i64 { econst(ab)  eb(0x20u32) } }                   /* cell array: i*8 (+base) */
            emit_av(sz, am)  eat(Q_SEMI)  return }
        let pli:i32=lidx(nt)  if pli>=0i32 { eu8(0x10u32,pli as u32)  C=C+2u32  ebin(0u32)  eat(Q_RBR)   /* pointer p[i] [op]= e */
            if LCH[pli as u64]==1u32 { eb(0x20u32)  emit_av(1i64, 0i64) }                                /* char* p[i]: byte */
            else { econst(8i64)  eb(0x22u32)  eb(0x20u32)  emit_av(8i64, 0i64) }                          /* int* p[i]: cell */
            eat(Q_SEMI)  return }
    } } }
    if TK[C as u64]==1u32 { if TK[(C+1u32) as u64]==3u32 { if prec(TV[(C+1u32) as u64])>0u32 { if TK[(C+2u32) as u64]==3u32 { if TV[(C+2u32) as u64]==Q_ASN {   /* x op= e ; (compound assign, local: += -= *= &= |= ^= >>= <<= ...) */
        let nt:u32=C  let opn:i64=TV[(C+1u32) as u64]  C=C+3u32  let li:i32=lidx(nt)
        if li>=0i32 { eu8(0x10u32,li as u32)  ebin(0u32)  eb(opc(opn))  emit_lset(li as u32) }  eat(Q_SEMI)  return
    } } } } }
    if TK[C as u64]==1u32 { if TK[(C+1u32) as u64]==3u32 { if TV[(C+1u32) as u64]==Q_ASN {   /* x = e ; */
        let nt:u32=C  C=C+2u32  ebin(0u32)  let li:i32=lidx(nt)  if li>=0i32 { emit_lset(li as u32) }  eat(Q_SEMI)  return
    } } }
    ebin(0u32)  eb(0x72u32)  eat(Q_SEMI)
}
fn pblock() {
    eat(Q_LB)  let mut go:u32=1u32
    while go==1u32 { if cp(Q_RB)==1u32 {go=0u32} else { if TK[C as u64]==0u32 {go=0u32} else { pstmt() } } }
    eat(Q_RB)
}

fn cparams(nt: u32) -> u32 {   /* int NAME ( int a, int b ) -> count the comma-separated `int x` params */
    let mut q:u32=nt+2u32
    if ispat(q,Q_RP)==1u32 { return 0u32 }
    let mut np:u32=1u32  let mut go:u32=1u32
    while go==1u32 { if TK[q as u64]==0u32 {go=0u32} else { if ispat(q,Q_RP)==1u32 {go=0u32} else { if ispat(q,Q_COM)==1u32 {np=np+1u32}  q=q+1u32 } } }
    return np
}
/* the function-name token = after [quals] returntype [*] (returntype: struct/union Name = 2 toks, else 1). */
fn fn_nametok(ft: u32) -> u32 {
    let mut q:u32=ft  let mut g:u32=1u32  while g==1u32 { if isqual(q)==1u32 {q=q+1u32} else {g=0u32} }
    if kw(q,"struct" as u64,6u32)==1u32 { q=q+2u32 } else { if kw(q,"union" as u64,5u32)==1u32 { q=q+2u32 } else { q=q+1u32 } }
    if ispat(q,Q_MUL)==1u32 { q=q+1u32 }
    return q
}
fn fn_retmask(ft: u32) -> i64 { let mut q:u32=ft  let mut g:u32=1u32  while g==1u32 { if isqual(q)==1u32 {q=q+1u32} else {g=0u32} }  return type_mask(q) }   /* the return type's width mask */
fn rec_fn(ft: u32) { let nt:u32=fn_nametok(ft)  FNO[FN as u64]=TO[nt as u64]  FNL[FN as u64]=TL[nt as u64]  FNP[FN as u64]=cparams(nt)  FNT[FN as u64]=ft  FRM[FN as u64]=fn_retmask(ft)  FN=FN+1u32 }
fn is_fn(t: u32) -> u32 {
    let mut ok:u32=0u32  if isqual(t)==1u32 {ok=1u32}  if dtype(t)==1u32 {ok=1u32}  if kw(t,"struct" as u64,6u32)==1u32 {ok=1u32}
    if ok==0u32 { return 0u32 }
    let nm:u32=fn_nametok(t)  if TK[nm as u64]==1u32 { if ispat(nm+1u32,Q_LP)==1u32 { return 1u32 } }
    return 0u32
}
fn prescan() {
    FN=0u32  let mut t:u32=0u32
    while t<NT { if is_fn(t)==1u32 { if kw(fn_nametok(t),"main" as u64,4u32)==1u32 { rec_fn(t) } }  t=t+1u32 }
    t=0u32
    while t<NT { if is_fn(t)==1u32 { if kw(fn_nametok(t),"main" as u64,4u32)==0u32 { rec_fn(t) } }  t=t+1u32 }
}
fn prescan_arr() {   /* `[quals] type NAME[NUM] [= { v0, ... }] ;` -> base in SVIR linear memory (after strings) + init data */
    AN=0u32  MTOP=DLEN  DEND=DLEN  let mut t:u32=0u32
    while t<NT {
        let mut isd:u32=0u32  if isqual(t)==1u32 {isd=1u32}  if dtype(t)==1u32 {isd=1u32}
        if isd==1u32 {
            let mut q:u32=t  let mut g0:u32=1u32  while g0==1u32 { if isqual(q)==1u32 {q=q+1u32} else {g0=0u32} }   /* skip quals */
            if dtype(q)==1u32 { let nt:u32=q+1u32
                if TK[nt as u64]==1u32 { if ispat(nt+1u32,Q_LBR)==1u32 { if TK[(nt+2u32) as u64]==2u32 {   /* NAME [ NUM ] */
                    let n:u64=TV[(nt+2u32) as u64] as u64  let base:u64=MTOP  let esz:i64=aesz_of(q)  let eszu:u64=esz as u64
                    AO[AN as u64]=TO[nt as u64]  AL[AN as u64]=TL[nt as u64]  AB[AN as u64]=base  AVT[AN as u64]=0i32-1i32  AW[AN as u64]=type_mask(q)  AESZ[AN as u64]=esz  ALEN[AN as u64]=n  MTOP=MTOP+(n*eszu)  AN=AN+1u32
                    if ispat(nt+4u32,Q_ASN)==1u32 { if ispat(nt+5u32,Q_LB)==1u32 {   /* NAME [ NUM ] = { v0, v1, ... } (] at nt+3, = at nt+4, { at nt+5) */
                        let mut p:u32=nt+6u32  let mut idx:u64=0u64  let mut gg:u32=1u32
                        while gg==1u32 {
                            if ispat(p,Q_RB)==1u32 {gg=0u32} else { if TK[p as u64]==0u32 {gg=0u32}
                            else { if TK[p as u64]==2u32 { if esz==1i64 { data_put8(base + idx, TV[p as u64]) } else { data_put64(base + idx*8u64, TV[p as u64]) }  idx=idx+1u64  p=p+1u32  if ispat(p,Q_COM)==1u32 {p=p+1u32} }
                                   else { let ci:i32=cidx(p)  if ci>=0i32 { if esz==1i64 { data_put8(base + idx, CNV[ci as u64]) } else { data_put64(base + idx*8u64, CNV[ci as u64]) }  idx=idx+1u64 }  p=p+1u32 } } }
                        }
                        let de:u64=base + idx*eszu  if de > DEND { DEND=de }
                    } }
                } } }
            }
        }
        t=t+1u32
    }
}
/* register a struct/union type: parse `int|char [*] field ;` entries from after_brace to the }, offsets cumulative
 * (struct) or all-0 (union).  is_union -> size 8 (max i64/ptr field). */
fn reg_type(name_tok:u32, after_brace:u32, is_union:u32) {
    STNO[STN as u64]=TO[name_tok as u64]  STNL[STN as u64]=TL[name_tok as u64]  STFB[STN as u64]=SFN
    let mut q:u32=after_brace  let mut off:u64=0u64  let mut nf:u32=0u32  let mut g:u32=1u32
    while g==1u32 {
        if ispat(q,Q_RB)==1u32 {g=0u32} else { if TK[q as u64]==0u32 {g=0u32}
        else { if dtype(q)==1u32 {
            let mut esz:i64=aesz_of(q)  let mut fq:u32=q+1u32  if ispat(fq,Q_MUL)==1u32 { fq=fq+1u32  esz=8i64 }   /* element/scalar size (ptr->8) */
            SFO[SFN as u64]=TO[fq as u64]  SFL[SFN as u64]=TL[fq as u64]  SFOFF[SFN as u64]=off  SFEL[SFN as u64]=esz
            let mut fsz:u64=esz as u64                                                          /* scalar field size */
            if ispat(fq+1u32,Q_LBR)==1u32 { if TK[(fq+2u32) as u64]==2u32 { fsz=(TV[(fq+2u32) as u64] as u64)*(esz as u64) } }   /* array field: NUM*elem */
            SFN=SFN+1u32  nf=nf+1u32
            if is_union==0u32 { off=off+fsz }
            let mut g2:u32=1u32  while g2==1u32 { if ispat(q,Q_SEMI)==1u32 {g2=0u32} else { if TK[q as u64]==0u32 {g2=0u32} else {q=q+1u32} } }  q=q+1u32
        } else { q=q+1u32 } } }
    }
    let mut sz:u64=off  if is_union==1u32 { sz=8u64 }
    STNF[STN as u64]=nf  STSZ[STN as u64]=sz  STN=STN+1u32
}
fn find_rb(after_brace:u32) -> u32 { let mut q:u32=after_brace  let mut g:u32=1u32  while g==1u32 { if ispat(q,Q_RB)==1u32 {g=0u32} else { if TK[q as u64]==0u32 {g=0u32} else {q=q+1u32} } }  return q }
fn reg_var(name_tok:u32, sti:i32) { if sti>=0i32 { AO[AN as u64]=TO[name_tok as u64]  AL[AN as u64]=TL[name_tok as u64]  AB[AN as u64]=MTOP  AVT[AN as u64]=sti  MTOP=MTOP+STSZ[sti as u64]  AN=AN+1u32 } }
fn istk(t:u32) -> u32 { if kw(t,"struct" as u64,6u32)==1u32 {return 1u32}  if kw(t,"union" as u64,5u32)==1u32 {return 1u32}  if kw(t,"typedef" as u64,7u32)==1u32 {return 1u32}  return 0u32 }
fn prescan_struct() {
    STN=0u32  SFN=0u32
    let mut t:u32=0u32                                              /* pass 1: register struct/union/typedef types */
    while t<NT {
        if kw(t,"struct" as u64,6u32)==1u32 { if TK[(t+1u32) as u64]==1u32 { if ispat(t+2u32,Q_LB)==1u32 { reg_type(t+1u32, t+3u32, 0u32) } } }
        if kw(t,"union" as u64,5u32)==1u32 { if TK[(t+1u32) as u64]==1u32 { if ispat(t+2u32,Q_LB)==1u32 { reg_type(t+1u32, t+3u32, 1u32) } } }
        if kw(t,"typedef" as u64,7u32)==1u32 {
            if kw(t+1u32,"struct" as u64,6u32)==1u32 { if ispat(t+2u32,Q_LB)==1u32 { let rb:u32=find_rb(t+3u32)  reg_type(rb+1u32, t+3u32, 0u32) } }
            if kw(t+1u32,"union" as u64,5u32)==1u32 { if ispat(t+2u32,Q_LB)==1u32 { let rb:u32=find_rb(t+3u32)  reg_type(rb+1u32, t+3u32, 1u32) } }
        }
        t=t+1u32
    }
    t=0u32                                                         /* pass 2: var decls -> mem region + type */
    while t<NT {
        if kw(t,"struct" as u64,6u32)==1u32 { if TK[(t+1u32) as u64]==1u32 { if TK[(t+2u32) as u64]==1u32 { reg_var(t+2u32, stidx(t+1u32)) } } }
        if kw(t,"union" as u64,5u32)==1u32 { if TK[(t+1u32) as u64]==1u32 { if TK[(t+2u32) as u64]==1u32 { reg_var(t+2u32, stidx(t+1u32)) } } }
        if TK[t as u64]==1u32 { if TK[(t+1u32) as u64]==1u32 {     /* TypedefName v ; (IDENT IDENT, first a registered type, not after struct/union/typedef) */
            let sti:i32=stidx(t)
            if sti>=0i32 { let mut pk:u32=0u32  if t>0u32 { pk=istk(t-1u32) }  if pk==0u32 { reg_var(t+1u32, sti) } }
        } }
        t=t+1u32
    }
}
fn prescan_enum() {   /* enum [Tag] { A [= v], B, ... } -> named constants A=v, B=v+1, ... */
    let mut t:u32=0u32
    while t<NT {
        if kw(t,"enum" as u64,4u32)==1u32 {
            let mut q:u32=t+1u32
            if TK[q as u64]==1u32 { q=q+1u32 }                  /* optional tag */
            if ispat(q,Q_LB)==1u32 {
                q=q+1u32  let mut val:i64=0i64  let mut g:u32=1u32
                while g==1u32 {
                    if ispat(q,Q_RB)==1u32 {g=0u32} else { if TK[q as u64]==0u32 {g=0u32}
                    else { if TK[q as u64]==1u32 {
                        let mo:u32=TO[q as u64]  let ml:u32=TL[q as u64]  q=q+1u32
                        if ispat(q,Q_ASN)==1u32 { q=q+1u32  if TK[q as u64]==2u32 { val=TV[q as u64]  q=q+1u32 } }
                        cadd(mo, ml, val)  val=val+1i64
                        if ispat(q,Q_COM)==1u32 { q=q+1u32 }
                    } else { q=q+1u32 } } }
                }
            }
        }
        t=t+1u32
    }
}
fn cfn(fk: u32) {
    let ft:u32=FNT[fk as u64]  C=fn_nametok(ft)  C=C+1u32  eat(Q_LP)   /* [quals] type [*] NAME ( -> at ( */
    CUR_RMASK=FRM[fk as u64]
    LN=0u32  let mut lz:u32=0u32  while lz<256u32 { LCH[lz as u64]=0u32  LPT[lz as u64]=0i32-1i32  LW[lz as u64]=0i64  lz=lz+1u32 }   /* reset per-fn local flags */
    let mut params:u32=0u32  let mut go:u32=1u32
    while go==1u32 { if cp(Q_RP)==1u32 {go=0u32} else { if TK[C as u64]==0u32 {go=0u32} else {   /* [quals] type [*] NAME */
        skipquals()  let mut isc:u32=0u32  let mut styp:i32=0i32-1i32  let pm:i64=type_mask(C)
        if kw(C,"struct" as u64,6u32)==1u32 { C=C+1u32  styp=stidx(C)  C=C+1u32 }
        else { if kw(C,"union" as u64,5u32)==1u32 { C=C+1u32  styp=stidx(C)  C=C+1u32 }
               else { if dtype(C)==1u32 { if byc(C)==1u32 {isc=1u32}  C=C+1u32 }
                      else { if TK[C as u64]==1u32 { let si:i32=stidx(C)  if si>=0i32 { let nx:u32=C+1u32  let mut isty:u32=0u32  if ispat(nx,Q_MUL)==1u32 {isty=1u32}  if TK[nx as u64]==1u32 {isty=1u32}  if isty==1u32 { styp=si  C=C+1u32 } } } } } }
        let mut isp:u32=0u32  let mut gp:u32=1u32  while gp==1u32 { if cp(Q_MUL)==1u32 { C=C+1u32  isp=1u32 } else {gp=0u32} }
        let pt2:u32=C  C=C+1u32  let sl:u32=ladd(pt2)
        if isc==1u32 { if isp==1u32 { LCH[sl as u64]=1u32 } }
        if styp>=0i32 { if isp==1u32 { LPT[sl as u64]=styp } }
        if isp==0u32 { LW[sl as u64]=pm }
        params=params+1u32  eat(Q_COM)
    } } }
    eat(Q_RP)  BL=0u64  ENDED_RET=0u32  pblock()
    if ENDED_RET==0u32 { econst(0i64)  eb(0x60u32) }          /* default `return 0` ONLY for void/fall-through fns (return-ending fns stay byte-identical -> byte-DDC preserved) */
    mb(params)  mb(1u32)  mb((BL & 0xFFu64) as u32)  mb(((BL >> 8u64) & 0xFFu64) as u32)
    let mut i:u64=0u64  while i<BL { mb(BD[i] as u32)  i=i+1u64 }
}

fn pc(c: u32) { putchar((c & 0xFFu32) as i32) }
fn pstr(s: u64) { let mut i:u64=0u64  let mut go:u32=1u32  while go==1u32 { let p:*u8=(s+i) as *u8  let b:u32=p[0u64] as u32  if b==126u32 {go=0u32} else { pc(b)  i=i+1u64 } } }
var DB : [u8; 24]
fn pdec(v0: u64) { if v0==0u64 { pc(48u32)  return }  let mut v:u64=v0  let mut n:u32=0u32  while v>0u64 { DB[n as u64]=(48u64+(v%10u64)) as u8  n=n+1u32  v=v/10u64 }  while n>0u32 { n=n-1u32  pc(DB[n as u64] as u32) } }
fn emit_module() {
    let total:u64=ML+1u64
    pstr("module gen_svir\nvar SVIR : [u8; ~" as u64)  pdec(total)  pstr("] = [\n~" as u64)
    pdec(FN as u64)  pstr("u8~" as u64)
    let mut i:u64=0u64  while i<ML { pc(44u32)  pdec(MO[i] as u64)  pstr("u8~" as u64)  i=i+1u64 }
    pstr("\n]\nfn svir_ptr() -> u64 @export { return &SVIR as u64 }\nfn svir_len() -> u64 @export { return ~" as u64)
    pdec(total)  pstr("u64 }\n~" as u64)
}

fn bb(base:u64, i:u64) -> u32 { let p:*u8=(base+i) as *u8  return p[0u64] as u32 }
fn src_emit(b:u32) { if SLEN<65535u64 { let p:*u8=((&SRC as u64)+SLEN) as *u8  p[0u64]=(b & 0xFFu32) as u8  SLEN=SLEN+1u64 } }
fn read_into(ib:u64) -> u64 { let f:u64=fopen(&IPATH as u64, &MODE_RB as u64)  if f==0u64 {return 0u64}  let n:u64=fread(ib, 1u64, 32767u64, f)  fclose(f)  return n }
fn path_seen() -> u32 { let mut e:u32=0u32  while e<PN { if PLEN[e as u64]==IPLEN { let mut k:u64=0u64  let mut eq:u32=1u32  while k<IPLEN { let ip:*u8=((&IPATH as u64)+k) as *u8  let pp:*u8=((&PATHBUF as u64)+POFF[e as u64]+k) as *u8  if ip[0u64]!=pp[0u64] {eq=0u32}  k=k+1u64 }  if eq==1u32 {return 1u32} }  e=e+1u32 }  return 0u32 }
fn path_add() { if PN<256u32 { if (PBE+IPLEN)<8192u64 { POFF[PN as u64]=PBE  PLEN[PN as u64]=IPLEN  let mut k:u64=0u64  while k<IPLEN { let ip:*u8=((&IPATH as u64)+k) as *u8  let pp:*u8=((&PATHBUF as u64)+PBE+k) as *u8  pp[0u64]=ip[0u64]  k=k+1u64 }  PBE=PBE+IPLEN  PN=PN+1u32 } } }
/* does (base)[i0..] begin (after ws) with `#include "` ?  (local "..." -> 1 ; system <...> -> 0, lexer skips it) */
fn is_inc2(base:u64, i0:u64, len:u64) -> u32 {
    let mut k:u64=i0  let mut g:u32=1u32  while g==1u32 { if k>=len {g=0u32} else { let ch:u32=bb(base,k)  if ch==32u32 {k=k+1u64} else { if ch==9u32 {k=k+1u64} else {g=0u32} } } }
    if k>=len { return 0u32 }  if bb(base,k)!=35u32 { return 0u32 }  k=k+1u64
    let mut g2:u32=1u32  while g2==1u32 { if k>=len {g2=0u32} else { let ch:u32=bb(base,k)  if ch==32u32 {k=k+1u64} else { if ch==9u32 {k=k+1u64} else {g2=0u32} } } }
    if (k+7u64) > len { return 0u32 }
    if bb(base,k)!=105u32 { return 0u32 }  if bb(base,k+1u64)!=110u32 { return 0u32 }  if bb(base,k+2u64)!=99u32 { return 0u32 }  if bb(base,k+3u64)!=108u32 { return 0u32 }
    if bb(base,k+4u64)!=117u32 { return 0u32 }  if bb(base,k+5u64)!=100u32 { return 0u32 }  if bb(base,k+6u64)!=101u32 { return 0u32 }
    let mut k2:u64=k+7u64  let mut hq:u32=0u32  let mut g3:u32=1u32
    while g3==1u32 { if k2>=len {g3=0u32} else { let ch:u32=bb(base,k2)  if ch==10u32 {g3=0u32} else { if ch==34u32 {hq=1u32 g3=0u32} else {k2=k2+1u64} } } }
    return hq
}
/* recursively flatten (base)[0..len) -> SRC, inlining `#include "f"` (resolved vs main's dir), each file ONCE. */
fn flatten_buf(base:u64, len:u64, depth:u32) {
    if depth>=8u32 { return }
    let mut i:u64=0u64  let mut atls:u32=1u32
    while i < len {
        if atls==1u32 { if is_inc2(base,i,len)==1u32 {
            let mut k:u64=i  let mut g:u32=1u32  while g==1u32 { if k>=len {g=0u32} else { if bb(base,k)==34u32 {g=0u32} else {k=k+1u64} } }  k=k+1u64
            let mut d:u64=DIRLEN  let mut g2:u32=1u32  while g2==1u32 { if k>=len {g2=0u32} else { let ch:u32=bb(base,k)  if ch==34u32 {g2=0u32} else { let ip:*u8=((&IPATH as u64)+d) as *u8  ip[0u64]=(ch & 0xFFu32) as u8  d=d+1u64  k=k+1u64 } } }
            let ipe:*u8=((&IPATH as u64)+d) as *u8  ipe[0u64]=0u8  IPLEN=d
            if path_seen()==0u32 {
                path_add()
                let ib:u64 = (&IBUFS as u64) + (depth as u64)*32768u64
                let n:u64 = read_into(ib)
                flatten_buf(ib, n, depth+1u32)  src_emit(10u32)
            }
            let mut g3:u32=1u32  while g3==1u32 { if i>=len {g3=0u32} else { if bb(base,i)==10u32 {g3=0u32} else {i=i+1u64} } }  if i<len { i=i+1u64 }
        } else { let ch:u32=bb(base,i)  src_emit(ch)  if ch==10u32 {atls=1u32} else {atls=0u32}  i=i+1u64 } }
        else { let ch:u32=bb(base,i)  src_emit(ch)  if ch==10u32 {atls=1u32} else {atls=0u32}  i=i+1u64 }
    }
}
fn main(argc: i32, argv: u64) -> u64 {
    if argc < 2i32 { return 2u64 }
    let pp : *u64 = argv as *u64
    let f : u64 = fopen(pp[1u64], &MODE_RB as u64)
    if f == 0u64 { return 3u64 }
    RLEN = fread(&RAW as u64, 1u64, 65535u64, f)
    fclose(f)
    /* main file's directory (up to & incl the last / or \) -> IPATH prefix, so includes resolve beside it */
    let mp:*u8 = pp[1u64] as *u8  let mut j:u64=0u64  let mut last:u64=0u64
    let mut gg:u32=1u32  while gg==1u32 { let ch:u32=mp[j] as u32  if ch==0u32 {gg=0u32} else { if ch==47u32 {last=j+1u64} if ch==92u32 {last=j+1u64}  j=j+1u64 } }
    let mut dd:u64=0u64  while dd<last { let ip:*u8=((&IPATH as u64)+dd) as *u8  ip[0u64]=mp[dd]  dd=dd+1u64 }  DIRLEN=last
    SLEN=0u64  flatten_buf(&RAW as u64, RLEN, 0u32)
    lex()  prescan()  prescan_str()  prescan_arr()  prescan_struct()  prescan_enum()
    ML=0u64
    let mut k:u32=0u32
    while k<FN { cfn(k)  k=k+1u32 }
    if DEND > 0u64 {                                                /* append the SVIR data section [u16 len][bytes] (strings + array inits) */
        mb((DEND & 0xFFu64) as u32)  mb(((DEND >> 8u64) & 0xFFu64) as u32)
        let mut d:u64=0u64  while d<DEND { mb(SDAT[d] as u32)  d=d+1u64 }
    }
    emit_module()
    return 0u64
}
