fn ppdef_del(o:u64, l:u64) { let mut e:u32=0u32  while e<PPD_N { if PPD_LEN[e as u64]==(l as u32) { let mut k:u64=0u64  let mut eq:u32=1u32  while k<l { let p:*u8=((&PPDBUF as u64)+(PPD_OFF[e as u64] as u64)+k) as *u8  if (p[0u64] as u32)!=sb(o+k) {eq=0u32}  k=k+1u64 }  if eq==1u32 { PPD_LEN[e as u64]=0u32 } }  e=e+1u32 } }   /* #undef -> len 0, never matches */
fn preprocess() {
    PPD_N=0u32  PPD_BE=0u32  PPCSP=0u32
    let mut ri:u64=0u64  let mut wi:u64=0u64
    while ri<SLEN {
        let ls:u64=ri
        let mut le:u64=ri  let mut fe:u32=1u32  while fe==1u32 { if le>=SLEN {fe=0u32} else { if sb(le)==10u32 {le=le+1u64  fe=0u32} else {le=le+1u64} } }
        let ds:u64=pp_skipws(ls, le)
        let mut isdir:u32=0u32  if ds<le { if sb(ds)==35u32 {isdir=1u32} }
