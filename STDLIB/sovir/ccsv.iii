fn rec_fn(ft: u32) { let nt:u32=fn_nametok(ft)  FNO[FN as u64]=TO[nt as u64]  FNL[FN as u64]=TL[nt as u64]  FNP[FN as u64]=fn_named(nt)  FVAR[FN as u64]=fn_variadic(nt)  FNT[FN as u64]=ft  FRM[FN as u64]=fn_retmask(ft)  FN=FN+1u32 }
