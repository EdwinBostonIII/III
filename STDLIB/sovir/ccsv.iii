}
fn main(argc: i32, argv: u64) -> u64 {
    if argc < 2i32 { return 2u64 }
    let pp : *u64 = argv as *u64
    let f : u64 = fopen(pp[1u64], &MODE_RB as u64)
    if f == 0u64 { return 3u64 }
    RLEN = fread(&RAW as u64, 1u64, 1048575u64, f)
    fclose(f)
    /* main file's directory (up to & incl the last / or \) -> IPATH prefix, so includes resolve beside it */
    let mp:*u8 = pp[1u64] as *u8  let mut j:u64=0u64  let mut last:u64=0u64
    let mut gg:u32=1u32  while gg==1u32 { let ch:u32=mp[j] as u32  if ch==0u32 {gg=0u32} else { if ch==47u32 {last=j+1u64} if ch==92u32 {last=j+1u64}  j=j+1u64 } }
    let mut dd:u64=0u64  while dd<last { let ip:*u8=((&IPATH as u64)+dd) as *u8  ip[0u64]=mp[dd]  dd=dd+1u64 }  DIRLEN=last
    SLEN=0u64  flatten_buf(&RAW as u64, RLEN, 0u32)
    preprocess()                                                   /* strip inactive #ifdef/#ifndef/#if-0 branches before lex */
    lex()  prescan()  prescan_str()  prescan_enum()  prescan_arr()  prescan_struct()  prescan_structarr()   /* struct ARRAYS last: needs STSZ (prescan_struct) + enum consts (prescan_enum) + MTOP after scalar arrays */
    if argc>=3i32 {   /* DEBUG: `ccsv file.c <any-2nd-arg>` -> print each registered fn's index + name (FNO/FNL into SRC), then exit -- maps SVIR fn-index to source */
        pstr("# STN=~" as u64) pdec(STN as u64) pstr(" SFN=~" as u64) pdec(SFN as u64) pstr(" AN=~" as u64) pdec(AN as u64) pstr(" CN=~" as u64) pdec(CN as u64) pstr(" FN=~" as u64) pdec(FN as u64) pstr(" MTOP=~" as u64) pdec(MTOP) pc(10u32)
        let mut sk:u32=0u32
        while sk<STN {
            pc(83u32) pc(32u32) pdec(sk as u64) pc(32u32)  let mut sci:u32=0u32  while sci<STNL[sk as u64] { pc(sb((STNO[sk as u64]+sci) as u64))  sci=sci+1u32 }  pstr(" nf=~" as u64) pdec(STNF[sk as u64] as u64) pstr(" sz=~" as u64) pdec(STSZ[sk as u64]) pc(10u32)
            let fbb:u32=STFB[sk as u64]  let nff:u32=STNF[sk as u64]  let mut fjj:u32=0u32
            while fjj<nff { let fii:u32=fbb+fjj  pstr("    ~" as u64) let mut fni:u32=0u32  while fni<SFL[fii as u64] { pc(sb((SFO[fii as u64]+fni) as u64))  fni=fni+1u32 }  pstr(" off=~" as u64) pdec(SFOFF[fii as u64]) pstr(" el=~" as u64) pdec(SFEL[fii as u64] as u64) pstr(" sgn=~" as u64) pdec(SFSGN[fii as u64] as u64) pstr(" pt=~" as u64) let sp:i32=SFPT[fii as u64]  if sp<0i32 {pc(45u32) pc(49u32)} else {pdec(sp as u64)}  pc(10u32)  fjj=fjj+1u32 }
            sk=sk+1u32
        }
        let mut fk:u32=0u32  while fk<FN { pdec(fk as u64)  pc(58u32)  pc(32u32)  let mut ci:u32=0u32  while ci<FNL[fk as u64] { pc(sb((FNO[fk as u64]+ci) as u64))  ci=ci+1u32 }  pc(10u32)  fk=fk+1u32 }
        return 0u64
    }
    ML=0u64
    let mut k:u32=0u32
    while k<FN { cfn(k)  k=k+1u32 }
    if DEND > 0u64 {                                                /* append the SVIR data section [u16 len][bytes] (strings + array inits) */
        mb((DEND & 0xFFu64) as u32)  mb(((DEND >> 8u64) & 0xFFu64) as u32)
