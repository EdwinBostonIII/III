fn elor_tail() {
    while cp(Q_LOR)==1u32 {
        C=C+1u32  let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}
        eb(0x42u32)                                     /* IF (LHS true) */
        econst(1i64)  eu8(0x11u32,tmp)                  /* tmp = 1 (short-circuit) */
        eb(0x43u32)                                     /* ELSE */
        ebin(2u32)  eland_tail()  econst(0i64)  eb(0x31u32)  eu8(0x11u32,tmp)   /* tmp = (rhs != 0) */
        eb(0x44u32)  eu8(0x10u32,tmp)                   /* END ; result */
    }
}
fn ebin(minp: u32) {
    if minp==0u32 { if TK[C as u64]==1u32 { if TK[(C+1u32) as u64]==3u32 { if TV[(C+1u32) as u64]==Q_ASN {   /* NAME = rhs : assignment EXPRESSION (a=b=c, while((c=x)), f(c=x)) -- only a SIMPLE local lvalue */
        let t:u32=C  let li:i32=lidx(t)  if li>=0i32 {
            C=C+2u32  ebin(0u32)                                  /* rhs (right-assoc -> a=b=c folds correctly) */
            let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}
            eu8(0x11u32,tmp)  eu8(0x10u32,tmp)  emit_lset(li as u32)  eu8(0x10u32,tmp)  return   /* tmp=rhs (decouple value from spill store) ; store ; leave value */
        }
    } } } }
    eprim()  let mut go:u32=1u32
    while go==1u32 {
        if TK[C as u64]!=3u32 { go=0u32 }
        else { let p:i64=TV[C as u64]  let pr:u32=prec(p)
            if pr==0u32 { go=0u32 } else { if pr<minp { go=0u32 } else { C=C+1u32  ebin(pr+1u32)  eb(opc(p)) } } }
    }
    if minp==0u32 {
        eland_tail()                                     /* && (binds tighter than ||) */
        elor_tail()                                      /* || */
        if cp(Q_QUEST)==1u32 {            /* cond ? a : b (lowest prec, right-assoc) */
        let tmp:u32=LN  if LN<255u32 { LN=LN+1u32 }   /* fresh temp local carries the value across the join */
        C=C+1u32  eb(0x42u32)                         /* cond ; IF (void block) */
        ebin(0u32)  eu8(0x11u32,tmp)                  /* then: a ; LOCAL_SET tmp */
        eb(0x43u32)  eat(Q_COLON)                     /* ELSE */
        ebin(0u32)  eu8(0x11u32,tmp)                  /* else: b ; LOCAL_SET tmp */
        eb(0x44u32)  eu8(0x10u32,tmp)                 /* END ; LOCAL_GET tmp -> result */
    } }
}

fn for_init() {   /* the for-loop's init clause (no trailing ;): `T i=0[, j=1]` or `i=0[, j=1]` or an expression (comma-separated) */
    skipquals()
    if dtype(C)==1u32 { let tym:i64=type_mask(C)  let bsz:i64=type_size(C)  let bsg:u32=type_signed(C)  C=C+1u32  let mut more:u32=1u32
        while more==1u32 { let mut isp:u32=0u32  while cp(Q_MUL)==1u32 { isp=1u32  C=C+1u32 }   /* `T *p` pointer declarator in the for-init */
            let nt:u32=C  C=C+1u32  let s:u32=ladd(nt)
            if isp==1u32 { LW[s as u64]=0i64  LSZ[s as u64]=8i64  LSG[s as u64]=0u32  LPSZ[s as u64]=bsz  LPSG[s as u64]=bsg } else { LW[s as u64]=tym  LSZ[s as u64]=bsz  LSG[s as u64]=bsg }
            if cp(Q_ASN)==1u32 { C=C+1u32  ebin(0u32)  emit_lset(s) }
            if cp(Q_COM)==1u32 { C=C+1u32  more=1u32 } else { more=0u32 } }
        return }
    let mut m2:u32=1u32
    while m2==1u32 {
        if TK[C as u64]==1u32 { if ispat(C+1u32,Q_ASN)==1u32 { let nt:u32=C  C=C+2u32  ebin(0u32)  let li:i32=lidx(nt)  if li>=0i32 { emit_lset(li as u32) } } else { ebin(0u32)  eb(0x72u32) } } else { ebin(0u32)  eb(0x72u32) }
        if cp(Q_COM)==1u32 { C=C+1u32  m2=1u32 } else { m2=0u32 }
    }
}
fn one_incr() {   /* one for-incr clause: i++ / i-- / i = e / expr */
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_INC)==1u32 { let nt:u32=C  let li:i32=lidx(nt)  if li>=0i32 { emit_lget(li as u32)  econst(1i64)  eb(0x20u32)  emit_lset(li as u32) }  C=C+2u32  return } }
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_DEC)==1u32 { let nt:u32=C  let li:i32=lidx(nt)  if li>=0i32 { emit_lget(li as u32)  econst(1i64)  eb(0x21u32)  emit_lset(li as u32) }  C=C+2u32  return } }
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_ASN)==1u32 { let nt:u32=C  C=C+2u32  ebin(0u32)  let li:i32=lidx(nt)  if li>=0i32 { emit_lset(li as u32) }  return } }
    ebin(0u32)  eb(0x72u32)
}
fn emit_for_incr() { one_incr()  while cp(Q_COM)==1u32 { C=C+1u32  one_incr() } }   /* comma-separated incr clauses */
/* the lvalue ADDRESS is already on the stack; consume `= rhs` or `op= rhs` and emit the store (esz=elem byte size,
 * mask=width mask or 0).  Compound uses a fresh temp so the address is computed once: SET tmp; GET(store-addr);
 * GET;LOAD(cur val); rhs; OP; [mask]; STORE. */
fn emit_av(esz:i64, sgn:u32, mask:i64) {
    let sgv:u32=sgn                                              /* bind the single-use param to a local -> forces spill (param-spill family) */
    let op:i64=TV[C as u64]
    if op==Q_ASN { C=C+1u32  ebin(0u32)  if mask!=0i64 {econst(mask)  eb(0x25u32)}  estore(esz) }
    else {
        let mut isinc:u32=0u32  if op==Q_INC {isinc=1u32}  if op==Q_DEC {isinc=1u32}   /* lvalue++ / lvalue-- (no RHS) vs op= (RHS) */
        if isinc==1u32 { C=C+1u32 } else { C=C+2u32 }
        let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}
        eu8(0x11u32,tmp)  eu8(0x10u32,tmp)  eu8(0x10u32,tmp)
        eload(esz, sgv)
        if isinc==1u32 { econst(1i64)  if op==Q_INC {eb(0x20u32)} else {eb(0x21u32)} }   /* +1 / -1 */
        else { ebin(0u32)  eb(opc(op)) }
        if mask!=0i64 {econst(mask)  eb(0x25u32)}
        estore(esz)
    }
}
/* a switch case constant: an integer/char literal (TK==2 -> TV) or an enum/#define name (cidx -> CNV). */
fn swconst(q:u32) -> i64 { if TK[q as u64]==2u32 { return TV[q as u64] }  let ci:i32=cidx(q)  if ci>=0i32 { return CNV[ci as u64] }  return 0i64 }
/* keywords that can never be a goto-label name (so `IDENT :` after them is case/ternary/decl, not a label). */
fn is_label_kw(t:u32) -> u32 {
    if kw(t,"case" as u64,4u32)==1u32 {return 1u32}  if kw(t,"default" as u64,7u32)==1u32 {return 1u32}  if kw(t,"goto" as u64,4u32)==1u32 {return 1u32}  if dtype(t)==1u32 {return 1u32}  if isqual(t)==1u32 {return 1u32}
    if kw(t,"if" as u64,2u32)==1u32 {return 1u32}  if kw(t,"else" as u64,4u32)==1u32 {return 1u32}  if kw(t,"while" as u64,5u32)==1u32 {return 1u32}  if kw(t,"for" as u64,3u32)==1u32 {return 1u32}  if kw(t,"do" as u64,2u32)==1u32 {return 1u32}  if kw(t,"switch" as u64,6u32)==1u32 {return 1u32}  if kw(t,"return" as u64,6u32)==1u32 {return 1u32}  if kw(t,"break" as u64,5u32)==1u32 {return 1u32}
    if kw(t,"struct" as u64,6u32)==1u32 {return 1u32}  if kw(t,"union" as u64,5u32)==1u32 {return 1u32}  if kw(t,"enum" as u64,4u32)==1u32 {return 1u32}  if kw(t,"typedef" as u64,7u32)==1u32 {return 1u32}  if kw(t,"sizeof" as u64,6u32)==1u32 {return 1u32}
    return 0u32
}
fn lblidx(t:u32) -> i32 { let mut k:u32=0u32  while k<LBLN { if neq(LBLO[k as u64],LBLL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return k as i32}  k=k+1u32 }  return 0i32-1i32 }
/* collect TOP-LEVEL (function-brace-depth 1) labels `IDENT :` at statement boundaries (the `goto fail` form). */
fn prescan_labels(start:u32) {
    LBLN=0u32  let mut q:u32=start  let mut bd:i32=0i32  let mut atb:u32=1u32  let mut g:u32=1u32
    while g==1u32 {
        if TK[q as u64]==0u32 { g=0u32 }
        else { if ispat(q,Q_LB)==1u32 { bd=bd+1i32  atb=1u32  q=q+1u32 }
               else { if ispat(q,Q_RB)==1u32 { bd=bd-1i32  if bd==0i32 {g=0u32} else { atb=1u32  q=q+1u32 } }
                      else { if ispat(q,Q_SEMI)==1u32 { atb=1u32  q=q+1u32 }
                             else { let mut islbl:u32=0u32
                                    if bd==1i32 { if atb==1u32 { if TK[q as u64]==1u32 { if is_label_kw(q)==0u32 { if ispat(q+1u32,Q_COLON)==1u32 { islbl=1u32 } } } } }
                                    if islbl==1u32 { if LBLN<64u32 { LBLO[LBLN as u64]=TO[q as u64]  LBLL[LBLN as u64]=TL[q as u64]  LBLN=LBLN+1u32 }  q=q+2u32  atb=1u32 }
                                    else { atb=0u32  q=q+1u32 } } } }
        }
    }
}
/* emit the case/default bodies (second walk over { }): close one case block before each case body (fall-through =
 * sequential emission), close B_def before the default body, close B_exit at the }.  `break` (handled in pstmt via
 * the BRKT stack) branches to B_exit.  Scope: default LAST or absent (the common/seed form); cases in source order. */
fn emit_switch_bodies(n:u32) {
    let mut closed:u32=0u32  let mut indef:u32=0u32  let mut g:u32=1u32
    while g==1u32 {
        if cp(Q_RB)==1u32 {
            if indef==0u32 { eb(0x44u32)  BLKD=BLKD-1i64 }          /* close B_def (no explicit default) */
            eb(0x44u32)  BLKD=BLKD-1i64  if BRKN>0u32 { BRKN=BRKN-1u32 }  C=C+1u32  g=0u32   /* close B_exit ; pop break target */
        } else { if TK[C as u64]==0u32 { g=0u32 }
            else { if kw(C,"case" as u64,4u32)==1u32 {
                       C=C+1u32  let mut sg:u32=1u32  while sg==1u32 { if cp(Q_COLON)==1u32 {sg=0u32} else { if TK[C as u64]==0u32 {sg=0u32} else {C=C+1u32} } }  eat(Q_COLON)   /* skip `case CONST :` */
                       eb(0x44u32)  BLKD=BLKD-1i64  closed=closed+1u32                       /* close B_{closed} -> this case's body lands here */
                   } else { if kw(C,"default" as u64,7u32)==1u32 {
                       C=C+1u32  eat(Q_COLON)
                       while closed<n { eb(0x44u32)  BLKD=BLKD-1i64  closed=closed+1u32 }     /* close any case blocks not yet closed */
                       eb(0x44u32)  BLKD=BLKD-1i64  indef=1u32                                /* close B_def -> default body lands here */
                   } else { pstmt() } }
            }
        }
    }
}
/* does the loop body at C contain a `continue` (within its own brace/stmt scope)? -> only then wrap it in a
 * continue block.  Over-detects a nested loop's continue (harmless extra block) but keeps continue-FREE loops
 * byte-identical (no extra BLOCK/END -> the cross-language byte-DDC + smaller output). */
fn loop_has_cont() -> u32 {
    let mut q:u32=C
    if ispat(q,Q_LB)==1u32 { let mut d:i32=0i32  let mut g:u32=1u32
        while g==1u32 { if TK[q as u64]==0u32 {g=0u32} else { if ispat(q,Q_LB)==1u32 {d=d+1i32}  if ispat(q,Q_RB)==1u32 { d=d-1i32  if d==0i32 {g=0u32} }  if kw(q,"continue" as u64,8u32)==1u32 {return 1u32}  if g==1u32 {q=q+1u32} } }
    } else { let mut g:u32=1u32  while g==1u32 { if ispat(q,Q_SEMI)==1u32 {g=0u32} else { if TK[q as u64]==0u32 {g=0u32} else { if kw(q,"continue" as u64,8u32)==1u32 {return 1u32}  q=q+1u32 } } } }
    return 0u32
}
fn pstmt() {
    ENDED_RET=0u32                                                 /* cleared each statement; the return handler sets it */
    if isqual(C)==1u32 { let mut sg:u32=1u32  while sg==1u32 { if isqual(C)==1u32 { if kw(C,"unsigned" as u64,8u32)==1u32 {sg=0u32} else { if kw(C,"signed" as u64,6u32)==1u32 {sg=0u32} else { if kw(C,"long" as u64,4u32)==1u32 {sg=0u32} else { if kw(C,"short" as u64,5u32)==1u32 {sg=0u32} else {C=C+1u32} } } } } else {sg=0u32} } }   /* skip leading const/static/volatile but KEEP the type specifiers unsigned/signed/long/short (the decl handler reads their size) */
    if cp(Q_INC)==1u32 { ebin(0u32)  eb(0x72u32)  eat(Q_SEMI)  return }   /* ++lvalue ; (prefix inc statement -> eval + DROP) */
    if cp(Q_DEC)==1u32 { ebin(0u32)  eb(0x72u32)  eat(Q_SEMI)  return }   /* --lvalue ; */
    if cp(Q_MUL)==1u32 {                                            /* *p [op]= e ;  (pointer deref store/compound, typed width) */
        C=C+1u32
        if TK[C as u64]==1u32 { let dli:i32=lidx(C)  if dli>=0i32 {
            let lp:i32=LPT[dli as u64]  let psz:i64=LPSZ[dli as u64]  let psg:u32=LPSG[dli as u64]   /* read into immutable lets BEFORE eprim (direct read, multi-use dli -> spilled) */
            eprim()                                                 /* store ADDRESS: *p (or *p++ -> old p, advance) */
            if lp<0i32 { emit_av(psz, psg, 0i64) } else { emit_av(8i64, 0u32, 0i64) }   /* = or op= (compound) via the unified store */
            eat(Q_SEMI)  return } }
        eprim()  emit_av(8i64, 0u32, 0i64)  eat(Q_SEMI)  return   /* complex deref expr -> 8 */
    }
    if kw(C,"struct" as u64,6u32)==1u32 {
        let sti:i32=stidx(C+1u32)
        if TK[(C+2u32) as u64]==3u32 { if TV[(C+2u32) as u64]==Q_MUL {   /* struct Name *p [= e] ; -> struct-pointer local */
            C=C+3u32  let nt:u32=C  C=C+1u32  let s:u32=ladd(nt)  if sti>=0i32 { LPT[s as u64]=sti }
            if cp(Q_ASN)==1u32 { C=C+1u32  ebin(0u32)  eu8(0x11u32,s) }
            eat(Q_SEMI)  return
        } }
        let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } }  eat(Q_SEMI)  return   /* struct Name v ; -> value (registered by prescan_struct); skip */
    }
    if kw(C,"union" as u64,5u32)==1u32 {                            /* union Name u ; (local) -> registered by prescan; skip */
        let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } }  eat(Q_SEMI)  return
    }
    if kw(C,"typedef" as u64,7u32)==1u32 {                          /* local typedef def -> registered by prescan; skip */
        let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } }  eat(Q_SEMI)  return
    }
    if kw(C,"enum" as u64,4u32)==1u32 {                             /* local enum def -> registered by prescan_enum; skip */
        let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } }  eat(Q_SEMI)  return
    }
    if TK[C as u64]==1u32 { if TK[(C+1u32) as u64]==3u32 { if TV[(C+1u32) as u64]==Q_MUL { let stc:i32=stidx(C)  if stc>=0i32 {   /* TypedefName *p [= e] ; -> struct-pointer local */
        C=C+2u32  let nt:u32=C  C=C+1u32  let s:u32=ladd(nt)  LPT[s as u64]=stc
        if cp(Q_ASN)==1u32 { C=C+1u32  ebin(0u32)  eu8(0x11u32,s) }
        eat(Q_SEMI)  return
    } } } }
    if TK[C as u64]==1u32 { if TK[(C+1u32) as u64]==1u32 { let stc:i32=stidx(C)  if stc>=0i32 {   /* TypedefName v [= e] ; -> struct-VALUE local: reserve STSZ inline, `p.field` via abase/avtype */
        let isval:u32=ispat(C+2u32,Q_SEMI)  let isini:u32=ispat(C+2u32,Q_ASN)   /* ONLY a scalar `Foo v ;` / `Foo v = e ;` (NOT `Foo v[N]`, `Foo v, w`, `Foo v(...)` -> those fall to the old skip) */
        if isval==1u32 { C=C+1u32  let nt:u32=C  C=C+1u32  let s:u32=ladd(nt)  LVT[s as u64]=stc  LVB[s as u64]=MTOP as i64  MTOP=MTOP+STSZ[stc as u64]  eat(Q_SEMI)  return }
        if isini==1u32 { C=C+1u32  let nt:u32=C  C=C+1u32  let s:u32=ladd(nt)  LVT[s as u64]=stc  LVB[s as u64]=MTOP as i64  MTOP=MTOP+STSZ[stc as u64]  C=C+1u32  let szc:i64=STSZ[stc as u64] as i64
            if szc<=8i64 { econst(LVB[s as u64])  ebin(0u32)  eb(0x83u32) }   /* `T r = <expr>` (<=8B): the init yields the packed value (call RETURN / struct-var packing) -> STORE64 to r */
            else { let srcvt:i32=avtype(C)
                if srcvt>=0i32 { if ispat(C+1u32,Q_SEMI)==1u32 {   /* = otherStructVar (>8B) : byte copy STSZ bytes */
                    let srcb:i64=abase(C)  let dstb:i64=LVB[s as u64]  let mut bc:i64=0i64
                    while bc<szc { econst(dstb+bc)  econst(srcb+bc)  eb(0x80u32)  eb(0x81u32)  bc=bc+1i64 }  C=C+1u32
                } else { let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } } } }
                else { let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } } } }   /* >8B unknown init (field-chain copy) -> skip */
            eat(Q_SEMI)  return }
        let mut g:u32=1u32  while g==1u32 { if cp(Q_SEMI)==1u32 {g=0u32} else { if TK[C as u64]==0u32 {g=0u32} else {C=C+1u32} } }  eat(Q_SEMI)  return   /* `Foo v[N]` / `Foo v, w` / other -> OLD skip (unchanged behavior) */
    } } }
    let mut uovs:i32=0i32-1i32  let mut usk:u32=0u32                /* leading unsigned/signed prefix (bare `unsigned` = unsigned int) */
    if kw(C,"unsigned" as u64,8u32)==1u32 { uovs=0i32  usk=1u32 } else { if kw(C,"signed" as u64,6u32)==1u32 { uovs=1i32  usk=1u32 } }
    let mut lsz:i64=0i64  let mut lsk:u32=0u32  let lq:u32=C+usk                 /* `long`/`short` size word (after the optional sign) -- isqual-skipped elsewhere, so capture SIZE here */
    if kw(lq,"long" as u64,4u32)==1u32 {lsz=8i64  lsk=1u32  if kw(lq+1u32,"long" as u64,4u32)==1u32 {lsk=2u32}} else { if kw(lq,"short" as u64,5u32)==1u32 {lsz=2i64  lsk=1u32} }
    let mut isdcl:u32=0u32  if dtype(C)==1u32 {isdcl=1u32}  if uovs>=0i32 {isdcl=1u32}  if lsz!=0i64 {isdcl=1u32}
    if isdcl==1u32 {                                               /* int/char/short/long/[un]signed decl, incl MULTI: `T a [=e], *p, b[N], c=e ;` */
        let dtt:u32=C+usk  let mut tt:u32=C  let mut bsz:i64=4i64  let mut tym:i64=4294967295i64  let mut bsg:u32=0u32  let mut adv:u32=1u32
        if lsz!=0i64 { bsz=lsz  bsg=1u32  if uovs>=0i32 {bsg=uovs as u32}  adv=usk+lsk  if lsz==2i64 {tym=65535i64} else {tym=0i64}  let dd:u32=C+usk+lsk  if dtype(dd)==1u32 {adv=adv+1u32} }   /* [un]signed short/long [long] [int] : size 2/8 + optional trailing base */
        else { if uovs>=0i32 { bsg=uovs as u32  if dtype(dtt)==1u32 { tt=dtt  bsz=type_size(dtt)  tym=type_mask(dtt)  adv=2u32 } }   /* `unsigned int/char` ; bare `unsigned` -> int (4B/0xFFFFFFFF) */
               else { bsz=type_size(C)  tym=type_mask(C)  bsg=type_signed(C) } }
        let isc:u32=byc(tt)  C=C+adv  let mut more:u32=1u32
        while more==1u32 {
            let mut isp:u32=0u32  if cp(Q_MUL)==1u32 { C=C+1u32  isp=1u32 }
            let nt:u32=C
            if ispat(C+1u32, Q_LBR)==1u32 {                         /* NAME[NUM] [= {...}] local array (base from prescan_arr) */
                let arrnt:u32=nt  C=C+1u32                          /* at [ */
