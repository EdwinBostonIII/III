    eat(Q_RP)  let mut gds:u32=1u32  while gds==1u32 { if cp(Q_LB)==1u32 {gds=0u32} else { if cp(Q_SEMI)==1u32 {gds=0u32} else { if TK[C as u64]==0u32 {gds=0u32} else {C=C+1u32} } } }   /* skip a trailing function-declarator suffix between the params `)` and the body `{` -- e.g. `uint8_t (**iii_pool_mhash(..))[32] {` leaves C at the outer `)[32]`; without this, prescan + eat(Q_LB) parse from the wrong point and the body mis-compiles (rc=8, the seed's ast pool-mhash accessors). Bounded by `;`/EOF (a prototype would stop, never eat the next fn). */
