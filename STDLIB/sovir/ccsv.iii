fn pp_kw(o:u64, s:u64, n:u64) -> u32 { let mut k:u64=0u64  while k<n { let q:*u8=(s+k) as *u8  if sb(o+k)!=(q[0u64] as u32) {return 0u32}  k=k+1u64 }  if idc(sb(o+n))==1u32 {return 0u32}  return 1u32 }
fn pp_active() -> u32 { if PPCSP==0u32 {return 1u32}  return PPCSTK[(PPCSP-1u32) as u64] }
fn pp_push(a:u32) { if PPCSP<64u32 { PPCSTK[PPCSP as u64]=a  PPCSP=PPCSP+1u32 } }
fn pp_pop() { if PPCSP>0u32 { PPCSP=PPCSP-1u32 } }
fn pp_skipws(o:u64, le:u64) -> u64 { let mut p:u64=o  let mut g:u32=1u32  while g==1u32 { if p>=le {g=0u32} else { if pp_wsb(sb(p))==1u32 {p=p+1u64} else {g=0u32} } }  return p }
fn pp_namelen(o:u64) -> u64 { let mut l:u64=0u64  let mut g:u32=1u32  while g==1u32 { if idc(sb(o+l))==1u32 {l=l+1u64} else {g=0u32} }  return l }
fn ppdef_add(o:u64, l:u64) { if PPD_N<8192u32 { if (PPD_BE+(l as u32))<131072u32 { PPD_OFF[PPD_N as u64]=PPD_BE  PPD_LEN[PPD_N as u64]=l as u32  let mut k:u64=0u64  while k<l { let p:*u8=((&PPDBUF as u64)+(PPD_BE as u64)+k) as *u8  p[0u64]=sb(o+k) as u8  k=k+1u64 }  PPD_BE=PPD_BE+(l as u32)  PPD_N=PPD_N+1u32 } } }
