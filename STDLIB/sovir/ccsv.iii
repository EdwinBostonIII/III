        eu8(0x10u32,tf)  eb(0x80u32)  eu8(0x11u32,tsp)                            /* tsp = *tf */
        eu8(0x10u32,tf)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,tf)                /* tf++ */
        eu8(0x10u32,tsp)  econst(115i64)  eb(0x30u32)  eb(0x42u32)                /* %s */
            eu8(0x10u32,tap)  eb(0x82u32)  eu8(0x11u32,ts)  eu8(0x10u32,tap)  econst(8i64)  eb(0x20u32)  eu8(0x11u32,tap)   /* ts = va_arg */
            eb(0x40u32)  eb(0x41u32)
            eu8(0x10u32,ts)  eb(0x80u32)  eu8(0x11u32,tc2)  eu8(0x10u32,tc2)  econst(0i64)  eb(0x30u32)  eu8(0x51u32,1u32)   /* tc2=*ts; if 0 break */
            eu8(0x10u32,td)  eu8(0x10u32,tc2)  eb(0x81u32)  eu8(0x10u32,td)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,td)       /* *td=tc2; td++ */
            eu8(0x10u32,ts)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ts)  eu8(0x50u32,0u32)                                    /* ts++; loop */
            eb(0x44u32)  eb(0x44u32)
        eb(0x44u32)
        eu8(0x10u32,tsp)  econst(100i64)  eb(0x30u32)  eb(0x42u32)                /* %d */
            eu8(0x10u32,tap)  eb(0x82u32)  eu8(0x11u32,tn)  eu8(0x10u32,tap)  econst(8i64)  eb(0x20u32)  eu8(0x11u32,tap)
            emit_putnum(td, tn, 10i64, 1u32)
        eb(0x44u32)
        eu8(0x10u32,tsp)  econst(117i64)  eb(0x30u32)  eb(0x42u32)                /* %u */
            eu8(0x10u32,tap)  eb(0x82u32)  eu8(0x11u32,tn)  eu8(0x10u32,tap)  econst(8i64)  eb(0x20u32)  eu8(0x11u32,tap)
            emit_putnum(td, tn, 10i64, 0u32)
        eb(0x44u32)
        eu8(0x10u32,tsp)  econst(120i64)  eb(0x30u32)  eb(0x42u32)                /* %x */
            eu8(0x10u32,tap)  eb(0x82u32)  eu8(0x11u32,tn)  eu8(0x10u32,tap)  econst(8i64)  eb(0x20u32)  eu8(0x11u32,tap)
            emit_putnum(td, tn, 16i64, 0u32)
        eb(0x44u32)
        eu8(0x10u32,tsp)  econst(99i64)  eb(0x30u32)  eb(0x42u32)                 /* %c */
            eu8(0x10u32,td)  eu8(0x10u32,tap)  eb(0x82u32)  eb(0x81u32)  eu8(0x10u32,td)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,td)  eu8(0x10u32,tap)  econst(8i64)  eb(0x20u32)  eu8(0x11u32,tap)
        eb(0x44u32)
        eu8(0x10u32,tsp)  econst(37i64)  eb(0x30u32)  eb(0x42u32)                 /* %% */
            eu8(0x10u32,td)  econst(37i64)  eb(0x81u32)  eu8(0x10u32,td)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,td)
        eb(0x44u32)
    eb(0x43u32)                                                                   /* ELSE (literal char) */
        eu8(0x10u32,td)  eu8(0x10u32,tc)  eb(0x81u32)  eu8(0x10u32,td)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,td)  eu8(0x10u32,tf)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,tf)
    eb(0x44u32)                                                                   /* END (%) */
    eu8(0x50u32,0u32)
    eb(0x44u32)  eb(0x44u32)                                                       /* END END (loop, block) */
    eu8(0x10u32,td)  econst(0i64)  eb(0x81u32)                                     /* *td = 0 (NUL) */
}
/* ++ / -- on a scalar LOCAL (scale 1).  isdec:1=-- ; post:1=leave OLD (postfix) / 0=leave NEW (prefix). */
fn pinc_local(slot:u32, isdec:u32, post:u32) {
    let tv:u32=LN  if LN<255u32 {LN=LN+1u32}
    if post==1u32 {
        emit_lget(slot)  eu8(0x11u32,tv)                                                          /* tv = old */
        eu8(0x10u32,tv)  econst(1i64)  if isdec==1u32 {eb(0x21u32)} else {eb(0x20u32)}  emit_lset(slot)   /* slot = old +/-1 */
        eu8(0x10u32,tv)                                                                            /* leave OLD */
    } else {
        emit_lget(slot)  econst(1i64)  if isdec==1u32 {eb(0x21u32)} else {eb(0x20u32)}  emit_lset(slot)
        emit_lget(slot)                                                                            /* leave NEW (canonical reload) */
    }
}
/* ++ / -- on a MEMORY lvalue: the store ADDRESS is ALREADY on the eval stack.  elem size/sign/mask ; scale 1. */
fn pinc_mem(esz:i64, sgn:u32, mask:i64, isdec:u32, post:u32) {
    let ta:u32=LN  if LN<255u32 {LN=LN+1u32}
    let tv:u32=LN  if LN<255u32 {LN=LN+1u32}
    eu8(0x11u32,ta)                                                                                /* ta = addr (computed once) */
    if post==1u32 {
        eu8(0x10u32,ta)  eload(esz,sgn)  eu8(0x11u32,tv)                                           /* tv = old = *addr */
        eu8(0x10u32,ta)  eu8(0x10u32,tv)  econst(1i64)  if isdec==1u32 {eb(0x21u32)} else {eb(0x20u32)}  if mask!=0i64 {econst(mask) eb(0x25u32)}  estore(esz)   /* *addr = old +/-1 */
        eu8(0x10u32,tv)                                                                            /* leave OLD */
    } else {
        eu8(0x10u32,ta)  eload(esz,sgn)  econst(1i64)  if isdec==1u32 {eb(0x21u32)} else {eb(0x20u32)}  if mask!=0i64 {econst(mask) eb(0x25u32)}  eu8(0x11u32,tv)   /* tv = new (masked) */
        eu8(0x10u32,ta)  eu8(0x10u32,tv)  estore(esz)                                              /* *addr = new */
        eu8(0x10u32,tv)                                                                            /* leave NEW */
    }
}
/* parse an lvalue at C and pre/post inc/dec it.  Handles NAME[idx] (global array / pointer) and bare scalar local NAME. */
fn elvalinc(isdec:u32, post:u32) {
    if TK[C as u64]==1u32 {
        let t:u32=C
        if ispat(C+1u32,Q_LBR)==1u32 {
            let ab:i64=abase(t)
            if ab>=0i64 { C=C+2u32  ebin(0u32)  eat(Q_RBR)  let sz:i64=aesize(t)  let sg:u32=asign(t)  let am:i64=awmask(t)
                estride(sz)  if ab>0i64 { econst(ab)  eb(0x20u32) }  pinc_mem(sz,sg,am,isdec,post)  return }
            let pli:i32=lidx(t)  if pli>=0i32 { let psz:i64=LPSZ[pli as u64]  let psg:u32=LPSG[pli as u64]  emit_lget(pli as u32)  C=C+2u32  ebin(0u32)  eat(Q_RBR)
                estride(psz)  eb(0x20u32)  pinc_mem(psz,psg,0i64,isdec,post)  return }
        }
        let li:i32=lidx(t)  if li>=0i32 { C=C+1u32  pinc_local(li as u32,isdec,post)  return }
        let gb:i64=abase(t)  if gb>=0i64 { if aisc(t)==1u32 {                                       /* global scalar ++g/--g/g++/g-- : was DROPPED (li<0 -> eprim read, no store) */
            let sz:i64=aesize(t)  let sg:u32=asign(t)  let gm:i64=awmask(t)  C=C+1u32
            let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}
            econst(gb)  eload(sz,sg)  eu8(0x11u32,tmp)                                              /* tmp = old g */
            econst(gb)  eu8(0x10u32,tmp)  econst(1i64)  if isdec==1u32 {eb(0x21u32)} else {eb(0x20u32)}  if gm!=0i64 {econst(gm)  eb(0x25u32)}  estore(sz)   /* *(gb) = old +/- 1 */
            if post==1u32 { eu8(0x10u32,tmp) } else { econst(gb)  eload(sz,sg) }                    /* leave: post=old, pre=new */
            return } }
    }
    eprim()                                                                                        /* not a recognized lvalue -> plain (++*p etc., rare) */
}
fn fn_ret_struct(ft:u32) -> i32 {   /* if the fn whose type starts at ft returns `StructType *` / `struct TAG *`, that struct's stidx, else -1.  Computed at CODEGEN time (structs registered) -> avoids the prescan-order trap.  Enables call()->field. */
    let mut q:u32=ft  let mut g:u32=1u32  while g==1u32 { if isqual(q)==1u32 {q=q+1u32} else {g=0u32} }
    if kw(q,"struct" as u64,6u32)==1u32 { if ispat(q+2u32,Q_MUL)==1u32 { return stidx(q+1u32) }  return 0i32-1i32 }
    let si:i32=stidx(q)  if si>=0i32 { if ispat(q+1u32,Q_MUL)==1u32 { return si } }
    return 0i32-1i32
}
fn fn_ret_sval(ft:u32) -> i32 {   /* struct-VALUE return (`StructType` / `struct TAG`, NO *, size > 8) -> its stidx, else -1.  For the sret hidden-pointer ABI (seed: `iii_src_pos_t pos = iiip_pos_of(..)`, 16B).  STSZ>8 guard: enum/scalar typedefs have stidx>=0 too -> would false-positive + break the fn (regressed the floor 82->84 without it). */
    if SRET_ON==0u32 { return 0i32-1i32 }   /* Boss-2 master switch OFF -> sret dormant (cfn reserve + return-copy + receive-site all gate on this) -> floor 82.  ON: test_structval all-4=99. */
    let mut q:u32=ft  let mut g:u32=1u32  while g==1u32 { if isqual(q)==1u32 {q=q+1u32} else {g=0u32} }
    if kw(q,"struct" as u64,6u32)==1u32 { if ispat(q+2u32,Q_MUL)==0u32 { let st:i32=stidx(q+1u32)  if st>=0i32 { if STSZ[st as u64]>8u64 { return st } } }  return 0i32-1i32 }
    let si:i32=stidx(q)  if si>=0i32 { if ispat(q+1u32,Q_MUL)==0u32 { if STSZ[si as u64]>8u64 { return si } } }
    return 0i32-1i32
}
fn emit_sret_copy(li:u32) {   /* copy CUR_SRETSZ bytes from struct-value LOCAL slot `li` (frame-aware via emit_vbase_s -> recursion-safe at SHADOW_ON=1, byte-identical at OFF) to *(slot CUR_SRET) : 8-byte chunks + 4-byte tail */
    let sz:i64=CUR_SRETSZ  let mut off:i64=0i64
    while off+8i64<=sz { eu8(0x10u32,CUR_SRET as u32)  if off>0i64 {econst(off)  eb(0x20u32)}  emit_vbase_s(li, off)  eb(0x82u32)  eb(0x83u32)  off=off+8i64 }   /* *(sret+off) = *(r+off)  [64] */
    while off+4i64<=sz { eu8(0x10u32,CUR_SRET as u32)  if off>0i64 {econst(off)  eb(0x20u32)}  emit_vbase_s(li, off)  eb(0x86u32)  eb(0x89u32)  off=off+4i64 }   /* tail [32] */
}
fn eprim() {
    if cp(Q_INC)==1u32 { C=C+1u32  elvalinc(0u32,0u32)  return }   /* ++lvalue (prefix, leave NEW) */
    if cp(Q_DEC)==1u32 { C=C+1u32  elvalinc(1u32,0u32)  return }   /* --lvalue (prefix) */
    if cp(Q_MUL)==1u32 { C=C+1u32                                  /* *p : pointer deref (typed by pointee width) */
        if TK[C as u64]==1u32 { let dli:i32=lidx(C)  if dli>=0i32 {
            let lp:i32=LPT[dli as u64]  let psz:i64=LPSZ[dli as u64]  let psg:u32=LPSG[dli as u64]   /* read into lets BEFORE branching (inline LPT[dli]<0 after lidx miscompiles -> skips, LOAD64) */
            if lp<0i32 {
                if ispat(C+1u32,Q_INC)==1u32 { let ta:u32=LN  if LN<255u32 {LN=LN+1u32}   /* *(p++) : deref OLD p, advance p by pointee size */
                    emit_lget(dli as u32)  eu8(0x11u32,ta)  emit_lget(dli as u32)  econst(psz)  eb(0x20u32)  emit_lset(dli as u32)
                    eu8(0x10u32,ta)  eload(psz,psg)  C=C+2u32  return }
                if ispat(C+1u32,Q_DEC)==1u32 { let ta:u32=LN  if LN<255u32 {LN=LN+1u32}   /* *(p--) */
                    emit_lget(dli as u32)  eu8(0x11u32,ta)  emit_lget(dli as u32)  econst(psz)  eb(0x21u32)  emit_lset(dli as u32)
                    eu8(0x10u32,ta)  eload(psz,psg)  C=C+2u32  return }
                emit_lget(dli as u32)  C=C+1u32  eload(psz, psg)  return } } }
        if TK[C as u64]==1u32 { let gps:i64=apsz(C)  if gps>0i64 { let gb:i64=abase(C)  if gb>=0i64 {   /* *gp : GLOBAL scalar-pointer deref-READ -> LOAD64(gp's value=address) THEN eload(pointee width/sign) ; was DROPPED (fell to the single-LOAD64 fallback -> read gp's address, not *gp) */
            econst(gb)  eb(0x82u32)  eload(gps, apsg(C))  C=C+1u32  return } } }
        eprim()  eb(0x82u32)  return                              /* fallback (struct-ptr / complex deref) -> LOAD64 */
    }
    if cp(Q_AND)==1u32 {                                            /* &arr[i] / &arr : address-of (no load) */
        C=C+1u32
        if cp(Q_LP)==1u32 { if ispat(C+1u32,Q_MUL)==1u32 { if TK[(C+2u32) as u64]==1u32 { if ispat(C+3u32,Q_RP)==1u32 { if ispat(C+4u32,Q_LBR)==1u32 {   /* &(*pp)[i] : address of elem i of the dereffed inner pointer -- the seed pool accessor `&(*pf)[slot]` */
            let idn:u32=C+2u32  let li:i32=lidx(idn)  if li>=0i32 { let st:i64=LPP[li as u64]  emit_lget(li as u32)  eb(0x82u32)  C=C+5u32  ebin(0u32)  eat(Q_RBR)  estride(st)  eb(0x20u32)  return } } } } } }
        if TK[C as u64]==1u32 { let at:u32=C
            let vt:i32=avtype(at)  if vt>=0i32 { if ispat(at+1u32,Q_DOT)==1u32 { let ft:u32=at+2u32  let foff:i64=fieldoff(vt,ft)  C=C+3u32  emit_vbase(at, foff)  return } }   /* &v.field : struct-value field address = base+offset (frame-aware) */
            let ptt:i32=lpt(at)  if ptt>=0i32 { if ispat(at+1u32,Q_ARROW)==1u32 { let ft:u32=at+2u32  let foff:i64=fieldoff(ptt,ft)  let pl:i32=lidx(at)  let eltp:i32=fieldpt(ptt,ft)
                if ispat(at+3u32,Q_LBR)==1u32 { if eltp>=0i32 { let fe:i64=fieldelem(ptt,ft)  let esz:i64=STSZ[eltp as u64] as i64  C=C+4u32  ebin(0u32)  eat(Q_RBR)  estride(esz)  emit_lget(pl as u32)  if foff>0i64 {econst(foff) eb(0x20u32)}  if fe==8i64 {eb(0x82u32)}  eb(0x20u32)  return } }   /* &p->arrfield[i] : i*STSZ + [*](p+foff) */
                if eltp>=0i32 { if ispat(at+3u32,Q_DOT)==1u32 {   /* &p->f1.f2.. : address of a field nested through struct/UNION members (union members at +0) -- the seed's `&n->u.<variant>.<field>`; the old code returned after `&p->u` leaving `.member.field` unconsumed -> residue */
                    C=C+3u32  let mut curA:i32=eltp  let mut accA:i64=foff  let mut gcA:u32=1u32
                    while gcA==1u32 { C=C+1u32  let nfA:u32=C  C=C+1u32  let nfoA:i64=fieldoff(curA,nfA)  accA=accA+nfoA  let nptA:i32=fieldpt(curA,nfA)  let mut moreA:u32=0u32  if nptA>=0i32 { if cp(Q_DOT)==1u32 {moreA=1u32} }  if moreA==1u32 {curA=nptA} else {gcA=0u32} }
                    emit_lget(pl as u32)  if accA>0i64 {econst(accA)  eb(0x20u32)}  return } }
                C=C+3u32  emit_lget(pl as u32)  if foff>0i64 {econst(foff)  eb(0x20u32)}  return } }   /* &p->field : ptr + field offset */
            let ab:i64=abase(at)
            if ab>=0i64 {
                if ispat(C+1u32,Q_LBR)==1u32 { C=C+2u32  ebin(0u32)  eat(Q_RBR)  let sz:i64=aesize(at)  estride(sz)  if ab>0i64 { econst(ab)  eb(0x20u32) }  return }   /* &arr[i] : i*esz (+base) */
                C=C+1u32  emit_vbase(at, 0i64)  return   /* &v (bare) : struct-value LOCAL -> frame-relative base (Boss-2) ; global array/struct -> econst(base) */
            }
            let ali:i32=lidx(at)  if ali>=0i32 { let am:i64=LMEM[ali as u64]  if am>=0i64 { C=C+1u32  emit_frame_addr(am)  return } }   /* &local : its spill frame address */
        }
        return
    }
    if cp(Q_NOT)==1u32 { C=C+1u32  eprim()  econst(0i64-1i64)  eb(0x27u32)  return }   /* ~x = x XOR -1 (correct for any width; svir_wasm c_leb_s64 now encodes negatives) */
    if cp(Q_LNOT)==1u32 { C=C+1u32  eprim()  econst(0i64)  eb(0x30u32)  return }   /* !x = (x == 0) -> 0/1 (logical NOT) */
    if cp(Q_SUB)==1u32 { C=C+1u32  econst(0i64)  eprim()  eb(0x21u32)  return }          /* -x = 0 - x (eprim had NO unary minus -> `-var` underflowed the eval stack) */
    if cp(Q_LP)==1u32 {
        if TK[(C+1u32) as u64]==1u32 { if ispat(C+2u32,Q_RP)==1u32 { if ispat(C+3u32,Q_LB)==1u32 { let clst:i32=stidx(C+1u32)  if clst>=0i32 { if STSZ[clst as u64]<=8u64 {   /* ( StructTypedef ) { f0, f1, .. } : COMPOUND LITERAL <=8B -> PACK the field inits into one value (the <=8B struct-value representation), no temp/frame.  ccsv mis-read it as a cast + stray brace -> the seed's `(iii_ast_list_t){0u,0u}` ternary branch orphaned (verify rc=8). */
            let fb:u32=STFB[clst as u64]  let nf:u32=STNF[clst as u64]  let mut bi:u32=0u32
            C=C+3u32  eat(Q_LB)  econst(0i64)                                          /* acc = 0 (un-given tail fields stay 0 -> C `{0}` semantics) */
            if cp(Q_RB)==0u32 { let mut go:u32=1u32  while go==1u32 {
                if bi<nf { let fi:u32=fb+bi  let foff:i64=SFOFF[fi as u64] as i64  let fel:i64=SFEL[fi as u64]
                    ebin(0u32)
                    if fel==1i64 { econst(255i64)  eb(0x25u32) }                        /* mask to field width (hardcoded -- a runtime `1<<(8*fel)` mis-shifted) */
                    if fel==2i64 { econst(65535i64)  eb(0x25u32) }
                    if fel==4i64 { econst(4294967295i64)  eb(0x25u32) }
                    if foff>0i64 { econst(8i64*foff)  eb(0x28u32) }                    /* shift to byte offset (SHL) */
                    eb(0x26u32) }                                                       /* OR into acc */
                else { ebin(0u32)  eb(0x72u32) }                                        /* extra initializer -> DROP */
                bi=bi+1u32  if cp(Q_COM)==1u32 { C=C+1u32 } else { go=0u32 } } }
            eat(Q_RB)  return                                                           /* packed struct-value on the stack */
        } else { CLOVF=1u32  C=C+3u32  eat(Q_LB)  let mut gbd:i32=1i32  while gbd>0i32 { if cp(Q_LB)==1u32 {gbd=gbd+1i32} else { if cp(Q_RB)==1u32 {gbd=gbd-1i32} }  if TK[C as u64]==0u32 {gbd=0i32}  C=C+1u32 }  econst(0i64)  return }   /* >8B compound literal in a NON-direct context (ternary/arg): UNSUPPORTED -> LOUD hard-stop (CLOVF -> fatal at module emit; never a silent-wrong binary). Direct-init `T x=(T){..}` is handled correctly in the local-init. */
        } } } }
        if ispat(C+1u32,Q_MUL)==1u32 { if TK[(C+2u32) as u64]==1u32 { if ispat(C+3u32,Q_RP)==1u32 { if ispat(C+4u32,Q_LBR)==1u32 {   /* (*pp)[i] rvalue : deref the inner pointer, index by base-elem stride, load */
            let idn:u32=C+2u32  let li:i32=lidx(idn)  if li>=0i32 { let st:i64=LPP[li as u64]  let sg:u32=LPSG[li as u64]  emit_lget(li as u32)  eb(0x82u32)  C=C+5u32  ebin(0u32)  eat(Q_RBR)  estride(st)  eb(0x20u32)  eload(st,sg)  return } } } } }
        if ispat(C+1u32,Q_MUL)==1u32 { if TK[(C+2u32) as u64]==1u32 { if ispat(C+3u32,Q_RP)==1u32 { let mut isd:u32=2u32  if ispat(C+4u32,Q_INC)==1u32 {isd=0u32} else { if ispat(C+4u32,Q_DEC)==1u32 {isd=1u32} }  if isd<2u32 { let idn:u32=C+2u32  let li:i32=lidx(idn)  if li>=0i32 { let st:i64=LPSZ[li as u64]  let sg:u32=LPSG[li as u64]  let t:u32=LN  if LN<255u32 {LN=LN+1u32}  emit_lget(li as u32)  eload(st,sg)  eu8(0x11u32,t)  emit_lget(li as u32)  eu8(0x10u32,t)  econst(1i64)  if isd==1u32 {eb(0x21u32)} else {eb(0x20u32)}  estore(st)  eu8(0x10u32,t)  C=C+5u32  return } } } } }   /* (*p)++ / (*p)-- : post-incr/decr the pointee (leave OLD value) -- the seed `slot = (*count_p)++` */
        if is_type_start(C+1u32)==1u32 { C=C+1u32  let mut cm:i64=cast_mask()
