fn find_rb(after_brace:u32) -> u32 { let mut q:u32=after_brace  let mut g:u32=1u32  while g==1u32 { if ispat(q,Q_RB)==1u32 {g=0u32} else { if TK[q as u64]==0u32 {g=0u32} else {q=q+1u32} } }  return q }
fn find_struct_body(tag:u32) -> u32 {   /* scan for `struct <name(tag)> {` -> the token after `{` (the body) ; 0 if none -- resolves `typedef struct TAG Name;` where TAG's body lives elsewhere (opaque type) */
