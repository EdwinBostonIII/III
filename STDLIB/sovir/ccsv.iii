fn prescan_struct() {
    STN=0u32  SFN=0u32
    let mut t:u32=0u32                                              /* pass 1: register struct/union/typedef types */
    while t<NT {
        if kw(t,"struct" as u64,6u32)==1u32 { if TK[(t+1u32) as u64]==1u32 { if ispat(t+2u32,Q_LB)==1u32 { reg_type(t+1u32, t+3u32, 0u32) } } }
        if kw(t,"union" as u64,5u32)==1u32 { if TK[(t+1u32) as u64]==1u32 { if ispat(t+2u32,Q_LB)==1u32 { reg_type(t+1u32, t+3u32, 1u32) } } }
        if kw(t,"typedef" as u64,7u32)==1u32 {
            if kw(t+1u32,"struct" as u64,6u32)==1u32 {
                if ispat(t+2u32,Q_LB)==1u32 { let rb:u32=match_rb(t+3u32)  reg_type(rb+1u32, t+3u32, 0u32) }                                                /* typedef struct { } Name */
                else { if TK[(t+2u32) as u64]==1u32 { if ispat(t+3u32,Q_LB)==1u32 { let rb:u32=match_rb(t+4u32)  reg_type(rb+1u32, t+4u32, 0u32) }     /* typedef struct TAG { } Name */
                       else { if TK[(t+3u32) as u64]==1u32 { let bp:u32=find_struct_body(t+2u32)  if bp>0u32 { reg_type(t+3u32, bp, 0u32) } } } } }       /* typedef struct TAG Name ; (opaque: TAG's body is elsewhere) */
            }
            if kw(t+1u32,"union" as u64,5u32)==1u32 {
                if ispat(t+2u32,Q_LB)==1u32 { let rb:u32=match_rb(t+3u32)  reg_type(rb+1u32, t+3u32, 1u32) }
                else { if TK[(t+2u32) as u64]==1u32 { if ispat(t+3u32,Q_LB)==1u32 { let rb:u32=match_rb(t+4u32)  reg_type(rb+1u32, t+4u32, 1u32) } } }   /* typedef union TAG { } Name */
            }
        }
        t=t+1u32
    }
    let mut fxi:u32=0u32                                            /* BUG-B fixpoint: re-fill ALL struct fields so forward-referenced embedded-struct SIZES converge (pass-1 sized a struct embedding a later-registered struct as int(4); each refill propagates one more nesting level -- 4 covers the seed's depth) */
    while fxi < 4u32 { SFN=0u32  let mut sfi:u32=0u32  while sfi<STN { reg_fields(sfi)  sfi=sfi+1u32 }  fxi=fxi+1u32 }
    t=0u32                                                         /* pass 2: var decls -> mem region + type */
    while t<NT {
        if kw(t,"struct" as u64,6u32)==1u32 { if TK[(t+1u32) as u64]==1u32 { if TK[(t+2u32) as u64]==1u32 { if ispat(t+3u32,Q_LBR)==0u32 { reg_var(t+2u32, stidx(t+1u32)) } } } }   /* not `[` -> struct ARRAY, owned by prescan_structarr */
        if kw(t,"union" as u64,5u32)==1u32 { if TK[(t+1u32) as u64]==1u32 { if TK[(t+2u32) as u64]==1u32 { if ispat(t+3u32,Q_LBR)==0u32 { reg_var(t+2u32, stidx(t+1u32)) } } } }
        if TK[t as u64]==1u32 { if TK[(t+1u32) as u64]==1u32 {     /* TypedefName v ; (IDENT IDENT, first a registered type, not after struct/union/typedef) */
            let sti:i32=stidx(t)
            if sti>=0i32 { let mut pk:u32=0u32  if t>0u32 { pk=istk(t-1u32) }  if pk==0u32 { if ispat(t+2u32,Q_LBR)==0u32 { reg_var(t+1u32, sti) } } }   /* not `[` -> struct ARRAY (prescan_structarr) */
        } }
