/* logical && : LHS truthiness already on the stack ; fold `&& rhs` LEFT-assoc with SHORT-CIRCUIT (rhs only
 * evaluated when LHS is true).  rhs is a bitwise-or expression (ebin(2)) -- && binds looser than every binop. */
fn eland_tail() {
    while cp(Q_LAND)==1u32 {
        C=C+1u32  let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}
        eb(0x42u32)                                     /* IF (pops LHS ; nonzero = true) */
        ebin(2u32)  econst(0i64)  eb(0x31u32)  eu8(0x11u32,tmp)   /* tmp = (rhs != 0) -> 0/1 */
        eb(0x43u32)  econst(0i64)  eu8(0x11u32,tmp)     /* ELSE tmp = 0 (short-circuit) */
        eb(0x44u32)  eu8(0x10u32,tmp)                   /* END ; result on stack (new LHS for chaining) */
    }
}
