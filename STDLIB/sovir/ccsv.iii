}
fn prescan_structval() {   /* Boss-2: does the body declare a struct-VALUE local `TypedefName v [;|=]` ? (stidx>=0, v an ident, NOT *).
 * Mirrors the pstmt struct-value-local detection; scans [C..fn-end] brace-depth-gated.  Sets HAS_STRUCTVAL so
 * the prologue allocates a recursion-safe frame for it (like &-taken scalars). */
    HAS_STRUCTVAL=0u32  STRUCTVAL_BYTES=0i64  let mut sc:u32=C  let mut d:i32=0i32  let mut g:u32=1u32
    while g==1u32 {
        if TK[sc as u64]==0u32 {g=0u32} else {
            if ispat(sc,Q_LB)==1u32 {d=d+1i32}
            if ispat(sc,Q_RB)==1u32 { d=d-1i32  if d==0i32 {g=0u32} }
            if TK[sc as u64]==1u32 { if TK[(sc+1u32) as u64]==1u32 { let sci:i32=stidx(sc)  if sci>=0i32 {            /* TypedefName name */
                let mut isv:u32=0u32  if ispat(sc+2u32,Q_SEMI)==1u32 {isv=1u32}  if ispat(sc+2u32,Q_ASN)==1u32 {isv=1u32}   /* `Foo v;` / `Foo v = e;` */
                if isv==1u32 { HAS_STRUCTVAL=1u32  STRUCTVAL_BYTES=STRUCTVAL_BYTES+(STSZ[sci as u64] as i64) }   /* this struct-value local needs STSZ frame bytes */
            } } }
            sc=sc+1u32
