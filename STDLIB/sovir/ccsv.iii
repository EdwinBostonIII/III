            else { if pp_kw(dk,"define" as u64,6u64)==1u32 { if pa==1u32 { let no:u64=pp_skipws(dk+6u64,le)  let nl:u64=pp_namelen(no)  ppdef_add(no,nl)  copy=1u32 } }   /* keep the #define line for lex (numeric -> named const) */
