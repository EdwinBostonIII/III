        eu8(0x10u32,CUR_FB as u32)  econst(0i64)  eb(0x30u32)  econst(SHADOW_TOP)  eb(0x22u32)  eu8(0x10u32,CUR_FB as u32)  eb(0x20u32)  eu8(0x11u32,CUR_FB as u32)   /* fb = (fb==0)*SHADOW_TOP + fb (lazy init) */
        eu8(0x10u32,CUR_FB as u32)  econst(CUR_FRAME_SZ)  eb(0x21u32)  eu8(0x11u32,CUR_FB as u32)                                                                    /* fb = fb - FRAME_SZ */
        econst(SSP_CELL)  eu8(0x10u32,CUR_FB as u32)  eb(0x83u32)                                                                                                /* *(SSP_CELL) = fb */
    }
