    let mut gb:u32=1u32  let mut last_ret:u32=0u32  while gb==1u32 { if cp(Q_RB)==1u32 {gb=0u32} else { if TK[C as u64]==0u32 {gb=0u32} else { let isr:u32=kw(C,"return" as u64,6u32)  pstmt()  last_ret=isr } } }   /* the body (label `L:` closes its block; goto -> BR to it) */
    eat(Q_RB)
