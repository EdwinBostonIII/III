        if kw(C,"struct" as u64,6u32)==1u32 { C=C+1u32  styp=stidx(C)  C=C+1u32 }
        else { if kw(C,"union" as u64,5u32)==1u32 { C=C+1u32  styp=stidx(C)  C=C+1u32 }
               else { if dtype(C)==1u32 { if byc(C)==1u32 {isc=1u32}  bsz=type_size(C)  bsg=type_signed(C)  C=C+1u32 }
                      else { if TK[C as u64]==1u32 { let si:i32=stidx(C)  let nx:u32=C+1u32  let mut isty:u32=0u32  if ispat(nx,Q_MUL)==1u32 {isty=1u32}  if TK[nx as u64]==1u32 {isty=1u32}
                                 if si>=0i32 { if isty==1u32 { styp=si  C=C+1u32 } } else { if isty==1u32 { C=C+1u32 } } } } } }   /* unknown typedef name (enum / forward typedef) used as a TYPE (followed by * or NAME) -> consume it as a scalar param-type, not a phantom param */
        let mut isp:u32=0u32  let mut gp:u32=1u32  while gp==1u32 { if cp(Q_MUL)==1u32 { C=C+1u32  isp=1u32 } else {gp=0u32} }
        let pt2:u32=C  C=C+1u32  let sl:u32=ladd(pt2)
        if cp(Q_LBR)==1u32 { isp=1u32  let mut ga:u32=1u32  while ga==1u32 { if cp(Q_RBR)==1u32 {ga=0u32} else { if TK[C as u64]==0u32 {ga=0u32} else {C=C+1u32} } }  eat(Q_RBR) }   /* array param `T name[N]` -> pointer decay */
        if isc==1u32 { if isp==1u32 { LCH[sl as u64]=1u32 } }
        if styp>=0i32 { if isp==1u32 { LPT[sl as u64]=styp } }
        if isp==1u32 { if styp<0i32 { LPSZ[sl as u64]=bsz  LPSG[sl as u64]=bsg } }   /* scalar/array pointer param: pointee width+sign */
        if isp==0u32 { LW[sl as u64]=pm  LSZ[sl as u64]=bsz  LSG[sl as u64]=bsg }    /* scalar param: size + sign (spill) */
        if styp>=0i32 { if isp==0u32 { let ssz:u64=STSZ[styp as u64]  if ssz>0u64 { if ssz<=8u64 { LVT[sl as u64]=styp  LVB[sl as u64]=MTOP as i64  MTOP=MTOP+8u64 } else { if SRET_ON==1u32 { LVT[sl as u64]=styp  LVB[sl as u64]=MTOP as i64  MTOP=MTOP+STSZ[styp as u64] } } } } }   /* struct-VALUE param: <=8B -> packed slot ; >8B (SRET_ON) -> COPY-IN value local (LVB); the slot still holds the passed &arg, entry-copies STSZ bytes *(slot)->LVB -> true value-semantics (mutating + same-arg correct, vs the old read-only alias) */
        params=params+1u32  eat(Q_COM) }
