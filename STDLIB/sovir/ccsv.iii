    if HAS_SPILL==1u32 {                                            /* shadow-stack PROLOGUE: fb_local = (lazily SHADOW_TOP) *(SSP_CELL) - FRAME_SZ ; *(SSP_CELL)=fb_local (stack-neutral) */
        CUR_FB=LN as i32  if LN<255u32 {LN=LN+1u32}  if LN>NLOC {NLOC=LN}   /* RESERVE the frame-base slot as PERSISTENT (>NLOC): else the per-statement `LN=NLOC` reset reuses CUR_FB's slot for the 1st body local -> that local's value overwrites the frame base -> &-taken spills land at (localval+off) in the data section (Boss-1: mypad's `bits=24` clobbered the frame base; pad/zero hit CL_K@32/40). Pinned by the reference SVIR interpreter (svir_interp.iii) const-data-corruption watch. */
