/* ccsv.iii -- the FOUNDATION of the non-gcc C compiler: compiles the C integer core -> SVIR, thence to a
 * SOVEREIGN x86 PE (svir_x86 -> sovas -> sovld) with NO gcc in the artifact path.  This is the seed-DDC's
 * missing input begun: an independent C front-end whose backend is III's own sovereign toolchain, not gcc.
 *
 * Subset (C's integer core, == SVIR's): int NAME(int p, ...) { ... } ; int x = e ; x = e ; if (e) {} else {} ;
 *   while (e) {} ; return e ; calls ; + - * / % & | ^ << >> == != < > <= >= , parens, int literals, locals.
 *   All ints are i64.  Reads argv[1] (a .c file); emits a .iii module wrapping SVIR v1 bytes (DOCS/SVIR-V1-
 *   CANONICAL.md), consumed by svir_x86/svir_wasm.  main() is SVIR func 0.
 * HONEST SCOPE: this compiles the integer core; the 26k-line iiis-0 seed uses full C (structs, pointers,
 * preprocessor, ...) -- the long road this foundation begins.  Demonstrates: a C program -> sovereign x86 (no
 * gcc) AND a mini-DDC (ccsv build vs gcc build agree on behaviour). */
module ccsv

extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fread(buf: u64, size: u64, n: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(stream: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

var SRC : [u8; 1048576]
var SLEN : u64 = 0u64
var MODE_RB : [u8; 3] = [114u8, 98u8, 0u8]
var RAW : [u8; 1048576]  var RLEN : u64 = 0u64        /* the main file, pre-flatten (1 MB: seed core files reach 190 KB) */
var IBUFS : [u8; 1048576]                            /* 8 include levels x 131072 (depth-indexed; recursion-safe) */
var IPATH : [u8; 512]  var DIRLEN : u64 = 0u64  var IPLEN : u64 = 0u64   /* resolved include path = main's dir + "filename" */
var PATHBUF : [u8; 8192]  var POFF : [u64; 256]  var PLEN : [u64; 256]  var PN : u32 = 0u32  var PBE : u64 = 0u64   /* include-once set */
var TK : [u32; 262144]  var TV : [i64; 262144]  var TO : [u32; 262144]  var TL : [u32; 262144]  var NT : u32 = 0u32  var C : u32 = 0u32

const Q_LP:i64=1i64 const Q_RP:i64=2i64 const Q_LB:i64=3i64 const Q_RB:i64=4i64 const Q_SEMI:i64=7i64 const Q_ASN:i64=8i64
const Q_EQ:i64=10i64 const Q_NE:i64=11i64 const Q_LT:i64=12i64 const Q_GT:i64=13i64 const Q_LE:i64=14i64 const Q_GE:i64=15i64
const Q_ADD:i64=16i64 const Q_SUB:i64=17i64 const Q_MUL:i64=18i64 const Q_DIV:i64=19i64 const Q_MOD:i64=20i64
const Q_AND:i64=21i64 const Q_OR:i64=22i64 const Q_XOR:i64=23i64 const Q_SHL:i64=24i64 const Q_SHR:i64=25i64 const Q_COM:i64=6i64
const Q_LBR:i64=26i64 const Q_RBR:i64=27i64 const Q_DOT:i64=28i64 const Q_ARROW:i64=29i64 const Q_INC:i64=30i64 const Q_DEC:i64=31i64 const Q_NOT:i64=32i64 const Q_QUEST:i64=33i64 const Q_COLON:i64=34i64
const Q_LAND:i64=35i64 const Q_LOR:i64=36i64 const Q_LNOT:i64=37i64   /* logical && / || / ! (distinct from bitwise Q_AND/Q_OR/Q_NOT) */
const HEAP_BASE:i64=1048576i64   /* bump-heap base in svir_mem (4 MiB); static data below, heap above; cell@HEAP_BASE = the bump ptr (lazily init) */

fn sp(c: u32) -> u32 { if c==32u32 {return 1u32} if c==9u32 {return 1u32} if c==10u32 {return 1u32} if c==13u32 {return 1u32} return 0u32 }
fn dg(c: u32) -> u32 { if c>=48u32 { if c<=57u32 {return 1u32} } return 0u32 }
fn hx(c: u32) -> u32 { if c>=48u32 { if c<=57u32 {return 1u32} }  if c>=97u32 { if c<=102u32 {return 1u32} }  if c>=65u32 { if c<=70u32 {return 1u32} }  return 0u32 }
fn hv(c: u32) -> i64 { if c<=57u32 {return (c-48u32) as i64}  if c>=97u32 {return ((c-97u32)+10u32) as i64}  return ((c-65u32)+10u32) as i64 }
fn idc(c: u32) -> u32 { if c==95u32 {return 1u32} if c>=48u32 { if c<=57u32 {return 1u32} } if c>=65u32 { if c<=90u32 {return 1u32} } if c>=97u32 { if c<=122u32 {return 1u32} } return 0u32 }
fn ids(c: u32) -> u32 { if c==95u32 {return 1u32} if c>=65u32 { if c<=90u32 {return 1u32} } if c>=97u32 { if c<=122u32 {return 1u32} } return 0u32 }
fn sb(i: u64) -> u32 { let p : *u8 = ((&SRC as u64) + i) as *u8  return p[0u64] as u32 }
fn pt(k: u32, v: i64, o: u32, l: u32) { if NT < 262143u32 { TK[NT as u64]=k  TV[NT as u64]=v  TO[NT as u64]=o  TL[NT as u64]=l  NT=NT+1u32 } }   /* token cap = the TK[262144] array (was 8192 -> silently truncated the seed core's tens of thousands of tokens) */

fn lex() {
    NT = 0u32
    let mut i : u64 = 0u64
    while i < SLEN {
        let c : u32 = sb(i)  let c2 : u32 = sb(i+1u64)  let mut done : u32 = 0u32
        if sp(c)==1u32 { i=i+1u64  done=1u32 }
        if done==0u32 { if c==35u32 {   /* #define NAME <number> -> a named constant ; other # directives -> skip the line */
            i=i+1u64
            let mut g0:u32=1u32  while g0==1u32 { if i>=SLEN {g0=0u32} else { let w0:u32=sb(i)  if w0==32u32 {i=i+1u64} else { if w0==9u32 {i=i+1u64} else {g0=0u32} } } }
            let dwo:u64=i  let mut g1:u32=1u32  while g1==1u32 { if i>=SLEN {g1=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g1=0u32} } }
            let dwl:u64=i-dwo  let mut isdef:u32=0u32
            if dwl==6u64 { if sb(dwo)==100u32 { if sb(dwo+1u64)==101u32 { if sb(dwo+2u64)==102u32 { if sb(dwo+3u64)==105u32 { if sb(dwo+4u64)==110u32 { if sb(dwo+5u64)==101u32 { isdef=1u32 } } } } } } }
            if isdef==1u32 {
                let mut g2:u32=1u32  while g2==1u32 { if i>=SLEN {g2=0u32} else { let w2:u32=sb(i)  if w2==32u32 {i=i+1u64} else { if w2==9u32 {i=i+1u64} else {g2=0u32} } } }
                let no:u64=i  let mut g3:u32=1u32  while g3==1u32 { if i>=SLEN {g3=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g3=0u32} } }
                let nl:u64=i-no
                let mut g4:u32=1u32  while g4==1u32 { if i>=SLEN {g4=0u32} else { let w4:u32=sb(i)  if w4==32u32 {i=i+1u64} else { if w4==9u32 {i=i+1u64} else { if w4==92u32 { i=i+1u64  if i<SLEN { if sb(i)==13u32 {i=i+1u64} }  if i<SLEN { if sb(i)==10u32 {i=i+1u64} } } else {g4=0u32} } } } }   /* `\`-newline continuation -> the value (e.g. a multi-line array-count macro) is on the next line */
                let mut sp2:u32=1u32  while sp2==1u32 { if i>=SLEN {sp2=0u32} else { let pc:u32=sb(i)   /* skip leading `(` + `(cast)` prefixes: ((size_t)4096), (64), 0x.. , 4096 */
                    if pc==40u32 {i=i+1u64} else { if pc==32u32 {i=i+1u64} else { if pc==9u32 {i=i+1u64}
                    else { let isal:u32=idc(pc)  let isdg:u32=dg(pc)
                        if isal==1u32 { if isdg==0u32 {   /* identifier (cast type) -> skip it + spaces + a closing ) ; if no ) it's a macro alias -> give up */
                            let st:u64=i  let mut gi:u32=1u32  while gi==1u32 { if i>=SLEN {gi=0u32} else { let ic:u32=sb(i)  if idc(ic)==1u32 {i=i+1u64} else { if ic==32u32 {i=i+1u64} else {gi=0u32} } } }
                            if i<SLEN { if sb(i)==41u32 { i=i+1u64 } else { i=st  sp2=0u32 } } else { i=st  sp2=0u32 }
                        } else { sp2=0u32 } } else { sp2=0u32 } } } } }
                }
                if i<SLEN { let mut issz:u32=0u32                                  /* `#define N (sizeof(ARR)/sizeof(ARR[0]))` -> defer N -> ALEN(ARR) */
                    if (i+6u64)<=SLEN { if sb(i)==115u32 { if sb(i+1u64)==105u32 { if sb(i+2u64)==122u32 { if sb(i+3u64)==101u32 { if sb(i+4u64)==111u32 { if sb(i+5u64)==102u32 { issz=1u32 } } } } } } }
                    if issz==1u32 {
                        let mut j:u64=i+6u64  let mut gs:u32=1u32  while gs==1u32 { if j>=SLEN {gs=0u32} else { let sc:u32=sb(j)  if sc==32u32 {j=j+1u64} else { if sc==9u32 {j=j+1u64} else {gs=0u32} } } }
                        if j<SLEN { if sb(j)==40u32 { j=j+1u64  let mut gs2:u32=1u32  while gs2==1u32 { if j>=SLEN {gs2=0u32} else { let s2:u32=sb(j)  if s2==32u32 {j=j+1u64} else { if s2==9u32 {j=j+1u64} else {gs2=0u32} } } }
                            let ao:u64=j  let mut gi:u32=1u32  while gi==1u32 { if j>=SLEN {gi=0u32} else { if idc(sb(j))==1u32 {j=j+1u64} else {gi=0u32} } }  let al:u64=j-ao
                            if al>0u64 { if DCM_N<128u32 { DCM_MO[DCM_N as u64]=no as u32  DCM_ML[DCM_N as u64]=nl as u32  DCM_AO[DCM_N as u64]=ao as u32  DCM_AL[DCM_N as u64]=al as u32  DCM_N=DCM_N+1u32 } }
                        } }
                    }
                }
                if i<SLEN {
                    let c0:u32=sb(i)  let mut doev:u32=0u32
                    if dg(c0)==1u32 {doev=1u32}  if c0==40u32 {doev=1u32}  if c0==45u32 {doev=1u32}  if c0==126u32 {doev=1u32}   /* number / ( / - / ~ -> a constant EXPRESSION (e.g. (64u*1024u)) */
                    if idc(c0)==1u32 { if dg(c0)==0u32 { let oo:u64=i  let mut ee:u64=i  let mut ge:u32=1u32  while ge==1u32 { if ee>=SLEN {ge=0u32} else { if idc(sb(ee))==1u32 {ee=ee+1u64} else {ge=0u32} } }  let mut kk:u32=0u32  while kk<CN { if neq(CNO[kk as u64],CNL[kk as u64],oo as u32,(ee-oo) as u32)==1u32 {doev=1u32}  kk=kk+1u32 } } }   /* identifier value -> evaluate ONLY if a known constant (else a CODE macro like `static inline` -> skip, never a 0 alias) */
                    if doev==1u32 { PPC=i  let vv:i64=ppc_expr(0u32)  cadd(no as u32, nl as u32, vv)  i=PPC }
                }
            }
            let mut g6:u32=1u32  while g6==1u32 { if i>=SLEN {g6=0u32} else { if sb(i)==92u32 { i=i+1u64  if i<SLEN { if sb(i)==13u32 {i=i+1u64} }  if i<SLEN { if sb(i)==10u32 {i=i+1u64} } } else { if sb(i)==10u32 {g6=0u32} else {i=i+1u64} } } }   /* `\`-newline continues the #define; a bare newline ends it (so the continuation line is NOT lexed as code) */
            done=1u32
        } }
        if done==0u32 { if c==39u32 {   /* 'x' char literal -> a NUM token with the ASCII value (incl \n \t \0 \r \\ \') */
            let mut v:i64=0i64  let mut j:u64=i+1u64
            if sb(j)==92u32 { let e:u32=sb(j+1u64)
                if e==110u32 {v=10i64} else { if e==116u32 {v=9i64} else { if e==48u32 {v=0i64} else { if e==114u32 {v=13i64} else { if e==97u32 {v=7i64} else { if e==98u32 {v=8i64} else { if e==102u32 {v=12i64} else { if e==118u32 {v=11i64} else { v=e as i64 } } } } } } } }   /* \n \t \0 \r \a \b \f \v ; else the raw char (\\ \' \") */
                j=j+2u64
            } else { v=sb(j) as i64  j=j+1u64 }
            if sb(j)==39u32 { j=j+1u64 }
            pt(2u32,v,0u32,0u32)  i=j  done=1u32
        } }
        if done==0u32 { if c==34u32 {   /* "..." string literal -> a STRING token (kind 4) over the raw span between quotes */
            let o:u64=i+1u64  let mut j:u64=o  let mut g:u32=1u32
            while g==1u32 { if j>=SLEN {g=0u32} else { let cc:u32=sb(j)  if cc==34u32 {g=0u32} else { if cc==92u32 {j=j+2u64} else {j=j+1u64} } } }
            pt(4u32, 0i64, o as u32, (j-o) as u32)  i=j+1u64  done=1u32
        } }
        if done==0u32 { if c==47u32 { if c2==47u32 { i=i+2u64  let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if sb(i)==10u32 {g=0u32} else {i=i+1u64} } }  done=1u32 }
                                      else { if c2==42u32 { i=i+2u64  let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if sb(i)==42u32 { if sb(i+1u64)==47u32 {i=i+2u64 g=0u32} else {i=i+1u64} } else {i=i+1u64} } }  done=1u32 } } } }
        if done==0u32 { if ids(c)==1u32 { let o:u64=i  let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g=0u32} } }  pt(1u32,0i64,o as u32,(i-o) as u32)  done=1u32 } }
        if done==0u32 { if dg(c)==1u32 {
            let mut v:i64=0i64  let mut ishex:u32=0u32  let mut isoct:u32=0u32
            if c==48u32 { let cn:u32=sb(i+1u64)  if cn==120u32 {ishex=1u32} else { if cn==88u32 {ishex=1u32} else { if cn>=48u32 { if cn<=55u32 {isoct=1u32} } } } }   /* 0x/0X = hex ; 0NNN = octal ; else decimal/bare 0 */
            if ishex==1u32 { i=i+2u64  let mut gh:u32=1u32  while gh==1u32 { if i>=SLEN {gh=0u32} else { let hc:u32=sb(i)  if hx(hc)==1u32 { v=(v*16i64)+hv(hc)  i=i+1u64 } else {gh=0u32} } } }
            else { if isoct==1u32 { i=i+1u64  let mut go:u32=1u32  while go==1u32 { if i>=SLEN {go=0u32} else { let oc:u32=sb(i)  if oc>=48u32 { if oc<=55u32 { v=(v*8i64)+((oc-48u32) as i64)  i=i+1u64 } else {go=0u32} } else {go=0u32} } } }   /* octal: digits 0-7 */
                   else { let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if dg(sb(i))==1u32 { v=(v*10i64)+((sb(i)-48u32) as i64)  i=i+1u64 } else {g=0u32} } } } }
            let mut g2:u32=1u32  while g2==1u32 { if i>=SLEN {g2=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g2=0u32} } }   /* skip u/l/U/L suffix */
            pt(2u32,v,0u32,0u32)  done=1u32
        } }
        if done==0u32 {
            let mut adv : u32 = 0u32
            if c==61u32 { if c2==61u32 { pt(3u32,Q_EQ,0u32,0u32) adv=2u32 } else { pt(3u32,Q_ASN,0u32,0u32) adv=1u32 } }
            if c==33u32 { if c2==61u32 { pt(3u32,Q_NE,0u32,0u32) adv=2u32 } else { pt(3u32,Q_LNOT,0u32,0u32) adv=1u32 } }   /* != or ! (logical NOT) */
            if c==60u32 { if c2==61u32 { pt(3u32,Q_LE,0u32,0u32) adv=2u32 } else { if c2==60u32 { pt(3u32,Q_SHL,0u32,0u32) adv=2u32 } else { pt(3u32,Q_LT,0u32,0u32) adv=1u32 } } }
            if c==62u32 { if c2==61u32 { pt(3u32,Q_GE,0u32,0u32) adv=2u32 } else { if c2==62u32 { pt(3u32,Q_SHR,0u32,0u32) adv=2u32 } else { pt(3u32,Q_GT,0u32,0u32) adv=1u32 } } }
            if c==38u32 { if c2==38u32 { pt(3u32,Q_LAND,0u32,0u32) adv=2u32 } else { pt(3u32,Q_AND,0u32,0u32) adv=1u32 } }   /* && or & */
            if c==124u32 { if c2==124u32 { pt(3u32,Q_LOR,0u32,0u32) adv=2u32 } else { pt(3u32,Q_OR,0u32,0u32) adv=1u32 } }   /* || or | */
            if c==40u32 { pt(3u32,Q_LP,0u32,0u32) adv=1u32 }
            if c==41u32 { pt(3u32,Q_RP,0u32,0u32) adv=1u32 }
            if c==123u32 { pt(3u32,Q_LB,0u32,0u32) adv=1u32 }
            if c==125u32 { pt(3u32,Q_RB,0u32,0u32) adv=1u32 }
            if c==91u32 { pt(3u32,Q_LBR,0u32,0u32) adv=1u32 }
            if c==93u32 { pt(3u32,Q_RBR,0u32,0u32) adv=1u32 }
            if c==46u32 { pt(3u32,Q_DOT,0u32,0u32) adv=1u32 }
            if c==59u32 { pt(3u32,Q_SEMI,0u32,0u32) adv=1u32 }
            if c==44u32 { pt(3u32,Q_COM,0u32,0u32) adv=1u32 }
            if c==43u32 { if c2==43u32 { pt(3u32,Q_INC,0u32,0u32) adv=2u32 } else { pt(3u32,Q_ADD,0u32,0u32) adv=1u32 } }   /* ++ or + */
            if c==45u32 { if c2==62u32 { pt(3u32,Q_ARROW,0u32,0u32) adv=2u32 } else { if c2==45u32 { pt(3u32,Q_DEC,0u32,0u32) adv=2u32 } else { pt(3u32,Q_SUB,0u32,0u32) adv=1u32 } } }   /* -> or -- or - */
            if c==42u32 { pt(3u32,Q_MUL,0u32,0u32) adv=1u32 }
            if c==47u32 { pt(3u32,Q_DIV,0u32,0u32) adv=1u32 }
            if c==37u32 { pt(3u32,Q_MOD,0u32,0u32) adv=1u32 }
            if c==94u32 { pt(3u32,Q_XOR,0u32,0u32) adv=1u32 }
            if c==126u32 { pt(3u32,Q_NOT,0u32,0u32) adv=1u32 }   /* ~ (bitwise NOT) */
            if c==63u32 { pt(3u32,Q_QUEST,0u32,0u32) adv=1u32 }   /* ? (ternary) */
            if c==58u32 { pt(3u32,Q_COLON,0u32,0u32) adv=1u32 }   /* : (ternary) */
            if adv==0u32 { adv=1u32 }
            i = i + (adv as u64)
        }
    }
    pt(0u32,0i64,0u32,0u32)
}

fn neq(o1: u32, l1: u32, o2: u32, l2: u32) -> u32 { if l1!=l2 {return 0u32}  let mut j:u32=0u32  while j<l1 { if sb((o1+j) as u64)!=sb((o2+j) as u64) {return 0u32}  j=j+1u32 }  return 1u32 }
fn kw(t: u32, s: u64, n: u32) -> u32 { if TK[t as u64]!=1u32 {return 0u32}  if TL[t as u64]!=n {return 0u32}  let mut j:u32=0u32  while j<n { let p:*u8=(s+(j as u64)) as *u8  if sb((TO[t as u64]+j) as u64)!=(p[0u64] as u32) {return 0u32}  j=j+1u32 }  return 1u32 }
/* a C scalar base-type keyword (all map to i64 in SVIR): int/char/void + the <stdint.h> fixed-width typedefs. */
fn dtype(t: u32) -> u32 {
    if kw(t,"int" as u64,3u32)==1u32 {return 1u32}  if kw(t,"char" as u64,4u32)==1u32 {return 1u32}  if kw(t,"void" as u64,4u32)==1u32 {return 1u32}
    if kw(t,"uint32_t" as u64,8u32)==1u32 {return 1u32}  if kw(t,"uint64_t" as u64,8u32)==1u32 {return 1u32}  if kw(t,"uint16_t" as u64,8u32)==1u32 {return 1u32}  if kw(t,"uint8_t" as u64,7u32)==1u32 {return 1u32}
    if kw(t,"int32_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int64_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int16_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int8_t" as u64,6u32)==1u32 {return 1u32}
    if kw(t,"size_t" as u64,6u32)==1u32 {return 1u32}  if kw(t,"ssize_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"bool" as u64,4u32)==1u32 {return 1u32}  if kw(t,"uintptr_t" as u64,9u32)==1u32 {return 1u32}  if kw(t,"intptr_t" as u64,8u32)==1u32 {return 1u32}
    if kw(t,"va_list" as u64,7u32)==1u32 {return 1u32}   /* va_list -> an 8-byte cursor local (the varargs walker) */
    return 0u32
}
/* a C type qualifier / storage class (no-op for ccsv's i64-everything model). */
fn isqual(t: u32) -> u32 {
    if kw(t,"static" as u64,6u32)==1u32 {return 1u32}  if kw(t,"const" as u64,5u32)==1u32 {return 1u32}  if kw(t,"unsigned" as u64,8u32)==1u32 {return 1u32}  if kw(t,"signed" as u64,6u32)==1u32 {return 1u32}
    if kw(t,"long" as u64,4u32)==1u32 {return 1u32}  if kw(t,"short" as u64,5u32)==1u32 {return 1u32}  if kw(t,"volatile" as u64,8u32)==1u32 {return 1u32}  if kw(t,"register" as u64,8u32)==1u32 {return 1u32}  if kw(t,"inline" as u64,6u32)==1u32 {return 1u32}
    return 0u32
}
fn skipquals() { let mut g:u32=1u32  while g==1u32 { if isqual(C)==1u32 { C=C+1u32 } else {g=0u32} } }
fn cp(p: i64) -> u32 { if TK[C as u64]==3u32 { if TV[C as u64]==p {return 1u32} }  return 0u32 }
fn eat(p: i64) -> u32 { if cp(p)==1u32 { C=C+1u32  return 1u32 }  return 0u32 }
fn ispat(t: u32, p: i64) -> u32 { if TK[t as u64]==3u32 { if TV[t as u64]==p {return 1u32} }  return 0u32 }

var FNO : [u32; 4096]  var FNL : [u32; 4096]  var FNP : [u32; 4096]  var FNT : [u32; 4096]  var FRM : [i64; 4096]  var FN : u32 = 0u32  var CUR_RMASK : i64 = 0i64  var ENDED_RET : u32 = 0u32  var CUR_SRET : i32 = 0i32-1i32  var CUR_SRETSZ : i64 = 0i64   /* FRM=per-fn return width-mask ; ENDED_RET=last stmt was a return ; CUR_SRET=sret hidden-ptr slot (0) when this fn returns a struct VALUE, else -1 ; CUR_SRETSZ=that struct's byte size */
var FVAR : [u32; 4096]  var CUR_VAPTR : i32 = 0i32-1i32   /* FVAR[f]=variadic(has ...) ; FNP[f]=NAMED count ; CUR_VAPTR=this fn's hidden va-ptr local slot (-1 if not variadic) */
const VA_BUF:i64=983040i64   /* svir_mem va-arg buffer (64KiB below HEAP_BASE): a variadic call writes its varargs here; the callee's va-ptr points at it */
const FMT_SCRATCH:i64=982784i64   /* 256B digit-reversal scratch for vsnprintf number conversion (just below VA_BUF) */
const SSP_CELL:i64=982776i64   /* shadow-stack-pointer cell: a RESERVED 8 bytes just below FMT_SCRATCH(982784), above the shadow region(<=917504) -- NOT addr 8 (that collides with the program's LOW global data: the SSP write corrupted a global -> SHA buffer garbage). Holds the CURRENT frame base between nested calls. */
const SHADOW_TOP:i64=917504i64   /* shadow stack grows DOWN from here -- BELOW FMT_SCRATCH(982784)/VA_BUF(983040)/HEAP_BASE(1MB) so it never collides with the bump heap (the prior SHADOW_TOP=4MB collided with the heap the ceiling SHA hammers -> x86 segfault) */
const FRAME_SZ:i64=512i64   /* MINIMUM per-fn shadow frame size (small fns stay 512 = byte-identical to Boss-1) */
var CUR_FRAME_SZ:i64=512i64    /* Boss-2: the ACTUAL per-fn frame size = max(512, round16(8 + ADN_N*8 + struct-value bytes)). Large struct-value fns (e.g. iiip_parse_extern_decl ~728B) get a frame that fits -> no overflow. */
var STRUCTVAL_BYTES:i64=0i64   /* prescan_structval's running sum of struct-value-local STSZ (frame bytes they need) */
var CUR_FB:i32 = 0i32-1i32   /* the fb_local SVIR slot (-1 = this fn has no spill frame) -- accessed via LOCAL_GET (svir_x86-safe), cell touched only in prologue/epilogue */
var CUR_FRAMEOFF:u64 = 0u64  /* next free byte in the current frame */
var HAS_SPILL:u32 = 0u32
var HAS_STRUCTVAL:u32 = 0u32   /* Boss-2: this fn declares a struct-VALUE local (LVT/LVB) -> needs a recursion-safe frame too */
var SHADOW_ON:u32 = 1u32   /* Boss-1 shadow-stack: NOW THE DEFAULT (ON). The ceiling_sha_full regression that forced OFF is FIXED (the NLOC-reserve in the prologue below: CUR_FB's frame-base slot is now persistent, so a body local no longer clobbers it). Validated @ON: recursive-&local KAT all-4=99 + svir_interp=99 (OFF crashes it); ceiling_sha_full x86+wasm+verifier+gcc all 99 == ba7816bf; run_ccsv green (only pre-existing crosslang); seed floor 56 unchanged; iii_adversarial_verify SURVIVES-high. Boss-2 (struct-VALUE LVB frame-relative, for recursive struct-value) is the REMAINDER. Pinned via STDLIB/sovir/svir_interp.iii (the reference SVIR value-tracer). */
var SRET_ON:u32 = 1u32   /* Boss-2 struct-by-value (sret hidden-pointer) master switch.  COMPLETE + PROVEN all-4=99 (RETURN+RECEIVE+PARAMS incl MUTATING + SAME-ARG + sret-fn-WITH-struct-params): test_structparam (comprehensive) + test_structval + _mut2 + _dup2 + _span.  COPY-IN value-semantics: a >8B struct param is a struct-value local (LVT/LVB) entry-copied from the passed &arg (cfn:1710 + :1729).  The sret+struct-params SLOT COLLISION (1st struct param aliased the sret slot) was a leftover LO/LL name-table false-match in lidx (searches 0..LN; the sret reserve bumps LN past slot 0 with no ladd); FIXED by the per-fn LL reset (cfn:~1690).  ON: seed verify_fail=69 < the SRET_ON=0 floor of 70 -- net progress, construct behaviorally gated by test_structparam. */
fn fidx(t: u32) -> i32 { let mut k:u32=0u32  while k<FN { if neq(FNO[k as u64],FNL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return k as i32}  k=k+1u32 }  return 0i32-1i32 }
var LO : [u32; 256]  var LL : [u32; 256]  var LN : u32 = 0u32  var LCH : [u32; 256]  var LPT : [i32; 256]  var LW : [i64; 256]  var LMEM : [i64; 256]   /* LCH=char* ; LPT=struct-ptr type ; LW=width mask ; LMEM=spill memory addr if &-taken (-1=SVIR slot) */
var LSZ : [i64; 256]  var LSG : [u32; 256]  var LPSZ : [i64; 256]  var LPSG : [u32; 256]  var LPP : [i64; 256]   /* P1 ABI: LSZ=scalar byte size (spill width) ; LSG=scalar signed ; LPSZ=pointee size ; LPSG=pointee signed ; LPP=ULTIMATE element size (base type) for `(*pp)[i]` on a multi-level pointer */
var LVT : [i32; 256]  var LVB : [i64; 256]   /* local struct-VALUE: LVT=struct type (-1=not a struct value) ; LVB=its inline frame base (STSZ bytes reserved) -> `p.field` via abase/avtype */
var LVF : [u32; 256]   /* Boss-2: LVB-is-FRAME flag. 1 = LVB is a shadow-FRAME offset (struct-value LOCAL @SHADOW_ON=1, recursion-safe) -> emit_frame_addr ; 0 = LVB is a fixed MTOP address (OFF, or a struct-value PARAM) -> econst */
var LOVF : u32 = 0u32                                  /* LOUD local-overflow flag: the SVIR LOCAL_GET/SET operand is ONE byte, so >256 locals/fn would silently collide (slot 256&0xFF=0); set this instead, fail the whole compile clearly */
var CLOVF : u32 = 0u32                                 /* LOUD compound-literal-overflow flag: a >8B compound literal in a NON-direct context (ternary branch / call arg) needs a temp+address path not yet built; rather than silently emit a corrupted value, set this and fail the whole compile (the direct-init `T x=(T){..}` IS handled correctly in the local-init) */
var NLOC : u32 = 0u32                                  /* DECLARED-local count (params + body decls + switch selectors). EXPRESSION temps live ABOVE NLOC and are reused per-statement (pstmt resets LN=NLOC) -- bounds LN well under the 256 cap (the header nlocals is hardcoded 1; backends scan the body for the real frame size, so slot REUSE is safe) */
var BLKD : i64 = 0i64                                  /* live structured-control nesting depth (BLOCK/LOOP/IF open count) -- read by `break` */
var BRKT : [i64; 32]  var BRKN : u32 = 0u32            /* break-target stack: BLKD just inside each enclosing loop/switch's exit block ; break -> BR(BLKD - BRKT[top]) */
var CONTT : [i64; 32]  var CONTN : u32 = 0u32          /* continue-target stack: BLKD just inside each loop's continue block (wraps the body; END lands before the incr/cond) ; continue -> BR(BLKD - CONTT[top]) */
var LBLO : [u32; 64]  var LBLL : [u32; 64]  var LBLBD : [i64; 64]  var LBLN : u32 = 0u32   /* per-fn FORWARD-goto labels: name offset/len + the BLKD of each label's goto-block (label[0]=innermost) */
var SWCC : [i64; 128]  var SWCN : u32 = 0u32           /* case constants of the switch being lowered (prescan, in source order) */
var ADN_O : [u32; 128]  var ADN_L : [u32; 128]  var ADN_N : u32 = 0u32   /* per-fn set of local names whose address is taken (-> spilled to memory) */
fn adn_has(o:u32, l:u32) -> u32 { let mut k:u32=0u32  while k<ADN_N { if neq(ADN_O[k as u64],ADN_L[k as u64],o,l)==1u32 {return 1u32}  k=k+1u32 }  return 0u32 }
fn lidx(t: u32) -> i32 { let mut k:u32=0u32  while k<LN { if neq(LO[k as u64],LL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return k as i32}  k=k+1u32 }  return 0i32-1i32 }
/* the width AND-mask for a fixed-width C type token (uintN_t/intN_t -> 2^N-1 ; else 0 = full i64). */
fn type_mask(t:u32) -> i64 {
    if kw(t,"uint32_t" as u64,8u32)==1u32 {return 4294967295i64}  if kw(t,"int32_t" as u64,7u32)==1u32 {return 4294967295i64}
    if kw(t,"uint16_t" as u64,8u32)==1u32 {return 65535i64}  if kw(t,"int16_t" as u64,7u32)==1u32 {return 65535i64}  if kw(t,"short" as u64,5u32)==1u32 {return 65535i64}
    if kw(t,"uint8_t" as u64,7u32)==1u32 {return 255i64}  if kw(t,"int8_t" as u64,6u32)==1u32 {return 255i64}  if kw(t,"char" as u64,4u32)==1u32 {return 255i64}  if kw(t,"bool" as u64,4u32)==1u32 {return 255i64}   /* char/short narrow like their int8_t/int16_t equivalents (a char local held its un-narrowed i64 before) */
    return 0i64
}
/* the REAL C size of a scalar/element type (the P1 ABI: char=1, short=2, int/u32=4, long/u64/ptr-ish=8). */
fn type_size(t:u32) -> i64 {
    if kw(t,"char" as u64,4u32)==1u32 {return 1i64}  if kw(t,"uint8_t" as u64,7u32)==1u32 {return 1i64}  if kw(t,"int8_t" as u64,6u32)==1u32 {return 1i64}
    if kw(t,"bool" as u64,4u32)==1u32 {return 1i64}  if kw(t,"void" as u64,4u32)==1u32 {return 1i64}
    if kw(t,"uint16_t" as u64,8u32)==1u32 {return 2i64}  if kw(t,"int16_t" as u64,7u32)==1u32 {return 2i64}  if kw(t,"short" as u64,5u32)==1u32 {return 2i64}
    if kw(t,"int" as u64,3u32)==1u32 {return 4i64}  if kw(t,"uint32_t" as u64,8u32)==1u32 {return 4i64}  if kw(t,"int32_t" as u64,7u32)==1u32 {return 4i64}
    if kw(t,"uint64_t" as u64,8u32)==1u32 {return 8i64}  if kw(t,"int64_t" as u64,7u32)==1u32 {return 8i64}  if kw(t,"size_t" as u64,6u32)==1u32 {return 8i64}  if kw(t,"ssize_t" as u64,7u32)==1u32 {return 8i64}
    if kw(t,"uintptr_t" as u64,9u32)==1u32 {return 8i64}  if kw(t,"intptr_t" as u64,8u32)==1u32 {return 8i64}  if kw(t,"long" as u64,4u32)==1u32 {return 8i64}
    let si:i32=stidx(t)  if si>=0i32 { return STSZ[si as u64] as i64 }   /* a typedef-struct type -> its computed size (struct value param / struct-array element) */
    return 8i64
}
/* signedness of a scalar/element type (drives LOAD16_S/LOAD32_S vs _U ; size-1 loads stay unsigned LOAD8). */
fn type_signed(t:u32) -> u32 {
    if kw(t,"int" as u64,3u32)==1u32 {return 1u32}  if kw(t,"char" as u64,4u32)==1u32 {return 1u32}
    if kw(t,"int8_t" as u64,6u32)==1u32 {return 1u32}  if kw(t,"int16_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int32_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int64_t" as u64,7u32)==1u32 {return 1u32}
    if kw(t,"short" as u64,5u32)==1u32 {return 1u32}  if kw(t,"long" as u64,4u32)==1u32 {return 1u32}  if kw(t,"intptr_t" as u64,8u32)==1u32 {return 1u32}  if kw(t,"ssize_t" as u64,7u32)==1u32 {return 1u32}
    return 0u32
}
fn emit_lset(slot:u32) { let m:i64=LW[slot as u64]  if m!=0i64 { econst(m)  eb(0x25u32) }   /* [AND width-mask] ; then spilled -> STORE64 to mem (via a temp), else LOCAL_SET */
    let mem:i64=LMEM[slot as u64]
    if mem>=0i64 { let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}  eu8(0x11u32,tmp)  emit_frame_addr(mem)  eu8(0x10u32,tmp)  estore(LSZ[slot as u64]) } else { eu8(0x11u32, slot) }
}
fn emit_frame_addr(off:i64) { if SHADOW_ON==1u32 { eu8(0x10u32, CUR_FB as u32)  if off!=0i64 { econst(off)  eb(0x20u32) } } else { econst(off) } }   /* ON: fb_local + off (runtime frame addr) ; OFF: econst(off) where off=the fixed MTOP addr (the old behavior) */
fn emit_ret() { if HAS_SPILL==1u32 { econst(SSP_CELL)  eu8(0x10u32, CUR_FB as u32)  econst(CUR_FRAME_SZ)  eb(0x20u32)  eb(0x83u32) }  eb(0x60u32) }   /* epilogue: restore *(SSP_CELL)=fb+FRAME_SZ (stack-neutral) before RETURN ; fb is per-call so a missed restore LEAKS, never clobbers */
fn lpt(t: u32) -> i32 { let li:i32=lidx(t)  if li<0i32 {return 0i32-1i32}  return LPT[li as u64] }
fn ladd(t: u32) -> u32 { let ex:i32=lidx(t)  if ex>=0i32 { return ex as u32 }  let s:u32=LN  if LN<256u32 { LO[LN as u64]=TO[t as u64]  LL[LN as u64]=TL[t as u64]  LMEM[LN as u64]=0i64-1i64  if adn_has(TO[t as u64],TL[t as u64])==1u32 { if SHADOW_ON==1u32 { LMEM[LN as u64]=CUR_FRAMEOFF as i64  CUR_FRAMEOFF=CUR_FRAMEOFF+8u64 } else { LMEM[LN as u64]=MTOP as i64  MTOP=MTOP+8u64 } }  LN=LN+1u32  if LN>NLOC {NLOC=LN} } else { LOVF=1u32 }  return s }   /* re-declared name reuses its slot; &-taken names spill to memory (LMEM); >256 -> LOUD overflow */
fn emit_lget(slot:u32) { let mem:i64=LMEM[slot as u64]  if mem>=0i64 { emit_frame_addr(mem)  eload(LSZ[slot as u64], LSG[slot as u64]) } else { eu8(0x10u32, slot) } }   /* spilled local -> typed LOAD from its memory addr ; else LOCAL_GET (byte-identical for non-spilled) */
/* global C arrays: `int NAME[NUM];` -> a cumulative base offset in SVIR linear memory (NAME[i] -> LOAD8/STORE8). */
var AO : [u32; 1024]  var AL : [u32; 1024]  var AB : [u64; 1024]  var AW : [i64; 1024]  var AESZ : [i64; 1024]  var ALEN : [u64; 1024]  var ASGN : [u32; 1024]  var AISC : [u32; 1024]  var AROW : [i64; 1024]  var APSZ : [i64; 1024]  var APSG : [u32; 1024]  var AN : u32 = 0u32  var MTOP : u64 = 0u64   /* APSZ/APSG = POINTEE byte size+sign for a global scalar POINTER (0 = not a scalar pointer) -> enables `*gp` rvalue deref-read at the right width */   /* AW=elem width-mask ; AESZ=elem byte size {1,2,4,8} ; ALEN=element count (for sizeof) ; ASGN=elem signed ; AISC=1 if a global SCALAR (bare read = LOAD value, not array->ptr decay) */
fn aisc(t: u32) -> u32 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AISC[k as u64]}  k=k+1u32 }  return 0u32 }   /* is t a global scalar? */
var DCM_MO:[u32;128]  var DCM_ML:[u32;128]  var DCM_AO:[u32;128]  var DCM_AL:[u32;128]  var DCM_N:u32=0u32   /* deferred array-count macros: `#define N (sizeof(ARR)/sizeof(ARR[0]))` -> resolve N to ALEN(ARR) at the USE site (ARR registered by then) */
fn alen_by_name(o:u32, l:u32) -> i64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],o,l)==1u32 {return ALEN[k as u64] as i64}  k=k+1u32 }  return 0i64-1i64 }
fn dcm_resolve(t:u32) -> i64 { let mut k:u32=0u32  while k<DCM_N { if neq(DCM_MO[k as u64],DCM_ML[k as u64],TO[t as u64],TL[t as u64])==1u32 { return alen_by_name(DCM_AO[k as u64], DCM_AL[k as u64]) }  k=k+1u32 }  return 0i64-1i64 }
fn abase(t: u32) -> i64 { let lv:i32=lidx(t)  if lv>=0i32 { let vt:i32=LVT[lv as u64]  if vt>=0i32 { return LVB[lv as u64] }  return 0i64-1i64 }   /* a LOCAL shadows: struct-value -> LVB, else -1 (no value base).  NEVER the reg_var AB global below (a local/param named like a global struct must NOT resolve to that global) */
    if lpt(t)>=0i32 { return 0i64-1i64 }   /* struct POINTER -> no value base; skip the reg_var AB global (polluted by the param-list prescan reg_var'ing `pos p`) */
    let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AB[k as u64] as i64}  k=k+1u32 }  return 0i64-1i64 }
fn awmask(t: u32) -> i64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AW[k as u64]}  k=k+1u32 }  return 0i64 }
fn aesize(t: u32) -> i64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AESZ[k as u64]}  k=k+1u32 }  return 8i64 }
fn asign(t: u32) -> u32 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return ASGN[k as u64]}  k=k+1u32 }  return 0u32 }
fn apsz(t: u32) -> i64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return APSZ[k as u64]}  k=k+1u32 }  return 0i64 }   /* pointee byte size of a global scalar pointer (0 = not one) */
fn apsg(t: u32) -> u32 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return APSG[k as u64]}  k=k+1u32 }  return 0u32 }   /* pointee sign of a global scalar pointer */
fn aesz_of(ty: u32) -> i64 { return type_size(ty) }   /* element byte size from the declared type (real C ABI {1,2,4,8}) */
fn byc(ty: u32) -> u32 { if aesz_of(ty)==1i64 {return 1u32}  return 0u32 }   /* is a byte type (char/uint8_t/int8_t)? -> byte pointer (stride-1 LOAD8/STORE8) */
/* struct types: NAME + a flattened field list (field name -> byte offset).  Struct vars reuse AO/AL/AB (base in
 * mem) + AVT (struct type index of that entry, -1 for plain arrays). */
var STNO:[u32;1024]  var STNL:[u32;1024]  var STFB:[u32;1024]  var STNF:[u32;1024]  var STSZ:[u64;1024]  var STN:u32=0u32  var STBODY:[u32;1024]  var STUNION:[u32;1024]   /* STBODY/STUNION: per-slot field-body token + union flag, so reg_fields can RE-FILL a slot (BUG-B forward-ref fixpoint) */
var SFO:[u32;8192]  var SFL:[u32;8192]  var SFOFF:[u64;8192]  var SFEL:[i64;8192]  var SFAR:[u32;8192]  var SFMASK:[i64;8192]  var SFSGN:[u32;8192]  var SFPT:[i32;8192]  var SFSZ:[i64;8192]  var SFN:u32=0u32  var AVT:[i32;1024]   /* SFEL=elem size {1,2,4,8} ; SFAR=array? ; SFMASK=field width-mask ; SFSGN=field signed ; SFPT=field's pointed-to/embedded STRUCT type (-1 if scalar) -> chained lvalue p->arr[i].subfield */
fn fieldpt(sti:i32, ft:u32)->i32 { if sti<0i32 {return 0i32-1i32}  let b:u32=STFB[sti as u64]  let n:u32=STNF[sti as u64]  let mut k:u32=0u32  while k<n { let fi:u32=b+k  if neq(SFO[fi as u64],SFL[fi as u64],TO[ft as u64],TL[ft as u64])==1u32 {return SFPT[fi as u64]}  k=k+1u32 }  return 0i32-1i32 }   /* the struct type a field points to / embeds */
/* named integer constants: enum members + object-like #define <number>.  Resolved in eprim -> econst. */
var CNO:[u32;16384]  var CNL:[u32;16384]  var CNV:[i64;16384]  var CN:u32=0u32
fn cadd(o:u32, l:u32, v:i64) { if CN<16384u32 { CNO[CN as u64]=o  CNL[CN as u64]=l  CNV[CN as u64]=v  CN=CN+1u32 } }
/* #define CONSTANT-EXPRESSION evaluator (byte-level Pratt over SRC) -> the macro's value: `#define BUF (64u*1024u)`,
 * `#define N (A * B)` (A/B resolved from the constant table).  Operates on the module cursor PPC. */
var PPC:u64=0u64
fn ppc_ws() { let mut g:u32=1u32  while g==1u32 { if PPC>=SLEN {g=0u32} else { let c:u32=sb(PPC)  if c==32u32 {PPC=PPC+1u64} else { if c==9u32 {PPC=PPC+1u64} else { if c==92u32 { PPC=PPC+1u64  if PPC<SLEN { if sb(PPC)==13u32 {PPC=PPC+1u64} }  if PPC<SLEN { if sb(PPC)==10u32 {PPC=PPC+1u64} } } else {g=0u32} } } } } }
fn ppc_num() -> i64 { let mut v:i64=0i64  let c0:u32=sb(PPC)  let mut hf:u32=0u32  let mut of:u32=0u32
    if c0==48u32 { let cn:u32=sb(PPC+1u64)  if cn==120u32 {hf=1u32} else { if cn==88u32 {hf=1u32} else { if cn>=48u32 { if cn<=55u32 {of=1u32} } } } }
    if hf==1u32 { PPC=PPC+2u64  let mut g:u32=1u32  while g==1u32 { if PPC>=SLEN {g=0u32} else { let c:u32=sb(PPC)  if hx(c)==1u32 { v=(v*16i64)+hv(c)  PPC=PPC+1u64 } else {g=0u32} } } }
    else { if of==1u32 { PPC=PPC+1u64  let mut g:u32=1u32  while g==1u32 { if PPC>=SLEN {g=0u32} else { let c:u32=sb(PPC)  if c>=48u32 { if c<=55u32 { v=(v*8i64)+((c-48u32) as i64)  PPC=PPC+1u64 } else {g=0u32} } else {g=0u32} } } }
           else { let mut g:u32=1u32  while g==1u32 { if PPC>=SLEN {g=0u32} else { let c:u32=sb(PPC)  if dg(c)==1u32 { v=(v*10i64)+((c-48u32) as i64)  PPC=PPC+1u64 } else {g=0u32} } } } }
    let mut gs:u32=1u32  while gs==1u32 { if PPC>=SLEN {gs=0u32} else { let c:u32=sb(PPC)  if c==117u32 {PPC=PPC+1u64} else { if c==108u32 {PPC=PPC+1u64} else { if c==85u32 {PPC=PPC+1u64} else { if c==76u32 {PPC=PPC+1u64} else {gs=0u32} } } } } }
    return v }
fn ppc_ident() -> i64 { let o:u64=PPC  let mut g:u32=1u32  while g==1u32 { if PPC>=SLEN {g=0u32} else { if idc(sb(PPC))==1u32 {PPC=PPC+1u64} else {g=0u32} } }  let l:u32=(PPC-o) as u32
    let mut k:u32=0u32  while k<CN { if neq(CNO[k as u64],CNL[k as u64],o as u32,l)==1u32 {return CNV[k as u64]}  k=k+1u32 }  return 0i64 }
fn ppc_peekop() -> u32 { if PPC>=SLEN {return 0u32}  let c:u32=sb(PPC)  let c2:u32=sb(PPC+1u64)
    if c==43u32 {return 17u32}  if c==45u32 {return 33u32}  if c==42u32 {return 49u32}  if c==47u32 {return 65u32}  if c==37u32 {return 81u32}
    if c==60u32 { if c2==60u32 {return 98u32} }  if c==62u32 { if c2==62u32 {return 114u32} }
    if c==38u32 { if c2!=38u32 {return 129u32} }  if c==124u32 { if c2!=124u32 {return 145u32} }  if c==94u32 {return 161u32}
    return 0u32 }
fn ppc_oprec(opid:u32) -> u32 { if opid==3u32 {return 6u32}  if opid==4u32 {return 6u32}  if opid==5u32 {return 6u32}  if opid==1u32 {return 5u32}  if opid==2u32 {return 5u32}  if opid==6u32 {return 4u32}  if opid==7u32 {return 4u32}  if opid==8u32 {return 3u32}  if opid==10u32 {return 2u32}  if opid==9u32 {return 1u32}  return 0u32 }
fn ppc_apply(opid:u32, a:i64, b:i64) -> i64 { if opid==1u32 {return a+b}  if opid==2u32 {return a-b}  if opid==3u32 {return a*b}  if opid==4u32 { if b!=0i64 {return a/b}  return 0i64 }  if opid==5u32 { if b!=0i64 {return a%b}  return 0i64 }  if opid==6u32 {return a<<b}  if opid==7u32 {return a>>b}  if opid==8u32 {return a&b}  if opid==9u32 {return a|b}  return a^b }
fn ppc_atom() -> i64 { ppc_ws()  if PPC>=SLEN {return 0i64}  let c:u32=sb(PPC)
    if c==40u32 { PPC=PPC+1u64  let v:i64=ppc_expr(0u32)  ppc_ws()  if PPC<SLEN { if sb(PPC)==41u32 {PPC=PPC+1u64} }  return v }
    if c==45u32 { PPC=PPC+1u64  return 0i64-ppc_atom() }
