fn emit_bcopy_v(dt: u32, st: u32, n: i64) {   /* Boss-2: frame-aware struct-value copy dt<-st (n bytes) -- bases via emit_vbase (frame-relative at SHADOW_ON=1, const at OFF), so recursive struct-value `b=a` is recursion-safe.  Mirrors emit_bcopy's loop. */
    let ti:u32=LN  if LN<255u32 {LN=LN+1u32}
