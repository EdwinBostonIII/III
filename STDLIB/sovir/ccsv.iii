    if SHADOW_ON==1u32 { if ADN_N>0u32 { HAS_SPILL=1u32 }  if HAS_STRUCTVAL==1u32 { HAS_SPILL=1u32 } }   /* &local OR struct-value-local spills -> recursion-safe shadow frame (Boss-1 + Boss-2) */
