}
/* per-fn pre-pass: find local names whose ADDRESS is taken (unary &NAME) -> ADN (so ladd spills them to memory).
 * `&` is address-of when the preceding token is NOT an expression-end (IDENT / number / ] / )). */
fn prescan_addrof() {
    ADN_N=0u32  let mut sc:u32=C  let mut d:i32=0i32  let mut g:u32=1u32
    while g==1u32 {
        if TK[sc as u64]==0u32 {g=0u32} else {
            if ispat(sc,Q_LB)==1u32 {d=d+1i32}
            if ispat(sc,Q_RB)==1u32 { d=d-1i32  if d==0i32 {g=0u32} }
            if TK[sc as u64]==3u32 { if TV[sc as u64]==Q_AND { if sc>0u32 {
                let pv:u32=sc-1u32  let mut isaddr:u32=1u32
                if TK[pv as u64]==1u32 {isaddr=0u32}  if TK[pv as u64]==2u32 {isaddr=0u32}
                if TK[pv as u64]==3u32 { if TV[pv as u64]==Q_RBR {isaddr=0u32}  if TV[pv as u64]==Q_RP {isaddr=0u32} }
                if isaddr==1u32 { if TK[(sc+1u32) as u64]==1u32 { if ADN_N<128u32 { ADN_O[ADN_N as u64]=TO[(sc+1u32) as u64]  ADN_L[ADN_N as u64]=TL[(sc+1u32) as u64]  ADN_N=ADN_N+1u32 } } }
            } } }
            sc=sc+1u32
