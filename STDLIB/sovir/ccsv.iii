    eu8(0x10u32,ta)  eu8(0x10u32,ti)  eb(0x20u32)  eb(0x80u32)  eu8(0x11u32,ca)                          /* ca=a[i] */
    eu8(0x10u32,tb)  eu8(0x10u32,ti)  eb(0x20u32)  eb(0x80u32)  eu8(0x11u32,cb)                          /* cb=b[i] */
    eu8(0x10u32,ca)  eu8(0x10u32,cb)  eb(0x21u32)  eu8(0x11u32,tr)
    eu8(0x10u32,ca)  eu8(0x10u32,cb)  eb(0x31u32)  eu8(0x51u32,1u32)                                     /* if differ break */
    eu8(0x10u32,ca)  econst(0i64)  eb(0x30u32)  eu8(0x51u32,1u32)                                        /* if NUL break */
    eu8(0x10u32,ti)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ti)  eu8(0x50u32,0u32)
    eb(0x44u32)  eb(0x44u32)  eu8(0x10u32,tr)
