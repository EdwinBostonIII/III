    emit_vbase(dt,0i64)  eu8(0x10u32,ti)  eb(0x20u32)  emit_vbase(st,0i64)  eu8(0x10u32,ti)  eb(0x20u32)  eb(0x80u32)  eb(0x81u32)   /* *(dt+ti) = *(st+ti) */
    eu8(0x10u32,ti)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ti)  eu8(0x50u32,0u32)
    eb(0x44u32)  eb(0x44u32)
