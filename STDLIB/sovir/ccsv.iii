/* ccsv.iii -- the FOUNDATION of the non-gcc C compiler: compiles the C integer core -> SVIR, thence to a
 * SOVEREIGN x86 PE (svir_x86 -> sovas -> sovld) with NO gcc in the artifact path.  This is the seed-DDC's
 * missing input begun: an independent C front-end whose backend is III's own sovereign toolchain, not gcc.
 *
 * Subset (C's integer core, == SVIR's): int NAME(int p, ...) { ... } ; int x = e ; x = e ; if (e) {} else {} ;
 *   while (e) {} ; return e ; calls ; + - * / % & | ^ << >> == != < > <= >= , parens, int literals, locals.
 *   All ints are i64.  Reads argv[1] (a .c file); emits a .iii module wrapping SVIR v1 bytes (DOCS/SVIR-V1-
 *   CANONICAL.md), consumed by svir_x86/svir_wasm.  main() is SVIR func 0.
 * HONEST SCOPE: this compiles the integer core; the 26k-line iiis-0 seed uses full C (structs, pointers,
 * preprocessor, ...) -- the long road this foundation begins.  Demonstrates: a C program -> sovereign x86 (no
 * gcc) AND a mini-DDC (ccsv build vs gcc build agree on behaviour). */
module ccsv

extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fread(buf: u64, size: u64, n: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(stream: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

var SRC : [u8; 1048576]
var SLEN : u64 = 0u64
var MODE_RB : [u8; 3] = [114u8, 98u8, 0u8]
var RAW : [u8; 1048576]  var RLEN : u64 = 0u64        /* the main file, pre-flatten (1 MB: seed core files reach 190 KB) */
var IBUFS : [u8; 1048576]                            /* 8 include levels x 131072 (depth-indexed; recursion-safe) */
var IPATH : [u8; 512]  var DIRLEN : u64 = 0u64  var IPLEN : u64 = 0u64   /* resolved include path = main's dir + "filename" */
var PATHBUF : [u8; 8192]  var POFF : [u64; 256]  var PLEN : [u64; 256]  var PN : u32 = 0u32  var PBE : u64 = 0u64   /* include-once set */
var TK : [u32; 262144]  var TV : [i64; 262144]  var TO : [u32; 262144]  var TL : [u32; 262144]  var NT : u32 = 0u32  var C : u32 = 0u32

const Q_LP:i64=1i64 const Q_RP:i64=2i64 const Q_LB:i64=3i64 const Q_RB:i64=4i64 const Q_SEMI:i64=7i64 const Q_ASN:i64=8i64
const Q_EQ:i64=10i64 const Q_NE:i64=11i64 const Q_LT:i64=12i64 const Q_GT:i64=13i64 const Q_LE:i64=14i64 const Q_GE:i64=15i64
const Q_ADD:i64=16i64 const Q_SUB:i64=17i64 const Q_MUL:i64=18i64 const Q_DIV:i64=19i64 const Q_MOD:i64=20i64
const Q_AND:i64=21i64 const Q_OR:i64=22i64 const Q_XOR:i64=23i64 const Q_SHL:i64=24i64 const Q_SHR:i64=25i64 const Q_COM:i64=6i64
const Q_LBR:i64=26i64 const Q_RBR:i64=27i64 const Q_DOT:i64=28i64 const Q_ARROW:i64=29i64 const Q_INC:i64=30i64 const Q_DEC:i64=31i64 const Q_NOT:i64=32i64 const Q_QUEST:i64=33i64 const Q_COLON:i64=34i64
const Q_LAND:i64=35i64 const Q_LOR:i64=36i64 const Q_LNOT:i64=37i64   /* logical && / || / ! (distinct from bitwise Q_AND/Q_OR/Q_NOT) */
const HEAP_BASE:i64=1048576i64   /* bump-heap base in svir_mem (4 MiB); static data below, heap above; cell@HEAP_BASE = the bump ptr (lazily init) */

fn sp(c: u32) -> u32 { if c==32u32 {return 1u32} if c==9u32 {return 1u32} if c==10u32 {return 1u32} if c==13u32 {return 1u32} return 0u32 }
fn dg(c: u32) -> u32 { if c>=48u32 { if c<=57u32 {return 1u32} } return 0u32 }
fn hx(c: u32) -> u32 { if c>=48u32 { if c<=57u32 {return 1u32} }  if c>=97u32 { if c<=102u32 {return 1u32} }  if c>=65u32 { if c<=70u32 {return 1u32} }  return 0u32 }
fn hv(c: u32) -> i64 { if c<=57u32 {return (c-48u32) as i64}  if c>=97u32 {return ((c-97u32)+10u32) as i64}  return ((c-65u32)+10u32) as i64 }
fn idc(c: u32) -> u32 { if c==95u32 {return 1u32} if c>=48u32 { if c<=57u32 {return 1u32} } if c>=65u32 { if c<=90u32 {return 1u32} } if c>=97u32 { if c<=122u32 {return 1u32} } return 0u32 }
fn ids(c: u32) -> u32 { if c==95u32 {return 1u32} if c>=65u32 { if c<=90u32 {return 1u32} } if c>=97u32 { if c<=122u32 {return 1u32} } return 0u32 }
fn sb(i: u64) -> u32 { let p : *u8 = ((&SRC as u64) + i) as *u8  return p[0u64] as u32 }
fn pt(k: u32, v: i64, o: u32, l: u32) { if NT < 262143u32 { TK[NT as u64]=k  TV[NT as u64]=v  TO[NT as u64]=o  TL[NT as u64]=l  NT=NT+1u32 } }   /* token cap = the TK[262144] array (was 8192 -> silently truncated the seed core's tens of thousands of tokens) */

fn lex() {
    NT = 0u32
    let mut i : u64 = 0u64
    while i < SLEN {
        let c : u32 = sb(i)  let c2 : u32 = sb(i+1u64)  let mut done : u32 = 0u32
        if sp(c)==1u32 { i=i+1u64  done=1u32 }
        if done==0u32 { if c==35u32 {   /* #define NAME <number> -> a named constant ; other # directives -> skip the line */
            i=i+1u64
            let mut g0:u32=1u32  while g0==1u32 { if i>=SLEN {g0=0u32} else { let w0:u32=sb(i)  if w0==32u32 {i=i+1u64} else { if w0==9u32 {i=i+1u64} else {g0=0u32} } } }
            let dwo:u64=i  let mut g1:u32=1u32  while g1==1u32 { if i>=SLEN {g1=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g1=0u32} } }
            let dwl:u64=i-dwo  let mut isdef:u32=0u32
            if dwl==6u64 { if sb(dwo)==100u32 { if sb(dwo+1u64)==101u32 { if sb(dwo+2u64)==102u32 { if sb(dwo+3u64)==105u32 { if sb(dwo+4u64)==110u32 { if sb(dwo+5u64)==101u32 { isdef=1u32 } } } } } } }
            if isdef==1u32 {
                let mut g2:u32=1u32  while g2==1u32 { if i>=SLEN {g2=0u32} else { let w2:u32=sb(i)  if w2==32u32 {i=i+1u64} else { if w2==9u32 {i=i+1u64} else {g2=0u32} } } }
                let no:u64=i  let mut g3:u32=1u32  while g3==1u32 { if i>=SLEN {g3=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g3=0u32} } }
                let nl:u64=i-no
                let mut g4:u32=1u32  while g4==1u32 { if i>=SLEN {g4=0u32} else { let w4:u32=sb(i)  if w4==32u32 {i=i+1u64} else { if w4==9u32 {i=i+1u64} else { if w4==92u32 { i=i+1u64  if i<SLEN { if sb(i)==13u32 {i=i+1u64} }  if i<SLEN { if sb(i)==10u32 {i=i+1u64} } } else {g4=0u32} } } } }   /* `\`-newline continuation -> the value (e.g. a multi-line array-count macro) is on the next line */
                let mut sp2:u32=1u32  while sp2==1u32 { if i>=SLEN {sp2=0u32} else { let pc:u32=sb(i)   /* skip leading `(` + `(cast)` prefixes: ((size_t)4096), (64), 0x.. , 4096 */
                    if pc==40u32 {i=i+1u64} else { if pc==32u32 {i=i+1u64} else { if pc==9u32 {i=i+1u64}
                    else { let isal:u32=idc(pc)  let isdg:u32=dg(pc)
                        if isal==1u32 { if isdg==0u32 {   /* identifier (cast type) -> skip it + spaces + a closing ) ; if no ) it's a macro alias -> give up */
                            let st:u64=i  let mut gi:u32=1u32  while gi==1u32 { if i>=SLEN {gi=0u32} else { let ic:u32=sb(i)  if idc(ic)==1u32 {i=i+1u64} else { if ic==32u32 {i=i+1u64} else {gi=0u32} } } }
                            if i<SLEN { if sb(i)==41u32 { i=i+1u64 } else { i=st  sp2=0u32 } } else { i=st  sp2=0u32 }
                        } else { sp2=0u32 } } else { sp2=0u32 } } } } }
                }
                if i<SLEN { let mut issz:u32=0u32                                  /* `#define N (sizeof(ARR)/sizeof(ARR[0]))` -> defer N -> ALEN(ARR) */
                    if (i+6u64)<=SLEN { if sb(i)==115u32 { if sb(i+1u64)==105u32 { if sb(i+2u64)==122u32 { if sb(i+3u64)==101u32 { if sb(i+4u64)==111u32 { if sb(i+5u64)==102u32 { issz=1u32 } } } } } } }
                    if issz==1u32 {
                        let mut j:u64=i+6u64  let mut gs:u32=1u32  while gs==1u32 { if j>=SLEN {gs=0u32} else { let sc:u32=sb(j)  if sc==32u32 {j=j+1u64} else { if sc==9u32 {j=j+1u64} else {gs=0u32} } } }
                        if j<SLEN { if sb(j)==40u32 { j=j+1u64  let mut gs2:u32=1u32  while gs2==1u32 { if j>=SLEN {gs2=0u32} else { let s2:u32=sb(j)  if s2==32u32 {j=j+1u64} else { if s2==9u32 {j=j+1u64} else {gs2=0u32} } } }
                            let ao:u64=j  let mut gi:u32=1u32  while gi==1u32 { if j>=SLEN {gi=0u32} else { if idc(sb(j))==1u32 {j=j+1u64} else {gi=0u32} } }  let al:u64=j-ao
                            if al>0u64 { if DCM_N<128u32 { DCM_MO[DCM_N as u64]=no as u32  DCM_ML[DCM_N as u64]=nl as u32  DCM_AO[DCM_N as u64]=ao as u32  DCM_AL[DCM_N as u64]=al as u32  DCM_N=DCM_N+1u32 } }
                        } }
                    }
                }
                if i<SLEN {
                    let c0:u32=sb(i)  let mut doev:u32=0u32
                    if dg(c0)==1u32 {doev=1u32}  if c0==40u32 {doev=1u32}  if c0==45u32 {doev=1u32}  if c0==126u32 {doev=1u32}   /* number / ( / - / ~ -> a constant EXPRESSION (e.g. (64u*1024u)) */
                    if idc(c0)==1u32 { if dg(c0)==0u32 { let oo:u64=i  let mut ee:u64=i  let mut ge:u32=1u32  while ge==1u32 { if ee>=SLEN {ge=0u32} else { if idc(sb(ee))==1u32 {ee=ee+1u64} else {ge=0u32} } }  let mut kk:u32=0u32  while kk<CN { if neq(CNO[kk as u64],CNL[kk as u64],oo as u32,(ee-oo) as u32)==1u32 {doev=1u32}  kk=kk+1u32 } } }   /* identifier value -> evaluate ONLY if a known constant (else a CODE macro like `static inline` -> skip, never a 0 alias) */
                    if doev==1u32 { PPC=i  let vv:i64=ppc_expr(0u32)  cadd(no as u32, nl as u32, vv)  i=PPC }
                }
            }
            let mut g6:u32=1u32  while g6==1u32 { if i>=SLEN {g6=0u32} else { if sb(i)==92u32 { i=i+1u64  if i<SLEN { if sb(i)==13u32 {i=i+1u64} }  if i<SLEN { if sb(i)==10u32 {i=i+1u64} } } else { if sb(i)==10u32 {g6=0u32} else {i=i+1u64} } } }   /* `\`-newline continues the #define; a bare newline ends it (so the continuation line is NOT lexed as code) */
            done=1u32
        } }
        if done==0u32 { if c==39u32 {   /* 'x' char literal -> a NUM token with the ASCII value (incl \n \t \0 \r \\ \') */
            let mut v:i64=0i64  let mut j:u64=i+1u64
            if sb(j)==92u32 { let e:u32=sb(j+1u64)
                if e==110u32 {v=10i64} else { if e==116u32 {v=9i64} else { if e==48u32 {v=0i64} else { if e==114u32 {v=13i64} else { if e==97u32 {v=7i64} else { if e==98u32 {v=8i64} else { if e==102u32 {v=12i64} else { if e==118u32 {v=11i64} else { v=e as i64 } } } } } } } }   /* \n \t \0 \r \a \b \f \v ; else the raw char (\\ \' \") */
                j=j+2u64
            } else { v=sb(j) as i64  j=j+1u64 }
            if sb(j)==39u32 { j=j+1u64 }
            pt(2u32,v,0u32,0u32)  i=j  done=1u32
        } }
        if done==0u32 { if c==34u32 {   /* "..." string literal -> a STRING token (kind 4) over the raw span between quotes */
            let o:u64=i+1u64  let mut j:u64=o  let mut g:u32=1u32
            while g==1u32 { if j>=SLEN {g=0u32} else { let cc:u32=sb(j)  if cc==34u32 {g=0u32} else { if cc==92u32 {j=j+2u64} else {j=j+1u64} } } }
            pt(4u32, 0i64, o as u32, (j-o) as u32)  i=j+1u64  done=1u32
        } }
        if done==0u32 { if c==47u32 { if c2==47u32 { i=i+2u64  let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if sb(i)==10u32 {g=0u32} else {i=i+1u64} } }  done=1u32 }
                                      else { if c2==42u32 { i=i+2u64  let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if sb(i)==42u32 { if sb(i+1u64)==47u32 {i=i+2u64 g=0u32} else {i=i+1u64} } else {i=i+1u64} } }  done=1u32 } } } }
        if done==0u32 { if ids(c)==1u32 { let o:u64=i  let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g=0u32} } }  pt(1u32,0i64,o as u32,(i-o) as u32)  done=1u32 } }
        if done==0u32 { if dg(c)==1u32 {
            let mut v:i64=0i64  let mut ishex:u32=0u32  let mut isoct:u32=0u32
            if c==48u32 { let cn:u32=sb(i+1u64)  if cn==120u32 {ishex=1u32} else { if cn==88u32 {ishex=1u32} else { if cn>=48u32 { if cn<=55u32 {isoct=1u32} } } } }   /* 0x/0X = hex ; 0NNN = octal ; else decimal/bare 0 */
            if ishex==1u32 { i=i+2u64  let mut gh:u32=1u32  while gh==1u32 { if i>=SLEN {gh=0u32} else { let hc:u32=sb(i)  if hx(hc)==1u32 { v=(v*16i64)+hv(hc)  i=i+1u64 } else {gh=0u32} } } }
            else { if isoct==1u32 { i=i+1u64  let mut go:u32=1u32  while go==1u32 { if i>=SLEN {go=0u32} else { let oc:u32=sb(i)  if oc>=48u32 { if oc<=55u32 { v=(v*8i64)+((oc-48u32) as i64)  i=i+1u64 } else {go=0u32} } else {go=0u32} } } }   /* octal: digits 0-7 */
                   else { let mut g:u32=1u32  while g==1u32 { if i>=SLEN {g=0u32} else { if dg(sb(i))==1u32 { v=(v*10i64)+((sb(i)-48u32) as i64)  i=i+1u64 } else {g=0u32} } } } }
            let mut g2:u32=1u32  while g2==1u32 { if i>=SLEN {g2=0u32} else { if idc(sb(i))==1u32 {i=i+1u64} else {g2=0u32} } }   /* skip u/l/U/L suffix */
            pt(2u32,v,0u32,0u32)  done=1u32
        } }
        if done==0u32 {
            let mut adv : u32 = 0u32
            if c==61u32 { if c2==61u32 { pt(3u32,Q_EQ,0u32,0u32) adv=2u32 } else { pt(3u32,Q_ASN,0u32,0u32) adv=1u32 } }
            if c==33u32 { if c2==61u32 { pt(3u32,Q_NE,0u32,0u32) adv=2u32 } else { pt(3u32,Q_LNOT,0u32,0u32) adv=1u32 } }   /* != or ! (logical NOT) */
            if c==60u32 { if c2==61u32 { pt(3u32,Q_LE,0u32,0u32) adv=2u32 } else { if c2==60u32 { pt(3u32,Q_SHL,0u32,0u32) adv=2u32 } else { pt(3u32,Q_LT,0u32,0u32) adv=1u32 } } }
            if c==62u32 { if c2==61u32 { pt(3u32,Q_GE,0u32,0u32) adv=2u32 } else { if c2==62u32 { pt(3u32,Q_SHR,0u32,0u32) adv=2u32 } else { pt(3u32,Q_GT,0u32,0u32) adv=1u32 } } }
            if c==38u32 { if c2==38u32 { pt(3u32,Q_LAND,0u32,0u32) adv=2u32 } else { pt(3u32,Q_AND,0u32,0u32) adv=1u32 } }   /* && or & */
            if c==124u32 { if c2==124u32 { pt(3u32,Q_LOR,0u32,0u32) adv=2u32 } else { pt(3u32,Q_OR,0u32,0u32) adv=1u32 } }   /* || or | */
            if c==40u32 { pt(3u32,Q_LP,0u32,0u32) adv=1u32 }
            if c==41u32 { pt(3u32,Q_RP,0u32,0u32) adv=1u32 }
            if c==123u32 { pt(3u32,Q_LB,0u32,0u32) adv=1u32 }
            if c==125u32 { pt(3u32,Q_RB,0u32,0u32) adv=1u32 }
            if c==91u32 { pt(3u32,Q_LBR,0u32,0u32) adv=1u32 }
            if c==93u32 { pt(3u32,Q_RBR,0u32,0u32) adv=1u32 }
            if c==46u32 { pt(3u32,Q_DOT,0u32,0u32) adv=1u32 }
            if c==59u32 { pt(3u32,Q_SEMI,0u32,0u32) adv=1u32 }
            if c==44u32 { pt(3u32,Q_COM,0u32,0u32) adv=1u32 }
            if c==43u32 { if c2==43u32 { pt(3u32,Q_INC,0u32,0u32) adv=2u32 } else { pt(3u32,Q_ADD,0u32,0u32) adv=1u32 } }   /* ++ or + */
            if c==45u32 { if c2==62u32 { pt(3u32,Q_ARROW,0u32,0u32) adv=2u32 } else { if c2==45u32 { pt(3u32,Q_DEC,0u32,0u32) adv=2u32 } else { pt(3u32,Q_SUB,0u32,0u32) adv=1u32 } } }   /* -> or -- or - */
            if c==42u32 { pt(3u32,Q_MUL,0u32,0u32) adv=1u32 }
            if c==47u32 { pt(3u32,Q_DIV,0u32,0u32) adv=1u32 }
            if c==37u32 { pt(3u32,Q_MOD,0u32,0u32) adv=1u32 }
            if c==94u32 { pt(3u32,Q_XOR,0u32,0u32) adv=1u32 }
            if c==126u32 { pt(3u32,Q_NOT,0u32,0u32) adv=1u32 }   /* ~ (bitwise NOT) */
            if c==63u32 { pt(3u32,Q_QUEST,0u32,0u32) adv=1u32 }   /* ? (ternary) */
            if c==58u32 { pt(3u32,Q_COLON,0u32,0u32) adv=1u32 }   /* : (ternary) */
            if adv==0u32 { adv=1u32 }
            i = i + (adv as u64)
        }
    }
    pt(0u32,0i64,0u32,0u32)
}

fn neq(o1: u32, l1: u32, o2: u32, l2: u32) -> u32 { if l1!=l2 {return 0u32}  let mut j:u32=0u32  while j<l1 { if sb((o1+j) as u64)!=sb((o2+j) as u64) {return 0u32}  j=j+1u32 }  return 1u32 }
fn kw(t: u32, s: u64, n: u32) -> u32 { if TK[t as u64]!=1u32 {return 0u32}  if TL[t as u64]!=n {return 0u32}  let mut j:u32=0u32  while j<n { let p:*u8=(s+(j as u64)) as *u8  if sb((TO[t as u64]+j) as u64)!=(p[0u64] as u32) {return 0u32}  j=j+1u32 }  return 1u32 }
/* a C scalar base-type keyword (all map to i64 in SVIR): int/char/void + the <stdint.h> fixed-width typedefs. */
fn dtype(t: u32) -> u32 {
    if kw(t,"int" as u64,3u32)==1u32 {return 1u32}  if kw(t,"char" as u64,4u32)==1u32 {return 1u32}  if kw(t,"void" as u64,4u32)==1u32 {return 1u32}
    if kw(t,"uint32_t" as u64,8u32)==1u32 {return 1u32}  if kw(t,"uint64_t" as u64,8u32)==1u32 {return 1u32}  if kw(t,"uint16_t" as u64,8u32)==1u32 {return 1u32}  if kw(t,"uint8_t" as u64,7u32)==1u32 {return 1u32}
    if kw(t,"int32_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int64_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int16_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int8_t" as u64,6u32)==1u32 {return 1u32}
    if kw(t,"size_t" as u64,6u32)==1u32 {return 1u32}  if kw(t,"ssize_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"bool" as u64,4u32)==1u32 {return 1u32}  if kw(t,"uintptr_t" as u64,9u32)==1u32 {return 1u32}  if kw(t,"intptr_t" as u64,8u32)==1u32 {return 1u32}
    if kw(t,"va_list" as u64,7u32)==1u32 {return 1u32}   /* va_list -> an 8-byte cursor local (the varargs walker) */
    return 0u32
}
/* a C type qualifier / storage class (no-op for ccsv's i64-everything model). */
fn isqual(t: u32) -> u32 {
    if kw(t,"static" as u64,6u32)==1u32 {return 1u32}  if kw(t,"const" as u64,5u32)==1u32 {return 1u32}  if kw(t,"unsigned" as u64,8u32)==1u32 {return 1u32}  if kw(t,"signed" as u64,6u32)==1u32 {return 1u32}
    if kw(t,"long" as u64,4u32)==1u32 {return 1u32}  if kw(t,"short" as u64,5u32)==1u32 {return 1u32}  if kw(t,"volatile" as u64,8u32)==1u32 {return 1u32}  if kw(t,"register" as u64,8u32)==1u32 {return 1u32}  if kw(t,"inline" as u64,6u32)==1u32 {return 1u32}
    return 0u32
}
fn skipquals() { let mut g:u32=1u32  while g==1u32 { if isqual(C)==1u32 { C=C+1u32 } else {g=0u32} } }
fn cp(p: i64) -> u32 { if TK[C as u64]==3u32 { if TV[C as u64]==p {return 1u32} }  return 0u32 }
fn eat(p: i64) -> u32 { if cp(p)==1u32 { C=C+1u32  return 1u32 }  return 0u32 }
fn ispat(t: u32, p: i64) -> u32 { if TK[t as u64]==3u32 { if TV[t as u64]==p {return 1u32} }  return 0u32 }

var FNO : [u32; 4096]  var FNL : [u32; 4096]  var FNP : [u32; 4096]  var FNT : [u32; 4096]  var FRM : [i64; 4096]  var FN : u32 = 0u32  var CUR_RMASK : i64 = 0i64  var ENDED_RET : u32 = 0u32   /* FRM=per-fn return width-mask ; ENDED_RET=last stmt was a return */
var FVAR : [u32; 4096]  var CUR_VAPTR : i32 = 0i32-1i32   /* FVAR[f]=variadic(has ...) ; FNP[f]=NAMED count ; CUR_VAPTR=this fn's hidden va-ptr local slot (-1 if not variadic) */
const VA_BUF:i64=983040i64   /* svir_mem va-arg buffer (64KiB below HEAP_BASE): a variadic call writes its varargs here; the callee's va-ptr points at it */
const FMT_SCRATCH:i64=982784i64   /* 256B digit-reversal scratch for vsnprintf number conversion (just below VA_BUF) */
fn fidx(t: u32) -> i32 { let mut k:u32=0u32  while k<FN { if neq(FNO[k as u64],FNL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return k as i32}  k=k+1u32 }  return 0i32-1i32 }
var LO : [u32; 256]  var LL : [u32; 256]  var LN : u32 = 0u32  var LCH : [u32; 256]  var LPT : [i32; 256]  var LW : [i64; 256]  var LMEM : [i64; 256]   /* LCH=char* ; LPT=struct-ptr type ; LW=width mask ; LMEM=spill memory addr if &-taken (-1=SVIR slot) */
var LSZ : [i64; 256]  var LSG : [u32; 256]  var LPSZ : [i64; 256]  var LPSG : [u32; 256]   /* P1 ABI: LSZ=scalar byte size (spill width) ; LSG=scalar signed ; LPSZ=pointee size ; LPSG=pointee signed */
var LVT : [i32; 256]  var LVB : [i64; 256]   /* local struct-VALUE: LVT=struct type (-1=not a struct value) ; LVB=its inline frame base (STSZ bytes reserved) -> `p.field` via abase/avtype */
var LOVF : u32 = 0u32                                  /* LOUD local-overflow flag: the SVIR LOCAL_GET/SET operand is ONE byte, so >256 locals/fn would silently collide (slot 256&0xFF=0); set this instead, fail the whole compile clearly */
var BLKD : i64 = 0i64                                  /* live structured-control nesting depth (BLOCK/LOOP/IF open count) -- read by `break` */
var BRKT : [i64; 32]  var BRKN : u32 = 0u32            /* break-target stack: BLKD just inside each enclosing loop/switch's exit block ; break -> BR(BLKD - BRKT[top]) */
var CONTT : [i64; 32]  var CONTN : u32 = 0u32          /* continue-target stack: BLKD just inside each loop's continue block (wraps the body; END lands before the incr/cond) ; continue -> BR(BLKD - CONTT[top]) */
var LBLO : [u32; 64]  var LBLL : [u32; 64]  var LBLBD : [i64; 64]  var LBLN : u32 = 0u32   /* per-fn FORWARD-goto labels: name offset/len + the BLKD of each label's goto-block (label[0]=innermost) */
var SWCC : [i64; 128]  var SWCN : u32 = 0u32           /* case constants of the switch being lowered (prescan, in source order) */
var ADN_O : [u32; 128]  var ADN_L : [u32; 128]  var ADN_N : u32 = 0u32   /* per-fn set of local names whose address is taken (-> spilled to memory) */
fn adn_has(o:u32, l:u32) -> u32 { let mut k:u32=0u32  while k<ADN_N { if neq(ADN_O[k as u64],ADN_L[k as u64],o,l)==1u32 {return 1u32}  k=k+1u32 }  return 0u32 }
fn lidx(t: u32) -> i32 { let mut k:u32=0u32  while k<LN { if neq(LO[k as u64],LL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return k as i32}  k=k+1u32 }  return 0i32-1i32 }
/* the width AND-mask for a fixed-width C type token (uintN_t/intN_t -> 2^N-1 ; else 0 = full i64). */
fn type_mask(t:u32) -> i64 {
    if kw(t,"uint32_t" as u64,8u32)==1u32 {return 4294967295i64}  if kw(t,"int32_t" as u64,7u32)==1u32 {return 4294967295i64}
    if kw(t,"uint16_t" as u64,8u32)==1u32 {return 65535i64}  if kw(t,"int16_t" as u64,7u32)==1u32 {return 65535i64}  if kw(t,"short" as u64,5u32)==1u32 {return 65535i64}
    if kw(t,"uint8_t" as u64,7u32)==1u32 {return 255i64}  if kw(t,"int8_t" as u64,6u32)==1u32 {return 255i64}  if kw(t,"char" as u64,4u32)==1u32 {return 255i64}  if kw(t,"bool" as u64,4u32)==1u32 {return 255i64}   /* char/short narrow like their int8_t/int16_t equivalents (a char local held its un-narrowed i64 before) */
    return 0i64
}
/* the REAL C size of a scalar/element type (the P1 ABI: char=1, short=2, int/u32=4, long/u64/ptr-ish=8). */
fn type_size(t:u32) -> i64 {
    if kw(t,"char" as u64,4u32)==1u32 {return 1i64}  if kw(t,"uint8_t" as u64,7u32)==1u32 {return 1i64}  if kw(t,"int8_t" as u64,6u32)==1u32 {return 1i64}
    if kw(t,"bool" as u64,4u32)==1u32 {return 1i64}  if kw(t,"void" as u64,4u32)==1u32 {return 1i64}
    if kw(t,"uint16_t" as u64,8u32)==1u32 {return 2i64}  if kw(t,"int16_t" as u64,7u32)==1u32 {return 2i64}  if kw(t,"short" as u64,5u32)==1u32 {return 2i64}
    if kw(t,"int" as u64,3u32)==1u32 {return 4i64}  if kw(t,"uint32_t" as u64,8u32)==1u32 {return 4i64}  if kw(t,"int32_t" as u64,7u32)==1u32 {return 4i64}
    if kw(t,"uint64_t" as u64,8u32)==1u32 {return 8i64}  if kw(t,"int64_t" as u64,7u32)==1u32 {return 8i64}  if kw(t,"size_t" as u64,6u32)==1u32 {return 8i64}  if kw(t,"ssize_t" as u64,7u32)==1u32 {return 8i64}
    if kw(t,"uintptr_t" as u64,9u32)==1u32 {return 8i64}  if kw(t,"intptr_t" as u64,8u32)==1u32 {return 8i64}  if kw(t,"long" as u64,4u32)==1u32 {return 8i64}
    let si:i32=stidx(t)  if si>=0i32 { return STSZ[si as u64] as i64 }   /* a typedef-struct type -> its computed size (struct value param / struct-array element) */
    return 8i64
}
/* signedness of a scalar/element type (drives LOAD16_S/LOAD32_S vs _U ; size-1 loads stay unsigned LOAD8). */
fn type_signed(t:u32) -> u32 {
    if kw(t,"int" as u64,3u32)==1u32 {return 1u32}  if kw(t,"char" as u64,4u32)==1u32 {return 1u32}
    if kw(t,"int8_t" as u64,6u32)==1u32 {return 1u32}  if kw(t,"int16_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int32_t" as u64,7u32)==1u32 {return 1u32}  if kw(t,"int64_t" as u64,7u32)==1u32 {return 1u32}
    if kw(t,"short" as u64,5u32)==1u32 {return 1u32}  if kw(t,"long" as u64,4u32)==1u32 {return 1u32}  if kw(t,"intptr_t" as u64,8u32)==1u32 {return 1u32}  if kw(t,"ssize_t" as u64,7u32)==1u32 {return 1u32}
    return 0u32
}
fn emit_lset(slot:u32) { let m:i64=LW[slot as u64]  if m!=0i64 { econst(m)  eb(0x25u32) }   /* [AND width-mask] ; then spilled -> STORE64 to mem (via a temp), else LOCAL_SET */
    let mem:i64=LMEM[slot as u64]
    if mem>=0i64 { let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}  eu8(0x11u32,tmp)  econst(mem)  eu8(0x10u32,tmp)  estore(LSZ[slot as u64]) } else { eu8(0x11u32, slot) }
}
fn lpt(t: u32) -> i32 { let li:i32=lidx(t)  if li<0i32 {return 0i32-1i32}  return LPT[li as u64] }
fn ladd(t: u32) -> u32 { let ex:i32=lidx(t)  if ex>=0i32 { return ex as u32 }  let s:u32=LN  if LN<256u32 { LO[LN as u64]=TO[t as u64]  LL[LN as u64]=TL[t as u64]  LMEM[LN as u64]=0i64-1i64  if adn_has(TO[t as u64],TL[t as u64])==1u32 { LMEM[LN as u64]=MTOP as i64  MTOP=MTOP+8u64 }  LN=LN+1u32 } else { LOVF=1u32 }  return s }   /* re-declared name reuses its slot; &-taken names spill to memory (LMEM); >256 -> LOUD overflow */
fn emit_lget(slot:u32) { let mem:i64=LMEM[slot as u64]  if mem>=0i64 { econst(mem)  eload(LSZ[slot as u64], LSG[slot as u64]) } else { eu8(0x10u32, slot) } }   /* spilled local -> typed LOAD from its memory addr ; else LOCAL_GET (byte-identical for non-spilled) */
/* global C arrays: `int NAME[NUM];` -> a cumulative base offset in SVIR linear memory (NAME[i] -> LOAD8/STORE8). */
var AO : [u32; 1024]  var AL : [u32; 1024]  var AB : [u64; 1024]  var AW : [i64; 1024]  var AESZ : [i64; 1024]  var ALEN : [u64; 1024]  var ASGN : [u32; 1024]  var AISC : [u32; 1024]  var AN : u32 = 0u32  var MTOP : u64 = 0u64   /* AW=elem width-mask ; AESZ=elem byte size {1,2,4,8} ; ALEN=element count (for sizeof) ; ASGN=elem signed ; AISC=1 if a global SCALAR (bare read = LOAD value, not array->ptr decay) */
fn aisc(t: u32) -> u32 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AISC[k as u64]}  k=k+1u32 }  return 0u32 }   /* is t a global scalar? */
var DCM_MO:[u32;128]  var DCM_ML:[u32;128]  var DCM_AO:[u32;128]  var DCM_AL:[u32;128]  var DCM_N:u32=0u32   /* deferred array-count macros: `#define N (sizeof(ARR)/sizeof(ARR[0]))` -> resolve N to ALEN(ARR) at the USE site (ARR registered by then) */
fn alen_by_name(o:u32, l:u32) -> i64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],o,l)==1u32 {return ALEN[k as u64] as i64}  k=k+1u32 }  return 0i64-1i64 }
fn dcm_resolve(t:u32) -> i64 { let mut k:u32=0u32  while k<DCM_N { if neq(DCM_MO[k as u64],DCM_ML[k as u64],TO[t as u64],TL[t as u64])==1u32 { return alen_by_name(DCM_AO[k as u64], DCM_AL[k as u64]) }  k=k+1u32 }  return 0i64-1i64 }
fn abase(t: u32) -> i64 { let lv:i32=lidx(t)  if lv>=0i32 { let vt:i32=LVT[lv as u64]  if vt>=0i32 { return LVB[lv as u64] } }   /* a local struct-VALUE shadows its (redundant) reg_var global entry -> LVB is the ONE base (field access + packing + entry-store all agree); vt bound to a let FIRST (i32 array-elem >=0 zero-extend trap) */
    let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AB[k as u64] as i64}  k=k+1u32 }  return 0i64-1i64 }
fn awmask(t: u32) -> i64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AW[k as u64]}  k=k+1u32 }  return 0i64 }
fn aesize(t: u32) -> i64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AESZ[k as u64]}  k=k+1u32 }  return 8i64 }
fn asign(t: u32) -> u32 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return ASGN[k as u64]}  k=k+1u32 }  return 0u32 }
fn aesz_of(ty: u32) -> i64 { return type_size(ty) }   /* element byte size from the declared type (real C ABI {1,2,4,8}) */
fn byc(ty: u32) -> u32 { if aesz_of(ty)==1i64 {return 1u32}  return 0u32 }   /* is a byte type (char/uint8_t/int8_t)? -> byte pointer (stride-1 LOAD8/STORE8) */
/* struct types: NAME + a flattened field list (field name -> byte offset).  Struct vars reuse AO/AL/AB (base in
 * mem) + AVT (struct type index of that entry, -1 for plain arrays). */
var STNO:[u32;1024]  var STNL:[u32;1024]  var STFB:[u32;1024]  var STNF:[u32;1024]  var STSZ:[u64;1024]  var STN:u32=0u32
var SFO:[u32;8192]  var SFL:[u32;8192]  var SFOFF:[u64;8192]  var SFEL:[i64;8192]  var SFAR:[u32;8192]  var SFMASK:[i64;8192]  var SFSGN:[u32;8192]  var SFPT:[i32;8192]  var SFN:u32=0u32  var AVT:[i32;1024]   /* SFEL=elem size {1,2,4,8} ; SFAR=array? ; SFMASK=field width-mask ; SFSGN=field signed ; SFPT=field's pointed-to/embedded STRUCT type (-1 if scalar) -> chained lvalue p->arr[i].subfield */
fn fieldpt(sti:i32, ft:u32)->i32 { if sti<0i32 {return 0i32-1i32}  let b:u32=STFB[sti as u64]  let n:u32=STNF[sti as u64]  let mut k:u32=0u32  while k<n { let fi:u32=b+k  if neq(SFO[fi as u64],SFL[fi as u64],TO[ft as u64],TL[ft as u64])==1u32 {return SFPT[fi as u64]}  k=k+1u32 }  return 0i32-1i32 }   /* the struct type a field points to / embeds */
/* named integer constants: enum members + object-like #define <number>.  Resolved in eprim -> econst. */
var CNO:[u32;16384]  var CNL:[u32;16384]  var CNV:[i64;16384]  var CN:u32=0u32
fn cadd(o:u32, l:u32, v:i64) { if CN<16384u32 { CNO[CN as u64]=o  CNL[CN as u64]=l  CNV[CN as u64]=v  CN=CN+1u32 } }
/* #define CONSTANT-EXPRESSION evaluator (byte-level Pratt over SRC) -> the macro's value: `#define BUF (64u*1024u)`,
 * `#define N (A * B)` (A/B resolved from the constant table).  Operates on the module cursor PPC. */
var PPC:u64=0u64
fn ppc_ws() { let mut g:u32=1u32  while g==1u32 { if PPC>=SLEN {g=0u32} else { let c:u32=sb(PPC)  if c==32u32 {PPC=PPC+1u64} else { if c==9u32 {PPC=PPC+1u64} else { if c==92u32 { PPC=PPC+1u64  if PPC<SLEN { if sb(PPC)==13u32 {PPC=PPC+1u64} }  if PPC<SLEN { if sb(PPC)==10u32 {PPC=PPC+1u64} } } else {g=0u32} } } } } }
fn ppc_num() -> i64 { let mut v:i64=0i64  let c0:u32=sb(PPC)  let mut hf:u32=0u32  let mut of:u32=0u32
    if c0==48u32 { let cn:u32=sb(PPC+1u64)  if cn==120u32 {hf=1u32} else { if cn==88u32 {hf=1u32} else { if cn>=48u32 { if cn<=55u32 {of=1u32} } } } }
    if hf==1u32 { PPC=PPC+2u64  let mut g:u32=1u32  while g==1u32 { if PPC>=SLEN {g=0u32} else { let c:u32=sb(PPC)  if hx(c)==1u32 { v=(v*16i64)+hv(c)  PPC=PPC+1u64 } else {g=0u32} } } }
    else { if of==1u32 { PPC=PPC+1u64  let mut g:u32=1u32  while g==1u32 { if PPC>=SLEN {g=0u32} else { let c:u32=sb(PPC)  if c>=48u32 { if c<=55u32 { v=(v*8i64)+((c-48u32) as i64)  PPC=PPC+1u64 } else {g=0u32} } else {g=0u32} } } }
           else { let mut g:u32=1u32  while g==1u32 { if PPC>=SLEN {g=0u32} else { let c:u32=sb(PPC)  if dg(c)==1u32 { v=(v*10i64)+((c-48u32) as i64)  PPC=PPC+1u64 } else {g=0u32} } } } }
    let mut gs:u32=1u32  while gs==1u32 { if PPC>=SLEN {gs=0u32} else { let c:u32=sb(PPC)  if c==117u32 {PPC=PPC+1u64} else { if c==108u32 {PPC=PPC+1u64} else { if c==85u32 {PPC=PPC+1u64} else { if c==76u32 {PPC=PPC+1u64} else {gs=0u32} } } } } }
    return v }
fn ppc_ident() -> i64 { let o:u64=PPC  let mut g:u32=1u32  while g==1u32 { if PPC>=SLEN {g=0u32} else { if idc(sb(PPC))==1u32 {PPC=PPC+1u64} else {g=0u32} } }  let l:u32=(PPC-o) as u32
    let mut k:u32=0u32  while k<CN { if neq(CNO[k as u64],CNL[k as u64],o as u32,l)==1u32 {return CNV[k as u64]}  k=k+1u32 }  return 0i64 }
fn ppc_peekop() -> u32 { if PPC>=SLEN {return 0u32}  let c:u32=sb(PPC)  let c2:u32=sb(PPC+1u64)
    if c==43u32 {return 17u32}  if c==45u32 {return 33u32}  if c==42u32 {return 49u32}  if c==47u32 {return 65u32}  if c==37u32 {return 81u32}
    if c==60u32 { if c2==60u32 {return 98u32} }  if c==62u32 { if c2==62u32 {return 114u32} }
    if c==38u32 { if c2!=38u32 {return 129u32} }  if c==124u32 { if c2!=124u32 {return 145u32} }  if c==94u32 {return 161u32}
    return 0u32 }
fn ppc_oprec(opid:u32) -> u32 { if opid==3u32 {return 6u32}  if opid==4u32 {return 6u32}  if opid==5u32 {return 6u32}  if opid==1u32 {return 5u32}  if opid==2u32 {return 5u32}  if opid==6u32 {return 4u32}  if opid==7u32 {return 4u32}  if opid==8u32 {return 3u32}  if opid==10u32 {return 2u32}  if opid==9u32 {return 1u32}  return 0u32 }
fn ppc_apply(opid:u32, a:i64, b:i64) -> i64 { if opid==1u32 {return a+b}  if opid==2u32 {return a-b}  if opid==3u32 {return a*b}  if opid==4u32 { if b!=0i64 {return a/b}  return 0i64 }  if opid==5u32 { if b!=0i64 {return a%b}  return 0i64 }  if opid==6u32 {return a<<b}  if opid==7u32 {return a>>b}  if opid==8u32 {return a&b}  if opid==9u32 {return a|b}  return a^b }
fn ppc_atom() -> i64 { ppc_ws()  if PPC>=SLEN {return 0i64}  let c:u32=sb(PPC)
    if c==40u32 { PPC=PPC+1u64  let v:i64=ppc_expr(0u32)  ppc_ws()  if PPC<SLEN { if sb(PPC)==41u32 {PPC=PPC+1u64} }  return v }
    if c==45u32 { PPC=PPC+1u64  return 0i64-ppc_atom() }
    if c==126u32 { PPC=PPC+1u64  let a:i64=ppc_atom()  return (0i64-a)-1i64 }
    if c==33u32 { PPC=PPC+1u64  let a:i64=ppc_atom()  if a==0i64 {return 1i64}  return 0i64 }
    if dg(c)==1u32 {return ppc_num()}
    if idc(c)==1u32 {return ppc_ident()}
    return 0i64 }
fn ppc_expr(minprec:u32) -> i64 { let mut lhs:i64=ppc_atom()  let mut g:u32=1u32
    while g==1u32 { ppc_ws()  let pk:u32=ppc_peekop()  if pk==0u32 {g=0u32} else { let opid:u32=pk>>4u32  let oplen:u32=pk&15u32  let pr:u32=ppc_oprec(opid)  if pr<minprec {g=0u32} else { PPC=PPC+(oplen as u64)  let rhs:i64=ppc_expr(pr+1u32)  lhs=ppc_apply(opid,lhs,rhs) } } }
    return lhs }
fn cidx(t:u32)->i32 { let mut k:u32=0u32  while k<CN { if neq(CNO[k as u64],CNL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return k as i32}  k=k+1u32 }  return 0i32-1i32 }
fn stidx(t:u32)->i32 { let mut k:u32=0u32  while k<STN { if neq(STNO[k as u64],STNL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return k as i32}  k=k+1u32 }  return 0i32-1i32 }
fn avtype(t:u32)->i32 { let lv:i32=lidx(t)  if lv>=0i32 { let vt:i32=LVT[lv as u64]  if vt>=0i32 { return vt } }   /* a local struct-VALUE's type shadows its reg_var global entry (consistent with abase); vt bound to a let FIRST (i32 array-elem >=0 trap) */
    let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return AVT[k as u64]}  k=k+1u32 }  return 0i32-1i32 }
fn fieldoff(sti:i32, ft:u32)->i64 { if sti<0i32 {return 0i64-1i64}  let b:u32=STFB[sti as u64]  let n:u32=STNF[sti as u64]  let mut k:u32=0u32  while k<n { let fi:u32=b+k  if neq(SFO[fi as u64],SFL[fi as u64],TO[ft as u64],TL[ft as u64])==1u32 {return SFOFF[fi as u64] as i64}  k=k+1u32 }  return 0i64-1i64 }
fn fieldelem(sti:i32, ft:u32)->i64 { if sti<0i32 {return 8i64}  let b:u32=STFB[sti as u64]  let n:u32=STNF[sti as u64]  let mut k:u32=0u32  while k<n { let fi:u32=b+k  if neq(SFO[fi as u64],SFL[fi as u64],TO[ft as u64],TL[ft as u64])==1u32 {return SFEL[fi as u64]}  k=k+1u32 }  return 8i64 }   /* element size of a (possibly array) field */
fn fieldisarr(sti:i32, ft:u32)->u32 { if sti<0i32 {return 0u32}  let b:u32=STFB[sti as u64]  let n:u32=STNF[sti as u64]  let mut k:u32=0u32  while k<n { let fi:u32=b+k  if neq(SFO[fi as u64],SFL[fi as u64],TO[ft as u64],TL[ft as u64])==1u32 {return SFAR[fi as u64]}  k=k+1u32 }  return 0u32 }   /* is this field an array? (bare access decays to address) */
fn fieldmask(sti:i32, ft:u32)->i64 { if sti<0i32 {return 0i64}  let b:u32=STFB[sti as u64]  let n:u32=STNF[sti as u64]  let mut k:u32=0u32  while k<n { let fi:u32=b+k  if neq(SFO[fi as u64],SFL[fi as u64],TO[ft as u64],TL[ft as u64])==1u32 {return SFMASK[fi as u64]}  k=k+1u32 }  return 0i64 }   /* the field's width mask (fixed-width field store/compound) */
fn fieldsign(sti:i32, ft:u32)->u32 { if sti<0i32 {return 0u32}  let b:u32=STFB[sti as u64]  let n:u32=STNF[sti as u64]  let mut k:u32=0u32  while k<n { let fi:u32=b+k  if neq(SFO[fi as u64],SFL[fi as u64],TO[ft as u64],TL[ft as u64])==1u32 {return SFSGN[fi as u64]}  k=k+1u32 }  return 0u32 }   /* the field's signedness (signed 16/32 loads) */
/* string literals: a BYTE-PACKED region at the START of svir_mem (real C layout), emitted as a SVIR DATA SECTION
 * (initialised linear memory -- no main-entry STORE init).  char *s = "..."; s[i] -> LOAD8 at s+i (stride 1, via
 * the char* flag LCH).  Each STRING token's TV becomes its byte address; arrays/structs follow (prescan_arr MTOP=DLEN). */
var SDAT:[u8;262144]  var DLEN:u64=0u64  var DEND:u64=0u64   /* SDAT = the SVIR data section: byte-packed strings [0..DLEN] + array initializers; DEND = total initialised extent */
fn sbyte(v:u32) { if DLEN<262143u64 { SDAT[DLEN]=(v & 0xFFu32) as u8  DLEN=DLEN+1u64 } }
fn data_put64(off:u64, v:i64) { let mut b:u64=0u64  while b<8u64 { if (off+b)<262144u64 { let p:*u8=((&SDAT as u64)+off+b) as *u8  p[0u64]=(((v as u64) >> (8u64*b)) & 0xFFu64) as u8 }  b=b+1u64 } }   /* 8-byte LE store into the data section */
fn data_put8(off:u64, v:i64) { if off<262144u64 { let p:*u8=((&SDAT as u64)+off) as *u8  p[0u64]=((v as u64) & 0xFFu64) as u8 } }   /* 1-byte store (byte-array initializer) */
fn data_put16(off:u64, v:i64) { let mut b:u64=0u64  while b<2u64 { if (off+b)<262144u64 { let p:*u8=((&SDAT as u64)+off+b) as *u8  p[0u64]=(((v as u64) >> (8u64*b)) & 0xFFu64) as u8 }  b=b+1u64 } }   /* 2-byte LE */
fn data_put32(off:u64, v:i64) { let mut b:u64=0u64  while b<4u64 { if (off+b)<262144u64 { let p:*u8=((&SDAT as u64)+off+b) as *u8  p[0u64]=(((v as u64) >> (8u64*b)) & 0xFFu64) as u8 }  b=b+1u64 } }   /* 4-byte LE */
fn data_putn(esz:i64, off:u64, v:i64) { if esz==1i64 { data_put8(off,v)  return }  if esz==2i64 { data_put16(off,v)  return }  if esz==4i64 { data_put32(off,v)  return }  data_put64(off,v) }   /* width-typed initializer store (real C stride) */
fn prescan_str() {
    DLEN=16u64  let mut t:u32=0u32   /* reserve [0..15] for NULL: address 0 must be distinct from any real string/array/data pointer (the seed checks `if(p)` / `p==NULL` on first-allocated objects -- e.g. &"firststring") */
    while t<NT {
        if TK[t as u64]==4u32 {
            TV[t as u64]=DLEN as i64                          /* address = byte offset in the packed region */
            let o:u32=TO[t as u64]  let l:u32=TL[t as u64]  let mut k:u32=0u32
            while k<l {
                let cc:u32=sb((o+k) as u64)
                if cc==92u32 { let e:u32=sb((o+k+1u32) as u64)   /* escape \n \t \0 \r (\\ \" -> literal) */
                    if e==110u32 {sbyte(10u32)} else { if e==116u32 {sbyte(9u32)} else { if e==48u32 {sbyte(0u32)} else { if e==114u32 {sbyte(13u32)} else { if e==97u32 {sbyte(7u32)} else { if e==98u32 {sbyte(8u32)} else { if e==102u32 {sbyte(12u32)} else { if e==118u32 {sbyte(11u32)} else {sbyte(e)} } } } } } } }   /* \n \t \0 \r \a \b \f \v ; else literal (\\ \" \') */
                    k=k+2u32
                } else { sbyte(cc)  k=k+1u32 }
            }
            sbyte(0u32)                                      /* NUL terminator */
        }
        t=t+1u32
    }
}

var BD : [u8; 262144]  var BL : u64 = 0u64
fn eb(b: u32) { if BL<262143u64 { BD[BL]=(b & 0xFFu32) as u8  BL=BL+1u64 } }
fn econst(v: i64) { eb(0x01u32)  let mut k:u32=0u32  while k<8u32 { eb(((v as u64) >> (8u64*(k as u64))) as u32)  k=k+1u32 } }
fn eu8(o: u32, a: u32) { eb(o)  eb(a) }
/* width-typed memory emit (P1 ABI): pick the LOAD/STORE/stride op for an element of byte-size sz (1/2/4/8). */
fn eload(sz:i64, sgn:u32) { if sz==1i64 { eb(0x80u32)  return }  if sz==2i64 { if sgn==1u32 {eb(0x85u32)} else {eb(0x84u32)}  return }  if sz==4i64 { if sgn==1u32 {eb(0x87u32)} else {eb(0x86u32)}  return }  eb(0x82u32) }   /* LOAD8 / LOAD16_{S,U} / LOAD32_{S,U} / LOAD64 */
fn estore(sz:i64) { if sz==1i64 { eb(0x81u32)  return }  if sz==2i64 { eb(0x88u32)  return }  if sz==4i64 { eb(0x89u32)  return }  eb(0x83u32) }   /* STORE8 / STORE16 / STORE32 / STORE64 */
fn estride(sz:i64) { if sz!=1i64 { econst(sz)  eb(0x22u32) } }   /* scale the index on TOS by elem size (MUL); no-op for byte stride */
var MO : [u8; 2097152]  var ML : u64 = 0u64
fn mb(b: u32) { if ML<2097151u64 { MO[ML]=(b & 0xFFu32) as u8  ML=ML+1u64 } }

fn prec(p: i64) -> u32 {
    if p==Q_MUL {return 9u32} if p==Q_DIV {return 9u32} if p==Q_MOD {return 9u32}
    if p==Q_ADD {return 8u32} if p==Q_SUB {return 8u32}  if p==Q_SHL {return 7u32} if p==Q_SHR {return 7u32}
    if p==Q_LT {return 6u32} if p==Q_GT {return 6u32} if p==Q_LE {return 6u32} if p==Q_GE {return 6u32}
    if p==Q_EQ {return 5u32} if p==Q_NE {return 5u32}  if p==Q_AND {return 4u32} if p==Q_XOR {return 3u32} if p==Q_OR {return 2u32}
    return 0u32
}
fn opc(p: i64) -> u32 {
    if p==Q_MUL {return 0x22u32} if p==Q_DIV {return 0x23u32} if p==Q_MOD {return 0x24u32}
    if p==Q_ADD {return 0x20u32} if p==Q_SUB {return 0x21u32}  if p==Q_SHL {return 0x28u32} if p==Q_SHR {return 0x29u32}
    if p==Q_LT {return 0x32u32} if p==Q_GT {return 0x35u32} if p==Q_LE {return 0x34u32} if p==Q_GE {return 0x33u32}
    if p==Q_EQ {return 0x30u32} if p==Q_NE {return 0x31u32}  if p==Q_AND {return 0x25u32} if p==Q_XOR {return 0x27u32} if p==Q_OR {return 0x26u32}
    return 0u32
}

fn alen(t: u32) -> u64 { let mut k:u32=0u32  while k<AN { if neq(AO[k as u64],AL[k as u64],TO[t as u64],TL[t as u64])==1u32 {return ALEN[k as u64]}  k=k+1u32 }  return 0u64 }
/* sizeof( type | TypedefName | struct/union X [*] | array | array[i] | struct-var | scalar ).  CCSV-consistent
 * sizes (int/uint32_t=8, char/uint8_t=1, ptr=8, struct=STSZ, array=count*elem) -- see GAP-MAP §4 re: vs C. */
fn esizeof() {
    let mut hasp:u32=0u32  if cp(Q_LP)==1u32 { C=C+1u32  hasp=1u32 }
    let mut sz:i64=8i64
    if cp(Q_MUL)==1u32 { C=C+1u32   /* sizeof(*ptr) -> pointee size (struct ptr -> STSZ ; scalar ptr -> LPSZ) */
        let dpt:i32=lpt(C)  if dpt>=0i32 { sz=STSZ[dpt as u64] as i64 } else { let dli:i32=lidx(C)  if dli>=0i32 { sz=LPSZ[dli as u64] } }
        C=C+1u32 }
    else { if dtype(C)==1u32 { sz=type_size(C)  C=C+1u32  let mut g:u32=1u32  while g==1u32 { if cp(Q_MUL)==1u32 {sz=8i64  C=C+1u32} else {g=0u32} } }
    else { if kw(C,"struct" as u64,6u32)==1u32 { C=C+1u32  let si:i32=stidx(C)  if si>=0i32 {sz=STSZ[si as u64] as i64}  C=C+1u32  let mut g2:u32=1u32  while g2==1u32 { if cp(Q_MUL)==1u32 {sz=8i64  C=C+1u32} else {g2=0u32} } }
           else { if kw(C,"union" as u64,5u32)==1u32 { C=C+1u32  let si:i32=stidx(C)  if si>=0i32 {sz=STSZ[si as u64] as i64}  C=C+1u32  let mut g3:u32=1u32  while g3==1u32 { if cp(Q_MUL)==1u32 {sz=8i64  C=C+1u32} else {g3=0u32} } }
                  else { if TK[C as u64]==1u32 {
                      let ti:i32=stidx(C)
                      if ti>=0i32 { sz=STSZ[ti as u64] as i64  C=C+1u32  let mut g4:u32=1u32  while g4==1u32 { if cp(Q_MUL)==1u32 {sz=8i64  C=C+1u32} else {g4=0u32} } }
                      else { let vt:i32=avtype(C)  let ab:i64=abase(C)
                          if vt>=0i32 { sz=STSZ[vt as u64] as i64  C=C+1u32 }
                          else { if ab>=0i64 {
                              if ispat(C+1u32,Q_LBR)==1u32 { sz=aesize(C)  C=C+2u32  let mut g5:u32=1u32  while g5==1u32 { if cp(Q_RBR)==1u32 {g5=0u32} else { if TK[C as u64]==0u32 {g5=0u32} else {C=C+1u32} } }  eat(Q_RBR) }
                              else { sz=(alen(C) as i64)*aesize(C)  C=C+1u32 } }
                          else { let sli:i32=lidx(C)  if sli>=0i32 {sz=LSZ[sli as u64]}  C=C+1u32 } } }   /* sizeof(scalar local) -> its declared byte size (LSZ), not a flat 8 */
                  } else { C=C+1u32 } } } } }
    if hasp==1u32 { eat(Q_RP) }
    econst(sz)
}
fn is_type_start(t:u32) -> u32 {   /* does token t begin a type (for cast / decl disambiguation)? */
    if dtype(t)==1u32 {return 1u32}  if isqual(t)==1u32 {return 1u32}
    if kw(t,"unsigned" as u64,8u32)==1u32 {return 1u32}  if kw(t,"signed" as u64,6u32)==1u32 {return 1u32}   /* `unsigned`/`signed` [base] cast */
    if kw(t,"struct" as u64,6u32)==1u32 {return 1u32}  if kw(t,"union" as u64,5u32)==1u32 {return 1u32}
    if TK[t as u64]==1u32 { if stidx(t)>=0i32 {return 1u32} }   /* typedef name */
    return 0u32
}
/* parse a cast type `[quals] base [*]...` at C, return its narrowing AND-mask (0 = none / pointer / int). */
fn cast_mask() -> i64 {
    skipquals()  let mut sz:i64=8i64  let mut usk:u32=0u32                                     /* sz = target byte size -> narrowing AND-mask (8/ptr = none) */
    if kw(C,"unsigned" as u64,8u32)==1u32 {usk=1u32  C=C+1u32} else { if kw(C,"signed" as u64,6u32)==1u32 {usk=1u32  C=C+1u32} }   /* `unsigned`/`signed` prefix -> optional base */
    if kw(C,"struct" as u64,6u32)==1u32 { C=C+2u32 } else { if kw(C,"union" as u64,5u32)==1u32 { C=C+2u32 }
        else { if dtype(C)==1u32 { sz=type_size(C)  C=C+1u32  if kw(C,"long" as u64,4u32)==1u32 { sz=8i64  C=C+1u32 } }   /* base size ; `long long` = 8B */
               else { if usk==1u32 { sz=4i64 } else { if TK[C as u64]==1u32 { C=C+1u32 } } } } }   /* bare `unsigned`/`signed` = int */
    let mut g:u32=1u32  while g==1u32 { if cp(Q_MUL)==1u32 { sz=8i64  C=C+1u32 } else {g=0u32} }   /* pointer cast -> no narrowing */
    let mut m:i64=0i64  if sz==1i64 {m=255i64} else { if sz==2i64 {m=65535i64} else { if sz==4i64 {m=4294967295i64} } }   /* width -> AND-mask (size 8 -> 0 = none) */
    return m
}
/* memcpy(dst,src,n) builtin: inline byte-copy loop (no libc on the sovereign target).  Parses the 3 args at C into
 * temps, emits a BLOCK/LOOP copying n bytes, leaves 0 on the stack (the call result, dropped at statement level). */
fn emit_memcpy() {
    let td:u32=LN  let ts:u32=LN+1u32  let tn:u32=LN+2u32  let ti:u32=LN+3u32  if LN<252u32 {LN=LN+4u32}
    ebin(0u32)  eu8(0x11u32,td)  eat(Q_COM)  ebin(0u32)  eu8(0x11u32,ts)  eat(Q_COM)  ebin(0u32)  eu8(0x11u32,tn)
    econst(0i64)  eu8(0x11u32,ti)
    eb(0x40u32)  eb(0x41u32)                                          /* BLOCK LOOP */
    eu8(0x10u32,ti)  eu8(0x10u32,tn)  eb(0x33u32)  eu8(0x51u32,1u32)  /* if i>=n (GE_S): BR_IF 1 (break) */
    eu8(0x10u32,td)  eu8(0x10u32,ti)  eb(0x20u32)                     /* dst+i */
    eu8(0x10u32,ts)  eu8(0x10u32,ti)  eb(0x20u32)  eb(0x80u32)        /* src[i] (LOAD8) */
    eb(0x81u32)                                                       /* STORE8 dst[i]=src[i] */
    eu8(0x10u32,ti)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ti)       /* i++ */
    eb(0x50u32)  eb(0u32)  eb(0x44u32)  eb(0x44u32)                   /* BR 0 ; END END */
    econst(0i64)                                                      /* call result */
}
/* memset(dst,val,n) builtin: inline byte-fill loop. */
fn emit_memset() {
    let td:u32=LN  let tv:u32=LN+1u32  let tn:u32=LN+2u32  let ti:u32=LN+3u32  if LN<252u32 {LN=LN+4u32}
    ebin(0u32)  eu8(0x11u32,td)  eat(Q_COM)  ebin(0u32)  eu8(0x11u32,tv)  eat(Q_COM)  ebin(0u32)  eu8(0x11u32,tn)
    econst(0i64)  eu8(0x11u32,ti)
    eb(0x40u32)  eb(0x41u32)
    eu8(0x10u32,ti)  eu8(0x10u32,tn)  eb(0x33u32)  eu8(0x51u32,1u32)  /* if i>=n: break */
    eu8(0x10u32,td)  eu8(0x10u32,ti)  eb(0x20u32)  eu8(0x10u32,tv)  eb(0x81u32)   /* dst[i] = val (STORE8) */
    eu8(0x10u32,ti)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ti)
    eb(0x50u32)  eb(0u32)  eb(0x44u32)  eb(0x44u32)
    econst(0i64)
}
/* malloc(size): a bump allocator over svir_mem.  The 8-byte cell @HEAP_BASE holds the next-free pointer, lazily
 * initialised (cell==0 -> HEAP_BASE+8) so library modules need no entry-init.  free()=no-op so every block is
 * fresh zero memory (calloc needs no explicit clear).  `size` is already on the stack; leaves the block address. */
fn emit_malloc() {   /* size on the stack -> user ptr ; an 8-byte SIZE HEADER sits at ptr-8 (so realloc can read the old size) */
    let tn:u32=LN  if LN<255u32 {LN=LN+1u32}  let tb:u32=LN  if LN<255u32 {LN=LN+1u32}
    eu8(0x11u32,tn)                                                                                       /* tn = size */
    econst(HEAP_BASE)  eb(0x82u32)  eu8(0x11u32,tb)                                                       /* tb = *(HEAP_BASE) (current bump = the header slot) */
    eu8(0x10u32,tb)  econst(0i64)  eb(0x30u32)  econst(HEAP_BASE+8i64)  eb(0x22u32)  eu8(0x10u32,tb)  eb(0x20u32)  eu8(0x11u32,tb)   /* tb = (tb==0)*(HB+8) + tb  (lazy init) */
    eu8(0x10u32,tb)  eu8(0x10u32,tn)  eb(0x83u32)                                                         /* *(tb) = size  (the header) */
    econst(HEAP_BASE)  eu8(0x10u32,tb)  econst(8i64)  eb(0x20u32)  eu8(0x10u32,tn)  econst(7i64)  eb(0x20u32)  econst(0i64-8i64)  eb(0x25u32)  eb(0x20u32)  eb(0x83u32)   /* *(HEAP_BASE) = tb + 8 + ((size+7)&~7) */
    eu8(0x10u32,tb)  econst(8i64)  eb(0x20u32)                                                            /* leave the user ptr = tb + 8 */
}
fn emit_realloc() {   /* [p, newsize] -> new ptr (header-based: copy min(oldsize,newsize); the old block leaks -- bump heap) */
    let tnw:u32=LN  if LN<255u32 {LN=LN+1u32}  let tp:u32=LN  if LN<255u32 {LN=LN+1u32}  let tr:u32=LN  if LN<255u32 {LN=LN+1u32}  let tc:u32=LN  if LN<255u32 {LN=LN+1u32}  let ti:u32=LN  if LN<255u32 {LN=LN+1u32}
    eu8(0x11u32,tnw)  eu8(0x11u32,tp)                                                                     /* tnw=newsize (top), tp=p */
    eu8(0x10u32,tnw)  emit_malloc()  eu8(0x11u32,tr)                                                      /* tr = malloc(newsize) */
    eu8(0x10u32,tp)  econst(0i64)  eb(0x31u32)  eb(0x42u32)                                               /* if p != 0 */
        eu8(0x10u32,tp)  econst(8i64)  eb(0x21u32)  eb(0x82u32)  eu8(0x11u32,tc)                          /* tc = *(p-8) = old size */
        eu8(0x10u32,tc)  eu8(0x10u32,tnw)  eb(0x34u32)  eb(0x42u32)  eb(0x43u32)  eu8(0x10u32,tnw)  eu8(0x11u32,tc)  eb(0x44u32)   /* tc = min(oldsize, newsize) */
        econst(0i64)  eu8(0x11u32,ti)
        eb(0x40u32)  eb(0x41u32)                                                                          /* copy tc bytes p->newp */
        eu8(0x10u32,ti)  eu8(0x10u32,tc)  eb(0x33u32)  eu8(0x51u32,1u32)                                  /* if i>=tc break */
        eu8(0x10u32,tr)  eu8(0x10u32,ti)  eb(0x20u32)  eu8(0x10u32,tp)  eu8(0x10u32,ti)  eb(0x20u32)  eb(0x80u32)  eb(0x81u32)   /* newp[i] = p[i] */
        eu8(0x10u32,ti)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ti)  eu8(0x50u32,0u32)
        eb(0x44u32)  eb(0x44u32)
    eb(0x44u32)
    eu8(0x10u32,tr)                                                                                       /* return new ptr */
}
fn emit_bcopy(dst:i64, src:i64, n:i64) {   /* copy n bytes dst<-src (compile-time addresses), inline byte loop */
    let ti:u32=LN  if LN<255u32 {LN=LN+1u32}
    econst(0i64)  eu8(0x11u32,ti)
    eb(0x40u32)  eb(0x41u32)
    eu8(0x10u32,ti)  econst(n)  eb(0x33u32)  eu8(0x51u32,1u32)        /* if ti>=n break (GE_S) */
    econst(dst)  eu8(0x10u32,ti)  eb(0x20u32)  econst(src)  eu8(0x10u32,ti)  eb(0x20u32)  eb(0x80u32)  eb(0x81u32)   /* *(dst+ti) = *(src+ti) */
    eu8(0x10u32,ti)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ti)  eu8(0x50u32,0u32)
    eb(0x44u32)  eb(0x44u32)
}
/* libc string builtins (no libc on the sovereign target) -- inline loops, result left on the stack.
 * Verifier-safe: results held in a temp, loops break via BR_IF (no IF-with-break). */
fn emit_strcmp() {   /* strcmp(a,b) -> (unsigned char)*a - *b at the first difference (0 if equal) */
    let ta:u32=LN  if LN<255u32 {LN=LN+1u32}  let tb:u32=LN  if LN<255u32 {LN=LN+1u32}  let ca:u32=LN  if LN<255u32 {LN=LN+1u32}  let cb:u32=LN  if LN<255u32 {LN=LN+1u32}  let tr:u32=LN  if LN<255u32 {LN=LN+1u32}
    ebin(0u32)  eu8(0x11u32,ta)  eat(Q_COM)  ebin(0u32)  eu8(0x11u32,tb)  econst(0i64)  eu8(0x11u32,tr)
    eb(0x40u32)  eb(0x41u32)
    eu8(0x10u32,ta)  eb(0x80u32)  eu8(0x11u32,ca)  eu8(0x10u32,tb)  eb(0x80u32)  eu8(0x11u32,cb)        /* ca=*a cb=*b */
    eu8(0x10u32,ca)  eu8(0x10u32,cb)  eb(0x21u32)  eu8(0x11u32,tr)                                       /* tr = ca-cb */
    eu8(0x10u32,ca)  eu8(0x10u32,cb)  eb(0x31u32)  eu8(0x51u32,1u32)                                     /* if ca!=cb break */
    eu8(0x10u32,ca)  econst(0i64)  eb(0x30u32)  eu8(0x51u32,1u32)                                        /* if ca==0 break */
    eu8(0x10u32,ta)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ta)  eu8(0x10u32,tb)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,tb)  eu8(0x50u32,0u32)
    eb(0x44u32)  eb(0x44u32)  eu8(0x10u32,tr)
}
fn emit_strncmp() {   /* strncmp(a,b,n) */
    let ta:u32=LN  if LN<255u32 {LN=LN+1u32}  let tb:u32=LN  if LN<255u32 {LN=LN+1u32}  let tn:u32=LN  if LN<255u32 {LN=LN+1u32}  let ca:u32=LN  if LN<255u32 {LN=LN+1u32}  let cb:u32=LN  if LN<255u32 {LN=LN+1u32}  let tr:u32=LN  if LN<255u32 {LN=LN+1u32}  let ti:u32=LN  if LN<255u32 {LN=LN+1u32}
    ebin(0u32)  eu8(0x11u32,ta)  eat(Q_COM)  ebin(0u32)  eu8(0x11u32,tb)  eat(Q_COM)  ebin(0u32)  eu8(0x11u32,tn)  econst(0i64)  eu8(0x11u32,tr)  econst(0i64)  eu8(0x11u32,ti)
    eb(0x40u32)  eb(0x41u32)
    eu8(0x10u32,ti)  eu8(0x10u32,tn)  eb(0x33u32)  eu8(0x51u32,1u32)                                     /* if i>=n break */
    eu8(0x10u32,ta)  eu8(0x10u32,ti)  eb(0x20u32)  eb(0x80u32)  eu8(0x11u32,ca)                          /* ca=a[i] */
    eu8(0x10u32,tb)  eu8(0x10u32,ti)  eb(0x20u32)  eb(0x80u32)  eu8(0x11u32,cb)                          /* cb=b[i] */
    eu8(0x10u32,ca)  eu8(0x10u32,cb)  eb(0x21u32)  eu8(0x11u32,tr)
    eu8(0x10u32,ca)  eu8(0x10u32,cb)  eb(0x31u32)  eu8(0x51u32,1u32)                                     /* if differ break */
    eu8(0x10u32,ca)  econst(0i64)  eb(0x30u32)  eu8(0x51u32,1u32)                                        /* if NUL break */
    eu8(0x10u32,ti)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ti)  eu8(0x50u32,0u32)
    eb(0x44u32)  eb(0x44u32)  eu8(0x10u32,tr)
}
fn emit_strlen() {   /* strlen(s) */
    let ts:u32=LN  if LN<255u32 {LN=LN+1u32}  let tn:u32=LN  if LN<255u32 {LN=LN+1u32}
    ebin(0u32)  eu8(0x11u32,ts)  econst(0i64)  eu8(0x11u32,tn)
    eb(0x40u32)  eb(0x41u32)
    eu8(0x10u32,ts)  eb(0x80u32)  econst(0i64)  eb(0x30u32)  eu8(0x51u32,1u32)                           /* if *s==0 break */
    eu8(0x10u32,tn)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,tn)  eu8(0x10u32,ts)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ts)  eu8(0x50u32,0u32)
    eb(0x44u32)  eb(0x44u32)  eu8(0x10u32,tn)
}
fn emit_memcmp() {   /* memcmp(a,b,n) */
    let ta:u32=LN  if LN<255u32 {LN=LN+1u32}  let tb:u32=LN  if LN<255u32 {LN=LN+1u32}  let tn:u32=LN  if LN<255u32 {LN=LN+1u32}  let ca:u32=LN  if LN<255u32 {LN=LN+1u32}  let cb:u32=LN  if LN<255u32 {LN=LN+1u32}  let tr:u32=LN  if LN<255u32 {LN=LN+1u32}  let ti:u32=LN  if LN<255u32 {LN=LN+1u32}
    ebin(0u32)  eu8(0x11u32,ta)  eat(Q_COM)  ebin(0u32)  eu8(0x11u32,tb)  eat(Q_COM)  ebin(0u32)  eu8(0x11u32,tn)  econst(0i64)  eu8(0x11u32,tr)  econst(0i64)  eu8(0x11u32,ti)
    eb(0x40u32)  eb(0x41u32)
    eu8(0x10u32,ti)  eu8(0x10u32,tn)  eb(0x33u32)  eu8(0x51u32,1u32)                                     /* if i>=n break */
    eu8(0x10u32,ta)  eu8(0x10u32,ti)  eb(0x20u32)  eb(0x80u32)  eu8(0x11u32,ca)
    eu8(0x10u32,tb)  eu8(0x10u32,ti)  eb(0x20u32)  eb(0x80u32)  eu8(0x11u32,cb)
    eu8(0x10u32,ca)  eu8(0x10u32,cb)  eb(0x21u32)  eu8(0x11u32,tr)
    eu8(0x10u32,ca)  eu8(0x10u32,cb)  eb(0x31u32)  eu8(0x51u32,1u32)                                     /* if differ break */
    eu8(0x10u32,ti)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ti)  eu8(0x50u32,0u32)
    eb(0x44u32)  eb(0x44u32)  eu8(0x10u32,tr)
}
/* vsnprintf core: emit the format-walk loop.  td=dst cursor, tf=fmt cursor, tap=va cursor (all temp slots,
 * pre-loaded).  Supports %s %d %u %x %c %%.  Number->string via FMT_SCRATCH (reversed digits, copied forward).
 * Verifier-safe: IF/ELSE that "produce" a value route through a temp; nested copy/digit loops are self-contained. */
fn emit_putnum(td:u32, tn:u32, base:i64, signd:u32) {
    let ts:u32=LN  if LN<255u32 {LN=LN+1u32}  let dg:u32=LN  if LN<255u32 {LN=LN+1u32}
    if signd==1u32 { eu8(0x10u32,tn)  econst(0i64)  eb(0x32u32)  eb(0x42u32)   /* if tn<0 */
        eu8(0x10u32,td)  econst(45i64)  eb(0x81u32)  eu8(0x10u32,td)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,td)   /* *td='-'; td++ */
        econst(0i64)  eu8(0x10u32,tn)  eb(0x21u32)  eu8(0x11u32,tn)  eb(0x44u32) }                                 /* tn = -tn ; END */
    econst(FMT_SCRATCH)  eu8(0x11u32,ts)                                          /* ts = scratch */
    eb(0x40u32)  eb(0x41u32)                                                       /* BLOCK LOOP : extract digits reversed */
    eu8(0x10u32,tn)  econst(base)  eb(0x24u32)  eu8(0x11u32,dg)                    /* dg = tn % base */
    eu8(0x10u32,dg)  econst(10i64)  eb(0x32u32)  eb(0x42u32)                       /* if dg<10 */
        eu8(0x10u32,dg)  econst(48i64)  eb(0x20u32)  eu8(0x11u32,dg)  eb(0x43u32)   /* '0'+dg ; ELSE */
        eu8(0x10u32,dg)  econst(87i64)  eb(0x20u32)  eu8(0x11u32,dg)  eb(0x44u32)   /* 'a'-10+dg ; END */
    eu8(0x10u32,ts)  eu8(0x10u32,dg)  eb(0x81u32)                                  /* *ts = digit char */
    eu8(0x10u32,ts)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ts)                    /* ts++ */
    eu8(0x10u32,tn)  econst(base)  eb(0x23u32)  eu8(0x11u32,tn)                    /* tn /= base */
    eu8(0x10u32,tn)  econst(0i64)  eb(0x31u32)  eu8(0x51u32,0u32)                  /* if tn!=0 -> loop */
    eb(0x44u32)  eb(0x44u32)
    eb(0x40u32)  eb(0x41u32)                                                       /* BLOCK LOOP : reverse-copy [FMT_SCRATCH,ts) -> td */
    eu8(0x10u32,ts)  econst(FMT_SCRATCH)  eb(0x34u32)  eu8(0x51u32,1u32)           /* if ts<=scratch -> break */
    eu8(0x10u32,ts)  econst(1i64)  eb(0x21u32)  eu8(0x11u32,ts)                    /* ts-- */
    eu8(0x10u32,td)  eu8(0x10u32,ts)  eb(0x80u32)  eb(0x81u32)                     /* *td = *ts */
    eu8(0x10u32,td)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,td)                    /* td++ */
    eu8(0x50u32,0u32)
    eb(0x44u32)  eb(0x44u32)
}
fn emit_fmt(td:u32, tf:u32, tap:u32) {
    let tc:u32=LN  if LN<255u32 {LN=LN+1u32}  let tsp:u32=LN  if LN<255u32 {LN=LN+1u32}  let tn:u32=LN  if LN<255u32 {LN=LN+1u32}  let ts:u32=LN  if LN<255u32 {LN=LN+1u32}  let tc2:u32=LN  if LN<255u32 {LN=LN+1u32}
    eb(0x40u32)  eb(0x41u32)                                                       /* BLOCK LOOP : walk fmt */
    eu8(0x10u32,tf)  eb(0x80u32)  eu8(0x11u32,tc)                                  /* tc = *tf */
    eu8(0x10u32,tc)  econst(0i64)  eb(0x30u32)  eu8(0x51u32,1u32)                  /* if tc==0 -> break */
    eu8(0x10u32,tc)  econst(37i64)  eb(0x30u32)  eb(0x42u32)                       /* if tc=='%' */
        eu8(0x10u32,tf)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,tf)                /* tf++ */
        eu8(0x10u32,tf)  eb(0x80u32)  eu8(0x11u32,tsp)                            /* tsp = *tf */
        eu8(0x10u32,tf)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,tf)                /* tf++ */
        eu8(0x10u32,tsp)  econst(115i64)  eb(0x30u32)  eb(0x42u32)                /* %s */
            eu8(0x10u32,tap)  eb(0x82u32)  eu8(0x11u32,ts)  eu8(0x10u32,tap)  econst(8i64)  eb(0x20u32)  eu8(0x11u32,tap)   /* ts = va_arg */
            eb(0x40u32)  eb(0x41u32)
            eu8(0x10u32,ts)  eb(0x80u32)  eu8(0x11u32,tc2)  eu8(0x10u32,tc2)  econst(0i64)  eb(0x30u32)  eu8(0x51u32,1u32)   /* tc2=*ts; if 0 break */
            eu8(0x10u32,td)  eu8(0x10u32,tc2)  eb(0x81u32)  eu8(0x10u32,td)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,td)       /* *td=tc2; td++ */
            eu8(0x10u32,ts)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ts)  eu8(0x50u32,0u32)                                    /* ts++; loop */
            eb(0x44u32)  eb(0x44u32)
        eb(0x44u32)
        eu8(0x10u32,tsp)  econst(100i64)  eb(0x30u32)  eb(0x42u32)                /* %d */
            eu8(0x10u32,tap)  eb(0x82u32)  eu8(0x11u32,tn)  eu8(0x10u32,tap)  econst(8i64)  eb(0x20u32)  eu8(0x11u32,tap)
            emit_putnum(td, tn, 10i64, 1u32)
        eb(0x44u32)
        eu8(0x10u32,tsp)  econst(117i64)  eb(0x30u32)  eb(0x42u32)                /* %u */
            eu8(0x10u32,tap)  eb(0x82u32)  eu8(0x11u32,tn)  eu8(0x10u32,tap)  econst(8i64)  eb(0x20u32)  eu8(0x11u32,tap)
            emit_putnum(td, tn, 10i64, 0u32)
        eb(0x44u32)
        eu8(0x10u32,tsp)  econst(120i64)  eb(0x30u32)  eb(0x42u32)                /* %x */
            eu8(0x10u32,tap)  eb(0x82u32)  eu8(0x11u32,tn)  eu8(0x10u32,tap)  econst(8i64)  eb(0x20u32)  eu8(0x11u32,tap)
            emit_putnum(td, tn, 16i64, 0u32)
        eb(0x44u32)
        eu8(0x10u32,tsp)  econst(99i64)  eb(0x30u32)  eb(0x42u32)                 /* %c */
            eu8(0x10u32,td)  eu8(0x10u32,tap)  eb(0x82u32)  eb(0x81u32)  eu8(0x10u32,td)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,td)  eu8(0x10u32,tap)  econst(8i64)  eb(0x20u32)  eu8(0x11u32,tap)
        eb(0x44u32)
        eu8(0x10u32,tsp)  econst(37i64)  eb(0x30u32)  eb(0x42u32)                 /* %% */
            eu8(0x10u32,td)  econst(37i64)  eb(0x81u32)  eu8(0x10u32,td)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,td)
        eb(0x44u32)
    eb(0x43u32)                                                                   /* ELSE (literal char) */
        eu8(0x10u32,td)  eu8(0x10u32,tc)  eb(0x81u32)  eu8(0x10u32,td)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,td)  eu8(0x10u32,tf)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,tf)
    eb(0x44u32)                                                                   /* END (%) */
    eu8(0x50u32,0u32)
    eb(0x44u32)  eb(0x44u32)                                                       /* END END (loop, block) */
    eu8(0x10u32,td)  econst(0i64)  eb(0x81u32)                                     /* *td = 0 (NUL) */
}
/* ++ / -- on a scalar LOCAL (scale 1).  isdec:1=-- ; post:1=leave OLD (postfix) / 0=leave NEW (prefix). */
fn pinc_local(slot:u32, isdec:u32, post:u32) {
    let tv:u32=LN  if LN<255u32 {LN=LN+1u32}
    if post==1u32 {
        emit_lget(slot)  eu8(0x11u32,tv)                                                          /* tv = old */
        eu8(0x10u32,tv)  econst(1i64)  if isdec==1u32 {eb(0x21u32)} else {eb(0x20u32)}  emit_lset(slot)   /* slot = old +/-1 */
        eu8(0x10u32,tv)                                                                            /* leave OLD */
    } else {
        emit_lget(slot)  econst(1i64)  if isdec==1u32 {eb(0x21u32)} else {eb(0x20u32)}  emit_lset(slot)
        emit_lget(slot)                                                                            /* leave NEW (canonical reload) */
    }
}
/* ++ / -- on a MEMORY lvalue: the store ADDRESS is ALREADY on the eval stack.  elem size/sign/mask ; scale 1. */
fn pinc_mem(esz:i64, sgn:u32, mask:i64, isdec:u32, post:u32) {
    let ta:u32=LN  if LN<255u32 {LN=LN+1u32}
    let tv:u32=LN  if LN<255u32 {LN=LN+1u32}
    eu8(0x11u32,ta)                                                                                /* ta = addr (computed once) */
    if post==1u32 {
        eu8(0x10u32,ta)  eload(esz,sgn)  eu8(0x11u32,tv)                                           /* tv = old = *addr */
        eu8(0x10u32,ta)  eu8(0x10u32,tv)  econst(1i64)  if isdec==1u32 {eb(0x21u32)} else {eb(0x20u32)}  if mask!=0i64 {econst(mask) eb(0x25u32)}  estore(esz)   /* *addr = old +/-1 */
        eu8(0x10u32,tv)                                                                            /* leave OLD */
    } else {
        eu8(0x10u32,ta)  eload(esz,sgn)  econst(1i64)  if isdec==1u32 {eb(0x21u32)} else {eb(0x20u32)}  if mask!=0i64 {econst(mask) eb(0x25u32)}  eu8(0x11u32,tv)   /* tv = new (masked) */
        eu8(0x10u32,ta)  eu8(0x10u32,tv)  estore(esz)                                              /* *addr = new */
        eu8(0x10u32,tv)                                                                            /* leave NEW */
    }
}
/* parse an lvalue at C and pre/post inc/dec it.  Handles NAME[idx] (global array / pointer) and bare scalar local NAME. */
fn elvalinc(isdec:u32, post:u32) {
    if TK[C as u64]==1u32 {
        let t:u32=C
        if ispat(C+1u32,Q_LBR)==1u32 {
            let ab:i64=abase(t)
            if ab>=0i64 { C=C+2u32  ebin(0u32)  eat(Q_RBR)  let sz:i64=aesize(t)  let sg:u32=asign(t)  let am:i64=awmask(t)
                estride(sz)  if ab>0i64 { econst(ab)  eb(0x20u32) }  pinc_mem(sz,sg,am,isdec,post)  return }
            let pli:i32=lidx(t)  if pli>=0i32 { let psz:i64=LPSZ[pli as u64]  let psg:u32=LPSG[pli as u64]  emit_lget(pli as u32)  C=C+2u32  ebin(0u32)  eat(Q_RBR)
                estride(psz)  eb(0x20u32)  pinc_mem(psz,psg,0i64,isdec,post)  return }
        }
        let li:i32=lidx(t)  if li>=0i32 { C=C+1u32  pinc_local(li as u32,isdec,post)  return }
    }
    eprim()                                                                                        /* not a recognized lvalue -> plain (++*p etc., rare) */
}
fn eprim() {
    if cp(Q_INC)==1u32 { C=C+1u32  elvalinc(0u32,0u32)  return }   /* ++lvalue (prefix, leave NEW) */
    if cp(Q_DEC)==1u32 { C=C+1u32  elvalinc(1u32,0u32)  return }   /* --lvalue (prefix) */
    if cp(Q_MUL)==1u32 { C=C+1u32                                  /* *p : pointer deref (typed by pointee width) */
        if TK[C as u64]==1u32 { let dli:i32=lidx(C)  if dli>=0i32 {
            let lp:i32=LPT[dli as u64]  let psz:i64=LPSZ[dli as u64]  let psg:u32=LPSG[dli as u64]   /* read into lets BEFORE branching (inline LPT[dli]<0 after lidx miscompiles -> skips, LOAD64) */
            if lp<0i32 {
                if ispat(C+1u32,Q_INC)==1u32 { let ta:u32=LN  if LN<255u32 {LN=LN+1u32}   /* *(p++) : deref OLD p, advance p by pointee size */
                    emit_lget(dli as u32)  eu8(0x11u32,ta)  emit_lget(dli as u32)  econst(psz)  eb(0x20u32)  emit_lset(dli as u32)
                    eu8(0x10u32,ta)  eload(psz,psg)  C=C+2u32  return }
                if ispat(C+1u32,Q_DEC)==1u32 { let ta:u32=LN  if LN<255u32 {LN=LN+1u32}   /* *(p--) */
                    emit_lget(dli as u32)  eu8(0x11u32,ta)  emit_lget(dli as u32)  econst(psz)  eb(0x21u32)  emit_lset(dli as u32)
                    eu8(0x10u32,ta)  eload(psz,psg)  C=C+2u32  return }
                emit_lget(dli as u32)  C=C+1u32  eload(psz, psg)  return } } }
        eprim()  eb(0x82u32)  return                              /* fallback (struct-ptr / complex deref) -> LOAD64 */
    }
    if cp(Q_AND)==1u32 {                                            /* &arr[i] / &arr : address-of (no load) */
        C=C+1u32
        if TK[C as u64]==1u32 { let at:u32=C
            let vt:i32=avtype(at)  if vt>=0i32 { if ispat(at+1u32,Q_DOT)==1u32 { let ft:u32=at+2u32  let foff:i64=fieldoff(vt,ft)  let vb:i64=abase(at)  C=C+3u32  econst(vb+foff)  return } }   /* &v.field : struct-value field address = base+offset */
            let ptt:i32=lpt(at)  if ptt>=0i32 { if ispat(at+1u32,Q_ARROW)==1u32 { let ft:u32=at+2u32  let foff:i64=fieldoff(ptt,ft)  let pl:i32=lidx(at)  let eltp:i32=fieldpt(ptt,ft)
                if ispat(at+3u32,Q_LBR)==1u32 { if eltp>=0i32 { let fe:i64=fieldelem(ptt,ft)  let esz:i64=STSZ[eltp as u64] as i64  C=C+4u32  ebin(0u32)  eat(Q_RBR)  estride(esz)  emit_lget(pl as u32)  if foff>0i64 {econst(foff) eb(0x20u32)}  if fe==8i64 {eb(0x82u32)}  eb(0x20u32)  return } }   /* &p->arrfield[i] : i*STSZ + [*](p+foff) */
                C=C+3u32  emit_lget(pl as u32)  if foff>0i64 {econst(foff)  eb(0x20u32)}  return } }   /* &p->field : ptr + field offset */
            let ab:i64=abase(at)
            if ab>=0i64 {
