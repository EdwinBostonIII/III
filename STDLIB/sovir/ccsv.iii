    eu8(0x10u32,ti)  eu8(0x10u32,tn)  eb(0x33u32)  eu8(0x51u32,1u32)  /* if i>=n: break */
    eu8(0x10u32,td)  eu8(0x10u32,ti)  eb(0x20u32)  eu8(0x10u32,tv)  eb(0x81u32)   /* dst[i] = val (STORE8) */
    eu8(0x10u32,ti)  econst(1i64)  eb(0x20u32)  eu8(0x11u32,ti)
    eb(0x50u32)  eb(0u32)  eb(0x44u32)  eb(0x44u32)
