}
/* ---- preprocessor: conditional compilation (#ifdef/#ifndef/#if 0/#else/#endif + #undef) ---------------------
 * The seed uses ONLY definedness conditionals (40 #ifdef, 23 #ifndef, 1 `#if 0`; zero #elif).  A single in-place
 * compacting pass over the flattened SRC strips inactive branches BEFORE lex; the defined-set is built from
 * #define (which lex still consumes for numeric -> named constants).  No-op for conditional-free files. */
var PPDBUF : [u8; 131072]  var PPD_OFF : [u32; 8192]  var PPD_LEN : [u32; 8192]  var PPD_N : u32 = 0u32  var PPD_BE : u32 = 0u32   /* defined-name set (copied bytes; offsets stable across compaction) */
