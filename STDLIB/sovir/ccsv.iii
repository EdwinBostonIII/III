            C=C+1u32  let ft:u32=C  C=C+1u32  let foff:i64=fieldoff(ptt,ft)  let fe:i64=fieldelem(ptt,ft)  let fsg:u32=fieldsign(ptt,ft)  let fm:i64=fieldmask(ptt,ft)
                let fpt0a:i32=fieldpt(ptt,ft)  if fpt0a>=0i32 { if cp(Q_DOT)==1u32 {   /* p->f0.f1.f2.. : arrow into an INLINE aggregate field, then a DOT-chain -> pointer + summed offsets, typed load on the last (an->u.arg.arg_name.length) */
                    emit_lget(lidx(t) as u32)  let mut cura:i32=fpt0a  let mut acca:i64=foff  let mut gca:u32=1u32
                    while gca==1u32 { C=C+1u32  let nfa:u32=C  C=C+1u32  let nfoa:i64=fieldoff(cura,nfa)  acca=acca+nfoa  let npta:i32=fieldpt(cura,nfa)  let mut morea:u32=0u32  if npta>=0i32 { if cp(Q_DOT)==1u32 {morea=1u32} }
                        if morea==1u32 { cura=npta } else { if acca>0i64 {econst(acca)  eb(0x20u32)}  let fea:i64=fieldelem(cura,nfa)  if cp(Q_LBR)==1u32 { C=C+1u32  ebin(0u32)  eat(Q_RBR)  estride(fea)  eb(0x20u32) }  eload(fea, fieldsign(cura,nfa))  gca=0u32 } }   /* last member: +[i]*subelem if it is an ARRAY field -- the seed's `n->u.hexad_.trits[i]` (else `[i]` left -> loads [0] + dangling token) */
                    return } }
                if cp(Q_LBR)==1u32 {
                    let elt:i32=fieldpt(ptt,ft)
                    if elt>=0i32 {   /* p->arrfield[i].subfield : ptr/embedded-struct array-element field READ -- lookahead past ] for a . */
                        let mut q:u32=C+1u32  let mut dd:i32=0i32  let mut gg:u32=1u32  while gg==1u32 { if ispat(q,Q_LBR)==1u32 {dd=dd+1i32} else { if ispat(q,Q_RBR)==1u32 { if dd==0i32 {gg=0u32} else {dd=dd-1i32} } }  if TK[q as u64]==0u32 {gg=0u32}  if gg==1u32 {q=q+1u32} }
                        if ispat(q+1u32,Q_DOT)==1u32 {
                            let esz:i64=STSZ[elt as u64] as i64  let sub:u32=q+2u32  let soff:i64=fieldoff(elt,sub)  let se:i64=fieldelem(elt,sub)  let ssg:u32=fieldsign(elt,sub)
                            C=C+1u32  ebin(0u32)  eat(Q_RBR)  estride(esz)  emit_lget(lidx(t) as u32)  if foff>0i64 {econst(foff) eb(0x20u32)}  if fieldisarr(ptt,ft)==0u32 { if fe==8i64 {eb(0x82u32)} }  eb(0x20u32)  if soff>0i64 {econst(soff) eb(0x20u32)}   /* (i*STSZ) + [(p+foff) if INLINE array / *(p+foff) if pointer field] + soff */
                            C=C+2u32  let spt:i32=fieldpt(elt,sub)  if spt>=0i32 { if cp(Q_DOT)==1u32 { let mut curn:i32=spt  let mut gcn:u32=1u32  while gcn==1u32 { C=C+1u32  let nfn:u32=C  C=C+1u32  let nfon:i64=fieldoff(curn,nfn)  if nfon>0i64 {econst(nfon) eb(0x20u32)}  let nptn:i32=fieldpt(curn,nfn)  let mut moren:u32=0u32  if nptn>=0i32 { if cp(Q_DOT)==1u32 {moren=1u32} }  if moren==1u32 {curn=nptn} else { eload(fieldelem(curn,nfn), fieldsign(curn,nfn))  gcn=0u32 } }  return } }   /* p->arr[i].sub.subsub.. : `sub` is itself a struct + more DOTs -> continue the member chain (cg->locals[i].name.len) */
                            if cp(Q_LBR)==1u32 { C=C+1u32  ebin(0u32)  eat(Q_RBR)  estride(se)  eb(0x20u32) }   /* p->arrfield[i].subARRAYfield[k] : + k*subelem -- the seed's ast->hashcons[i].mhash[k] (else `[k]` left -> loads mhash[0] always + dangling token) */
                            eload(se, ssg)  return
                        }
                    }
                    C=C+1u32  ebin(0u32)  eat(Q_RBR)  estride(fe)  emit_lget(lidx(t) as u32)  eb(0x20u32)  if foff>0i64 {econst(foff) eb(0x20u32)}
                    if cp(Q_INC)==1u32 { C=C+1u32  pinc_mem(fe,fsg,fm,0u32,1u32)  return }  if cp(Q_DEC)==1u32 { C=C+1u32  pinc_mem(fe,fsg,fm,1u32,1u32)  return }   /* p->field[i]++ */
                    eload(fe, fsg)  return }
                if fieldisarr(ptt,ft)==1u32 { emit_lget(lidx(t) as u32)  if foff>0i64 {econst(foff) eb(0x20u32)}  return }   /* bare array field -> p+foff (decay) */
                emit_lget(lidx(t) as u32)  if foff>0i64 { econst(foff)  eb(0x20u32) }
                if cp(Q_INC)==1u32 { C=C+1u32  pinc_mem(fe,fsg,fm,0u32,1u32)  return }  if cp(Q_DEC)==1u32 { C=C+1u32  pinc_mem(fe,fsg,fm,1u32,1u32)  return }   /* p->field++ */
                eload(fe, fsg)  return }
        }
        if kw(t,"true" as u64,4u32)==1u32 { econst(1i64)  return }  if kw(t,"false" as u64,5u32)==1u32 { econst(0i64)  return }  if kw(t,"NULL" as u64,4u32)==1u32 { econst(0i64)  return }   /* bool / null literals */
        if kw(t,"UINT8_MAX" as u64,9u32)==1u32 { econst(255i64)  return }  if kw(t,"UINT16_MAX" as u64,10u32)==1u32 { econst(65535i64)  return }  if kw(t,"UINT32_MAX" as u64,10u32)==1u32 { econst(4294967295i64)  return }  if kw(t,"UINT64_MAX" as u64,10u32)==1u32 { econst(0i64-1i64)  return }  if kw(t,"SIZE_MAX" as u64,8u32)==1u32 { econst(0i64-1i64)  return }   /* stdint limit macros (ccsv ignores <stdint.h>) */
        if kw(t,"INT8_MAX" as u64,8u32)==1u32 { econst(127i64)  return }  if kw(t,"INT16_MAX" as u64,9u32)==1u32 { econst(32767i64)  return }  if kw(t,"INT32_MAX" as u64,9u32)==1u32 { econst(2147483647i64)  return }  if kw(t,"INT32_MIN" as u64,9u32)==1u32 { econst(0i64-2147483648i64)  return }  if kw(t,"INT_MAX" as u64,7u32)==1u32 { econst(2147483647i64)  return }  if kw(t,"INT_MIN" as u64,7u32)==1u32 { econst(0i64-2147483648i64)  return }
        let ad:i64=abase(t)  if ad>=0i64 { let lck:i32=lidx(t)  if lck<0i32 {   /* (a shadowing local wins -> fall through to lidx) */
            if aisc(t)==1u32 { econst(ad)  eload(aesize(t), asign(t)) } else { econst(ad) }  return } }   /* global SCALAR -> LOAD value ; bare array -> &arr[0] (decay) */
        let ci:i32=cidx(t)  if ci>=0i32 { econst(CNV[ci as u64])  return }   /* enum member / #define constant */
        let dcv:i64=dcm_resolve(t)  if dcv>=0i64 { econst(dcv)  return }   /* array-count macro N = sizeof(ARR)/sizeof(ARR[0]) -> ALEN(ARR) */
        let li:i32=lidx(t)  if li>=0i32 {
            let svt:i32=LVT[li as u64]  if svt>=0i32 { let ssz:u64=STSZ[svt as u64]  if ssz<=8u64 { emit_vbase(t, 0i64)  eb(0x82u32)  return } else { if SRET_ON==1u32 { emit_vbase(t, 0i64)  return } } }   /* bare struct-VALUE used as a value (frame-aware): <=8B -> LOAD64 packed bytes ; >8B (SRET_ON) -> push its ADDRESS (pass-by-pointer arg; the callee's aliased struct-ptr param derefs) */
            if cp(Q_INC)==1u32 { C=C+1u32  pinc_local(li as u32,0u32,1u32)  return }   /* i++ (postfix) */
            if cp(Q_DEC)==1u32 { C=C+1u32  pinc_local(li as u32,1u32,1u32)  return }   /* i-- (postfix) */
            emit_lget(li as u32) } else { let fnv:i32=fidx(t)  if fnv>=0i32 { econst(fnv as i64) } }   /* fn-ptr INC-1: a function NAME used as a VALUE (not called) -> CONST(fidx) ; locals/globals/enums checked first so they shadow it ; builtins have fidx<0 -> unchanged */
        return
    }
    C=C+1u32
}
/* logical && : LHS truthiness already on the stack ; fold `&& rhs` LEFT-assoc with SHORT-CIRCUIT (rhs only
 * evaluated when LHS is true).  rhs is a bitwise-or expression (ebin(2)) -- && binds looser than every binop. */
fn eland_tail() {
    while cp(Q_LAND)==1u32 {
        C=C+1u32  let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}
        eb(0x42u32)                                     /* IF (pops LHS ; nonzero = true) */
        ebin(2u32)  econst(0i64)  eb(0x31u32)  eu8(0x11u32,tmp)   /* tmp = (rhs != 0) -> 0/1 */
        eb(0x43u32)  econst(0i64)  eu8(0x11u32,tmp)     /* ELSE tmp = 0 (short-circuit) */
        eb(0x44u32)  eu8(0x10u32,tmp)                   /* END ; result on stack (new LHS for chaining) */
    }
}
/* logical || : LHS on the stack ; fold `|| rhs` LEFT-assoc with SHORT-CIRCUIT.  rhs is an &&-expression
 * (ebin(2) + eland_tail) since && binds tighter than ||. */
fn elor_tail() {
    while cp(Q_LOR)==1u32 {
        C=C+1u32  let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}
        eb(0x42u32)                                     /* IF (LHS true) */
        econst(1i64)  eu8(0x11u32,tmp)                  /* tmp = 1 (short-circuit) */
        eb(0x43u32)                                     /* ELSE */
        ebin(2u32)  eland_tail()  econst(0i64)  eb(0x31u32)  eu8(0x11u32,tmp)   /* tmp = (rhs != 0) */
        eb(0x44u32)  eu8(0x10u32,tmp)                   /* END ; result */
    }
}
fn ebin(minp: u32) {
    if minp==0u32 { if TK[C as u64]==1u32 { if TK[(C+1u32) as u64]==3u32 { if TV[(C+1u32) as u64]==Q_ASN {   /* NAME = rhs : assignment EXPRESSION (a=b=c, while((c=x)), f(c=x)) -- only a SIMPLE local lvalue */
        let t:u32=C  let li:i32=lidx(t)  if li>=0i32 {
            C=C+2u32  ebin(0u32)                                  /* rhs (right-assoc -> a=b=c folds correctly) */
            let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}
            eu8(0x11u32,tmp)  eu8(0x10u32,tmp)  emit_lset(li as u32)  eu8(0x10u32,tmp)  return   /* tmp=rhs (decouple value from spill store) ; store ; leave value */
        }
    } } } }
    if minp==0u32 { if TK[C as u64]==1u32 { if ispat(C+1u32,Q_ARROW)==1u32 { if TK[(C+2u32) as u64]==1u32 { if ispat(C+3u32,Q_ASN)==1u32 {   /* s->field = rhs : pointer-field assignment EXPRESSION -> store AND LEAVE the value (so chains `a->x = b->y = v` fold) */
        let pt:i32=lpt(C)  let li2:i32=lidx(C)  if pt>=0i32 { if li2>=0i32 {
            let foff:i64=fieldoff(pt,C+2u32)  let fe:i64=fieldelem(pt,C+2u32)  let fm:i64=fieldmask(pt,C+2u32)
            emit_lget(li2 as u32)  if foff>0i64 {econst(foff)  eb(0x20u32)}   /* addr = s + foff */
            C=C+4u32  ebin(0u32)                                              /* rhs (right-assoc recurse) */
            if fm!=0i64 {econst(fm)  eb(0x25u32)}                             /* field width mask */
            let tmp2:u32=LN  if LN<255u32 {LN=LN+1u32}
            eu8(0x11u32,tmp2)  eu8(0x10u32,tmp2)  estore(fe)  eu8(0x10u32,tmp2)  return   /* SET tmp; GET tmp; STORE; GET tmp -> store + leave value */
        } }
    } } } } }
    if minp==0u32 { if TK[C as u64]==1u32 { if ispat(C+1u32,Q_DOT)==1u32 { if TK[(C+2u32) as u64]==1u32 { if ispat(C+3u32,Q_ASN)==1u32 {   /* v.field = rhs : struct-VALUE field assignment EXPRESSION -> store AND LEAVE the value (chains `out.a = out.b = v` fold; the seed's iiip_node_pos `out.start = out.end = .. = 0`).  The DOT complement of the s->field handler above. */
        let vt:i32=avtype(C)  if vt>=0i32 {
            let foff:i64=fieldoff(vt,C+2u32)  let fe:i64=fieldelem(vt,C+2u32)  let fm:i64=fieldmask(vt,C+2u32)
            emit_vbase(C, foff)                                              /* addr = base + foff (frame-aware, Boss-2) */
            C=C+4u32  ebin(0u32)                                             /* rhs (right-assoc recurse -> the chain folds) */
            if fm!=0i64 {econst(fm)  eb(0x25u32)}                            /* field width mask */
            let tmp3:u32=LN  if LN<255u32 {LN=LN+1u32}
            eu8(0x11u32,tmp3)  eu8(0x10u32,tmp3)  estore(fe)  eu8(0x10u32,tmp3)  return   /* SET tmp; GET tmp; STORE; GET tmp -> store + leave value */
        }
    } } } } }
    eprim()  let mut go:u32=1u32
    while go==1u32 {
        if TK[C as u64]!=3u32 { go=0u32 }
        else { let p:i64=TV[C as u64]  let pr:u32=prec(p)
            if pr==0u32 { go=0u32 } else { if pr<minp { go=0u32 } else { C=C+1u32  ebin(pr+1u32)  eb(opc(p)) } } }
    }
    if minp==0u32 {
        eland_tail()                                     /* && (binds tighter than ||) */
        elor_tail()                                      /* || */
        if cp(Q_QUEST)==1u32 {            /* cond ? a : b (lowest prec, right-assoc) */
        let tmp:u32=LN  if LN<255u32 { LN=LN+1u32 }   /* fresh temp local carries the value across the join */
        C=C+1u32  eb(0x42u32)                         /* cond ; IF (void block) */
        ebin(0u32)  eu8(0x11u32,tmp)                  /* then: a ; LOCAL_SET tmp */
        eb(0x43u32)  eat(Q_COLON)                     /* ELSE */
        ebin(0u32)  eu8(0x11u32,tmp)                  /* else: b ; LOCAL_SET tmp */
        eb(0x44u32)  eu8(0x10u32,tmp)                 /* END ; LOCAL_GET tmp -> result */
    } }
}

fn for_init() {   /* the for-loop's init clause (no trailing ;): `T i=0[, j=1]` or `i=0[, j=1]` or an expression (comma-separated) */
    let mut isdecl:u32=is_type_start(C)                              /* detect a decl BEFORE skipquals (which eats unsigned/signed/long/short -- they are isqual) ; is_type_start sees dtype/qual/unsigned/struct/struct-typedef */
    if isdecl==0u32 { if is_label_kw(C)==0u32 { if TK[C as u64]==1u32 { if ispat(C+1u32,Q_MUL)==1u32 { if stidx(C)<0i32 { if lidx(C)<0i32 { let abq:i64=abase(C)  let ciq:i32=cidx(C)  if abq<0i64 { if ciq<0i32 { isdecl=1u32 } } } } } } } }   /* opaque typedef pointer `T *name` (the seed's `const iii_chunk_t *c` after const-skip, or a bare struct-alias ptr) */
    if isdecl==1u32 {
        let mut sgn:i32=0i32-1i32  if kw(C,"unsigned" as u64,8u32)==1u32 {sgn=0i32} else { if kw(C,"signed" as u64,6u32)==1u32 {sgn=1i32} }   /* capture sign before skipquals discards it */
        skipquals()
        let mut bsz:i64=4i64  let mut tym:i64=4294967295i64  let mut bsg:u32=0u32  let mut stid:i32=0i32-1i32   /* stid = base struct index (for `T *c` -> LPT, so c->field resolves) */
        if dtype(C)==1u32 { bsz=type_size(C)  tym=type_mask(C)  bsg=type_signed(C)  C=C+1u32 }
        else { if TK[C as u64]==1u32 { let nx:u32=C+1u32  if ispat(nx,Q_MUL)==1u32 { stid=stidx(C)  if stid>=0i32 { bsz=type_size(C)  tym=type_mask(C)  bsg=type_signed(C) } else { bsz=8i64  tym=0i64 }  C=C+1u32 }   /* `Typedef *name` : base is the typedef (struct -> its size+stid ; opaque -> 8B pointee) */
            else { if TK[nx as u64]==1u32 { stid=stidx(C)  bsz=type_size(C)  tym=type_mask(C)  bsg=type_signed(C)  C=C+1u32 } } } }   /* `Typedef name` (value) : two adjacent identifiers -> the first is the base type */
        if sgn>=0i32 { bsg=sgn as u32 }
        let mut more:u32=1u32
        while more==1u32 { let mut isp:u32=0u32  while cp(Q_MUL)==1u32 { isp=1u32  C=C+1u32 }   /* `T *p` pointer declarator in the for-init */
            let nt:u32=C  C=C+1u32  let s:u32=ladd(nt)
            if isp==1u32 { LW[s as u64]=0i64  LSZ[s as u64]=8i64  LSG[s as u64]=0u32  LPSZ[s as u64]=bsz  LPSG[s as u64]=bsg  if stid>=0i32 { LPT[s as u64]=stid } } else { LW[s as u64]=tym  LSZ[s as u64]=bsz  LSG[s as u64]=bsg }   /* set LPT for a struct-typedef pointer -> `c->field` resolves */
            if cp(Q_ASN)==1u32 { C=C+1u32  ebin(0u32)  emit_lset(s) }
            if cp(Q_COM)==1u32 { C=C+1u32  more=1u32 } else { more=0u32 } }
        return }
    let mut m2:u32=1u32
    while m2==1u32 {
        if TK[C as u64]==1u32 { if ispat(C+1u32,Q_ASN)==1u32 { let nt:u32=C  C=C+2u32  ebin(0u32)  let li:i32=lidx(nt)  if li>=0i32 { emit_lset(li as u32) } } else { ebin(0u32)  eb(0x72u32) } } else { ebin(0u32)  eb(0x72u32) }
        if cp(Q_COM)==1u32 { C=C+1u32  m2=1u32 } else { m2=0u32 }
    }
}
fn one_incr() {   /* one for-incr clause: i++ / i-- / i = e / expr */
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_INC)==1u32 { let nt:u32=C  let li:i32=lidx(nt)  if li>=0i32 { emit_lget(li as u32)  econst(1i64)  eb(0x20u32)  emit_lset(li as u32) }  C=C+2u32  return } }
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_DEC)==1u32 { let nt:u32=C  let li:i32=lidx(nt)  if li>=0i32 { emit_lget(li as u32)  econst(1i64)  eb(0x21u32)  emit_lset(li as u32) }  C=C+2u32  return } }
    if TK[C as u64]==1u32 { if ispat(C+1u32,Q_ASN)==1u32 { let nt:u32=C  C=C+2u32  ebin(0u32)  let li:i32=lidx(nt)  if li>=0i32 { emit_lset(li as u32) }  return } }
    ebin(0u32)  eb(0x72u32)
}
fn emit_for_incr() { one_incr()  while cp(Q_COM)==1u32 { C=C+1u32  one_incr() } }   /* comma-separated incr clauses */
/* the lvalue ADDRESS is already on the stack; consume `= rhs` or `op= rhs` and emit the store (esz=elem byte size,
 * mask=width mask or 0).  Compound uses a fresh temp so the address is computed once: SET tmp; GET(store-addr);
 * GET;LOAD(cur val); rhs; OP; [mask]; STORE. */
fn emit_av(esz:i64, sgn:u32, mask:i64) {
    let sgv:u32=sgn                                              /* bind the single-use param to a local -> forces spill (param-spill family) */
    let op:i64=TV[C as u64]
    if op==Q_ASN { C=C+1u32  ebin(0u32)  if mask!=0i64 {econst(mask)  eb(0x25u32)}  estore(esz) }
    else {
        let mut isinc:u32=0u32  if op==Q_INC {isinc=1u32}  if op==Q_DEC {isinc=1u32}   /* lvalue++ / lvalue-- (no RHS) vs op= (RHS) */
        if isinc==1u32 { C=C+1u32 } else { C=C+2u32 }
        let tmp:u32=LN  if LN<255u32 {LN=LN+1u32}
        eu8(0x11u32,tmp)  eu8(0x10u32,tmp)  eu8(0x10u32,tmp)
        eload(esz, sgv)
        if isinc==1u32 { econst(1i64)  if op==Q_INC {eb(0x20u32)} else {eb(0x21u32)} }   /* +1 / -1 */
        else { ebin(0u32)  eb(opc(op)) }
        if mask!=0i64 {econst(mask)  eb(0x25u32)}
        estore(esz)
    }
}
/* a switch case constant: an integer/char literal (TK==2 -> TV) or an enum/#define name (cidx -> CNV). */
fn swconst(q:u32) -> i64 { if TK[q as u64]==2u32 { return TV[q as u64] }  let ci:i32=cidx(q)  if ci>=0i32 { return CNV[ci as u64] }  return 0i64 }
/* keywords that can never be a goto-label name (so `IDENT :` after them is case/ternary/decl, not a label). */
fn is_label_kw(t:u32) -> u32 {
    if kw(t,"case" as u64,4u32)==1u32 {return 1u32}  if kw(t,"default" as u64,7u32)==1u32 {return 1u32}  if kw(t,"goto" as u64,4u32)==1u32 {return 1u32}  if dtype(t)==1u32 {return 1u32}  if isqual(t)==1u32 {return 1u32}
    if kw(t,"if" as u64,2u32)==1u32 {return 1u32}  if kw(t,"else" as u64,4u32)==1u32 {return 1u32}  if kw(t,"while" as u64,5u32)==1u32 {return 1u32}  if kw(t,"for" as u64,3u32)==1u32 {return 1u32}  if kw(t,"do" as u64,2u32)==1u32 {return 1u32}  if kw(t,"switch" as u64,6u32)==1u32 {return 1u32}  if kw(t,"return" as u64,6u32)==1u32 {return 1u32}  if kw(t,"break" as u64,5u32)==1u32 {return 1u32}
    if kw(t,"struct" as u64,6u32)==1u32 {return 1u32}  if kw(t,"union" as u64,5u32)==1u32 {return 1u32}  if kw(t,"enum" as u64,4u32)==1u32 {return 1u32}  if kw(t,"typedef" as u64,7u32)==1u32 {return 1u32}  if kw(t,"sizeof" as u64,6u32)==1u32 {return 1u32}
    return 0u32
}
