    if CLOVF==1u32 { pstr("// FATAL ccsv: a >8B compound literal in a non-direct context (ternary/arg) needs a temp+address path not yet built -- refused rather than emit a silently-corrupted value.\n!!!CCSV_COMPOUND_LITERAL_OVERFLOW!!!\n" as u64)  return 9u64 }   /* LOUD: the Latent-Axiom Guillotine -- a future seed edit that uses an unsupported >8B compound literal fails the BUILD, never a corrupted binary */
    emit_module()
    return 0u64
}
