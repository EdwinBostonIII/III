                    let mut fsz:u64=fesz as u64  if isarr==1u32 { if TK[(ffq+2u32) as u64]==2u32 { fsz=(TV[(ffq+2u32) as u64] as u64)*(fesz as u64) } }
                    if fsz>maxsz {maxsz=fsz}
                    SFN=SFN+1u32  nf=nf+1u32  if is_union==0u32 {off=off+fsz}
                    let mut g4:u32=1u32  while g4==1u32 { if ispat(q,Q_SEMI)==1u32 {g4=0u32} else { if TK[q as u64]==0u32 {g4=0u32} else {q=q+1u32} } }  q=q+1u32
                } else { q=q+1u32 }
