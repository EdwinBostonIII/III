/* iiisv.iii -- an INDEPENDENT .iii -> SVIR compiler (lexer + recursive-descent parser + single-pass lowerer).
 * Shares ZERO code with cg_r3 -- so it is both (a) the path that makes REAL .iii source host-agnostic via SVIR,
 * and (b) the diverse front-end Diverse Double-Compilation needs (its x86 output vs cg_r3's agree only if neither
 * has a codegen backdoor; the gcc-built seed remains the last hurdle).
 *
 * Subset (the integer core): module ; fn NAME(p: T, ...) -> T { ... } ; let [mut] x : T = e ; x = e ;
 *   if e { } [else { }] ; while e { } ; return e ; calls.  Expr: + - * / % & | ^ << >> == != < > <= >= ,
 *   parens, integer literals (uNN/iNN suffix skipped), locals, calls.  All types lowered to i64.
 * Reads argv[1] (.iii file); emits a .iii module wrapping SVIR v1 bytes (consumed by svir_x86 / svir_wasm).
 * main() is forced to SVIR func 0 (the translators' entry). */
module iiisv

extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fread(buf: u64, size: u64, n: u64, stream: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(stream: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"

var SRC : [u8; 65536]
var SLEN : u64 = 0u64
var MODE_RB : [u8; 3] = [114u8, 98u8, 0u8]

var TK_KIND : [u32; 8192]
var TK_VAL  : [i64; 8192]
var TK_OFF  : [u32; 8192]
var TK_LEN  : [u32; 8192]
var NTOK : u32 = 0u32
var TP : u32 = 0u32

/* PUNCT ids */
const PU_LP:i64=1i64  const PU_RP:i64=2i64  const PU_LB:i64=3i64  const PU_RB:i64=4i64  const PU_COL:i64=5i64
const PU_COM:i64=6i64 const PU_SEMI:i64=7i64 const PU_ASSIGN:i64=8i64 const PU_ARROW:i64=9i64 const PU_EQ:i64=10i64
const PU_NE:i64=11i64 const PU_LT:i64=12i64  const PU_GT:i64=13i64  const PU_LE:i64=14i64  const PU_GE:i64=15i64
const PU_ADD:i64=16i64 const PU_SUB:i64=17i64 const PU_MUL:i64=18i64 const PU_DIV:i64=19i64 const PU_MOD:i64=20i64
const PU_AND:i64=21i64 const PU_OR:i64=22i64  const PU_XOR:i64=23i64 const PU_SHL:i64=24i64 const PU_SHR:i64=25i64
const PU_ANDAND:i64=26i64 const PU_OROR:i64=27i64 const PU_LBR:i64=28i64 const PU_RBR:i64=29i64

fn is_sp(c: u32) -> u32 { if c == 32u32 { return 1u32 } if c == 9u32 { return 1u32 } if c == 10u32 { return 1u32 } if c == 13u32 { return 1u32 } return 0u32 }
fn is_dig(c: u32) -> u32 { if c >= 48u32 { if c <= 57u32 { return 1u32 } } return 0u32 }
fn is_idc(c: u32) -> u32 { if c == 95u32 { return 1u32 } if c >= 48u32 { if c <= 57u32 { return 1u32 } } if c >= 65u32 { if c <= 90u32 { return 1u32 } } if c >= 97u32 { if c <= 122u32 { return 1u32 } } return 0u32 }
fn is_ids(c: u32) -> u32 { if c == 95u32 { return 1u32 } if c >= 65u32 { if c <= 90u32 { return 1u32 } } if c >= 97u32 { if c <= 122u32 { return 1u32 } } return 0u32 }
fn sbyte(i: u64) -> u32 { let p : *u8 = ((&SRC as u64) + i) as *u8  return p[0u64] as u32 }
fn add_tok(kind: u32, val: i64, off: u32, len: u32) { if NTOK < 8192u32 { TK_KIND[NTOK as u64] = kind  TK_VAL[NTOK as u64] = val  TK_OFF[NTOK as u64] = off  TK_LEN[NTOK as u64] = len  NTOK = NTOK + 1u32 } }

fn lex() {
    NTOK = 0u32
    let mut i : u64 = 0u64
    while i < SLEN {
        let c : u32 = sbyte(i)
        if is_sp(c) == 1u32 { i = i + 1u64 }
        else { if c == 47u32 {
            let c2 : u32 = sbyte(i + 1u64)
            if c2 == 47u32 { i = i + 2u64  let mut g : u32 = 1u32  while g == 1u32 { if i >= SLEN { g = 0u32 } else { if sbyte(i) == 10u32 { g = 0u32 } else { i = i + 1u64 } } } }
            else { if c2 == 42u32 { i = i + 2u64  let mut g : u32 = 1u32  while g == 1u32 { if i >= SLEN { g = 0u32 } else { if sbyte(i) == 42u32 { if sbyte(i + 1u64) == 47u32 { i = i + 2u64  g = 0u32 } else { i = i + 1u64 } } else { i = i + 1u64 } } } }
            else { add_tok(3u32, PU_DIV, 0u32, 0u32)  i = i + 1u64 } }
        }
        else { if is_ids(c) == 1u32 {
            let off : u64 = i  let mut g : u32 = 1u32
            while g == 1u32 { if i >= SLEN { g = 0u32 } else { if is_idc(sbyte(i)) == 1u32 { i = i + 1u64 } else { g = 0u32 } } }
            add_tok(1u32, 0i64, off as u32, (i - off) as u32)
        }
        else { if is_dig(c) == 1u32 {
            let mut v : i64 = 0i64  let mut g : u32 = 1u32
            while g == 1u32 { if i >= SLEN { g = 0u32 } else { if is_dig(sbyte(i)) == 1u32 { v = (v * 10i64) + ((sbyte(i) - 48u32) as i64)  i = i + 1u64 } else { g = 0u32 } } }
            let mut g2 : u32 = 1u32
            while g2 == 1u32 { if i >= SLEN { g2 = 0u32 } else { if is_idc(sbyte(i)) == 1u32 { i = i + 1u64 } else { g2 = 0u32 } } }
            add_tok(2u32, v, 0u32, 0u32)
        }
        else {
            let c2 : u32 = sbyte(i + 1u64)
            let mut adv : u32 = 0u32
            if c == 45u32 { if c2 == 62u32 { add_tok(3u32, PU_ARROW, 0u32, 0u32)  adv = 2u32 } else { add_tok(3u32, PU_SUB, 0u32, 0u32)  adv = 1u32 } }
            if c == 61u32 { if c2 == 61u32 { add_tok(3u32, PU_EQ, 0u32, 0u32)  adv = 2u32 } else { add_tok(3u32, PU_ASSIGN, 0u32, 0u32)  adv = 1u32 } }
            if c == 33u32 { if c2 == 61u32 { add_tok(3u32, PU_NE, 0u32, 0u32)  adv = 2u32 } else { adv = 1u32 } }
            if c == 60u32 { if c2 == 61u32 { add_tok(3u32, PU_LE, 0u32, 0u32)  adv = 2u32 } else { if c2 == 60u32 { add_tok(3u32, PU_SHL, 0u32, 0u32)  adv = 2u32 } else { add_tok(3u32, PU_LT, 0u32, 0u32)  adv = 1u32 } } }
            if c == 62u32 { if c2 == 61u32 { add_tok(3u32, PU_GE, 0u32, 0u32)  adv = 2u32 } else { if c2 == 62u32 { add_tok(3u32, PU_SHR, 0u32, 0u32)  adv = 2u32 } else { add_tok(3u32, PU_GT, 0u32, 0u32)  adv = 1u32 } } }
            if c == 38u32 { if c2 == 38u32 { add_tok(3u32, PU_ANDAND, 0u32, 0u32)  adv = 2u32 } else { add_tok(3u32, PU_AND, 0u32, 0u32)  adv = 1u32 } }
            if c == 124u32 { if c2 == 124u32 { add_tok(3u32, PU_OROR, 0u32, 0u32)  adv = 2u32 } else { add_tok(3u32, PU_OR, 0u32, 0u32)  adv = 1u32 } }
            if c == 40u32 { add_tok(3u32, PU_LP, 0u32, 0u32)  adv = 1u32 }
            if c == 41u32 { add_tok(3u32, PU_RP, 0u32, 0u32)  adv = 1u32 }
            if c == 123u32 { add_tok(3u32, PU_LB, 0u32, 0u32)  adv = 1u32 }
            if c == 125u32 { add_tok(3u32, PU_RB, 0u32, 0u32)  adv = 1u32 }
            if c == 58u32 { add_tok(3u32, PU_COL, 0u32, 0u32)  adv = 1u32 }
            if c == 44u32 { add_tok(3u32, PU_COM, 0u32, 0u32)  adv = 1u32 }
            if c == 43u32 { add_tok(3u32, PU_ADD, 0u32, 0u32)  adv = 1u32 }
            if c == 42u32 { add_tok(3u32, PU_MUL, 0u32, 0u32)  adv = 1u32 }
            if c == 37u32 { add_tok(3u32, PU_MOD, 0u32, 0u32)  adv = 1u32 }
            if c == 94u32 { add_tok(3u32, PU_XOR, 0u32, 0u32)  adv = 1u32 }
            if c == 59u32 { add_tok(3u32, PU_SEMI, 0u32, 0u32)  adv = 1u32 }
            if c == 91u32 { add_tok(3u32, PU_LBR, 0u32, 0u32)  adv = 1u32 }
            if c == 93u32 { add_tok(3u32, PU_RBR, 0u32, 0u32)  adv = 1u32 }
            if adv == 0u32 { adv = 1u32 }
            i = i + (adv as u64)
        } } } }
    }
    add_tok(0u32, 0i64, 0u32, 0u32)
}

fn names_eq(o1: u32, l1: u32, o2: u32, l2: u32) -> u32 {
    if l1 != l2 { return 0u32 }
    let mut j : u32 = 0u32
    while j < l1 { if sbyte((o1 + j) as u64) != sbyte((o2 + j) as u64) { return 0u32 }  j = j + 1u32 }
    return 1u32
}
fn tok_kw(t: u32, s: u64, n: u32) -> u32 {
    if TK_KIND[t as u64] != 1u32 { return 0u32 }
    if TK_LEN[t as u64] != n { return 0u32 }
    let mut j : u32 = 0u32
    while j < n { let sp : *u8 = (s + (j as u64)) as *u8  if sbyte((TK_OFF[t as u64] + j) as u64) != (sp[0u64] as u32) { return 0u32 }  j = j + 1u32 }
    return 1u32
}
fn cur_punct(p: i64) -> u32 { if TK_KIND[TP as u64] == 3u32 { if TK_VAL[TP as u64] == p { return 1u32 } }  return 0u32 }
fn eat(p: i64) -> u32 { if cur_punct(p) == 1u32 { TP = TP + 1u32  return 1u32 }  return 0u32 }

var FN_OFF : [u32; 256]
var FN_LEN : [u32; 256]
var FN_PARAMS : [u32; 256]
var FN_TOK : [u32; 256]
var FN_NF : u32 = 0u32
fn fn_index(t: u32) -> i32 {
    let mut k : u32 = 0u32
    while k < FN_NF { if names_eq(FN_OFF[k as u64], FN_LEN[k as u64], TK_OFF[t as u64], TK_LEN[t as u64]) == 1u32 { return k as i32 }  k = k + 1u32 }
    return 0i32 - 1i32
}

/* module-level arrays -> SVIR linear memory (var NAME : [T; SIZE]) */
var ARR_OFF : [u32; 64]
var ARR_LEN : [u32; 64]
var ARR_BASE : [u64; 64]
var ARR_N : u32 = 0u32
var MEM_TOP : u64 = 0u64
fn arr_base(t: u32) -> i64 {   /* base offset if t names an array, else -1 */
    let mut k : u32 = 0u32
    while k < ARR_N { if names_eq(ARR_OFF[k as u64], ARR_LEN[k as u64], TK_OFF[t as u64], TK_LEN[t as u64]) == 1u32 { return ARR_BASE[k as u64] as i64 }  k = k + 1u32 }
    return 0i64 - 1i64
}

/* module-level constants (const NAME : T = LIT) -> compile-time literal substitution at reference sites */
var CON_OFF : [u32; 128]
var CON_LEN : [u32; 128]
var CON_VAL : [i64; 128]
var CON_N : u32 = 0u32
fn con_index(t: u32) -> i32 {
    let mut k : u32 = 0u32
    while k < CON_N { if names_eq(CON_OFF[k as u64], CON_LEN[k as u64], TK_OFF[t as u64], TK_LEN[t as u64]) == 1u32 { return k as i32 }  k = k + 1u32 }
    return 0i32 - 1i32
}

var LOC_OFF : [u32; 256]
var LOC_LEN : [u32; 256]
var LOC_N : u32 = 0u32
fn loc_index(t: u32) -> i32 {
    let mut k : u32 = 0u32
    while k < LOC_N { if names_eq(LOC_OFF[k as u64], LOC_LEN[k as u64], TK_OFF[t as u64], TK_LEN[t as u64]) == 1u32 { return k as i32 }  k = k + 1u32 }
    return 0i32 - 1i32
}
fn loc_add(t: u32) -> u32 { let s : u32 = LOC_N  if LOC_N < 256u32 { LOC_OFF[LOC_N as u64] = TK_OFF[t as u64]  LOC_LEN[LOC_N as u64] = TK_LEN[t as u64]  LOC_N = LOC_N + 1u32 }  return s }

var BODY : [u8; 16384]
var BLEN : u64 = 0u64
fn eb(b: u32) { if BLEN < 16384u64 { BODY[BLEN] = (b & 0xFFu32) as u8  BLEN = BLEN + 1u64 } }
/* SV_LAST_OP = the last OPCODE emitted into BODY (operand bytes via eb do NOT change it).  compile_fn uses it to
 * emit the trailing default return ONLY on fall-through -- so a function already ending in an unconditional RETURN
 * (0x60) gets no dead trailing return, making iiisv's SVIR byte-identical to ccsv's (the cross-language DDC). */
var SV_LAST_OP : u32 = 0u32
fn e_const(v: i64) { SV_LAST_OP = 0x01u32  eb(0x01u32)  let mut k : u32 = 0u32  while k < 8u32 { eb(((v as u64) >> (8u64 * (k as u64))) as u32)  k = k + 1u32 } }
fn e_op(o: u32) { SV_LAST_OP = o  eb(o) }
fn e_u8(o: u32, a: u32) { SV_LAST_OP = o  eb(o)  eb(a) }
fn e_call(f: u32, ac: u32) { SV_LAST_OP = 0x70u32  eb(0x70u32)  eb(f)  eb(ac) }

var MOD : [u8; 32768]
var MLEN : u64 = 0u64
fn mb(b: u32) { if MLEN < 32768u64 { MOD[MLEN] = (b & 0xFFu32) as u8  MLEN = MLEN + 1u64 } }

fn op_prec(p: i64) -> u32 {
    if p == PU_MUL { return 9u32 } if p == PU_DIV { return 9u32 } if p == PU_MOD { return 9u32 }
    if p == PU_ADD { return 8u32 } if p == PU_SUB { return 8u32 }
    if p == PU_SHL { return 7u32 } if p == PU_SHR { return 7u32 }
    if p == PU_LT { return 6u32 } if p == PU_GT { return 6u32 } if p == PU_LE { return 6u32 } if p == PU_GE { return 6u32 }
    if p == PU_EQ { return 5u32 } if p == PU_NE { return 5u32 }
    if p == PU_AND { return 4u32 } if p == PU_XOR { return 3u32 } if p == PU_OR { return 2u32 }
    return 0u32
}
fn op_svir(p: i64) -> u32 {
    if p == PU_MUL { return 0x22u32 } if p == PU_DIV { return 0x23u32 } if p == PU_MOD { return 0x24u32 }
    if p == PU_ADD { return 0x20u32 } if p == PU_SUB { return 0x21u32 }
    if p == PU_SHL { return 0x28u32 } if p == PU_SHR { return 0x29u32 }
    if p == PU_LT { return 0x32u32 } if p == PU_GT { return 0x35u32 } if p == PU_LE { return 0x34u32 } if p == PU_GE { return 0x33u32 }
    if p == PU_EQ { return 0x30u32 } if p == PU_NE { return 0x31u32 }
    if p == PU_AND { return 0x25u32 } if p == PU_XOR { return 0x27u32 } if p == PU_OR { return 0x26u32 }
    return 0u32
}

fn skip_as() { while tok_kw(TP, "as" as u64, 2u32) == 1u32 { TP = TP + 1u32  TP = TP + 1u32 } }   /* `expr as T`: all types lower to i64, so a cast is a no-op (consume `as` + the type token) */
fn parse_atom() {
    if eat(PU_LP) == 1u32 { parse_bin(0u32)  eat(PU_RP)  return }
    if TK_KIND[TP as u64] == 2u32 { e_const(TK_VAL[TP as u64])  TP = TP + 1u32  return }
    if TK_KIND[TP as u64] == 1u32 {
        let t : u32 = TP  TP = TP + 1u32
        if cur_punct(PU_LP) == 1u32 {
            TP = TP + 1u32
            let mut ac : u32 = 0u32
            if cur_punct(PU_RP) == 0u32 {
                parse_bin(0u32)  ac = 1u32
                while cur_punct(PU_COM) == 1u32 { TP = TP + 1u32  parse_bin(0u32)  ac = ac + 1u32 }
            }
            eat(PU_RP)
            let fi : i32 = fn_index(t)
            if fi >= 0i32 { e_call(fi as u32, ac) }
            return
        }
        if cur_punct(PU_LBR) == 1u32 { let ab : i64 = arr_base(t)  if ab >= 0i64 { TP = TP + 1u32  parse_bin(0u32)  eat(PU_RBR)  if ab > 0i64 { e_const(ab)  e_op(0x20u32) }  e_op(0x80u32)  return } }   /* array load: addr=index(+base) ; LOAD8 */
        let li : i32 = loc_index(t)
        if li >= 0i32 { e_u8(0x10u32, li as u32)  return }
        let ci : i32 = con_index(t)
        if ci >= 0i32 { e_const(CON_VAL[ci as u64]) }
        return
    }
    TP = TP + 1u32
}
fn parse_primary() { parse_atom()  skip_as() }
fn parse_bin(minp: u32) {
    parse_primary()
    let mut go : u32 = 1u32
    while go == 1u32 {
        if TK_KIND[TP as u64] != 3u32 { go = 0u32 }
        else {
            let p : i64 = TK_VAL[TP as u64]
            let pr : u32 = op_prec(p)
            if pr == 0u32 { go = 0u32 } else { if pr < minp { go = 0u32 } else { TP = TP + 1u32  parse_bin(pr + 1u32)  e_op(op_svir(p)) } }
        }
    }
}

fn parse_stmt() {
    if tok_kw(TP, "let" as u64, 3u32) == 1u32 {
        TP = TP + 1u32
        if tok_kw(TP, "mut" as u64, 3u32) == 1u32 { TP = TP + 1u32 }
        let nt : u32 = TP  TP = TP + 1u32
        eat(PU_COL)  TP = TP + 1u32
        eat(PU_ASSIGN)
        parse_bin(0u32)
        let s : u32 = loc_add(nt)
        e_u8(0x11u32, s)
        return
    }
    if tok_kw(TP, "return" as u64, 6u32) == 1u32 { TP = TP + 1u32  parse_bin(0u32)  e_op(0x60u32)  return }
    if tok_kw(TP, "if" as u64, 2u32) == 1u32 {
        TP = TP + 1u32  parse_bin(0u32)  e_op(0x42u32)
        parse_block()
        if tok_kw(TP, "else" as u64, 4u32) == 1u32 { TP = TP + 1u32  e_op(0x43u32)  parse_block() }
        e_op(0x44u32)
        return
    }
    if tok_kw(TP, "while" as u64, 5u32) == 1u32 {
        TP = TP + 1u32
        e_op(0x40u32)  e_op(0x41u32)
        parse_bin(0u32)  e_const(0i64)  e_op(0x30u32)  e_u8(0x51u32, 1u32)
        parse_block()
        e_u8(0x50u32, 0u32)
        e_op(0x44u32)  e_op(0x44u32)
        return
    }
    if TK_KIND[TP as u64] == 1u32 { if TK_KIND[(TP + 1u32) as u64] == 3u32 { if TK_VAL[(TP + 1u32) as u64] == PU_LBR {   /* array store: NAME [ index ] = value */
        let nt : u32 = TP  let ab : i64 = arr_base(nt)
        if ab >= 0i64 {
            TP = TP + 2u32  parse_bin(0u32)  eat(PU_RBR)
            if ab > 0i64 { e_const(ab)  e_op(0x20u32) }
            eat(PU_ASSIGN)  parse_bin(0u32)  e_op(0x81u32)
            return
        }
    } } }
    if TK_KIND[TP as u64] == 1u32 { if TK_KIND[(TP + 1u32) as u64] == 3u32 { if TK_VAL[(TP + 1u32) as u64] == PU_ASSIGN {
        let nt : u32 = TP  TP = TP + 2u32  parse_bin(0u32)
        let li : i32 = loc_index(nt)  if li >= 0i32 { e_u8(0x11u32, li as u32) }
        return
    } } }
    parse_bin(0u32)  e_op(0x72u32)
}
fn parse_block() {
    eat(PU_LB)
    let mut go : u32 = 1u32
    while go == 1u32 { if cur_punct(PU_RB) == 1u32 { go = 0u32 } else { if TK_KIND[TP as u64] == 0u32 { go = 0u32 } else { parse_stmt() } } }
    eat(PU_RB)
}

fn count_params(nt: u32) -> u32 {   /* nt = name token; params = commas+1 between (), or 0 if empty */
    let mut q : u32 = nt + 2u32
    if cur_punct_at(q, PU_RP) == 1u32 { return 0u32 }
    let mut np : u32 = 1u32
    let mut go : u32 = 1u32
    while go == 1u32 { if TK_KIND[q as u64] == 0u32 { go = 0u32 } else { if cur_punct_at(q, PU_RP) == 1u32 { go = 0u32 } else { if cur_punct_at(q, PU_COM) == 1u32 { np = np + 1u32 }  q = q + 1u32 } } }
    return np
}
fn cur_punct_at(t: u32, p: i64) -> u32 { if TK_KIND[t as u64] == 3u32 { if TK_VAL[t as u64] == p { return 1u32 } }  return 0u32 }

fn record_fn(ft: u32) {   /* ft = token index of 'fn' */
    let nt : u32 = ft + 1u32
    FN_OFF[FN_NF as u64] = TK_OFF[nt as u64]  FN_LEN[FN_NF as u64] = TK_LEN[nt as u64]
    FN_PARAMS[FN_NF as u64] = count_params(nt)  FN_TOK[FN_NF as u64] = ft
    FN_NF = FN_NF + 1u32
}
fn prescan() {   /* main FIRST (SVIR func 0 = the entry), then the others in source order */
    FN_NF = 0u32
    let mut t : u32 = 0u32
    while t < NTOK { if tok_kw(t, "fn" as u64, 2u32) == 1u32 { if tok_kw(t + 1u32, "main" as u64, 4u32) == 1u32 { record_fn(t) } }  t = t + 1u32 }
    t = 0u32
    while t < NTOK { if tok_kw(t, "fn" as u64, 2u32) == 1u32 { if tok_kw(t + 1u32, "main" as u64, 4u32) == 0u32 { record_fn(t) } }  t = t + 1u32 }
}
fn prescan_arrays() {   /* var NAME : [ T ; SIZE ]  -> assign a base offset in SVIR linear memory */
    ARR_N = 0u32  MEM_TOP = 16u64   /* reserve [0..15] for NULL -- match ccsv's data origin so address 0 is never a real object (cross-language byte-DDC + correct NULL semantics) */
    let mut t : u32 = 0u32
    while t < NTOK {
        if tok_kw(t, "var" as u64, 3u32) == 1u32 {
            let nt : u32 = t + 1u32
            if cur_punct_at(nt + 2u32, PU_LBR) == 1u32 {       /* NAME : [ T ; NUM ] */
                if TK_KIND[(nt + 5u32) as u64] == 2u32 {
                    ARR_OFF[ARR_N as u64] = TK_OFF[nt as u64]  ARR_LEN[ARR_N as u64] = TK_LEN[nt as u64]  ARR_BASE[ARR_N as u64] = MEM_TOP
                    MEM_TOP = MEM_TOP + (TK_VAL[(nt + 5u32) as u64] as u64)
                    ARR_N = ARR_N + 1u32
                }
            }
        }
        t = t + 1u32
    }
}

fn prescan_consts() {   /* const NAME : T = LIT  ->  record name -> literal value (compile-time substitution) */
    CON_N = 0u32
    let mut t : u32 = 0u32
    while t < NTOK {
        if tok_kw(t, "const" as u64, 5u32) == 1u32 {
            let nt : u32 = t + 1u32                       /* const(t) NAME(t+1) :(t+2) T(t+3) =(t+4) NUM(t+5) */
            if TK_KIND[(nt + 4u32) as u64] == 2u32 {
                if CON_N < 128u32 {
                    CON_OFF[CON_N as u64] = TK_OFF[nt as u64]  CON_LEN[CON_N as u64] = TK_LEN[nt as u64]
                    CON_VAL[CON_N as u64] = TK_VAL[(nt + 4u32) as u64]
                    CON_N = CON_N + 1u32
                }
            }
        }
        t = t + 1u32
    }
}

fn compile_fn(fk: u32) {
    TP = FN_TOK[fk as u64]
    TP = TP + 1u32  TP = TP + 1u32        /* fn name */
    eat(PU_LP)
    LOC_N = 0u32
    let mut params : u32 = 0u32
    let mut go : u32 = 1u32
    while go == 1u32 {
        if cur_punct(PU_RP) == 1u32 { go = 0u32 }
        else { if TK_KIND[TP as u64] == 0u32 { go = 0u32 }
        else { let pt : u32 = TP  TP = TP + 1u32  eat(PU_COL)  TP = TP + 1u32  loc_add(pt)  params = params + 1u32  eat(PU_COM) } }
    }
    eat(PU_RP)
    if cur_punct(PU_ARROW) == 1u32 { TP = TP + 1u32  TP = TP + 1u32 }
    let mut sg : u32 = 1u32   /* skip annotation tokens (e.g. @export) between the signature and the body `{` */
    while sg == 1u32 { if TK_KIND[TP as u64] == 0u32 { sg = 0u32 } else { if cur_punct(PU_LB) == 1u32 { sg = 0u32 } else { TP = TP + 1u32 } } }
    BLEN = 0u64   SV_LAST_OP = 0u32
    parse_block()
    /* Trailing default return ONLY on fall-through.  A void fn / fall-through must push 0 (the SVIR CALL convention,
     * svir_verify: depth+1 per call).  When the body already ends in an unconditional RETURN (0x60) the default is
     * dead code; omitting it makes iiisv's SVIR byte-identical to ccsv's for the same algorithm (cross-language DDC). */
    if SV_LAST_OP != 0x60u32 { e_const(0i64)  e_op(0x60u32) }
    mb(params)  mb(1u32)  mb((BLEN & 0xFFu64) as u32)  mb(((BLEN >> 8u64) & 0xFFu64) as u32)
    let mut i : u64 = 0u64  while i < BLEN { mb(BODY[i] as u32)  i = i + 1u64 }
}

fn pcc(c: u32) { putchar((c & 0xFFu32) as i32) }
fn pstr(s: u64) { let mut i : u64 = 0u64  let mut go : u32 = 1u32  while go == 1u32 { let p : *u8 = (s + i) as *u8  let b : u32 = p[0u64] as u32  if b == 126u32 { go = 0u32 } else { pcc(b)  i = i + 1u64 } } }
var DBUF : [u8; 24]
fn pdec(v0: u64) { if v0 == 0u64 { pcc(48u32)  return }  let mut v : u64 = v0  let mut n : u32 = 0u32  while v > 0u64 { DBUF[n as u64] = (48u64 + (v % 10u64)) as u8  n = n + 1u32  v = v / 10u64 }  while n > 0u32 { n = n - 1u32  pcc(DBUF[n as u64] as u32) } }

fn emit_module() {
    let total : u64 = MLEN + 1u64
    pstr("module gen_svir\nvar SVIR : [u8; ~" as u64)  pdec(total)  pstr("] = [\n~" as u64)
    pdec(FN_NF as u64)  pstr("u8~" as u64)
    let mut i : u64 = 0u64
    while i < MLEN { pcc(44u32)  pdec(MOD[i] as u64)  pstr("u8~" as u64)  i = i + 1u64 }
    pstr("\n]\nfn svir_ptr() -> u64 @export { return &SVIR as u64 }\nfn svir_len() -> u64 @export { return ~" as u64)
    pdec(total)  pstr("u64 }\n~" as u64)
}

fn main(argc: i32, argv: u64) -> u64 {
    if argc < 2i32 { return 2u64 }
    let pp : *u64 = argv as *u64
    let f : u64 = fopen(pp[1u64], &MODE_RB as u64)
    if f == 0u64 { return 3u64 }
    SLEN = fread(&SRC as u64, 1u64, 65535u64, f)
    fclose(f)
    lex()
    prescan()
    prescan_arrays()
    prescan_consts()
    MLEN = 0u64
    let mut k : u32 = 0u32
    while k < FN_NF { compile_fn(k)  k = k + 1u32 }
    emit_module()
    return 0u64
}
