module au_crucible_kat

/* THE CRUCIBLE (Phase 2/3 integration, B3 (x) B2): a strided-write loop is CRUSHED to a single O(1) holographic
 * tensor hash (no loop, no branch); an affine scalar loop crushes to its closed form; a geometric loop DEFERS. */
extern @abi(c-msvc-x64) fn au_crucible_stride(base: u64, stride: u64, nn: u64, valbits: u64) -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_crucible_scalar(op: u32, arg: u64, seed: u64, nn: u64) -> u64 from "ser_antiunify.iii"

const AU_NONE64 : u64 = 18446744073709551615u64

fn main() -> u64 {
    let h1 : u64 = au_crucible_stride(0u64, 8u64, 16u64, 777u64)
    if h1 == 0u64 { return 1u64 }                                                /* loop CRUSHED -> nonzero tensor hash */
    if au_crucible_stride(0u64, 8u64, 16u64, 777u64) != h1 { return 2u64 }       /* deterministic                      */
    if au_crucible_stride(100u64, 8u64, 16u64, 777u64) == h1 { return 3u64 }     /* different base -> different hash (teeth)   */
    if au_crucible_stride(0u64, 16u64, 16u64, 777u64) == h1 { return 4u64 }      /* different STRIDE -> different hash (teeth) */
    if au_crucible_scalar(0u32, 5u64, 7u64, 10u64) != 57u64 { return 5u64 }      /* affine acc loop -> cf(10) = 7+10*5 = 57    */
    if au_crucible_scalar(1u32, 3u64, 1u64, 10u64) != AU_NONE64 { return 6u64 }  /* geometric loop DEFERS (honest, no crush)  */
    return 99u64
}
