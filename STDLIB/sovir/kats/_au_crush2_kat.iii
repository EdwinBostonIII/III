module au_crush2_kat

/* UNIVERSAL topology extraction (Task F2a): the nesting-aware locator finds EACH loop at its own structural
 * level.  A module with TWO sequential affine while-loops is fully crushed -> zero loops remain. */
extern @abi(c-msvc-x64) fn au_crush_module(base: u64, boff: u64, blen: u64, accum: u32) -> u32 from "ser_antiunify.iii"

/* while i!=0 { acc=acc+5; i=i-1 }   then   while j!=0 { acc=acc+3; j=j-1 }   (acc=L0, i=L1, j=L2) */
var TWOLOOP : [u8; 96] = [
  64u8,65u8, 16u8,1u8, 1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 48u8, 81u8,1u8, 16u8,0u8, 1u8,5u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 32u8, 17u8,0u8, 16u8,1u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 33u8, 17u8,1u8, 80u8,0u8, 68u8,68u8,
  64u8,65u8, 16u8,2u8, 1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 48u8, 81u8,1u8, 16u8,0u8, 1u8,3u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 32u8, 17u8,0u8, 16u8,2u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 33u8, 17u8,2u8, 80u8,0u8, 68u8,68u8]

fn main() -> u64 {
    if au_crush_module(&TWOLOOP as u64, 0u64, 96u64, 0u32) != 1u32 { return 1u64 }   /* BOTH sequential loops crushed -> zero loops remain */
    return 99u64
}
