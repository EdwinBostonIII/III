module au_storewalk_kat

/* THE STORE RUNG (the memory fragment's first rung, 2026-07-04): a loop whose body's sole memory effect
 * is ONE store per iteration, with the address advancing by a constant stride and the value a constant,
 * is the affine constant-write family -- B2's aff_of geometry, behaviorally extracted, symbolically
 * discharged over ALL entry states by the twice-composed denotation:
 *
 *     ADDR2(X) == ADDR1(X) + S      VAL1(X) == V      VAL2(X) == V
 *
 * A body that stores can NEVER crush on a scalar rung (the store-presence gate) -- a scalar certificate
 * says nothing about the memory effect.  Loads are past this rung: the symbolic denoter defers on them,
 * so a copy-shaped body whose zeroed-heap fuzz LOOKS like a constant store still defers (never crushed).
 *
 *   (1) MEMSET   mem32[1000+4i]=42; i++    -> CRUSHED kind STORE, S=4 V=42 W=4, param = FNV(S,V,W)
 *   (2) WINVAL   value 42+(i&~3)           -> window-fits V=42 (i=0..3) but the VAL miter dies at i=4 -> REFUTED
 *   (3) WINADDR  addr 1000+(i&~3)+i        -> window-fits S=1 but the ADDR miter dies at i=3 -> REFUTED
 *   (4) QADDR    addr 1000+i*i             -> stride trace 1,3,5: no fit -> DEFER
 *   (5) TWOSTORE two stores per pass       -> not a single-store family -> DEFER
 *   (6) COPY     mem8[2000]=mem8[1000]     -> fuzz sees V=0,S=0 (zeroed heap!) but the LOAD defers the
 *                                             guillotine -> DEFER, never a false crush
 *
 * exit 99 = all; 1..7 = the numbered contract broken (10+ = a certificate field wrong). */

extern @abi(c-msvc-x64) fn au_topo_amputate(base: u64, boff: u64, blen: u64, accum: u32, seed: u64) -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_last_kind() -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_last_param() -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_last_store_stride() -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_last_store_value() -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_last_store_width() -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_crush_report(base: u64, boff: u64, blen: u64, accum: u32) -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_report_n() -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_report_verdict(i: u32) -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_report_kind(i: u32) -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_report_delta(i: u32) -> u64 from "ser_antiunify.iii"

/* mem32[1000 + 4*i] = 42 ; i++    (CONST1000 GET1 CONST4 MUL ADD  CONST42 STORE32  GET1 CONST1 ADD SET1) */
var MEMSET : [u8; 46] = [
  1u8,232u8,3u8,0u8,0u8,0u8,0u8,0u8,0u8, 16u8,1u8, 1u8,4u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 34u8, 32u8,
  1u8,42u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 137u8,
  16u8,1u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 32u8, 17u8,1u8]
/* value = (i & ~3) + 42 -- constant on the fuzz window, NOT constant over all states */
var WINVAL : [u8; 49] = [
  1u8,232u8,3u8,0u8,0u8,0u8,0u8,0u8,0u8, 16u8,1u8, 1u8,4u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 34u8, 32u8,
  16u8,1u8, 1u8,252u8,255u8,255u8,255u8,255u8,255u8,255u8,255u8, 37u8, 1u8,42u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 32u8, 137u8,
  16u8,1u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 32u8, 17u8,1u8]
/* addr = 1000 + (i & ~3) + i -- stride 1 on the fuzz window, NOT affine over all states */
var WINADDR : [u8; 49] = [
  1u8,232u8,3u8,0u8,0u8,0u8,0u8,0u8,0u8, 16u8,1u8, 1u8,252u8,255u8,255u8,255u8,255u8,255u8,255u8,255u8, 37u8, 32u8, 16u8,1u8, 32u8,
  1u8,42u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 137u8,
  16u8,1u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 32u8, 17u8,1u8]
/* addr = 1000 + i*i -- strides 1,3,5: fits nothing */
var QADDR : [u8; 39] = [
  1u8,232u8,3u8,0u8,0u8,0u8,0u8,0u8,0u8, 16u8,1u8, 16u8,1u8, 34u8, 32u8,
  1u8,42u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 137u8,
  16u8,1u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 32u8, 17u8,1u8]
/* two stores per pass -- not a single-store family */
var TWOSTORE : [u8; 38] = [
  1u8,232u8,3u8,0u8,0u8,0u8,0u8,0u8,0u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 129u8,
  1u8,208u8,7u8,0u8,0u8,0u8,0u8,0u8,0u8, 1u8,2u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 129u8]
/* mem8[2000] = mem8[1000] -- the zeroed fuzz heap makes this LOOK like a constant store; the LOAD defers it */
var COPY : [u8; 20] = [
  1u8,208u8,7u8,0u8,0u8,0u8,0u8,0u8,0u8, 1u8,232u8,3u8,0u8,0u8,0u8,0u8,0u8,0u8, 128u8, 129u8]
/* while i!=0 { mem32[1000+4i]=42; i++ }  (shell 16 + MEMSET 46 + 4 = 66) */
var WMOD : [u8; 66] = [
  64u8,65u8, 16u8,1u8, 1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 48u8, 81u8,1u8,
  1u8,232u8,3u8,0u8,0u8,0u8,0u8,0u8,0u8, 16u8,1u8, 1u8,4u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 34u8, 32u8,
  1u8,42u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 137u8,
  16u8,1u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 32u8, 17u8,1u8,
  80u8,0u8, 68u8,68u8]

fn main() -> u64 {
    /* (1) the memset family crushes with the full certificate */
    if au_topo_amputate(&MEMSET as u64, 0u64, 46u64, 0u32, 7u64) != 1u32 { return 1u64 }
    if au_last_kind() != 3u32 { return 10u64 }
    if au_last_store_stride() != 4u64 { return 11u64 }
    if au_last_store_value() != 42u64 { return 12u64 }
    if au_last_store_width() != 4u32 { return 13u64 }
    let mut dg : u64 = 14695981039346656037u64                    /* the cert digest must BIND the components */
    dg = (dg ^ 4u64) * 1099511628211u64
    dg = (dg ^ 42u64) * 1099511628211u64
    dg = (dg ^ 4u64) * 1099511628211u64
    if au_last_param() != dg { return 14u64 }

    /* (2)(3) the sampled-window adversaries die at the miters, never crushed */
    if au_topo_amputate(&WINVAL as u64, 0u64, 49u64, 0u32, 7u64) != 0u32 { return 2u64 }
    if au_topo_amputate(&WINADDR as u64, 0u64, 49u64, 0u32, 7u64) != 0u32 { return 3u64 }

    /* (4)(5)(6) the honest defers: no fit / two stores / the load boundary */
    if au_topo_amputate(&QADDR as u64, 0u64, 39u64, 0u32, 7u64) != 2u32 { return 4u64 }
    if au_topo_amputate(&TWOSTORE as u64, 0u64, 38u64, 0u32, 7u64) != 2u32 { return 5u64 }
    if au_topo_amputate(&COPY as u64, 0u64, 20u64, 0u32, 7u64) != 2u32 { return 6u64 }

    /* (7) the whole-module walk records the STORE certificate in the ledger */
    if au_crush_report(&WMOD as u64, 0u64, 66u64, 0u32) != 1u32 { return 7u64 }
    if au_report_n() != 1u32 { return 15u64 }
    if au_report_verdict(0u32) != 1u32 { return 16u64 }
    if au_report_kind(0u32) != 3u32 { return 17u64 }
    if au_report_delta(0u32) != dg { return 18u64 }
    return 99u64
}
