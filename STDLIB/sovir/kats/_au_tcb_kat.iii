module au_tcb_kat

/* EPOCH I -- THE MERKLE-SEALED TCB: a binary hash tree over the crush certificates.  Deterministic genesis root;
 * leaf membership proof verifies and a tampered leaf is rejected; the admission gate accepts ONLY a report whose
 * root equals the sealed genesis (residue drift is refused at the door). */
extern @abi(c-msvc-x64) fn au_crush_report(base: u64, boff: u64, blen: u64, accum: u32) -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_report_merkle_root() -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_report_leaf(i: u32) -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_merkle_open(target: u32) -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_merkle_check(leaf_hash: u64, target: u32, root: u64) -> u32 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_tcb_seal() -> u64 from "ser_antiunify.iii"
extern @abi(c-msvc-x64) fn au_tcb_admits() -> u32 from "ser_antiunify.iii"

/* MOD_A: two affine loops (acc+=5 ; acc+=3) ; MOD_C: geometric acc*=2 (crushes kind-MUL, ratio 2) then affine
 * acc+=3 -- a different certificate profile either way, so its root must NOT be admitted under MOD_A's seal */
var MOD_A : [u8; 96] = [
  64u8,65u8, 16u8,1u8, 1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 48u8, 81u8,1u8, 16u8,0u8, 1u8,5u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 32u8, 17u8,0u8, 16u8,1u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 33u8, 17u8,1u8, 80u8,0u8, 68u8,68u8,
  64u8,65u8, 16u8,1u8, 1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 48u8, 81u8,1u8, 16u8,0u8, 1u8,3u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 32u8, 17u8,0u8, 16u8,1u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 33u8, 17u8,1u8, 80u8,0u8, 68u8,68u8]
var MOD_C : [u8; 96] = [
  64u8,65u8, 16u8,1u8, 1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 48u8, 81u8,1u8, 16u8,0u8, 1u8,2u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 34u8, 17u8,0u8, 16u8,1u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 33u8, 17u8,1u8, 80u8,0u8, 68u8,68u8,
  64u8,65u8, 16u8,1u8, 1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 48u8, 81u8,1u8, 16u8,0u8, 1u8,3u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 32u8, 17u8,0u8, 16u8,1u8, 1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 33u8, 17u8,1u8, 80u8,0u8, 68u8,68u8]

fn main() -> u64 {
    au_crush_report(&MOD_A as u64, 0u64, 96u64, 0u32)
    let r1 : u64 = au_report_merkle_root()
    au_crush_report(&MOD_A as u64, 0u64, 96u64, 0u32)
    if au_report_merkle_root() != r1 { return 1u64 }            /* deterministic genesis root */
    if r1 == 0u64 { return 2u64 }
    if au_tcb_seal() != r1 { return 3u64 }                      /* seal genesis = r1 */
    au_crush_report(&MOD_A as u64, 0u64, 96u64, 0u32)
    if au_tcb_admits() != 1u32 { return 4u64 }                  /* same module admitted */
    let leaf0 : u64 = au_report_leaf(0u32)
    au_merkle_open(0u32)
    if au_merkle_check(leaf0, 0u32, r1) != 1u32 { return 5u64 } /* membership proof VERIFIES */
    if au_merkle_check(leaf0 ^ 1u64, 0u32, r1) != 0u32 { return 6u64 }  /* tampered leaf REJECTED (teeth) */
    au_crush_report(&MOD_C as u64, 0u64, 96u64, 0u32)
    if au_tcb_admits() != 0u32 { return 7u64 }                  /* residue drift -> admission REFUSED (teeth) */
    return 99u64
}
