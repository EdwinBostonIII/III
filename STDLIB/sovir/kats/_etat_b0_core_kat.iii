/* _etat_b0_core_kat.iii -- Leg-A PROVE-THE-PROVER gate (reconstructed 2026-07-04 into tracked kats/).
 *
 * B0 is the load-bearing lemma of the entire memory-amputation theory: ETAT's causal-fold read
 * resolution (etat_fold_step, newest-write-first) must REFINE sequential McCarthy read-over-write
 * (etat_mc_step) for UNBOUNDED write logs -- otherwise no ETAT memory-equivalence proof means
 * anything.  The proof is inductive: a BASE (empty log), a DEPTH-INDEPENDENT STEP proven over all
 * 2^64 valuations against a FREE symbolic tail (single step => unbounded by composition), a
 * COMPOSE grounding on a concrete depth-3 log, and -- the anti-vacuity guard -- the WRONG
 * resolution must DIVERGE from McCarthy (or the whole check couldn't tell a right rule from a wrong
 * one).  This gate runs each rung so a regression names it, and pins the teeth.
 *
 * exit 99 = B0 fully proven; 10 base; 11 step; 12 wrong-model didn't diverge (VACUOUS);
 *   13 compose; 14 the composed lemma et_refines_row. */
module corpus_etat_b0_core_kat

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn et_refines_base() -> u8 from "ser_causal.iii"
extern @abi(c-msvc-x64) fn et_refines_row_step() -> u8 from "ser_causal.iii"
extern @abi(c-msvc-x64) fn et_refines_row_step_wrong() -> u8 from "ser_causal.iii"
extern @abi(c-msvc-x64) fn et_refines_compose() -> u8 from "ser_causal.iii"
extern @abi(c-msvc-x64) fn et_refines_row() -> u8 from "ser_causal.iii"

fn main() -> u64 {
    let b  : u8 = et_refines_base()
    let s  : u8 = et_refines_row_step()
    let w  : u8 = et_refines_row_step_wrong()   /* MUST be 0: the wrong rule diverges from McCarthy */
    let c  : u8 = et_refines_compose()
    let r  : u8 = et_refines_row()

    putchar(66i32) putchar(48i32) putchar(58i32)   /* "B0:" */
    putchar((48u8 + b) as i32) putchar((48u8 + s) as i32) putchar((48u8 + w) as i32) putchar((48u8 + c) as i32) putchar((48u8 + r) as i32) putchar(10i32)

    if b != 1u8 { return 10u64 }        /* base: empty log reads init */
    if s != 1u8 { return 11u64 }        /* the 64-bit depth-independent step (== McCarthy over 2^64) */
    if w != 0u8 { return 12u64 }        /* TEETH: the wrong resolution MUST diverge -- non-vacuous */
    if c != 1u8 { return 13u64 }        /* depth-3 compose grounding */
    if r != 1u8 { return 14u64 }        /* the assembled lemma (base & step & !wrong & compose) */
    return 99u64
}
