/* sovir/mathesis_radical_main.iii -- THE RADICAL ROUND-1 STREAM DRIVER (campaign Rho).
 * Runs both declared sweeps + the round chain and prints the ENTIRE discovery stream:
 * bounds first (never silent), every theorem row, the summary pins, the chain head.
 * Output is sealed as DOCS/MATHESIS-RADICAL-ROUND1.log; run_mathesis.sh greps the pins;
 * re-running this driver must reproduce the log byte-identically (the MXS replay law). */
module mathesis_radical_main

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn mrd_sweep(amax: i64, bmax: i64, cmax: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrd_found() -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrd_nonde() -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrd_skip() -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrd_row_a(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrd_row_b(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrd_row_c(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrd_row_m(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrd_row_n(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrd_row_novel(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrc_sweep(emax: i64, fmax: i64, umax: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrc_count() -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrc_equal_count() -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrc_tested() -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrc_box() -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrc_row_e(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrc_row_f(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrc_row_u(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrc_row_v(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrc_row_w(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mrc_row_q(i: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mxr_chain_round(amax: i64, bmax: i64, cmax: i64) -> i64 from "mathesis_radical.iii"
extern @abi(c-msvc-x64) fn mxr_head_byte(i: i64) -> u64 from "mathesis_radical.iii"

fn e_i64(v: i64) -> i32 { if v < 0i64 { putchar(45i32)   return e_i64(0i64 - v) }   if v >= 10i64 { e_i64(v / 10i64) }   putchar(((v % 10i64) + 48i64) as i32)   return 0i32 }
fn sp() -> i32 { putchar(32i32)   return 0i32 }   fn nl() -> i32 { putchar(10i32)   return 0i32 }
fn ps(msg: u64) -> i32 {
    let p : *u8 = msg as *u8
    let mut i : u64 = 0u64
    let mut going : u8 = 1u8
    while going == 1u8 {
        let ch : u8 = p[i]
        if ch == 0u8 { going = 0u8 } else { putchar(ch as i32)   i = i + 1u64 }
    }
    return 0i32
}
fn hexnib(v: u64) -> i32 {
    if v < 10u64 { putchar((48u64 + v) as i32) } else { putchar((87u64 + v) as i32) }
    return 0i32
}

fn main() -> u64 {
    ps("MXR-ROUND1 declared: denest a in 2..32, b in 1..6, c in 2..32 (c-square out of class); cube e in 1..9, f in -9..9 (radicand > 0 exact), u,v,w in -2..2; prefilter 2^-14; judge = pair-gcd\n" as u64)
    let sw : i64 = mrd_sweep(32i64, 6i64, 32i64)
    if sw < 1i64 { return 1u64 }
    let cq : i64 = mrc_sweep(9i64, 9i64, 2i64)
    if cq < 0i64 { return 2u64 }
    let ch : i64 = mxr_chain_round(32i64, 6i64, 32i64)
    if ch < 1i64 { return 3u64 }
    let nf : i64 = mrd_found()
    let mut nv : i64 = 0i64
    let mut i : i64 = 0i64
    while i < nf {
        ps("MXR# D " as u64) e_i64(mrd_row_a(i)) sp() e_i64(mrd_row_b(i)) sp() e_i64(mrd_row_c(i))
        sp() e_i64(mrd_row_m(i)) sp() e_i64(mrd_row_n(i)) sp() e_i64(mrd_row_novel(i)) nl()
        if mrd_row_novel(i) == 1i64 { nv = nv + 1i64 }
        i = i + 1i64
    }
    i = 0i64
    while i < mrc_count() {
        ps("MXR# C " as u64) e_i64(mrc_row_e(i)) sp() e_i64(mrc_row_f(i)) sp() e_i64(mrc_row_u(i))
        sp() e_i64(mrc_row_v(i)) sp() e_i64(mrc_row_w(i)) sp() e_i64(mrc_row_q(i)) nl()
        i = i + 1i64
    }
    ps("MXR denest=" as u64) e_i64(nf)
    ps(" novel=" as u64) e_i64(nv)
    ps(" redisc=" as u64) e_i64(nf - nv)
    ps(" nonexist=" as u64) e_i64(mrd_nonde())
    ps(" skip=" as u64) e_i64(mrd_skip())
    ps(" cube_eq=" as u64) e_i64(mrc_equal_count())
    ps(" cube_tested=" as u64) e_i64(mrc_tested())
    ps(" cube_box=" as u64) e_i64(mrc_box())
    ps(" chain=" as u64) e_i64(ch)
    ps(" head=" as u64)
    i = 0i64
    while i < 32i64 {
        let b : u64 = mxr_head_byte(i)
        hexnib(b >> 4u64)
        hexnib(b & 15u64)
        i = i + 1i64
    }
    nl()
    return 0u64
}
