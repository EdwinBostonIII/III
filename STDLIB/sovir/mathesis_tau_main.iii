/* sovir/mathesis_tau_main.iii -- THE TAU STREAM DRIVER (campaign Tau: the machine attacks its own
 * open question).  Prints the height escalation, the extended-d pattern, every extended find,
 * the closure structure, and the d=5 local table.  Sealed as DOCS/MATHESIS-TAU-ROUND1.log;
 * replay must be byte-identical. */
module mathesis_tau_main

extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn mcv_hunt_reset() -> i32 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcv_hunt(d: i64, curve: i64, hmax: i64) -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcv_found() -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcv_row_d(i: i64) -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcv_row_c(i: i64) -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcv_row_u(i: i64) -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcv_row_v(i: i64) -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcv_row_w(i: i64) -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcv_row_e(i: i64) -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcv_row_f(i: i64) -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcg_closure(d: i64, curve: i64, seedmode: i64) -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcg_over() -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcg_has(u: i64, v: i64, w: i64) -> i64 from "mathesis_curve.iii"
extern @abi(c-msvc-x64) fn mcv_local(d: i64, curve: i64, p: i64) -> i64 from "mathesis_curve.iii"

fn e_i64(v: i64) -> i32 { if v < 0i64 { putchar(45i32)   return e_i64(0i64 - v) }   if v >= 10i64 { e_i64(v / 10i64) }   putchar(((v % 10i64) + 48i64) as i32)   return 0i32 }
fn sp() -> i32 { putchar(32i32)   return 0i32 }   fn nl() -> i32 { putchar(10i32)   return 0i32 }
fn ps(msg: u64) -> i32 {
    let p : *u8 = msg as *u8
    let mut i : u64 = 0u64
    let mut going : u8 = 1u8
    while going == 1u8 {
        let ch : u8 = p[i]
        if ch == 0u8 { going = 0u8 } else { putchar(ch as i32)   i = i + 1u64 }
    }
    return 0i32
}

var XD : [i64; 5]   var PS2 : [i64; 6]

fn main() -> u64 {
    ps("MXG-ROUND1 declared: the open question attacked -- d=5 escalated to height 200 both curves; extended d in {10,11,12,13,17} at height 60; chord-tangent closures (exact integer, on-curve rechecked, height cap 4096, escapes counted); d=5 local projective counts mod p\n" as u64)
    mcv_hunt_reset()
    let f1 : i64 = mcv_hunt(5i64, 1i64, 200i64)
    let f2 : i64 = mcv_hunt(5i64, 2i64, 200i64)
    ps("MXG F5H200 " as u64) e_i64(f1) sp() e_i64(f2) nl()
    XD[0u64] = 10i64   XD[1u64] = 11i64   XD[2u64] = 12i64   XD[3u64] = 13i64   XD[4u64] = 17i64
    let mut k : i64 = 0i64
    while k < 5i64 {
        let mut cv : i64 = 1i64
        while cv <= 2i64 {
            let r : i64 = mcv_hunt(XD[k as u64], cv, 60i64)
            ps("MXG H " as u64) e_i64(XD[k as u64]) sp() e_i64(cv) sp() e_i64(r) nl()
            if r < 0i64 { return 1u64 }
            cv = cv + 1i64
        }
        k = k + 1i64
    }
    let mut i : i64 = 0i64
    while i < mcv_found() {
        if mcv_row_d(i) >= 10i64 {
            ps("MXG C " as u64) e_i64(mcv_row_d(i)) sp() e_i64(mcv_row_c(i)) sp() e_i64(mcv_row_u(i))
            sp() e_i64(mcv_row_v(i)) sp() e_i64(mcv_row_w(i)) sp() e_i64(mcv_row_e(i)) sp() e_i64(mcv_row_f(i))
            ps(" name=SIGMA-d" as u64) e_i64(mcv_row_d(i)) putchar(65i32) putchar(45i32)
            e_i64(((i + 1i64) * 1i64) - (mcv_found() - 6i64))
            nl()
        }
        i = i + 1i64
    }
    mcv_hunt_reset()
    mcv_hunt(2i64, 1i64, 60i64)
    mcv_hunt(3i64, 2i64, 60i64)
    let k0 : i64 = mcg_closure(2i64, 1i64, 0i64)
    ps("MXG K 2 1 0 " as u64) e_i64(k0) sp() e_i64(mcg_over()) nl()
    ps("MXG RAMANUJAN-IN-TRIVIAL-CLOSURE " as u64) e_i64(mcg_has(1i64, 0i64 - 1i64, 1i64)) nl()
    let k1 : i64 = mcg_closure(2i64, 1i64, 1i64)
    ps("MXG K 2 1 1 " as u64) e_i64(k1) sp() e_i64(mcg_over()) nl()
    let k3 : i64 = mcg_closure(3i64, 2i64, 1i64)
    ps("MXG K 3 2 1 " as u64) e_i64(k3) sp() e_i64(mcg_over()) nl()
    let k5a : i64 = mcg_closure(5i64, 1i64, 0i64)
    ps("MXG K 5 1 0 " as u64) e_i64(k5a) sp() e_i64(mcg_over()) nl()
    let k5b : i64 = mcg_closure(5i64, 2i64, 0i64)
    ps("MXG K 5 2 0 " as u64) e_i64(k5b) sp() e_i64(mcg_over()) nl()
    PS2[0u64] = 2i64   PS2[1u64] = 3i64   PS2[2u64] = 5i64   PS2[3u64] = 7i64   PS2[4u64] = 11i64   PS2[5u64] = 13i64
    k = 0i64
    while k < 6i64 {
        ps("MXG L " as u64) e_i64(PS2[k as u64]) sp() e_i64(mcv_local(5i64, 1i64, PS2[k as u64])) sp() e_i64(mcv_local(5i64, 2i64, PS2[k as u64])) nl()
        k = k + 1i64
    }
    ps("MXG pattern: A={2,6,7,12} B={3} empty={5,10,11,13,17}; d=5 empty to H=200; trivial triangle CLOSED and does NOT generate the sigma-points; {trivials+Ramanujan-orbit} EXACTLY CLOSED at 6; d=3B escapes=12 past the height envelope; B5 mod 7 = the bare trivial minimum -- THE OPEN QUESTION STANDS, SHARPENED\n" as u64)
    return 0u64
}
