/* svir_interp.iii -- the REFERENCE SVIR v1/v2 interpreter (the value-tracer): a 3rd, INDEPENDENT executor of a
 * linked `gen_svir` module, sharing NO code with svir_x86 / svir_wasm.  It executes SVIR SEMANTICS faithfully
 * (per DOCS/SVIR-V1-CANONICAL.md + the svir_x86 ABI: func 0 = main; flat `svir_mem` byte memory with direct
 * mem[addr] LOAD/STORE; trailing data section byte-packed at offset 0 (v1 [u16 len] / v2 [u32 len]); CALL/CALL2
 * = pop argcount args -> callee locals 0..n-1, push the RETURN result) and PRINTS the output via putchar.
 *
 * PURPOSE (Boss-1): a faithful reference executor is the ground-truth oracle for ANY SVIR-vs-backend question.
 * If it reproduces the SHADOW_ON=1 wrong SHA digest, the SVIR is semantically wrong (ccsv codegen) -- a 3rd
 * independent confirmation -- AND it can be instrumented to trace the exact diverging memory/slot.
 *
 * NIH: libc putchar only.  No island: it is the SVIR reference semantics, the same ISA svir_verify validates.
 *
 * HOST-BOUNDARY SHIMS (Lambda-0, the linked whole-seed): a CALL landing on an IMPORT body whose name is on
 * the CRT WHITELIST (fopen fclose fread fwrite fseek ftell rewind fgets clock) dispatches to the HOST CRT --
 * SVIR addresses marshal as &MEM[off] (NULL passes through), FILE* returns flow back as opaque i64 handles
 * (the seed never dereferences them), fgets' return maps back to the SVIR buffer offset.  Anything else
 * stays the LOUD 198 sentinel.  argv: the interp's own argv[1..] stages into MEM at ARGV_TAB (argv[0] =
 * "iiis-0") so the linked seed's main(argc, argv) sees a real command line. */
module svir_interp
extern @abi(c-msvc-x64) fn svir_ptr() -> u64 from "gen_svir.iii"
extern @abi(c-msvc-x64) fn svir_len() -> u64 from "gen_svir.iii"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn fopen(path: u64, mode: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fclose(f: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn fread(buf: u64, sz: u64, n: u64, f: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fwrite(buf: u64, sz: u64, n: u64, f: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn fseek(f: u64, off: i64, whence: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn ftell(f: u64) -> i64 from "msvcrt"
extern @abi(c-msvc-x64) fn rewind(f: u64) -> i64 from "msvcrt"
extern @abi(c-msvc-x64) fn ferror(f: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn fgets(buf: u64, n: i32, f: u64) -> u64 from "msvcrt"
extern @abi(c-msvc-x64) fn clock() -> i64 from "msvcrt"
extern @abi(c-msvc-x64) fn system(cmd: u64) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn putenv(nv: u64) -> i32 from "msvcrt"

var MEM  : [u8; 4194304]                 /* svir_mem: flat linear memory (4 MiB) */
var VS   : [u64; 16384]   var VSP : u32 = 0u32      /* the shared eval (value) stack */
var LOC  : [u64; 131072]                 /* per-call locals: frame `depth` owns LOC[depth*256 .. +256] (512 frames) */
var CK   : [u32; 16384]   var CP : [u64; 16384]   var CE : [u64; 16384]   /* per-call control stack: depth*64 + csp */

var FN_OFF   : [u64; 4096]   var FN_BLEN : [u64; 4096]   var NFUNC : u32 = 0u32   /* 4096: the linked whole-seed is ~2,300 fns (v2 container) */
var V2G : u32 = 0u32                     /* 1 = v2 container (0x00 [nfunc:u16 LE]; data length u32) */
const STEP_CAP : u64 = 4000000000u64     /* global step budget (a non-terminating module refuses, never hangs) */
var STEPS : u64 = 0u64

/* CONST-DATA CORRUPTION WATCH: the data section [0..DLEN_G) is const/input (CL_K, string literals) and must NOT
 * be written during execution.  Any STORE below DLEN_G is a codegen bug (a mis-addressed write).  Record the
 * first 64 such writes with the offending function id -> pins the corrupting opcode's function. */
var DLEN_G : u64 = 0u64
var CUR_FN : u32 = 0u32
var BADW_N : u32 = 0u32   var BADW_A : [u64; 64]   var BADW_V : [u64; 64]   var BADW_F : [u32; 64]
var OOB_IND : u32 = 0u32   /* count of out-of-range CALL_INDIRECT indices -> the oracle reflects safe (no-silent-dispatch) semantics */
var UNRES_IMP : u32 = 0u32   /* count of CALLs that landed on an IMPORT-decl body [0x8A][nl][name] (cross-module fn, unresolved single-file) -> trap sentinel 198, never execute the NAME BYTES as opcodes (the silent-wrongness class); resolution is the P3 linker's job */
var PDEC_D : [u8; 24]
fn pdec(v0: u64) { if v0==0u64 { putchar(48i32)  return }  let mut v:u64=v0  let mut n:u32=0u32  while v>0u64 { PDEC_D[n as u64]=(48u64+(v%10u64)) as u8  n=n+1u32  v=v/10u64 }  while n>0u32 { n=n-1u32  putchar(PDEC_D[n as u64] as i32) } }
fn pstr2(a:u32,b:u32){ putchar(a as i32) putchar(b as i32) }

/* ---- Lambda-0 HOST SHIMS: import-name dispatch to the CRT (whitelist only) ---- */
var SHIM_HIT : u32 = 0u32
var ARGV_DBG : u32 = 0u32   /* TEMP */
var FPRINTF_DBG : u32 = 0u32   /* S4 microscope (OFF by default): 1 -> trace silent-fprintf fmt strings, fopen path+mode+result, system/ferror rcs, low-address write sweeps (LW=count[min,max]).  Session 7 used it to pin `cg->pe_static_fp[i]=NULL` writing byte 0 AT ADDRESS i -- the "rb"-literal wipe behind the silent EMIT_FAIL 16. */
var LOWW_N : u32 = 0u32   var LOWW_MIN : u64 = 999999999u64   var LOWW_MAX : u64 = 0u64   /* TEMP S4: low-address write sweep extent */
fn m2h(off: u64) -> u64 { if off==0u64 { return 0u64 }  return (&MEM as u64) + off }   /* SVIR addr -> host ptr (NULL passes) */
fn nm_is(no: u64, nl: u32, s: u64, sl: u32) -> u32 {   /* import name bytes (module) == the .iii literal */
    if nl != sl { return 0u32 }
    let p : *u8 = s as *u8
    let mut j : u32 = 0u32
    while j < nl { if ib(no + (j as u64)) != (p[j as u64] as u32) { return 0u32 }  j = j + 1u32 }
    return 1u32
}
fn shim_call(boff: u64, lb: u64) -> u64 {
    SHIM_HIT = 1u32
    let nl : u32 = ib(boff + 1u64)
    let no : u64 = boff + 2u64
    let a0 : u64 = LOC[lb]  let a1 : u64 = LOC[lb + 1u64]  let a2 : u64 = LOC[lb + 2u64]  let a3 : u64 = LOC[lb + 3u64]
    if nm_is(no, nl, "fopen"  as u64, 5u32)==1u32 { let fo9:u64=fopen(m2h(a0), m2h(a1))  if FPRINTF_DBG==1u32 { putchar(10i32) putchar(70i32) putchar(79i32) putchar(61i32)   /* "FO=" path bytes , mode@addr bytes , :0/:1 */
        let mut pj:u64=0u64  let pp9:*u8=m2h(a0) as *u8  while pj<80u64 { let pb9:u32=pp9[pj] as u32  if pb9==0u32 {pj=80u64} else { if pb9>=32u32 {putchar(pb9 as i32)}  pj=pj+1u64 } }
        putchar(44i32)  pdec(a1)  putchar(61i32)
        let mut mj:u64=0u64  let mm9:*u8=m2h(a1) as *u8  while mj<8u64 { let mb9:u32=mm9[mj] as u32  if mb9==0u32 {mj=8u64} else { if mb9>=32u32 {putchar(mb9 as i32)} else {putchar(63i32)}  mj=mj+1u64 } }
        putchar(58i32)  if fo9==0u64 {putchar(48i32)} else {putchar(49i32)}  putchar(10i32) }
        return fo9 }
    if nm_is(no, nl, "fclose" as u64, 6u32)==1u32 { return (fclose(a0)) as u64 }
    if nm_is(no, nl, "fread"  as u64, 5u32)==1u32 { return fread(m2h(a0), a1, a2, a3) }
    if nm_is(no, nl, "fwrite" as u64, 6u32)==1u32 { return fwrite(m2h(a0), a1, a2, a3) }
    if nm_is(no, nl, "fseek"  as u64, 5u32)==1u32 { return (fseek(a0, a1 as i64, a2 as i32)) as u64 }
    if nm_is(no, nl, "ftell"  as u64, 5u32)==1u32 { return (ftell(a0)) as u64 }
    if nm_is(no, nl, "rewind" as u64, 6u32)==1u32 { rewind(a0)  return 0u64 }
    if nm_is(no, nl, "ferror" as u64, 6u32)==1u32 { let fe9:i32=ferror(a0)  if FPRINTF_DBG==1u32 { putchar(10i32) putchar(70i32) putchar(69i32) putchar(61i32) pdec(fe9 as u64) putchar(10i32) }  return fe9 as u64 }   /* main.c's iii_mhash_file read-back check: unshimmed it mis-read as truthy -> silent EMIT_FAIL 16 with a byte-correct .o (S4 session 7's last delta) ; FE=<rc> trace under FPRINTF_DBG */
    if nm_is(no, nl, "fgets"  as u64, 5u32)==1u32 { let r:u64=fgets(m2h(a0), a1 as i32, a2)  if r==0u64 { return 0u64 }  return a0 }   /* host buf-ptr maps back to the SVIR offset */
    if nm_is(no, nl, "clock"  as u64, 5u32)==1u32 { return (clock()) as u64 }
    if nm_is(no, nl, "fprintf" as u64, 7u32)==1u32 { if FPRINTF_DBG==1u32 { putchar(10i32) putchar(70i32) putchar(80i32) putchar(33i32) putchar(32i32)   /* "\nFP! " + the fmt bytes: WHICH silent stderr diagnostic fired */
        let mut fj:u64=0u64  let fp9:*u8=m2h(a1) as *u8  while fj<120u64 { let fb9:u32=fp9[fj] as u32  if fb9==0u32 {fj=120u64} else { if fb9>=32u32 {putchar(fb9 as i32)}  fj=fj+1u64 } }  putchar(10i32) }
        return 0u64 }   /* stderr diagnostics: dropped (the seed's error text goes to stderr; the interp is a stdout oracle) -- a no-op so error paths don't 198 */
    if nm_is(no, nl, "fputc"  as u64, 5u32)==1u32 { return 0u64 }
    if nm_is(no, nl, "fputs"  as u64, 5u32)==1u32 { return 0u64 }
    if nm_is(no, nl, "fflush" as u64, 6u32)==1u32 { return 0u64 }
    if nm_is(no, nl, "signal" as u64, 6u32)==1u32 { return 0u64 }   /* iii_install_signals: no signal handling in the interp */
    if nm_is(no, nl, "getenv" as u64, 6u32)==1u32 { return 0u64 }   /* SOURCE_DATE_EPOCH: NULL -> default 0 (deterministic) */
    if nm_is(no, nl, "system" as u64, 6u32)==1u32 { let sy9:i32=system(m2h(a0))  if FPRINTF_DBG==1u32 { putchar(10i32) putchar(83i32) putchar(89i32) putchar(61i32) pdec(sy9 as u64) putchar(10i32) }  return sy9 as u64 }   /* iiis-0 emit.c shells `gcc -c` to assemble the .s (written via fopen/fwrite shims) into the .o ; SY=<rc> trace under FPRINTF_DBG */
    if nm_is(no, nl, "putenv" as u64, 6u32)==1u32 { return (putenv(m2h(a0))) as u64 }   /* D1/D5/D6 forced env (SOURCE_DATE_EPOCH=0, LC_ALL=C) -> visible to the gcc child = byte-identical to gcc iiis-0 */
    SHIM_HIT = 0u32
    return 0u64
}
fn ib(i: u64) -> u32 { let p : *u8 = (svir_ptr() + i) as *u8  return p[0u64] as u32 }   /* a byte of the SVIR module */
fn ird8(i: u64) -> u64 { let mut v:u64=0u64  let mut k:u64=0u64  while k<8u64 { v = v | ((ib(i+k)) as u64 << (k*8u64))  k=k+1u64 }  return v }   /* 8-byte LE from the module body */
fn iu16(i: u64) -> u64 { return (ib(i) as u64) | ((ib(i+1u64) as u64) << 8u64) }

fn mb(a: u64) -> u32 { if a < 4194304u64 { return MEM[a] as u32 }  return 0u32 }
fn msb(a: u64, v: u32) { if a < 4194304u64 { MEM[a] = (v & 255u32) as u8 } }
fn mld(a: u64, w: u32, sgn: u32) -> u64 {                 /* load w bytes (1/2/4/8) from MEM, sign- or zero-extend */
    let mut v : u64 = 0u64  let mut k : u64 = 0u64
    while k < (w as u64) { v = v | ((mb(a+k)) as u64 << (k*8u64))  k=k+1u64 }
    if sgn == 1u32 { if w == 2u32 { if v >= 32768u64 { v = v | 18446744073709551360u64 } }   /* sign-extend 16 */
                     if w == 4u32 { if v >= 2147483648u64 { v = v | 18446744069414584320u64 } } }   /* sign-extend 32 */
    return v
}
fn mst(a: u64, w: u32, v: u64) {
    if a < DLEN_G { if BADW_N < 64u32 { BADW_A[BADW_N as u64]=a  BADW_V[BADW_N as u64]=v  BADW_F[BADW_N as u64]=CUR_FN  BADW_N=BADW_N+1u32 } }   /* WRITE into the const data section = the codegen bug */
    if FPRINTF_DBG==1u32 { if a<300u64 { if LOWW_N<3u32 { putchar(10i32) putchar(87i32) putchar(33i32) putchar(61i32) pdec(CUR_FN as u64) putchar(64i32) pdec(a) putchar(43i32) pdec(w as u64) putchar(61i32) pdec(v) putchar(10i32) }
        LOWW_N=LOWW_N+1u32  if a<LOWW_MIN {LOWW_MIN=a}  if a>LOWW_MAX {LOWW_MAX=a} } }   /* TEMP S4: first-3 low writes verbatim + min/max/count summary at exit */
    let mut k : u64 = 0u64  while k < (w as u64) { msb(a+k, ((v >> (k*8u64)) & 255u64) as u32)  k=k+1u64 }
}

fn vpush(v: u64) { if VSP < 16384u32 { VS[VSP as u64] = v  VSP = VSP + 1u32 } }
fn vpop() -> u64 { if VSP > 0u32 { VSP = VSP - 1u32  return VS[VSP as u64] }  return 0u64 }

fn op_w(op: u32) -> u64 { if op==0x01u32 {return 8u64}  if op==0x10u32 {return 1u64}  if op==0x11u32 {return 1u64}  if op==0x50u32 {return 1u64}  if op==0x51u32 {return 1u64}  if op==0x70u32 {return 2u64}  if op==0x73u32 {return 1u64}  if op==0x74u32 {return 3u64}  return 0u64 }   /* 0x73 CALL_INDIRECT ac (1 imm byte) + 0x74 CALL2 [fi:u16 LE][ac] (3 imm bytes); needed so match_end/match_else skip them correctly */

/* find, for the construct opening at body-offset q (BLOCK/LOOP/IF), its matching END position (opcode-aware). */
fn match_end(boff: u64, blen: u64, q: u64) -> u64 {
    let mut p : u64 = q + 1u64  let mut depth : i64 = 1i64  let mut res : u64 = blen  let mut done : u32 = 0u32
    while p < blen { if done == 0u32 {
        let op : u32 = ib(boff + p)  let w : u64 = op_w(op)
        if op==0x40u32 { depth=depth+1i64 }  if op==0x41u32 { depth=depth+1i64 }  if op==0x42u32 { depth=depth+1i64 }
        if op==0x44u32 { depth=depth-1i64  if depth==0i64 { res=p  done=1u32 } }
        p = p + 1u64 + w
    } else { p = blen } }
    return res
}
/* for an IF at body-offset q, find its matching ELSE position (at depth 0) or NONE (=blen). */
fn match_else(boff: u64, blen: u64, q: u64) -> u64 {
    let mut p : u64 = q + 1u64  let mut depth : i64 = 1i64  let mut res : u64 = blen  let mut done : u32 = 0u32
    while p < blen { if done == 0u32 {
        let op : u32 = ib(boff + p)  let w : u64 = op_w(op)
        if op==0x40u32 { depth=depth+1i64 }  if op==0x41u32 { depth=depth+1i64 }  if op==0x42u32 { depth=depth+1i64 }
        if op==0x44u32 { depth=depth-1i64  if depth==0i64 { done=1u32 } }
        if op==0x43u32 { if depth==1i64 { res=p  done=1u32 } }
        if done==0u32 { p = p + 1u64 + w }
    } else { p = blen } }
    return res
}

/* execute function `fnidx` at call-frame `depth` (locals base = depth*256, control base = depth*64).
 * args are already placed in LOC[depth*256 .. +argcount] by the caller.  Returns the RETURN value. */
fn exec_fn(fnidx: u32, depth: u32) -> u64 {
    let boff : u64 = FN_OFF[fnidx as u64]
    let blen : u64 = FN_BLEN[fnidx as u64]
    if blen > 0u64 { if ib(boff) == 0x8Au32 {   /* IMPORT decl [0x8A][nl][name]: WHITELISTED CRT names dispatch to the HOST (Lambda-0 shims); everything else stays the LOUD 198 sentinel (mirrors OOB_IND; the name bytes must never EXECUTE as opcodes) */
        let sr : u64 = shim_call(boff, (depth as u64) * 256u64)
        if SHIM_HIT == 1u32 { return sr }
        UNRES_IMP = UNRES_IMP + 1u32  return 0u64 } }
    let lb   : u64 = (depth as u64) * 256u64        /* locals base */
    let cb   : u64 = (depth as u64) * 64u64         /* control-stack base */
    let mut csp : u32 = 0u32
    let mut p   : u64 = 0u64
    while p < blen {
        STEPS = STEPS + 1u64
        if STEPS > STEP_CAP { return 0u64 }
        CUR_FN = fnidx                                  /* attribute any store this iteration to THIS function */
        let op : u32 = ib(boff + p)
        let mut adv : u32 = 1u32        /* most ops advance p by 1+operand; control ops set p directly + adv=0 */
        if op == 0x60u32 { return vpop() }                                                  /* RETURN */
        if op == 0x01u32 { vpush(ird8(boff + p + 1u64))  p = p + 9u64  adv = 0u32 }          /* CONST */
        if op == 0x10u32 { let sl:u32=ib(boff+p+1u64)  vpush(LOC[lb + (sl as u64)])  p = p + 2u64  adv=0u32 }   /* LOCAL_GET */
        if op == 0x11u32 { let sl:u32=ib(boff+p+1u64)  LOC[lb + (sl as u64)] = vpop()  p = p + 2u64  adv=0u32 } /* LOCAL_SET */
        if op == 0x40u32 { CK[(cb+(csp as u64))]=0u32  CP[(cb+(csp as u64))]=p  CE[(cb+(csp as u64))]=match_end(boff,blen,p)  csp=csp+1u32 }   /* BLOCK */
        if op == 0x41u32 { CK[(cb+(csp as u64))]=1u32  CP[(cb+(csp as u64))]=p  CE[(cb+(csp as u64))]=match_end(boff,blen,p)  csp=csp+1u32 }   /* LOOP */
        if op == 0x44u32 { if csp>0u32 {csp=csp-1u32} }                                      /* END */
        if op == 0x71u32 { let c:u64=vpop()  putchar((c & 255u64) as i32) }                  /* PRINT_CHAR */
        if op == 0x72u32 { vpop() }                                                          /* DROP */
        if op == 0x42u32 { adv=0u32  let c:u64=vpop()  let me:u64=match_end(boff,blen,p)  CK[(cb+(csp as u64))]=2u32  CP[(cb+(csp as u64))]=p  CE[(cb+(csp as u64))]=me  csp=csp+1u32   /* IF */
            if c != 0u64 { p = p + 1u64 } else { let el:u64=match_else(boff,blen,p)  if el < blen { p = el + 1u64 } else { if csp>0u32 {csp=csp-1u32}  p = me + 1u64 } } }
        if op == 0x43u32 { adv=0u32  let top:u32=csp-1u32  p = CE[(cb+(top as u64))] + 1u64  if csp>0u32 {csp=csp-1u32} }   /* ELSE -> past END */
        if op == 0x50u32 { adv=0u32  let d:u32=ib(boff+p+1u64)  let tgt:u32=(csp-1u32)-d      /* BR d */
            if CK[(cb+(tgt as u64))]==1u32 { csp=tgt+1u32  p=CP[(cb+(tgt as u64))]+1u64 } else { csp=tgt  p=CE[(cb+(tgt as u64))]+1u64 } }
        if op == 0x51u32 { adv=0u32  let c:u64=vpop()  let d:u32=ib(boff+p+1u64)              /* BR_IF d */
            if c != 0u64 { let tgt:u32=(csp-1u32)-d  if CK[(cb+(tgt as u64))]==1u32 { csp=tgt+1u32  p=CP[(cb+(tgt as u64))]+1u64 } else { csp=tgt  p=CE[(cb+(tgt as u64))]+1u64 } } else { p=p+2u64 } }
        if op == 0x70u32 { adv=0u32  let fi:u32=ib(boff+p+1u64)  let ac:u32=ib(boff+p+2u64)  p=p+3u64   /* CALL fi ac */
            let nb : u64 = ((depth+1u32) as u64) * 256u64
            let mut j : u32 = ac  while j > 0u32 { j = j - 1u32  LOC[nb + (j as u64)] = vpop() }
            vpush(exec_fn(fi, depth + 1u32)) }
        if op == 0x74u32 { adv=0u32  let fi:u32=(iu16(boff+p+1u64)) as u32  let ac:u32=ib(boff+p+3u64)  p=p+4u64   /* CALL2 [fi:u16 LE][ac] */
            let nb : u64 = ((depth+1u32) as u64) * 256u64
            let mut j : u32 = ac  while j > 0u32 { j = j - 1u32  LOC[nb + (j as u64)] = vpop() }
            vpush(exec_fn(fi, depth + 1u32)) }
        if op == 0x73u32 { adv=0u32  let ac:u32=ib(boff+p+1u64)  p=p+2u64   /* CALL_INDIRECT ac : fn-index is on TOP of the eval stack (pushed after the args) */
            let fi:u32 = vpop() as u32                                       /* pop the index first */
            let nb : u64 = ((depth+1u32) as u64) * 256u64
            let mut j : u32 = ac  while j > 0u32 { j = j - 1u32  LOC[nb + (j as u64)] = vpop() }   /* then pop ac args -> callee locals */
            if fi < NFUNC { vpush(exec_fn(fi, depth + 1u32)) } else { OOB_IND = OOB_IND + 1u32  vpush(0u64) } }   /* OOB runtime index: defined-safe (no FN_OFF OOB, no silent mis-dispatch) + recorded; a real x86/wasm backend MUST TRAP here (hard Layer-3 gate) */
        if op >= 0x80u32 { if op <= 0x89u32 {                                                 /* typed memory */
            if op==0x80u32 { let a:u64=vpop()  vpush(mld(a,1u32,0u32)) }
            if op==0x82u32 { let a:u64=vpop()  vpush(mld(a,8u32,0u32)) }
            if op==0x84u32 { let a:u64=vpop()  vpush(mld(a,2u32,0u32)) }
            if op==0x85u32 { let a:u64=vpop()  vpush(mld(a,2u32,1u32)) }
            if op==0x86u32 { let a:u64=vpop()  vpush(mld(a,4u32,0u32)) }
            if op==0x87u32 { let a:u64=vpop()  vpush(mld(a,4u32,1u32)) }
            if op==0x81u32 { let v:u64=vpop()  let a:u64=vpop()  mst(a,1u32,v) }
            if op==0x83u32 { let v:u64=vpop()  let a:u64=vpop()  mst(a,8u32,v) }
            if op==0x88u32 { let v:u64=vpop()  let a:u64=vpop()  mst(a,2u32,v) }
            if op==0x89u32 { let v:u64=vpop()  let a:u64=vpop()  mst(a,4u32,v) }
        } }
        if op >= 0x20u32 { if op <= 0x35u32 {                                                 /* binops */
            let b:u64=vpop()  let a:u64=vpop()  let mut r:u64=0u64
            if op==0x20u32 { r = a + b }  if op==0x21u32 { r = a - b }  if op==0x22u32 { r = a * b }
            if op==0x23u32 { let bi:i64=b as i64  if bi != 0i64 { r = ((a as i64) / bi) as u64 } }
            if op==0x24u32 { let bi:i64=b as i64  if bi != 0i64 { r = ((a as i64) % bi) as u64 } }
            if op==0x2Au32 { if b != 0u64 { r = a / b } }  if op==0x2Bu32 { if b != 0u64 { r = a % b } }   /* DIV_U / REM_U : UNSIGNED div/mod (a,b already u64) -- the unsigned complement of SDIV/SREM */
            if op==0x25u32 { r = a & b }  if op==0x26u32 { r = a | b }  if op==0x27u32 { r = a ^ b }
            if op==0x28u32 { r = a << (b & 63u64) }  if op==0x29u32 { r = a >> (b & 63u64) }
            if op==0x30u32 { if a == b { r = 1u64 } }  if op==0x31u32 { if a != b { r = 1u64 } }
            if op==0x32u32 { let ai:i64=a as i64  let bi:i64=b as i64  if ai <  bi { r = 1u64 } }
            if op==0x33u32 { let ai:i64=a as i64  let bi:i64=b as i64  if ai >= bi { r = 1u64 } }
            if op==0x34u32 { let ai:i64=a as i64  let bi:i64=b as i64  if ai <= bi { r = 1u64 } }
            if op==0x35u32 { let ai:i64=a as i64  let bi:i64=b as i64  if ai >  bi { r = 1u64 } }
            vpush(r)
        } }
        if adv == 1u32 { p = p + 1u64 + op_w(op) }
    }
    return 0u64
}

fn load_module() {
    NFUNC = ib(0u64)
    let mut p : u64 = 1u64  let mut fi : u32 = 0u32
    if NFUNC == 0u32 { NFUNC = (iu16(1u64)) as u32  p = 3u64  V2G = 1u32 }   /* v2: 0x00 [nfunc:u16 LE], funcs from offset 3 */
    while fi < NFUNC {
        let bl : u64 = iu16(p + 2u64)
        FN_OFF[fi as u64] = p + 4u64  FN_BLEN[fi as u64] = bl
        p = p + 4u64 + bl
        fi = fi + 1u32
    }
    /* trailing data section (v1 [u16 len] ; v2 [u32 len]) -> byte-packed into MEM at offset 0 */
    let total : u64 = svir_len()
    if p < total {
        let mut dl : u64 = iu16(p)
        let mut db : u64 = p + 2u64
        if V2G == 1u32 { dl = dl | (iu16(p + 2u64) << 16u64)  db = p + 4u64 }
        DLEN_G = dl
        let mut k : u64 = 0u64  while k < dl { MEM[k] = ib(db + k) as u8  k=k+1u64 }
    }
}

fn main(argc: i32, argv: u64) -> u64 {
    load_module()
    let mut s : u32 = 0u32  while s < 256u32 { LOC[s as u64] = 0u64  s = s + 1u32 }   /* main's locals start 0 */
    /* Lambda-0 argv staging: the linked seed's main(argc, argv) reads a REAL command line.  The seed's
     * memory map is statics[0..~477K) / shadow-stack(grows DOWN from 917,504) / VA+FMT(~983K) /
     * heap(UP from 1,048,576) -- so argv must live ABOVE the heap's reach.  MEM is 4 MiB; the table +
     * strings sit at the TOP (MEM[4,190,000..]), clear of a small-input compile's heap growth (the
     * stage1_corpus programs are tiny).  8B table slots; argv[0]="iiis-0"; argv[1..]=THIS interp's
     * argv[1..].  No args -> argc=1 -> the seed's usage path (rc parity). */
    let pp : *u64 = argv as *u64
    let tb : u64 = 4190000u64
    let mut scur : u64 = 4190256u64
    MEM[scur]=105u8 MEM[scur+1u64]=105u8 MEM[scur+2u64]=105u8 MEM[scur+3u64]=115u8 MEM[scur+4u64]=45u8 MEM[scur+5u64]=48u8 MEM[scur+6u64]=0u8   /* "iiis-0" */
    let mut k8 : u64 = 0u64  while k8 < 8u64 { MEM[tb+k8] = ((scur >> (8u64*k8)) & 255u64) as u8  k8=k8+1u64 }
    scur = scur + 7u64
    let mut ai : u64 = 1u64
    while ai < (argc as u64) {
        let sp2 : *u8 = pp[ai] as *u8
        let ent : u64 = tb + ai*8u64
        let mut k9 : u64 = 0u64  while k9 < 8u64 { MEM[ent+k9] = ((scur >> (8u64*k9)) & 255u64) as u8  k9=k9+1u64 }
        let mut ci : u64 = 0u64
        while (sp2[ci] as u32) != 0u32 { MEM[scur] = sp2[ci]  scur=scur+1u64  ci=ci+1u64 }
        MEM[scur]=0u8  scur=scur+1u64
        ai = ai + 1u64
    }
    LOC[0u64] = argc as u64                       /* the seed's argc (prog name + args) */
    LOC[1u64] = tb                                /* the seed's argv */
    if FPRINTF_DBG==1u32 { putchar(10i32) putchar(68i32) putchar(73i32) putchar(61i32)   /* "DI=" data-image bytes 55..95 at startup: is literal@63 carried? */
        let mut dk:u64=55u64  while dk<95u64 { let db9:u32=MEM[dk] as u32  if db9>=32u32 { if db9<127u32 {putchar(db9 as i32)} else {putchar(46i32)} } else {putchar(46i32)}  dk=dk+1u64 }  putchar(10i32) }
    if ARGV_DBG == 1u32 { return MEM[4190256u64] as u64 }   /* DEBUG: prove the staged byte survives to exec */
    let r : u64 = exec_fn(0u32, 0u32)            /* func 0 = main (the entry); prints via PRINT_CHAR */
    if BADW_N > 0u32 {                            /* CONST-DATA CORRUPTION detected -> print the offending writes */
        putchar(10i32)  pstr2(66u32,87u32)  putchar(58i32)  putchar(32i32)   /* "BW: " */
        let mut i : u32 = 0u32
        while i < BADW_N { if i < 8u32 {           /* first 8 bad writes: fn=F@addr=A=val */
            pstr2(102u32,110u32) putchar(61i32) pdec(BADW_F[i as u64] as u64)  putchar(64i32)  pdec(BADW_A[i as u64])  putchar(61i32)  pdec(BADW_V[i as u64])  putchar(32i32)
        }  i = i + 1u32 }
        putchar(10i32)  pstr2(78u32,61u32) pdec(BADW_N as u64) putchar(10i32)   /* "N=<total>" */
    }
    if FPRINTF_DBG==1u32 { if LOWW_N>0u32 { putchar(10i32) putchar(76i32) putchar(87i32) putchar(61i32) pdec(LOWW_N as u64) putchar(91i32) pdec(LOWW_MIN) putchar(44i32) pdec(LOWW_MAX) putchar(93i32) putchar(10i32) } }   /* TEMP S4: "LW=count[min,max]" low-write sweep extent */
    if OOB_IND > 0u32 { return 199u64 }   /* an out-of-range indirect call fired -> distinct sentinel (teeth for the CALL_INDIRECT bounds-check) */
    if UNRES_IMP > 0u32 { return 198u64 }   /* a CALL reached an IMPORT-decl body (unresolved cross-module fn) -> distinct sentinel (teeth: single-file execution of an import-bearing call path must never read as green) */
    return r
}
