/* svir_loop.iii -- SVIR v1 module: ONE function (main), a real COUNTED LOOP (sum 0..99 == 4950 -> 99).
 * Proves BLOCK/LOOP/BR/BR_IF + LOCAL_GET/SET + GE_S in the v1 module format. */
module svir_loop

var SVIR : [u8; 101] = [
    1u8,                          /* func_count = 1 */
    0u8, 1u8, 96u8, 0u8,          /* func0: params=0, results=1, body_len=96 */
    /* body (96 bytes): acc=0;i=0; block{loop{ if i>=100 break; acc+=i; i+=1; continue }}; return (acc==4950)?99:1 */
    1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,   0x11u8,0u8,
    1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,   0x11u8,1u8,
    0x40u8,
    0x41u8,
    0x10u8,1u8,   1u8,100u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 0x33u8, 0x51u8,1u8,
    0x10u8,0u8,   0x10u8,1u8,   0x20u8,   0x11u8,0u8,
    0x10u8,1u8,   1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 0x20u8, 0x11u8,1u8,
    0x50u8,0u8,
    0x44u8,
    0x44u8,
    0x10u8,0u8,   1u8,0x56u8,0x13u8,0u8,0u8,0u8,0u8,0u8,0u8, 0x30u8,
    1u8,98u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 0x22u8,
    1u8,1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8, 0x20u8,
    0x60u8
]

fn svir_ptr() -> u64 @export { return &SVIR as u64 }
fn svir_len() -> u64 @export { return 101u64 }
