/* svir_prog.iii -- SVIR v1 module: ONE function (main), straight-line arithmetic (gauss == 4950 -> 99).
 * v1 module format:  [u8 func_count]  then per function: [u8 param_count][u8 nresults][u16 LE body_len][body].
 * Func 0 is the entry (main). locals 0..param_count-1 are the params. */
module svir_prog

var SVIR : [u8; 65] = [
    1u8,                          /* func_count = 1 */
    0u8, 1u8, 60u8, 0u8,          /* func0: params=0, results=1, body_len=60 */
    /* body (60 bytes): CONST 100;CONST 99;MUL;CONST 2;SDIV;CONST 4950;EQ;CONST 98;MUL;CONST 1;ADD;RETURN */
    1u8,100u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,
    1u8, 99u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,
    0x22u8,
    1u8,  2u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,
    0x23u8,
    1u8,0x56u8,0x13u8,0u8,0u8,0u8,0u8,0u8,0u8,
    0x30u8,
    1u8, 98u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,
    0x22u8,
    1u8,  1u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,
    0x20u8,
    0x60u8
]

fn svir_ptr() -> u64 @export { return &SVIR as u64 }
fn svir_len() -> u64 @export { return 65u64 }
