/* svir_riscv_w.iii -- svir_riscv AS A WAIST OBJECT (Γ3 × Γ2d): the SVIR->ELF64-RV64IM translator in the
 * iiisv subset.  Same memory contract as svir_elf_w / svir_arm64_w (PLEN_[16..23] input length, INP[24..)
 * input bytes), same byte-match law: output must be BYTE-IDENTICAL to native svir_riscv for every program.
 * With this, ALL THREE native ISAs (x86-64, AArch64, RV64) travel as anchor-verified SVIR: an x86-64 Linux
 * germ regrows RISC-V binaries on a host with no RISC-V hardware and no foreign toolchain.  Logic is
 * svir_riscv.iii line-for-line; opcodes are decimal (OP=51 OPIMM=19 LUI=55 BRANCH=99 JAL=111 LOAD=3
 * STORE=35 OPIMM32=27 JALR=103 ecall-word=115).  Frame bound: emitted-program frames use a 12-bit addi
 * (fsz<=2047); every corpus program is far under (default 512). */
module svir_riscv_w

var PLEN_ : [u8; 8]
var INP : [u8; 262144]

var LBL : [u64; 16384]
var FSTART : [u64; 1024]
var CS_KIND : [u64; 1024]
var CS_TGT  : [u64; 1024]
var CS_ELSE : [u64; 1024]
var CS_ELSEEN : [u64; 1024]

var PASS : u64 = 0
var CUR  : u64 = 0
var CS_N : u64 = 0
var LBLCTR : u64 = 0
var SVCIADDR : u64 = 0

fn ob(b: u64) { svir_putc(b & 255) }
fn o16(v: u64) { ob(v & 255)  ob((v >> 8) & 255) }
fn o32(v: u64) { o16(v & 65535)  o16((v >> 16) & 65535) }
fn o64(v: u64) { o32(v & 4294967295)  o32(v >> 32) }

fn w32(w: u64) {
    if PASS == 2 { ob(w & 255)  ob((w >> 8) & 255)  ob((w >> 16) & 255)  ob((w >> 24) & 255) }
    CUR = CUR + 4
}

fn rv_r(funct7: u64, rs2: u64, rs1: u64, funct3: u64, rd: u64, opc: u64) { w32((funct7 << 25) | (rs2 << 20) | (rs1 << 15) | (funct3 << 12) | (rd << 7) | opc) }
fn rv_i(imm12: u64, rs1: u64, funct3: u64, rd: u64, opc: u64) { w32(((imm12 & 4095) << 20) | (rs1 << 15) | (funct3 << 12) | (rd << 7) | opc) }
fn rv_s(imm12: u64, rs2: u64, rs1: u64, funct3: u64, opc: u64) { w32((((imm12 >> 5) & 127) << 25) | (rs2 << 20) | (rs1 << 15) | (funct3 << 12) | ((imm12 & 31) << 7) | opc) }
fn rv_u(imm20: u64, rd: u64, opc: u64) { w32(((imm20 & 1048575) << 12) | (rd << 7) | opc) }
fn rv_b(imm: u64, rs2: u64, rs1: u64, funct3: u64) {
    let b12 : u64 = (imm >> 12) & 1  let b11 : u64 = (imm >> 11) & 1
    let b10_5 : u64 = (imm >> 5) & 63  let b4_1 : u64 = (imm >> 1) & 15
    w32((b12 << 31) | (b10_5 << 25) | (rs2 << 20) | (rs1 << 15) | (funct3 << 12) | (b4_1 << 8) | (b11 << 7) | 99)
}
fn rv_j(imm: u64, rd: u64) {
    let b20 : u64 = (imm >> 20) & 1  let b10_1 : u64 = (imm >> 1) & 1023
    let b11 : u64 = (imm >> 11) & 1  let b19_12 : u64 = (imm >> 12) & 255
    w32((b20 << 31) | (b10_1 << 21) | (b11 << 20) | (b19_12 << 12) | (rd << 7) | 111)
}

fn hi20(x: u64) -> u64 { return ((x + 2048) >> 12) & 1048575 }
fn lo12(x: u64) -> u64 { return x & 4095 }
fn li64(rd: u64, imm: u64) {
    let lo : u64 = imm & 4294967295
    let hi : u64 = (imm >> 32) & 4294967295
    rv_u(hi20(lo), rd, 55)
    rv_i(lo12(lo), rd, 0, rd, 27)
    rv_i(32, rd, 1, rd, 19)
    rv_i(32, rd, 5, rd, 19)
    rv_u(hi20(hi), 31, 55)
    rv_i(lo12(hi), 31, 0, 31, 27)
    rv_i(32, 31, 1, 31, 19)
    rv_r(0, 31, rd, 6, rd, 51)
}

fn e_push(rs: u64) { rv_i(4088, 18, 0, 18, 19)  rv_s(0, rs, 18, 3, 35) }
fn e_pop(rd: u64)  { rv_i(0, 18, 3, rd, 3)  rv_i(8, 18, 0, 18, 19) }
fn e_membase(rd: u64) { rv_u(2560, rd, 55) }

fn ld_loc(rd: u64, uoff: u64) { rv_i(uoff, 2, 3, rd, 3) }
fn sd_loc(rs: u64, uoff: u64) { rv_s(uoff, rs, 2, 3, 35) }

fn e_exit_imm(code: u64) { li64(10, code)  li64(17, 93)  w32(115) }

fn hdr_nfunc() -> u64 { let n : u64 = INP[0]  if n == 0 { return INP[1] | (INP[2] << 8) }  return n }
fn hdr_off() -> u64 { if INP[0] == 0 { return 3 }  return 1 }

fn lbl_here(id: u64) { if PASS == 1 { LBL[id] = CUR } }
fn loc_off(slot: u64) -> u64 { return 16 + (8 * slot) }

fn j_to(id: u64) { let t : u64 = LBL[id]  rv_j(t - CUR, 0) }
fn br_if_zero_to(rs: u64, id: u64) { rv_b(8, 0, rs, 1)  let t : u64 = LBL[id]  rv_j(t - CUR, 0) }
fn br_if_nz_to(rs: u64, id: u64)   { rv_b(8, 0, rs, 0)  let t : u64 = LBL[id]  rv_j(t - CUR, 0) }

fn max_local(boff: u64, blen: u64) -> u64 {
    let mut mx : u64 = 0  let mut s : u64 = 0
    while s < blen {
        let o : u64 = INP[boff + s]  s = s + 1
        if o == 1 { s = s + 8 }
        if o == 16 { let li : u64 = INP[boff + s]  if li > mx { mx = li }  s = s + 1 }
        if o == 17 { let li : u64 = INP[boff + s]  if li > mx { mx = li }  s = s + 1 }
        if o == 80 { s = s + 1 }
        if o == 81 { s = s + 1 }
        if o == 112 { s = s + 2 }
        if o == 115 { s = s + 1 }
        if o == 116 { s = s + 3 }
    }
    return mx
}

fn e_call_seq(ac: u64, kind: u64, tgt: u64) {
    let mut stackargs : u64 = 0  if ac > 8 { stackargs = ac - 8 }
    let ssz : u64 = (((8 * stackargs) + 15) / 16) * 16
    if ssz > 0 { rv_i(4096 - ssz, 2, 0, 2, 19) }
    let mut i : u64 = 8
    while i < ac {
        rv_i(8 * ((ac - 1) - i), 18, 3, 5, 3)
        rv_s(8 * (i - 8), 5, 2, 3, 35)
        i = i + 1
    }
    let mut nreg : u64 = ac  if nreg > 8 { nreg = 8 }
    let mut j : u64 = 0
    while j < nreg { rv_i(8 * ((ac - 1) - j), 18, 3, 10 + j, 3)  j = j + 1 }
    if kind == 0 { rv_j(tgt - CUR, 1) } else { rv_j(SVCIADDR - CUR, 1) }
    if ssz > 0 { rv_i(ssz, 2, 0, 2, 19) }
    rv_i(8 * ac, 18, 0, 18, 19)
    e_push(10)
}

fn gen_function(boff: u64, blen: u64, params: u64) {
    CS_N = 0
    if blen > 0 { if INP[boff] == 138 { e_exit_imm(198)  return 0 } }
    let ml : u64 = max_local(boff, blen)
    let need : u64 = ((((16 + (8 * (ml + 1))) + 64) + 15) / 16) * 16
    let mut fsz : u64 = need  if fsz < 512 { fsz = 512 }
    rv_i(4096 - fsz, 2, 0, 2, 19)
    rv_s(fsz - 8, 1, 2, 3, 35)
    let mut j : u64 = 0
    while j < params {
        if j < 8 { sd_loc(10 + j, loc_off(j)) }
        else { rv_i(fsz + (8 * (j - 8)), 2, 3, 5, 3)  sd_loc(5, loc_off(j)) }
        j = j + 1
    }
    let mut p : u64 = 0
    while p < blen {
        let op : u64 = INP[boff + p]  p = p + 1
        if op == 1 {
            let mut imm : u64 = 0  let mut k : u64 = 0
            while k < 8 { imm = imm | (INP[boff + p + k] << (8 * k))  k = k + 1 }
            p = p + 8
            li64(5, imm)  e_push(5)
        }
        if op == 16 { let slot : u64 = INP[boff + p]  p = p + 1  ld_loc(5, loc_off(slot))  e_push(5) }
        if op == 17 { let slot : u64 = INP[boff + p]  p = p + 1  e_pop(5)  sd_loc(5, loc_off(slot)) }
        if op == 32 { e_pop(6)  e_pop(5)  rv_r(0, 6, 5, 0, 5, 51)  e_push(5) }
        if op == 33 { e_pop(6)  e_pop(5)  rv_r(32, 6, 5, 0, 5, 51)  e_push(5) }
        if op == 34 { e_pop(6)  e_pop(5)  rv_r(1, 6, 5, 0, 5, 51)  e_push(5) }
        if op == 35 { e_pop(6)  e_pop(5)  rv_r(1, 6, 5, 4, 5, 51)  e_push(5) }
        if op == 36 { e_pop(6)  e_pop(5)  rv_r(1, 6, 5, 6, 5, 51)  e_push(5) }
        if op == 42 { e_pop(6)  e_pop(5)  rv_r(1, 6, 5, 5, 5, 51)  e_push(5) }
        if op == 43 { e_pop(6)  e_pop(5)  rv_r(1, 6, 5, 7, 5, 51)  e_push(5) }
        if op == 37 { e_pop(6)  e_pop(5)  rv_r(0, 6, 5, 7, 5, 51)  e_push(5) }
        if op == 38 { e_pop(6)  e_pop(5)  rv_r(0, 6, 5, 6, 5, 51)  e_push(5) }
        if op == 39 { e_pop(6)  e_pop(5)  rv_r(0, 6, 5, 4, 5, 51)  e_push(5) }
        if op == 40 { e_pop(6)  e_pop(5)  rv_r(0, 6, 5, 1, 5, 51)  e_push(5) }
        if op == 41 { e_pop(6)  e_pop(5)  rv_r(0, 6, 5, 5, 5, 51)  e_push(5) }
        if op == 48 { e_pop(6)  e_pop(5)  rv_r(32, 6, 5, 0, 5, 51)  rv_i(1, 5, 3, 5, 19)  e_push(5) }
        if op == 49 { e_pop(6)  e_pop(5)  rv_r(32, 6, 5, 0, 5, 51)  rv_r(0, 5, 0, 3, 5, 51)  e_push(5) }
        if op == 50 { e_pop(6)  e_pop(5)  rv_r(0, 6, 5, 2, 5, 51)  e_push(5) }
        if op == 51 { e_pop(6)  e_pop(5)  rv_r(0, 6, 5, 2, 5, 51)  rv_i(1, 5, 4, 5, 19)  e_push(5) }
        if op == 52 { e_pop(6)  e_pop(5)  rv_r(0, 5, 6, 2, 5, 51)  rv_i(1, 5, 4, 5, 19)  e_push(5) }
        if op == 53 { e_pop(6)  e_pop(5)  rv_r(0, 5, 6, 2, 5, 51)  e_push(5) }
        if op == 64 { CS_KIND[CS_N] = 0  CS_TGT[CS_N] = LBLCTR  LBLCTR = LBLCTR + 1  CS_N = CS_N + 1 }
        if op == 65 { let id : u64 = LBLCTR  LBLCTR = LBLCTR + 1  lbl_here(id)  CS_KIND[CS_N] = 1  CS_TGT[CS_N] = id  CS_N = CS_N + 1 }
        if op == 66 {
            let endid : u64 = LBLCTR  LBLCTR = LBLCTR + 1
            let elsid : u64 = LBLCTR  LBLCTR = LBLCTR + 1
            e_pop(5)  br_if_zero_to(5, elsid)
            CS_KIND[CS_N] = 2  CS_TGT[CS_N] = endid  CS_ELSE[CS_N] = elsid  CS_ELSEEN[CS_N] = 0  CS_N = CS_N + 1
        }
        if op == 67 { let tt : u64 = CS_N - 1  j_to(CS_TGT[tt])  lbl_here(CS_ELSE[tt])  CS_ELSEEN[tt] = 1 }
        if op == 68 {
            CS_N = CS_N - 1
            let kind : u64 = CS_KIND[CS_N]
            if kind == 0 { lbl_here(CS_TGT[CS_N]) }
            if kind == 2 { if CS_ELSEEN[CS_N] == 0 { lbl_here(CS_ELSE[CS_N]) }  lbl_here(CS_TGT[CS_N]) }
        }
        if op == 80 { let depth : u64 = INP[boff + p]  p = p + 1  j_to(CS_TGT[(CS_N - 1) - depth]) }
        if op == 81 { let depth : u64 = INP[boff + p]  p = p + 1  e_pop(5)  br_if_nz_to(5, CS_TGT[(CS_N - 1) - depth]) }
        if op == 128 { e_pop(5)  e_membase(7)  rv_r(0, 5, 7, 0, 28, 51)  rv_i(0, 28, 4, 5, 3)  e_push(5) }
        if op == 129 { e_pop(6)  e_pop(5)  e_membase(7)  rv_r(0, 5, 7, 0, 28, 51)  rv_s(0, 6, 28, 0, 35) }
        if op == 130 { e_pop(5)  e_membase(7)  rv_r(0, 5, 7, 0, 28, 51)  rv_i(0, 28, 3, 5, 3)  e_push(5) }
        if op == 131 { e_pop(6)  e_pop(5)  e_membase(7)  rv_r(0, 5, 7, 0, 28, 51)  rv_s(0, 6, 28, 3, 35) }
        if op == 132 { e_pop(5)  e_membase(7)  rv_r(0, 5, 7, 0, 28, 51)  rv_i(0, 28, 5, 5, 3)  e_push(5) }
        if op == 133 { e_pop(5)  e_membase(7)  rv_r(0, 5, 7, 0, 28, 51)  rv_i(0, 28, 1, 5, 3)  e_push(5) }
        if op == 134 { e_pop(5)  e_membase(7)  rv_r(0, 5, 7, 0, 28, 51)  rv_i(0, 28, 6, 5, 3)  e_push(5) }
        if op == 135 { e_pop(5)  e_membase(7)  rv_r(0, 5, 7, 0, 28, 51)  rv_i(0, 28, 2, 5, 3)  e_push(5) }
        if op == 136 { e_pop(6)  e_pop(5)  e_membase(7)  rv_r(0, 5, 7, 0, 28, 51)  rv_s(0, 6, 28, 1, 35) }
        if op == 137 { e_pop(6)  e_pop(5)  e_membase(7)  rv_r(0, 5, 7, 0, 28, 51)  rv_s(0, 6, 28, 2, 35) }
        if op == 114 { rv_i(8, 18, 0, 18, 19) }
        if op == 113 {
            e_pop(5)
            rv_s(4088, 5, 18, 0, 35)
            rv_i(4088, 18, 0, 11, 19)
            li64(10, 1)
            li64(12, 1)
            li64(17, 64)
            w32(115)
        }
        if op == 96 {
            e_pop(10)
            rv_i(fsz - 8, 2, 3, 1, 3)
            rv_i(fsz, 2, 0, 2, 19)
            rv_i(0, 1, 0, 0, 103)
        }
        if op == 112 {
            let fi : u64 = INP[boff + p]
            let ac : u64 = INP[boff + p + 1]
            p = p + 2
            e_call_seq(ac, 0, FSTART[fi])
        }
        if op == 116 {
            let fi : u64 = INP[boff + p] | (INP[boff + p + 1] << 8)
            let ac : u64 = INP[boff + p + 2]
            p = p + 3
            e_call_seq(ac, 0, FSTART[fi])
        }
        if op == 115 {
            let ac : u64 = INP[boff + p]
            p = p + 1
            e_pop(29)
            e_call_seq(ac, 1, 0)
        }
    }
    return 0
}

fn mod_has_ci() -> u64 {
    let nf : u64 = hdr_nfunc()
    let mut off : u64 = hdr_off()  let mut i : u64 = 0
    while i < nf {
        let blen : u64 = INP[off + 2] | (INP[off + 3] << 8)
        let boff : u64 = off + 4
        let mut s : u64 = 0
        while s < blen {
            let o : u64 = INP[boff + s]  s = s + 1
            if o == 115 { return 1 }
            if o == 1 { s = s + 8 }
            if o == 16 { s = s + 1 }
            if o == 17 { s = s + 1 }
            if o == 80 { s = s + 1 }
            if o == 81 { s = s + 1 }
            if o == 112 { s = s + 2 }
            if o == 116 { s = s + 3 }
            if o == 138 { s = s + 1 + INP[boff + s] }
        }
        off = off + 4 + blen
        i = i + 1
    }
    return 0
}
fn mod_has_mem() -> u64 {
    let nf : u64 = hdr_nfunc()
    let mut off : u64 = hdr_off()  let mut i : u64 = 0
    while i < nf {
        let blen : u64 = INP[off + 2] | (INP[off + 3] << 8)
        let boff : u64 = off + 4
        let mut s : u64 = 0
        while s < blen {
            let o : u64 = INP[boff + s]  s = s + 1
            if o == 128 { return 1 }
            if o == 129 { return 1 }
            if o == 130 { return 1 }
            if o == 131 { return 1 }
            if o >= 132 { if o <= 137 { return 1 } }
            if o == 1 { s = s + 8 }
            if o == 16 { s = s + 1 }
            if o == 17 { s = s + 1 }
            if o == 80 { s = s + 1 }
            if o == 81 { s = s + 1 }
            if o == 112 { s = s + 2 }
            if o == 115 { s = s + 1 }
            if o == 116 { s = s + 3 }
            if o == 138 { s = s + 1 + INP[boff + s] }
        }
        off = off + 4 + blen
        i = i + 1
    }
    return 0
}

fn gen_svci_real(nfunc: u64) {
    let mut k : u64 = 0
    while k < nfunc {
        li64(30, k)
        rv_b(8, 30, 29, 1)
        rv_j(FSTART[k] - CUR, 0)
        k = k + 1
    }
    e_exit_imm(199)
}

fn text_pass(nfunc: u64, hasci: u64) {
    LBLCTR = 0
    rv_u(2304, 18, 55)
    rv_j(FSTART[0] - CUR, 1)
    li64(17, 93)
    w32(115)
    let mut off : u64 = hdr_off()
    let mut i : u64 = 0
    while i < nfunc {
        if PASS == 1 { FSTART[i] = CUR }
        let params : u64 = INP[off]
        let blen : u64 = INP[off + 2] | (INP[off + 3] << 8)
        gen_function(off + 4, blen, params)
        off = off + 4 + blen
        i = i + 1
    }
    if hasci == 1 { if PASS == 1 { SVCIADDR = CUR }  gen_svci_real(nfunc) }
}

fn main() -> u64 {
    let mut total : u64 = 0  let mut tk : u64 = 0
    while tk < 8 { total = total | (PLEN_[tk] << (8 * tk))  tk = tk + 1 }
    let nfunc : u64 = hdr_nfunc()
    let mut isv2 : u64 = 0  if INP[0] == 0 { isv2 = 1 }
    let hasci : u64 = mod_has_ci()
    let hasmem : u64 = mod_has_mem()
    let mut off : u64 = hdr_off()
    let mut i : u64 = 0
    while i < nfunc {
        let blen : u64 = INP[off + 2] | (INP[off + 3] << 8)
        off = off + 4 + blen
        i = i + 1
    }
    let mut dlen : u64 = 0
    let mut dhd : u64 = 2
    if isv2 == 1 { dhd = 4 }
    if off < total {
        dlen = INP[off] | (INP[off + 1] << 8)
        if isv2 == 1 { dlen = dlen | (INP[off + 2] << 16) | (INP[off + 3] << 24) }
    }
    let baseva : u64 = 4194304
    let mut phnum : u64 = 2  if hasmem == 1 { phnum = 3 }
    let t0 : u64 = 64 + (56 * phnum)
    let start : u64 = baseva + t0
    PASS = 1  CUR = start
    text_pass(nfunc, hasci)
    let textend : u64 = CUR
    let fsz1 : u64 = textend - baseva
    let d0off : u64 = ((fsz1 + 4095) / 4096) * 4096
    ob(127)  ob(69)  ob(76)  ob(70)
    ob(2)  ob(1)  ob(1)  ob(0)
    o64(0)
    o16(2)
    o16(243)
    o32(1)
    o64(start)
    o64(64)
    o64(0)
    o32(0)
    o16(64)  o16(56)  o16(phnum)
    o16(0)  o16(0)  o16(0)
    o32(1)  o32(5)
    o64(0)  o64(baseva)  o64(baseva)
    o64(fsz1)  o64(fsz1)  o64(4096)
    o32(1)  o32(6)
    o64(0)  o64(8388608)  o64(8388608)
    o64(0)  o64(1048576)  o64(4096)
    if hasmem == 1 {
        o32(1)  o32(6)
        o64(d0off)  o64(10485760)  o64(10485760)
        o64(dlen)  o64(4194304)  o64(4096)
    }
    PASS = 2  CUR = start
    text_pass(nfunc, hasci)
    if hasmem == 1 { if dlen > 0 {
        let mut z : u64 = fsz1
        while z < d0off { ob(0)  z = z + 1 }
        let mut d : u64 = 0
        while d < dlen { ob(INP[off + dhd + d])  d = d + 1 }
    } }
    return 99
}
