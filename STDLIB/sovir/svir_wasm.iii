/* svir_wasm.iii -- TRANSLATOR #2 (SVIR v1/v2): a multi-function .wasm module to stdout.
 * v1 module: [u8 func_count] then per func [u8 params][u8 nresults][u16 LE body_len][body].
 * v2 module: first byte 0x00 (illegal in v1) then [func_count:u16 LE], funcs from offset 3; data length u32.
 * CALL2 = 0x74 [fi:u16 LE][ac:u8] -> the same `call` lowering as CALL, wide index (LEB carries it natively).
 * PRINT_CHAR -> call an imported env.putc (the host does I/O); imports shift the func index space, so a module
 * that prints gets import_count=1 and every CALL/main/export index is offset by 1.  Independent of svir_x86.
 * CALL_INDIRECT -> i32.wrap_i64 (the popped SVIR index) + native call_indirect over a funcref table whose
 * slot k holds defined func k (wasm index k+IC) -- SVIR's index space verbatim, so the engine's own bounds
 * check traps an OOB index natively; the per-arg-count (ac x i64)->i64 types are appended after the per-fn
 * types at indices IC+FN_N+j.  Table/elem/extra types are emitted ONLY when a 0x73 occurs (byte-stable). */
module svir_wasm

extern @abi(c-msvc-x64) fn svir_ptr() -> u64 from "svir_prog.iii"
extern @abi(c-msvc-x64) fn svir_len() -> u64 from "svir_prog.iii"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn _setmode(fd: i32, mode: i32) -> i32 from "msvcrt"

fn pc(c: u32) { putchar((c & 0xFFu32) as i32) }
fn pleb_u(n0: u64) { let mut n : u64 = n0  let mut go : u32 = 1u32  while go == 1u32 { if n >= 128u64 { pc(((n & 0x7Fu64) | 0x80u64) as u32)  n = n >> 7u64 } else { pc(n as u32)  go = 0u32 } } }
fn leblen_u(n0: u64) -> u64 { let mut n : u64 = n0  let mut c : u64 = 1u64  while n >= 128u64 { c = c + 1u64  n = n >> 7u64 }  return c }

var FN_PARAMS : [u32; 4096]
var FN_BOFF   : [u64; 4096]
var FN_BLEN   : [u64; 4096]
var FN_N : u32 = 0u32
var IC : u32 = 0u32                 /* import count (1 if any PRINT_CHAR -> env.putc) */

var CBUF : [u8; 4194304]            /* all functions' wasm bodies concatenated -- seed modules reach 100+ fns */
var CLEN : u64 = 0u64
/* CALL_INDIRECT support: the distinct arg-counts seen at 0x73 sites (first-seen order, deterministic).
 * ci type j lives at type index IC+FN_N+j; ac is a u8 so 256 slots is total (no silent cap). */
var CI_ACS : [u32; 256]
var CI_NAC : u32 = 0u32
fn ci_type_pos(ac: u32) -> u32 {
    let mut i : u32 = 0u32
    while i < CI_NAC { if CI_ACS[i as u64] == ac { return i }  i = i + 1u32 }
    CI_ACS[CI_NAC as u64] = ac  let s : u32 = CI_NAC  CI_NAC = CI_NAC + 1u32  return s
}
var FN_COFF : [u64; 4096]
var FN_CLEN : [u64; 4096]
fn c_emit(byte: u32) { if CLEN < 4194303u64 { CBUF[CLEN] = (byte & 0xFFu32) as u8  CLEN = CLEN + 1u64 } }
fn c_leb_u(n0: u64) { let mut n : u64 = n0  let mut go : u32 = 1u32  while go == 1u32 { if n >= 128u64 { c_emit(((n & 0x7Fu64) | 0x80u64) as u32)  n = n >> 7u64 } else { c_emit(n as u32)  go = 0u32 } } }
fn c_leb_s64(v0: i64) {
    let mut v : i64 = v0  let mut more : u32 = 1u32
    while more == 1u32 {
        let byte : u32 = ((v as u64) & 0x7Fu64) as u32
        let neg : u32 = ((v as u64) >> 63u64) as u32                              /* sign bit before the shift */
        v = ((v as u64) >> 7u64) as i64                                          /* logical >> ... */
        if neg == 1u32 { v = ((v as u64) | 0xFE00000000000000u64) as i64 }       /* ...then sign-extend -> ARITHMETIC (robust vs iiis-2's >>) */
        let signset : u32 = byte & 0x40u32
        if v == 0i64 { if signset == 0u32 { more = 0u32 } }
        if v == (0i64 - 1i64) { if signset != 0u32 { more = 0u32 } }
        if more == 1u32 { c_emit(byte | 0x80u32) } else { c_emit(byte) }
    }
}

fn build_body(base: u64, boff: u64, blen: u64, params: u32) {
    if blen > 0u64 { let ip0 : *u8 = (base + boff) as *u8  if (ip0[0u64] as u32) == 0x8Au32 {   /* IMPORT decl [0x8A][nl][name] (svir_verify:49): emit a TRAP-STUB body -- 0 locals ; `unreachable` ; end.  `unreachable` is stack-polymorphic so the stub validates against the fn's declared type; executing it (a single-file call of an unresolved cross-module fn) is a native RuntimeError (node rc=1), mirroring the CALL_INDIRECT OOB gate.  Walking the name bytes instead registered PHANTOM call_indirect arg-counts (a name byte 0x73 's') and produced an invalid module (the _imp_dead.c wasm=1 pre-fix reading). */
        c_emit(0x00u32)  c_emit(0x00u32)  c_emit(0x0Bu32)
        return
    } }
    let mut nloc : u32 = params
    let mut s : u64 = 0u64
    while s < blen {
        let sop : *u8 = (base + boff + s) as *u8  let o : u32 = sop[0u64] as u32  s = s + 1u64
        if o == 0x01u32 { s = s + 8u64 }
        if o == 0x10u32 { let lp : *u8 = (base + boff + s) as *u8  let sl : u32 = lp[0u64] as u32  s = s + 1u64  if (sl + 1u32) > nloc { nloc = sl + 1u32 } }
        if o == 0x11u32 { let lp : *u8 = (base + boff + s) as *u8  let sl : u32 = lp[0u64] as u32  s = s + 1u64  if (sl + 1u32) > nloc { nloc = sl + 1u32 } }
        if o == 0x50u32 { s = s + 1u64 }
        if o == 0x51u32 { s = s + 1u64 }
        if o == 0x70u32 { s = s + 2u64 }
        if o == 0x73u32 { s = s + 1u64 }
        if o == 0x74u32 { s = s + 3u64 }
    }
    let extra : u32 = nloc - params
    if extra == 0u32 { c_emit(0x00u32) } else { c_emit(0x01u32)  c_leb_u(extra as u64)  c_emit(0x7Eu32) }

    let mut p : u64 = 0u64
    while p < blen {
        let opp : *u8 = (base + boff + p) as *u8  let op : u32 = opp[0u64] as u32  p = p + 1u64
        if op == 0x01u32 {
            let mut imm : u64 = 0u64  let mut k : u64 = 0u64
            while k < 8u64 { let bp : *u8 = (base + boff + p + k) as *u8  imm = imm | ((bp[0u64] as u64) << (8u64 * k))  k = k + 1u64 }
            p = p + 8u64
            c_emit(0x42u32)  c_leb_s64(imm as i64)
        }
        if op == 0x10u32 { let lp : *u8 = (base + boff + p) as *u8  p = p + 1u64  c_emit(0x20u32)  c_leb_u(lp[0u64] as u64) }
        if op == 0x11u32 { let lp : *u8 = (base + boff + p) as *u8  p = p + 1u64  c_emit(0x21u32)  c_leb_u(lp[0u64] as u64) }
        if op == 0x20u32 { c_emit(0x7Cu32) }
        if op == 0x21u32 { c_emit(0x7Du32) }
        if op == 0x22u32 { c_emit(0x7Eu32) }
        if op == 0x23u32 { c_emit(0x7Fu32) }
        if op == 0x24u32 { c_emit(0x81u32) }                  /* SREM -> i64.rem_s */
        if op == 0x2Au32 { c_emit(0x80u32) }                  /* DIV_U -> i64.div_u */
        if op == 0x2Bu32 { c_emit(0x82u32) }                  /* REM_U -> i64.rem_u */
        if op == 0x30u32 { c_emit(0x51u32)  c_emit(0xADu32) }
        if op == 0x32u32 { c_emit(0x53u32)  c_emit(0xADu32) }  /* LT_S -> i64.lt_s (0x53; 0x55 is gt_s) ; extend */
        if op == 0x33u32 { c_emit(0x59u32)  c_emit(0xADu32) }
        if op == 0x34u32 { c_emit(0x57u32)  c_emit(0xADu32) }  /* LE_S -> i64.le_s ; extend */
        if op == 0x35u32 { c_emit(0x55u32)  c_emit(0xADu32) }  /* GT_S -> i64.gt_s ; extend */
        if op == 0x31u32 { c_emit(0x52u32)  c_emit(0xADu32) }  /* NE   -> i64.ne ; extend */
        if op == 0x25u32 { c_emit(0x83u32) }                   /* AND  -> i64.and */
        if op == 0x26u32 { c_emit(0x84u32) }                   /* OR   -> i64.or */
        if op == 0x27u32 { c_emit(0x85u32) }                   /* XOR  -> i64.xor */
        if op == 0x28u32 { c_emit(0x86u32) }                   /* SHL  -> i64.shl */
        if op == 0x29u32 { c_emit(0x88u32) }                   /* SHR_U -> i64.shr_u */
        if op == 0x40u32 { c_emit(0x02u32)  c_emit(0x40u32) }
        if op == 0x41u32 { c_emit(0x03u32)  c_emit(0x40u32) }
        if op == 0x42u32 { c_emit(0xA7u32)  c_emit(0x04u32)  c_emit(0x40u32) }
        if op == 0x43u32 { c_emit(0x05u32) }
        if op == 0x44u32 { c_emit(0x0Bu32) }
        if op == 0x50u32 { let dp : *u8 = (base + boff + p) as *u8  p = p + 1u64  c_emit(0x0Cu32)  c_leb_u(dp[0u64] as u64) }
        if op == 0x51u32 { let dp : *u8 = (base + boff + p) as *u8  p = p + 1u64  c_emit(0xA7u32)  c_emit(0x0Du32)  c_leb_u(dp[0u64] as u64) }
        if op == 0x60u32 { c_emit(0x0Fu32) }
        if op == 0x70u32 { let fp : *u8 = (base + boff + p) as *u8  let f : u32 = fp[0u64] as u32  p = p + 2u64  c_emit(0x10u32)  c_leb_u((f + IC) as u64) }   /* CALL -> call (funcidx + imports) */
        if op == 0x74u32 { let f0 : *u8 = (base + boff + p) as *u8  let f1 : *u8 = (base + boff + p + 1u64) as *u8  let f : u32 = (f0[0u64] as u32) | ((f1[0u64] as u32) << 8u32)  p = p + 3u64  c_emit(0x10u32)  c_leb_u((f + IC) as u64) }   /* CALL2 [fi:u16][ac] -> the same `call` (LEB funcidx) */
        if op == 0x73u32 { let ap : *u8 = (base + boff + p) as *u8  let ac : u32 = ap[0u64] as u32  p = p + 1u64   /* CALL_INDIRECT ac : SVIR index on TOP (i64) */
            c_emit(0xA7u32)  c_emit(0x11u32)  c_leb_u((FN_N + IC + ci_type_pos(ac)) as u64)  c_emit(0x00u32) }    /* i32.wrap_i64 ; call_indirect (ac-type) (table 0) -- engine bounds-check traps OOB */
        if op == 0x71u32 { c_emit(0x10u32)  c_leb_u(0u64) }   /* PRINT_CHAR -> call $putc (import 0) */
        if op == 0x72u32 { c_emit(0x1Au32) }                  /* DROP */
        if op == 0x80u32 { c_emit(0xA7u32)  c_emit(0x31u32)  c_emit(0x00u32)  c_emit(0x00u32) }   /* LOAD8: i32.wrap_i64 ; i64.load8_u a0 o0 */
        if op == 0x81u32 { c_emit(0x24u32)  c_emit(0x00u32)  c_emit(0xA7u32)  c_emit(0x23u32)  c_emit(0x00u32)  c_emit(0x3Cu32)  c_emit(0x00u32)  c_emit(0x00u32) }   /* STORE8: global.set0(val) ; wrap(addr) ; global.get0(val) ; i64.store8 */
        if op == 0x82u32 { c_emit(0xA7u32)  c_emit(0x29u32)  c_emit(0x03u32)  c_emit(0x00u32) }   /* LOAD64: i32.wrap_i64 ; i64.load a3 o0 */
        if op == 0x83u32 { c_emit(0x24u32)  c_emit(0x00u32)  c_emit(0xA7u32)  c_emit(0x23u32)  c_emit(0x00u32)  c_emit(0x37u32)  c_emit(0x03u32)  c_emit(0x00u32) }   /* STORE64: global.set0(val) ; wrap(addr) ; global.get0(val) ; i64.store a3 o0 */
        if op == 0x84u32 { c_emit(0xA7u32)  c_emit(0x33u32)  c_emit(0x01u32)  c_emit(0x00u32) }   /* LOAD16_U: i32.wrap_i64 ; i64.load16_u a1 o0 */
        if op == 0x85u32 { c_emit(0xA7u32)  c_emit(0x32u32)  c_emit(0x01u32)  c_emit(0x00u32) }   /* LOAD16_S: i32.wrap_i64 ; i64.load16_s a1 o0 */
        if op == 0x86u32 { c_emit(0xA7u32)  c_emit(0x35u32)  c_emit(0x02u32)  c_emit(0x00u32) }   /* LOAD32_U: i32.wrap_i64 ; i64.load32_u a2 o0 */
        if op == 0x87u32 { c_emit(0xA7u32)  c_emit(0x34u32)  c_emit(0x02u32)  c_emit(0x00u32) }   /* LOAD32_S: i32.wrap_i64 ; i64.load32_s a2 o0 */
        if op == 0x88u32 { c_emit(0x24u32)  c_emit(0x00u32)  c_emit(0xA7u32)  c_emit(0x23u32)  c_emit(0x00u32)  c_emit(0x3Du32)  c_emit(0x01u32)  c_emit(0x00u32) }   /* STORE16: global.set0(val) ; wrap(addr) ; global.get0(val) ; i64.store16 a1 o0 */
        if op == 0x89u32 { c_emit(0x24u32)  c_emit(0x00u32)  c_emit(0xA7u32)  c_emit(0x23u32)  c_emit(0x00u32)  c_emit(0x3Eu32)  c_emit(0x02u32)  c_emit(0x00u32) }   /* STORE32: global.set0(val) ; wrap(addr) ; global.get0(val) ; i64.store32 a2 o0 */
    }
    c_emit(0x0Bu32)
}

fn body_has_print(base: u64, boff: u64, blen: u64) -> u32 {
    let mut s : u64 = 0u64
    while s < blen {
        let sop : *u8 = (base + boff + s) as *u8  let o : u32 = sop[0u64] as u32  s = s + 1u64
        if o == 0x71u32 { return 1u32 }
        if o == 0x01u32 { s = s + 8u64 }
        if o == 0x10u32 { s = s + 1u64 }
        if o == 0x11u32 { s = s + 1u64 }
        if o == 0x50u32 { s = s + 1u64 }
        if o == 0x51u32 { s = s + 1u64 }
        if o == 0x70u32 { s = s + 2u64 }
        if o == 0x73u32 { s = s + 1u64 }
        if o == 0x74u32 { s = s + 3u64 }
        if o == 0x8Au32 { let np : *u8 = (base + boff + s) as *u8  s = s + 1u64 + (np[0u64] as u64) }   /* IMPORT decl: skip [nl][name] -- a name byte 0x71 ('q') must not force a phantom putc import (IC) */
    }
    return 0u32
}

fn body_has_mem(base: u64, boff: u64, blen: u64) -> u32 {
    let mut s : u64 = 0u64
    while s < blen {
        let sop : *u8 = (base + boff + s) as *u8  let o : u32 = sop[0u64] as u32  s = s + 1u64
        if o == 0x80u32 { return 1u32 }
        if o == 0x81u32 { return 1u32 }
        if o == 0x82u32 { return 1u32 }
        if o == 0x83u32 { return 1u32 }
        if o >= 0x84u32 { if o <= 0x89u32 { return 1u32 } }   /* typed mem ops LOAD/STORE 16/32 */
        if o == 0x01u32 { s = s + 8u64 }
        if o == 0x10u32 { s = s + 1u64 }
        if o == 0x11u32 { s = s + 1u64 }
        if o == 0x50u32 { s = s + 1u64 }
        if o == 0x51u32 { s = s + 1u64 }
        if o == 0x70u32 { s = s + 2u64 }
        if o == 0x73u32 { s = s + 1u64 }
        if o == 0x74u32 { s = s + 3u64 }
        if o == 0x8Au32 { let np : *u8 = (base + boff + s) as *u8  s = s + 1u64 + (np[0u64] as u64) }   /* IMPORT decl: skip [nl][name] -- a name byte in 0x80..0x89 must not read as a memory op */
    }
    return 0u32
}

fn main() -> u64 {
    _setmode(1i32, 0x8000i32)
    let base : u64 = svir_ptr()

    /* parse module header (v1 [nfunc:u8]@1 ; v2 0x00 [nfunc:u16 LE]@3) */
    let hp : *u8 = base as *u8
    FN_N = hp[0u64] as u32
    let mut off : u64 = 1u64
    let mut v2 : u32 = 0u32
    if FN_N == 0u32 { FN_N = (hp[1u64] as u32) | ((hp[2u64] as u32) << 8u32)  off = 3u64  v2 = 1u32 }
    let mut i : u32 = 0u32
    while i < FN_N {
        let pp : *u8 = (base + off) as *u8
        FN_PARAMS[i as u64] = pp[0u64] as u32
        let lp0 : *u8 = (base + off + 2u64) as *u8  let lp1 : *u8 = (base + off + 3u64) as *u8
        let blen : u64 = (lp0[0u64] as u64) | ((lp1[0u64] as u64) << 8u64)
        FN_BLEN[i as u64] = blen
        FN_BOFF[i as u64] = off + 4u64
        off = off + 4u64 + blen
        i = i + 1u32
    }
    /* does any function print? -> env.putc import.  use memory? -> memory + scratch global sections */
    IC = 0u32
    let mut UM : u32 = 0u32
    let mut pf : u32 = 0u32
    while pf < FN_N {
        if body_has_print(base, FN_BOFF[pf as u64], FN_BLEN[pf as u64]) == 1u32 { IC = 1u32 }
        if body_has_mem(base, FN_BOFF[pf as u64], FN_BLEN[pf as u64]) == 1u32 { UM = 1u32 }
        pf = pf + 1u32
    }
    /* trailing data section (v1 [u16 len] ; v2 [u32 len]) after the last function -> byte-packed initial linear memory */
    let total : u64 = svir_len()
    let mut dlen : u64 = 0u64
    let mut dhd : u64 = 2u64
    if v2 == 1u32 { dhd = 4u64 }
    if off < total {
        let d0:*u8=(base+off) as *u8  let d1:*u8=(base+off+1u64) as *u8  dlen = (d0[0u64] as u64) | ((d1[0u64] as u64) << 8u64)
        if v2 == 1u32 { let d2:*u8=(base+off+2u64) as *u8  let d3:*u8=(base+off+3u64) as *u8  dlen = dlen | ((d2[0u64] as u64) << 16u64) | ((d3[0u64] as u64) << 24u64) }
    }
    if dlen > 0u64 { UM = 1u32 }

    /* build every function body into CBUF (registers every CALL_INDIRECT arg-count into CI_ACS) */
    CLEN = 0u64
    CI_NAC = 0u32
    let mut f : u32 = 0u32
    while f < FN_N { FN_COFF[f as u64] = CLEN  build_body(base, FN_BOFF[f as u64], FN_BLEN[f as u64], FN_PARAMS[f as u64])  FN_CLEN[f as u64] = CLEN - FN_COFF[f as u64]  f = f + 1u32 }

    /* ---- emit module ---- */
    pc(0x00u32) pc(0x61u32) pc(0x73u32) pc(0x6Du32) pc(0x01u32) pc(0x00u32) pc(0x00u32) pc(0x00u32)
    /* Type section: [putc (i64)->() if IC] + one type per function + one (ac x i64)->i64 per distinct
     * CALL_INDIRECT arg-count (indices IC+FN_N+j -- what build_body's call_indirect references) */
    let ntypes : u64 = (FN_N as u64) + (IC as u64) + (CI_NAC as u64)
    let mut tlen : u64 = leblen_u(ntypes)
    if IC == 1u32 { tlen = tlen + 4u64 }                      /* 0x60 01 7e 00 */
    let mut t : u32 = 0u32
    while t < FN_N { tlen = tlen + 1u64 + leblen_u(FN_PARAMS[t as u64] as u64) + (FN_PARAMS[t as u64] as u64) + 2u64  t = t + 1u32 }
    t = 0u32
    while t < CI_NAC { tlen = tlen + 1u64 + leblen_u(CI_ACS[t as u64] as u64) + (CI_ACS[t as u64] as u64) + 2u64  t = t + 1u32 }
    pc(0x01u32)  pleb_u(tlen)  pleb_u(ntypes)
    if IC == 1u32 { pc(0x60u32)  pc(0x01u32)  pc(0x7Eu32)  pc(0x00u32) }   /* putc: (i64)->() */
    t = 0u32
    while t < FN_N {
        pc(0x60u32)  pleb_u(FN_PARAMS[t as u64] as u64)
        let mut a : u32 = 0u32  while a < FN_PARAMS[t as u64] { pc(0x7Eu32)  a = a + 1u32 }
        pc(0x01u32)  pc(0x7Eu32)
        t = t + 1u32
    }
    t = 0u32
    while t < CI_NAC {
        pc(0x60u32)  pleb_u(CI_ACS[t as u64] as u64)
        let mut a2 : u32 = 0u32  while a2 < CI_ACS[t as u64] { pc(0x7Eu32)  a2 = a2 + 1u32 }
        pc(0x01u32)  pc(0x7Eu32)
        t = t + 1u32
    }
    /* Import section: env.putc -> type 0 (only when IC) */
    if IC == 1u32 { pc(0x02u32)  pc(0x0Cu32)  pc(0x01u32)  pc(0x03u32) pc(0x65u32)pc(0x6Eu32)pc(0x76u32)  pc(0x04u32) pc(0x70u32)pc(0x75u32)pc(0x74u32)pc(0x63u32)  pc(0x00u32)  pc(0x00u32) }   /* import "env"."putc" func type0 (content=12) */
    /* Function section: func i -> type (i + IC) */
    let mut flen : u64 = leblen_u(FN_N as u64)
    let mut g : u32 = 0u32  while g < FN_N { flen = flen + leblen_u((g + IC) as u64)  g = g + 1u32 }
    pc(0x03u32)  pleb_u(flen)  pleb_u(FN_N as u64)
    g = 0u32  while g < FN_N { pleb_u((g + IC) as u64)  g = g + 1u32 }
    /* Table section (id 4): one funcref table, min=max=FN_N -- slot k = defined func k (SVIR's index space
     * verbatim; the wasm engine's own bounds check traps an OOB indirect index).  Only when 0x73 occurs. */
    if CI_NAC > 0u32 {
        let tblen : u64 = 3u64 + (2u64 * leblen_u(FN_N as u64))
        pc(0x04u32)  pleb_u(tblen)  pleb_u(1u64)  pc(0x70u32)  pc(0x01u32)  pleb_u(FN_N as u64)  pleb_u(FN_N as u64)
    }
    /* Memory section (id 5): 64 pages (4 MiB -- static data + bump heap).  Global section (id 6): one mutable i64 scratch. */
    if UM == 1u32 {
        pc(0x05u32) pc(0x03u32) pc(0x01u32) pc(0x00u32) pc(0x40u32)
        pc(0x06u32) pc(0x06u32) pc(0x01u32) pc(0x7Eu32) pc(0x01u32) pc(0x42u32) pc(0x00u32) pc(0x0Bu32)
    }
    /* Export section: "main" -> func index IC (defined func 0, after imports) */
    pc(0x07u32) pc(0x08u32) pc(0x01u32) pc(0x04u32) pc(0x6Du32) pc(0x61u32) pc(0x69u32) pc(0x6Eu32) pc(0x00u32)  pleb_u(IC as u64)
    /* Elem section (id 9): one active segment filling table 0 slots 0..FN_N-1 with defined funcs IC..IC+FN_N-1
     * (SVIR fidx k -> wasm func k+IC, registration order verbatim = index-space agreement).  Only when 0x73 occurs. */
    if CI_NAC > 0u32 {
        let mut eln : u64 = 5u64 + leblen_u(FN_N as u64)          /* count=1 ; flags ; i32.const 0 ; end ; vec-count */
        let mut e : u32 = 0u32
        while e < FN_N { eln = eln + leblen_u((e + IC) as u64)  e = e + 1u32 }
        pc(0x09u32)  pleb_u(eln)  pleb_u(1u64)
        pc(0x00u32)  pc(0x41u32)  pc(0x00u32)  pc(0x0Bu32)  pleb_u(FN_N as u64)
        e = 0u32
        while e < FN_N { pleb_u((e + IC) as u64)  e = e + 1u32 }
    }
    /* Code section */
    let mut clen : u64 = leblen_u(FN_N as u64)
    let mut h : u32 = 0u32
    while h < FN_N { clen = clen + leblen_u(FN_CLEN[h as u64]) + FN_CLEN[h as u64]  h = h + 1u32 }
    pc(0x0Au32)  pleb_u(clen)  pleb_u(FN_N as u64)
    h = 0u32
    while h < FN_N {
        pleb_u(FN_CLEN[h as u64])
        let mut q : u64 = 0u64
        while q < FN_CLEN[h as u64] { pc(CBUF[FN_COFF[h as u64] + q] as u32)  q = q + 1u64 }
        h = h + 1u32
    }
    /* Data section (id 11): one active segment at offset 0 with the byte-packed initial memory. */
    if dlen > 0u64 {
        let seglen : u64 = 4u64 + leblen_u(dlen) + dlen          /* 0x00 0x41 0x00 0x0B + lenLEB + bytes */
        pc(0x0Bu32)  pleb_u(1u64 + seglen)  pleb_u(1u64)         /* section id, len, count=1 */
        pc(0x00u32)  pc(0x41u32)  pc(0x00u32)  pc(0x0Bu32)  pleb_u(dlen)   /* flags=0 ; i32.const 0 ; end ; len */
        let mut d:u64=0u64  while d < dlen { let dp:*u8=(base+off+dhd+d) as *u8  pc(dp[0u64] as u32)  d=d+1u64 }
    }
    return 0u64
}
