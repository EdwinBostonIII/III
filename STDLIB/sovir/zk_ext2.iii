/* zk_ext2.iii -- GF(p^2) arithmetic, the verifiable FOUNDATION for EXTENSION-FIELD Fiat-Shamir challenges (the fix for
 * concrete-soundness weakness #1: the 30-bit base field caps every randomized check at ~2^-27).
 *
 * Construction: GF(p^2) = F_p[u]/(u^2 + u + 1), p = 998244353.  This is a FIELD because p = 2 (mod 3) (digit-sum 47 ->
 * 2), so 3 does NOT divide p-1, so F_p has NO primitive cube roots of unity, so u^2+u+1 (whose roots ARE the primitive
 * cube roots of unity) has no root in F_p and is therefore IRREDUCIBLE.  An element a0 + a1*u is packed as the u64
 * (a0 | a1<<32) (each limb < p < 2^30).  Multiplication uses u^2 = -u - 1:
 *   (a0+a1u)(b0+b1u) = (a0 b0 - a1 b1) + (a0 b1 + a1 b0 - a1 b1) u.
 * Inverse uses the norm N(a) = a0^2 - a0 a1 + a1^2 (= a * conj(a), conj(a0+a1u) = (a0-a1) - a1 u):
 *   (a0+a1u)^-1 = ((a0-a1) - a1 u) / N.
 * A degree-2 challenge space is ~2^59.8 (a 2x lift over the base field); a tower GF(p^2)[v] -> GF(p^4) ~2^119.6 reaches
 * full production.  This module is the arithmetic; wiring the FS challenges + FRI fold + OOD point onto it is the next
 * phase (DOCS/III-ZK-CONCRETE-SOUNDNESS.md).
 *
 * Returns 99 iff EVERY field axiom verifies: the defining relation u^2+u+1=0, a*a^-1=1, commutativity, distributivity,
 * associativity, and that the norm a*conj(a) lands in the base field (u-coefficient 0).  A self-graded structural test
 * would not catch a reducible modulus; the a*a^-1=1 + norm-in-base-field checks DO (a zero divisor would fail them). */
module zk_ext2

extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_add(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_sub(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"

const PRIME : u32 = 998244353u32

fn mod_pow(base: u32, ex: u32) -> u32 {
    let mut r : u32 = 1u32  let mut b : u32 = base  let mut e : u32 = ex
    while e > 0u32 { if (e & 1u32) == 1u32 { r = sf_mul(r, b) }  b = sf_mul(b, b)  e = e >> 1u32 }
    return r
}

fn e2lo(x: u64) -> u32 { return (x & 4294967295u64) as u32 }
fn e2hi(x: u64) -> u32 { return (x >> 32u64) as u32 }
fn e2pack(a0: u32, a1: u32) -> u64 { return (a0 as u64) | ((a1 as u64) << 32u64) }

fn ext2_add(a: u64, b: u64) -> u64 { return e2pack(sf_add(e2lo(a), e2lo(b)), sf_add(e2hi(a), e2hi(b))) }
fn ext2_sub(a: u64, b: u64) -> u64 { return e2pack(sf_sub(e2lo(a), e2lo(b)), sf_sub(e2hi(a), e2hi(b))) }

fn ext2_mul(a: u64, b: u64) -> u64 {
    let a0 : u32 = e2lo(a)  let a1 : u32 = e2hi(a)
    let b0 : u32 = e2lo(b)  let b1 : u32 = e2hi(b)
    let a1b1 : u32 = sf_mul(a1, b1)
    let c0 : u32 = sf_sub(sf_mul(a0, b0), a1b1)                                  /* a0 b0 - a1 b1 */
    let c1 : u32 = sf_sub(sf_add(sf_mul(a0, b1), sf_mul(a1, b0)), a1b1)          /* a0 b1 + a1 b0 - a1 b1 */
    return e2pack(c0, c1)
}

/* conjugate: the image under Frobenius x -> x^p; conj(a0 + a1 u) = (a0 - a1) - a1 u. */
fn ext2_conj(a: u64) -> u64 {
    let a0 : u32 = e2lo(a)  let a1 : u32 = e2hi(a)
    return e2pack(sf_sub(a0, a1), sf_sub(0u32, a1))
}

fn ext2_norm(a: u64) -> u32 {
    let a0 : u32 = e2lo(a)  let a1 : u32 = e2hi(a)
    return sf_add(sf_sub(sf_mul(a0, a0), sf_mul(a0, a1)), sf_mul(a1, a1))        /* a0^2 - a0 a1 + a1^2 */
}

fn ext2_inv(a: u64) -> u64 {
    let n : u32 = ext2_norm(a)
    if n == 0u32 { return 0u64 }
    let ni : u32 = mod_pow(n, PRIME - 2u32)
    let a0 : u32 = e2lo(a)  let a1 : u32 = e2hi(a)
    return e2pack(sf_mul(sf_sub(a0, a1), ni), sf_mul(sf_sub(0u32, a1), ni))      /* ((a0-a1) - a1 u) / N */
}

const ONE : u64 = 1u64   /* 1 + 0u */

fn main() -> u64 {
    let a : u64 = e2pack(123456u32, 789012u32)
    let b : u64 = e2pack(345678u32, 901234u32)
    let c : u64 = e2pack(555555u32, 222222u32)
    /* (1) defining relation: u^2 + u + 1 == 0.  u = 0 + 1*u = e2pack(0,1). */
    let u : u64 = e2pack(0u32, 1u32)
    let uu : u64 = ext2_mul(u, u)
    let rel : u64 = ext2_add(ext2_add(uu, u), ONE)
    if rel != 0u64 { return 1u64 }                                  /* the modulus genuinely vanishes -> GF(p^2) is a field */
    /* (2) a * a^-1 == 1 (would FAIL on a zero divisor -> catches a reducible modulus). */
    if ext2_mul(a, ext2_inv(a)) != ONE { return 2u64 }
    if ext2_mul(b, ext2_inv(b)) != ONE { return 3u64 }
    /* (3) commutativity. */
    if ext2_mul(a, b) != ext2_mul(b, a) { return 4u64 }
    /* (4) distributivity: a*(b+c) == a*b + a*c. */
    if ext2_mul(a, ext2_add(b, c)) != ext2_add(ext2_mul(a, b), ext2_mul(a, c)) { return 5u64 }
    /* (5) associativity: (a*b)*c == a*(b*c). */
    if ext2_mul(ext2_mul(a, b), c) != ext2_mul(a, ext2_mul(b, c)) { return 6u64 }
    /* (6) norm lands in the base field: a*conj(a) has u-coefficient 0, and equals N(a). */
    let nrm : u64 = ext2_mul(a, ext2_conj(a))
    if e2hi(nrm) != 0u32 { return 7u64 }
    if e2lo(nrm) != ext2_norm(a) { return 8u64 }
    /* (7) a non-base element is NOT its own conjugate (Frobenius is nontrivial). */
    if ext2_conj(a) == a { return 9u64 }
    return 99u64
}
