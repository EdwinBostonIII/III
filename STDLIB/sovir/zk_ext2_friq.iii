/* zk_ext2_friq.iii -- the QUERY-BASED GF(p^2) FRI verify: the SOUNDNESS-BEARING half the advisor flagged (the fold
 * arithmetic alone proves nothing; FRI's soundness lives in commit -> FS-challenge -> open QUERIES -> verify-fold).
 *
 * The prover folds a GF(p^2) composition polynomial CP (size 16) down two layers (16->8->4) with fold challenges
 * Fiat-Shamir-derived (keccak) from each committed layer, then the verifier (a) re-derives the challenges, (b) checks
 * the final layer is a CODEWORD (constant), and (c) at FS-derived QUERY indices checks the fold-consistency
 * L_{i+1}[q] == foldpoint(L_i[q], L_i[q+half], r_i).  A FORGED CP -- high-degree, or layers faked to look low-degree --
 * is caught: an honestly-folded garbage CP fails (c-final not constant); a CP with faked low-degree layers fails the
 * QUERY fold-consistency (the committed layers do not fold to each other under the FS challenge).
 *
 * Returns 99 iff a true low-degree CP ACCEPTS, an honestly-folded garbage CP is REJECTED by the final-codeword check,
 * AND a garbage CP with FAKED low-degree layers is REJECTED by the QUERY fold-consistency check.  This is where the
 * GF(p^2) field size finally becomes a real soundness knob (the fold challenges range over ~2^60). */
module zk_ext2_friq

extern @abi(c-msvc-x64) fn ext2_add(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_sub(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_mul(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_smul(s: u32, a: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn e2pack(a0: u32, a1: u32) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn keccak256_oneshot(msg_ptr: u64, msg_len: u64, out_ptr: u64) -> i32 from "keccak256.iii"
extern @abi(c-msvc-x64) fn sf_rou(n: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_add(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"

const PRIME : u32 = 998244353u32

var OM0 : [u32; 16] = [0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32]
var OM1 : [u32; 8]  = [0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32]
var L0  : [u64; 16] = [0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64]
var L1  : [u64; 8]  = [0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64]
var L2  : [u64; 4]  = [0u64,0u64,0u64,0u64]
var CC  : [u64; 16] = [0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64]
var DIG : [u8; 32]  = [0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8]

fn base_inv(v: u32) -> u32 {
    let mut r : u32 = 1u32  let mut b : u32 = v  let mut e : u32 = PRIME - 2u32
    while e > 0u32 { if (e & 1u32) == 1u32 { r = sf_mul(r, b) }  b = sf_mul(b, b)  e = e >> 1u32 }
    return r
}
fn fill_om() {
    let w0 : u32 = sf_rou(16u32)  OM0[0] = 1u32
    let mut j : u64 = 1u64
    while j < 16u64 { OM0[j] = sf_mul(OM0[j - 1u64], w0)  j = j + 1u64 }
    let w1 : u32 = sf_rou(8u32)   OM1[0] = 1u32
    j = 1u64
    while j < 8u64 { OM1[j] = sf_mul(OM1[j - 1u64], w1)  j = j + 1u64 }
}
fn rd4(off: u64) -> u32 {
    let p : *u8 = ((&DIG as u64) + off) as *u8
    let mut x : u32 = (p[0u64] as u32) | ((p[1u64] as u32) << 8u32) | ((p[2u64] as u32) << 16u32) | ((p[3u64] as u32) << 24u32)
    while x >= PRIME { x = x - PRIME }
    return x
}
/* keccak the layer bytes -> a GF(p^2) fold challenge (bytes 0..3 -> real, 4..7 -> imag). */
fn challenge(layerAddr: u64, nbytes: u64) -> u64 {
    keccak256_oneshot(layerAddr, nbytes, &DIG as u64)
    return e2pack(rd4(0u64), rd4(4u64))
}
fn foldpoint(lo: u64, hi: u64, r: u64, x: u32) -> u64 {
    let inv2 : u32 = base_inv(2u32)
    let fe : u64 = ext2_smul(inv2, ext2_add(lo, hi))
    let fo : u64 = ext2_smul(base_inv(sf_add(x, x)), ext2_sub(lo, hi))
    return ext2_add(fe, ext2_mul(r, fo))
}
/* prover: honestly fold L0 (size 16) -> L1 (8) -> L2 (4), FS challenges from each committed layer. */
fn prover_fold() {
    let r1 : u64 = challenge(&L0 as u64, 128u64)
    let mut j : u64 = 0u64
    while j < 8u64 { L1[j] = foldpoint(L0[j], L0[j + 8u64], r1, OM0[j])  j = j + 1u64 }
    let r2 : u64 = challenge(&L1 as u64, 64u64)
    j = 0u64
    while j < 4u64 { L2[j] = foldpoint(L1[j], L1[j + 4u64], r2, OM1[j])  j = j + 1u64 }
}
/* verifier: re-derive challenges, check final codeword + fold-consistency at FS-derived queries.  Returns 1 = accept. */
fn verify() -> u64 {
    let r1 : u64 = challenge(&L0 as u64, 128u64)
    let r2 : u64 = challenge(&L1 as u64, 64u64)
    if L2[0u64] != L2[1u64] { return 0u64 }            /* final layer must be a CODEWORD (constant) */
    if L2[1u64] != L2[2u64] { return 0u64 }
    if L2[2u64] != L2[3u64] { return 0u64 }
    keccak256_oneshot(&L2 as u64, 32u64, &DIG as u64)  /* query indices from the final commitment */
    let mut k : u64 = 0u64
    while k < 8u64 {
        let pq : *u8 = ((&DIG as u64) + k) as *u8
        let q  : u64 = (pq[0u64] as u64) & 7u64        /* a query index in 0..7 */
        if L1[q] != foldpoint(L0[q], L0[q + 8u64], r1, OM0[q]) { return 0u64 }       /* layer 0->1 fold-consistency */
        let q1 : u64 = q & 3u64
        if L2[q1] != foldpoint(L1[q1], L1[q1 + 4u64], r2, OM1[q1]) { return 0u64 }   /* layer 1->2 fold-consistency */
        k = k + 1u64
    }
    return 1u64
}

fn set_true() {   /* L0 = a degree-3 codeword: P(x) = sum_{k<4} c_k x^k, GF(p^2) coeffs. */
    let mut k : u64 = 0u64
    while k < 16u64 { if k < 4u64 { CC[k] = e2pack(((k as u32)*131u32)+7u32, ((k as u32)*53u32)+2u32) } else { CC[k] = 0u64 }  k = k + 1u64 }
    let mut j : u64 = 0u64
    while j < 16u64 {
        let mut a : u64 = 0u64  let mut kk : u64 = 0u64
        while kk < 16u64 { a = ext2_add(a, ext2_smul(OM0[(j*kk) & 15u64], CC[kk]))  kk = kk + 1u64 }
        L0[j] = a  j = j + 1u64
    }
}
fn set_garbage() {   /* L0 = a high-degree (non-codeword) function. */
    let mut j : u64 = 0u64
    while j < 16u64 { L0[j] = e2pack(((j as u32)*40503u32)+11u32, ((j as u32)*22277u32)+5u32)  j = j + 1u64 }
}

fn main() -> u64 {
    fill_om()
    /* (1) TRUE: a low-degree CP, honestly folded -> the query verifier ACCEPTS. */
    set_true()  prover_fold()
    if verify() != 1u64 { return 1u64 }
    /* (2) FORGED, honest fold: garbage CP folded honestly -> final layer NOT a codeword -> REJECT. */
    set_garbage()  prover_fold()
    if verify() == 1u64 { return 2u64 }
    /* (3) FORGED, FAKED layers: garbage L0, but L1/L2 are the fold of a TRUE CP (so L2 is constant) -> the committed
     * L0 does NOT fold to L1 under the FS challenge -> the QUERY fold-consistency REJECTS (the query-based catch). */
    set_true()  prover_fold()              /* L1,L2 = honest fold of the true CP (L2 constant) */
    set_garbage()                          /* overwrite L0 with garbage, keep the faked L1,L2 */
    if verify() == 1u64 { return 3u64 }
    return 99u64
}
