/* zk_ext2_live2.iii -- the REAL query-based GF(p^2) STARK verify on a REAL constraint: connects air_build_cp_ext2 (the
 * GF(p^2) composition polynomial from a live trace) to the QUERY-based verify (zk_ext2_friq's commit->challenge->open).
 * Unlike zk_ext2_live (which re-evaluated consistency at EVERY point), this checks the line-755 consistency
 * CP[q]*Z_T(omega^q)==combine(omega^q) and the FRI fold-consistency only at FS-DERIVED QUERY indices -- the succinct,
 * soundness-bearing form, where the GF(p^2) field size is a real knob.
 *
 * Program: a column with next=cur^2 on rows 0..2 (N=4, D=16).  Three arms:
 *   (1) SATISFYING [2,4,16,256] -> the GF(p^2) CP is the true low-degree quotient -> consistency + FRI pass at the
 *       queries -> ACCEPT.
 *   (2) VIOLATING [2,4,17,256] -> combine!=0 at the tampered row -> the line-755 consistency FAILS at a query -> REJECT.
 *   (3) FORGED-FAKED -> the satisfying CP's honest fold (L1,L2) kept, but L0 overwritten with garbage -> the FRI
 *       fold-consistency FAILS at a query (committed L0 doesn't fold to L1) -> REJECT.
 *
 * Returns 99 iff arm1 ACCEPTS and arms 2,3 are REJECTED -- a true statement passes, a false trace is caught by the
 * query consistency, a forged CP is caught by the query FRI.  The real prover, verified the succinct way over GF(p^2). */
module zk_ext2_live2

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha_ext2(con: u64, a: u64) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp_ext2() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_ext2_at(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_combine_ext2_at(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn ext2_add(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_sub(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_mul(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_smul(s: u32, a: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn e2pack(a0: u32, a1: u32) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn keccak256_oneshot(msg_ptr: u64, msg_len: u64, out_ptr: u64) -> i32 from "keccak256.iii"
extern @abi(c-msvc-x64) fn sf_rou(n: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_add(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_sub(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"

const PRIME : u32 = 998244353u32
const NEG1  : u32 = 998244352u32

var OM0 : [u32; 16] = [0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32]
var OM1 : [u32; 8]  = [0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32]
var L0  : [u64; 16] = [0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64]
var L1  : [u64; 8]  = [0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64]
var L2  : [u64; 4]  = [0u64,0u64,0u64,0u64]
var DIG : [u8; 32]  = [0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8,0u8]

fn base_inv(v: u32) -> u32 {
    let mut r : u32 = 1u32  let mut b : u32 = v  let mut e : u32 = PRIME - 2u32
    while e > 0u32 { if (e & 1u32) == 1u32 { r = sf_mul(r, b) }  b = sf_mul(b, b)  e = e >> 1u32 }
    return r
}
fn fill_om() {
    let w0 : u32 = sf_rou(16u32)  OM0[0] = 1u32
    let mut j : u64 = 1u64
    while j < 16u64 { OM0[j] = sf_mul(OM0[j - 1u64], w0)  j = j + 1u64 }
    let w1 : u32 = sf_rou(8u32)   OM1[0] = 1u32
    j = 1u64
    while j < 8u64 { OM1[j] = sf_mul(OM1[j - 1u64], w1)  j = j + 1u64 }
}
fn rd4(off: u64) -> u32 {
    let p : *u8 = ((&DIG as u64) + off) as *u8
    let mut x : u32 = (p[0u64] as u32) | ((p[1u64] as u32) << 8u32) | ((p[2u64] as u32) << 16u32) | ((p[3u64] as u32) << 24u32)
    while x >= PRIME { x = x - PRIME }
    return x
}
fn challenge(layerAddr: u64, nbytes: u64) -> u64 {
    keccak256_oneshot(layerAddr, nbytes, &DIG as u64)
    return e2pack(rd4(0u64), rd4(4u64))
}
fn foldpoint(lo: u64, hi: u64, r: u64, x: u32) -> u64 {
    let inv2 : u32 = base_inv(2u32)
    let fe : u64 = ext2_smul(inv2, ext2_add(lo, hi))
    let fo : u64 = ext2_smul(base_inv(sf_add(x, x)), ext2_sub(lo, hi))
    return ext2_add(fe, ext2_mul(r, fo))
}
/* build the GF(p^2) CP for trace [t0..t3] with next=cur^2, read it into L0. */
fn build_cp(t0: u32, t1: u32, t2: u32, t3: u32) {
    air_reset(1u32, 4u32)
    air_set_trace(0u64, 0u64, t0)  air_set_trace(1u64, 0u64, t1)
    air_set_trace(2u64, 0u64, t2)  air_set_trace(3u64, 0u64, t3)
    air_add_term(0u32, 1u32, 2u32, 0u32)  air_add_term(0u32, NEG1, 1u32, 1u32)   /* next - cur^2 */
    air_set_alpha_ext2(0u64, e2pack(13u32, 9u32))
    air_build_lde()  air_build_cp_ext2()
    let mut j : u64 = 0u64
    while j < 16u64 { L0[j] = air_cp_ext2_at(j)  j = j + 1u64 }
}
fn prover_fold() {
    let r1 : u64 = challenge(&L0 as u64, 128u64)
    let mut j : u64 = 0u64
    while j < 8u64 { L1[j] = foldpoint(L0[j], L0[j + 8u64], r1, OM0[j])  j = j + 1u64 }
    let r2 : u64 = challenge(&L1 as u64, 64u64)
    j = 0u64
    while j < 4u64 { L2[j] = foldpoint(L1[j], L1[j + 4u64], r2, OM1[j])  j = j + 1u64 }
}
/* the line-755 consistency CP[q]*Z_T(omega^q)==combine(omega^q) at a query (q != 12, the excluded wrap row). */
fn consistent_at(q: u64) -> u64 {
    if q == 12u64 { return 1u64 }
    let zt : u32 = sf_mul(sf_sub(OM0[(4u64 * q) & 15u64], 1u32), base_inv(sf_sub(OM0[q], OM0[12])))
    if ext2_smul(zt, air_cp_ext2_at(q)) != air_combine_ext2_at(q) { return 0u64 }
    return 1u64
}
fn verify_full() -> u64 {
    let r1 : u64 = challenge(&L0 as u64, 128u64)
    let r2 : u64 = challenge(&L1 as u64, 64u64)
    if L2[0u64] != L2[1u64] { return 0u64 }
    if L2[1u64] != L2[2u64] { return 0u64 }
    if L2[2u64] != L2[3u64] { return 0u64 }
    keccak256_oneshot(&L2 as u64, 32u64, &DIG as u64)
    let mut k : u64 = 0u64
    while k < 8u64 {
        let pq : *u8 = ((&DIG as u64) + k) as *u8
        let q  : u64 = (pq[0u64] as u64) & 7u64
        if consistent_at(q) != 1u64 { return 0u64 }                                 /* line-755 at the query */
        if L1[q] != foldpoint(L0[q], L0[q + 8u64], r1, OM0[q]) { return 0u64 }       /* FRI fold-consistency 0->1 */
        let q1 : u64 = q & 3u64
        if L2[q1] != foldpoint(L1[q1], L1[q1 + 4u64], r2, OM1[q1]) { return 0u64 }   /* FRI fold-consistency 1->2 */
        k = k + 1u64
    }
    return 1u64
}

fn main() -> u64 {
    fill_om()
    /* (1) SATISFYING -> accept. */
    build_cp(2u32, 4u32, 16u32, 256u32)  prover_fold()
    if verify_full() != 1u64 { return 1u64 }
    /* (2) VIOLATING -> the line-755 consistency fails at a query -> reject. */
    build_cp(2u32, 4u32, 17u32, 256u32)  prover_fold()
    if verify_full() == 1u64 { return 2u64 }
    /* (3) FORGED-FAKED: satisfying CP's honest fold kept, L0 overwritten with garbage -> FRI query rejects. */
    build_cp(2u32, 4u32, 16u32, 256u32)  prover_fold()
    let mut j : u64 = 0u64
    while j < 16u64 { L0[j] = e2pack(((j as u32)*44851u32)+9u32, ((j as u32)*30011u32)+7u32)  j = j + 1u64 }
    if verify_full() == 1u64 { return 3u64 }
    return 99u64
}
