/* zk_ext4_stark_committed.iii -- P2b CORE (DOCS/III-GRAND-UNIFICATION-AUDIT-AND-PLAN.md): a COMMITTED, succinct,
 * witness-free GF(p^4) STARK on a REAL constraint -- the committed CONSISTENCY check (line-755) that zk_fused_prod
 * does over SHARED MEMORY, now done the production way: against MERKLE commitments with opened, path-verified values.
 *
 * Constraint: a single column f with the nonlinear transition  next = cur^2  on rows 0..N-2 (N=16, D=B*N=64).  The
 * trace satisfies it ([2,4,16,256,...]); a forged trace violates a row.  Built on the PROVEN zk_air machinery
 * (air_build_lde -> trace LDE; air_build_cp_ext4 -> the GF(p^4) composition polynomial CP = combine/Z_T) -- this gadget
 * adds the COMMITMENT layer P2a proved + the committed line-755:
 *   - the trace-column LDE is MERKLE-COMMITTED (4-byte u32 leaves) -> TROOT, BEFORE the combination challenge;
 *   - alpha (GF(p^4)) is FS-DERIVED from TROOT (sound commit-before-challenge order);
 *   - the CP is the FRI layer 0, MERKLE-COMMITTED per layer (16-byte GF(p^4) leaves), like P2a;
 *   - the verifier, per query q: OPENS f(q) and f(q+B) from TROOT (Merkle-verified), recomputes combine(q) =
 *     alpha*(f(q+B) - f(q)^2) ITSELF (witness-free -- it never reads the whole trace), OPENS CP(q) from the layer-0
 *     root, and checks the line-755  CP(q)*Z_T(q) == combine(q)  AND the GF(p^4) FRI fold-consistency.
 *
 * Returns 99 iff: (H) the honest trace ACCEPTS; (V) a VIOLATING trace (a row breaks next=cur^2) is REJECTED (CP is not
 * the true low-degree quotient -> final FRI layer not constant / line-755 fails at a query); (O) a forged trace OPENING
 * (a claimed f value inconsistent with TROOT) is REJECTED; (R) a corrupted committed root is REJECTED; (S) the
 * trace-low-degree SOUNDNESS gap is CLOSED (see below).
 *
 * SOUNDNESS HISTORY (full account: DOCS/III-ZKVM-TRACE-LDT-GAP.md): (1) the original verify bound the trace by MERKLE
 * only (values, not degree) -> a high-degree trace + honest CP passed.  (2) A first trace-FRI fix went green on its
 * self-test.  (3) An ADVERSARIAL FS AUDIT on the fixed verifier found that fix INSUFFICIENT -- two critical holes.
 * (4) BOTH now FIXED, each verified by reproduce-then-fix (the lesson: a fix is only as good as the attack that tests it):
 *   HOLE 1 (binding) -- FIXED: the trace FRI used to be a SEPARATE commitment from the constraint trace, tied only at
 *     the 16 queries -> a DECOUPLED low-degree decoy passed.  build_attack_decoupled/zk_trace_attack_decoupled
 *     REPRODUCE it (verify ACCEPTED, main rc=8).  FIX: trace_fri_commit() no longer commits layer 0 separately -- its
 *     commitment IS TROOT, and verify() folds layer 0 from open_trace(TROOT), so the LDT folds the SAME trace line-755
 *     reads.  Post-fix the decoupled attack REJECTS (rc 8 -> 99); (S3) gates it.
 *   HOLE 2 (adaptive CP) -- FIXED: the first fix had moved the query seed to the trace root alone, unbinding the CP ->
 *     an adaptive prover could fix the trace, learn the queries, and craft a degree-<N CP fitting line-755 only there.
 *     FIX: queries now seed from keccak(CP_final_root || trace_final_root), binding the CP commitment before the queries
 *     (the interpolation-based reproduction is a separate sub-project; the binding fix is argued structurally).
 * (S)/(S2)/(S3) confirm honest ACCEPTS + the COUPLED and DECOUPLED provers both REJECT (load-bearing, not dead checks).
 * PRODUCTION (zk_fused_committed, ~2^-86) was independently verified UNAFFECTED throughout: it reads the LIVE air LDE
 * (degree-<N by construction, no decoupling) and seeds queries from the CP final root (binds the CP). */
module zk_ext4_stark_committed

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha_ext4(con: u64, a: u64, b: u64) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp_ext4() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_ext4_a(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_ext4_b(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_lde_at(col: u64, j: u64) -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_combine_ext4_at(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cmb4_b() -> u64 from "zk_air.iii"

extern @abi(c-msvc-x64) fn ext2_add(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_sub(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_mul(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_smul(s: u32, a: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn e2pack(a0: u32, a1: u32) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn sf_rou(n: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_add(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_sub(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn keccak256_oneshot(msg_ptr: u64, msg_len: u64, out_ptr: u64) -> i32 from "keccak256.iii"
extern @abi(c-msvc-x64) fn merkle_compute_root(leaves_ptr: u64, leaf_count: u32, leaf_size: u64, out_32: u64) -> i32 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_proof_len_for(leaf_count: u32, leaf_index: u32) -> u32 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_compute_proof(leaves_ptr: u64, leaf_size: u64, packed_count_index: u64, proof_out_ptr: u64) -> i32 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_verify_proof(leaf_ptr: u64, packed_meta: u64, proof_ptr: u64, root_32_ptr: u64) -> u8 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_pack_count_index(leaf_count: u32, leaf_index: u32) -> u64 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_pack_verify_meta(leaf_size: u32, leaf_index: u32, proof_steps: u32) -> u64 from "merkle.iii"

const PRIME : u32 = 998244353u32
const NEG1  : u32 = 998244352u32
const N     : u64 = 16u64
const DOM   : u64 = 64u64          /* D = B*N = 4*16 */
const BLOW  : u64 = 4u64           /* AIR_B */
const G4    : u64 = 4294967298u64

var OM   : [u32; 64]
var FA   : [u64; 124]   var FB : [u64; 124]   /* FRI layers; layer 0 = CP */
var OFFS : [u64; 8]      var SIZES: [u64; 8]
var ROOT : [u8; 256]                          /* per-FRI-layer Merkle root */
var RR   : [u64; 8]      var RI : [u64; 8]
var TROOT: [u8; 32]                            /* trace-column LDE Merkle root */
var TLEAF: [u8; 256]                           /* trace LDE leaves: D * 4 bytes */
var ALA  : [u64; 1]      var ALB : [u64; 1]    /* GF(p^4) combination challenge alpha (FS from TROOT) */
var DIG  : [u8; 32]
var LEAF : [u8; 1024]
var PRF  : [u8; 512]
var QLEAF: [u8; 16]
var TQ   : [u8; 4]
var FRA  : [u64; 1]      var FRB : [u64; 1]
var TF   : [u32; 16]                            /* the trace column */
var TT   : [u32; 16]                            /* SOUNDNESS-DEMO: the tampered (decoupled, high-degree) committed trace */
/* TRACE low-degree test (the soundness fix): a SECOND FRI directly on the committed trace LDE (lifted to GF(p^4)),
 * mirroring the CP FRI.  Layer 0 = lift(committed trace) committed as TFROOT[0] + tied to TROOT by a per-query
 * consistency check; folding to a constant final layer proves the committed trace is degree < N. */
var TFA  : [u64; 124]   var TFB : [u64; 124]    /* trace FRI layers (GF(p^4) lift of the committed trace) */
var TFROOT : [u8; 256]                          /* per-trace-FRI-layer Merkle root */
var TFRR : [u64; 8]     var TFRI : [u64; 8]     /* trace fold challenges (FS from each trace layer root) */
var TFOFFS: [u64; 8]    var TFSIZES: [u64; 8]
var QSEED : [u8; 64]                            /* query seed = CP final root || trace final root (Hole-2 fix) */

fn base_inv(v: u32) -> u32 {
    let mut r : u32 = 1u32  let mut b : u32 = v  let mut e : u32 = PRIME - 2u32
    while e > 0u32 { if (e & 1u32) == 1u32 { r = sf_mul(r, b) }  b = sf_mul(b, b)  e = e >> 1u32 }
    return r
}
fn fill_om() {
    let w : u32 = sf_rou(DOM as u32)  OM[0] = 1u32
    let mut j : u64 = 1u64
    while j < DOM { OM[j] = sf_mul(OM[j - 1u64], w)  j = j + 1u64 }
}
fn p4mul_a(ra: u64, rb: u64, fa: u64, fb: u64) -> u64 { return ext2_add(ext2_mul(ra, fa), ext2_mul(ext2_mul(rb, fb), G4)) }
fn p4mul_b(ra: u64, rb: u64, fa: u64, fb: u64) -> u64 { return ext2_add(ext2_mul(ra, fb), ext2_mul(rb, fa)) }
fn foldp4(loa: u64, lob: u64, hia: u64, hib: u64, ra: u64, rb: u64, x: u32) {
    let inv2 : u32 = base_inv(2u32)  let i2x : u32 = base_inv(sf_add(x, x))
    let fea : u64 = ext2_smul(inv2, ext2_add(loa, hia))  let feb : u64 = ext2_smul(inv2, ext2_add(lob, hib))
    let foa : u64 = ext2_smul(i2x, ext2_sub(loa, hia))   let fob : u64 = ext2_smul(i2x, ext2_sub(lob, hib))
    FRA[0] = ext2_add(fea, p4mul_a(ra, rb, foa, fob))
    FRB[0] = ext2_add(feb, p4mul_b(ra, rb, foa, fob))
}
fn rd4(o: u64) -> u32 {
    let p : *u8 = ((&DIG as u64) + o) as *u8
    let mut x : u32 = (p[0u64] as u32) | ((p[1u64] as u32) << 8u32) | ((p[2u64] as u32) << 16u32) | ((p[3u64] as u32) << 24u32)
    while x >= PRIME { x = x - PRIME }
    return x
}
fn ser_leaf(idx: u64, off: u64) {
    let a : u64 = FA[off + idx]  let b : u64 = FB[off + idx]
    let base : u64 = idx * 16u64
    let mut k : u64 = 0u64
    while k < 8u64 { LEAF[base + k] = ((a >> (8u64 * k)) & 0xFFu64) as u8  k = k + 1u64 }
    k = 0u64
    while k < 8u64 { LEAF[base + 8u64 + k] = ((b >> (8u64 * k)) & 0xFFu64) as u8  k = k + 1u64 }
}
fn ser_layer(off: u64, size: u64) { let mut i : u64 = 0u64  while i < size { ser_leaf(i, off)  i = i + 1u64 } }
fn ser_leaf_tf(idx: u64, off: u64) {
    let a : u64 = TFA[off + idx]  let b : u64 = TFB[off + idx]
    let base : u64 = idx * 16u64
    let mut k : u64 = 0u64
    while k < 8u64 { LEAF[base + k] = ((a >> (8u64 * k)) & 0xFFu64) as u8  k = k + 1u64 }
    k = 0u64
    while k < 8u64 { LEAF[base + 8u64 + k] = ((b >> (8u64 * k)) & 0xFFu64) as u8  k = k + 1u64 }
}
fn ser_layer_tf(off: u64, size: u64) { let mut i : u64 = 0u64  while i < size { ser_leaf_tf(i, off)  i = i + 1u64 } }
/* TRACE low-degree test (the soundness fix): a FRI on the committed trace LDE (lifted to GF(p^4)), mirroring the CP
 * FRI.  Layer 0 = lift(committed TLEAF); fold to a constant final layer.  A high-degree committed trace folds to a
 * NON-constant final layer -> the verifier rejects.  Committed AFTER the CP FRI; the queries bind the final trace root. */
fn trace_fri_commit() {
    let mut j : u64 = 0u64
    while j < DOM {
        let f : u32 = (TLEAF[j * 4u64] as u32) | ((TLEAF[j * 4u64 + 1u64] as u32) << 8u32) | ((TLEAF[j * 4u64 + 2u64] as u32) << 16u32) | ((TLEAF[j * 4u64 + 3u64] as u32) << 24u32)
        TFA[j] = e2pack(f, 0u32)  TFB[j] = e2pack(0u32, 0u32)
        j = j + 1u64
    }
    /* HOLE-1 FIX: layer 0's commitment IS TROOT (the SAME trace line-755 reads) -- NOT a separate TFROOT[0].  Commit
     * only the FOLDED layers 1.. as TFROOT[0..], and derive each fold challenge from layer li's commitment (TROOT for
     * li==0, else TFROOT[li-1]).  So the LDT folds the constraint trace itself -- no decoupled decoy column exists. */
    let mut size : u64 = DOM  let mut off : u64 = 0u64  let mut li : u64 = 0u64
    while size > 4u64 {
        if li == 0u64 { keccak256_oneshot((&TROOT as u64), 32u64, (&DIG as u64)) }
        if li != 0u64 { keccak256_oneshot((&TFROOT as u64) + (li - 1u64) * 32u64, 32u64, (&DIG as u64)) }
        TFRR[li] = e2pack(rd4(0u64), rd4(4u64))  TFRI[li] = e2pack(rd4(8u64), rd4(12u64))
        let half : u64 = size / 2u64  let noff : u64 = off + size  let str : u64 = DOM / size
        let mut k : u64 = 0u64
        while k < half {
            foldp4(TFA[off + k], TFB[off + k], TFA[off + k + half], TFB[off + k + half], TFRR[li], TFRI[li], OM[str * k])
            TFA[noff + k] = FRA[0]  TFB[noff + k] = FRB[0]
            k = k + 1u64
        }
        ser_layer_tf(noff, half)                                       /* commit the FOLDED layer (li+1) as TFROOT[li] */
        merkle_compute_root((&LEAF as u64), half as u32, 16u64, (&TFROOT as u64) + li * 32u64)
        off = noff  size = half  li = li + 1u64
    }
}
fn qleaf_a() -> u64 { let mut a : u64 = 0u64  let mut k : u64 = 0u64  while k < 8u64 { a = a | ((QLEAF[k] as u64) << (8u64 * k))  k = k + 1u64 }  return a }
fn qleaf_b() -> u64 { let mut b : u64 = 0u64  let mut k : u64 = 0u64  while k < 8u64 { b = b | ((QLEAF[8u64 + k] as u64) << (8u64 * k))  k = k + 1u64 }  return b }
fn open_leaf(off: u64, size: u64, idx: u64) -> u32 {
    ser_layer(off, size)
    let plen : u32 = merkle_proof_len_for(size as u32, idx as u32)
    merkle_compute_proof((&LEAF as u64), 16u64, merkle_pack_count_index(size as u32, idx as u32), (&PRF as u64))
    let lp : *u8 = ((&LEAF as u64) + idx * 16u64) as *u8
    let mut k : u64 = 0u64  while k < 16u64 { QLEAF[k] = lp[k]  k = k + 1u64 }
    return plen
}
/* open trace-FRI layer leaf (16-byte GF(p^4)) -- serializes TFA/TFB; caller merkle_verify_proof's against TFROOT. */
fn open_leaf_tf(off: u64, size: u64, idx: u64) -> u32 {
    ser_layer_tf(off, size)
    let plen : u32 = merkle_proof_len_for(size as u32, idx as u32)
    merkle_compute_proof((&LEAF as u64), 16u64, merkle_pack_count_index(size as u32, idx as u32), (&PRF as u64))
    let lp : *u8 = ((&LEAF as u64) + idx * 16u64) as *u8
    let mut k : u64 = 0u64  while k < 16u64 { QLEAF[k] = lp[k]  k = k + 1u64 }
    return plen
}
/* open trace LDE leaf j (4-byte u32) against TROOT; returns the opened f(j), or 0xFFFFFFFF on a Merkle-verify failure. */
fn open_trace(j: u64) -> u32 {
    let plen : u32 = merkle_proof_len_for(DOM as u32, j as u32)
    merkle_compute_proof((&TLEAF as u64), 4u64, merkle_pack_count_index(DOM as u32, j as u32), (&PRF as u64))
    let lp : *u8 = ((&TLEAF as u64) + j * 4u64) as *u8
    let mut k : u64 = 0u64  while k < 4u64 { TQ[k] = lp[k]  k = k + 1u64 }
    if merkle_verify_proof((&TQ as u64), merkle_pack_verify_meta(4u32, j as u32, plen), (&PRF as u64), (&TROOT as u64)) == 0u8 { return 0xFFFFFFFFu32 }
    return (TQ[0u64] as u32) | ((TQ[1u64] as u32) << 8u32) | ((TQ[2u64] as u32) << 16u32) | ((TQ[3u64] as u32) << 24u32)
}
/* Z_T(q) = (x^N - 1) / (x - omega_N^{N-1}),  x = OM[q],  omega_N^{N-1} = OM[(N-1)*BLOW] = OM[DOM-BLOW]. */
fn zt_at(q: u64) -> u32 {
    let xn : u32 = OM[(N * q) & (DOM - 1u64)]
    return sf_mul(sf_sub(xn, 1u32), base_inv(sf_sub(OM[q], OM[DOM - BLOW])))
}

/* PROVER: set the trace, commit the trace LDE, FS-derive alpha, build the CP, FRI-fold + commit layers. */
fn build(forge: u64) {
    air_reset(1u32, N as u32)
    let mut v : u32 = 2u32
    let mut i : u64 = 0u64
    while i < N {
        TF[i] = v
        v = sf_mul(v, v)
        i = i + 1u64
    }
    if forge == 1u64 { TF[5u64] = sf_add(TF[5u64], 1u32) }     /* break next=cur^2 at row 4->5 */
    i = 0u64
    while i < N { air_set_trace(i, 0u64, TF[i])  i = i + 1u64 }
    air_build_lde()
    /* commit the trace LDE column 0 (4-byte leaves). */
    let mut j : u64 = 0u64
    while j < DOM {
        let f : u32 = air_lde_at(0u64, j)
        TLEAF[j * 4u64]        = (f & 0xFFu32) as u8
        TLEAF[j * 4u64 + 1u64] = ((f >> 8u32) & 0xFFu32) as u8
        TLEAF[j * 4u64 + 2u64] = ((f >> 16u32) & 0xFFu32) as u8
        TLEAF[j * 4u64 + 3u64] = ((f >> 24u32) & 0xFFu32) as u8
        j = j + 1u64
    }
    merkle_compute_root((&TLEAF as u64), DOM as u32, 4u64, (&TROOT as u64))
    /* alpha (GF(p^4)) FS-derived from the committed trace root. */
    keccak256_oneshot((&TROOT as u64), 32u64, (&DIG as u64))
    ALA[0] = e2pack(rd4(0u64), rd4(4u64))  ALB[0] = e2pack(rd4(8u64), rd4(12u64))
    /* constraint: next.f - f^2  (air_eval_var: var0 = const 1 ; var 1..W = cur cols ; var W+1..2W = next cols.
     * W=1 here -> cur col0 = var 1, next col0 = var 2). */
    air_add_term(0u32, 1u32, 2u32, 0u32)
    air_add_term(0u32, NEG1, 1u32, 1u32)
    air_set_alpha_ext4(0u64, ALA[0], ALB[0])
    air_build_cp_ext4()
    /* layer 0 = the CP. */
    j = 0u64
    while j < DOM { FA[j] = air_cp_ext4_a(j)  FB[j] = air_cp_ext4_b(j)  j = j + 1u64 }
    /* FRI fold + per-layer Merkle commit (challenge from each root). */
    let mut size : u64 = DOM  let mut off : u64 = 0u64  let mut li : u64 = 0u64
    while size > 4u64 {
        OFFS[li] = off  SIZES[li] = size
        ser_layer(off, size)
        merkle_compute_root((&LEAF as u64), size as u32, 16u64, (&ROOT as u64) + li * 32u64)
        keccak256_oneshot((&ROOT as u64) + li * 32u64, 32u64, (&DIG as u64))
        RR[li] = e2pack(rd4(0u64), rd4(4u64))  RI[li] = e2pack(rd4(8u64), rd4(12u64))
        let half : u64 = size / 2u64  let noff : u64 = off + size  let str : u64 = DOM / size
        let mut k : u64 = 0u64
        while k < half {
            foldp4(FA[off + k], FB[off + k], FA[off + k + half], FB[off + k + half], RR[li], RI[li], OM[str * k])
            FA[noff + k] = FRA[0]  FB[noff + k] = FRB[0]
            k = k + 1u64
        }
        off = noff  size = half  li = li + 1u64
    }
    OFFS[li] = off  SIZES[li] = size
    ser_layer(off, size)
    merkle_compute_root((&LEAF as u64), size as u32, 16u64, (&ROOT as u64) + li * 32u64)
    trace_fri_commit()                               /* SOUNDNESS FIX: low-degree test on the committed trace itself */
}

/* VERIFIER: re-derive challenges from the committed roots; final-constant; per query open+verify trace + CP + FRI
 * layers against their roots; check line-755 (CP*Z_T == alpha*(f_next - f^2)) + FRI fold-consistency + the TRACE
 * low-degree FRI (binds the committed trace to degree < N, closing the trace-LDT soundness gap). */
fn verify() -> u64 {
    /* re-derive alpha from the committed trace root. */
    keccak256_oneshot((&TROOT as u64), 32u64, (&DIG as u64))
    ALA[0] = e2pack(rd4(0u64), rd4(4u64))  ALB[0] = e2pack(rd4(8u64), rd4(12u64))
    /* re-derive fold challenges + layer offsets. */
    let mut size : u64 = DOM  let mut off : u64 = 0u64  let mut i : u64 = 0u64
    while size > 4u64 {
        OFFS[i] = off  SIZES[i] = size
        keccak256_oneshot((&ROOT as u64) + i * 32u64, 32u64, (&DIG as u64))
        RR[i] = e2pack(rd4(0u64), rd4(4u64))  RI[i] = e2pack(rd4(8u64), rd4(12u64))
        off = off + size  size = size / 2u64  i = i + 1u64
    }
    let nl : u64 = i  let foff : u64 = off
    OFFS[nl] = foff  SIZES[nl] = 4u64
    let fa0 : u64 = FA[foff]  let fb0 : u64 = FB[foff]
    let mut c : u64 = 1u64
    while c < 4u64 { if FA[foff + c] != fa0 { return 2u64 }  if FB[foff + c] != fb0 { return 2u64 }  c = c + 1u64 }
    /* TRACE low-degree FRI: re-derive fold challenges.  Layer 0's commitment = TROOT (Hole-1 fix); layer i+1's = TFROOT[i]. */
    let mut tsz : u64 = DOM  let mut toff : u64 = 0u64  let mut ti : u64 = 0u64
    while tsz > 4u64 {
        TFOFFS[ti] = toff  TFSIZES[ti] = tsz
        if ti == 0u64 { keccak256_oneshot((&TROOT as u64), 32u64, (&DIG as u64)) }
        if ti != 0u64 { keccak256_oneshot((&TFROOT as u64) + (ti - 1u64) * 32u64, 32u64, (&DIG as u64)) }
        TFRR[ti] = e2pack(rd4(0u64), rd4(4u64))  TFRI[ti] = e2pack(rd4(8u64), rd4(12u64))
        toff = toff + tsz  tsz = tsz / 2u64  ti = ti + 1u64
    }
    let tnl : u64 = ti  let tfoff : u64 = toff
    TFOFFS[tnl] = tfoff  TFSIZES[tnl] = 4u64
    /* trace FRI final-constant (the fold-consistency below binds the folded layers to the TROOT trace per query). */
    let tfa0 : u64 = TFA[tfoff]  let tfb0 : u64 = TFB[tfoff]
    let mut tc : u64 = 1u64
    while tc < 4u64 { if TFA[tfoff + tc] != tfa0 { return 20u64 }  if TFB[tfoff + tc] != tfb0 { return 20u64 }  tc = tc + 1u64 }
    /* HOLE-2 FIX: queries bind BOTH the CP final root (ROOT[nl]) AND the trace final root (TFROOT[tnl-1]) -- else an
     * adaptive prover fixes the trace, learns the queries, and crafts a degree-<N CP fitting line-755 only there. */
    let mut qb : u64 = 0u64
    while qb < 32u64 { QSEED[qb] = ROOT[nl * 32u64 + qb]  QSEED[32u64 + qb] = TFROOT[(tnl - 1u64) * 32u64 + qb]  qb = qb + 1u64 }
    keccak256_oneshot((&QSEED as u64), 64u64, (&DIG as u64))
    let mut qi : u64 = 0u64
    while qi < 16u64 {
        let pq : *u8 = ((&DIG as u64) + qi) as *u8
        let q0 : u64 = (pq[0u64] as u64) & (DOM - 1u64)
        let fq : u32 = open_trace(q0)
        if fq == 0xFFFFFFFFu32 { return 3u64 }
        let fn_idx : u64 = (q0 + BLOW) & (DOM - 1u64)
        let fnx : u32 = open_trace(fn_idx)
        if fnx == 0xFFFFFFFFu32 { return 4u64 }
        /* WITNESS-FREE combine: recomputed from the two OPENED trace values only (verified equal to air's own
         * full-LDE air_combine_ext4 during bring-up; the verifier here never reads the whole trace). */
        let cval : u32 = sf_sub(fnx, sf_mul(fq, fq))
        let cmba : u64 = ext2_smul(cval, ALA[0])  let cmbb : u64 = ext2_smul(cval, ALB[0])
        let plc : u32 = open_leaf(0u64, DOM, q0)
        if merkle_verify_proof((&QLEAF as u64), merkle_pack_verify_meta(16u32, q0 as u32, plc), (&PRF as u64), (&ROOT as u64)) == 0u8 { return 7u64 }
        let cpa : u64 = qleaf_a()  let cpb : u64 = qleaf_b()
        /* construction-exact line-755: CP*Z_H == combine*(x - omega^{n-1}). */
        let zh : u32 = sf_sub(OM[(N * q0) & (DOM - 1u64)], 1u32)
        let fac : u32 = sf_sub(OM[q0], OM[DOM - BLOW])
        if ext2_smul(zh, cpa) != ext2_smul(fac, cmba) { return 5u64 }
        if ext2_smul(zh, cpb) != ext2_smul(fac, cmbb) { return 6u64 }
        let mut li : u64 = 0u64
        while li < nl {
            let s : u64 = SIZES[li]  let o : u64 = OFFS[li]  let half : u64 = s / 2u64
            let qm : u64 = q0 & (half - 1u64)
            let pl1 : u32 = open_leaf(o, s, qm)
            if merkle_verify_proof((&QLEAF as u64), merkle_pack_verify_meta(16u32, qm as u32, pl1), (&PRF as u64), (&ROOT as u64) + li * 32u64) == 0u8 { return 8u64 }
            let loa : u64 = qleaf_a()  let lob : u64 = qleaf_b()
            let pl2 : u32 = open_leaf(o, s, qm + half)
            if merkle_verify_proof((&QLEAF as u64), merkle_pack_verify_meta(16u32, (qm + half) as u32, pl2), (&PRF as u64), (&ROOT as u64) + li * 32u64) == 0u8 { return 8u64 }
            let hia : u64 = qleaf_a()  let hib : u64 = qleaf_b()
            let no : u64 = OFFS[li + 1u64]  let ns : u64 = SIZES[li + 1u64]
            let pl3 : u32 = open_leaf(no, ns, qm)
            if merkle_verify_proof((&QLEAF as u64), merkle_pack_verify_meta(16u32, qm as u32, pl3), (&PRF as u64), (&ROOT as u64) + (li + 1u64) * 32u64) == 0u8 { return 8u64 }
            let nxa : u64 = qleaf_a()  let nxb : u64 = qleaf_b()
            foldp4(loa, lob, hia, hib, RR[li], RI[li], OM[(DOM / s) * qm])
            if FRA[0] != nxa { return 9u64 }
            if FRB[0] != nxb { return 9u64 }
            li = li + 1u64
        }
        /* TRACE FRI per query (Hole-1 fix): fold-consistency from layer 0 = the TROOT-committed trace down to the
         * constant final.  Layer 0's leaves come from open_trace (bound to TROOT, the SAME trace line-755 reads), so
         * there is no decoupled column -- a high-degree or violating TROOT trace fails the fold/final-constant. */
        let mut tli : u64 = 0u64
        while tli < tnl {
            let ts : u64 = TFSIZES[tli]  let thalf : u64 = ts / 2u64
            let tqm : u64 = q0 & (thalf - 1u64)
            let mut tloa : u64 = 0u64  let mut tlob : u64 = 0u64  let mut thia : u64 = 0u64  let mut thib : u64 = 0u64
            if tli == 0u64 {
                let lf : u32 = open_trace(tqm)            if lf == 0xFFFFFFFFu32 { return 23u64 }
                let hf : u32 = open_trace(tqm + thalf)    if hf == 0xFFFFFFFFu32 { return 23u64 }
                tloa = e2pack(lf, 0u32)  tlob = e2pack(0u32, 0u32)  thia = e2pack(hf, 0u32)  thib = e2pack(0u32, 0u32)
            }
            if tli != 0u64 {
                let tp1 : u32 = open_leaf_tf(TFOFFS[tli], ts, tqm)
                if merkle_verify_proof((&QLEAF as u64), merkle_pack_verify_meta(16u32, tqm as u32, tp1), (&PRF as u64), (&TFROOT as u64) + (tli - 1u64) * 32u64) == 0u8 { return 23u64 }
                tloa = qleaf_a()  tlob = qleaf_b()
                let tp2 : u32 = open_leaf_tf(TFOFFS[tli], ts, tqm + thalf)
                if merkle_verify_proof((&QLEAF as u64), merkle_pack_verify_meta(16u32, (tqm + thalf) as u32, tp2), (&PRF as u64), (&TFROOT as u64) + (tli - 1u64) * 32u64) == 0u8 { return 23u64 }
                thia = qleaf_a()  thib = qleaf_b()
            }
            let tp3 : u32 = open_leaf_tf(TFOFFS[tli + 1u64], TFSIZES[tli + 1u64], tqm)   /* layer tli+1 from TFROOT[tli] */
            if merkle_verify_proof((&QLEAF as u64), merkle_pack_verify_meta(16u32, tqm as u32, tp3), (&PRF as u64), (&TFROOT as u64) + tli * 32u64) == 0u8 { return 24u64 }
            let tnxa : u64 = qleaf_a()  let tnxb : u64 = qleaf_b()
            foldp4(tloa, tlob, thia, thib, TFRR[tli], TFRI[tli], OM[(DOM / ts) * tqm])
            if FRA[0] != tnxa { return 24u64 }
            if FRB[0] != tnxb { return 24u64 }
            tli = tli + 1u64
        }
        qi = qi + 1u64
    }
    return 1u64
}

/* ============================ SOUNDNESS DEMONSTRATION (the trace-LDT gap) ============================
 * MALICIOUS PROVER: commit an HONEST low-degree CP (= alpha*Q_h, FRI-valid) but a SEPARATELY-committed,
 * genuinely HIGH-DEGREE trace that equals the honest LDE at the 48 non-H points yet violates next=cur^2 at
 * exactly one row (4->5).  Because verify() binds the trace by MERKLE ONLY (values, not degree) and FRI
 * never touches it, the pointwise line-755 catches the violation at exactly ONE of 64 queries.  We GRIND the
 * violation magnitude kk so that the proof's own 16-query set misses that one bad point -> verify() ACCEPTS a
 * FALSE statement.  zk_trace_attack_k() returns the first kk for which verify ACCEPTS (0 = none in range =
 * the hole is CLOSED, e.g. after a trace low-degree test is added). */
fn build_attack(kk: u32) {
    air_reset(1u32, N as u32)
    let mut v : u32 = 2u32  let mut i : u64 = 0u64
    while i < N { TF[i] = v  v = sf_mul(v, v)  i = i + 1u64 }
    i = 0u64  while i < N { air_set_trace(i, 0u64, TF[i])  i = i + 1u64 }
    air_build_lde()                                  /* HONEST air state -> CP will be the honest low-degree quotient */
    /* tampered COMMITTED rows: honest 0..4, row5 = row4^2 + kk (break 4->5), re-square forward (only 4->5 breaks) */
    i = 0u64  while i < N { TT[i] = TF[i]  i = i + 1u64 }
    TT[5u64] = sf_add(sf_mul(TF[4u64], TF[4u64]), kk)
    i = 6u64  while i < N { TT[i] = sf_mul(TT[i - 1u64], TT[i - 1u64])  i = i + 1u64 }
    /* commit TLEAF: H points (j%BLOW==0, row r=j/BLOW) = tampered TT[r]; non-H = honest LDE extension. */
    let mut j : u64 = 0u64
    while j < DOM {
        let mut f : u32 = 0u32
        if (j & (BLOW - 1u64)) == 0u64 { f = TT[j / BLOW] }
        if (j & (BLOW - 1u64)) != 0u64 { f = air_lde_at(0u64, j) }
        TLEAF[j * 4u64]        = (f & 0xFFu32) as u8
        TLEAF[j * 4u64 + 1u64] = ((f >> 8u32) & 0xFFu32) as u8
        TLEAF[j * 4u64 + 2u64] = ((f >> 16u32) & 0xFFu32) as u8
        TLEAF[j * 4u64 + 3u64] = ((f >> 24u32) & 0xFFu32) as u8
        j = j + 1u64
    }
    merkle_compute_root((&TLEAF as u64), DOM as u32, 4u64, (&TROOT as u64))
    keccak256_oneshot((&TROOT as u64), 32u64, (&DIG as u64))
    ALA[0] = e2pack(rd4(0u64), rd4(4u64))  ALB[0] = e2pack(rd4(8u64), rd4(12u64))
    air_add_term(0u32, 1u32, 2u32, 0u32)
    air_add_term(0u32, NEG1, 1u32, 1u32)
    air_set_alpha_ext4(0u64, ALA[0], ALB[0])
    air_build_cp_ext4()                              /* CP = alpha*Q_h from the HONEST air state -> genuinely low-degree */
    j = 0u64
    while j < DOM { FA[j] = air_cp_ext4_a(j)  FB[j] = air_cp_ext4_b(j)  j = j + 1u64 }
    /* FRI fold + per-layer Merkle commit (identical to build()) -- FRI ACCEPTS this honest CP. */
    let mut size : u64 = DOM  let mut off : u64 = 0u64  let mut li : u64 = 0u64
    while size > 4u64 {
        OFFS[li] = off  SIZES[li] = size
        ser_layer(off, size)
        merkle_compute_root((&LEAF as u64), size as u32, 16u64, (&ROOT as u64) + li * 32u64)
        keccak256_oneshot((&ROOT as u64) + li * 32u64, 32u64, (&DIG as u64))
        RR[li] = e2pack(rd4(0u64), rd4(4u64))  RI[li] = e2pack(rd4(8u64), rd4(12u64))
        let half : u64 = size / 2u64  let noff : u64 = off + size  let str : u64 = DOM / size
        let mut k : u64 = 0u64
        while k < half {
            foldp4(FA[off + k], FB[off + k], FA[off + k + half], FB[off + k + half], RR[li], RI[li], OM[str * k])
            FA[noff + k] = FRA[0]  FB[noff + k] = FRB[0]
            k = k + 1u64
        }
        off = noff  size = half  li = li + 1u64
    }
    OFFS[li] = off  SIZES[li] = size
    ser_layer(off, size)
    merkle_compute_root((&LEAF as u64), size as u32, 16u64, (&ROOT as u64) + li * 32u64)
    trace_fri_commit()                               /* the attack also commits a trace FRI -- but on the HIGH-degree trace */
}
fn zk_trace_attack_k() -> u32 @export {
    fill_om()
    let mut kk : u32 = 1u32
    while kk < 256u32 {
        build_attack(kk)
        if verify() == 1u64 { return kk }           /* ACCEPT of a false trace -> the hole, at this kk */
        kk = kk + 1u32
    }
    return 0u32                                      /* no false accept in range -> hole CLOSED */
}
/* HOLE-1 reproduction (the DECOUPLED prover the coupled self-test above never models): commit the trace FRI on a
 * low-degree DECOY (the honest LDE) while TROOT commits a VIOLATING trace (one H-point at row rstar tampered). The
 * decoupled trace FRI is genuinely low-degree -> passes the LDT; the violation is caught ONLY if a query hits the
 * tampered rows {rstar-1, rstar}.  Grinds rstar to one outside the (decoy-derived, fixed) query set -> ACCEPT. */
fn build_attack_decoupled(rstar: u64) {
    air_reset(1u32, N as u32)
    let mut v : u32 = 2u32  let mut i : u64 = 0u64
    while i < N { TF[i] = v  v = sf_mul(v, v)  i = i + 1u64 }
    i = 0u64  while i < N { air_set_trace(i, 0u64, TF[i])  i = i + 1u64 }
    air_build_lde()
    /* (1) DECOY: commit the trace FRI on the HONEST LDE (low-degree). */
    let mut j : u64 = 0u64
    while j < DOM {
        let f : u32 = air_lde_at(0u64, j)
        TLEAF[j * 4u64] = (f & 0xFFu32) as u8  TLEAF[j * 4u64 + 1u64] = ((f >> 8u32) & 0xFFu32) as u8
        TLEAF[j * 4u64 + 2u64] = ((f >> 16u32) & 0xFFu32) as u8  TLEAF[j * 4u64 + 3u64] = ((f >> 24u32) & 0xFFu32) as u8
        j = j + 1u64
    }
    trace_fri_commit()
    /* (2) TROOT on a VIOLATING trace: honest LDE except the H-point at row rstar set to TF[rstar]+1. */
    j = 0u64
    while j < DOM {
        let mut f : u32 = air_lde_at(0u64, j)
        if j == BLOW * rstar { f = sf_add(TF[rstar], 1u32) }
        TLEAF[j * 4u64] = (f & 0xFFu32) as u8  TLEAF[j * 4u64 + 1u64] = ((f >> 8u32) & 0xFFu32) as u8
        TLEAF[j * 4u64 + 2u64] = ((f >> 16u32) & 0xFFu32) as u8  TLEAF[j * 4u64 + 3u64] = ((f >> 24u32) & 0xFFu32) as u8
        j = j + 1u64
    }
    merkle_compute_root((&TLEAF as u64), DOM as u32, 4u64, (&TROOT as u64))
    keccak256_oneshot((&TROOT as u64), 32u64, (&DIG as u64))
    ALA[0] = e2pack(rd4(0u64), rd4(4u64))  ALB[0] = e2pack(rd4(8u64), rd4(12u64))
    air_add_term(0u32, 1u32, 2u32, 0u32)
    air_add_term(0u32, NEG1, 1u32, 1u32)
    air_set_alpha_ext4(0u64, ALA[0], ALB[0])
    air_build_cp_ext4()
    j = 0u64
    while j < DOM { FA[j] = air_cp_ext4_a(j)  FB[j] = air_cp_ext4_b(j)  j = j + 1u64 }
    let mut size : u64 = DOM  let mut off : u64 = 0u64  let mut li : u64 = 0u64
    while size > 4u64 {
        OFFS[li] = off  SIZES[li] = size
        ser_layer(off, size)
        merkle_compute_root((&LEAF as u64), size as u32, 16u64, (&ROOT as u64) + li * 32u64)
        keccak256_oneshot((&ROOT as u64) + li * 32u64, 32u64, (&DIG as u64))
        RR[li] = e2pack(rd4(0u64), rd4(4u64))  RI[li] = e2pack(rd4(8u64), rd4(12u64))
        let half : u64 = size / 2u64  let noff : u64 = off + size  let str : u64 = DOM / size
        let mut k : u64 = 0u64
        while k < half { foldp4(FA[off + k], FB[off + k], FA[off + k + half], FB[off + k + half], RR[li], RI[li], OM[str * k])  FA[noff + k] = FRA[0]  FB[noff + k] = FRB[0]  k = k + 1u64 }
        off = noff  size = half  li = li + 1u64
    }
    OFFS[li] = off  SIZES[li] = size
    ser_layer(off, size)
    merkle_compute_root((&LEAF as u64), size as u32, 16u64, (&ROOT as u64) + li * 32u64)
}
fn zk_trace_attack_decoupled() -> u64 @export {
    fill_om()
    let mut rstar : u64 = 1u64
    while rstar < 15u64 {
        build_attack_decoupled(rstar)
        if verify() == 1u64 { return rstar }        /* ACCEPT of a DECOUPLED false trace -> Hole 1, at this rstar */
        rstar = rstar + 1u64
    }
    return 0u64
}

fn main() -> u64 {
    fill_om()
    /* (H) honest trace: committed STARK ACCEPTS. */
    build(0u64)
    let hr : u64 = verify()
    if hr != 1u64 { return 10u64 + hr }   /* 12=final-const 13/14=trace-open 15/16=line755 a/b 17=CP-merkle 18=FRI-merkle 19=FRI-fold */
    /* (V) violating trace: CP not the true low-degree quotient -> REJECT (final not constant / line-755 at a query). */
    build(1u64)
    if verify() == 1u64 { return 2u64 }
    /* (O) forged trace OPENING: commit honestly, then claim a different f at a leaf -> Merkle-verify REJECTS. */
    build(0u64)
    let plen : u32 = merkle_proof_len_for(DOM as u32, 0u32)
    merkle_compute_proof((&TLEAF as u64), 4u64, merkle_pack_count_index(DOM as u32, 0u32), (&PRF as u64))
    TQ[0u64] = TLEAF[0u64] ^ 1u8  TQ[1u64] = TLEAF[1u64]  TQ[2u64] = TLEAF[2u64]  TQ[3u64] = TLEAF[3u64]
    if merkle_verify_proof((&TQ as u64), merkle_pack_verify_meta(4u32, 0u32, plen), (&PRF as u64), (&TROOT as u64)) != 0u8 { return 3u64 }
    /* (R) corrupted committed root: the full verify REJECTS. */
    build(0u64)
    TROOT[0u64] = TROOT[0u64] ^ 1u8
    if verify() == 1u64 { return 4u64 }
    /* (D) honest re-proves. */
    build(0u64)
    if verify() != 1u64 { return 5u64 }
    /* (S) SOUNDNESS -- the trace low-degree gap: a decoupled HIGH-DEGREE committed trace (honest low-degree CP +
     * tampered trace agreeing with the LDE off-H) must be REJECTED.  zk_trace_attack_k()!=0 means verify() ACCEPTED
     * a false trace -> the trace is not degree-bound.  RED (returns 6) until a trace low-degree test is added. */
    if zk_trace_attack_k() != 0u32 { return 6u64 }
    /* (S2) confirm the trace LDT is the LOAD-BEARING catcher (not a dead check beside an incidental reject): the
     * attack must reject with a TRACE-FRI code -- 20 (final-constant non-constant), 21/22 (layer-0 consistency),
     * 23/24 (fold-consistency) -- NOT an unrelated <20 code. */
    build_attack(1u32)
    if verify() < 20u64 { return 7u64 }
    /* (S3) HOLE 1 (binding) -- the DECOUPLED prover: a low-degree DECOY trace FRI + a violating TROOT must be
     * REJECTED.  zk_trace_attack_decoupled()!=0 means verify() ACCEPTED a decoupled false trace (the trace FRI was
     * proven low-degree on a decoy, not on the constraint trace).  RED (returns 8) until the trace FRI is bound to
     * TROOT globally (layer 0 = the TROOT-committed trace). */
    if zk_trace_attack_decoupled() != 0u64 { return 8u64 }
    return 99u64
}
