/* zk_fused_committed.iii -- P2b SCALE-UP (DOCS/III-GRAND-UNIFICATION-AUDIT-AND-PLAN.md): the FULL compute+memory+control
 * zkVM (a real 32-STORE + 32-LOAD program, ONE N=64 trace, W=19, 20 transition constraints + a k=4 grand-product
 * permutation) verified as a COMMITTED proof over GF(p^4) -- closing finding F1 for the whole fused AIR.
 *
 * Over zk_fused_prod (whose verify() read the prover's FRI arrays from shared memory and used a FIXED combination
 * alpha), this adds:
 *   (1) the 19 trace-column LDEs are MERKLE-COMMITTED (one SHA-256 root per column); the composition polynomial CP is
 *       committed as the FRI layer-0 root; every FRI layer is committed (P2a).  Challenges + queries derive from the
 *       committed roots, so the prover is BOUND before it sees them.
 *   (2) the combination challenge alpha (GF(p^4), per constraint) is FS-DERIVED from the committed trace roots (sound
 *       order: commit-then-challenge) -- not the fixed alpha zk_fused_prod baked in (a prover could otherwise pick a
 *       trace whose constraint violations cancel under a known alpha).
 *   (3) the verifier, per FS-derived query q, OPENS + merkle_verify_proof's every trace leaf air_combine_ext4 reads
 *       (all 19 columns at q and at q+B) against their committed roots, BINDING air's proven combine to the commitment;
 *       opens CP(q); checks the construction-exact line-755 CP*Z_H == combine*(x-omega^{n-1}) + the GF(p^4) FRI fold;
 *       and checks the k=4 permutation boundary at OPENED accumulator leaves.
 *
 * Returns 99 iff: (H) the honest execution VERIFIES + the k=4 boundary holds; (L) a FORGED LOAD value (read-consistency)
 * is REJECTED by the line-755 at a query; (P) a FORGED program access (non-permutation) is REJECTED by the k=4 boundary;
 * (O) a forged trace OPENING is REJECTED by Merkle; (R) a corrupted committed root is REJECTED.  A committed,
 * commitment-bound fused zkVM -- the production claim earned against Merkle openings, not shared memory. */
module zk_fused_committed

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_perm_term(con: u32, kind: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_setup(start: u64, nv: u64) -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_beta() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r2() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r3() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r4() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r5() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r6() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r7() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha_ext4(con: u64, a: u64, b: u64) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp_ext4() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_ext4_a(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_ext4_b(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_combine_ext4_at(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cmb4_b() -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_lde_at(col: u64, j: u64) -> u32 from "zk_air.iii"

extern @abi(c-msvc-x64) fn ext2_add(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_sub(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_mul(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_smul(s: u32, a: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn e2pack(a0: u32, a1: u32) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn sf_rou(n: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_add(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_sub(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn keccak256_oneshot(msg_ptr: u64, msg_len: u64, out_ptr: u64) -> i32 from "keccak256.iii"
extern @abi(c-msvc-x64) fn merkle_compute_root(leaves_ptr: u64, leaf_count: u32, leaf_size: u64, out_32: u64) -> i32 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_proof_len_for(leaf_count: u32, leaf_index: u32) -> u32 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_compute_proof(leaves_ptr: u64, leaf_size: u64, packed_count_index: u64, proof_out_ptr: u64) -> i32 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_verify_proof(leaf_ptr: u64, packed_meta: u64, proof_ptr: u64, root_32_ptr: u64) -> u8 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_pack_count_index(leaf_count: u32, leaf_index: u32) -> u64 from "merkle.iii"
extern @abi(c-msvc-x64) fn merkle_pack_verify_meta(leaf_size: u32, leaf_index: u32, proof_steps: u32) -> u64 from "merkle.iii"

const PRIME : u32 = 998244353u32
const NEG1  : u32 = 998244352u32
const NEG7  : u32 = 998244346u32
const DOM   : u64 = 256u64
const NN    : u64 = 64u64
const BLOW  : u64 = 4u64
const WCOL  : u64 = 19u64
const G4    : u64 = 4294967298u64
const NQPB  : u64 = 32u64           /* FS queries per keccak batch */
const NBATCH: u64 = 4u64            /* 4 re-hash batches * 32 = 128 FS queries -> PRODUCTION query soundness ~2^-86 */

var OM   : [u32; 256]
var FA   : [u64; 512]    var FB : [u64; 512]
var OFFS : [u64; 8]      var SIZES: [u64; 8]
var FROOT: [u8; 256]                 /* per-FRI-layer root */
var RR   : [u64; 8]      var RI : [u64; 8]
var TROOT: [u8; 640]                 /* 19 trace-column roots (col*32) */
var TLEAF: [u8; 1024]                /* one column's D u32 leaves (D*4) */
var ALA  : [u64; 32]     var ALB : [u64; 32]   /* per-constraint GF(p^4) combination alpha (FS) */
var DIG  : [u8; 32]
var LEAF : [u8; 8192]                /* FRI layer GF(p^4) leaves (16B each) */
var PRF  : [u8; 512]
var QLEAF: [u8; 16]
var TQ4  : [u8; 4]
var FRA  : [u64; 1]      var FRB : [u64; 1]
var AP : [u32; 64]  var VP : [u32; 64]  var WP : [u32; 64]
var AS : [u32; 64]  var VS : [u32; 64]  var WS : [u32; 64]
var P1 : [u32; 64]  var S1 : [u32; 64]  var P2 : [u32; 64]  var S2 : [u32; 64]
var P3 : [u32; 64]  var S3 : [u32; 64]  var P4 : [u32; 64]  var S4 : [u32; 64]
var DM : [u32; 64]  var WV : [u32; 64]  var IZ : [u32; 64]  var RA : [u32; 64]

fn base_inv(v: u32) -> u32 {
    let mut r : u32 = 1u32  let mut b : u32 = v  let mut e : u32 = PRIME - 2u32
    while e > 0u32 { if (e & 1u32) == 1u32 { r = sf_mul(r, b) }  b = sf_mul(b, b)  e = e >> 1u32 }
    return r
}
fn inv0(d: u32) -> u32 { if d == 0u32 { return 0u32 }  return base_inv(d) }
fn fill_om() {
    let w : u32 = sf_rou(DOM as u32)  OM[0] = 1u32
    let mut j : u64 = 1u64
    while j < DOM { OM[j] = sf_mul(OM[j - 1u64], w)  j = j + 1u64 }
}
fn p4mul_a(ra: u64, rb: u64, fa: u64, fb: u64) -> u64 { return ext2_add(ext2_mul(ra, fa), ext2_mul(ext2_mul(rb, fb), G4)) }
fn p4mul_b(ra: u64, rb: u64, fa: u64, fb: u64) -> u64 { return ext2_add(ext2_mul(ra, fb), ext2_mul(rb, fa)) }
fn foldp4(loa: u64, lob: u64, hia: u64, hib: u64, ra: u64, rb: u64, x: u32) {
    let inv2 : u32 = base_inv(2u32)  let i2x : u32 = base_inv(sf_add(x, x))
    let fea : u64 = ext2_smul(inv2, ext2_add(loa, hia))  let feb : u64 = ext2_smul(inv2, ext2_add(lob, hib))
    let foa : u64 = ext2_smul(i2x, ext2_sub(loa, hia))   let fob : u64 = ext2_smul(i2x, ext2_sub(lob, hib))
    FRA[0] = ext2_add(fea, p4mul_a(ra, rb, foa, fob))
    FRB[0] = ext2_add(feb, p4mul_b(ra, rb, foa, fob))
}
fn rd4(o: u64) -> u32 {
    let p : *u8 = ((&DIG as u64) + o) as *u8
    let mut x : u32 = (p[0u64] as u32) | ((p[1u64] as u32) << 8u32) | ((p[2u64] as u32) << 16u32) | ((p[3u64] as u32) << 24u32)
    while x >= PRIME { x = x - PRIME }
    return x
}
fn encf(a: u32, v: u32, w: u32, alpha: u32, beta: u32, bsq: u32) -> u32 {
    let enc : u32 = sf_add(sf_add(a, sf_mul(beta, v)), sf_mul(bsq, w))
    return sf_sub(alpha, enc)
}

/* commit one trace-column LDE (col) into TROOT[col]; leaves = air_lde_at(col,j), 4-byte LE. */
fn commit_col(col: u64) {
    let mut j : u64 = 0u64
    while j < DOM {
        let f : u32 = air_lde_at(col, j)
        TLEAF[j * 4u64]        = (f & 0xFFu32) as u8
        TLEAF[j * 4u64 + 1u64] = ((f >> 8u32) & 0xFFu32) as u8
        TLEAF[j * 4u64 + 2u64] = ((f >> 16u32) & 0xFFu32) as u8
        TLEAF[j * 4u64 + 3u64] = ((f >> 24u32) & 0xFFu32) as u8
        j = j + 1u64
    }
    merkle_compute_root((&TLEAF as u64), DOM as u32, 4u64, (&TROOT as u64) + col * 32u64)
}
/* open + Merkle-verify trace leaf (col, idx) against TROOT[col]; returns 1 ok, 0 reject. */
fn open_col(col: u64, idx: u64) -> u64 {
    let mut j : u64 = 0u64
    while j < DOM {
        let f : u32 = air_lde_at(col, j)
        TLEAF[j * 4u64]        = (f & 0xFFu32) as u8
        TLEAF[j * 4u64 + 1u64] = ((f >> 8u32) & 0xFFu32) as u8
        TLEAF[j * 4u64 + 2u64] = ((f >> 16u32) & 0xFFu32) as u8
        TLEAF[j * 4u64 + 3u64] = ((f >> 24u32) & 0xFFu32) as u8
        j = j + 1u64
    }
    let plen : u32 = merkle_proof_len_for(DOM as u32, idx as u32)
    merkle_compute_proof((&TLEAF as u64), 4u64, merkle_pack_count_index(DOM as u32, idx as u32), (&PRF as u64))
    let lp : *u8 = ((&TLEAF as u64) + idx * 4u64) as *u8
    TQ4[0u64] = lp[0u64]  TQ4[1u64] = lp[1u64]  TQ4[2u64] = lp[2u64]  TQ4[3u64] = lp[3u64]
    return merkle_verify_proof((&TQ4 as u64), merkle_pack_verify_meta(4u32, idx as u32, plen), (&PRF as u64), (&TROOT as u64) + col * 32u64) as u64
}

/* serialise + commit a FRI layer (GF(p^4), 16B leaves) at flat offset off/size into FROOT[li]. */
fn commit_fri_layer(off: u64, size: u64, li: u64) {
    let mut i : u64 = 0u64
    while i < size {
        let a : u64 = FA[off + i]  let b : u64 = FB[off + i]  let base : u64 = i * 16u64
        let mut k : u64 = 0u64
        while k < 8u64 { LEAF[base + k] = ((a >> (8u64 * k)) & 0xFFu64) as u8  k = k + 1u64 }
        k = 0u64
        while k < 8u64 { LEAF[base + 8u64 + k] = ((b >> (8u64 * k)) & 0xFFu64) as u8  k = k + 1u64 }
        i = i + 1u64
    }
    merkle_compute_root((&LEAF as u64), size as u32, 16u64, (&FROOT as u64) + li * 32u64)
}
fn open_fri(off: u64, size: u64, idx: u64, li: u64) -> u64 {
    let mut i : u64 = 0u64
    while i < size {
        let a : u64 = FA[off + i]  let b : u64 = FB[off + i]  let base : u64 = i * 16u64
        let mut k : u64 = 0u64
        while k < 8u64 { LEAF[base + k] = ((a >> (8u64 * k)) & 0xFFu64) as u8  k = k + 1u64 }
        k = 0u64
        while k < 8u64 { LEAF[base + 8u64 + k] = ((b >> (8u64 * k)) & 0xFFu64) as u8  k = k + 1u64 }
        i = i + 1u64
    }
    let plen : u32 = merkle_proof_len_for(size as u32, idx as u32)
    merkle_compute_proof((&LEAF as u64), 16u64, merkle_pack_count_index(size as u32, idx as u32), (&PRF as u64))
    let lp : *u8 = ((&LEAF as u64) + idx * 16u64) as *u8
    let mut k : u64 = 0u64  while k < 16u64 { QLEAF[k] = lp[k]  k = k + 1u64 }
    return merkle_verify_proof((&QLEAF as u64), merkle_pack_verify_meta(16u32, idx as u32, plen), (&PRF as u64), (&FROOT as u64) + li * 32u64) as u64
}
fn qa() -> u64 { let mut a : u64 = 0u64  let mut k : u64 = 0u64  while k < 8u64 { a = a | ((QLEAF[k] as u64) << (8u64 * k))  k = k + 1u64 }  return a }
fn qb() -> u64 { let mut b : u64 = 0u64  let mut k : u64 = 0u64  while k < 8u64 { b = b | ((QLEAF[8u64 + k] as u64) << (8u64 * k))  k = k + 1u64 }  return b }
fn zt_h(q: u64) -> u32 { return sf_sub(OM[(NN * q) & (DOM - 1u64)], 1u32) }
fn zt_fac(q: u64) -> u32 { return sf_sub(OM[q], OM[DOM - BLOW]) }

/* PROVER: build the fused trace (verbatim zk_fused_prod), commit the 19 trace columns, FS-derive the combination
 * alpha from the trace commitment, build the GF(p^4) CP, FRI-fold + commit every layer. */
fn build(forge: u64) {
    air_reset(WCOL as u32, NN as u32)
    let mut k : u64 = 0u64
    while k < 32u64 {
        AP[k] = k as u32  VP[k] = sf_mul(7u32, k as u32)  WP[k] = 1u32
        AP[32u64 + k] = k as u32  VP[32u64 + k] = sf_mul(7u32, k as u32)  WP[32u64 + k] = 0u32
        AS[2u64 * k] = k as u32  VS[2u64 * k] = sf_mul(7u32, k as u32)  WS[2u64 * k] = 1u32
        AS[2u64 * k + 1u64] = k as u32  VS[2u64 * k + 1u64] = sf_mul(7u32, k as u32)  WS[2u64 * k + 1u64] = 0u32
        k = k + 1u64
    }
    if forge == 1u64 { VS[1] = 99u32 }
    if forge == 2u64 { VP[32] = 99u32 }
    if forge == 3u64 { VP[63u64] = 99u32 }   /* LAST-ACCESS forge: row-63 load value (excluded from the i<63 product) */
    let mut i : u64 = 0u64
    while i < 64u64 {
        air_set_trace(i, 0u64, i as u32)  air_set_trace(i, 1u64, AP[i])  air_set_trace(i, 2u64, VP[i])  air_set_trace(i, 3u64, WP[i])
        air_set_trace(i, 4u64, AS[i])  air_set_trace(i, 5u64, VS[i])  air_set_trace(i, 6u64, WS[i])
        i = i + 1u64
    }
    let aa1 : u32 = air_perm_setup(1u64, 6u64)
    let b1b : u32 = air_perm_beta()  let b2b : u32 = air_perm_r4()  let b3b : u32 = air_perm_r5()  let b4b : u32 = air_perm_r7()
    let aa2 : u32 = air_perm_r2()  let aa3 : u32 = air_perm_r3()  let aa4 : u32 = air_perm_r6()
    P1[0] = 1u32  S1[0] = 1u32  P2[0] = 1u32  S2[0] = 1u32  P3[0] = 1u32  S3[0] = 1u32  P4[0] = 1u32  S4[0] = 1u32
    let q1 : u32 = sf_mul(b1b, b1b)  let q2 : u32 = sf_mul(b2b, b2b)  let q3 : u32 = sf_mul(b3b, b3b)  let q4 : u32 = sf_mul(b4b, b4b)
    i = 0u64
    while i < 63u64 {
        P1[i + 1u64] = sf_mul(P1[i], encf(AP[i], VP[i], WP[i], aa1, b1b, q1))  S1[i + 1u64] = sf_mul(S1[i], encf(AS[i], VS[i], WS[i], aa1, b1b, q1))
        P2[i + 1u64] = sf_mul(P2[i], encf(AP[i], VP[i], WP[i], aa2, b2b, q2))  S2[i + 1u64] = sf_mul(S2[i], encf(AS[i], VS[i], WS[i], aa2, b2b, q2))
        P3[i + 1u64] = sf_mul(P3[i], encf(AP[i], VP[i], WP[i], aa3, b3b, q3))  S3[i + 1u64] = sf_mul(S3[i], encf(AS[i], VS[i], WS[i], aa3, b3b, q3))
        P4[i + 1u64] = sf_mul(P4[i], encf(AP[i], VP[i], WP[i], aa4, b4b, q4))  S4[i + 1u64] = sf_mul(S4[i], encf(AS[i], VS[i], WS[i], aa4, b4b, q4))
        i = i + 1u64
    }
    i = 0u64
    while i < 64u64 {
        let inx : u64 = (i + 1u64) & 63u64
        DM[i] = sf_sub(AS[inx], AS[i])  WV[i] = inv0(DM[i])
        if DM[i] == 0u32 { IZ[i] = 1u32 } else { IZ[i] = 0u32 }
        RA[i] = sf_mul(IZ[i], sf_sub(VS[inx], VS[i]))
        i = i + 1u64
    }
    i = 0u64
    while i < 64u64 {
        air_set_trace(i, 7u64, P1[i])  air_set_trace(i, 8u64, S1[i])  air_set_trace(i, 9u64, P2[i])  air_set_trace(i, 10u64, S2[i])
        air_set_trace(i, 11u64, P3[i])  air_set_trace(i, 12u64, S3[i])  air_set_trace(i, 13u64, P4[i])  air_set_trace(i, 14u64, S4[i])
        air_set_trace(i, 15u64, DM[i])  air_set_trace(i, 16u64, WV[i])  air_set_trace(i, 17u64, IZ[i])  air_set_trace(i, 18u64, RA[i])
        i = i + 1u64
    }
    air_build_lde()
    /* commit the 19 trace-column LDEs, then FS-derive the combination alpha from the concatenated roots. */
    let mut c : u64 = 0u64
    while c < WCOL { commit_col(c)  c = c + 1u64 }
    keccak256_oneshot((&TROOT as u64), WCOL * 32u64, (&DIG as u64))
    c = 0u64
    while c < 20u64 {
        /* derive a fresh per-constraint alpha by re-hashing (chain DIG). */
        ALA[c] = e2pack(rd4(0u64), rd4(4u64))  ALB[c] = e2pack(rd4(8u64), rd4(12u64))
        air_set_alpha_ext4(c, ALA[c], ALB[c])
        keccak256_oneshot((&DIG as u64), 32u64, (&DIG as u64))
        c = c + 1u64
    }
    /* the 20 transition constraints + perm terms (verbatim zk_fused_prod). */
    air_add_term(0u32, 1u32, 20u32, 0u32)  air_add_term(0u32, NEG1, 1u32, 0u32)  air_add_term(0u32, NEG1, 0u32, 0u32)
    air_add_term(1u32, 1u32, 4u32, 3u32)   air_add_term(1u32, NEG7, 4u32, 2u32)
    air_add_term(2u32, 1u32, 7u32, 6u32)   air_add_term(2u32, NEG7, 7u32, 5u32)
    air_add_term(3u32, 1u32, 27u32, 0u32)  air_add_perm_term(3u32, 1u32, 8u32, 0u32)   air_add_term(3u32, 1u32, 8u32, 2u32)   air_add_perm_term(3u32, 2u32, 8u32, 3u32)   air_add_perm_term(3u32, 3u32, 8u32, 4u32)
    air_add_term(4u32, 1u32, 28u32, 0u32)  air_add_perm_term(4u32, 1u32, 9u32, 0u32)   air_add_term(4u32, 1u32, 9u32, 5u32)   air_add_perm_term(4u32, 2u32, 9u32, 6u32)   air_add_perm_term(4u32, 3u32, 9u32, 7u32)
    air_add_term(5u32, 1u32, 29u32, 0u32)  air_add_perm_term(5u32, 4u32, 10u32, 0u32)  air_add_term(5u32, 1u32, 10u32, 2u32)  air_add_perm_term(5u32, 6u32, 10u32, 3u32)  air_add_perm_term(5u32, 7u32, 10u32, 4u32)
    air_add_term(6u32, 1u32, 30u32, 0u32)  air_add_perm_term(6u32, 4u32, 11u32, 0u32)  air_add_term(6u32, 1u32, 11u32, 5u32)  air_add_perm_term(6u32, 6u32, 11u32, 6u32)  air_add_perm_term(6u32, 7u32, 11u32, 7u32)
    air_add_term(7u32, 1u32, 31u32, 0u32)  air_add_perm_term(7u32, 5u32, 12u32, 0u32)  air_add_term(7u32, 1u32, 12u32, 2u32)  air_add_perm_term(7u32, 8u32, 12u32, 3u32)  air_add_perm_term(7u32, 9u32, 12u32, 4u32)
    air_add_term(8u32, 1u32, 32u32, 0u32)  air_add_perm_term(8u32, 5u32, 13u32, 0u32)  air_add_term(8u32, 1u32, 13u32, 5u32)  air_add_perm_term(8u32, 8u32, 13u32, 6u32)  air_add_perm_term(8u32, 9u32, 13u32, 7u32)
    air_add_term(9u32, 1u32, 33u32, 0u32)  air_add_perm_term(9u32, 10u32, 14u32, 0u32) air_add_term(9u32, 1u32, 14u32, 2u32)  air_add_perm_term(9u32, 11u32, 14u32, 3u32) air_add_perm_term(9u32, 12u32, 14u32, 4u32)
    air_add_term(10u32, 1u32, 34u32, 0u32) air_add_perm_term(10u32, 10u32, 15u32, 0u32) air_add_term(10u32, 1u32, 15u32, 5u32) air_add_perm_term(10u32, 11u32, 15u32, 6u32) air_add_perm_term(10u32, 12u32, 15u32, 7u32)
    air_add_term(11u32, 1u32, 16u32, 0u32) air_add_term(11u32, NEG1, 24u32, 0u32)  air_add_term(11u32, 1u32, 5u32, 0u32)
    air_add_term(12u32, 1u32, 18u32, 16u32)
    air_add_term(13u32, 1u32, 18u32, 0u32) air_add_term(13u32, 1u32, 16u32, 17u32) air_add_term(13u32, NEG1, 0u32, 0u32)
    air_add_term(14u32, 1u32, 16u32, 16u32) air_add_term(14u32, NEG1, 16u32, 0u32)
    air_add_term(15u32, 1u32, 19u32, 0u32) air_add_term(15u32, NEG1, 18u32, 25u32) air_add_term(15u32, 1u32, 18u32, 6u32)
    air_add_term(16u32, 1u32, 19u32, 0u32) air_add_term(16u32, NEG1, 19u32, 26u32)
    air_add_term(17u32, 1u32, 4u32, 4u32) air_add_term(17u32, NEG1, 4u32, 0u32)
    air_add_term(18u32, 1u32, 7u32, 7u32) air_add_term(18u32, NEG1, 7u32, 0u32)
    air_add_term(19u32, 1u32, 18u32, 18u32) air_add_term(19u32, NEG1, 18u32, 0u32)
    air_build_cp_ext4()
    /* FRI layer 0 = CP; fold + commit each layer; fold challenge from each committed root. */
    let mut j : u64 = 0u64
    while j < DOM { FA[j] = air_cp_ext4_a(j)  FB[j] = air_cp_ext4_b(j)  j = j + 1u64 }
    let mut size : u64 = DOM  let mut off : u64 = 0u64  let mut li : u64 = 0u64
    while size > 4u64 {
        OFFS[li] = off  SIZES[li] = size
        commit_fri_layer(off, size, li)
        keccak256_oneshot((&FROOT as u64) + li * 32u64, 32u64, (&DIG as u64))
        RR[li] = e2pack(rd4(0u64), rd4(4u64))  RI[li] = e2pack(rd4(8u64), rd4(12u64))
        let half : u64 = size / 2u64  let noff : u64 = off + size  let str : u64 = DOM / size
        let mut m : u64 = 0u64
        while m < half {
            foldp4(FA[off + m], FB[off + m], FA[off + m + half], FB[off + m + half], RR[li], RI[li], OM[str * m])
            FA[noff + m] = FRA[0]  FB[noff + m] = FRB[0]
            m = m + 1u64
        }
        off = noff  size = half  li = li + 1u64
    }
    OFFS[li] = off  SIZES[li] = size
    commit_fri_layer(off, size, li)
}

/* the k=4 permutation boundary at OPENED accumulator leaves.  SOUND grand product requires BOTH the START PIN
 * P_k[0]==S_k[0]==1 (Z(1)=1) AND the final equality P_k[63]==S_k[63].  Without the seed pin a malicious prover rigs
 * S_k[0]=Pi_p_k*inv(Pi_s_k) so a NON-permutation satisfies the final equality -> ACCEPT (DOCS/III-ZK-PERM-SEED-GAP).
 * With both seeds pinned to 1, P_k[63]==S_k[63] forces Pi_p_k==Pi_s_k -> genuine permutation. All leaves merkle-opened. */
fn tq4_u32() -> u32 { return (TQ4[0u64] as u32) | ((TQ4[1u64] as u32) << 8u32) | ((TQ4[2u64] as u32) << 16u32) | ((TQ4[3u64] as u32) << 24u32) }
fn boundary_ok() -> u64 {
    let bi : u64 = 63u64 * BLOW
    let bi0 : u64 = 0u64                               /* trace row 0 -> LDE index 0: the accumulator SEED */
    /* re-derive the k=4 perm challenges (same FS derivation as build, from the committed access columns 1..6). */
    let aa1 : u32 = air_perm_setup(1u64, 6u64)
    let b1b : u32 = air_perm_beta()  let b2b : u32 = air_perm_r4()  let b3b : u32 = air_perm_r5()  let b4b : u32 = air_perm_r7()
    let aa2 : u32 = air_perm_r2()  let aa3 : u32 = air_perm_r3()  let aa4 : u32 = air_perm_r6()
    let q1 : u32 = sf_mul(b1b, b1b)  let q2 : u32 = sf_mul(b2b, b2b)  let q3 : u32 = sf_mul(b3b, b3b)  let q4 : u32 = sf_mul(b4b, b4b)
    /* LAST-ACCESS FIX (DOCS/III-ZK-PERM-SEED-GAP): access 63 is EXCLUDED from the i<63 product, so open it (program
     * cols 1,2,3 + sorted 4,5,6 at row 63) and fold encf(access_63) into the final product -- a forged last LOAD is caught. */
    if open_col(1u64, bi) == 0u64 { return 0u64 }  let ap63 : u32 = tq4_u32()
    if open_col(2u64, bi) == 0u64 { return 0u64 }  let vp63 : u32 = tq4_u32()
    if open_col(3u64, bi) == 0u64 { return 0u64 }  let wp63 : u32 = tq4_u32()
    if open_col(4u64, bi) == 0u64 { return 0u64 }  let as63 : u32 = tq4_u32()
    if open_col(5u64, bi) == 0u64 { return 0u64 }  let vs63 : u32 = tq4_u32()
    if open_col(6u64, bi) == 0u64 { return 0u64 }  let ws63 : u32 = tq4_u32()
    let mut kk : u64 = 0u64
    while kk < 4u64 {
        let pcol : u64 = 7u64 + 2u64 * kk  let scol : u64 = 8u64 + 2u64 * kk
        /* SEED PIN (Z(1)=1): P_k[0] and S_k[0] must BOTH equal 1, opened+verified at row 0. */
        if open_col(pcol, bi0) == 0u64 { return 0u64 }
        if tq4_u32() != 1u32 { return 0u64 }
        if open_col(scol, bi0) == 0u64 { return 0u64 }
        if tq4_u32() != 1u32 { return 0u64 }
        /* FINAL with the LAST access folded in: P_k[63]*encf(prog_63) == S_k[63]*encf(sort_63). */
        if open_col(pcol, bi) == 0u64 { return 0u64 }  let pv : u32 = tq4_u32()
        if open_col(scol, bi) == 0u64 { return 0u64 }  let sv : u32 = tq4_u32()
        let mut aak : u32 = aa1  let mut bk : u32 = b1b  let mut qk : u32 = q1
        if kk == 1u64 { aak = aa2  bk = b2b  qk = q2 }
        if kk == 2u64 { aak = aa3  bk = b3b  qk = q3 }
        if kk == 3u64 { aak = aa4  bk = b4b  qk = q4 }
        let ep : u32 = encf(ap63, vp63, wp63, aak, bk, qk)
        let es : u32 = encf(as63, vs63, ws63, aak, bk, qk)
        if sf_mul(pv, ep) != sf_mul(sv, es) { return 0u64 }
        kk = kk + 1u64
    }
    return 1u64
}

fn verify() -> u64 {
    /* re-derive combination alpha from the committed trace roots (same chain as build). */
    keccak256_oneshot((&TROOT as u64), WCOL * 32u64, (&DIG as u64))
    let mut c : u64 = 0u64
    while c < 20u64 {
        ALA[c] = e2pack(rd4(0u64), rd4(4u64))  ALB[c] = e2pack(rd4(8u64), rd4(12u64))
        air_set_alpha_ext4(c, ALA[c], ALB[c])
        keccak256_oneshot((&DIG as u64), 32u64, (&DIG as u64))
        c = c + 1u64
    }
    /* re-derive FRI fold challenges + offsets from the committed layer roots. */
    let mut size : u64 = DOM  let mut off : u64 = 0u64  let mut i : u64 = 0u64
    while size > 4u64 {
        OFFS[i] = off  SIZES[i] = size
        keccak256_oneshot((&FROOT as u64) + i * 32u64, 32u64, (&DIG as u64))
        RR[i] = e2pack(rd4(0u64), rd4(4u64))  RI[i] = e2pack(rd4(8u64), rd4(12u64))
        off = off + size  size = size / 2u64  i = i + 1u64
    }
    let nl : u64 = i  let foff : u64 = off
    OFFS[nl] = foff  SIZES[nl] = 4u64
    let fa0 : u64 = FA[foff]  let fb0 : u64 = FB[foff]
    let mut cc : u64 = 1u64
    while cc < 4u64 { if FA[foff + cc] != fa0 { return 0u64 }  if FB[foff + cc] != fb0 { return 0u64 }  cc = cc + 1u64 }
    /* queries from keccak(final FRI root): NBATCH re-hash batches of NQPB -> 128 FS-derived queries (~2^-86). */
    keccak256_oneshot((&FROOT as u64) + nl * 32u64, 32u64, (&DIG as u64))
    let mut batch : u64 = 0u64
    while batch < NBATCH {
      let mut qi : u64 = 0u64
      while qi < NQPB {
        let pq : *u8 = ((&DIG as u64) + qi) as *u8
        let q0 : u64 = (pq[0u64] as u64) & (DOM - 1u64)
        /* bind air's combine: open+verify ALL 19 columns at q0 and at q0+B (every leaf air_eval_var reads). */
        let qn : u64 = (q0 + BLOW) & (DOM - 1u64)
        let mut col : u64 = 0u64
        while col < WCOL {
            if open_col(col, q0) == 0u64 { return 0u64 }
            if open_col(col, qn) == 0u64 { return 0u64 }
            col = col + 1u64
        }
        /* open CP(q0) (FRI layer 0) + the line-755 against air's now-bound combine. */
        if open_fri(0u64, DOM, q0, 0u64) == 0u64 { return 0u64 }
        let cpa : u64 = qa()  let cpb : u64 = qb()
        let mba : u64 = air_combine_ext4_at(q0)  let mbb : u64 = air_cmb4_b()
        let zh : u32 = zt_h(q0)  let fac : u32 = zt_fac(q0)
        if ext2_smul(zh, cpa) != ext2_smul(fac, mba) { return 0u64 }
        if ext2_smul(zh, cpb) != ext2_smul(fac, mbb) { return 0u64 }
        /* FRI fold-consistency up the layers (opened + verified). */
        let mut li : u64 = 0u64
        while li < nl {
            let s : u64 = SIZES[li]  let o : u64 = OFFS[li]  let half : u64 = s / 2u64
            let qm : u64 = q0 & (half - 1u64)
            if open_fri(o, s, qm, li) == 0u64 { return 0u64 }
            let loa : u64 = qa()  let lob : u64 = qb()
            if open_fri(o, s, qm + half, li) == 0u64 { return 0u64 }
            let hia : u64 = qa()  let hib : u64 = qb()
            if open_fri(OFFS[li + 1u64], SIZES[li + 1u64], qm, li + 1u64) == 0u64 { return 0u64 }
            let nxa : u64 = qa()  let nxb : u64 = qb()
            foldp4(loa, lob, hia, hib, RR[li], RI[li], OM[(DOM / s) * qm])
            if FRA[0] != nxa { return 0u64 }
            if FRB[0] != nxb { return 0u64 }
            li = li + 1u64
        }
        qi = qi + 1u64
      }
      keccak256_oneshot((&DIG as u64), 32u64, (&DIG as u64))   /* re-hash for the next query batch */
      batch = batch + 1u64
    }
    return 1u64
}

fn main() -> u64 {
    fill_om()
    /* (H) honest: committed verify ACCEPTS + the k=4 boundary holds. */
    build(0u64)
    if verify() != 1u64 { return 1u64 }
    if boundary_ok() != 1u64 { return 2u64 }
    /* (L) forged LOAD value (read-consistency): line-755 REJECTS. */
    build(1u64)
    if verify() == 1u64 { return 3u64 }
    /* (P) forged program access (non-permutation): transitions still hold but the k=4 boundary REJECTS. */
    build(2u64)
    if verify() != 1u64 { return 5u64 }
    if boundary_ok() == 1u64 { return 4u64 }
    /* (LA) forged LAST-access load VP[63] (row 63, EXCLUDED from the i<63 product): transitions hold (no row-64
     * successor) but boundary_ok's last-access fold REJECTS -> gates the last-access pin on the REAL boundary_ok. */
    build(3u64)
    if verify() != 1u64 { return 14u64 }
    if boundary_ok() == 1u64 { return 15u64 }
    /* (O) forged trace OPENING: claim a wrong leaf -> Merkle REJECTS. */
    build(0u64)
    commit_col(0u64)
    let plen : u32 = merkle_proof_len_for(DOM as u32, 0u32)
    merkle_compute_proof((&TLEAF as u64), 4u64, merkle_pack_count_index(DOM as u32, 0u32), (&PRF as u64))
    TQ4[0u64] = TLEAF[0u64] ^ 1u8  TQ4[1u64] = TLEAF[1u64]  TQ4[2u64] = TLEAF[2u64]  TQ4[3u64] = TLEAF[3u64]
    if merkle_verify_proof((&TQ4 as u64), merkle_pack_verify_meta(4u32, 0u32, plen), (&PRF as u64), (&TROOT as u64)) != 0u8 { return 6u64 }
    /* (R) corrupted committed root: verify REJECTS. */
    build(0u64)
    FROOT[0u64] = FROOT[0u64] ^ 1u8
    if verify() == 1u64 { return 7u64 }
    return 99u64
}
