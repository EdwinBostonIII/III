/* zk_fused_prod.iii -- THE PRODUCTION FUSED zkVM: a real compute + memory + control program, ONE N=64 trace, verified
 * at production concrete soundness over GF(p^4).  Program: for i in 0..31 { STORE mem[i] = 7*i }; for i in 0..31 {
 * LOAD mem[i] } -- 64 VM steps.  All pillars on one trace:
 *   CONTROL: the step counter ic increments (next.ic = ic + 1).
 *   COMPUTE: a STORE writes 7*addr (is_store*(vp - 7*ap) = 0).
 *   MEMORY (dynamic): the (addr,val,iswrite) accesses are consistent -- the program order is a PERMUTATION of the
 *     (addr,time)-sorted order [grand product over enc = ap + beta*vp + beta^2*wp], READ-CONSISTENT [a same-addr LOAD
 *     returns the previous STORE's value, via an inverse-witness is-zero on the sorted address-difference], and SORTED
 *     [the sorted addresses are dense, d in {0,1}].
 * Verified by the GF(p^4) production verifier: the line-755 consistency CP[q]*Z_T==combine AND the D=256 GF(p^4) FRI
 * fold, both at 128 FS-derived correlated queries (~2^-86) for ALL 20 transition constraints; PLUS the permutation
 * boundary acp_k[last]==acs_k[last] under k=4 INDEPENDENT FS challenges (~(n/p)^4 ~2^-89, FS-bound -> grinding ~2^89).
 * Overall ~min(2^-86, 2^-89) = ~2^-86 = PRODUCTION on a real compute+memory+control program.
 *
 * Returns 99 iff: the HONEST execution verifies + boundaries hold; a FORGED LOAD value (read-consistency violated) is
 * REJECTED by the line-755; a FORGED program access (non-permutation) is REJECTED by the k=4 permutation boundary. */
module zk_fused_prod

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_perm_term(con: u32, kind: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_setup(start: u64, nv: u64) -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_beta() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r2() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r3() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r4() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r5() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r6() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_r7() -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha_ext4(con: u64, a: u64, b: u64) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp_ext4() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_ext4_a(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_ext4_b(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_combine_ext4_at(j: u64) -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cmb4_b() -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn ext2_add(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_sub(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_mul(a: u64, b: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn ext2_smul(s: u32, a: u64) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn e2pack(a0: u32, a1: u32) -> u64 from "zk_ext2.iii"
extern @abi(c-msvc-x64) fn keccak256_oneshot(msg_ptr: u64, msg_len: u64, out_ptr: u64) -> i32 from "keccak256.iii"
extern @abi(c-msvc-x64) fn sf_rou(n: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_add(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_sub(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"

const PRIME : u32 = 998244353u32
const NEG1  : u32 = 998244352u32
const NEG7  : u32 = 998244346u32
const DOM   : u64 = 256u64
const G4    : u64 = 4294967298u64

var OM   : [u32; 256]
var FA   : [u64; 512]    var FB : [u64; 512]
var RSA  : [u64; 8]      var RSB : [u64; 8]
var OFFS : [u64; 8]      var SIZES: [u64; 8]
var DIG  : [u8; 32]
var FRA  : [u64; 1]      var FRB : [u64; 1]
var CHA  : [u64; 1]      var CHB : [u64; 1]
var AP : [u32; 64]  var VP : [u32; 64]  var WP : [u32; 64]
var AS : [u32; 64]  var VS : [u32; 64]  var WS : [u32; 64]
var P1 : [u32; 64]  var S1 : [u32; 64]  var P2 : [u32; 64]  var S2 : [u32; 64]
var P3 : [u32; 64]  var S3 : [u32; 64]  var P4 : [u32; 64]  var S4 : [u32; 64]
var DM : [u32; 64]  var WV : [u32; 64]  var IZ : [u32; 64]  var RA : [u32; 64]

fn base_inv(v: u32) -> u32 {
    let mut r : u32 = 1u32  let mut b : u32 = v  let mut e : u32 = PRIME - 2u32
    while e > 0u32 { if (e & 1u32) == 1u32 { r = sf_mul(r, b) }  b = sf_mul(b, b)  e = e >> 1u32 }
    return r
}
fn inv0(d: u32) -> u32 { if d == 0u32 { return 0u32 } return base_inv(d) }
fn fill_om() {
    let w : u32 = sf_rou(DOM as u32)  OM[0] = 1u32
    let mut j : u64 = 1u64
    while j < DOM { OM[j] = sf_mul(OM[j - 1u64], w)  j = j + 1u64 }
}
fn rd4(off: u64) -> u32 {
    let p : *u8 = ((&DIG as u64) + off) as *u8
    let mut x : u32 = (p[0u64] as u32) | ((p[1u64] as u32) << 8u32) | ((p[2u64] as u32) << 16u32) | ((p[3u64] as u32) << 24u32)
    while x >= PRIME { x = x - PRIME }
    return x
}
fn challenge(off: u64, size: u64) {
    keccak256_oneshot((&FA as u64) + off * 8u64, size * 8u64, &DIG as u64)
    CHA[0] = e2pack(rd4(0u64), rd4(4u64))  CHB[0] = e2pack(rd4(8u64), rd4(12u64))
}
fn p4mul_a(ra: u64, rb: u64, fa: u64, fb: u64) -> u64 { return ext2_add(ext2_mul(ra, fa), ext2_mul(ext2_mul(rb, fb), G4)) }
fn p4mul_b(ra: u64, rb: u64, fa: u64, fb: u64) -> u64 { return ext2_add(ext2_mul(ra, fb), ext2_mul(rb, fa)) }
fn foldp4(loa: u64, lob: u64, hia: u64, hib: u64, ra: u64, rb: u64, x: u32) {
    let inv2 : u32 = base_inv(2u32)  let i2x : u32 = base_inv(sf_add(x, x))
    let fea : u64 = ext2_smul(inv2, ext2_add(loa, hia))  let feb : u64 = ext2_smul(inv2, ext2_add(lob, hib))
    let foa : u64 = ext2_smul(i2x, ext2_sub(loa, hia))   let fob : u64 = ext2_smul(i2x, ext2_sub(lob, hib))
    FRA[0] = ext2_add(fea, p4mul_a(ra, rb, foa, fob))
    FRB[0] = ext2_add(feb, p4mul_b(ra, rb, foa, fob))
}
/* one grand-product step factor (alpha_k - enc) with enc = a + beta*v + beta^2*w. */
fn encf(a: u32, v: u32, w: u32, alpha: u32, beta: u32, bsq: u32) -> u32 {
    let enc : u32 = sf_add(sf_add(a, sf_mul(beta, v)), sf_mul(bsq, w))
    return sf_sub(alpha, enc)
}
fn build_cp(forge: u64) {
    air_reset(19u32, 64u32)
    let mut k : u64 = 0u64
    while k < 32u64 {                                    /* program: 32 STOREs then 32 LOADs */
        AP[k] = k as u32  VP[k] = sf_mul(7u32, k as u32)  WP[k] = 1u32
        AP[32u64 + k] = k as u32  VP[32u64 + k] = sf_mul(7u32, k as u32)  WP[32u64 + k] = 0u32
        AS[2u64 * k] = k as u32  VS[2u64 * k] = sf_mul(7u32, k as u32)  WS[2u64 * k] = 1u32          /* sorted: STORE k */
        AS[2u64 * k + 1u64] = k as u32  VS[2u64 * k + 1u64] = sf_mul(7u32, k as u32)  WS[2u64 * k + 1u64] = 0u32 /* LOAD k */
        k = k + 1u64
    }
    if forge == 1u64 { VS[1] = 99u32 }                   /* read-consistency forge: sorted LOAD 0 returns 99, not the stored 0 */
    if forge == 2u64 { VP[32] = 99u32 }                  /* permutation forge: program LOAD 0 value tampered (multiset != sorted) */
    let mut i : u64 = 0u64
    while i < 64u64 {
        air_set_trace(i, 0u64, i as u32)  air_set_trace(i, 1u64, AP[i])  air_set_trace(i, 2u64, VP[i])  air_set_trace(i, 3u64, WP[i])
        air_set_trace(i, 4u64, AS[i])  air_set_trace(i, 5u64, VS[i])  air_set_trace(i, 6u64, WS[i])
        i = i + 1u64
    }
    /* commit the 6 access columns -> the 8 FS challenges.  alpha_k use kinds 1/4/5/10 = AIR_PERM_A/R2/R3/R6;
       beta_k use AIR_PERM_B/R4/R5/R7 (kinds 2,3 / 6,7 / 8,9 / 11,12 in air_combine_ext4). */
    let aa1 : u32 = air_perm_setup(1u64, 6u64)           /* aa1 = AIR_PERM_A (alpha1) */
    let b1b : u32 = air_perm_beta()  let b2b : u32 = air_perm_r4()  let b3b : u32 = air_perm_r5()  let b4b : u32 = air_perm_r7()
    let aa2 : u32 = air_perm_r2()  let aa3 : u32 = air_perm_r3()  let aa4 : u32 = air_perm_r6()
    P1[0] = 1u32  S1[0] = 1u32  P2[0] = 1u32  S2[0] = 1u32  P3[0] = 1u32  S3[0] = 1u32  P4[0] = 1u32  S4[0] = 1u32
    let q1 : u32 = sf_mul(b1b, b1b)  let q2 : u32 = sf_mul(b2b, b2b)  let q3 : u32 = sf_mul(b3b, b3b)  let q4 : u32 = sf_mul(b4b, b4b)
    i = 0u64
    while i < 63u64 {
        P1[i + 1u64] = sf_mul(P1[i], encf(AP[i], VP[i], WP[i], aa1, b1b, q1))  S1[i + 1u64] = sf_mul(S1[i], encf(AS[i], VS[i], WS[i], aa1, b1b, q1))
        P2[i + 1u64] = sf_mul(P2[i], encf(AP[i], VP[i], WP[i], aa2, b2b, q2))  S2[i + 1u64] = sf_mul(S2[i], encf(AS[i], VS[i], WS[i], aa2, b2b, q2))
        P3[i + 1u64] = sf_mul(P3[i], encf(AP[i], VP[i], WP[i], aa3, b3b, q3))  S3[i + 1u64] = sf_mul(S3[i], encf(AS[i], VS[i], WS[i], aa3, b3b, q3))
        P4[i + 1u64] = sf_mul(P4[i], encf(AP[i], VP[i], WP[i], aa4, b4b, q4))  S4[i + 1u64] = sf_mul(S4[i], encf(AS[i], VS[i], WS[i], aa4, b4b, q4))
        i = i + 1u64
    }
    i = 0u64
    while i < 64u64 {
        let inx : u64 = (i + 1u64) & 63u64
        DM[i] = sf_sub(AS[inx], AS[i])  WV[i] = inv0(DM[i])
        if DM[i] == 0u32 { IZ[i] = 1u32 } else { IZ[i] = 0u32 }
        RA[i] = sf_mul(IZ[i], sf_sub(VS[inx], VS[i]))
        i = i + 1u64
    }
    i = 0u64
    while i < 64u64 {
        air_set_trace(i, 7u64, P1[i])  air_set_trace(i, 8u64, S1[i])  air_set_trace(i, 9u64, P2[i])  air_set_trace(i, 10u64, S2[i])
        air_set_trace(i, 11u64, P3[i])  air_set_trace(i, 12u64, S3[i])  air_set_trace(i, 13u64, P4[i])  air_set_trace(i, 14u64, S4[i])
        air_set_trace(i, 15u64, DM[i])  air_set_trace(i, 16u64, WV[i])  air_set_trace(i, 17u64, IZ[i])  air_set_trace(i, 18u64, RA[i])
        i = i + 1u64
    }
    /* vars: cur 1=ic 2=ap 3=vp 4=wp 5=as 6=vs 7=ws 8=p1 9=s1 10=p2 11=s2 12=p3 13=s3 14=p4 15=s4 16=dm 17=wv 18=iz 19=ra ;
       next (col c -> 20+c): 20=ic 21=ap 22=vp 23=wp 24=as 25=vs 26=ws 27=p1 28=s1 29=p2 30=s2 31=p3 32=s3 33=p4 34=s4 35=dm 36=wv 37=iz 38=ra. */
    air_add_term(0u32, 1u32, 20u32, 0u32)  air_add_term(0u32, NEG1, 1u32, 0u32)  air_add_term(0u32, NEG1, 0u32, 0u32)        /* control: next.ic - ic - 1 */
    air_add_term(1u32, 1u32, 4u32, 3u32)   air_add_term(1u32, NEG7, 4u32, 2u32)                                              /* compute: is_store*(vp - 7*ap) = wp*vp - 7*wp*ap */
    air_add_term(2u32, 1u32, 7u32, 6u32)   air_add_term(2u32, NEG7, 7u32, 5u32)                                              /* sorted compute: ws*(vs - 7*as) */
    air_add_term(3u32, 1u32, 27u32, 0u32)  air_add_perm_term(3u32, 1u32, 8u32, 0u32)   air_add_term(3u32, 1u32, 8u32, 2u32)   air_add_perm_term(3u32, 2u32, 8u32, 3u32)   air_add_perm_term(3u32, 3u32, 8u32, 4u32)   /* p1 */
    air_add_term(4u32, 1u32, 28u32, 0u32)  air_add_perm_term(4u32, 1u32, 9u32, 0u32)   air_add_term(4u32, 1u32, 9u32, 5u32)   air_add_perm_term(4u32, 2u32, 9u32, 6u32)   air_add_perm_term(4u32, 3u32, 9u32, 7u32)   /* s1 */
    air_add_term(5u32, 1u32, 29u32, 0u32)  air_add_perm_term(5u32, 4u32, 10u32, 0u32)  air_add_term(5u32, 1u32, 10u32, 2u32)  air_add_perm_term(5u32, 6u32, 10u32, 3u32)  air_add_perm_term(5u32, 7u32, 10u32, 4u32)  /* p2 */
    air_add_term(6u32, 1u32, 30u32, 0u32)  air_add_perm_term(6u32, 4u32, 11u32, 0u32)  air_add_term(6u32, 1u32, 11u32, 5u32)  air_add_perm_term(6u32, 6u32, 11u32, 6u32)  air_add_perm_term(6u32, 7u32, 11u32, 7u32)  /* s2 */
    air_add_term(7u32, 1u32, 31u32, 0u32)  air_add_perm_term(7u32, 5u32, 12u32, 0u32)  air_add_term(7u32, 1u32, 12u32, 2u32)  air_add_perm_term(7u32, 8u32, 12u32, 3u32)  air_add_perm_term(7u32, 9u32, 12u32, 4u32)  /* p3 */
    air_add_term(8u32, 1u32, 32u32, 0u32)  air_add_perm_term(8u32, 5u32, 13u32, 0u32)  air_add_term(8u32, 1u32, 13u32, 5u32)  air_add_perm_term(8u32, 8u32, 13u32, 6u32)  air_add_perm_term(8u32, 9u32, 13u32, 7u32)  /* s3 */
    air_add_term(9u32, 1u32, 33u32, 0u32)  air_add_perm_term(9u32, 10u32, 14u32, 0u32) air_add_term(9u32, 1u32, 14u32, 2u32)  air_add_perm_term(9u32, 11u32, 14u32, 3u32) air_add_perm_term(9u32, 12u32, 14u32, 4u32) /* p4 */
    air_add_term(10u32, 1u32, 34u32, 0u32) air_add_perm_term(10u32, 10u32, 15u32, 0u32) air_add_term(10u32, 1u32, 15u32, 5u32) air_add_perm_term(10u32, 11u32, 15u32, 6u32) air_add_perm_term(10u32, 12u32, 15u32, 7u32) /* s4 */
    air_add_term(11u32, 1u32, 16u32, 0u32) air_add_term(11u32, NEG1, 24u32, 0u32)  air_add_term(11u32, 1u32, 5u32, 0u32)      /* dm - as_next + as */
    air_add_term(12u32, 1u32, 18u32, 16u32)                                                                                  /* iz*dm */
    air_add_term(13u32, 1u32, 18u32, 0u32) air_add_term(13u32, 1u32, 16u32, 17u32) air_add_term(13u32, NEG1, 0u32, 0u32)     /* iz + dm*wv - 1 */
    air_add_term(14u32, 1u32, 16u32, 16u32) air_add_term(14u32, NEG1, 16u32, 0u32)                                           /* dm in {0,1} (sortedness) */
    air_add_term(15u32, 1u32, 19u32, 0u32) air_add_term(15u32, NEG1, 18u32, 25u32) air_add_term(15u32, 1u32, 18u32, 6u32)    /* ra - iz*(vs_next - vs) */
    air_add_term(16u32, 1u32, 19u32, 0u32) air_add_term(16u32, NEG1, 19u32, 26u32)                                           /* ra*(1 - ws_next) = read-consistency */
    air_add_term(17u32, 1u32, 4u32, 4u32) air_add_term(17u32, NEG1, 4u32, 0u32)                                              /* wp bool */
    air_add_term(18u32, 1u32, 7u32, 7u32) air_add_term(18u32, NEG1, 7u32, 0u32)                                              /* ws bool */
    air_add_term(19u32, 1u32, 18u32, 18u32) air_add_term(19u32, NEG1, 18u32, 0u32)                                           /* iz bool */
    let mut c : u64 = 0u64
    while c < 20u64 { air_set_alpha_ext4(c, e2pack(13u32 + (c as u32), 9u32 + (c as u32)), e2pack(7u32 + (c as u32), 5u32 + (c as u32)))  c = c + 1u64 }
    air_build_lde()  air_build_cp_ext4()
    let mut j : u64 = 0u64
    while j < DOM { FA[j] = air_cp_ext4_a(j)  FB[j] = air_cp_ext4_b(j)  j = j + 1u64 }
}
fn boundaries_ok() -> u64 {   /* the permutation under k=4 independent challenges (~2^-89). */
    /* SEED PIN (grand-product Z(1)=1): each accumulator MUST start at 1 -- else a non-permutation rigs
     * S_k[0]=Pi_p_k*inv(Pi_s_k) so the final equality holds vacuously (DOCS/III-ZK-PERM-SEED-GAP.md). */
    if P1[0] != 1u32 { return 0u64 }  if S1[0] != 1u32 { return 0u64 }
    if P2[0] != 1u32 { return 0u64 }  if S2[0] != 1u32 { return 0u64 }
    if P3[0] != 1u32 { return 0u64 }  if S3[0] != 1u32 { return 0u64 }
    if P4[0] != 1u32 { return 0u64 }  if S4[0] != 1u32 { return 0u64 }
    if P1[63] != S1[63] { return 0u64 }
    if P2[63] != S2[63] { return 0u64 }
    if P3[63] != S3[63] { return 0u64 }
    if P4[63] != S4[63] { return 0u64 }
    return 1u64
}
fn build_layers() {
    let mut size : u64 = DOM  let mut off : u64 = 0u64  let mut i : u64 = 0u64
    while size > 4u64 {
        OFFS[i] = off  SIZES[i] = size  challenge(off, size)  RSA[i] = CHA[0]  RSB[i] = CHB[0]
        let half : u64 = size / 2u64  let noff : u64 = off + size  let str : u64 = DOM / size
        let mut j : u64 = 0u64
        while j < half {
            foldp4(FA[off + j], FB[off + j], FA[off + j + half], FB[off + j + half], RSA[i], RSB[i], OM[str * j])
            FA[noff + j] = FRA[0]  FB[noff + j] = FRB[0]
            j = j + 1u64
        }
        off = noff  size = half  i = i + 1u64
    }
    OFFS[i] = off  SIZES[i] = size
}
fn consistent_at(q: u64) -> u64 {
    if q == 252u64 { return 1u64 }
    let zt : u32 = sf_mul(sf_sub(OM[(64u64 * q) & 255u64], 1u32), base_inv(sf_sub(OM[q], OM[252])))
    let mba : u64 = air_combine_ext4_at(q)  let mbb : u64 = air_cmb4_b()
    if ext2_smul(zt, FA[q]) != mba { return 0u64 }
    if ext2_smul(zt, FB[q]) != mbb { return 0u64 }
    return 1u64
}
fn verify() -> u64 {
    let mut size : u64 = DOM  let mut off : u64 = 0u64  let mut i : u64 = 0u64
    while size > 4u64 {
        OFFS[i] = off  SIZES[i] = size  challenge(off, size)  RSA[i] = CHA[0]  RSB[i] = CHB[0]
        off = off + size  size = size / 2u64  i = i + 1u64
    }
    let foff : u64 = off  let nl : u64 = i
    let mut c : u64 = 1u64
    while c < 4u64 { if FA[foff + c] != FA[foff] { return 0u64 }  if FB[foff + c] != FB[foff] { return 0u64 }  c = c + 1u64 }
    keccak256_oneshot((&FA as u64) + foff * 8u64, 32u64, &DIG as u64)
    let mut batch : u64 = 0u64
    while batch < 4u64 {
        let mut kk : u64 = 0u64
        while kk < 32u64 {
            let pq : *u8 = ((&DIG as u64) + kk) as *u8
            let q0 : u64 = (pq[0u64] as u64) & (DOM - 1u64)
            if consistent_at(q0) != 1u64 { return 0u64 }
            let mut li : u64 = 0u64
            while li < nl {
                let s : u64 = SIZES[li]  let o : u64 = OFFS[li]  let half : u64 = s / 2u64
                let qm : u64 = q0 & (half - 1u64)
                foldp4(FA[o + qm], FB[o + qm], FA[o + qm + half], FB[o + qm + half], RSA[li], RSB[li], OM[(DOM / s) * qm])
                let no : u64 = OFFS[li + 1u64]
                if FA[no + qm] != FRA[0] { return 0u64 }
                if FB[no + qm] != FRB[0] { return 0u64 }
                li = li + 1u64
            }
            kk = kk + 1u64
        }
        keccak256_oneshot(&DIG as u64, 32u64, &DIG as u64)
        batch = batch + 1u64
    }
    return 1u64
}

fn main() -> u64 {
    fill_om()
    build_cp(0u64)  build_layers()
    if verify() != 1u64 { return 1u64 }                  /* honest: all 20 transition constraints verify */
    if boundaries_ok() != 1u64 { return 2u64 }           /* honest: the k=4 permutation holds */
    build_cp(1u64)  build_layers()                       /* forge: a LOAD returns the wrong value */
    if verify() == 1u64 { return 3u64 }                  /* -> read-consistency violated -> line-755 REJECTS */
    build_cp(2u64)  build_layers()                       /* forge: a program access tampered (non-permutation) */
    if verify() != 1u64 { return 5u64 }                  /* its transitions still hold (load value unconstrained by compute) */
    if boundaries_ok() == 1u64 { return 4u64 }           /* -> the k=4 permutation boundary REJECTS */
    return 99u64
}
