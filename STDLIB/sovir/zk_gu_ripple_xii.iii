/* zk_gu_ripple_xii.iii -- Omega4/F2: the EIDOS ripple, ONE computation proven in TWO views, bound on one object.
 *
 * The audit's F2 was: Omega3 canonicalised a HAND-BUILT XII term unrelated to R0.  This closes it -- the XII term is
 * DERIVED FROM THE RIPPLE'S OWN EVENT STREAM (the same geometry eidos_ripple_r0.iii folds into SVIR):
 *   - each ripple edge over the canonical geometry is an XII node: a FLAT edge (V_NONE, "no ripple") -> K12_NULL (the
 *     THEN identity); a real ripple edge (verb in {BELOW,REFLECT}) -> K12 carrying the content-address enc =
 *     verb*65536 + a*256 + b.  The edges are right-folded into one F.THEN chain.
 *   - XII canonicalisation provably DROPS every flat edge (R021/R022: THEN(NULL,a)->a, THEN(a,NULL)->a) -- the ripple's
 *     "a flat edge emits nothing" stated as a CHECKABLE proof (omnia/xii_proof: sealed-rule steps, mhash-chained,
 *     independently re-checked by xii_proof_check).  The canonical form is the THEN-chain of the real events, in order.
 *   - THE BINDING (one object, two views): folding the canonical form's enc subforms (state' = (BASE*state+enc) % MODP)
 *     yields EXACTLY the value eidos_ripple_r0 folds in SVIR (and zk_fused-style attests) = GOLDEN 675673294.
 *
 * So the SAME ripple computation is proven in the XII INTENT algebra (canonicalisation + proof-carrying) and the SVIR
 * EXECUTION layer (the R0/committed-zk pillar), and the two agree on the answer.  Returns 99 iff: the XII proof
 * validates (independent re-check rc 0), the canonical fold == GOLDEN (the cross-view binding), AND a tampered proof
 * step is REJECTED (the proof has teeth). */
module zk_gu_ripple_xii

extern @abi(c-msvc-x64) fn xii_term_arena_reset() -> i32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_basis(kind: u8, sub: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_make_fusion2(kind: u8, a: u32, b: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_kind(idx: u32) -> u8 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_subform(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_a(idx: u32) -> u32 from "xii_term.iii"
extern @abi(c-msvc-x64) fn xii_term_get_child_b(idx: u32) -> u32 from "xii_term.iii"

extern @abi(c-msvc-x64) fn xii_proof_prove(root: u32) -> u32 from "xii_proof.iii"
extern @abi(c-msvc-x64) fn xii_proof_count() -> u32 from "xii_proof.iii"
extern @abi(c-msvc-x64) fn xii_proof_set_rid(step: u32, rid: u32) -> i32 from "xii_proof.iii"
extern @abi(c-msvc-x64) fn xii_proof_check(root: u32) -> u32 from "xii_proof_check.iii"
extern @abi(c-msvc-x64) fn xad_admit() -> u32 from "xii_admission.iii"

const K12     : u8  = 11u8
const FTHEN   : u8  = 19u8
const NULLF   : u32 = 0xFFFFFFFFu32     /* K12_NULL ground form (the THEN identity) */
const BASE    : u64 = 257u64
const MODP    : u64 = 1000000007u64
const NEV     : u32 = 16u32
const GOLDEN  : u64 = 675673294u64      /* eidos_ripple_r0's SVIR fold over the same 16 events */
const VNONE   : u32 = 2u32

var RANK  : [u8; 16]
var EDGES : [u32; 512]
var NE    : [u32; 1]

fn init_ranks() {
    RANK[0] = 0u8   RANK[1] = 1u8   RANK[2] = 2u8   RANK[3] = 3u8
    RANK[4] = 4u8   RANK[5] = 5u8   RANK[6] = 0u8   RANK[7] = 6u8
    RANK[8] = 0u8   RANK[9] = 0u8   RANK[10] = 0u8  RANK[11] = 0u8
    RANK[12] = 0u8  RANK[13] = 0u8  RANK[14] = 0u8  RANK[15] = 0u8
}
fn direction(hf: u32, ht: u32) -> u32 {
    let rf : u32 = RANK[hf] as u32
    let rt : u32 = RANK[ht] as u32
    if rt > rf { return 0u32 }
    if rt < rf { return 1u32 }
    return VNONE
}

/* build the F.THEN chain over the canonical ripple geometry: flats -> K12_NULL, real edges -> K12(enc).  Right-folded.
 * Returns the chain root.  (Deterministic: same edges every call.) */
fn build_chain() -> u32 {
    let mut emitted : u32 = 0u32
    let mut h : u32 = 0u32
    let mut n : u32 = 0u32
    while emitted < NEV {
        if h >= 256u32 { h = 256u32  emitted = NEV }
        else {
            let hf : u32 = h & 15u32
            let ht : u32 = ((h >> 4u32) + 1u32) & 15u32
            let verb : u32 = direction(hf, ht)
            if verb < VNONE {
                let a : u32 = emitted + 1u32
                let b : u32 = emitted + 2u32
                let enc : u32 = verb * 65536u32 + a * 256u32 + b
                EDGES[n as u64] = xii_term_make_basis(K12, enc)
                emitted = emitted + 1u32
            } else {
                EDGES[n as u64] = xii_term_make_basis(K12, NULLF)   /* flat = no ripple = THEN identity */
            }
            n = n + 1u32
            h = h + 1u32
        }
    }
    NE[0] = n
    /* right-fold: acc = EDGES[n-1]; acc = THEN(EDGES[i], acc) for i = n-2..0 */
    let mut acc : u32 = EDGES[(n - 1u32) as u64]
    let mut i : u32 = n - 1u32
    while i > 0u32 {
        i = i - 1u32
        acc = xii_term_make_fusion2(FTHEN, EDGES[i as u64], acc)
    }
    return acc
}

/* fold the canonical form's K12 enc subforms in order: state' = (BASE*state + enc) % MODP.  The canonical form is a
 * right-assoc F.THEN chain of K12(enc) nodes (flats dropped). */
fn fold_canon(root: u32) -> u64 {
    let mut state : u64 = 0u64
    let mut cur : u32 = root
    let mut guard : u32 = 0u32
    while guard < 1000u32 {
        guard = guard + 1u32
        if xii_term_get_kind(cur) == FTHEN {
            let e : u32 = xii_term_get_child_a(cur)
            state = (BASE * state + (xii_term_get_subform(e) as u64)) % MODP
            cur = xii_term_get_child_b(cur)
        } else {
            /* the last element (a bare K12). */
            state = (BASE * state + (xii_term_get_subform(cur) as u64)) % MODP
            return state
        }
    }
    return state
}

fn main() -> u64 {
    if xad_admit() != 1u32 { return 8u64 }            /* manifest-admitted rule set (Omega3-T3) */
    init_ranks()
    /* (P) build the ripple-derived XII term, prove its canonicalisation, fold the canonical form. */
    xii_term_arena_reset()
    let root : u32 = build_chain()
    let canon : u32 = xii_proof_prove(root)
    if xii_proof_count() == 0u32 { return 1u64 }      /* the flats must produce at least one drop step */
    let f : u64 = fold_canon(canon)
    if f != GOLDEN { return 2u64 }                    /* THE BINDING: XII canonical fold == R0's SVIR fold */
    /* (C) the INDEPENDENT re-checker accepts the proof (rebuild T0, replay the sealed steps). */
    xii_term_arena_reset()
    let root2 : u32 = build_chain()
    if xii_proof_check(root2) != 0u32 { return 3u64 }
    /* (N) the proof has teeth: an out-of-manifest rule on step 0 is REJECTED. */
    xii_term_arena_reset()  xii_proof_prove(build_chain())
    xii_proof_set_rid(0u32, 200u32)
    xii_term_arena_reset()
    if xii_proof_check(build_chain()) == 0u32 { return 4u64 }
    return 99u64
}
