/* zk_iiisv_attest.iii -- THE Omega.e CLOSURE: a SOUND proof of the EXECUTION OF iiisv's REAL SVIR BYTECODE.
 *
 * Unlike zk_svir_stack (a hand-written opcode sequence), this PARSES the actual bytecode iiisv emitted for a real .iii
 * program -- read from gen_svir's svir_ptr()/svir_len() -- and proves THAT execution.  The attested opcodes come from
 * the COMPILER, not the prover.  Pipeline: iiisv f.iii -> gen_svir.iii (var SVIR + svir_ptr/svir_len) -> this gadget
 * links it, reads the bytes, decodes the SVIR ISA (CONST=0x01 + 8-byte LE immediate, MUL=0x22, ADD=0x20, RETURN=0x60),
 * maps each opcode to the sound 2-slot stack AIR (zk_svir_stack), interprets, and proves with air_stark_prove/verify.
 *
 * The program is  fn f() -> i64 { return 5 * 257 + 7; }  -- iiisv lowers it to  CONST 5, CONST 257, MUL, CONST 7, ADD,
 * RETURN.  Cross-check (a second oracle): the proven stack top must equal 1292 = 5*257+7 (so iiisv computed it right).
 *
 * Returns 99 iff: the parse yields the expected opcodes, the proven result is 1292, the honest execution VERIFIES, and
 * a forged stack-top is REJECTED BY THE MATH.  This is Omega.e for a straight-line program: the compiler's own SVIR,
 * parsed and soundly attested by a witness-free verifier.  Residual: LOCAL_GET/SET (variables) + binding the opcode
 * columns to the bytecode bytes (here the parse fills them directly from the real bytes -- a strong binding already). */
module zk_iiisv_attest

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_get_trace(row: u64, col: u64) -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_boundary_reset() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_boundary(col: u32, row: u32, value: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_prove() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_verify() -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_add(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
/* iiisv's emitted module (gen_svir.iii): the real SVIR bytecode buffer. */
extern @abi(c-msvc-x64) fn svir_ptr() -> u64 from "gen_svir.iii"
extern @abi(c-msvc-x64) fn svir_len() -> u64 from "gen_svir.iii"

const NEG1 : u32 = 998244352u32

/* the AIR program columns, FILLED BY PARSING iiisv's bytecode (not hand-authored). */
var ISC : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
var ISM : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
var ISA : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
var ARG : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
var NOPS : [u32; 1] = [0u32]   /* number of real (non-pad) opcodes parsed */

fn rdbyte(base: u64, off: u64) -> u32 {
    let p : *u8 = (base + off) as *u8
    return p[0u64] as u32
}

/* parse iiisv's SVIR body into the AIR program.  Header = [FN_NF, params, 1, blen_lo, blen_hi] (5 bytes). */
fn parse() {
    let base : u64 = svir_ptr()
    let len  : u64 = svir_len()
    let mut p : u64 = 5u64
    let mut row : u64 = 0u64
    let mut nops : u32 = 0u32
    while row < 8u64 {
        let past : u32 = 0u32
        if p >= len {
            /* past the body: pad with ADD-0 (a nop preserving the stack top). */
            ISC[row] = 0u32  ISM[row] = 0u32  ISA[row] = 1u32  ARG[row] = 0u32
            row = row + 1u64
        } else {
            let op : u32 = rdbyte(base, p)
            if op == 1u32 {                                  /* CONST 0x01 + 8-byte LE immediate */
                let b0 : u32 = rdbyte(base, p + 1u64)
                let b1 : u32 = rdbyte(base, p + 2u64)
                let b2 : u32 = rdbyte(base, p + 3u64)
                let b3 : u32 = rdbyte(base, p + 4u64)
                ISC[row] = 1u32  ISM[row] = 0u32  ISA[row] = 0u32
                ARG[row] = b0 + b1*256u32 + b2*65536u32 + b3*16777216u32
                p = p + 9u64  row = row + 1u64  nops = nops + 1u32
            } else {
                if op == 34u32 {                             /* MUL 0x22 */
                    ISC[row] = 0u32  ISM[row] = 1u32  ISA[row] = 0u32  ARG[row] = 0u32
                    p = p + 1u64  row = row + 1u64  nops = nops + 1u32
                } else {
                    if op == 32u32 {                         /* ADD 0x20 */
                        ISC[row] = 0u32  ISM[row] = 0u32  ISA[row] = 1u32  ARG[row] = 0u32
                        p = p + 1u64  row = row + 1u64  nops = nops + 1u32
                    } else {                                  /* RETURN 0x60 / trailing -> treat as nop, keep padding */
                        ISC[row] = 0u32  ISM[row] = 0u32  ISA[row] = 1u32  ARG[row] = 0u32
                        p = p + 1u64  row = row + 1u64
                    }
                }
            }
        }
    }
    NOPS[0] = nops
}

fn setup() {
    air_reset(7u32, 8u32)
    air_boundary_reset()
    air_add_boundary(0u32, 0u32, 0u32)               /* s0_0 = 0 */
    air_add_boundary(1u32, 0u32, 0u32)               /* s1_0 = 0 */
    air_add_term(0u32, 1u32, 3u32, 0u32)             /* con0: p - s0*s1 */
    air_add_term(0u32, NEG1, 1u32, 2u32)
    air_add_term(1u32, 1u32, 9u32, 0u32)             /* con1: next.s1 - is_const*arg - is_mul*p - is_add*s0 - is_add*s1 */
    air_add_term(1u32, NEG1, 4u32, 7u32)
    air_add_term(1u32, NEG1, 5u32, 3u32)
    air_add_term(1u32, NEG1, 6u32, 1u32)
    air_add_term(1u32, NEG1, 6u32, 2u32)
    air_add_term(2u32, 1u32, 8u32, 0u32)             /* con2: next.s0 - is_const*s1 */
    air_add_term(2u32, NEG1, 4u32, 2u32)
    air_add_term(3u32, 1u32, 4u32, 0u32)             /* con3: one-hot */
    air_add_term(3u32, 1u32, 5u32, 0u32)
    air_add_term(3u32, 1u32, 6u32, 0u32)
    air_add_term(3u32, NEG1, 0u32, 0u32)
    air_add_term(4u32, 1u32, 4u32, 4u32)  air_add_term(4u32, NEG1, 4u32, 0u32)   /* booleans */
    air_add_term(5u32, 1u32, 5u32, 5u32)  air_add_term(5u32, NEG1, 5u32, 0u32)
    air_add_term(6u32, 1u32, 6u32, 6u32)  air_add_term(6u32, NEG1, 6u32, 0u32)
    air_set_alpha(0u64, 7u32)   air_set_alpha(1u64, 13u32)  air_set_alpha(2u64, 17u32)
    air_set_alpha(3u64, 19u32)  air_set_alpha(4u64, 23u32)  air_set_alpha(5u64, 29u32)  air_set_alpha(6u64, 31u32)
}

fn fill() {
    let mut s0 : u32 = 0u32
    let mut s1 : u32 = 0u32
    let mut i : u64 = 0u64
    while i < 8u64 {
        let p : u32 = sf_mul(s0, s1)
        air_set_trace(i, 0u64, s0)  air_set_trace(i, 1u64, s1)  air_set_trace(i, 2u64, p)
        air_set_trace(i, 3u64, ISC[i])  air_set_trace(i, 4u64, ISM[i])  air_set_trace(i, 5u64, ISA[i])  air_set_trace(i, 6u64, ARG[i])
        let opres : u32 = sf_add(sf_add(sf_mul(ISC[i], ARG[i]), sf_mul(ISM[i], p)), sf_mul(ISA[i], sf_add(s0, s1)))
        let ns0 : u32 = sf_mul(ISC[i], s1)
        s0 = ns0
        s1 = opres
        i = i + 1u64
    }
}

fn main() -> u64 {
    parse()                                            /* fill the AIR program from iiisv's REAL bytecode */
    if NOPS[0] != 5u32 { return 6u64 }                 /* expect 5 compute opcodes: CONST,CONST,MUL,CONST,ADD */
    setup()  fill()
    /* cross-check (second oracle): iiisv's bytecode must compute 5*257+7 = 1292 (stack top after the ADD at row 4). */
    if air_get_trace(5u64, 1u64) != 1292u32 { return 5u64 }
    /* (1) HONEST: prove the execution of iiisv's bytecode; the sound verifier ACCEPTS. */
    air_stark_prove()
    if air_stark_verify() != 0u64 { return 1u64 }
    /* (2) FORGED: tamper the stack top s1_3 -> the MUL transition is violated -> REJECT. */
    setup()  fill()  air_set_trace(3u64, 1u64, 99999u32)  air_stark_prove()
    if air_stark_verify() == 0u64 { return 2u64 }
    /* (3) re-prove honest. */
    setup()  fill()  air_stark_prove()
    if air_stark_verify() != 0u64 { return 4u64 }
    return 99u64
}
