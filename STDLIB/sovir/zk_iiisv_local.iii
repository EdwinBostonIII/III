/* zk_iiisv_local.iii -- Omega.e for a program WITH A VARIABLE: a SOUND proof of iiisv's real bytecode for a .iii
 * program that uses a LOCAL (let-binding).  Extends zk_iiisv_attest with LOCAL_GET (0x10) / LOCAL_SET (0x11).
 *
 * Program:  fn f() -> i64 { let a : i64 = 5 * 257; return a + 7; }  -- iiisv lowers it to
 *   CONST 5, CONST 257, MUL, LSET 0, LGET 0, CONST 7, ADD, RETURN   (+ 0x72 statement separators it skips).
 * The local `a` is a REGISTER-FILE column L: LSET 0 writes L = stack-top; LGET 0 pushes L; L is carried row-to-row
 * otherwise (con_L).  A FIXED local needs no permutation (read-consistency is the column itself) -- it is
 * TRANSITION-ONLY, sound today.  (The grand-product permutation, now also sound, is for DYNAMIC memory / arrays.)
 *
 * 2-slot stack [s0,s1] + local L + product-aux p + 5 one-hot opcode selectors (CONST/MUL/ADD/LGET/LSET) + arg.
 * W=10, 10 constraints (needs AIR_CMAX>=10, raised to 16).  The program columns are FILLED BY PARSING iiisv's real
 * bytecode.  Returns 99 iff: 7 opcodes parsed, the result (stack top) is 1292 = 5*257+7, the honest execution
 * VERIFIES (witness-free), and a forged local L is REJECTED BY THE MATH (proving the LOCAL read-consistency is sound). */
module zk_iiisv_local

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_get_trace(row: u64, col: u64) -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_boundary_reset() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_boundary(col: u32, row: u32, value: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_prove() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_verify() -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_add(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_sub(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn svir_ptr() -> u64 from "gen_svir.iii"
extern @abi(c-msvc-x64) fn svir_len() -> u64 from "gen_svir.iii"

const NEG1 : u32 = 998244352u32

var ISC : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
var ISM : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
var ISA : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
var ILG : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
var ILS : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
var ARG : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
var NOPS : [u32; 1] = [0u32]

fn rdbyte(base: u64, off: u64) -> u32 { let q : *u8 = (base + off) as *u8  return q[0u64] as u32 }

fn parse() {
    let base : u64 = svir_ptr()
    let len  : u64 = svir_len()
    let mut p : u64 = 5u64
    let mut row : u64 = 0u64
    let mut nops : u32 = 0u32
    while row < 8u64 {
        if p >= len {
            ISC[row]=0u32 ISM[row]=0u32 ISA[row]=1u32 ILG[row]=0u32 ILS[row]=0u32 ARG[row]=0u32   /* pad: ADD-0 nop */
            row = row + 1u64
        } else {
            let op : u32 = rdbyte(base, p)
            if op == 1u32 {                                  /* CONST + 8-byte LE imm */
                let b0 : u32 = rdbyte(base, p + 1u64)  let b1 : u32 = rdbyte(base, p + 2u64)
                let b2 : u32 = rdbyte(base, p + 3u64)  let b3 : u32 = rdbyte(base, p + 4u64)
                ISC[row]=1u32 ISM[row]=0u32 ISA[row]=0u32 ILG[row]=0u32 ILS[row]=0u32
                ARG[row] = b0 + b1*256u32 + b2*65536u32 + b3*16777216u32
                p = p + 9u64  row = row + 1u64  nops = nops + 1u32
            } else { if op == 34u32 {                        /* MUL */
                ISC[row]=0u32 ISM[row]=1u32 ISA[row]=0u32 ILG[row]=0u32 ILS[row]=0u32 ARG[row]=0u32
                p = p + 1u64  row = row + 1u64  nops = nops + 1u32
            } else { if op == 32u32 {                        /* ADD */
                ISC[row]=0u32 ISM[row]=0u32 ISA[row]=1u32 ILG[row]=0u32 ILS[row]=0u32 ARG[row]=0u32
                p = p + 1u64  row = row + 1u64  nops = nops + 1u32
            } else { if op == 16u32 {                        /* LOCAL_GET 0x10 + 1-byte index */
                ISC[row]=0u32 ISM[row]=0u32 ISA[row]=0u32 ILG[row]=1u32 ILS[row]=0u32 ARG[row]=0u32
                p = p + 2u64  row = row + 1u64  nops = nops + 1u32
            } else { if op == 17u32 {                        /* LOCAL_SET 0x11 + 1-byte index */
                ISC[row]=0u32 ISM[row]=0u32 ISA[row]=0u32 ILG[row]=0u32 ILS[row]=1u32 ARG[row]=0u32
                p = p + 2u64  row = row + 1u64  nops = nops + 1u32
            } else {                                          /* 0x72 sep / RETURN 0x60 / other -> skip, no row */
                p = p + 1u64
            } } } } }
        }
    }
    NOPS[0] = nops
}

fn setup() {
    air_reset(10u32, 8u32)
    air_boundary_reset()
    air_add_boundary(0u32, 0u32, 0u32)  air_add_boundary(1u32, 0u32, 0u32)  air_add_boundary(2u32, 0u32, 0u32)  /* s0,s1,L = 0 */
    /* vars: 0=1 ; cur 1=s0 2=s1 3=L 4=p 5=isc 6=ism 7=isa 8=ilg 9=ils 10=arg ; next 11=s0 12=s1 13=L 14=p 15.. */
    air_add_term(0u32, 1u32, 4u32, 0u32)   air_add_term(0u32, NEG1, 1u32, 2u32)                       /* con0: p - s0*s1 */
    air_add_term(1u32, 1u32, 12u32, 0u32)                                                             /* con1: next.s1 - ... */
    air_add_term(1u32, NEG1, 5u32, 10u32)  air_add_term(1u32, NEG1, 6u32, 4u32)
    air_add_term(1u32, NEG1, 7u32, 1u32)   air_add_term(1u32, NEG1, 7u32, 2u32)
    air_add_term(1u32, NEG1, 8u32, 3u32)   air_add_term(1u32, NEG1, 9u32, 1u32)
    air_add_term(2u32, 1u32, 11u32, 0u32)  air_add_term(2u32, NEG1, 5u32, 2u32)  air_add_term(2u32, NEG1, 8u32, 2u32)  /* con2: next.s0 - (isc+ilg)*s1 */
    air_add_term(3u32, 1u32, 13u32, 0u32)  air_add_term(3u32, NEG1, 3u32, 0u32)
    air_add_term(3u32, NEG1, 9u32, 2u32)   air_add_term(3u32, 1u32, 9u32, 3u32)                       /* con3: next.L - L - ils*s1 + ils*L */
    air_add_term(4u32, 1u32, 5u32, 0u32)  air_add_term(4u32, 1u32, 6u32, 0u32)  air_add_term(4u32, 1u32, 7u32, 0u32)
    air_add_term(4u32, 1u32, 8u32, 0u32)  air_add_term(4u32, 1u32, 9u32, 0u32)  air_add_term(4u32, NEG1, 0u32, 0u32) /* con4: one-hot */
    air_add_term(5u32, 1u32, 5u32, 5u32)  air_add_term(5u32, NEG1, 5u32, 0u32)
    air_add_term(6u32, 1u32, 6u32, 6u32)  air_add_term(6u32, NEG1, 6u32, 0u32)
    air_add_term(7u32, 1u32, 7u32, 7u32)  air_add_term(7u32, NEG1, 7u32, 0u32)
    air_add_term(8u32, 1u32, 8u32, 8u32)  air_add_term(8u32, NEG1, 8u32, 0u32)
    air_add_term(9u32, 1u32, 9u32, 9u32)  air_add_term(9u32, NEG1, 9u32, 0u32)                        /* con5..9: booleans */
    air_set_alpha(0u64, 7u32)   air_set_alpha(1u64, 13u32)  air_set_alpha(2u64, 17u32)  air_set_alpha(3u64, 19u32)
    air_set_alpha(4u64, 23u32)  air_set_alpha(5u64, 29u32)  air_set_alpha(6u64, 31u32)  air_set_alpha(7u64, 37u32)
    air_set_alpha(8u64, 41u32)  air_set_alpha(9u64, 43u32)
}

fn fill() {
    let mut s0 : u32 = 0u32  let mut s1 : u32 = 0u32  let mut L : u32 = 0u32  let mut i : u64 = 0u64
    while i < 8u64 {
        let p : u32 = sf_mul(s0, s1)
        air_set_trace(i, 0u64, s0)  air_set_trace(i, 1u64, s1)  air_set_trace(i, 2u64, L)  air_set_trace(i, 3u64, p)
        air_set_trace(i, 4u64, ISC[i])  air_set_trace(i, 5u64, ISM[i])  air_set_trace(i, 6u64, ISA[i])
        air_set_trace(i, 7u64, ILG[i])  air_set_trace(i, 8u64, ILS[i])  air_set_trace(i, 9u64, ARG[i])
        let ns1 : u32 = sf_add(sf_add(sf_add(sf_add(sf_mul(ISC[i], ARG[i]), sf_mul(ISM[i], p)), sf_mul(ISA[i], sf_add(s0, s1))), sf_mul(ILG[i], L)), sf_mul(ILS[i], s0))
        let ns0 : u32 = sf_add(sf_mul(ISC[i], s1), sf_mul(ILG[i], s1))
        let nL : u32 = sf_add(L, sf_mul(ILS[i], sf_sub(s1, L)))
        s0 = ns0  s1 = ns1  L = nL
        i = i + 1u64
    }
}

fn main() -> u64 {
    parse()
    if NOPS[0] != 7u32 { return 6u64 }                 /* CONST,CONST,MUL,LSET,LGET,CONST,ADD */
    setup()  fill()
    if air_get_trace(7u64, 1u64) != 1292u32 { return 5u64 }   /* cross-check: a (=5*257=1285) read back, +7 = 1292 */
    air_stark_prove()
    if air_stark_verify() != 0u64 { return 1u64 }
    /* FORGED LOCAL: tamper L at row 4 (the LGET row) -> the LGET reads a bad L -> the s1 transition is violated -> REJECT. */
    setup()  fill()  air_set_trace(4u64, 2u64, 99999u32)  air_stark_prove()
    if air_stark_verify() == 0u64 { return 2u64 }
    setup()  fill()  air_stark_prove()
    if air_stark_verify() != 0u64 { return 4u64 }
    return 99u64
}
