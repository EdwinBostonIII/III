/* zk_perm_malicious.iii -- the MALICIOUS-PROVER oracle for permutation soundness, now against the FS-BOUND alpha.
 *
 * The adversary holds a NON-permutation: program order {3,7,5,9}, forged "sorted" {3,3,5,10} (these collide at the
 * alpha=11 the OLD baked-alpha verifier could not reject).  It builds the grand-product accumulators with its OWN
 * chosen alpha'=11 (so both products reach 384 and the boundary closes).  But the constraint's -alpha*acc term is now
 * an air_add_perm_term, so the verifier uses AIR_PERM_A = Fiat-Shamir-DERIVED from the committed ACCESS-column roots
 * (air_perm_setup, columns 0=vO and 1=vS) -- NOT the prover's 11.  The honest alpha != 11 (with overwhelming
 * probability), so the transitions next.acc = acc*(alpha_fs - v) do NOT hold for products built at 11 -> REJECT.
 *
 * Layout (access columns FIRST so air_perm_setup commits them): 0=vO 1=vS 2=aO 3=aS.
 * Returns 50 if air_stark_verify ACCEPTS (still unsound), 99 if it REJECTS (the FS-bind works -- a prover-chosen alpha
 * is defeated; ZK-MEMORY/ZK-FUSED can be re-made sound by the same air_perm_setup + air_add_perm_term). */
module zk_perm_malicious

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_perm_term(con: u32, kind: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_perm_setup(start: u64, nv: u64) -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_boundary_reset() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_boundary(col: u32, row: u32, value: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_prove() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_verify() -> u64 from "zk_air.iii"

var VO : [u32; 8] = [3u32, 7u32, 5u32, 9u32, 10u32, 10u32, 10u32, 10u32]
var VS : [u32; 8] = [3u32, 3u32, 5u32, 10u32, 10u32, 10u32, 10u32, 10u32]   /* NON-permutation, collides at alpha'=11 */
var AO : [u32; 8] = [1u32, 8u32, 32u32, 192u32, 384u32, 384u32, 384u32, 384u32]    /* products at the prover's alpha'=11 */
var AS : [u32; 8] = [1u32, 8u32, 64u32, 384u32, 384u32, 384u32, 384u32, 384u32]

fn main() -> u64 {
    air_reset(4u32, 8u32)
    air_boundary_reset()
    /* PHASE 1: set the ACCESS columns (vO,vS) and let the STARK commit them + derive alpha (the prover cannot choose it). */
    let mut i : u64 = 0u64
    while i < 8u64 { air_set_trace(i, 0u64, VO[i])  air_set_trace(i, 1u64, VS[i])  i = i + 1u64 }
    air_perm_setup(0u64, 2u64)
    /* PHASE 2 (MALICIOUS): build the product columns with the prover's OWN alpha'=11 (ignoring the derived alpha). */
    i = 0u64
    while i < 8u64 { air_set_trace(i, 2u64, AO[i])  air_set_trace(i, 3u64, AS[i])  i = i + 1u64 }
    /* vars: 0=1 ; cur 1=vO 2=vS 3=aO 4=aS ; next 5=vO 6=vS 7=aO 8=aS.  -alpha*acc is now an FS-BOUND perm term. */
    air_add_term(0u32, 1u32, 7u32, 0u32)  air_add_perm_term(0u32, 1u32, 3u32, 0u32)  air_add_term(0u32, 1u32, 3u32, 1u32) /* con0: next.aO - alpha*aO + aO*vO */
    air_add_term(1u32, 1u32, 8u32, 0u32)  air_add_perm_term(1u32, 1u32, 4u32, 0u32)  air_add_term(1u32, 1u32, 4u32, 2u32) /* con1: next.aS - alpha*aS + aS*vS */
    air_set_alpha(0u64, 3u32)  air_set_alpha(1u64, 5u32)
    air_add_boundary(2u32, 0u32, 1u32)  air_add_boundary(3u32, 0u32, 1u32)
    air_add_boundary(2u32, 4u32, 384u32)  air_add_boundary(3u32, 4u32, 384u32)
    air_stark_prove()
    if air_stark_verify() == 0u64 { return 50u64 }   /* ACCEPTED -> still unsound */
    return 99u64                                       /* REJECTED -> FS-bound alpha defeats the prover-chosen challenge */
}
