/* zk_svir_add.iii -- the FOUNDATIONAL zkVM brick: arithmetize the SVIR 64-bit ADD opcode over the 30-bit STARK
 * field GF(998244353) via 14-bit LIMB DECOMPOSITION + a CARRY CHAIN, proven by III's general zk_air.
 *
 * The bridge the user named: SVIR is i64, zk_air's field is ~2^30, so a 64-bit add cannot be one field element.
 * Decompose a,b,c into 5 limbs of <=14 bits (a = sum a_k * 2^{14k}); lay the chain one limb per ROW (W=4 cols:
 * a_k, b_k, c_k, carry_in_k), N=8 (5 limb-rows + 3 zero-padding rows, N a power of two for the NTT).  Two
 * degree-<=2 AIR constraints:
 *   (con0, limb-add, the CARRY CHAIN): next.carry_in * 2^14 - cur.a - cur.b - cur.carry_in + cur.c == 0
 *       -- i.e. c_k = (a_k + b_k + carry_in_k) mod 2^14 and carry_in_{k+1} = (a_k+b_k+carry_in_k) >> 14, for
 *          every limb (rows 0..N-2 are transition-checked; row4->row5 with next.carry_in=0 asserts NO overflow).
 *   (con1, carry boolean): cur.carry_in^2 - cur.carry_in == 0  (each carry is 0/1).
 * a=0x123456789ABCDEF0, b=0x0FEDCBA987654321, c=a+b (no i64 overflow), carries [0,0,1,1,1].
 *
 * Returns 99 iff: the honest limb trace satisfies the AIR (air_constraints_hold==1 + CP consistent) AND a
 * TAMPERED result limb is rejected (air_constraints_hold==0).  This arithmetizes ONE SVIR opcode (ADD) over the
 * field via limbs -- the foundational unit of a SVIR zkVM.  HONEST RESIDUAL: soundness here catches a WRONG sum
 * (a violated carry constraint); a full zkVM additionally needs RANGE CHECKS proving each limb < 2^14 (to close
 * the malleable-limb attack) -- which zk_air lacks today (a lookup argument or capacity expansion: the named
 * follow-on).  The verifier-opening bridge generalises from zk_svir_exec.iii (W=1, demonstrated). */
module zk_svir_add

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_constraints_hold() -> u8 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_consistent_at(j: u64) -> u8 from "zk_air.iii"

var AL : [u32; 5] = [7920u32, 10995u32, 10121u32, 3349u32, 18u32]      /* a's 14-bit limbs */
var BL : [u32; 5] = [801u32, 7573u32, 15000u32, 15218u32, 15u32]       /* b's */
var CL : [u32; 5] = [8721u32, 2184u32, 8738u32, 2184u32, 34u32]        /* c = a+b */
var KIN : [u32; 5] = [0u32, 0u32, 1u32, 1u32, 1u32]                    /* carry_in per limb (carry_in_0=0) */

fn fill_trace() {
    let mut i : u64 = 0u64
    while i < 5u64 {                                  /* rows 0..4 : the real limb carry chain */
        air_set_trace(i, 0u64, AL[i])
        air_set_trace(i, 1u64, BL[i])
        air_set_trace(i, 2u64, CL[i])
        air_set_trace(i, 3u64, KIN[i])
        i = i + 1u64
    }
    while i < 8u64 {                                  /* rows 5..7 : zero padding (carry_in=0 -> constraints hold) */
        air_set_trace(i, 0u64, 0u32)  air_set_trace(i, 1u64, 0u32)  air_set_trace(i, 2u64, 0u32)  air_set_trace(i, 3u64, 0u32)
        i = i + 1u64
    }
}

fn setup_constraints() {
    let p : u32 = 998244353u32
    let two14 : u32 = 16384u32
    /* con0 (limb-add): +2^14*next.carry_in - a - b - carry_in + c.  vars: 0=const1, cur cols 1..4 (a,b,c,kin),
     * next cols 5..8 (a,b,c,kin) -> next.carry_in = var 8.  Each term is coeff*var*const1 (degree 1). */
    air_add_term(0u32, two14, 8u32, 0u32)            /* + 2^14 * next.carry_in */
    air_add_term(0u32, p - 1u32, 1u32, 0u32)         /* - a */
    air_add_term(0u32, p - 1u32, 2u32, 0u32)         /* - b */
    air_add_term(0u32, p - 1u32, 4u32, 0u32)         /* - carry_in */
    air_add_term(0u32, 1u32, 3u32, 0u32)             /* + c */
    /* con1 (carry boolean): carry_in^2 - carry_in. */
    air_add_term(1u32, 1u32, 4u32, 4u32)             /* + carry_in^2 */
    air_add_term(1u32, p - 1u32, 4u32, 0u32)         /* - carry_in */
    air_set_alpha(0u64, 3u32)
    air_set_alpha(1u64, 5u32)
}

fn build_air() { air_reset(4u32, 8u32)  fill_trace()  setup_constraints()  air_build_lde()  air_build_cp() }

fn main() -> u64 {
    build_air()
    /* honest: the limb carry-chain AIR is satisfied (every limb-add + every carry boolean vanish), CP consistent */
    if air_constraints_hold() != 1u8 { return 1u64 }
    if air_cp_consistent_at(1u64) != 1u8 { return 2u64 }
    if air_cp_consistent_at(5u64) != 1u8 { return 3u64 }
    /* SOUNDNESS NEGATIVE: forge a result limb (c_2: 8738 -> 9999) -> the limb-add at row 2 no longer vanishes ->
     * a wrong 64-bit sum is caught. */
    build_air()  air_set_trace(2u64, 2u64, 9999u32)  air_build_lde()
    if air_constraints_hold() != 0u8 { return 4u64 }
    /* a forged carry (carry_in_3: 1 -> 0) is also caught (the chain breaks). */
    build_air()  air_set_trace(3u64, 3u64, 0u32)  air_build_lde()
    if air_constraints_hold() != 0u8 { return 5u64 }
    /* tampers isolated: the honest trace proves again. */
    build_air()
    if air_constraints_hold() != 1u8 { return 6u64 }
    return 99u64
}
