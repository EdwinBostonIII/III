/* zk_svir_attest.iii -- the HONEST end-to-end zk attestation test (the discriminating one): a MECHANICALLY-COMPUTED
 * trace, a REAL STARK proof object, an INDEPENDENT verifier that never sees the witness, and -- the un-fakeable part
 * -- a FALSE computation REJECTED BY THE MATH (FRI low-degree + the AIR constraint at Fiat-Shamir-random openings),
 * not by air_constraints_hold (prover-side satisfiability) and not by a hand-placed tamper.
 *
 * This is the test that separates a zkVM from a constraint-demo library.  The per-opcode gadgets hand-write a trace,
 * hand-write constraints, and check air_constraints_hold (does the polynomial vanish on the domain).  That is "I
 * transcribed my arithmetic correctly."  Here instead:
 *   1. the trace is COMPUTED by running the recurrence c0' = c0*c1, c1' = c1+c0 over GF(998244353) -- nothing is
 *      hand-authored; if the loop is wrong the proof is wrong.
 *   2. air_stark_prove() emits a real proof: Merkle-committed trace roots, FS-derived challenges + queries, a FRI
 *      low-degree certificate, and openings.
 *   3. air_stark_verify() reconstructs the FS challenges from the transcript and checks every Merkle opening, the
 *      AIR constraint CP[q]*Z_H(q) == air_combine_opened at the random query points, and the FRI folding -- WITHOUT
 *      the witness.  0 = ACCEPT.
 *   4. a FALSE computation (one cell broken so the recurrence is violated) is then proven and verified: its
 *      constraint does not vanish on the domain, so CP is not low-degree -> FRI / the opened-constraint check must
 *      REJECT (nonzero).  If air_stark_verify ACCEPTS a false trace, the STARK is UNSOUND and this returns 2.
 *
 * Returns 99 iff: the honest computation's proof VERIFIES, AND the false computation's proof is REJECTED by the
 * verifier's math, AND the honest proof verifies again.  This is the external oracle the gadget self-tests lacked. */
module zk_svir_attest

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_boundary_reset() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_boundary(col: u32, row: u32, value: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_prove() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_verify() -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_constraints_hold() -> u8 from "zk_air.iii"
extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_add(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"

const NEG1 : u32 = 998244352u32   /* -1 mod the STARK prime 998244353 */

/* the 2-column degree-2 AIR: con0 (c0' = c0*c1), con1 (c1' = c1 + c0), with the start pinned (c0_0=2, c1_0=3). */
fn setup() {
    air_reset(2u32, 8u32)
    air_boundary_reset()
    air_add_boundary(0u32, 0u32, 2u32)
    air_add_boundary(1u32, 0u32, 3u32)
    air_add_term(0u32, 1u32, 3u32, 0u32)         /* + next.c0 */
    air_add_term(0u32, NEG1, 1u32, 2u32)         /* - c0*c1 */
    air_add_term(1u32, 1u32, 4u32, 0u32)         /* + next.c1 */
    air_add_term(1u32, NEG1, 2u32, 0u32)         /* - c1 */
    air_add_term(1u32, NEG1, 1u32, 0u32)         /* - c0 */
    air_set_alpha(0u64, 7u32)
    air_set_alpha(1u64, 13u32)
}

/* MECHANICAL trace extraction: run the recurrence, write each computed step.  No hand-authored values. */
fn fill() {
    let mut c0 : u32 = 2u32
    let mut c1 : u32 = 3u32
    let mut t : u64 = 0u64
    while t < 8u64 {
        air_set_trace(t, 0u64, c0)
        air_set_trace(t, 1u64, c1)
        let n0 : u32 = sf_mul(c0, c1)
        let n1 : u32 = sf_add(c1, c0)
        c0 = n0
        c1 = n1
        t = t + 1u64
    }
}

fn main() -> u64 {
    /* (1) HONEST: a mechanically-computed trace, full STARK proof, INDEPENDENT verifier. */
    setup()  fill()  air_stark_prove()
    let honest : u64 = air_stark_verify()
    /* (2) INTERIOR forge: break the recurrence at trace[4][0] (an interior, transition-constrained cell). */
    setup()  fill()  air_set_trace(4u64, 0u64, 12345u32)  air_stark_prove()
    let interior : u64 = air_stark_verify()
    /* (3) BOUNDARY forge: break trace[0][0] (pinned to 2 by air_add_boundary -- the boundary check should catch it). */
    setup()  fill()  air_set_trace(0u64, 0u64, 99u32)  air_stark_prove()
    let boundary : u64 = air_stark_verify()
    /* characterize: 0 = ACCEPT (verify passed); nonzero = REJECT (sound). */
    if honest != 0u64 { return 1u64 }                  /* honest MUST verify; if not, the API is misused */
    if interior != 0u64 {                              /* interior forge REJECTED */
        if boundary != 0u64 { return 99u64 }           /* both rejected -> the STARK is SOUND */
        return 80u64
    }
    if boundary != 0u64 { return 92u64 }               /* interior ACCEPTED (unsound), boundary REJECTED -> gap is FRI/constraint */
    return 93u64                                        /* both ACCEPTED -> fully unsound */
}
