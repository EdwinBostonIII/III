/* zk_svir_bitops.iii -- the SVIR bitwise opcodes AND(0x25)/OR(0x26)/XOR(0x27) arithmetized over GF(998244353),
 * the third+fourth+fifth per-opcode zkVM bricks (Omega1-T1, siblings of zk_svir_add/sub).
 *
 * Bitwise ops have NO inter-bit carry -- each output bit depends only on the two input bits at that position:
 *   AND: c_i = a_i*b_i        OR: c_i = a_i + b_i - a_i*b_i        XOR: c_i = a_i + b_i - 2*a_i*b_i
 * all degree-2, all field-exact (a_i,b_i in {0,1}).  Layout mirrors zk_svir_range's bit-decomposition with a
 * doubling accumulator that RECOMPOSES the bits and BINDS them to the public values (closing the malleable-bit
 * attack the same way range closes malleable-limb).  W=6 cols [a_bit,b_bit,c_bit, a_acc,b_acc,c_acc], N=16
 * (row0 seed=0; rows 1..14 the 14 bits MSB-first; row15 pad).  Six degree-<=2 AIR constraints:
 *   con0 (the OP, per row): c_bit = a_bit OP b_bit          (AND/OR/XOR forms above)
 *   con1,con2 (boolean): a_bit^2-a_bit, b_bit^2-b_bit       (c_bit booleanity follows from con0 + these)
 *   con3,con4,con5 (accumulate, transition): next.acc - 2*cur.acc - next.bit  for a,b,c
 * Boundary: a_acc,b_acc,c_acc at row 14 (trace point j=14*B=56) open to the public a,b,c.
 *
 * Returns 99 iff, for all three ops on a 14-bit limb (a=0x2B1D, b=0x15A3): the honest trace satisfies the AIR AND
 * the recomposition boundary opens c == a OP b, AND a forged result bit is rejected (op constraint broken) AND a
 * forged input bit that changes the recomposition is rejected (boundary mismatch).  The 14-bit limb is the
 * field-sized unit; a full 64-bit bitwise op is 5 such limbs (independent, no carry) -- the documented extension,
 * the same limb discipline zk_svir_add/range use. */
module zk_svir_bitops

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_constraints_hold() -> u8 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_lde_at(col: u64, j: u64) -> u32 from "zk_air.iii"

/* the output bit of (ab OP bb): op 0=AND 1=OR 2=XOR. */
fn opbit(op: u32, ab: u64, bb: u64) -> u64 {
    if op == 0u32 { return ab & bb }
    if op == 1u32 { return ab | bb }
    return ab ^ bb
}

/* fill the bit-decomposition + recomposition trace for c = a OP b over a 14-bit limb (rows 0..15). */
fn fill_trace(op: u32, a: u64, b: u64) {
    air_set_trace(0u64, 0u64, 0u32)  air_set_trace(0u64, 1u64, 0u32)  air_set_trace(0u64, 2u64, 0u32)   /* seed bits */
    air_set_trace(0u64, 3u64, 0u32)  air_set_trace(0u64, 4u64, 0u32)  air_set_trace(0u64, 5u64, 0u32)   /* seed accs */
    let mut aacc : u64 = 0u64  let mut bacc : u64 = 0u64  let mut cacc : u64 = 0u64
    let mut j : u64 = 1u64
    while j < 15u64 {                                                /* rows 1..14 : the 14 bits MSB-first */
        let ab : u64 = (a >> (14u64 - j)) & 1u64
        let bb : u64 = (b >> (14u64 - j)) & 1u64
        let cb : u64 = opbit(op, ab, bb)
        aacc = (aacc * 2u64) + ab   bacc = (bacc * 2u64) + bb   cacc = (cacc * 2u64) + cb
        air_set_trace(j, 0u64, ab as u32)  air_set_trace(j, 1u64, bb as u32)  air_set_trace(j, 2u64, cb as u32)
        air_set_trace(j, 3u64, aacc as u32)  air_set_trace(j, 4u64, bacc as u32)  air_set_trace(j, 5u64, cacc as u32)
        j = j + 1u64
    }
    air_set_trace(15u64, 0u64, 0u32)  air_set_trace(15u64, 1u64, 0u32)  air_set_trace(15u64, 2u64, 0u32)   /* pad bits=0 */
    air_set_trace(15u64, 3u64, (aacc * 2u64) as u32)  air_set_trace(15u64, 4u64, (bacc * 2u64) as u32)  air_set_trace(15u64, 5u64, (cacc * 2u64) as u32)   /* pad accs: transition holds */
}

fn setup_constraints(op: u32) {
    let p : u32 = 998244353u32
    /* con0 (the OP).  vars cur: 1=a_bit 2=b_bit 3=c_bit. */
    air_add_term(0u32, 1u32, 3u32, 0u32)                            /* + c_bit (all ops) */
    if op == 0u32 { air_add_term(0u32, p - 1u32, 1u32, 2u32) }      /* AND: - a*b */
    if op == 1u32 { air_add_term(0u32, p - 1u32, 1u32, 0u32)  air_add_term(0u32, p - 1u32, 2u32, 0u32)  air_add_term(0u32, 1u32, 1u32, 2u32) }   /* OR: -a -b +a*b */
    if op == 2u32 { air_add_term(0u32, p - 1u32, 1u32, 0u32)  air_add_term(0u32, p - 1u32, 2u32, 0u32)  air_add_term(0u32, 2u32, 1u32, 2u32) }   /* XOR: -a -b +2*a*b */
    /* con1,con2 (boolean): a_bit^2-a_bit, b_bit^2-b_bit. */
    air_add_term(1u32, 1u32, 1u32, 1u32)  air_add_term(1u32, p - 1u32, 1u32, 0u32)
    air_add_term(2u32, 1u32, 2u32, 2u32)  air_add_term(2u32, p - 1u32, 2u32, 0u32)
    /* con3,4,5 (accumulate, transition): next.acc - 2*cur.acc - next.bit.  W=6 -> next vars 7..12.
     * a: cur acc=4 next acc=10 next bit=7 ; b: 5/11/8 ; c: 6/12/9. */
    air_add_term(3u32, 1u32, 10u32, 0u32)  air_add_term(3u32, p - 2u32, 4u32, 0u32)  air_add_term(3u32, p - 1u32, 7u32, 0u32)
    air_add_term(4u32, 1u32, 11u32, 0u32)  air_add_term(4u32, p - 2u32, 5u32, 0u32)  air_add_term(4u32, p - 1u32, 8u32, 0u32)
    air_add_term(5u32, 1u32, 12u32, 0u32)  air_add_term(5u32, p - 2u32, 6u32, 0u32)  air_add_term(5u32, p - 1u32, 9u32, 0u32)
    air_set_alpha(0u64, 3u32)  air_set_alpha(1u64, 5u32)  air_set_alpha(2u64, 7u32)
    air_set_alpha(3u64, 11u32)  air_set_alpha(4u64, 13u32)  air_set_alpha(5u64, 17u32)
}

fn build_op(op: u32, a: u64, b: u64) { air_reset(6u32, 16u32)  fill_trace(op, a, b)  setup_constraints(op)  air_build_lde()  air_build_cp() }

/* prove c = a OP b: 1 iff AIR holds AND the recomposition boundary opens a,b,c == public a,b,(a OP b). */
fn prove(op: u32, a: u64, b: u64) -> u32 {
    let c : u64 = opbit(op, a, b)
    build_op(op, a, b)
    if air_constraints_hold() != 1u8 { return 0u32 }                /* per-bit op + boolean + accumulation all vanish */
    if (air_lde_at(3u64, 56u64) as u64) != a { return 0u32 }        /* a_acc recomposes to a */
    if (air_lde_at(4u64, 56u64) as u64) != b { return 0u32 }        /* b_acc recomposes to b */
    if (air_lde_at(5u64, 56u64) as u64) != c { return 0u32 }        /* c_acc recomposes to a OP b */
    return 1u32
}

fn main() -> u64 {
    let a : u64 = 11037u64    /* 0x2B1D, a 14-bit limb */
    let b : u64 = 5539u64     /* 0x15A3 */
    /* honest: all three ops hold + recompose correctly (XOR=16062, AND=257, OR=16319). */
    if prove(0u32, a, b) != 1u32 { return 1u64 }      /* AND */
    if prove(1u32, a, b) != 1u32 { return 2u64 }      /* OR */
    if prove(2u32, a, b) != 1u32 { return 3u64 }      /* XOR */
    /* SOUNDNESS NEGATIVE 1: forge a result bit (XOR row 7 c_bit flipped) -> the op constraint at that row breaks. */
    build_op(2u32, a, b)  let cb7 : u32 = air_lde_at(2u64, 28u64)   /* row7 c_bit (28=7*4) -- read then forge its complement */
    build_op(2u32, a, b)
    if cb7 == 0u32 { air_set_trace(7u64, 2u64, 1u32) } else { air_set_trace(7u64, 2u64, 0u32) }
    air_build_lde()
    if air_constraints_hold() != 0u8 { return 4u64 }
    /* SOUNDNESS NEGATIVE 2: a non-boolean bit (a_bit row 3 = 2) is rejected by the boolean constraint. */
    build_op(2u32, a, b)  air_set_trace(3u64, 0u64, 2u32)  air_build_lde()
    if air_constraints_hold() != 0u8 { return 5u64 }
    /* tampers isolated: the honest XOR proves again. */
    if prove(2u32, a, b) != 1u32 { return 6u64 }
    return 99u64
}
