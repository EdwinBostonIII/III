/* zk_svir_cmp.iii -- the SVIR COMPARISON opcodes arithmetized over GF(998244353) via the INVERSE-WITNESS
 * (is-zero) certificate.  The first RELATIONAL zkVM brick (Omega1, sibling of the arithmetic add/sub/mul/bitops).
 *
 * Equality is not a polynomial (it is discontinuous), so it cannot be a direct AIR constraint.  The standard
 * arithmetization is an inverse CERTIFICATE: the prover supplies a witness w, and two degree-2 constraints force
 * the truth.  With d = a - b (over the field):
 *   con0 (difference):  a - b - d == 0                 (d is the honest difference, not a free cell)
 *   con1 (is-zero def): c - 1 + d*w == 0   i.e. c = 1 - d*w
 *   con2 (is-zero kill): c * d == 0
 *   => if d == 0 (a==b): con1 gives c = 1 (w free).        => if d != 0 (a!=b): con2 forces c = 0, then con1
 *      forces 0 = 1 - d*w, i.e. w = d^{-1} -- the prover CANNOT satisfy both unless it knows the field inverse of
 *      the difference.  So c == is_zero(a-b) is certified.  (c is thereby forced boolean -- no extra constraint.)
 * SVIR EQ(0x30) returns c ; NE(0x31) returns 1 - c.  The four signed ORDERINGS (LT_S 0x32 / GE_S 0x33 / LE_S 0x34 /
 * GT_S 0x35) reduce to this EQ certificate plus ONE signed less-than (a < b iff the i64 subtraction underflows:
 * the final borrow of zk_svir_sub's chain, sign-biased by +2^63) -- the named follow-on, reusing the sub borrow.
 *
 * The honest witness w = d^{-1} is computed in-gadget by Fermat (w = d^{p-2} mod p), self-contained (no link dep);
 * w = 0 when d = 0 (0^{p-2}=0), so one uniform formula serves both branches.  Returns 99 iff: the EQ case (a==b)
 * AND the NE case (a!=b, with the real inverse witness) both satisfy the AIR, AND three soundness negatives are
 * rejected -- a forged c in the EQ case, a forged c in the NE case, and a FORGED (wrong) inverse witness in the NE
 * case (the last is what makes the certificate sound: a lying prover with no true inverse is caught). */
module zk_svir_cmp

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_constraints_hold() -> u8 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_consistent_at(j: u64) -> u8 from "zk_air.iii"

/* Fermat inverse over GF(p): w = base^{p-2} mod p (= 0 when base = 0).  p ~ 2^30 so products fit u64; no call
 * occurs between any multiply and its `% m`, so no modulo-after-call hazard. */
fn mod_pow(base: u64, exp: u64, m: u64) -> u64 {
    let mut result : u64 = 1u64
    let mut b : u64 = base % m
    let mut e : u64 = exp
    while e > 0u64 {
        if (e & 1u64) == 1u64 { result = (result * b) % m }
        b = (b * b) % m
        e = e >> 1u64
    }
    return result
}

/* fill all 8 rows with the same comparison (a,b): cols [a, b, d=a-b, w=d^{-1}, c=is_zero(d)].  The constraint is
 * per-row (no transition), so a uniform replication keeps every row a witnessed comparison. */
fn fill_all(a: u64, b: u64) {
    let p : u64 = 998244353u64
    let d : u64 = (a + p - b) % p                 /* (a-b) mod p, computed before any call (no hazard) */
    let w : u64 = mod_pow(d, p - 2u64, p)         /* d^{-1}, or 0 when d==0 */
    let mut i : u64 = 0u64
    while i < 8u64 {
        air_set_trace(i, 0u64, a as u32)
        air_set_trace(i, 1u64, b as u32)
        air_set_trace(i, 2u64, d as u32)
        air_set_trace(i, 3u64, w as u32)
        if d == 0u64 { air_set_trace(i, 4u64, 1u32) } else { air_set_trace(i, 4u64, 0u32) }
        i = i + 1u64
    }
}

fn setup_constraints() {
    let p : u32 = 998244353u32
    /* vars: 0=const1 ; cols 1=a 2=b 3=d 4=w 5=c (single-row relation, no next-row vars). */
    /* con0 (difference): a - b - d. */
    air_add_term(0u32, 1u32, 1u32, 0u32)            /* + a */
    air_add_term(0u32, p - 1u32, 2u32, 0u32)        /* - b */
    air_add_term(0u32, p - 1u32, 3u32, 0u32)        /* - d */
    /* con1 (is-zero def): c - 1 + d*w. */
    air_add_term(1u32, 1u32, 5u32, 0u32)            /* + c */
    air_add_term(1u32, p - 1u32, 0u32, 0u32)        /* - 1 (const) */
    air_add_term(1u32, 1u32, 3u32, 4u32)            /* + d*w */
    /* con2 (is-zero kill): c*d. */
    air_add_term(2u32, 1u32, 5u32, 3u32)            /* + c*d */
    air_set_alpha(0u64, 3u32)
    air_set_alpha(1u64, 5u32)
    air_set_alpha(2u64, 7u32)
}

fn build(a: u64, b: u64) { air_reset(5u32, 8u32)  fill_all(a, b)  setup_constraints()  air_build_lde()  air_build_cp() }

fn main() -> u64 {
    /* EQ case: a == b -> is_zero(a-b) = 1.  Every constraint vanishes (d=0, c=1). */
    build(42u64, 42u64)
    if air_constraints_hold() != 1u8 { return 1u64 }
    if air_cp_consistent_at(1u64) != 1u8 { return 7u64 }
    /* NE case: a != b -> is_zero(a-b) = 0, witnessed by w = (a-b)^{-1}.  con1 = 0 - 1 + d*d^{-1} = 0. */
    build(42u64, 17u64)
    if air_constraints_hold() != 1u8 { return 2u64 }
    /* SOUNDNESS NEGATIVE 1: forge c in the EQ case (c: 1 -> 0).  con1 (d=0): 0 - 1 + 0 = -1 != 0 -> rejected. */
    build(42u64, 42u64)  air_set_trace(0u64, 4u64, 0u32)  air_build_lde()  air_build_cp()
    if air_constraints_hold() != 0u8 { return 3u64 }
    /* SOUNDNESS NEGATIVE 2: forge c in the NE case (c: 0 -> 1).  con2 (d!=0): 1*d = d != 0 -> rejected. */
    build(42u64, 17u64)  air_set_trace(0u64, 4u64, 1u32)  air_build_lde()  air_build_cp()
    if air_constraints_hold() != 0u8 { return 4u64 }
    /* SOUNDNESS NEGATIVE 3 (the certificate's teeth): forge the inverse witness in the NE case (w -> 12345, not
     * d^{-1}).  con1 (c=0): -1 + d*12345 != 0 (12345 is not 25^{-1}) -> a lying prover with no true inverse caught. */
    build(42u64, 17u64)  air_set_trace(0u64, 3u64, 12345u32)  air_build_lde()  air_build_cp()
    if air_constraints_hold() != 0u8 { return 5u64 }
    /* tampers isolated: the honest NE certificate proves again. */
    build(42u64, 17u64)
    if air_constraints_hold() != 1u8 { return 6u64 }
    return 99u64
}
