/* zk_svir_control.iii -- the SVIR CONTROL-FLOW opcodes (BR 0x50 / BR_IF 0x51, and the structured BLOCK 0x40 /
 * LOOP 0x41 / IF 0x42 / END 0x44 that define branch targets) arithmetized over GF(998244353) as a PROGRAM-COUNTER
 * TRANSITION AIR.  The last genuinely-new Omega1 technique (after limb-arithmetic, the is-zero certificate, and the
 * grand-product permutation): proving that execution's pc sequence FOLLOWS the declared control flow -- a forged
 * jump (skipping a guard, branching to a fabricated target) is caught.
 *
 * Each trace ROW is an execution step: columns W=4 [pc, sel_seq, sel_br, target].  sel_seq/sel_br is a one-hot
 * selector (this step falls through, or it is a taken branch).  ONE degree-2 transition constraint chains the pc:
 *   con0 (pc update): next.pc - sel_seq*(pc+1) - sel_br*target == 0
 *       => fall-through advances pc by 1 ; a taken branch jumps to `target`.  A forged next.pc (any wrong jump
 *          destination) makes con0 non-zero.
 *   con1 (one-hot): sel_seq + sel_br - 1 == 0          con2 (sel_seq boolean): sel_seq^2 - sel_seq == 0
 *       (=> sel_br is forced boolean too; claiming a branch is a fall-through fails con0, as the pc won't match.)
 * Demo program: a 3-instruction loop body run TWICE via a back-edge, then exit -- pc = [0,1,2, 0,1,2, 3,4].  Row 2
 * branches back to 0 (the loop back-edge); row 5 branches to 3 (the loop exit); all others fall through.
 *
 * Returns 99 iff: the honest pc trace satisfies the AIR (every transition + selector vanishes, CP consistent) AND
 * two soundness negatives are rejected -- a FORGED JUMP DESTINATION (the branch's next.pc altered to a fabricated
 * target) and a FAKED FALL-THROUGH (a taken branch relabelled sequential to skip its jump).  HONEST RESIDUAL: this
 * proves pc-SEQUENCE validity against the declared selectors; binding the selectors/targets to the actual program
 * bytecode (the BLOCK/LOOP/IF/END structure) is the layer atop -- a fixed program-table lookup, the named follow-on. */
module zk_svir_control

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_constraints_hold() -> u8 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_consistent_at(j: u64) -> u8 from "zk_air.iii"

var PC   : [u32; 8] = [0u32, 1u32, 2u32, 0u32, 1u32, 2u32, 3u32, 4u32]    /* the executed pc sequence (back-edge loop) */
var SSEQ : [u32; 8] = [1u32, 1u32, 0u32, 1u32, 1u32, 0u32, 1u32, 1u32]    /* fall-through selector */
var SBR  : [u32; 8] = [0u32, 0u32, 1u32, 0u32, 0u32, 1u32, 0u32, 0u32]    /* taken-branch selector */
var TGT  : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 3u32, 0u32, 0u32]    /* branch target (row2->0 back-edge, row5->3 exit) */

fn fill_trace() {
    let mut i : u64 = 0u64
    while i < 8u64 {
        air_set_trace(i, 0u64, PC[i])
        air_set_trace(i, 1u64, SSEQ[i])
        air_set_trace(i, 2u64, SBR[i])
        air_set_trace(i, 3u64, TGT[i])
        i = i + 1u64
    }
}

fn setup_constraints() {
    let p : u32 = 998244353u32
    /* vars: 0=const1 ; cur 1=pc 2=sel_seq 3=sel_br 4=target ; next 5=pc 6=sel_seq 7=sel_br 8=target. */
    /* con0 (pc update): next.pc - sel_seq*pc - sel_seq - sel_br*target. */
    air_add_term(0u32, 1u32, 5u32, 0u32)             /* + next.pc */
    air_add_term(0u32, p - 1u32, 2u32, 1u32)         /* - sel_seq*pc */
    air_add_term(0u32, p - 1u32, 2u32, 0u32)         /* - sel_seq   (the +1 of pc+1) */
    air_add_term(0u32, p - 1u32, 3u32, 4u32)         /* - sel_br*target */
    /* con1 (one-hot): sel_seq + sel_br - 1. */
    air_add_term(1u32, 1u32, 2u32, 0u32)             /* + sel_seq */
    air_add_term(1u32, 1u32, 3u32, 0u32)             /* + sel_br */
    air_add_term(1u32, p - 1u32, 0u32, 0u32)         /* - 1 */
    /* con2 (sel_seq boolean): sel_seq^2 - sel_seq. */
    air_add_term(2u32, 1u32, 2u32, 2u32)             /* + sel_seq^2 */
    air_add_term(2u32, p - 1u32, 2u32, 0u32)         /* - sel_seq */
    air_set_alpha(0u64, 3u32)
    air_set_alpha(1u64, 5u32)
    air_set_alpha(2u64, 7u32)
}

fn build() { air_reset(4u32, 8u32)  fill_trace()  setup_constraints()  air_build_lde()  air_build_cp() }

fn main() -> u64 {
    /* honest: the pc follows the declared control flow (both branches + all fall-throughs vanish). */
    build()
    if air_constraints_hold() != 1u8 { return 1u64 }
    if air_cp_consistent_at(1u64) != 1u8 { return 7u64 }
    /* SOUNDNESS NEGATIVE 1 (forged jump destination): alter the back-edge's landing pc (row3.pc: 0 -> 5) -- a branch
     * to a fabricated target.  con0 at row 2: next.pc(5) - 0 - 0 - sbr*tgt(1*0) = 5 != 0 -> rejected. */
    build()  air_set_trace(3u64, 0u64, 5u32)  air_build_lde()  air_build_cp()
    if air_constraints_hold() != 0u8 { return 2u64 }
    /* SOUNDNESS NEGATIVE 2 (faked fall-through): relabel the exit branch (row5) as sequential to skip its jump
     * (sel_seq 0->1, sel_br 1->0).  con0 at row 5: next.pc(3) - 1*2 - 1 - 0 = 0 (pc+1 would be 3!) ... so use the
     * back-edge row 2 where pc+1 != target: relabel row2 sequential -> con0: next.pc(0) - 1*2 - 1 - 0 = -3 != 0. */
    build()  air_set_trace(2u64, 1u64, 1u32)  air_set_trace(2u64, 2u64, 0u32)  air_build_lde()  air_build_cp()
    if air_constraints_hold() != 0u8 { return 3u64 }
    /* tampers isolated: the honest control trace proves again. */
    build()
    if air_constraints_hold() != 1u8 { return 4u64 }
    return 99u64
}
