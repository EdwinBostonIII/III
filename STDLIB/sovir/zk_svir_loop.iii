/* zk_svir_loop.iii -- CONTROL FLOW: a SOUND proof of a real LOOP's execution (the third zkVM pillar after compute +
 * memory).  A program counter follows the loop -- a CHECK row evaluates the condition and either enters the BODY or
 * EXITS; the BODY row increments and takes the BACK-EDGE to the check.  The condition i<3 is certified by an
 * inverse-witness IS-ZERO on (3-i); the pc is bound to one-hot {check,body,exit} selectors.  Transition-only, sound.
 *
 * Loop:  i = 0; while i < 3 { i = i + 1; }  -- unrolled across 8 rows: pc=[0,1,0,1,0,1,0,2], i=[0,0,1,1,2,2,3,3].
 *   pc-transition: CHECK (pc 0) -> 2 - cont (1=body if i<3, 2=exit); BODY (pc 1) -> 0 (back-edge); EXIT (pc 2) -> halt.
 *   cont = 1 - isz3, isz3 = is_zero(3 - i).  Counter: next.i = i + is_body.  Boundaries pin i_0=0, pc_0=0, i_6=3
 *   (the loop ran to completion), pc_7=2 (it exited).
 *
 * Returns 99 iff the honest loop VERIFIES (air_stark_prove/verify) and BOTH a forged iteration count (a skipped
 * increment) AND a forged control decision (taking the back-edge when it should exit) are REJECTED BY THE MATH.
 * This is structured iteration attested soundly -- with compute + memory + this, an arbitrary-program zkVM is whole. */
module zk_svir_loop

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_get_trace(row: u64, col: u64) -> u32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_boundary_reset() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_boundary(col: u32, row: u32, value: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_prove() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_verify() -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_sub(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"

const NEG1 : u32 = 998244352u32
const NEG2 : u32 = 998244351u32
const NEG3 : u32 = 998244350u32
const PRIME : u32 = 998244353u32

fn mod_pow(base: u32, ex: u32) -> u32 {
    let mut r : u32 = 1u32  let mut b : u32 = base  let mut e : u32 = ex
    while e > 0u32 { if (e & 1u32) == 1u32 { r = sf_mul(r, b) }  b = sf_mul(b, b)  e = e >> 1u32 }
    return r
}
fn inv(d: u32) -> u32 { if d == 0u32 { return 0u32 } return mod_pow(d, PRIME - 2u32) }

fn setup() {
    air_reset(9u32, 8u32)
    air_boundary_reset()
    air_add_boundary(0u32, 0u32, 0u32)               /* pc_0 = 0 (start at the check) */
    air_add_boundary(1u32, 0u32, 0u32)               /* i_0 = 0 */
    air_add_boundary(1u32, 6u32, 3u32)               /* i_6 = 3 (loop ran to completion) */
    air_add_boundary(0u32, 7u32, 2u32)               /* pc_7 = 2 (exited) */
    /* vars: 0=1 ; cur 1=pc 2=i 3=cont 4=is_check 5=is_body 6=is_exit 7=d3 8=winv 9=isz3 ; next 10=pc 11=i ... */
    /* con0 pc-transition: next.pc - is_check*(2-cont) - is_exit*2 = next.pc - 2*is_check + is_check*cont - 2*is_exit */
    air_add_term(0u32, 1u32, 10u32, 0u32)  air_add_term(0u32, NEG2, 4u32, 0u32)
    air_add_term(0u32, 1u32, 4u32, 3u32)   air_add_term(0u32, NEG2, 6u32, 0u32)
    air_add_term(1u32, 1u32, 11u32, 0u32)  air_add_term(1u32, NEG1, 2u32, 0u32)  air_add_term(1u32, NEG1, 5u32, 0u32) /* con1 next.i - i - is_body */
    air_add_term(2u32, 1u32, 3u32, 0u32)   air_add_term(2u32, NEG1, 0u32, 0u32)  air_add_term(2u32, 1u32, 9u32, 0u32) /* con2 cont - 1 + isz3 */
    air_add_term(3u32, 1u32, 7u32, 0u32)   air_add_term(3u32, NEG3, 0u32, 0u32)  air_add_term(3u32, 1u32, 2u32, 0u32) /* con3 d3 - 3 + i */
    air_add_term(4u32, 1u32, 9u32, 7u32)                                                                              /* con4 isz3*d3 */
    air_add_term(5u32, 1u32, 9u32, 0u32)   air_add_term(5u32, 1u32, 7u32, 8u32)  air_add_term(5u32, NEG1, 0u32, 0u32) /* con5 isz3 + d3*winv - 1 */
    air_add_term(6u32, 1u32, 4u32, 0u32)   air_add_term(6u32, 1u32, 5u32, 0u32)  air_add_term(6u32, 1u32, 6u32, 0u32)  air_add_term(6u32, NEG1, 0u32, 0u32) /* con6 one-hot */
    air_add_term(7u32, 1u32, 1u32, 0u32)   air_add_term(7u32, NEG1, 5u32, 0u32)  air_add_term(7u32, NEG2, 6u32, 0u32) /* con7 pc = is_body + 2*is_exit */
    air_add_term(8u32, 1u32, 4u32, 4u32)   air_add_term(8u32, NEG1, 4u32, 0u32)
    air_add_term(9u32, 1u32, 5u32, 5u32)   air_add_term(9u32, NEG1, 5u32, 0u32)
    air_add_term(10u32, 1u32, 6u32, 6u32)  air_add_term(10u32, NEG1, 6u32, 0u32)
    air_add_term(11u32, 1u32, 9u32, 9u32)  air_add_term(11u32, NEG1, 9u32, 0u32)                                      /* con8..11 booleans */
    let mut c : u64 = 0u64
    while c < 12u64 { air_set_alpha(c, (7u32 + (c as u32)*4u32))  c = c + 1u64 }
}

/* the INTERPRETER: simulate the loop, computing pc,i,cont,selectors,condition per row. */
fn fill() {
    let mut pc : u32 = 0u32  let mut i : u32 = 0u32  let mut row : u64 = 0u64
    while row < 8u64 {
        let mut isc : u32 = 0u32  let mut isb : u32 = 0u32  let mut ise : u32 = 0u32
        if pc == 0u32 { isc = 1u32 }
        if pc == 1u32 { isb = 1u32 }
        if pc == 2u32 { ise = 1u32 }
        let d3 : u32 = sf_sub(3u32, i)
        let mut isz3 : u32 = 0u32
        if d3 == 0u32 { isz3 = 1u32 }
        let wv : u32 = inv(d3)
        let cont : u32 = sf_sub(1u32, isz3)
        air_set_trace(row, 0u64, pc)   air_set_trace(row, 1u64, i)     air_set_trace(row, 2u64, cont)
        air_set_trace(row, 3u64, isc)  air_set_trace(row, 4u64, isb)   air_set_trace(row, 5u64, ise)
        air_set_trace(row, 6u64, d3)   air_set_trace(row, 7u64, wv)    air_set_trace(row, 8u64, isz3)
        let mut npc : u32 = 2u32  let mut ni : u32 = i
        if isc == 1u32 { npc = sf_sub(2u32, cont)  ni = i }
        if isb == 1u32 { npc = 0u32  ni = i + 1u32 }
        pc = npc  i = ni
        row = row + 1u64
    }
}

fn main() -> u64 {
    /* (1) HONEST loop: pc follows the control flow, counter + condition certified -> the sound verifier ACCEPTS. */
    setup()  fill()  air_stark_prove()
    if air_stark_verify() != 0u64 { return 1u64 }
    /* (2) FORGED ITERATION COUNT: tamper i_4 (2 -> 1, a skipped increment) -> con1 (next.i = i + is_body) at row 3 violated -> REJECT. */
    setup()  fill()  air_set_trace(4u64, 1u64, 1u32)  air_stark_prove()
    if air_stark_verify() == 0u64 { return 2u64 }
    /* (3) FORGED CONTROL: tamper pc_2 (0 -> 2, exit instead of back-edge) -> con0 (BODY -> 0) at row 1 violated -> REJECT. */
    setup()  fill()  air_set_trace(2u64, 0u64, 2u32)  air_stark_prove()
    if air_stark_verify() == 0u64 { return 3u64 }
    /* (4) honest re-proves. */
    setup()  fill()  air_stark_prove()
    if air_stark_verify() != 0u64 { return 4u64 }
    return 99u64
}
