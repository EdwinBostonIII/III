/* zk_svir_range.iii -- the RANGE-CHECK gadget that makes the limb arithmetic SOUND (closes the malleable-limb
 * residual of zk_svir_add): prove a value x is a valid 14-bit limb (x < 2^14) over zk_air's degree-<=2 AIR --
 * WITHOUT a lookup argument (which zk_air lacks).  Pure bit-decomposition:
 *   x = sum_{i=0}^{13} bit_i * 2^i ,  each bit_i in {0,1}.
 * Layout: W=2 cols [bit, partial], N=16 (row0 seed=0; rows 1..14 = the 14 bits MSB-first with a DOUBLING
 * accumulator partial_{j} = 2*partial_{j-1} + bit; row15 pad).  Two degree-<=2 AIR constraints:
 *   con0 (accumulate): next.partial - 2*cur.partial - next.bit == 0   (binds every row -> partial_14 = x)
 *   con1 (boolean):    cur.bit^2 - cur.bit == 0
 * Soundness: the boolean constraint forces each bit in {0,1}, so the recomposition partial_14 <= 2^14-1; the
 * BOUNDARY (partial at row 14, opened via air_lde_at at the trace point j=14*B) must equal x.  An out-of-range
 * x >= 2^14 cannot satisfy BOTH (14 boolean bits recompose to at most 2^14-1 != x) -> REJECTED.
 *
 * Returns 99 iff: a valid limb (10995 < 2^14) passes (constraints hold + boundary opens to x) AND an out-of-range
 * value (20000 >= 2^14) is REJECTED (its 14-bit recomposition 20000 mod 2^14 = 3616 != 20000 at the boundary).
 * This is the range-check a sound SVIR zkVM applies to EVERY limb -- built in zk_air's existing AIR, no lookup. */
module zk_svir_range

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_constraints_hold() -> u8 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_lde_at(col: u64, j: u64) -> u32 from "zk_air.iii"

/* fill the bit-decomposition trace for x (rows 0..15); returns partial_14 (the recomposition, == x iff x<2^14). */
fn fill_range(x: u64) -> u64 {
    air_set_trace(0u64, 0u64, 0u32)  air_set_trace(0u64, 1u64, 0u32)        /* seed: bit=0, partial=0 */
    let mut partial : u64 = 0u64
    let mut j : u64 = 1u64
    while j < 15u64 {                                                        /* rows 1..14 : MSB-first bits */
        let bit : u64 = (x >> (14u64 - j)) & 1u64
        partial = (partial * 2u64) + bit
        air_set_trace(j, 0u64, bit as u32)
        air_set_trace(j, 1u64, partial as u32)
        j = j + 1u64
    }
    air_set_trace(15u64, 0u64, 0u32)  air_set_trace(15u64, 1u64, (partial * 2u64) as u32)   /* pad: transition holds */
    return partial
}

fn setup_constraints() {
    let p : u32 = 998244353u32
    /* con0 (accumulate): next.partial - 2*cur.partial - next.bit.  vars: 0=const1, cur 1=bit 2=partial,
     * next 3=bit 4=partial. */
    air_add_term(0u32, 1u32, 4u32, 0u32)             /* + next.partial */
    air_add_term(0u32, p - 2u32, 2u32, 0u32)         /* - 2*cur.partial */
    air_add_term(0u32, p - 1u32, 3u32, 0u32)         /* - next.bit */
    /* con1 (boolean): bit^2 - bit. */
    air_add_term(1u32, 1u32, 1u32, 1u32)             /* + bit^2 */
    air_add_term(1u32, p - 1u32, 1u32, 0u32)         /* - bit */
    air_set_alpha(0u64, 3u32)
    air_set_alpha(1u64, 5u32)
}

/* range-check x: returns 1 iff x is a valid 14-bit limb (AIR holds AND the boundary opens partial_14 == x). */
fn range_ok(x: u64) -> u32 {
    air_reset(2u32, 16u32)
    fill_range(x)
    setup_constraints()
    air_build_lde()
    air_build_cp()
    if air_constraints_hold() != 1u8 { return 0u32 }            /* every bit boolean + accumulation consistent */
    /* boundary: the recomposition partial_14 (col1, trace point j = 14*B = 56) must equal x. */
    if (air_lde_at(1u64, 56u64) as u64) != x { return 0u32 }
    return 1u32
}

fn main() -> u64 {
    if range_ok(10995u64) != 1u32 { return 1u64 }      /* a valid 14-bit limb (from zk_svir_add) range-checks */
    if range_ok(0u64) != 1u32 { return 2u64 }          /* edge: 0 */
    if range_ok(16383u64) != 1u32 { return 3u64 }      /* edge: 2^14-1 (the max) */
    if range_ok(20000u64) != 0u32 { return 4u64 }      /* OUT OF RANGE (>= 2^14): must be REJECTED */
    if range_ok(16384u64) != 0u32 { return 5u64 }      /* edge: 2^14 itself -> REJECTED */
    return 99u64
}
