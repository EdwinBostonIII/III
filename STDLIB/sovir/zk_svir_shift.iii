/* zk_svir_shift.iii -- the SVIR SHIFT opcode SHL(0x28) arithmetized over GF(998244353) by BIT RE-INDEXING.  The
 * last arithmetic Omega1 brick (completing per-opcode coverage with shift).
 *
 * A left shift by 1 is a re-indexing of the bit-decomposition: c_bit_i = a_bit_{i-1} (every bit moves up one
 * position), with a 0 shifted in at the bottom and the top bit dropped.  Laid one bit per ROW (columns W=2
 * [a_bit, c_bit], N=8), this is a TRANSITION constraint plus a BOUNDARY:
 *   con0 (shift): next.c_bit - cur.a_bit == 0       => c_bit_{i+1} = a_bit_i for rows 0..N-2 (the upward move)
 *   con1 (a_bit boolean): a_bit^2 - a_bit == 0      con2 (c_bit boolean): c_bit^2 - c_bit == 0
 *   boundary: c_bit_0 = 0                            => the bit shifted in at the bottom is 0
 * The shifted-in low bit lives ONLY in the boundary (no transition produces c_bit_0), so air_boundaries_hold (added
 * for the permutation/counter arguments) is its third consumer.  Demo: a = 0b01101101 (109), c = a<<1 = 0b11011010
 * (218); a_bit = [1,0,1,1,0,1,1,0], c_bit = [0,1,0,1,1,0,1,1].
 *
 * Returns 99 iff: the honest shift satisfies BOTH air_constraints_hold (the re-index transition + booleans) AND
 * air_boundaries_hold (c_bit_0 = 0); a broken re-index is transition-caught; AND a FORGED shifted-in bit (c_bit_0:
 * 0 -> 1) is caught ONLY by the boundary (no transition constrains it).  HONEST RESIDUAL: SHL-by-1 demonstrates the
 * technique; SHL/SHR-by-k is the k-row-offset mirror (SHR: c_bit_i = a_bit_{i+1}, boundary c_bit_{N-1}=0); binding
 * the bits to the public 64-bit values is the recomposition layer (zk_svir_bitops) -- the named follow-on. */
module zk_svir_shift

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_lde() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_build_cp() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_constraints_hold() -> u8 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_cp_consistent_at(j: u64) -> u8 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_boundary_reset() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_boundary(col: u32, row: u32, value: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_boundaries_hold() -> u8 from "zk_air.iii"

var AB : [u32; 8] = [1u32, 0u32, 1u32, 1u32, 0u32, 1u32, 1u32, 0u32]    /* a = 109, LSB-first bits */
var CB : [u32; 8] = [0u32, 1u32, 0u32, 1u32, 1u32, 0u32, 1u32, 1u32]    /* c = a<<1 = 218, LSB-first bits */

fn fill_trace() {
    let mut i : u64 = 0u64
    while i < 8u64 {
        air_set_trace(i, 0u64, AB[i])
        air_set_trace(i, 1u64, CB[i])
        i = i + 1u64
    }
}

fn setup_constraints() {
    let p : u32 = 998244353u32
    /* vars: 0=const1 ; cur 1=a_bit 2=c_bit ; next 3=a_bit 4=c_bit. */
    /* con0 (shift re-index): next.c_bit - cur.a_bit. */
    air_add_term(0u32, 1u32, 4u32, 0u32)             /* + next.c_bit */
    air_add_term(0u32, p - 1u32, 1u32, 0u32)         /* - cur.a_bit */
    /* con1 (a_bit boolean): a_bit^2 - a_bit. */
    air_add_term(1u32, 1u32, 1u32, 1u32)
    air_add_term(1u32, p - 1u32, 1u32, 0u32)
    /* con2 (c_bit boolean): c_bit^2 - c_bit. */
    air_add_term(2u32, 1u32, 2u32, 2u32)
    air_add_term(2u32, p - 1u32, 2u32, 0u32)
    air_set_alpha(0u64, 3u32)
    air_set_alpha(1u64, 5u32)
    air_set_alpha(2u64, 7u32)
}

fn build() {
    air_reset(2u32, 8u32)
    air_boundary_reset()
    fill_trace()
    setup_constraints()
    air_add_boundary(1u32, 0u32, 0u32)               /* c_bit_0 = 0 (the bit shifted in at the bottom) */
    air_build_lde()
    air_build_cp()
}

fn main() -> u64 {
    /* honest: c = a<<1 -- the re-index transition holds AND the shifted-in low bit is 0. */
    build()
    if air_constraints_hold() != 1u8 { return 1u64 }
    if air_boundaries_hold() != 1u8 { return 2u64 }
    if air_cp_consistent_at(1u64) != 1u8 { return 7u64 }
    /* NEGATIVE A (transition catches a broken re-index): forge c_bit_3 (1 -> 0) -> con0 at row 2:
     * next.c_bit(0) - a_bit_2(1) = -1 != 0. */
    build()  air_set_trace(3u64, 1u64, 0u32)  air_build_lde()  air_build_cp()
    if air_constraints_hold() != 0u8 { return 3u64 }
    /* NEGATIVE B (the boundary's teeth): forge the shifted-in bit c_bit_0 (0 -> 1).  No transition produces c_bit_0
     * (the first transition makes c_bit_1 = a_bit_0), so every transition still holds -- caught ONLY by the
     * boundary c_bit_0 = 0. */
    build()  air_set_trace(0u64, 1u64, 1u32)  air_build_lde()  air_build_cp()
    if air_constraints_hold() != 1u8 { return 4u64 }   /* transitions STILL hold */
    if air_boundaries_hold() != 0u8 { return 5u64 }    /* but the shifted-in bit must be 0 -> boundary rejects */
    /* honest re-proves on both axes. */
    build()
    if air_constraints_hold() != 1u8 { return 6u64 }
    if air_boundaries_hold() != 1u8 { return 8u64 }
    return 99u64
}
