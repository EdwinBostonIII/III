/* zk_svir_vm_fused.iii -- THE FUSED zkVM: COMPUTE + MEMORY + CONTROL on ONE trace, attested soundly.
 *
 * A real loop-with-memory program:  for i in 0..6 { mem[i] = 7*i }  then LOAD mem[3] (=> 21).  Every VM step is one
 * row, and -- crucially -- one memory access (no nulls): rows 0..5 STORE mem[i]=7*i (the loop body), row 6 LOADs
 * mem[3].  All three zkVM pillars compose on the single trace:
 *   CONTROL: the loop counter i increments every row (next.i = i + 1) -- the iteration that drives the addresses.
 *   COMPUTE: the stored value is computed, vp = 7*i at the store rows (linked to the counter).
 *   MEMORY (dynamic): the (addr,val,iswrite) accesses are proven consistent by the grand-product PERMUTATION
 *     (program-order == (addr,time)-sorted, FS-alpha,beta) + READ-CONSISTENCY (the LOAD of mem[3] returns the
 *     value STORED there, 21, via an inverse-witness is-zero on the sorted address-difference) + SORTEDNESS.
 * The COMPUTE/CONTROL link binds the memory access to the loop: is_store*(ap - i) = 0 and is_store*(vp - 7*i) = 0.
 *
 * W=15 (needs the WMAX 16->32 enlargement), 17 constraints.  Returns 99 iff the honest fused execution VERIFIES
 * (air_stark_prove/verify) and BOTH a forged LOAD value (read-consistency) AND a forged stored value (the compute
 * link) are REJECTED BY THE MATH.  This is a complete zkVM step over a real program: compute, memory, and control
 * proven TOGETHER on one trace, by a verifier that never sees the witness. */
module zk_svir_vm_fused

extern @abi(c-msvc-x64) fn air_reset(w: u32, n: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_trace(row: u64, col: u64, v: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_term(con: u32, coeff: u32, va: u32, vb: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_set_alpha(con: u64, a: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_boundary_reset() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_add_boundary(col: u32, row: u32, value: u32) -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_prove() -> i32 from "zk_air.iii"
extern @abi(c-msvc-x64) fn air_stark_verify() -> u64 from "zk_air.iii"
extern @abi(c-msvc-x64) fn sf_mul(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_add(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"
extern @abi(c-msvc-x64) fn sf_sub(x: u32, y: u32) -> u32 from "ntt_fri_organ.iii"

const NEG1 : u32 = 998244352u32
const NEG7 : u32 = 998244346u32
const PRIME : u32 = 998244353u32

/* counter + program-order access [addr,val,iswrite] + phase (store/load).  Row 7 is a dummy store (Z_T-excluded). */
var IC : [u32; 8] = [0u32, 1u32, 2u32, 3u32, 4u32, 5u32, 6u32, 7u32]
var AP : [u32; 8] = [0u32, 1u32, 2u32, 3u32, 4u32, 5u32, 3u32, 6u32]
var VP : [u32; 8] = [0u32, 7u32, 14u32, 21u32, 28u32, 35u32, 21u32, 42u32]
var WP : [u32; 8] = [1u32, 1u32, 1u32, 1u32, 1u32, 1u32, 0u32, 1u32]
var IST : [u32; 8] = [1u32, 1u32, 1u32, 1u32, 1u32, 1u32, 0u32, 1u32]
var ILD : [u32; 8] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 1u32, 0u32]
/* (addr,time)-sorted access */
var AS : [u32; 8] = [0u32, 1u32, 2u32, 3u32, 3u32, 4u32, 5u32, 6u32]
var VS : [u32; 8] = [0u32, 7u32, 14u32, 21u32, 21u32, 28u32, 35u32, 42u32]
var WS : [u32; 8] = [1u32, 1u32, 1u32, 1u32, 0u32, 1u32, 1u32, 1u32]
/* computed: grand products + is-zero/read witnesses over the sorted trace */
var ACP : [u32; 8] = [0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32]
var ACS : [u32; 8] = [0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32]
var DM  : [u32; 8] = [0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32]
var WV  : [u32; 8] = [0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32]
var IZ  : [u32; 8] = [0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32]
var RA  : [u32; 8] = [0u32,0u32,0u32,0u32,0u32,0u32,0u32,0u32]

fn mod_pow(base: u32, ex: u32) -> u32 {
    let mut r : u32 = 1u32  let mut b : u32 = base  let mut e : u32 = ex
    while e > 0u32 { if (e & 1u32) == 1u32 { r = sf_mul(r, b) }  b = sf_mul(b, b)  e = e >> 1u32 }
    return r
}
fn inv(d: u32) -> u32 { if d == 0u32 { return 0u32 } return mod_pow(d, PRIME - 2u32) }
fn derive(seed: u32) -> u32 {
    let mut a : u32 = seed  let mut i : u64 = 0u64
    while i < 8u64 {
        a = sf_add(sf_mul(a, 16777619u32), AP[i])  a = sf_add(sf_mul(a, a), 1u32)
        a = sf_add(sf_mul(a, 16777619u32), VP[i])  a = sf_add(sf_mul(a, a), 2u32)
        i = i + 1u64
    }
    if a < 2u32 { a = 2u32 }
    return a
}

fn build() -> u32 {
    let alpha : u32 = derive(169647555u32)
    let beta  : u32 = derive(305419896u32)
    let beta2 : u32 = sf_mul(beta, beta)
    ACP[0] = 1u32  ACS[0] = 1u32
    let mut i : u64 = 0u64
    while i < 7u64 {
        let ep : u32 = sf_add(sf_add(AP[i], sf_mul(beta, VP[i])), sf_mul(beta2, WP[i]))
        let es : u32 = sf_add(sf_add(AS[i], sf_mul(beta, VS[i])), sf_mul(beta2, WS[i]))
        ACP[i + 1u64] = sf_mul(ACP[i], sf_sub(alpha, ep))
        ACS[i + 1u64] = sf_mul(ACS[i], sf_sub(alpha, es))
        i = i + 1u64
    }
    let x : u32 = ACP[7]
    i = 0u64
    while i < 8u64 {
        let inx : u64 = (i + 1u64) & 7u64
        let d : u32 = sf_sub(AS[inx], AS[i])
        DM[i] = d
        WV[i] = inv(d)
        if d == 0u32 { IZ[i] = 1u32 } else { IZ[i] = 0u32 }
        RA[i] = sf_mul(IZ[i], sf_sub(VS[inx], VS[i]))
        i = i + 1u64
    }
    air_reset(15u32, 8u32)
    air_boundary_reset()
    i = 0u64
    while i < 8u64 {
        air_set_trace(i, 0u64, IC[i])  air_set_trace(i, 1u64, AP[i])  air_set_trace(i, 2u64, VP[i])  air_set_trace(i, 3u64, WP[i])
        air_set_trace(i, 4u64, AS[i])  air_set_trace(i, 5u64, VS[i])  air_set_trace(i, 6u64, WS[i])
        air_set_trace(i, 7u64, ACP[i]) air_set_trace(i, 8u64, ACS[i])
        air_set_trace(i, 9u64, DM[i])  air_set_trace(i, 10u64, WV[i]) air_set_trace(i, 11u64, IZ[i]) air_set_trace(i, 12u64, RA[i])
        air_set_trace(i, 13u64, IST[i]) air_set_trace(i, 14u64, ILD[i])
        i = i + 1u64
    }
    let am : u32 = sf_sub(0u32, alpha)
    /* vars: 0=1 ; cur 1=i 2=ap 3=vp 4=wp 5=as 6=vs 7=ws 8=acp 9=acs 10=dm 11=wv 12=iz 13=ra 14=ist 15=ild ;
     *        next 16=i 17=ap 18=vp 19=wp 20=as 21=vs 22=ws 23=acp 24=acs 25=dm ... */
    air_add_term(0u32, 1u32, 16u32, 0u32)  air_add_term(0u32, NEG1, 1u32, 0u32)  air_add_term(0u32, NEG1, 0u32, 0u32)  /* con0 counter: next.i - i - 1 */
    air_add_term(1u32, 1u32, 14u32, 2u32)  air_add_term(1u32, NEG1, 14u32, 1u32)                                       /* con1 link addr: is_store*(ap - i) */
    air_add_term(2u32, 1u32, 14u32, 3u32)  air_add_term(2u32, NEG7, 14u32, 1u32)                                       /* con2 link val: is_store*(vp - 7*i) */
    air_add_term(3u32, 1u32, 23u32, 0u32)  air_add_term(3u32, am, 8u32, 0u32)
    air_add_term(3u32, 1u32, 8u32, 2u32)   air_add_term(3u32, beta, 8u32, 3u32)  air_add_term(3u32, beta2, 8u32, 4u32) /* con3 perm_p */
    air_add_term(4u32, 1u32, 24u32, 0u32)  air_add_term(4u32, am, 9u32, 0u32)
    air_add_term(4u32, 1u32, 9u32, 5u32)   air_add_term(4u32, beta, 9u32, 6u32)  air_add_term(4u32, beta2, 9u32, 7u32) /* con4 perm_s */
    air_add_term(5u32, 1u32, 10u32, 0u32)  air_add_term(5u32, NEG1, 20u32, 0u32) air_add_term(5u32, 1u32, 5u32, 0u32)  /* con5 dm - as_next + as */
    air_add_term(6u32, 1u32, 12u32, 10u32)                                                                             /* con6 iz*dm */
    air_add_term(7u32, 1u32, 12u32, 0u32)  air_add_term(7u32, 1u32, 10u32, 11u32) air_add_term(7u32, NEG1, 0u32, 0u32) /* con7 iz + dm*wv - 1 */
    air_add_term(8u32, 1u32, 13u32, 0u32)  air_add_term(8u32, NEG1, 12u32, 21u32) air_add_term(8u32, 1u32, 12u32, 6u32)/* con8 ra - iz*(vs_next - vs) */
    air_add_term(9u32, 1u32, 13u32, 0u32)  air_add_term(9u32, NEG1, 22u32, 13u32)                                      /* con9 ra*(1 - ws_next) = read-consistency */
    air_add_term(10u32, 1u32, 10u32, 10u32) air_add_term(10u32, NEG1, 10u32, 0u32)                                     /* con10 dm in {0,1} */
    air_add_term(11u32, 1u32, 4u32, 4u32)  air_add_term(11u32, NEG1, 4u32, 0u32)                                       /* con11 wp bool */
    air_add_term(12u32, 1u32, 7u32, 7u32)  air_add_term(12u32, NEG1, 7u32, 0u32)                                       /* con12 ws bool */
    air_add_term(13u32, 1u32, 12u32, 12u32) air_add_term(13u32, NEG1, 12u32, 0u32)                                     /* con13 iz bool */
    air_add_term(14u32, 1u32, 14u32, 0u32) air_add_term(14u32, 1u32, 15u32, 0u32) air_add_term(14u32, NEG1, 0u32, 0u32)/* con14 is_store + is_load = 1 */
    air_add_term(15u32, 1u32, 14u32, 14u32) air_add_term(15u32, NEG1, 14u32, 0u32)                                     /* con15 is_store bool */
    air_add_term(16u32, 1u32, 15u32, 15u32) air_add_term(16u32, NEG1, 15u32, 0u32)                                     /* con16 is_load bool */
    let mut c : u64 = 0u64
    while c < 17u64 { air_set_alpha(c, (7u32 + (c as u32)*4u32))  c = c + 1u64 }
    air_add_boundary(0u32, 0u32, 0u32)                                          /* i_0 = 0 */
    air_add_boundary(7u32, 0u32, 1u32)  air_add_boundary(8u32, 0u32, 1u32)      /* acp_0 = acs_0 = 1 */
    air_add_boundary(7u32, 7u32, x)     air_add_boundary(8u32, 7u32, x)         /* acp_7 = acs_7 = X (permutation) */
    return x
}

fn main() -> u64 {
    /* (1) HONEST fused execution: control + compute + memory all hold -> the sound verifier ACCEPTS. */
    build()  air_stark_prove()
    if air_stark_verify() != 0u64 { return 1u64 }
    /* (2) FORGED LOAD value: mem[3] returns 99 (program row 6, its sorted image row 4) -> read-consistency REJECTS. */
    VP[6] = 99u32  VS[4] = 99u32
    build()  air_stark_prove()
    let fl : u64 = air_stark_verify()
    VP[6] = 21u32  VS[4] = 21u32
    if fl == 0u64 { return 2u64 }
    /* (3) FORGED COMPUTE: a store writes the wrong value (mem[3] = 99 instead of 7*3=21) -> the compute link
     * is_store*(vp - 7*i) REJECTS (the stored value is not 7*i). */
    VP[3] = 99u32  VS[3] = 99u32
    build()  air_stark_prove()
    let fc : u64 = air_stark_verify()
    VP[3] = 21u32  VS[3] = 21u32
    if fc == 0u64 { return 3u64 }
    /* (4) honest re-proves. */
    build()  air_stark_prove()
    if air_stark_verify() != 0u64 { return 4u64 }
    return 99u64
}
