/* sov_drive5.iii  --  the .bss COFF driver.  Assembles the REAL cg_r3 output for a module with a large
 * uninitialized array (`var BIG:[u64;64]; fn main(){return 99}`) -> a .text+.bss .o (.bss = 512 bytes,
 * uninitialized: SizeOfRawData set, PointerToRawData=0).  Gates .bss section emission.  Exit 0 = emitted.
 */
module sovtc_drive5

extern @abi(c-msvc-x64) fn sovparse_full(ptr: *u8, len: u32) -> i32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn sovcoff_emit() -> i32 from "sovcoff.iii"

fn slen(s: *u8) -> u32 { let mut i : u32 = 0u32  while i < 8192u32 { if s[i as u64] == 126u8 { return i }  i = i + 1u32 }  return 0u32 }

fn main() -> u64 {
    let src : *u8 = "  .section .bss\n  .global L_BIG\nL_BIG:\n  .zero 512\n  .text\n  .global main\nmain:\n  pushq %rbp\n  movq %rsp, %rbp\n  subq $1024, %rsp\n  movabsq $0x63, %rax\n  pushq %rax\n  popq %rax\n  movq %rbp, %rsp\n  popq %rbp\n  retq\n  movq $0, %rax\n  pushq %rax\n  movq $0, %rax\n  movq %rbp, %rsp\n  popq %rbp\n  retq\n~" as *u8
    let n : u32 = slen(src)
    if sovparse_full(src, n) != 0i32 { return 1u64 }
    sovcoff_emit()
    return 0u64
}
