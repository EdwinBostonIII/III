/* sovas_main.iii  --  the REAL sovereign assembler as a TOOL: `sovas_main <input.s>` reads a .s file from
 * disk (argv[1], CreateFileA/ReadFile) and writes a COFF .o to stdout (sovparse + sovcoff).  This is the
 * goodie that turns the unit-gates into an actual file-driven assembler -- it can be pointed at ANY real
 * cg_r3 emission, the first step toward assembling whole programs (and eventually the compiler) with no gas.
 * Exit: 2 = no argv, 3 = read failed, 4 = assembly error (LOUD), 0 = .o emitted to stdout. */
module sovtc_sovas_main

extern @abi(c-msvc-x64) fn CreateFileA(name: *u8, access: u32, share: u32, sec: u64, disp: u32, flags: u32, tmpl: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn ReadFile(h: u64, buf: *u8, n: u32, nread: u64, ovl: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn sovparse_full(ptr: *u8, len: u32) -> i32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn sovcoff_emit() -> i32 from "sovcoff.iii"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn sov_err_pos() -> u32 from "sovparse.iii"
/* DIAGNOSTIC: on a parse error, print the failing source line (from sov_err_pos's line-start offset) to stdout
 * (no .o is emitted on failure, so stdout is free).  Lets a sweep collect the exact first-unhandled construct. */
fn sm_print_fail() {
    let p : *u8 = (&SBUF) as *u8
    let mut i : u32 = sov_err_pos()
    let mut go : u32 = 1u32
    while go == 1u32 {
        if i >= SBUF_MAX { go = 0u32 }
        else { let c : u8 = p[i as u64]  if c == 10u8 { go = 0u32 } else { putchar(c as i32)  i = i + 1u32 } }
    }
    putchar(10i32)
}

const GENERIC_READ   : u32 = 0x80000000u32
const OPEN_EXISTING  : u32 = 3u32
const SHARE_READ     : u32 = 1u32
const ATTR_NORMAL    : u32 = 0x80u32
const INVALID_HANDLE : u64 = 0xFFFFFFFFFFFFFFFFu64
const SBUF_MAX       : u32 = 16777216u32   /* 16MB: the .s for a seed core file exceeds 1MB (parse.c .s ~1MB+; was 1048576 -> silently truncated -> capped .text -> crash) */

var NXFER : [u8; 8]
var SBUF  : [u8; 16777216]

fn read_file(path: *u8) -> u32 {
    let h : u64 = CreateFileA(path, GENERIC_READ, SHARE_READ, 0u64, OPEN_EXISTING, ATTR_NORMAL, 0u64)
    if h == INVALID_HANDLE { return 0u32 }
    let mut off : u32 = 0u32
    let mut go  : u32 = 1u32
    while go == 1u32 {
        let dst : *u8 = ((&SBUF as u64) + (off as u64)) as *u8
        let ok  : i32 = ReadFile(h, dst, SBUF_MAX - off, (&NXFER) as u64, 0u64)
        if ok == 0i32 { go = 0u32 }
        else {
            let p  : *u32 = (&NXFER) as *u32
            let nr : u32 = p[0u64]
            if nr == 0u32 { go = 0u32 }
            else { off = off + nr }
        }
    }
    CloseHandle(h)
    return off
}

fn main(argc: i32, argv: u64) -> u64 {
    let ac : i32 = argc
    if ac < 2i32 { return 2u64 }
    let pp   : *u64 = argv as *u64
    let path : *u8  = pp[1u64] as *u8
    let n    : u32  = read_file(path)
    if n == 0u32 { return 3u64 }
    if sovparse_full((&SBUF) as *u8, n) != 0i32 { sm_print_fail()  return 4u64 }
    sovcoff_emit()
    return 0u64
}
