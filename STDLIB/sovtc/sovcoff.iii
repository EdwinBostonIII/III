/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\sovtc\sovcoff.iii
 *
 * III sovereign toolchain -- the COFF .o EMITTER (assembler back-end).
 *
 * Turns sovas's assembled .text bytes (+ the in-memory reloc/symbol info) into a valid PE/COFF object that
 * gcc's ld accepts.  Emits to STDOUT (set to BINARY first, so 0x0A bytes are not \r\n-translated on Windows);
 * the caller redirects stdout to out.o.  This avoids fopen path/mode NUL-termination and module-array-address
 * pitfalls -- putchar takes an int.
 *
 * GATE-1 scope: a text-only object (one .text section, the exported function symbols, no relocations) -- the
 * minimal COFF proven (by stripping cg_r3's own .o) to link + run.  Relocations + data sections are the next
 * increment (REL records + .data/.rodata/.bss section symbols).
 *
 * NIH; reads sovas (.text) + sovparse (exports) + msvcrt (putchar/_setmode).  Ring R0.
 */
module sovtc_sovcoff

extern @abi(c-msvc-x64) fn sov_len() -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_at(i: u32) -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sp_export_n() -> u32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn sp_export_off(i: u32) -> u32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn sp_export_namelen(i: u32) -> u32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn sp_export_namebyte(i: u32, j: u32) -> u32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn putchar(c: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn _setmode(fd: i32, mode: i32) -> i32 from "msvcrt"

/* string table (for export names > 8 chars): the strings, accumulated during symbol emission, written last. */
var STR_BUF : [u8; 8192]
var STR_LEN : u32 = 0u32

fn w8(b: u32) { putchar((b & 0xFFu32) as i32) }
fn w16(v: u32) { w8(v)  w8(v >> 8u32) }
fn w32(v: u32) { w8(v)  w8(v >> 8u32)  w8(v >> 16u32)  w8(v >> 24u32) }

/* emit an 8-byte COFF symbol Name field: inline if <=8 chars, else 0x00000000 + a string-table offset. */
fn w_symname(eidx: u32) {
    let nl : u32 = sp_export_namelen(eidx)
    if nl <= 8u32 {
        let mut j : u32 = 0u32
        while j < 8u32 { if j < nl { w8(sp_export_namebyte(eidx, j)) } else { w8(0u32) }  j = j + 1u32 }
    } else {
        let off : u32 = 4u32 + STR_LEN           /* offset within the string table (incl. its 4-byte size) */
        w32(0u32)  w32(off)
        let mut j : u32 = 0u32
        while j < nl { STR_BUF[STR_LEN as u64] = sp_export_namebyte(eidx, j) as u8  STR_LEN = STR_LEN + 1u32  j = j + 1u32 }
        STR_BUF[STR_LEN as u64] = 0u8  STR_LEN = STR_LEN + 1u32
    }
}

/* emit the whole COFF object to (binary) stdout.  Returns 0. */
fn sovcoff_emit() -> i32 @export {
    _setmode(1i32, 0x8000i32)                    /* fd 1 = stdout -> _O_BINARY (no \n translation) */
    STR_LEN = 0u32
    let textlen : u32 = sov_len()
    let nexp : u32 = sp_export_n()
    let nsym : u32 = 2u32 + nexp                 /* .text section symbol + its aux + the exports */
    let symptr : u32 = 60u32 + textlen           /* symbol table follows 20-byte file hdr + 40-byte sec hdr + text */

    /* ── IMAGE_FILE_HEADER (20) ── */
    w16(0x8664u32)   /* Machine = AMD64 */
    w16(1u32)        /* NumberOfSections */
    w32(0u32)        /* TimeDateStamp */
    w32(symptr)      /* PointerToSymbolTable */
    w32(nsym)        /* NumberOfSymbols */
    w16(0u32)        /* SizeOfOptionalHeader */
    w16(0u32)        /* Characteristics */

    /* ── IMAGE_SECTION_HEADER for .text (40) ── */
    w8(46u32) w8(116u32) w8(101u32) w8(120u32) w8(116u32) w8(0u32) w8(0u32) w8(0u32)   /* ".text\0\0\0" */
    w32(0u32)            /* VirtualSize */
    w32(0u32)            /* VirtualAddress */
    w32(textlen)         /* SizeOfRawData */
    w32(60u32)           /* PointerToRawData */
    w32(0u32)            /* PointerToRelocations */
    w32(0u32)            /* PointerToLinenumbers */
    w16(0u32)            /* NumberOfRelocations */
    w16(0u32)            /* NumberOfLinenumbers */
    w32(0x60500020u32)   /* Characteristics: CODE | ALIGN_16BYTES | MEM_EXECUTE | MEM_READ */

    /* ── .text raw data ── */
    let mut i : u32 = 0u32
    while i < textlen { w8(sov_at(i))  i = i + 1u32 }

    /* ── symbol table ── */
    /* .text section symbol + aux */
    w8(46u32) w8(116u32) w8(101u32) w8(120u32) w8(116u32) w8(0u32) w8(0u32) w8(0u32)   /* ".text" */
    w32(0u32)  w16(1u32)  w16(0u32)  w8(3u32)  w8(1u32)    /* Value=0, Sec=1, Type=0, scl=STATIC(3), naux=1 */
    w32(textlen)  w16(0u32)  w16(0u32)  w32(0u32)  w16(0u32)  w8(0u32)  w8(0u32) w8(0u32) w8(0u32)   /* aux (18) */
    /* exported function symbols */
    let mut e : u32 = 0u32
    while e < nexp {
        w_symname(e)
        w32(sp_export_off(e))  w16(1u32)  w16(0u32)  w8(2u32)  w8(0u32)   /* Value=off, Sec=.text, scl=EXTERNAL(2) */
        e = e + 1u32
    }

    /* ── string table (size field + strings) ── */
    w32(4u32 + STR_LEN)
    let mut s : u32 = 0u32
    while s < STR_LEN { w8(STR_BUF[s as u64] as u32)  s = s + 1u32 }
    return 0i32
}
