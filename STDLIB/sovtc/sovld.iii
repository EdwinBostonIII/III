/* C:\Users\Edwin Boston\OneDrive\Desktop\III\STDLIB\sovtc\sovld.iii
 *
 * III sovereign toolchain -- sovld, the PE32+ LINKER/IMAGE WRITER (S2).  Replaces gcc's ld -- NO gcc, NO ld.
 * Emits a PE32+ executable to _O_BINARY stdout via putchar.
 *
 *   - multi-section: .text [+ .data] [+ .idata], section-aligned RVAs.
 *   - APPLY internal REL32 relocations (.data): disp = target_RVA - (field_RVA + 4).
 *   - IMPORTS, MULTI-DLL: externs are grouped by DLL (heuristic: a CamelCase/UPPER-first name is a Windows
 *     API -> kernel32; a lowercase-first name is a CRT fn -> msvcrt).  The .idata section holds one import
 *     descriptor per used DLL, each with its own ILT + IAT + DLL-name; one shared hint/name table; and a jump
 *     thunk per import appended to .text.  Data dirs IMPORT(1) + IAT(12).  The named E8 call's REL32 is patched
 *     to its thunk's RVA.  So a program importing from msvcrt AND kernel32 links + runs sovereignly.
 *   - entry = the `main` export (else .text+0); ret-only entries exit via RtlUserThreadStart.
 *
 * NIH; reads sovas (.text/.data/relocs/externs) + sovparse (exports) + msvcrt (putchar/_setmode).  Ring R0.
 */
module sovtc_sovld

extern @abi(c-msvc-x64) fn sov_len() -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_at(i: u32) -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_data_len(sec: u32) -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_bss_size() -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_data_at(sec: u32, i: u32) -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_reloc_n() -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_reloc_off(i: u32) -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_reloc_sec(i: u32) -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_reloc_sym(i: u32) -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_ext_n() -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_ext_namelen(slot: u32) -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_ext_namebyte(slot: u32, j: u32) -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sp_export_n() -> u32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn sp_export_off(i: u32) -> u32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn sp_export_namelen(i: u32) -> u32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn sp_export_namebyte(i: u32, j: u32) -> u32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn _setmode(fd: i32, mode: i32) -> i32 from "msvcrt"
extern @abi(c-msvc-x64) fn sov_putbyte(c: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_out_is_buffer() -> u32 from "sovas.iii"
/* linker-surface (sovas state append/patch) for the in-process multi-object MERGE driver below --
 * the same exports sovlink_main.iii drives; folded here so emit.iii (and sovlink_main) share ONE
 * definition of the merge. */
extern @abi(c-msvc-x64) fn sov_text_emit(b: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_data_emit(sec: u32, b: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_bss_add(n: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_patch(i: u32, b: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_rec_reloc_at(off: u32, sec: u32, sym: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_cn_clear() -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_cn_push(ch: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_ext_intern_pub() -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_reset() -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_data_reset() -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sp_export_inject(off: u32) -> i32 from "sovparse.iii"

var LDPOS : u32 = 0u32
var TEXTBUF : [u8; 8388608]   /* the whole .text, loaded for reloc patching -- seed modules reach 150-200KB code (was 16384) */
var EXT_DLL    : [u32; 4096]   /* DLL id per import -- indexed by k=sov_ext_n() ; seed modules have 100s of symbols (was 64 -> overflow at k>64) */
var EXT_HNRVA  : [u32; 4096]   /* hint/name RVA per import */
var EXT_IATRVA : [u32; 4096]   /* IAT-entry RVA per import */
/* per-DLL import layout, indexed by DLL id 0..NDLL-1 (kernel32 msvcrt user32 gdi32 ws2_32).  Sized [u32;8]
 * (headroom to 8) -- id 4 (ws2_32) overran the old [u32;4]; a program using user32/gdi32/ws2_32 needs all. */
const NDLL : u32 = 5u32
var DLL_USED   : [u32; 8]
var DLL_COUNT  : [u32; 8]
var DLL_ILTRVA : [u32; 8]
var DLL_IATRVA : [u32; 8]
var DLL_NAMERVA: [u32; 8]
var DLL_FILL   : [u32; 8]   /* running per-DLL import rank while assigning IAT-entry RVAs */

fn p8(b: u32) { sov_putbyte(b)  LDPOS = LDPOS + 1u32 }
fn p16(v: u32) { p8(v)  p8(v >> 8u32) }
fn p32(v: u32) { p8(v)  p8(v >> 8u32)  p8(v >> 16u32)  p8(v >> 24u32) }
fn p64(lo: u32, hi: u32) { p32(lo)  p32(hi) }
fn ppad(target: u32) { while LDPOS < target { p8(0u32) } }
fn alignup(v: u32, a: u32) -> u32 { return (v + (a - 1u32)) & (0u32 - a) }
fn wr32(off: u32, v: u32) {
    TEXTBUF[off as u64] = (v & 0xFFu32) as u8
    TEXTBUF[(off + 1u32) as u64] = ((v >> 8u32) & 0xFFu32) as u8
    TEXTBUF[(off + 2u32) as u64] = ((v >> 16u32) & 0xFFu32) as u8
    TEXTBUF[(off + 3u32) as u64] = ((v >> 24u32) & 0xFFu32) as u8
}
fn rd32(off: u32) -> u32 {
    return (TEXTBUF[off as u64] as u32) | ((TEXTBUF[(off + 1u32) as u64] as u32) << 8u32) | ((TEXTBUF[(off + 2u32) as u64] as u32) << 16u32) | ((TEXTBUF[(off + 3u32) as u64] as u32) << 24u32)
}
fn find_main_off() -> u32 {
    let mut e : u32 = 0u32
    while e < sp_export_n() {
        if sp_export_off(e) != 0xFFFFFFFFu32 { if sp_export_namelen(e) == 4u32 {
            if sp_export_namebyte(e, 0u32) == 109u32 { if sp_export_namebyte(e, 1u32) == 97u32 { if sp_export_namebyte(e, 2u32) == 105u32 { if sp_export_namebyte(e, 3u32) == 110u32 {
                return sp_export_off(e)
            } } } }
        } }
        e = e + 1u32
    }
    return 0u32
}
fn name_eq(slot: u32, lit: *u8, litlen: u32) -> u32 {
    if sov_ext_namelen(slot) != litlen { return 0u32 }
    let mut j : u32 = 0u32
    while j < litlen { if sov_ext_namebyte(slot, j) != (lit[j as u64] as u32) { return 0u32 }  j = j + 1u32 }
    return 1u32
}
/* DLL of an import (kernel32=0 msvcrt=1 user32=2 gdi32=3 ws2_32=4).  A TABLE of known functions (exact --
 * notably the lowercase kernel32 lstr* and the lowercase Winsock set a case-heuristic mis-routes), then the
 * case heuristic as a fallback for the rest.  The table is the MEASURED import surface of the tree's modules
 * (aether/net.iii sockets, aether/ui_win.iii + aether_world.iii + aether_lens_win.iii windows/GDI). */
fn ext_dll_of(slot: u32) -> u32 {
    /* ws2_32 (Winsock; all-lowercase names the heuristic would send to msvcrt) */
    if name_eq(slot, "WSAStartup" as *u8, 10u32) == 1u32 { return 4u32 }
    if name_eq(slot, "WSACleanup" as *u8, 10u32) == 1u32 { return 4u32 }
    if name_eq(slot, "socket" as *u8, 6u32) == 1u32 { return 4u32 }
    if name_eq(slot, "closesocket" as *u8, 11u32) == 1u32 { return 4u32 }
    if name_eq(slot, "connect" as *u8, 7u32) == 1u32 { return 4u32 }
    if name_eq(slot, "send" as *u8, 4u32) == 1u32 { return 4u32 }
    if name_eq(slot, "recv" as *u8, 4u32) == 1u32 { return 4u32 }
    if name_eq(slot, "htons" as *u8, 5u32) == 1u32 { return 4u32 }
    if name_eq(slot, "bind" as *u8, 4u32) == 1u32 { return 4u32 }
    if name_eq(slot, "listen" as *u8, 6u32) == 1u32 { return 4u32 }
    if name_eq(slot, "accept" as *u8, 6u32) == 1u32 { return 4u32 }
    /* user32 (window/message surface; incl. GetDC/ReleaseDC, whose Win32 home is user32 NOT gdi32) */
    if name_eq(slot, "CreateWindowExA" as *u8, 15u32) == 1u32 { return 2u32 }
    if name_eq(slot, "DefWindowProcA" as *u8, 14u32) == 1u32 { return 2u32 }
    if name_eq(slot, "DispatchMessageA" as *u8, 16u32) == 1u32 { return 2u32 }
    if name_eq(slot, "GetClientRect" as *u8, 13u32) == 1u32 { return 2u32 }
    if name_eq(slot, "GetDC" as *u8, 5u32) == 1u32 { return 2u32 }
    if name_eq(slot, "ReleaseDC" as *u8, 9u32) == 1u32 { return 2u32 }
    if name_eq(slot, "LoadCursorA" as *u8, 11u32) == 1u32 { return 2u32 }
    if name_eq(slot, "PeekMessageA" as *u8, 12u32) == 1u32 { return 2u32 }
    if name_eq(slot, "PostQuitMessage" as *u8, 15u32) == 1u32 { return 2u32 }
    if name_eq(slot, "RegisterClassA" as *u8, 14u32) == 1u32 { return 2u32 }
    if name_eq(slot, "RegisterClassExA" as *u8, 16u32) == 1u32 { return 2u32 }
    if name_eq(slot, "SetWindowTextA" as *u8, 14u32) == 1u32 { return 2u32 }
    if name_eq(slot, "ShowWindow" as *u8, 10u32) == 1u32 { return 2u32 }
    if name_eq(slot, "TranslateMessage" as *u8, 16u32) == 1u32 { return 2u32 }
    /* gdi32 (device-context drawing surface) */
    if name_eq(slot, "SetBkMode" as *u8, 9u32) == 1u32 { return 3u32 }
    if name_eq(slot, "SetTextColor" as *u8, 12u32) == 1u32 { return 3u32 }
    if name_eq(slot, "StretchDIBits" as *u8, 13u32) == 1u32 { return 3u32 }
    if name_eq(slot, "TextOutA" as *u8, 8u32) == 1u32 { return 3u32 }
    /* kernel32 (incl. lowercase lstr* the heuristic would wrongly send to msvcrt) */
    if name_eq(slot, "lstrlenA" as *u8, 8u32) == 1u32 { return 0u32 }
    if name_eq(slot, "lstrcpyA" as *u8, 8u32) == 1u32 { return 0u32 }
    if name_eq(slot, "lstrcatA" as *u8, 8u32) == 1u32 { return 0u32 }
    if name_eq(slot, "lstrcmpA" as *u8, 8u32) == 1u32 { return 0u32 }
    if name_eq(slot, "ExitProcess" as *u8, 11u32) == 1u32 { return 0u32 }
    if name_eq(slot, "GetTickCount" as *u8, 12u32) == 1u32 { return 0u32 }
    if name_eq(slot, "GetCurrentProcessId" as *u8, 19u32) == 1u32 { return 0u32 }
    if name_eq(slot, "GetStdHandle" as *u8, 12u32) == 1u32 { return 0u32 }
    if name_eq(slot, "WriteFile" as *u8, 9u32) == 1u32 { return 0u32 }
    if name_eq(slot, "ReadFile" as *u8, 8u32) == 1u32 { return 0u32 }
    if name_eq(slot, "CloseHandle" as *u8, 11u32) == 1u32 { return 0u32 }
    if name_eq(slot, "GetLastError" as *u8, 12u32) == 1u32 { return 0u32 }
    if name_eq(slot, "Sleep" as *u8, 5u32) == 1u32 { return 0u32 }
    if name_eq(slot, "GetProcAddress" as *u8, 14u32) == 1u32 { return 0u32 }
    if name_eq(slot, "LoadLibraryA" as *u8, 12u32) == 1u32 { return 0u32 }
    if name_eq(slot, "GetModuleHandleA" as *u8, 16u32) == 1u32 { return 0u32 }
    if name_eq(slot, "VirtualAlloc" as *u8, 12u32) == 1u32 { return 0u32 }
    if name_eq(slot, "VirtualFree" as *u8, 11u32) == 1u32 { return 0u32 }
    /* msvcrt (CRT) */
    if name_eq(slot, "putchar" as *u8, 7u32) == 1u32 { return 1u32 }
    if name_eq(slot, "puts" as *u8, 4u32) == 1u32 { return 1u32 }
    if name_eq(slot, "printf" as *u8, 6u32) == 1u32 { return 1u32 }
    if name_eq(slot, "malloc" as *u8, 6u32) == 1u32 { return 1u32 }
    if name_eq(slot, "free" as *u8, 4u32) == 1u32 { return 1u32 }
    if name_eq(slot, "memcpy" as *u8, 6u32) == 1u32 { return 1u32 }
    if name_eq(slot, "memset" as *u8, 6u32) == 1u32 { return 1u32 }
    if name_eq(slot, "strlen" as *u8, 6u32) == 1u32 { return 1u32 }
    if name_eq(slot, "fwrite" as *u8, 6u32) == 1u32 { return 1u32 }
    /* fallback: case heuristic (UPPER-first => kernel32, else msvcrt) */
    let c0 : u32 = sov_ext_namebyte(slot, 0u32)
    if c0 >= 65u32 { if c0 <= 90u32 { return 0u32 } }
    return 1u32
}
/* LINKER/KAT surface: the DLL-routing decision for an interned import slot, exported so a routing gate can
 * assert it (kernel32=0 msvcrt=1 user32=2 gdi32=3 ws2_32=4) without laying out a whole PE. */
fn sovld_ext_dll_of_pub(slot: u32) -> u32 @export { return ext_dll_of(slot) }
/* DLL-name string bytes + length by id: 0 kernel32.dll(13) 1 msvcrt.dll(11) 2 user32.dll(11) 3 gdi32.dll(10)
 * 4 ws2_32.dll(11) -- all NUL-terminated (lengths include the \0). */
fn dll_name_len(d: u32) -> u32 {
    if d == 0u32 { return 13u32 }   /* kernel32.dll\0 */
    if d == 3u32 { return 10u32 }   /* gdi32.dll\0 */
    return 11u32                    /* msvcrt.dll\0 / user32.dll\0 / ws2_32.dll\0 */
}
fn emit_dll_name(d: u32) {
    if d == 0u32 { p8(107u32) p8(101u32) p8(114u32) p8(110u32) p8(101u32) p8(108u32) p8(51u32) p8(50u32) p8(46u32) p8(100u32) p8(108u32) p8(108u32) p8(0u32)  return }   /* kernel32.dll */
    if d == 1u32 { p8(109u32) p8(115u32) p8(118u32) p8(99u32) p8(114u32) p8(116u32) p8(46u32) p8(100u32) p8(108u32) p8(108u32) p8(0u32)  return }                        /* msvcrt.dll */
    if d == 2u32 { p8(117u32) p8(115u32) p8(101u32) p8(114u32) p8(51u32) p8(50u32) p8(46u32) p8(100u32) p8(108u32) p8(108u32) p8(0u32)  return }                         /* user32.dll */
    if d == 3u32 { p8(103u32) p8(100u32) p8(105u32) p8(51u32) p8(50u32) p8(46u32) p8(100u32) p8(108u32) p8(108u32) p8(0u32)  return }                                    /* gdi32.dll */
    p8(119u32) p8(115u32) p8(50u32) p8(95u32) p8(51u32) p8(50u32) p8(46u32) p8(100u32) p8(108u32) p8(108u32) p8(0u32)                                                    /* ws2_32.dll */
}

/* ══ IN-PROCESS MULTI-OBJECT LINK DRIVER (independence C3) ═══════════════════════════════════════════
 * Folded from sovlink_main.iii so emit.iii can LINK loose COFF objects IN-PROCESS: read each .o into a
 * caller buffer, sovld_link_add_obj() merges its sections into sovas state + collects globals + stashes
 * cross-module relocs, sovld_link_finish() patches them, picks the entry (crt0 cstart else main), and
 * calls sovld_emit() to write the PE.  sovlink_main.iii is now a thin shell over this API (ONE
 * definition of the merge).  lk_-prefixed to avoid sovld's own rd32/wr32/find_main_off. */
var LK_OBJ : u64 = 0u64            /* current object buffer base */
var LK_NS     : u32 = 0u32
var LK_SYMPTR : u32 = 0u32
var LK_NSYM   : u32 = 0u32
var LK_SEC_ID    : [u32; 16]
var LK_SEC_RAWLEN: [u32; 16]
var LK_SEC_RAWPTR: [u32; 16]
var LK_SEC_RELPTR: [u32; 16]
var LK_SEC_NRELOC: [u32; 16]
var LK_GSYM_NAME : [u8; 1048576]
var LK_GSYM_NLEN : [u32; 16384]
var LK_GSYM_OFF  : [u32; 16384]
var LK_GSYM_N : u32 = 0u32
var LK_ST_OFF  : [u32; 65536]
var LK_ST_NAME : [u8; 4194304]
var LK_ST_NLEN : [u32; 65536]
var LK_ST_N : u32 = 0u32
var LK_NMBUF : [u8; 64]

fn lk_rd8(o: u32)  -> u32 { let p : *u8 = (LK_OBJ + (o as u64)) as *u8  return p[0u64] as u32 }
fn lk_rd16(o: u32) -> u32 { return lk_rd8(o) | (lk_rd8(o + 1u32) << 8u32) }
fn lk_rd32(o: u32) -> u32 { return lk_rd16(o) | (lk_rd16(o + 2u32) << 16u32) }
fn lk_secid(nameoff: u32) -> u32 {
    let b : u32 = lk_rd8(nameoff + 1u32)
    if b == 116u32 { return 0u32 }
    if b == 100u32 { return 1u32 }
    if b == 114u32 { return 2u32 }
    if b == 98u32  { return 3u32 }
    return 9u32
}
fn lk_parse_obj() {
    LK_NS = lk_rd16(2u32)  LK_SYMPTR = lk_rd32(8u32)  LK_NSYM = lk_rd32(12u32)
    let mut i : u32 = 0u32
    while i < LK_NS {
        let sh : u32 = 20u32 + (40u32 * i)
        LK_SEC_ID[i as u64]     = lk_secid(sh)
        LK_SEC_RAWLEN[i as u64] = lk_rd32(sh + 16u32)
        LK_SEC_RAWPTR[i as u64] = lk_rd32(sh + 20u32)
        LK_SEC_RELPTR[i as u64] = lk_rd32(sh + 24u32)
        LK_SEC_NRELOC[i as u64] = lk_rd16(sh + 32u32)
        i = i + 1u32
    }
}
fn lk_sym_name(idx: u32) -> u32 {
    let so : u32 = LK_SYMPTR + (idx * 18u32)
    if lk_rd32(so) == 0u32 {
        let stroff : u32 = (LK_SYMPTR + (LK_NSYM * 18u32)) + lk_rd32(so + 4u32)
        let mut n : u32 = 0u32  let mut go : u32 = 1u32
        while go == 1u32 { let c : u32 = lk_rd8(stroff + n)  if c == 0u32 { go = 0u32 } else { if n < 64u32 { LK_NMBUF[n as u64] = c as u8   n = n + 1u32 } else { go = 0u32 } } }
        return n
    }
    let mut n : u32 = 0u32  let mut go : u32 = 1u32
    while go == 1u32 {
        if n >= 8u32 { go = 0u32 }
        else { let c : u32 = lk_rd8(so + n)  if c == 0u32 { go = 0u32 } else { LK_NMBUF[n as u64] = c as u8  n = n + 1u32 } }
    }
    return n
}
fn lk_patch32(off: u32, v: u32) {
    sov_patch(off, v & 0xFFu32)  sov_patch(off + 1u32, (v >> 8u32) & 0xFFu32)
    sov_patch(off + 2u32, (v >> 16u32) & 0xFFu32)  sov_patch(off + 3u32, (v >> 24u32) & 0xFFu32)
}
fn lk_gsym_find(len: u32) -> u32 {
    let mut g : u32 = 0u32
    while g < LK_GSYM_N {
        if LK_GSYM_NLEN[g as u64] == len {
            let mut j : u32 = 0u32  let mut eq : u32 = 1u32
            while j < len { if LK_NMBUF[j as u64] != LK_GSYM_NAME[((g * 64u32) + j) as u64] { eq = 0u32  j = len } else { j = j + 1u32 } }
            if eq == 1u32 { return LK_GSYM_OFF[g as u64] }
        }
        g = g + 1u32
    }
    return 0xFFFFFFFFu32
}
fn lk_add_object() {
    lk_parse_obj()
    let tb : u32 = sov_len()
    let db : u32 = sov_data_len(1u32)
    let bb : u32 = sov_bss_size()
    let mut ti : u32 = 9u32  let mut di : u32 = 9u32  let mut ri : u32 = 9u32  let mut bi : u32 = 9u32
    let mut s : u32 = 0u32
    while s < LK_NS {
        let id : u32 = LK_SEC_ID[s as u64]
        if id == 0u32 { ti = s }  if id == 1u32 { di = s }  if id == 2u32 { ri = s }  if id == 3u32 { bi = s }
        s = s + 1u32
    }
    if ti != 9u32 { let n : u32 = LK_SEC_RAWLEN[ti as u64]  let p : u32 = LK_SEC_RAWPTR[ti as u64]  let mut i : u32 = 0u32  while i < n { sov_text_emit(lk_rd8(p + i))  i = i + 1u32 } }
    if di != 9u32 { let n : u32 = LK_SEC_RAWLEN[di as u64]  let p : u32 = LK_SEC_RAWPTR[di as u64]  let mut i : u32 = 0u32  while i < n { sov_data_emit(1u32, lk_rd8(p + i))  i = i + 1u32 } }
    let rob : u32 = sov_data_len(1u32)
    if ri != 9u32 { let n : u32 = LK_SEC_RAWLEN[ri as u64]  let p : u32 = LK_SEC_RAWPTR[ri as u64]  let mut i : u32 = 0u32  while i < n { sov_data_emit(1u32, lk_rd8(p + i))  i = i + 1u32 } }
    if bi != 9u32 { sov_bss_add(LK_SEC_RAWLEN[bi as u64]) }
    let mut k : u32 = 0u32
    while k < LK_NSYM {
        let so : u32 = LK_SYMPTR + (k * 18u32)
        let scl : u32 = lk_rd8(so + 16u32)
        let sec : u32 = lk_rd16(so + 12u32)
        let naux : u32 = lk_rd8(so + 17u32)
        if scl == 2u32 { if sec > 0u32 {
            let val : u32 = lk_rd32(so + 8u32)
            let id : u32 = LK_SEC_ID[(sec - 1u32) as u64]
            let nlen : u32 = lk_sym_name(k)
            if LK_GSYM_N < 16384u32 {
                let mut j : u32 = 0u32  while j < nlen { LK_GSYM_NAME[((LK_GSYM_N * 64u32) + j) as u64] = LK_NMBUF[j as u64]  j = j + 1u32 }
                LK_GSYM_NLEN[LK_GSYM_N as u64] = nlen
                let mut goff : u32 = tb + val
                if id == 1u32 { goff = db + val }  if id == 2u32 { goff = rob + val }  if id == 3u32 { goff = bb + val }
                LK_GSYM_OFF[LK_GSYM_N as u64] = goff
                LK_GSYM_N = LK_GSYM_N + 1u32
            }
        } }
        k = k + 1u32 + naux
    }
    if ti != 9u32 {
        let rp : u32 = LK_SEC_RELPTR[ti as u64]
        let nr : u32 = LK_SEC_NRELOC[ti as u64]
        let mut r : u32 = 0u32
        while r < nr {
            let ro : u32 = rp + (r * 10u32)
            let va : u32 = lk_rd32(ro)
            let symidx : u32 = lk_rd32(ro + 4u32)
            let merged : u32 = tb + va
            let so : u32 = LK_SYMPTR + (symidx * 18u32)
            let scl : u32 = lk_rd8(so + 16u32)
            let sec : u32 = lk_rd16(so + 12u32)
            if scl == 3u32 {
                let id : u32 = LK_SEC_ID[(sec - 1u32) as u64]
                let addend : u32 = lk_rd32(LK_SEC_RAWPTR[ti as u64] + va)
                if id == 0u32 { lk_patch32(merged, ((tb + addend) - (merged + 4u32))) }
                else {
                    let mut base : u32 = db  let mut rsec : u32 = 1u32
                    if id == 2u32 { base = rob }
                    if id == 3u32 { base = bb  rsec = 3u32 }
                    lk_patch32(merged, base + addend)
                    sov_rec_reloc_at(merged, rsec, 0xFFFFFFFFu32)
                }
            } else {
                if sec > 0u32 {
                    let val : u32 = lk_rd32(so + 8u32)
                    lk_patch32(merged, ((tb + val) - (merged + 4u32)))
                } else {
                    let nlen : u32 = lk_sym_name(symidx)
                    if LK_ST_N < 65536u32 {
                        LK_ST_OFF[LK_ST_N as u64] = merged
                        let mut j : u32 = 0u32  while j < nlen { LK_ST_NAME[((LK_ST_N * 64u32) + j) as u64] = LK_NMBUF[j as u64]  j = j + 1u32 }
                        LK_ST_NLEN[LK_ST_N as u64] = nlen
                        LK_ST_N = LK_ST_N + 1u32
                    }
                }
            }
            r = r + 1u32
        }
    }
}
fn lk_resolve() {
    let mut i : u32 = 0u32
    while i < LK_ST_N {
        let off : u32 = LK_ST_OFF[i as u64]
        let len : u32 = LK_ST_NLEN[i as u64]
        let mut j : u32 = 0u32  while j < len { LK_NMBUF[j as u64] = LK_ST_NAME[((i * 64u32) + j) as u64]  j = j + 1u32 }
        let tgt : u32 = lk_gsym_find(len)
        if tgt != 0xFFFFFFFFu32 { lk_patch32(off, (tgt - (off + 4u32))) }
        else {
            sov_cn_clear()
            let mut p : u32 = 0u32  while p < len { sov_cn_push(LK_NMBUF[p as u64])  p = p + 1u32 }
            sov_rec_reloc_at(off, 0u32, sov_ext_intern_pub())
        }
        i = i + 1u32
    }
}
fn lk_find(nm0: u32, nm1: u32, nm2: u32, nm3: u32, nm4: u32, nm5: u32, ln: u32) -> u32 {
    let mut g : u32 = 0u32
    while g < LK_GSYM_N {
        if LK_GSYM_NLEN[g as u64] == ln {
            let base : u32 = g * 64u32
            let mut ok : u32 = 1u32
            if LK_GSYM_NAME[base as u64] != (nm0 as u8) { ok = 0u32 }
            if ln > 1u32 { if LK_GSYM_NAME[(base + 1u32) as u64] != (nm1 as u8) { ok = 0u32 } }
            if ln > 2u32 { if LK_GSYM_NAME[(base + 2u32) as u64] != (nm2 as u8) { ok = 0u32 } }
            if ln > 3u32 { if LK_GSYM_NAME[(base + 3u32) as u64] != (nm3 as u8) { ok = 0u32 } }
            if ln > 4u32 { if LK_GSYM_NAME[(base + 4u32) as u64] != (nm4 as u8) { ok = 0u32 } }
            if ln > 5u32 { if LK_GSYM_NAME[(base + 5u32) as u64] != (nm5 as u8) { ok = 0u32 } }
            if ok == 1u32 { return LK_GSYM_OFF[g as u64] }
        }
        g = g + 1u32
    }
    return 0xFFFFFFFFu32
}

/* PUBLIC in-process link API (emit.iii + sovlink_main drive these): reset, add each object buffer, finish. */
fn sovld_link_reset() -> i32 @export { LK_GSYM_N = 0u32  LK_ST_N = 0u32  sov_reset()  sov_data_reset()  return 0i32 }
fn sovld_link_add_obj(buf: u64, len: u32) -> i32 @export { LK_OBJ = buf  lk_add_object()  return 0i32 }
fn sovld_link_finish() -> i32 @export {
    lk_resolve()
    let mut entry : u32 = lk_find(99u32,115u32,116u32,97u32,114u32,116u32,6u32)   /* cstart (crt0 argv shim) */
    if entry == 0xFFFFFFFFu32 { entry = lk_find(109u32,97u32,105u32,110u32,0u32,0u32,4u32) }  /* main */
    if entry == 0xFFFFFFFFu32 { entry = 0u32 }
    sp_export_inject(entry)
    return sovld_emit()
}

fn sovld_emit() -> i32 @export {
    if sov_out_is_buffer() == 0u32 { _setmode(1i32, 0x8000i32) }   /* only touch stdout when actually writing to it */
    LDPOS = 0u32
    let textlen : u32 = sov_len()
    let mut i : u32 = 0u32
    while i < textlen { TEXTBUF[i as u64] = sov_at(i) as u8  i = i + 1u32 }

    let k : u32 = sov_ext_n()
    let new_textlen : u32 = textlen + (k * 6u32)
    let text_rva : u32 = 0x1000u32
    let text_mem : u32 = alignup(new_textlen, 0x1000u32)
    let text_raw : u32 = alignup(new_textlen, 0x200u32)

    let datalen : u32 = sov_data_len(1u32)
    let mut has_data : u32 = 0u32
    if datalen > 0u32 { has_data = 1u32 }
    let mut has_idata : u32 = 0u32
    if k > 0u32 { has_idata = 1u32 }

    let mut cur_rva : u32 = text_rva + text_mem
    let mut data_rva : u32 = 0u32
    let data_mem : u32 = alignup(datalen, 0x1000u32)
    if has_data == 1u32 { data_rva = cur_rva  cur_rva = cur_rva + data_mem }

    /* ── classify imports by DLL + lay out .idata ── */
    let mut idata_rva : u32 = 0u32
    let mut idata_len : u32 = 0u32
    let mut idt_rva : u32 = 0u32
    let mut dnum : u32 = 0u32
    let mut iat_total : u32 = 0u32
    let mut iat_dir_rva : u32 = 0u32
    if has_idata == 1u32 {
        idata_rva = cur_rva
        idt_rva = idata_rva
        let mut d : u32 = 0u32                                  /* zero ALL NDLL slots (id 2/3/4 must start clean) */
        while d < NDLL { DLL_USED[d as u64] = 0u32  DLL_COUNT[d as u64] = 0u32  DLL_FILL[d as u64] = 0u32  d = d + 1u32 }
        i = 0u32
        while i < k { let dm : u32 = ext_dll_of(i)  EXT_DLL[i as u64] = dm  DLL_USED[dm as u64] = 1u32  DLL_COUNT[dm as u64] = DLL_COUNT[dm as u64] + 1u32  i = i + 1u32 }
        dnum = 0u32                                             /* count of DISTINCT used DLLs (summed, not hardcoded 2) */
        d = 0u32
        while d < NDLL { dnum = dnum + DLL_USED[d as u64]  d = d + 1u32 }
        let mut cur : u32 = idata_rva + ((dnum + 1u32) * 20u32)
        d = 0u32                                                /* ILTs, in id order */
        while d < NDLL { if DLL_USED[d as u64] == 1u32 { DLL_ILTRVA[d as u64] = cur  cur = cur + ((DLL_COUNT[d as u64] + 1u32) * 8u32) }  d = d + 1u32 }
        iat_dir_rva = cur                                       /* IAT data-directory base = first used DLL's IAT RVA */
        d = 0u32                                                /* IATs (contiguous, id order) */
        while d < NDLL { if DLL_USED[d as u64] == 1u32 { DLL_IATRVA[d as u64] = cur  iat_total = iat_total + ((DLL_COUNT[d as u64] + 1u32) * 8u32)  cur = cur + ((DLL_COUNT[d as u64] + 1u32) * 8u32) }  d = d + 1u32 }
        i = 0u32                                                /* per-import IAT-entry RVA = its DLL's IAT + rank*8 */
        while i < k {
            let dm : u32 = EXT_DLL[i as u64]
            EXT_IATRVA[i as u64] = DLL_IATRVA[dm as u64] + (DLL_FILL[dm as u64] * 8u32)
            DLL_FILL[dm as u64] = DLL_FILL[dm as u64] + 1u32
            i = i + 1u32
        }
        i = 0u32                                                /* hint/name RVAs */
        while i < k { EXT_HNRVA[i as u64] = cur  cur = cur + alignup(2u32 + sov_ext_namelen(i) + 1u32, 2u32)  i = i + 1u32 }
        d = 0u32                                                /* DLL-name RVAs, id order */
        while d < NDLL { if DLL_USED[d as u64] == 1u32 { DLL_NAMERVA[d as u64] = cur  cur = cur + dll_name_len(d) }  d = d + 1u32 }
        idata_len = cur - idata_rva
        cur_rva = cur_rva + alignup(idata_len, 0x1000u32)
    }
    /* ── .bss: uninitialized data, virtual-only (no file bytes).  sovld dropped it before -> any program with a
     * large .bss (boot7's 1MB array, sovas's ~5MB buffers) accessed unmapped memory -> segfault. ── */
    let bsslen : u32 = sov_bss_size()
    let mut has_bss : u32 = 0u32
    if bsslen > 0u32 { has_bss = 1u32 }
    let mut bss_rva : u32 = 0u32
    if has_bss == 1u32 { bss_rva = cur_rva  cur_rva = cur_rva + alignup(bsslen, 0x1000u32) }
    let size_of_image : u32 = cur_rva

    /* ── generate thunks (FF 25 jmp *[IAT-entry]) + patch relocations ── */
    let mut s2 : u32 = 0u32
    while s2 < k {
        let toff : u32 = textlen + (s2 * 6u32)
        let thunk_rva : u32 = text_rva + toff
        TEXTBUF[toff as u64] = 0xFFu8  TEXTBUF[(toff + 1u32) as u64] = 0x25u8
        wr32(toff + 2u32, EXT_IATRVA[s2 as u64] - (thunk_rva + 6u32))
        s2 = s2 + 1u32
    }
    let nreloc : u32 = sov_reloc_n()
    let mut r : u32 = 0u32
    while r < nreloc {
        let rsec : u32 = sov_reloc_sec(r)
        let roff : u32 = sov_reloc_off(r)
        if rsec == 1u32 { wr32(roff, (data_rva + rd32(roff)) - ((text_rva + roff) + 4u32)) }
        if rsec == 0u32 { wr32(roff, (text_rva + textlen + (sov_reloc_sym(r) * 6u32)) - ((text_rva + roff) + 4u32)) }
        if rsec == 3u32 { wr32(roff, (bss_rva + rd32(roff)) - ((text_rva + roff) + 4u32)) }   /* .bss rip-relative */
        r = r + 1u32
    }

    let entry_rva : u32 = text_rva + find_main_off()
    let nsec : u32 = ((1u32 + has_data) + has_idata) + has_bss
    let mut cur_file : u32 = 0x200u32 + text_raw
    let data_raw : u32 = alignup(datalen, 0x200u32)
    let mut data_fileptr : u32 = 0u32
    if has_data == 1u32 { data_fileptr = cur_file  cur_file = cur_file + data_raw }
    let idata_raw : u32 = alignup(idata_len, 0x200u32)
    let mut idata_fileptr : u32 = 0u32
    if has_idata == 1u32 { idata_fileptr = cur_file  cur_file = cur_file + idata_raw }

    /* ── headers ── */
    p8(77u32) p8(90u32)  ppad(0x3Cu32)  p32(0x40u32)
    p8(80u32) p8(69u32) p8(0u32) p8(0u32)
    p16(0x8664u32)  p16(nsec)  p32(0u32)  p32(0u32)  p32(0u32)  p16(0xF0u32)  p16(0x23u32)
    p16(0x20Bu32)  p8(14u32) p8(0u32)
    p32(text_raw)  p32(data_raw + idata_raw)  p32(0u32)
    p32(entry_rva)  p32(text_rva)
    p64(0x40000000u32, 1u32)
    p32(0x1000u32)  p32(0x200u32)
    p16(6u32) p16(0u32)  p16(0u32) p16(0u32)  p16(6u32) p16(0u32)
    p32(0u32)  p32(size_of_image)  p32(0x200u32)  p32(0u32)
    p16(3u32)  p16(0u32)
    p64(0x100000u32, 0u32)  p64(0x1000u32, 0u32)  p64(0x100000u32, 0u32)  p64(0x1000u32, 0u32)
    p32(0u32)  p32(16u32)
    let mut dd : u32 = 0u32
    while dd < 16u32 {
        if has_idata == 1u32 {
            if dd == 1u32 { p32(idt_rva)  p32((dnum + 1u32) * 20u32) }       /* IMPORT */
            else { if dd == 12u32 { p32(iat_dir_rva)  p32(iat_total) }       /* IAT (first used DLL's IAT) */
            else { p32(0u32)  p32(0u32) } }
        } else { p32(0u32)  p32(0u32) }
        dd = dd + 1u32
    }

    /* ── section headers ── */
    p8(46u32) p8(116u32) p8(101u32) p8(120u32) p8(116u32) p8(0u32) p8(0u32) p8(0u32)   /* .text */
    p32(new_textlen)  p32(text_rva)  p32(text_raw)  p32(0x200u32)  p32(0u32)  p32(0u32)  p16(0u32)  p16(0u32)  p32(0x60000020u32)
    if has_data == 1u32 {
        p8(46u32) p8(100u32) p8(97u32) p8(116u32) p8(97u32) p8(0u32) p8(0u32) p8(0u32)   /* .data */
        p32(datalen)  p32(data_rva)  p32(data_raw)  p32(data_fileptr)  p32(0u32)  p32(0u32)  p16(0u32)  p16(0u32)  p32(0xC0000040u32)
    }
    if has_idata == 1u32 {
        p8(46u32) p8(105u32) p8(100u32) p8(97u32) p8(116u32) p8(97u32) p8(0u32) p8(0u32)   /* .idata */
        p32(idata_len)  p32(idata_rva)  p32(idata_raw)  p32(idata_fileptr)  p32(0u32)  p32(0u32)  p16(0u32)  p16(0u32)  p32(0xC0000040u32)
    }
    if has_bss == 1u32 {
        p8(46u32) p8(98u32) p8(115u32) p8(115u32) p8(0u32) p8(0u32) p8(0u32) p8(0u32)   /* .bss */
        p32(bsslen)  p32(bss_rva)  p32(0u32)  p32(0u32)  p32(0u32)  p32(0u32)  p16(0u32)  p16(0u32)  p32(0xC0000080u32)   /* UNINIT|R|W, no raw data */
    }

    /* ── raw data ── */
    ppad(0x200u32)
    i = 0u32  while i < new_textlen { p8(TEXTBUF[i as u64] as u32)  i = i + 1u32 }
    ppad(0x200u32 + text_raw)
    if has_data == 1u32 {
        i = 0u32  while i < datalen { p8(sov_data_at(1u32, i))  i = i + 1u32 }
        ppad(data_fileptr + data_raw)
    }
    if has_idata == 1u32 {
        /* IDT: one descriptor per used DLL (id order 0..NDLL-1), then a null descriptor */
        let mut d : u32 = 0u32
        while d < NDLL { if DLL_USED[d as u64] == 1u32 { p32(DLL_ILTRVA[d as u64])  p32(0u32)  p32(0u32)  p32(DLL_NAMERVA[d as u64])  p32(DLL_IATRVA[d as u64]) }  d = d + 1u32 }
        p32(0u32)  p32(0u32)  p32(0u32)  p32(0u32)  p32(0u32)
        /* ILTs: per used DLL, its imports' hint/name RVAs + null */
        d = 0u32
        while d < NDLL { if DLL_USED[d as u64] == 1u32 {
            i = 0u32  while i < k { if EXT_DLL[i as u64] == d { p64(EXT_HNRVA[i as u64], 0u32) }  i = i + 1u32 }
            p64(0u32, 0u32)
        } d = d + 1u32 }
        /* IATs: identical (loader overwrites) */
        d = 0u32
        while d < NDLL { if DLL_USED[d as u64] == 1u32 {
            i = 0u32  while i < k { if EXT_DLL[i as u64] == d { p64(EXT_HNRVA[i as u64], 0u32) }  i = i + 1u32 }
            p64(0u32, 0u32)
        } d = d + 1u32 }
        /* hint/name table (all imports) */
        i = 0u32
        while i < k {
            p16(0u32)
            let nl : u32 = sov_ext_namelen(i)
            let mut j : u32 = 0u32
            while j < nl { p8(sov_ext_namebyte(i, j))  j = j + 1u32 }
            p8(0u32)
            if ((2u32 + nl + 1u32) & 1u32) == 1u32 { p8(0u32) }
            i = i + 1u32
        }
        /* DLL name strings (per used DLL, id order 0..NDLL-1) */
        d = 0u32
        while d < NDLL { if DLL_USED[d as u64] == 1u32 { emit_dll_name(d) }  d = d + 1u32 }
        ppad(idata_fileptr + idata_raw)
    }
    return 0i32
}
