/* sovlink_main.iii -- the SOVEREIGN MULTI-OBJECT LINKER as a TOOL: `sovlink_main a.o b.o ... > out.exe`.
 * Reads N sov-emitted COFF .o and drives the in-process link DRIVER now folded into sovld.iii
 * (sovld_link_reset / sovld_link_add_obj / sovld_link_finish) -- ONE definition of the merge, shared with
 * emit.iii's in-process sovereign link (independence C3).  This file is a thin file-I/O shell: read each
 * object into a buffer, hand it to the driver, finish (which picks the entry + emits the PE via sovld_emit).
 *   .rodata is folded into .data (sovld has no .rodata section).  NO gcc/ld/gas. */
module sovtc_sovlink_main

extern @abi(c-msvc-x64) fn CreateFileA(name: *u8, access: u32, share: u32, sec: u64, disp: u32, flags: u32, tmpl: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn ReadFile(h: u64, buf: *u8, n: u32, nread: u64, ovl: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn sovld_link_reset() -> i32 from "sovld.iii"
extern @abi(c-msvc-x64) fn sovld_link_add_obj(buf: u64, len: u32) -> i32 from "sovld.iii"
extern @abi(c-msvc-x64) fn sovld_link_finish() -> i32 from "sovld.iii"

const GENERIC_READ : u32 = 0x80000000u32
const OPEN_EXISTING : u32 = 3u32

var OBJBUF : [u8; 8388608]
var NXFER  : u32 = 0u32

fn read_file(path: *u8) -> u32 {
    let h : u64 = CreateFileA(path, GENERIC_READ, 1u32, 0u64, OPEN_EXISTING, 0u32, 0u64)
    if h == 0xFFFFFFFFFFFFFFFFu64 { return 0u32 }
    let mut off : u32 = 0u32  let mut go : u32 = 1u32
    while go == 1u32 {
        let dst : *u8 = ((&OBJBUF as u64) + (off as u64)) as *u8
        let ok : i32 = ReadFile(h, dst, 8388608u32 - off, (&NXFER) as u64, 0u64)
        if ok == 0i32 { go = 0u32 } else { if NXFER == 0u32 { go = 0u32 } else { off = off + NXFER } }
    }
    CloseHandle(h)
    return off
}

fn main(argc: i32, argv: u64) -> u64 {
    if argc < 2i32 { return 2u64 }
    let pp : *u64 = argv as *u64
    let ac : u32 = argc as u32
    sovld_link_reset()
    let mut a : u32 = 1u32
    while a < ac {
        let path : *u8 = pp[a as u64] as *u8
        let n : u32 = read_file(path)
        if n == 0u32 { return 3u64 }
        sovld_link_add_obj((&OBJBUF) as u64, n)
        a = a + 1u32
    }
    sovld_link_finish()
    return 0u64
}
