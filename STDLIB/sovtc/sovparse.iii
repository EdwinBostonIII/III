/* ASCII (numeric, to avoid any char-literal assumptions) */
const C_SP : u32 = 32u32
const C_TAB: u32 = 9u32
const C_NL : u32 = 10u32
const C_CR : u32 = 13u32
const C_HASH:u32 = 35u32
const C_DOT: u32 = 46u32
const C_COLON:u32 = 58u32
const C_PCT: u32 = 37u32   /* % */
const C_DOL: u32 = 36u32   /* $ */
const C_LP : u32 = 40u32   /* ( */
const C_RP : u32 = 41u32   /* ) */
const C_COM: u32 = 44u32   /* , */
const C_MIN: u32 = 45u32   /* - */
const C_0  : u32 = 48u32
const C_9  : u32 = 57u32
const C_x  : u32 = 120u32
const C_a  : u32 = 97u32
const C_z  : u32 = 122u32

var IN_PTR : u64 = 0u64
var IN_LEN : u32 = 0u32
var IN_POS : u32 = 0u32
var CUR_OFF : u32 = 0u32   /* DIAGNOSTIC: byte offset of the last line start parsed before PARSE_ERR fired */
fn sov_err_pos() -> u32 @export { return CUR_OFF }

const C_US : u32 = 95u32   /* _ */
const C_AU : u32 = 65u32   /* A */
const C_ZU : u32 = 90u32   /* Z */

/* operand decode registers: kind 0=reg 1=imm 2=mem(disp(base)) 3=sym(%rip) */
var OPK : u32 = 0u32
var OPR : u32 = 0u32      /* register (or mem base) */
var OPD : i32 = 0i32      /* mem displacement */
var OPI : i64 = 0i64      /* immediate */
var OPSEC : u32 = 0u32    /* sym(%rip): resolved target section */
var OPOFF : i32 = 0i32    /* sym(%rip): resolved offset within that section (the disp32 addend) */
var OPINDEX : u32 = 0u32  /* SIB (OPK=4): index register */
var OPSCALE : u32 = 1u32  /* SIB: scale (1/2/4/8) */
var VW : u32 = 0u32       /* vector-register width of the last %xmm/%ymm/%zmm parsed: 0=xmm(128) 1=ymm(256) 2=zmm(512) */

/* the data-symbol table (pass 1).  section ids: TEXT=0 DATA=1 RODATA=2 BSS=3 OTHER=9. */
const SEC_TEXT : u32 = 0u32
const SEC_DATA : u32 = 1u32
const SEC_RODATA : u32 = 2u32
const SEC_BSS : u32 = 3u32
const SEC_OTHER : u32 = 9u32
var SYM_NAME : [u8; 524288]   /* flat name bytes, 64 per slot (32 truncated 33-char import names) */
var SYM_NLEN : [u32; 8192]
var SYM_SEC  : [u32; 8192]
var SYM_OFF  : [u32; 8192]
var SYM_N    : u32 = 0u32
var SEC_OFF  : [u32; 4]      /* running byte offset per section (TEXT/DATA/RODATA/BSS) */
var CUR_SEC  : u32 = 9u32

/* .text label byte-offset table (for branch + sibling-call resolution), built in the LAYOUT pass. */
var LBL_NAME : [u8; 524288]   /* 8192 slots * 64 */
var LBL_NLEN : [u32; 8192]
var LBL_OFF  : [u32; 8192]
var LBL_N    : u32 = 0u32
var SP_PASS  : u32 = 2u32     /* 1 = layout (record label offsets), 2 = final (resolve displacements) */

fn lbl_record(slot: u32, slen2: u32) {   /* the label name is in SYM_NAME scratch slot 'slot' */
    if LBL_N < 8192u32 {   /* match the LBL array size (was a 64 dev-scaffold cap; cg_r3 has 998 .text labels) */
        let mut j : u32 = 0u32
        while j < slen2 { LBL_NAME[((LBL_N * 64u32) + j) as u64] = SYM_NAME[((slot * 64u32) + j) as u64]  j = j + 1u32 }
        LBL_NLEN[LBL_N as u64] = slen2
        LBL_OFF[LBL_N as u64] = sov_len()
        LBL_N = LBL_N + 1u32
    }
}
fn lbl_name_eq(slot: u32, slen2: u32, lidx: u32) -> u32 {
    if LBL_NLEN[lidx as u64] != slen2 { return 0u32 }
    let mut j : u32 = 0u32
    while j < slen2 { if SYM_NAME[((slot * 64u32) + j) as u64] != LBL_NAME[((lidx * 64u32) + j) as u64] { return 0u32 }  j = j + 1u32 }
    return 1u32
}
fn lbl_find(slot: u32, slen2: u32) -> u32 {   /* return the .text offset of the label, or 0xFFFFFFFF */
    let mut i : u32 = 0u32
    while i < LBL_N { if lbl_name_eq(slot, slen2, i) == 1u32 { return LBL_OFF[i as u64] }  i = i + 1u32 }
    return 0xFFFFFFFFu32
}

/* exported symbols (.global names) -- the COFF defined-external symbols.  Names recorded in pass D, .text
 * offsets resolved from LBL after the layout pass. */
var EXP_NAME : [u8; 131072]   /* 2048 slots * 64 */
var EXP_NLEN : [u32; 2048]
var EXP_OFF  : [u32; 2048]
var EXP_SEC  : [u32; 2048]   /* section id per export (TEXT=0 DATA=1 RODATA=2 BSS=3): cg_r3 marks every module-var .global, so data globals are REAL COFF exports, not only .text fns */
var EXP_N    : u32 = 0u32
fn exp_record(slot: u32, slen2: u32) {
    if EXP_N < 2048u32 {   /* match the EXP array size (was a 32 dev-scaffold cap; cg_r3 has 340 .global) */
        let mut j : u32 = 0u32
        while j < slen2 { EXP_NAME[((EXP_N * 64u32) + j) as u64] = SYM_NAME[((slot * 64u32) + j) as u64]  j = j + 1u32 }
        EXP_NLEN[EXP_N as u64] = slen2  EXP_SEC[EXP_N as u64] = 0u32  EXP_N = EXP_N + 1u32   /* sec fixed up after layout; explicit 0 clears stale cross-run state */
    }
}
fn sp_export_n() -> u32 @export { return EXP_N }
fn sp_export_off(i: u32) -> u32 @export { if i < EXP_N { return EXP_OFF[i as u64] }  return 0xFFFFFFFFu32 }
fn sp_export_namelen(i: u32) -> u32 @export { if i < EXP_N { return EXP_NLEN[i as u64] }  return 0u32 }
fn sp_export_namebyte(i: u32, j: u32) -> u32 @export { if i < EXP_N { if j < EXP_NLEN[i as u64] { return EXP_NAME[((i * 64u32) + j) as u64] as u32 } }  return 0u32 }
fn sp_export_sec(i: u32) -> u32 @export { if i < EXP_N { return EXP_SEC[i as u64] }  return 0u32 }
/* LINKER: register an export named "main" at off, so sovld's find_main_off picks up the merged entry point. */
fn sp_export_inject(off: u32) -> i32 @export {
    if EXP_N < 2048u32 {
        EXP_NAME[(EXP_N * 64u32) as u64] = 109u8
        EXP_NAME[((EXP_N * 64u32) + 1u32) as u64] = 97u8
        EXP_NAME[((EXP_N * 64u32) + 2u32) as u64] = 105u8
        EXP_NAME[((EXP_N * 64u32) + 3u32) as u64] = 110u8
        EXP_NLEN[EXP_N as u64] = 4u32  EXP_OFF[EXP_N as u64] = off  EXP_SEC[EXP_N as u64] = 0u32  EXP_N = EXP_N + 1u32
    }
    return 0i32
}

fn is_ident_start(c: u32) -> u32 {
    if c == C_US { return 1u32 }
    if is_lower(c) == 1u32 { return 1u32 }
    if c >= C_AU { if c <= C_ZU { return 1u32 } }
    return 0u32
}
fn is_ident(c: u32) -> u32 {
    if is_ident_start(c) == 1u32 { return 1u32 }
    if is_digit(c) == 1u32 { return 1u32 }
    return 0u32
}
/* read an identifier at the cursor into a 32-byte slot at SYM_N (not yet committed); return its length */
fn sp_read_name_into(slot: u32) -> u32 {
    let mut n : u32 = 0u32
    while is_ident(sp_ch()) == 1u32 {
        if n < 64u32 { SYM_NAME[((slot * 64u32) + n) as u64] = sp_ch() as u8  n = n + 1u32 }
        sp_adv()
    }
    return n
}
fn sp_names_eq(slot: u32, alen: u32, blot: u32, blen: u32) -> u32 {
    if alen != blen { return 0u32 }
    let mut i : u32 = 0u32
    while i < alen {
        if SYM_NAME[((slot * 64u32) + i) as u64] != SYM_NAME[((blot * 64u32) + i) as u64] { return 0u32 }
        i = i + 1u32
    }
    return 1u32
}

fn sp_ch() -> u32 {
    if IN_POS < IN_LEN { let p : *u8 = IN_PTR as *u8  return p[IN_POS as u64] as u32 }
    return 0u32
}
fn sp_ch1() -> u32 {
    let n : u32 = IN_POS + 1u32
    if n < IN_LEN { let p : *u8 = IN_PTR as *u8  return p[n as u64] as u32 }
    return 0u32
}
fn sp_adv() { IN_POS = IN_POS + 1u32 }
fn sp_skip_ws() { while sp_ch() == C_SP { sp_adv() }  while sp_ch() == C_TAB { sp_adv() }
    let mut g : u32 = 1u32
    while g == 1u32 { if sp_ch() == C_SP { sp_adv() } else { if sp_ch() == C_TAB { sp_adv() } else { g = 0u32 } } } }
fn sp_skip_line() { while IN_POS < IN_LEN { let c : u32 = sp_ch()  sp_adv()  if c == C_NL { return } } }

fn is_digit(c: u32) -> u32 { if c >= C_0 { if c <= C_9 { return 1u32 } }  return 0u32 }
fn is_lower(c: u32) -> u32 { if c >= C_a { if c <= C_z { return 1u32 } }  return 0u32 }
fn hexv(c: u32) -> u32 {
    if c >= C_0 { if c <= C_9 { return c - C_0 } }
    if c >= C_a { if c <= (C_a + 5u32) { return (c - C_a) + 10u32 } }   /* a..f */
    if c >= 65u32 { if c <= 70u32 { return (c - 65u32) + 10u32 } }      /* A..F (hand-written asm: $0xB1) */
    return 0u32
}

/* parse a signed number (decimal, or 0x-hex) at the cursor */
fn sp_num() -> i64 {
    let mut neg : u32 = 0u32
    if sp_ch() == C_MIN { neg = 1u32  sp_adv() }
    let mut val : i64 = 0i64
    if sp_ch() == C_0 { if sp_ch1() == C_x {
        sp_adv()  sp_adv()
        let mut g : u32 = 1u32
        while g == 1u32 {
            let c : u32 = sp_ch()
            let mut ish : u32 = 0u32
            if is_digit(c) == 1u32 { ish = 1u32 }
            if c >= C_a { if c <= (C_a + 5u32) { ish = 1u32 } }
            if c >= 65u32 { if c <= 70u32 { ish = 1u32 } }   /* A..F uppercase hex */
            if ish == 1u32 { val = (val * 16i64) + (hexv(c) as i64)  sp_adv() } else { g = 0u32 }
        }
        if neg == 1u32 { return 0i64 - val }
        return val
    } }
    while is_digit(sp_ch()) == 1u32 { val = (val * 10i64) + ((sp_ch() - C_0) as i64)  sp_adv() }
    if neg == 1u32 { return 0i64 - val }
    return val
}

/* map a register name (cursor just past '%') to its number 0..15; advance past the FULL name.
 * Handles 8/16/32/64-bit (al/ax/eax/rax all = 0) and r8..r15 (+ optional d/w/b size suffix). */
fn sp_rc(c: u32) -> u32 { if is_lower(c) == 1u32 { return 1u32 }  if is_digit(c) == 1u32 { return 1u32 }  return 0u32 }
fn sp_reg() -> u32 {
    let mut rn0 : u32 = 0u32  let mut rn1 : u32 = 0u32  let mut rn2 : u32 = 0u32  let mut rln : u32 = 0u32
    if sp_rc(sp_ch()) == 1u32 { rn0 = sp_ch()  sp_adv()  rln = 1u32 }
    if sp_rc(sp_ch()) == 1u32 { rn1 = sp_ch()  sp_adv()  rln = 2u32 }
    if sp_rc(sp_ch()) == 1u32 { rn2 = sp_ch()  sp_adv()  rln = 3u32 }
    /* xmm/ymm/zmm<N> : a vector register -- ?mm prefix then a DECIMAL number (the reg id 0..15/31).
     * Must read the number HERE (the generic trailing consumer below would discard it). */
    if rln == 3u32 { if rn1 == 109u32 { if rn2 == 109u32 {
        let mut isv : u32 = 0u32
        if rn0 == 120u32 { isv = 1u32 }  if rn0 == 121u32 { isv = 1u32 }  if rn0 == 122u32 { isv = 1u32 }
        if isv == 1u32 {
            if rn0 == 120u32 { VW = 0u32 }  if rn0 == 121u32 { VW = 1u32 }  if rn0 == 122u32 { VW = 2u32 }   /* x=128 y=256 z=512 */
            let mut xv : u32 = 0u32
            while is_digit(sp_ch()) == 1u32 { xv = (xv * 10u32) + (sp_ch() - 48u32)  sp_adv() }
            return xv
        }
    } } }
    while sp_rc(sp_ch()) == 1u32 { sp_adv() }   /* consume any trailing (r10d, etc.) */
    /* r8..r15 : 'r' then digit(s) */
    if rn0 == 114u32 { if is_digit(rn1) == 1u32 {
        let mut v : u32 = rn1 - 48u32
        if rln >= 3u32 { if is_digit(rn2) == 1u32 { v = (v * 10u32) + (rn2 - 48u32) } }
        return v
    } }
    /* the identifying 2-char base: (rn0,rn1) for a 2-char name, (rn1,rn2) for a 3-char (r/e prefix) name */
    let mut a : u32 = rn0  let mut b : u32 = rn1
    if rln == 3u32 { a = rn1  b = rn2 }
    if b == 120u32 { if a == 97u32 { return 0u32 } if a == 99u32 { return 1u32 } if a == 100u32 { return 2u32 } if a == 98u32 { return 3u32 } }   /* ?x 16-bit */
    if b == 108u32 { if a == 97u32 { return 0u32 } if a == 99u32 { return 1u32 } if a == 100u32 { return 2u32 } if a == 98u32 { return 3u32 } }   /* ?l 8-bit */
    if a == 115u32 { if b == 112u32 { return 4u32 } }   /* sp */
    if a == 98u32  { if b == 112u32 { return 5u32 } }   /* bp */
    if a == 115u32 { if b == 105u32 { return 6u32 } }   /* si */
    if a == 100u32 { if b == 105u32 { return 7u32 } }   /* di */
    return 0xFFu32
}

/* decode one operand at the cursor into OPK/OPR/OPD/OPI */
fn sp_operand() {
    sp_skip_ws()
    let c : u32 = sp_ch()
    if c == C_PCT { sp_adv()  OPK = 0u32  OPR = sp_reg()  return }
    if c == C_DOL { sp_adv()  OPK = 1u32  OPI = sp_num()  return }
    if is_ident_start(c) == 1u32 {
        /* sym(%rip) : read the symbol, resolve via the data-symbol table, consume "(%rip)" */
        OPK = 3u32
        let nlen : u32 = sp_read_name_into(SYM_N)        /* SYM_N = a scratch slot beyond the recorded set */
        OPSEC = SEC_OTHER  OPOFF = 0i32
        let mut i : u32 = 0u32
        while i < SYM_N {
            if sp_names_eq(SYM_N, nlen, i, SYM_NLEN[i as u64]) == 1u32 {
                OPSEC = SYM_SEC[i as u64]  OPOFF = SYM_OFF[i as u64] as i32  i = SYM_N
            } else { i = i + 1u32 }
        }
        if OPSEC == SEC_TEXT { let lo : u32 = lbl_find(SYM_N, nlen)  if lo != 0xFFFFFFFFu32 { OPOFF = lo as i32 } }   /* .text label: real offset from LBL table (SYM_OFF is a 0 placeholder) */
        if sp_ch() == C_LP { sp_adv()  if sp_ch() == C_PCT { sp_adv() }  sp_reg()  if sp_ch() == C_RP { sp_adv() } }
        return
    }
    /* memory: [disp](%base[,%index,scale]) */
    OPK = 2u32
    OPD = 0i32
    if (c == C_MIN) { OPD = sp_num() as i32 } else { if is_digit(c) == 1u32 { OPD = sp_num() as i32 } }
    if sp_ch() == C_LP {
        sp_adv()  if sp_ch() == C_PCT { sp_adv() }  OPR = sp_reg()
        if sp_ch() == C_COM {                                   /* SIB: ,%index,scale -> OPK=4 */
            sp_adv()  if sp_ch() == C_PCT { sp_adv() }  OPINDEX = sp_reg()
            if sp_ch() == C_COM { sp_adv()  OPSCALE = sp_num() as u32 }
            OPK = 4u32
        }
        if sp_ch() == C_RP { sp_adv() }
    }
}

/* read the mnemonic token into m0..m4 (we only need first 5 chars); returns length */
var MN : [u32; 16]   /* up to 16 chars so long SIMD mnemonics (sha256msg1/2, len 10) are disambiguable by MN[9] */
var MNN : u32 = 0u32
fn sp_mnem() {   /* read a full identifier (so a label like L_foo: or foo_bar: is detected as a label, not an op) */
    MNN = 0u32
    while is_ident(sp_ch()) == 1u32 { if MNN < 16u32 { MN[MNN as u64] = sp_ch()  MNN = MNN + 1u32 }  sp_adv() }
}
fn mn_is(a: u32, b: u32, c: u32, d: u32, n: u32) -> u32 {
    if MNN != n { return 0u32 }
    if MN[0u64] != a { return 0u32 }
    if n >= 2u32 { if MN[1u64] != b { return 0u32 } }
    if n >= 3u32 { if MN[2u64] != c { return 0u32 } }
    if n >= 4u32 { if MN[3u64] != d { return 0u32 } }
    return 1u32
}

/* saved first operand */
var S1K : u32 = 0u32
var S1R : u32 = 0u32
var S1D : i32 = 0i32
var S1I : i64 = 0i64
var S1SEC : u32 = 0u32
var S1OFF : i32 = 0i32
var S1INDEX : u32 = 0u32
var S1SCALE : u32 = 1u32
var PARSE_ERR : u32 = 0u32   /* set on an unknown mnemonic; sovparse returns nonzero so the gate fails LOUDLY */

/* sibling call: callq L_x (L_x a .text label) -> E8 + computed disp32 (5 bytes), no reloc.  The target name
 * is already in SYM_NAME scratch slot SYM_N (read by the callq dispatch). */
fn sp_sibcall(nlen: u32) {
    if SP_PASS == 1u32 { sov_call_rel32(0i32) }       /* layout: 5-byte placeholder */
    else {
        let off : u32 = lbl_find(SYM_N, nlen)
        if off == 0xFFFFFFFFu32 { PARSE_ERR = 1u32 }
        else { let site : u32 = sov_len()  let rel : i32 = (off as i32) - ((site + 5u32) as i32)  sov_call_rel32(rel) }
    }
}
/* ── branch relaxation state ── per branch (in encounter order): site, chosen size (rel8/rel32), kind, cc,
 * and target name.  The layout pass is iterated; a REL8 branch that overflows is grown to REL32 (which shifts
 * later offsets), until stable. */
var BR_SITE : [u32; 16384]
var BR_BIG  : [u32; 16384]    /* 0 = rel8 (2B), 1 = rel32 (jmp 5B / jcc 6B) */
var BR_JMP  : [u32; 16384]
var BR_CC   : [u32; 16384]
var BR_TNAME: [u8; 1048576]   /* 16384 slots * 64 */
var BR_TLEN : [u32; 16384]
var BR_N    : u32 = 0u32
var BR_IDX  : u32 = 0u32

fn sp_branch_size(id: u32, isjmp: u32) -> u32 {
    if BR_BIG[id as u64] == 1u32 { if isjmp == 1u32 { return 5u32 }  return 6u32 }
    return 2u32
}
fn sp_emit_branch(id: u32, isjmp: u32, cc: u32, rel: i32) {
    if BR_BIG[id as u64] == 1u32 { if isjmp == 1u32 { sov_jmp_rel32(rel) } else { sov_jcc_rel32(cc, rel) } }
    else { if isjmp == 1u32 { sov_jmp_rel8(rel) } else { sov_jcc_rel8(cc, rel) } }
}
/* after a layout pass: grow any still-REL8 branch whose displacement no longer fits a signed byte. returns 1
 * if anything grew (-> re-layout). */
fn sp_relax_check() -> u32 {
    let mut changed : u32 = 0u32
    let mut id : u32 = 0u32
    while id < BR_N {
        if BR_BIG[id as u64] == 0u32 {
            let nlen : u32 = BR_TLEN[id as u64]
            let mut jj : u32 = 0u32
            while jj < nlen { SYM_NAME[((SYM_N * 64u32) + jj) as u64] = BR_TNAME[((id * 64u32) + jj) as u64]  jj = jj + 1u32 }
            let off : u32 = lbl_find(SYM_N, nlen)
            if off != 0xFFFFFFFFu32 {
                let rel : i32 = (off as i32) - ((BR_SITE[id as u64] + 2u32) as i32)
                let mut fits : u32 = 0u32
                if rel >= -128i32 { if rel <= 127i32 { fits = 1u32 } }
                if fits == 0u32 { BR_BIG[id as u64] = 1u32  changed = 1u32 }
            }
        }
        id = id + 1u32
    }
    return changed
}

/* a line beginning with '.' is EITHER a gas local label (.Lxxx:) OR a directive (.text/.byte/...).  Peek:
 * read the token after the dot; if a ':' follows it is a .text local label (recorded dot-dropped, so a
 * `jnz .Lxxx` reference matches); otherwise rewind and dispatch as a directive.  Handles the metal{}-block
 * AVX loops (blake2s/chacha20) that use `.Lb2s_avx_rnd:` gas-idiom labels. */
fn sp_dot_line() {
    sp_adv()                                               /* consume '.' */
    let save : u32 = IN_POS
    let dlen : u32 = sp_read_name_into(SYM_N)
    if sp_ch() == C_COLON {
        sp_adv()
        if SP_PASS == 1u32 { if CUR_SEC == SEC_TEXT { lbl_record(SYM_N, dlen) } }
    } else { IN_POS = save  sp_dir1() }
}

/* branch: jmp/jCC L_x -> opcode + computed rel8/rel32 (relaxed), no reloc.  Returns 1 if MN was a branch. */
fn sp_try_branch() -> u32 {
    let mut isbr : u32 = 0u32  let mut isjmp : u32 = 0u32  let mut cc : u32 = 0u32
    if mn_is(106u32,109u32,112u32,0u32,3u32) == 1u32 { isbr = 1u32  isjmp = 1u32 }   /* jmp */
    if mn_is(106u32,122u32,0u32,0u32,2u32) == 1u32 { isbr = 1u32  cc = 4u32 }        /* jz */
    if mn_is(106u32,101u32,0u32,0u32,2u32) == 1u32 { isbr = 1u32  cc = 4u32 }        /* je */
    if mn_is(106u32,110u32,101u32,0u32,3u32) == 1u32 { isbr = 1u32  cc = 5u32 }      /* jne */
    if mn_is(106u32,110u32,122u32,0u32,3u32) == 1u32 { isbr = 1u32  cc = 5u32 }      /* jnz */
    if mn_is(106u32,108u32,0u32,0u32,2u32) == 1u32 { isbr = 1u32  cc = 12u32 }       /* jl */
    if mn_is(106u32,108u32,101u32,0u32,3u32) == 1u32 { isbr = 1u32  cc = 14u32 }     /* jle */
    if mn_is(106u32,103u32,0u32,0u32,2u32) == 1u32 { isbr = 1u32  cc = 15u32 }       /* jg */
    if mn_is(106u32,103u32,101u32,0u32,3u32) == 1u32 { isbr = 1u32  cc = 13u32 }     /* jge */
    if mn_is(106u32,98u32,0u32,0u32,2u32) == 1u32 { isbr = 1u32  cc = 2u32 }         /* jb */
    if mn_is(106u32,98u32,101u32,0u32,3u32) == 1u32 { isbr = 1u32  cc = 6u32 }       /* jbe */
    if mn_is(106u32,97u32,0u32,0u32,2u32) == 1u32 { isbr = 1u32  cc = 7u32 }         /* ja */
    if mn_is(106u32,97u32,101u32,0u32,3u32) == 1u32 { isbr = 1u32  cc = 3u32 }       /* jae */
    if isbr == 0u32 { return 0u32 }
    let id : u32 = BR_IDX  BR_IDX = BR_IDX + 1u32
    sp_skip_ws()
    if sp_ch() == C_DOT { sp_adv() }                       /* gas local label `.Lxxx` -> drop the dot (matches lbl_record) */
    let nlen : u32 = sp_read_name_into(SYM_N)
    if SP_PASS == 1u32 {                                   /* LAYOUT: record site + target; placeholder at the chosen size */
        BR_SITE[id as u64] = sov_len()
        BR_JMP[id as u64] = isjmp  BR_CC[id as u64] = cc  BR_TLEN[id as u64] = nlen
        let mut jj : u32 = 0u32
        while jj < nlen { BR_TNAME[((id * 64u32) + jj) as u64] = SYM_NAME[((SYM_N * 64u32) + jj) as u64]  jj = jj + 1u32 }
        if (id + 1u32) > BR_N { BR_N = id + 1u32 }
        sp_emit_branch(id, isjmp, cc, 0i32)
    } else {                                               /* FINAL: resolve + emit at the relaxed size */
        let off : u32 = lbl_find(SYM_N, nlen)
        if off == 0xFFFFFFFFu32 { PARSE_ERR = 1u32 }
        else {
            let site : u32 = sov_len()
            let sz : u32 = sp_branch_size(id, isjmp)
            sp_emit_branch(id, isjmp, cc, (off as i32) - ((site + sz) as i32))
        }
    }
    return 1u32
}

/* read two comma-separated operands (op1 saved to S1*, op2 in OP*) */
fn sp_two_ops() {
    sp_operand()  S1K = OPK  S1R = OPR  S1D = OPD  S1I = OPI  S1SEC = OPSEC  S1OFF = OPOFF  S1INDEX = OPINDEX  S1SCALE = OPSCALE
    sp_skip_ws()  if sp_ch() == C_COM { sp_adv() }
    sp_operand()
}

/* three-operand reader (SIMD imm/implicit forms): op1 -> T1*, op2 -> T2*, op3 -> OP*.
 * T1D carries op1's memory displacement (VEX mem-source forms: `vpaddd disp(%base),%src1,%dst`). */
var T1K : u32 = 0u32  var T1R : u32 = 0u32  var T1I : i64 = 0i64  var T1D : i32 = 0i32
var T2K : u32 = 0u32  var T2R : u32 = 0u32
fn sp_three_ops() {
    sp_operand()  T1K = OPK  T1R = OPR  T1I = OPI  T1D = OPD
    sp_skip_ws()  if sp_ch() == C_COM { sp_adv() }
    sp_operand()  T2K = OPK  T2R = OPR
    sp_skip_ws()  if sp_ch() == C_COM { sp_adv() }
    sp_operand()
}

/* four-operand reader (vpternlogq $imm,%src2,%src1,%dst): F1I=imm F2R=src2(rm) F3R=src1(vvvv) OP=dst(reg). */
var F1I : i64 = 0i64  var F2R : u32 = 0u32  var F3R : u32 = 0u32
fn sp_four_ops() {
    sp_operand()  F1I = OPI
    sp_skip_ws()  if sp_ch() == C_COM { sp_adv() }
    sp_operand()  F2R = OPR
    sp_skip_ws()  if sp_ch() == C_COM { sp_adv() }
    sp_operand()  F3R = OPR
    sp_skip_ws()  if sp_ch() == C_COM { sp_adv() }
    sp_operand()
}

/* VEX (Tier-2 SIMD) dispatch -- returns 1 if MN was a recognized VEX mnemonic (even if it set PARSE_ERR).
 * AT&T 3-operand order is `op src2,src1,dst` so T1=src2, T2=src1, OP=dst.  EVEX-only mnemonics + zmm-width
 * vpaddq/vpsrlq are NOT handled here (return 0, or PARSE_ERR) -> routed to the EVEX dispatch (Task B3).
 * Near-miss guards (MN[5]/MN[6]) keep vpsllq/vpshufb from mis-encoding as vpslld/vpshufd. */
fn sp_try_vec() -> u32 {
    if MN[0u64] != 118u32 { return 0u32 }               /* fast reject: all vector mnemonics begin with 'v' */
    if mn_is(118u32,122u32,101u32,114u32,10u32) == 1u32 { sov_vzeroupper()  return 1u32 }                                  /* vzeroupper */
    if mn_is(118u32,112u32,120u32,111u32,5u32) == 1u32 { sp_three_ops()  sov_vpxor(OPR, T2R, T1R)  return 1u32 }            /* vpxor */
    if mn_is(118u32,112u32,111u32,114u32,4u32) == 1u32 { sp_three_ops()  sov_vpor(OPR, T2R, T1R)  return 1u32 }             /* vpor */
    if mn_is(118u32,112u32,97u32,100u32,6u32) == 1u32 {                                                                     /* vpadd? */
        if MN[5u64] == 100u32 { sp_three_ops()  if T1K == 2u32 { sov_vpaddd_mem(OPR, T2R, T1R, T1D) } else { sov_vpaddd(OPR, T2R, T1R) }  return 1u32 }   /* vpaddd (reg/mem) */
        if MN[5u64] == 113u32 { sp_three_ops()  if VW == 1u32 { sov_vpaddq_y(OPR, T2R, T1R)  return 1u32 }  if VW == 2u32 { sov_vpaddq_e(OPR, T2R, T1R, 2u32)  return 1u32 }  PARSE_ERR = 1u32  return 1u32 }   /* vpaddq: ymm=VEX zmm=EVEX */
        PARSE_ERR = 1u32  return 1u32
    }
    if mn_is(118u32,112u32,115u32,104u32,7u32) == 1u32 { if MN[6u64] == 100u32 { sp_three_ops()  sov_vpshufd(OPR, T2R, T1I as u32)  return 1u32 }  PARSE_ERR = 1u32  return 1u32 }   /* vpshufd (guard vpshufb) */
    if mn_is(118u32,112u32,115u32,108u32,6u32) == 1u32 { if MN[5u64] == 100u32 { sp_three_ops()  sov_vpslld(OPR, T2R, T1I as u32)  return 1u32 }  PARSE_ERR = 1u32  return 1u32 }    /* vpslld (guard vpsllq) */
    if mn_is(118u32,112u32,115u32,114u32,6u32) == 1u32 {                                                                    /* vpsr?? */
        if MN[5u64] == 100u32 { sp_three_ops()  sov_vpsrld(OPR, T2R, T1I as u32)  return 1u32 }                             /* vpsrld */
        if MN[5u64] == 113u32 { sp_three_ops()  if VW == 1u32 { sov_vpsrlq_y(OPR, T2R, T1I as u32)  return 1u32 }  if VW == 2u32 { sov_vpsrlq_e(OPR, T2R, T1I as u32, 2u32)  return 1u32 }  PARSE_ERR = 1u32  return 1u32 }   /* vpsrlq: ymm=VEX zmm=EVEX */
        PARSE_ERR = 1u32  return 1u32
    }
    if mn_is(118u32,109u32,111u32,118u32,7u32) == 1u32 {                                                                    /* vmovdqu (len7; vmovdqu64 len9 falls through) */
        sp_two_ops()
        if S1K == 2u32 { if OPK == 0u32 { sov_vmovdqu_vload(OPR, S1R, S1D, VW)  return 1u32 } }                             /* load  disp(%base),%reg */
        if S1K == 0u32 { if OPK == 2u32 { sov_vmovdqu_vstore(S1R, OPR, OPD, VW)  return 1u32 } }                            /* store %reg,disp(%base) */
        PARSE_ERR = 1u32  return 1u32
    }
    /* ── EVEX-only mnemonics (width from VW: xmm=0 ymm=1 zmm=2; ll = VW) ── */
    if mn_is(118u32,112u32,120u32,111u32,6u32) == 1u32 {                                                                    /* vpxord / vpxorq */
        sp_three_ops()
        if MN[5u64] == 100u32 { sov_vpxord(OPR, T2R, T1R, VW)  return 1u32 }
        if MN[5u64] == 113u32 { sov_vpxorq(OPR, T2R, T1R, VW)  return 1u32 }
        PARSE_ERR = 1u32  return 1u32
    }
    if mn_is(118u32,112u32,97u32,110u32,6u32) == 1u32 { sp_three_ops()  sov_vpandq(OPR, T2R, T1R, VW)  return 1u32 }        /* vpandq */
    if mn_is(118u32,112u32,109u32,117u32,8u32) == 1u32 { sp_three_ops()  sov_vpmuludq(OPR, T2R, T1R, VW)  return 1u32 }     /* vpmuludq */
    if mn_is(118u32,112u32,109u32,117u32,7u32) == 1u32 { sp_three_ops()  sov_vpmullq(OPR, T2R, T1R, VW)  return 1u32 }      /* vpmullq */
    if mn_is(118u32,112u32,101u32,114u32,6u32) == 1u32 { sp_three_ops()  sov_vpermq_e(OPR, T2R, T1R, VW)  return 1u32 }     /* vpermq */
    if mn_is(118u32,112u32,114u32,111u32,6u32) == 1u32 {                                                                    /* vprold / vprord / vprolq (rotate $imm) */
        sp_three_ops()
        if MN[4u64] == 108u32 { if MN[5u64] == 100u32 { sov_vprold(OPR, T2R, T1I as u32, VW)  return 1u32 }  if MN[5u64] == 113u32 { sov_vprolq(OPR, T2R, T1I as u32, VW)  return 1u32 } }
        if MN[4u64] == 114u32 { if MN[5u64] == 100u32 { sov_vprord(OPR, T2R, T1I as u32, VW)  return 1u32 } }
        PARSE_ERR = 1u32  return 1u32
    }
    if mn_is(118u32,112u32,116u32,101u32,10u32) == 1u32 { sp_four_ops()  sov_vpternlogq(OPR, F3R, F2R, F1I as u32, VW)  return 1u32 }   /* vpternlogq $imm,%s2,%s1,%d */
    if mn_is(118u32,112u32,98u32,114u32,12u32) == 1u32 {                                                                    /* vpbroadcastq disp(%base),%zmm */
        sp_two_ops()
        if S1K == 2u32 { if OPK == 0u32 { sov_vpbroadcastq(OPR, S1R, S1D, VW)  return 1u32 } }
        PARSE_ERR = 1u32  return 1u32
    }
    if mn_is(118u32,109u32,111u32,118u32,9u32) == 1u32 {                                                                    /* vmovdqu64 load/store */
        sp_two_ops()
        if S1K == 2u32 { if OPK == 0u32 { sov_vmovdqu64_load(OPR, S1R, S1D, VW)  return 1u32 } }
        if S1K == 0u32 { if OPK == 2u32 { sov_vmovdqu64_store(S1R, OPR, OPD, VW)  return 1u32 } }
        PARSE_ERR = 1u32  return 1u32
    }
    return 0u32
}

/* dispatch one instruction (MN = mnemonic).  Early-return form: each branch reads operands only when it
 * matches, so adding a mnemonic is a single self-contained line.  Unknown mnemonic -> PARSE_ERR (loud). */
fn sp_dispatch_instr() {
    if mn_is(112u32,117u32,115u32,104u32,5u32) == 1u32 { sp_operand()  sov_push_r(OPR)  return }   /* pushq */
    if mn_is(112u32,111u32,112u32,113u32,4u32) == 1u32 { sp_operand()  sov_pop_r(OPR)  return }    /* popq */
    if mn_is(114u32,101u32,116u32,113u32,4u32) == 1u32 { sov_ret()  return }                       /* retq */
    if mn_is(114u32,101u32,116u32,0u32,3u32) == 1u32 { sov_ret()  return }                          /* ret (bare; hand-written asm) */
    if mn_is(99u32,113u32,116u32,111u32,4u32) == 1u32 { sov_cqto()  return }                        /* cqto (48 99) */
    if mn_is(114u32,100u32,114u32,97u32,6u32) == 1u32 { sp_operand()  sov_rdrand(OPR)  return }      /* rdrand %reg */
    if mn_is(114u32,100u32,115u32,101u32,6u32) == 1u32 { sp_operand()  sov_rdseed(OPR)  return }     /* rdseed %reg */
    if mn_is(99u32,112u32,117u32,105u32,5u32) == 1u32 { sov_cpuid()  return }                        /* cpuid (0F A2) */
    if mn_is(120u32,103u32,101u32,116u32,6u32) == 1u32 { sov_xgetbv()  return }                      /* xgetbv (0F 01 D0) */
    if mn_is(109u32,111u32,118u32,113u32,4u32) == 1u32 {                                            /* movq */
        sp_two_ops()
        if S1K == 0u32 { if OPK == 0u32 { sov_mov_rr(OPR, S1R) } }
        if S1K == 0u32 { if OPK == 2u32 { sov_store_base(S1R, OPR, OPD) } }   /* movq %reg, disp(%base) */
        if S1K == 2u32 { if OPK == 0u32 { sov_load_base(OPR, S1R, S1D) } }    /* movq disp(%base), %reg */
        if S1K == 1u32 { if OPK == 0u32 { sov_mov_imm32(OPR, S1I as i32) } }
        if S1K == 3u32 { if OPK == 0u32 { sov_load_rip_sym(OPR, S1SEC, S1OFF) } }
        if S1K == 0u32 { if OPK == 3u32 { sov_store_rip_sym(S1R, OPSEC, OPOFF) } }
        if S1K == 0u32 { if OPK == 4u32 { sov_store_sib_d(S1R, OPR, OPINDEX, OPSCALE, OPD) } }   /* movq %s,disp(base,idx,sc) */
        if S1K == 4u32 { if OPK == 0u32 { sov_load_sib_d(OPR, S1R, S1INDEX, S1SCALE, S1D) } }    /* movq disp(base,idx,sc),%d */
        return
    }
    if mn_is(108u32,101u32,97u32,113u32,4u32) == 1u32 {                                              /* leaq */
        sp_two_ops()
        if S1K == 3u32 {
            if S1SEC == SEC_TEXT { sov_lea_rip_local(OPR, S1OFF)  return }   /* same-section .text label: resolve inline, no reloc */
            sov_lea_rip_sym(OPR, S1SEC, S1OFF)  return                       /* data symbol (.data/.rodata/.bss): rip-rel + reloc */
        }
        if S1K == 2u32 { sov_lea_base(OPR, S1R, S1D)  return }          /* leaq disp(%base), %reg */
        if S1K == 4u32 { sov_lea_sib(OPR, S1R, S1INDEX, S1SCALE, S1D)  return }   /* leaq (b,i,s), %reg */
        PARSE_ERR = 1u32  return
    }
    if mn_is(109u32,111u32,118u32,97u32,7u32) == 1u32 { sp_two_ops()  sov_movabs(OPR, S1I as u64)  return }         /* movabsq */
    if mn_is(109u32,111u32,118u32,108u32,4u32) == 1u32 {              /* movl (32-bit reg,reg; mem forms loud) */
        sp_two_ops()
        if S1K == 0u32 { if OPK == 0u32 { sov_movl_rr(OPR, S1R)  return } }
        if S1K == 0u32 { if OPK == 2u32 { sov_movl_store_base(S1R, OPR, OPD)  return } }   /* movl %reg, disp(%base) */
        if S1K == 2u32 { if OPK == 0u32 { sov_movl_load_base(OPR, S1R, S1D)  return } }    /* movl disp(%base), %reg */
        if S1K == 0u32 { if OPK == 4u32 { sov_movl_store_sib(S1R, OPR, OPINDEX, OPSCALE, OPD)  return } }   /* movl %r,disp(b,i,s) */
        if S1K == 4u32 { if OPK == 0u32 { sov_movl_load_sib(OPR, S1R, S1INDEX, S1SCALE, S1D)  return } }    /* movl disp(b,i,s),%r */
        if S1K == 3u32 { if OPK == 0u32 { sov_movl_load_rip_sym(OPR, S1SEC, S1OFF)  return } }              /* movl sym(%rip), %reg */
        if S1K == 0u32 { if OPK == 3u32 { sov_movl_store_rip_sym(S1R, OPSEC, OPOFF)  return } }             /* movl %reg, sym(%rip) */
        if S1K == 1u32 { if OPK == 0u32 { sov_movl_imm(OPR, S1I as i32)  return } }                         /* movl $imm32, %reg (B8+r) */
        PARSE_ERR = 1u32  return
    }
    if mn_is(109u32,111u32,118u32,98u32,4u32) == 1u32 {                                              /* movb (8-bit) */
        sp_two_ops()
        if S1K == 0u32 { if OPK == 0u32 { sov_movb_rr(OPR, S1R)  return } }
        if S1K == 0u32 { if OPK == 2u32 { sov_movb_store_base(S1R, OPR, OPD)  return } }   /* movb %reg, disp(%base) */
        if S1K == 2u32 { if OPK == 0u32 { sov_movb_load_base(OPR, S1R, S1D)  return } }    /* movb disp(%base), %reg */
        if S1K == 0u32 { if OPK == 3u32 { sov_movb_store_rip_sym(S1R, OPSEC, OPOFF)  return } }   /* movb %reg, sym(%rip) */
        if S1K == 3u32 { if OPK == 0u32 { sov_movb_load_rip_sym(OPR, S1SEC, S1OFF)  return } }    /* movb sym(%rip), %reg */
        if S1K == 0u32 { if OPK == 4u32 { sov_movb_store_sib(S1R, OPR, OPINDEX, OPSCALE, OPD)  return } }   /* movb %reg, (b,i,s) */
        if S1K == 4u32 { if OPK == 0u32 { sov_movb_load_sib(OPR, S1R, S1INDEX, S1SCALE, S1D)  return } }    /* movb (b,i,s), %reg */
        PARSE_ERR = 1u32  return
    }
    if mn_is(109u32,111u32,118u32,119u32,4u32) == 1u32 {                                             /* movw (16-bit) */
        sp_two_ops()
        if S1K == 0u32 { if OPK == 2u32 { sov_movw_store_base(S1R, OPR, OPD)  return } }
        if S1K == 2u32 { if OPK == 0u32 { sov_movw_load_base(OPR, S1R, S1D)  return } }
        if S1K == 0u32 { if OPK == 4u32 { sov_movw_store_sib(S1R, OPR, OPINDEX, OPSCALE, OPD)  return } }
        if S1K == 0u32 { if OPK == 3u32 { sov_movw_store_rip_sym(S1R, OPSEC, OPOFF)  return } }
        PARSE_ERR = 1u32  return
    }
    if mn_is(99u32,97u32,108u32,108u32,5u32) == 1u32 {                                              /* callq <name> | *%reg */
        sp_skip_ws()
        if sp_ch() == 42u32 {                                          /* B2: callq *%reg -> FF /2 (ff d0), no reloc */
            sp_adv()  if sp_ch() == C_PCT { sp_adv() }  sov_call_reg(sp_reg())  return
        }
        let nlen : u32 = sp_read_name_into(SYM_N)
        let mut sib : u32 = 0u32
        let mut ci : u32 = 0u32
        while ci < SYM_N {
            if sp_names_eq(SYM_N, nlen, ci, SYM_NLEN[ci as u64]) == 1u32 { if SYM_SEC[ci as u64] == SEC_TEXT { sib = 1u32 }  ci = SYM_N } else { ci = ci + 1u32 }
        }
        if sib == 1u32 { sp_sibcall(nlen) }
        else { sov_cn_clear()  let mut cj : u32 = 0u32  while cj < nlen { sov_cn_push(SYM_NAME[((SYM_N * 64u32) + cj) as u64] as u32)  cj = cj + 1u32 }  sov_call_ext() }
        return
    }
    /* binary ALU (op1 reg|imm, op2 reg) */
    if mn_is(97u32,100u32,100u32,113u32,4u32) == 1u32 { sp_two_ops()  if S1K == 1u32 { sov_add_imm32(OPR, S1I as i32) } else { sov_add_rr(OPR, S1R) }  return }  /* addq */
    if mn_is(115u32,117u32,98u32,113u32,4u32) == 1u32 { sp_two_ops()  if S1K == 1u32 { sov_sub_imm32(OPR, S1I as i32) } else { sov_sub_rr(OPR, S1R) }  return }   /* subq */
    if mn_is(99u32,109u32,112u32,113u32,4u32) == 1u32 { sp_two_ops()  if S1K == 1u32 { sov_cmp_imm32(OPR, S1I as i32) } else { sov_cmp_rr(OPR, S1R) }  return }   /* cmpq */
    if mn_is(116u32,101u32,115u32,116u32,5u32) == 1u32 { sp_two_ops()  sov_test_rr(OPR, S1R)  return }   /* testq */
    if mn_is(97u32,110u32,100u32,113u32,4u32) == 1u32 { sp_two_ops()  if S1K == 1u32 { sov_and_imm32(OPR, S1I as i32) } else { sov_and_rr(OPR, S1R) }  return }     /* andq (imm or reg) */
    if mn_is(111u32,114u32,113u32,0u32,3u32) == 1u32 { sp_two_ops()  sov_or_rr(OPR, S1R)  return }       /* orq */
    if mn_is(120u32,111u32,114u32,113u32,4u32) == 1u32 { sp_two_ops()  sov_xor_rr(OPR, S1R)  return }    /* xorq */
    /* setCC %reg8 (cc: b=2 ae=3 e=4 ne=5 be=6 a=7 l=12 ge=13 le=14 g=15) */
    if mn_is(115u32,101u32,116u32,97u32,4u32) == 1u32 { sp_operand()  sov_setcc(7u32, OPR)  return }     /* seta */
    if mn_is(115u32,101u32,116u32,97u32,5u32) == 1u32 { sp_operand()  sov_setcc(3u32, OPR)  return }     /* setae */
    if mn_is(115u32,101u32,116u32,98u32,4u32) == 1u32 { sp_operand()  sov_setcc(2u32, OPR)  return }     /* setb */
    if mn_is(115u32,101u32,116u32,99u32,4u32) == 1u32 { sp_operand()  sov_setcc(2u32, OPR)  return }     /* setc (= setb, CF) */
    if mn_is(115u32,101u32,116u32,98u32,5u32) == 1u32 { sp_operand()  sov_setcc(6u32, OPR)  return }     /* setbe */
    if mn_is(115u32,101u32,116u32,101u32,4u32) == 1u32 { sp_operand()  sov_setcc(4u32, OPR)  return }    /* sete */
    if mn_is(115u32,101u32,116u32,110u32,5u32) == 1u32 { sp_operand()  sov_setcc(5u32, OPR)  return }    /* setne */
    if mn_is(115u32,101u32,116u32,108u32,4u32) == 1u32 { sp_operand()  sov_setcc(12u32, OPR)  return }   /* setl */
    if mn_is(115u32,101u32,116u32,108u32,5u32) == 1u32 { sp_operand()  sov_setcc(14u32, OPR)  return }   /* setle */
    if mn_is(115u32,101u32,116u32,103u32,4u32) == 1u32 { sp_operand()  sov_setcc(15u32, OPR)  return }   /* setg */
    if mn_is(115u32,101u32,116u32,103u32,5u32) == 1u32 { sp_operand()  sov_setcc(13u32, OPR)  return }   /* setge */
    /* movzx/movsx %src,%dst (encoder takes dst,src) */
    if mn_is(109u32,111u32,118u32,122u32,6u32) == 1u32 {                                            /* movz?q */
        sp_two_ops()
        if S1K == 4u32 {                                          /* SIB source: movzbq/movzwq disp(%b,%i,sc),%d */
            let mut op2 : u32 = 0xB6u32
            if MN[4u64] == 119u32 { op2 = 0xB7u32 }
            sov_movzx_sib(OPR, S1R, S1INDEX, S1SCALE, S1D, op2)  return
        }
        if S1K == 2u32 {                                          /* disp(%base) source */
            let mut op2m : u32 = 0xB6u32
            if MN[4u64] == 119u32 { op2m = 0xB7u32 }
            sov_movzx_mem(OPR, S1R, S1D, op2m)  return
        }
        if S1K == 3u32 {                                          /* sym(%rip) source */
            let mut op2r : u32 = 0xB6u32
            if MN[4u64] == 119u32 { op2r = 0xB7u32 }
            sov_movzx_rip(OPR, S1SEC, S1OFF, op2r)  return
        }
        if MN[4u64] == 98u32 { sov_movzbq(OPR, S1R)  return }     /* movzbq */
        if MN[4u64] == 119u32 { sov_movzwq(OPR, S1R)  return }    /* movzwq */
        PARSE_ERR = 1u32  return
    }
    if mn_is(109u32,111u32,118u32,115u32,6u32) == 1u32 {                                            /* movs?q */
        sp_two_ops()
        if S1K == 4u32 {                                          /* SIB source: movsbq/movswq (0f be/bf) / movslq (63) */
            if MN[4u64] == 108u32 { sov_movsxd_sib(OPR, S1R, S1INDEX, S1SCALE, S1D)  return }
            let mut op2 : u32 = 0xBEu32
            if MN[4u64] == 119u32 { op2 = 0xBFu32 }
            sov_movzx_sib(OPR, S1R, S1INDEX, S1SCALE, S1D, op2)  return
        }
        if S1K == 2u32 {                                          /* disp(%base) source */
            if MN[4u64] == 108u32 { sov_movslq_mem(OPR, S1R, S1D)  return }
            let mut op2m : u32 = 0xBEu32
            if MN[4u64] == 119u32 { op2m = 0xBFu32 }
            sov_movzx_mem(OPR, S1R, S1D, op2m)  return
        }
        if S1K == 3u32 {                                          /* sym(%rip) source */
            if MN[4u64] == 108u32 { sov_movslq_rip(OPR, S1SEC, S1OFF)  return }
            let mut op2r : u32 = 0xBEu32
            if MN[4u64] == 119u32 { op2r = 0xBFu32 }
            sov_movzx_rip(OPR, S1SEC, S1OFF, op2r)  return
        }
        if MN[4u64] == 98u32 { sov_movsbq(OPR, S1R)  return }     /* movsbq */
        if MN[4u64] == 119u32 { sov_movswq(OPR, S1R)  return }    /* movswq */
        if MN[4u64] == 108u32 { sov_movslq(OPR, S1R)  return }    /* movslq */
        PARSE_ERR = 1u32  return
    }
    /* F7 unary */
    if mn_is(110u32,101u32,103u32,113u32,4u32) == 1u32 { sp_operand()  sov_neg_r(OPR)  return }    /* negq */
    if mn_is(110u32,111u32,116u32,113u32,4u32) == 1u32 { sp_operand()  sov_not_r(OPR)  return }    /* notq */
    if mn_is(105u32,109u32,117u32,108u32,5u32) == 1u32 { sp_two_ops()  sov_imul_rr(OPR, S1R)  return }   /* imulq %src,%dst -> REX.W 0F AF /r */
    if mn_is(105u32,100u32,105u32,118u32,5u32) == 1u32 { sp_operand()  sov_idiv_r(OPR)  return }   /* idivq */
    if mn_is(109u32,117u32,108u32,113u32,4u32) == 1u32 { sp_operand()  sov_mul_r(OPR)  return }    /* mulq (one-operand unsigned, F7/4) */
    if mn_is(100u32,105u32,118u32,113u32,4u32) == 1u32 { sp_operand()  sov_div_r(OPR)  return }    /* divq */
    /* shift $imm8,%reg */
    if mn_is(115u32,104u32,108u32,113u32,4u32) == 1u32 { sp_two_ops()  if S1K == 1u32 { sov_shl_imm8(OPR, S1I as u32) } else { sov_shl_cl(OPR) }  return }  /* shlq $imm|%cl */
    if mn_is(115u32,104u32,114u32,113u32,4u32) == 1u32 { sp_two_ops()  if S1K == 1u32 { sov_shr_imm8(OPR, S1I as u32) } else { sov_shr_cl(OPR) }  return }  /* shrq $imm|%cl */
    /* 32-bit shifts (shll/shrl/sarl $imm,%reg) + dec/inc + addl $imm,mem -- crypto-SIMD integer forms */
    if mn_is(115u32,104u32,108u32,108u32,4u32) == 1u32 { sp_two_ops()  if S1K == 1u32 { sov_shll_imm8(OPR, S1I as u32)  return }  PARSE_ERR = 1u32  return }   /* shll $imm,%reg */
    if mn_is(115u32,104u32,114u32,108u32,4u32) == 1u32 { sp_two_ops()  if S1K == 1u32 { sov_shrl_imm8(OPR, S1I as u32)  return }  PARSE_ERR = 1u32  return }   /* shrl */
    if mn_is(115u32,97u32,114u32,108u32,4u32) == 1u32 { sp_two_ops()  if S1K == 1u32 { sov_sarl_imm8(OPR, S1I as u32)  return }  PARSE_ERR = 1u32  return }    /* sarl */
    if mn_is(100u32,101u32,99u32,108u32,4u32) == 1u32 { sp_operand()  sov_decl_r(OPR)  return }                                                              /* decl %reg */
    if mn_is(105u32,110u32,99u32,108u32,4u32) == 1u32 { sp_operand()  sov_incl_r(OPR)  return }                                                              /* incl %reg */
    /* 32-bit reg-reg ALU -- sov_op32_rr/sov_xorl_rr existed but were never dispatched; xorl %eax,%eax zeroing dominates (122 modules) */
    if mn_is(120u32,111u32,114u32,108u32,4u32) == 1u32 { sp_two_ops()  if S1K == 0u32 { if OPK == 0u32 { sov_xorl_rr(OPR, S1R)  return } }  PARSE_ERR = 1u32  return }   /* xorl */
    if mn_is(97u32,100u32,100u32,108u32,4u32)  == 1u32 { sp_two_ops()  if S1K == 0u32 { if OPK == 0u32 { sov_addl_rr(OPR, S1R)  return } }  if S1K == 1u32 { if OPK == 2u32 { sov_addl_imm_mem(OPR, OPD, S1I as i32)  return } }  PARSE_ERR = 1u32  return }   /* addl reg,reg | $imm,disp(%base) */
    if mn_is(115u32,117u32,98u32,108u32,4u32)  == 1u32 { sp_two_ops()  if S1K == 0u32 { if OPK == 0u32 { sov_subl_rr(OPR, S1R)  return } }  PARSE_ERR = 1u32  return }   /* subl */
    if mn_is(97u32,110u32,100u32,108u32,4u32)  == 1u32 { sp_two_ops()  if S1K == 0u32 { if OPK == 0u32 { sov_andl_rr(OPR, S1R)  return } }  PARSE_ERR = 1u32  return }   /* andl */
    if mn_is(111u32,114u32,108u32,0u32,3u32)   == 1u32 { sp_two_ops()  if S1K == 0u32 { if OPK == 0u32 { sov_orl_rr(OPR, S1R)  return } }  PARSE_ERR = 1u32  return }   /* orl */
    if mn_is(99u32,109u32,112u32,108u32,4u32)  == 1u32 { sp_two_ops()  if S1K == 0u32 { if OPK == 0u32 { sov_cmpl_rr(OPR, S1R)  return } }  PARSE_ERR = 1u32  return }   /* cmpl */
    /* ── SSE / SHA-NI (Tier-2 crypto SIMD): xmm operands; modrm reg=DEST, rm=SRC; conditional W0 REX ── */
    if mn_is(112u32,97u32,100u32,100u32,5u32) == 1u32 { sp_two_ops()  sov_sse_0f(0x66u32, 0xFEu32, OPR, S1R)  return }                       /* paddd %src,%dst : 66 0F FE /r */
    if mn_is(112u32,115u32,104u32,117u32,6u32) == 1u32 {                                                                                    /* pshu? (MN[5] b=98 / d=100) */
        if MN[5u64] == 98u32  { sp_two_ops()    sov_sse_0f38(0x66u32, 0x00u32, OPR, S1R)  return }                                          /* pshufb %src,%dst : 66 0F 38 00 /r */
        if MN[5u64] == 100u32 { sp_three_ops()  sov_sse_0f_ib(0x66u32, 0x70u32, OPR, T2R, T1I as u32)  return }                              /* pshufd $i,%src,%dst : 66 0F 70 /r ib */
        PARSE_ERR = 1u32  return
    }
    if mn_is(112u32,97u32,108u32,105u32,7u32) == 1u32 { sp_three_ops()  sov_sse_0f3a_ib(0x66u32, 0x0Fu32, OPR, T2R, T1I as u32)  return }    /* palignr $i,%src,%dst : 66 0F 3A 0F /r ib */
    if mn_is(112u32,98u32,108u32,101u32,7u32) == 1u32 { sp_three_ops()  sov_sse_0f3a_ib(0x66u32, 0x0Eu32, OPR, T2R, T1I as u32)  return }    /* pblendw $i,%src,%dst : 66 0F 3A 0E /r ib */
    if mn_is(115u32,104u32,97u32,50u32,11u32) == 1u32 { sp_three_ops()  sov_sse_0f38(0x00u32, 0xCBu32, OPR, T2R)  return }                   /* sha256rnds2 %xmm0,%src,%dst : 0F 38 CB /r (xmm0 implicit) */
    if mn_is(115u32,104u32,97u32,50u32,10u32) == 1u32 {                                                                                     /* sha256msg1/2 (MN[9] '1'=49 / '2'=50) */
        sp_two_ops()
        if MN[9u64] == 49u32 { sov_sse_0f38(0x00u32, 0xCCu32, OPR, S1R)  return }                                                           /* sha256msg1 : 0F 38 CC /r */
        if MN[9u64] == 50u32 { sov_sse_0f38(0x00u32, 0xCDu32, OPR, S1R)  return }                                                           /* sha256msg2 : 0F 38 CD /r */
        PARSE_ERR = 1u32  return
    }
    if mn_is(109u32,111u32,118u32,100u32,6u32) == 1u32 { if MN[5u64] == 117u32 {                                                            /* movdqu (MN[5] u=117; guards vs movdqa) */
        sp_two_ops()
        if S1K == 0u32 { if OPK == 0u32 { sov_movdqu_rr(OPR, S1R)  return } }                                                               /* movdqu %src,%dst : F3 0F 6F /r */
        if S1K == 2u32 { if OPK == 0u32 { sov_movdqu_load_base(OPR, S1R, S1D)  return } }                                                   /* movdqu disp(%base),%dst */
        if S1K == 4u32 { if OPK == 0u32 { sov_movdqu_load_sib(OPR, S1R, S1INDEX, S1SCALE, S1D)  return } }                                  /* movdqu disp(b,i,s),%dst */
        if S1K == 3u32 { if OPK == 0u32 { sov_movdqu_load_rip_sym(OPR, S1SEC, S1OFF)  return } }                                            /* movdqu sym(%rip),%dst (REL32) */
        if S1K == 0u32 { if OPK == 2u32 { sov_movdqu_store_base(S1R, OPR, OPD)  return } }                                                  /* movdqu %src,disp(%base) : F3 0F 7F /r */
        if S1K == 0u32 { if OPK == 4u32 { sov_movdqu_store_sib(S1R, OPR, OPINDEX, OPSCALE, OPD)  return } }                                 /* movdqu %src,disp(b,i,s) */
        PARSE_ERR = 1u32  return
    } }
    /* VEX SIMD (vpxor/vpaddd/vmovdqu/... ) -- Tier-2 crypto set */
    if sp_try_vec() == 1u32 { return }
    /* branches (jmp/jcc to a .text label) -- resolved via the two-pass */
    if sp_try_branch() == 1u32 { return }
    PARSE_ERR = 1u32    /* unknown mnemonic -> loud, located failure */
}

/* ONE encode pass (LAYOUT if SP_PASS==1, FINAL if SP_PASS==2).  Tracks CUR_SEC (for label-section), reads the
 * full token (so long labels are not truncated), records .text label offsets in the layout pass, dispatches
 * instructions otherwise.  Returns 0 ok / -1 on PARSE_ERR. */
fn sovparse(ptr: *u8, len: u32) -> i32 @export {
    sov_reset()
    PARSE_ERR = 0u32
    CUR_SEC = SEC_OTHER
    IN_PTR = ptr as u64  IN_LEN = len  IN_POS = 0u32
    while IN_POS < IN_LEN {
        if PARSE_ERR == 0u32 { CUR_OFF = IN_POS }   /* DIAGNOSTIC: last line-start parsed before the error */
        sp_skip_ws()
        let c : u32 = sp_ch()
        if c == C_NL { sp_adv() }
        else { if c == C_CR { sp_adv() }
        else { if c == 0u32 { sp_adv() }
        else { if c == C_DOT { sp_dot_line()  sp_skip_line() }   /* directive (track CUR_SEC) OR a .Lxxx: local label */
        else { if c == C_HASH { sp_skip_line() }    /* comment */
        else {
            if is_ident_start(c) == 1u32 {
                /* read the FULL token into scratch slot SYM_N; mirror first <=8 chars into MN for mn_is */
                let tlen : u32 = sp_read_name_into(SYM_N)
                MNN = tlen  if MNN > 16u32 { MNN = 16u32 }   /* 16 (was 8): long SIMD mnemonics need MN[9] disambiguation */
                let mut mi : u32 = 0u32
                while mi < MNN { MN[mi as u64] = SYM_NAME[((SYM_N * 64u32) + mi) as u64] as u32  mi = mi + 1u32 }
                if sp_ch() == C_COLON {
                    sp_adv()
                    if SP_PASS == 1u32 { if CUR_SEC == SEC_TEXT { lbl_record(SYM_N, tlen) } }   /* record .text label offset */
                    sp_skip_line()
                } else {
                    sp_dispatch_instr()
                    sp_skip_line()
                }
            } else { sp_skip_line() }
        } } } } }
    }
    if PARSE_ERR == 1u32 { return 0i32 - 1i32 }
    return 0i32
}

/* ── PASS 1: build the data-symbol table (L_* -> section, offset within section) ── */
fn sp_read_dir() {   /* read a directive name (after the '.') into MN */
    MNN = 0u32
    while is_ident(sp_ch()) == 1u32 { if MNN < 16u32 { MN[MNN as u64] = sp_ch()  MNN = MNN + 1u32 }  sp_adv() }
}
fn sp_count_bytes() -> u32 {   /* count comma-separated values on the rest of the line (.byte a,b,c) */
    let save : u32 = IN_POS
    let mut cnt : u32 = 1u32
    while IN_POS < IN_LEN { let c : u32 = sp_ch()  if c == C_NL { IN_POS = save  return cnt }  if c == C_COM { cnt = cnt + 1u32 }  sp_adv() }
    IN_POS = save
    return cnt
}
fn sp_record_at(nlen: u32) {   /* commit the just-read name (in scratch slot SYM_N) as a symbol */
    if SYM_N < 8191u32 {   /* 8191 NOT 8192: SYM_N is also the scratch name-write slot (SYM_NAME[SYM_N*32+..]); 8192 would overrun SYM_NAME[262144] */
        SYM_NLEN[SYM_N as u64] = nlen
        SYM_SEC[SYM_N as u64] = CUR_SEC
        SYM_OFF[SYM_N as u64] = SEC_OFF[CUR_SEC as u64]
        SYM_N = SYM_N + 1u32
    }
}
/* emit n little-endian bytes of a numeric value into the current data section (.data/.rodata) */
fn sp_emit_val(v: i64, n: u32) {
    let u : u64 = v as u64
    let mut k : u32 = 0u32
    while k < n { sov_data_emit(CUR_SEC, ((u >> (8u64 * (k as u64))) & 0xFFu64) as u32)  k = k + 1u32 }
}
/* emit comma-separated .byte values, one byte each */
fn sp_emit_bytes() {
    sp_skip_ws()
    let mut go : u32 = 1u32
    while go == 1u32 {
        let v : i64 = sp_num()
        sov_data_emit(CUR_SEC, (v as u32) & 0xFFu32)
        sp_skip_ws()
        if sp_ch() == C_COM { sp_adv()  sp_skip_ws() } else { go = 0u32 }
    }
}
/* emit a .ascii/.asciz string's raw bytes into the current data section; return the byte count.  Handles the
 * common backslash escapes (\0 \n \t \r) + \\ \" .  addnull=1 appends a NUL terminator (.asciz). */
fn sp_emit_string(addnull: u32) -> u32 {
    let mut cnt : u32 = 0u32
    sp_skip_ws()
    if sp_ch() == 34u32 { sp_adv() }                 /* opening quote */
    let mut go : u32 = 1u32
    while go == 1u32 {
        let c : u32 = sp_ch()
        if c == 34u32 { sp_adv()  go = 0u32 }          /* closing quote */
        else { if c == 0u32 { go = 0u32 }              /* end of buffer (safety) */
        else { if c == 92u32 {                          /* backslash escape */
            sp_adv()  let ee : u32 = sp_ch()  sp_adv()
            let mut bb : u32 = ee
            if ee == 48u32 { bb = 0u32 }                /* \0 */
            if ee == 110u32 { bb = 10u32 }              /* \n */
            if ee == 116u32 { bb = 9u32 }               /* \t */
            if ee == 114u32 { bb = 13u32 }              /* \r */
            sov_data_emit(CUR_SEC, bb)  cnt = cnt + 1u32
        }
        else { sov_data_emit(CUR_SEC, c)  cnt = cnt + 1u32  sp_adv() } } }
    }
    if addnull == 1u32 { sov_data_emit(CUR_SEC, 0u32)  cnt = cnt + 1u32 }
    return cnt
}
fn sp_dir1() {
    sp_read_dir()
    if mn_is(115u32,101u32,99u32,116u32,7u32) == 1u32 {        /* section <name> */
        sp_skip_ws()
        if sp_ch() == C_DOT { sp_adv() }
        let f : u32 = sp_ch()
        if f == 100u32 { CUR_SEC = SEC_DATA }                  /* .data */
        else { if f == 114u32 { CUR_SEC = SEC_RODATA }         /* .rodata */
        else { if f == 98u32 { CUR_SEC = SEC_BSS }             /* .bss */
        else { if f == 116u32 { CUR_SEC = SEC_TEXT }           /* .text */
        else { CUR_SEC = SEC_OTHER } } } }
        return
    }
    if mn_is(116u32,101u32,120u32,116u32,4u32) == 1u32 { CUR_SEC = SEC_TEXT  return }     /* .text */
    if mn_is(100u32,97u32,116u32,97u32,4u32) == 1u32 { CUR_SEC = SEC_DATA  return }       /* .data */
    if mn_is(98u32,115u32,115u32,0u32,3u32) == 1u32 { CUR_SEC = SEC_BSS  return }         /* .bss */
    if mn_is(114u32,111u32,100u32,97u32,6u32) == 1u32 { CUR_SEC = SEC_RODATA  return }    /* .rodata */
    if mn_is(103u32,108u32,111u32,98u32,6u32) == 1u32 {   /* .global <name> -> an exported COFF symbol */
        if SP_PASS == 0u32 { sp_skip_ws()  let gl : u32 = sp_read_name_into(SYM_N)  exp_record(SYM_N, gl) }
        return
    }
    if mn_is(103u32,108u32,111u32,98u32,5u32) == 1u32 {   /* .globl <name> (gas short spelling; hand-written cpuid_helper.s) */
        if SP_PASS == 0u32 { sp_skip_ws()  let gl : u32 = sp_read_name_into(SYM_N)  exp_record(SYM_N, gl) }
        return
    }
    if CUR_SEC < 4u32 {
        if mn_is(113u32,117u32,97u32,100u32,4u32) == 1u32 {        /* .quad */
            SEC_OFF[CUR_SEC as u64] = SEC_OFF[CUR_SEC as u64] + 8u32
            if SP_PASS == 0u32 { if CUR_SEC < 3u32 { sp_skip_ws()  sp_emit_val(sp_num(), 8u32) } }
        }
        if mn_is(108u32,111u32,110u32,103u32,4u32) == 1u32 {       /* .long */
            SEC_OFF[CUR_SEC as u64] = SEC_OFF[CUR_SEC as u64] + 4u32
            if SP_PASS == 0u32 { if CUR_SEC < 3u32 { sp_skip_ws()  sp_emit_val(sp_num(), 4u32) } }
        }
        if mn_is(98u32,121u32,116u32,101u32,4u32) == 1u32 {        /* .byte */
            SEC_OFF[CUR_SEC as u64] = SEC_OFF[CUR_SEC as u64] + sp_count_bytes()
            if SP_PASS == 0u32 { if CUR_SEC < 3u32 { sp_emit_bytes() } }
        }
        if mn_is(122u32,101u32,114u32,111u32,4u32) == 1u32 {       /* .zero */
            sp_skip_ws()  let zn : u32 = sp_num() as u32
            SEC_OFF[CUR_SEC as u64] = SEC_OFF[CUR_SEC as u64] + zn
            if SP_PASS == 0u32 {
                if CUR_SEC == 3u32 { sov_bss_add(zn) }
                else { let mut zk : u32 = 0u32  while zk < zn { sov_data_emit(CUR_SEC, 0u32)  zk = zk + 1u32 } }
            }
        }
        if mn_is(97u32,115u32,99u32,105u32,5u32) == 1u32 {         /* .ascii (MN[4]='i') or .asciz (MN[4]='z') */
            if SP_PASS == 0u32 { if CUR_SEC < 3u32 {
                let mut an : u32 = 0u32
                if MN[4u64] == 122u32 { an = 1u32 }
                SEC_OFF[CUR_SEC as u64] = SEC_OFF[CUR_SEC as u64] + sp_emit_string(an)
            } }
        }
    }
    /* NOTE: .ascii/.asciz raw bytes not yet emitted -> a tracked-section string would under-size the section.
     * cg_r3 keeps its function-name strings in OTHER sections (.iii.ring3), so this is exact for numeric data;
     * .ascii/.asciz emission is the next data sub-step (needed for .rodata string literals). */
}
fn sp_build_symtab(ptr: *u8, len: u32) {
    SYM_N = 0u32
    EXP_N = 0u32
    SP_PASS = 0u32      /* pass D: record exports + emit data-section bytes here, once */
    sov_data_reset()
    SEC_OFF[0u64] = 0u32  SEC_OFF[1u64] = 0u32  SEC_OFF[2u64] = 0u32  SEC_OFF[3u64] = 0u32
    CUR_SEC = SEC_OTHER
    IN_PTR = ptr as u64  IN_LEN = len  IN_POS = 0u32
    while IN_POS < IN_LEN {
        sp_skip_ws()
        let c : u32 = sp_ch()
        if c == C_NL { sp_adv() }
        else { if c == C_CR { sp_adv() }
        else { if c == 0u32 { sp_adv() }
        else { if c == C_HASH { sp_skip_line() }
        else { if c == C_DOT { sp_adv()  sp_dir1()  sp_skip_line() }
        else { if is_ident_start(c) == 1u32 {
            let nlen : u32 = sp_read_name_into(SYM_N)
            if sp_ch() == C_COLON {
                if CUR_SEC == SEC_DATA { sp_record_at(nlen) }
                else { if CUR_SEC == SEC_RODATA { sp_record_at(nlen) }
                else { if CUR_SEC == SEC_BSS { sp_record_at(nlen) }
                else { if CUR_SEC == SEC_TEXT { sp_record_at(nlen) } } } }   /* TEXT labels: for sibling-call/branch detection */
            }
            sp_skip_line()
        }
        else { sp_skip_line() } } } } } }
    }
}

/* the full assemble: D (data symbol table) -> L (layout: record .text label offsets) -> F (final: resolve
 * branch + sibling-call displacements and emit).  The final pass's SOV_BUF + reloc table are the result. */
fn sovparse_full(ptr: *u8, len: u32) -> i32 @export {
    sp_build_symtab(ptr, len)        /* D */
    /* L: layout, iterated for branch RELAXATION -- all branches start REL8; any that overflows grows to REL32
     * (shifting later offsets), re-layout, until stable. */
    let mut bi : u32 = 0u32
    while bi < 16384u32 { BR_BIG[bi as u64] = 0u32  bi = bi + 1u32 }
    BR_N = 0u32
    let mut iter : u32 = 0u32
    let mut go : u32 = 1u32
    while go == 1u32 {
        LBL_N = 0u32  BR_IDX = 0u32
        SP_PASS = 1u32  sovparse(ptr, len)
        go = sp_relax_check()
        iter = iter + 1u32
        if iter > 8u32 { go = 0u32 }
    }
    /* resolve each export's offset now that the layout (incl. relaxation) is stable.  A .text global
     * resolves via the label table; a DATA global (.data/.rodata/.bss module var) resolves via the pass-D
     * data-symbol table to (section, section-relative offset).  Without the data fallback, module-var
     * globals resolved 0xFFFFFFFF and sovcoff silently dropped them from the COFF symbol table -> external
     * refs (resolver_hot.s) failed to link (DOCS/III-SOVEREIGN-EMIT-SYMBOL-REGRESSION.md). */
    let mut e : u32 = 0u32
    while e < EXP_N {
        let elen : u32 = EXP_NLEN[e as u64]
        let mut j : u32 = 0u32
        while j < elen { SYM_NAME[((SYM_N * 64u32) + j) as u64] = EXP_NAME[((e * 64u32) + j) as u64]  j = j + 1u32 }
        EXP_OFF[e as u64] = lbl_find(SYM_N, elen)
        EXP_SEC[e as u64] = 0u32
        if EXP_OFF[e as u64] == 0xFFFFFFFFu32 {
            let mut si : u32 = 0u32
            while si < SYM_N {
                if sp_names_eq(SYM_N, elen, si, SYM_NLEN[si as u64]) == 1u32 {
                    let ssec : u32 = SYM_SEC[si as u64]
                    if ssec >= 1u32 { if ssec <= 3u32 { EXP_OFF[e as u64] = SYM_OFF[si as u64]  EXP_SEC[e as u64] = ssec } }
                    si = SYM_N
                } else { si = si + 1u32 }
            }
        }
        e = e + 1u32
    }
    BR_IDX = 0u32
    SP_PASS = 2u32  return sovparse(ptr, len)   /* F */
}
