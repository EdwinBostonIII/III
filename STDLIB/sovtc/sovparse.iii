extern @abi(c-msvc-x64) fn sov_cn_push(ch: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_call_ext() -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_test_rr(dst: u32, src: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_setcc(cc: u32, reg8: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_movzbq(dst: u32, src: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_movzwq(dst: u32, src: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_movslq(dst: u32, src: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_movsbq(dst: u32, src: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_movswq(dst: u32, src: u32) -> i32 from "sovas.iii"
