/* test_dllroute.iii  --  teeth for sovld's DLL routing (Phase A / audit P2b).
 *
 * Interns real Win32/CRT import names and asserts ext_dll_of maps each to the correct DLL id:
 *   kernel32=0  msvcrt=1  user32=2  gdi32=3  ws2_32=4.
 * Before the 5-DLL id table lands, ws2_32 names (WSAStartup/htons) fall through the UPPER-first/lowercase
 * heuristic to kernel32/msvcrt, and user32/gdi32 names (CreateWindowExA/StretchDIBits) mis-route to kernel32
 * -- so this KAT goes RED (returns the first failing stage's code).  With the table it returns 99.
 * The asserted names are the MEASURED import surface (aether/net.iii, aether/ui_win.iii, aether_world.iii).
 *   exit: 1 WSAStartup  2 htons  3 ExitProcess  4 putchar  5 CreateWindowExA  6 StretchDIBits  7 lstrlenA
 *         8 send  9 GetDC(user32!)  ; 99 = all exact.
 */
module sovtc_test_dllroute

extern @abi(c-msvc-x64) fn sov_cn_clear() -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_cn_push(ch: u32) -> i32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_ext_intern_pub() -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sovld_ext_dll_of_pub(slot: u32) -> u32 from "sovld.iii"

fn route(s: *u8, n: u32) -> u32 {
    sov_cn_clear()
    let mut i : u32 = 0u32
    while i < n { sov_cn_push(s[i as u64] as u32)  i = i + 1u32 }
    return sovld_ext_dll_of_pub(sov_ext_intern_pub())
}

fn main() -> u64 {
    if route("WSAStartup" as *u8, 10u32) != 4u32 { return 1u64 }        /* ws2_32 */
    if route("htons" as *u8, 5u32) != 4u32 { return 2u64 }              /* ws2_32 (lowercase, not a CRT fn) */
    if route("ExitProcess" as *u8, 11u32) != 0u32 { return 3u64 }       /* kernel32 */
    if route("putchar" as *u8, 7u32) != 1u32 { return 4u64 }            /* msvcrt */
    if route("CreateWindowExA" as *u8, 15u32) != 2u32 { return 5u64 }   /* user32 */
    if route("StretchDIBits" as *u8, 13u32) != 3u32 { return 6u64 }     /* gdi32 */
    if route("lstrlenA" as *u8, 8u32) != 0u32 { return 7u64 }           /* kernel32 (lowercase, exact-table override) */
    if route("send" as *u8, 4u32) != 4u32 { return 8u64 }               /* ws2_32 (would heuristic-route to msvcrt) */
    if route("GetDC" as *u8, 5u32) != 2u32 { return 9u64 }              /* user32 (NOT gdi32 -- the real Win32 home) */
    return 99u64
}
