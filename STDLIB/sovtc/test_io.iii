/* test_io.iii  --  GOODIE 1 gate: argv[1] + Win32 file-read, isolated.
 * main(argc, argv) takes the CRT's argv; opens argv[1] with CreateFileA(GENERIC_READ); reads it in a
 * ReadFile loop into SBUF; returns bytes_read & 0xFF.  Run `test_io.exe <file>`; for boot1.o.s (4691 bytes)
 * the exit code is 4691 & 0xFF = 83.  Proves BOTH the CRT argv hand-off AND the read loop on real Win32. */
module sovtc_test_io

extern @abi(c-msvc-x64) fn CreateFileA(name: *u8, access: u32, share: u32, sec: u64, disp: u32, flags: u32, tmpl: u64) -> u64 from "kernel32"
extern @abi(c-msvc-x64) fn ReadFile(h: u64, buf: *u8, n: u32, nread: u64, ovl: u64) -> i32 from "kernel32"
extern @abi(c-msvc-x64) fn CloseHandle(h: u64) -> i32 from "kernel32"

const GENERIC_READ   : u32 = 0x80000000u32
const OPEN_EXISTING  : u32 = 3u32
const SHARE_READ     : u32 = 1u32
const ATTR_NORMAL    : u32 = 0x80u32
const INVALID_HANDLE : u64 = 0xFFFFFFFFFFFFFFFFu64

var NXFER : [u8; 8]
var SBUF  : [u8; 65536]

fn read_file(path: *u8) -> u32 {
    let h : u64 = CreateFileA(path, GENERIC_READ, SHARE_READ, 0u64, OPEN_EXISTING, ATTR_NORMAL, 0u64)
    if h == INVALID_HANDLE { return 0u32 }
    let mut off : u32 = 0u32
    let mut go  : u32 = 1u32
    while go == 1u32 {
        let dst : *u8 = ((&SBUF as u64) + (off as u64)) as *u8
        let ok  : i32 = ReadFile(h, dst, 65536u32 - off, (&NXFER) as u64, 0u64)
        if ok == 0i32 { go = 0u32 }
        else {
            let p  : *u32 = (&NXFER) as *u32
            let nr : u32 = p[0u64]
            if nr == 0u32 { go = 0u32 }
            else { off = off + nr }
        }
    }
    CloseHandle(h)
    return off
}

fn main(argc: i32, argv: u64) -> u64 {
    let ac : i32 = argc
    if ac < 2i32 { return 2u64 }
    let pp   : *u64 = argv as *u64
    let path : *u8  = pp[1u64] as *u8
    let n    : u32  = read_file(path)
    return (n & 0xFFu32) as u64
}
