/* test_movzx_sib.iii  --  movz/movs from a SIB memory operand (string/array byte+word reads).  gas-exact:
 *   movzbq (%rax,%rcx,1),%rax     = 48 0f b6 04 08
 *   movzbq 8(%rax,%rcx,1),%rax    = 48 0f b6 44 08 08            (disp8)
 *   movzbq 200(%rax,%rcx,1),%rax  = 48 0f b6 84 08 c8 00 00 00   (disp32)
 *   movzwq (%rax,%rcx,2),%rax     = 48 0f b7 04 48
 *   movsbq (%rax,%rcx,1),%rax     = 48 0f be 04 08
 *   movswq (%rax,%rcx,2),%rax     = 48 0f bf 04 48
 *   movslq (%rax,%rcx,4),%rax     = 48 63 04 88                  (movsxd, opcode 63)
 *   movslq 8(%rax,%rcx,4),%rax    = 48 63 44 88 08
 * exit 99 = all 44 bytes match gas.  13 len / 14+i byte i.
 */
module sovtc_test_movzx_sib

extern @abi(c-msvc-x64) fn sovparse_full(ptr: *u8, len: u32) -> i32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn sov_len() -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_at(i: u32) -> u32 from "sovas.iii"

var GOLD : [u8; 44] = [
  0x48u8,0x0Fu8,0xB6u8,0x04u8,0x08u8,
  0x48u8,0x0Fu8,0xB6u8,0x44u8,0x08u8,0x08u8,
  0x48u8,0x0Fu8,0xB6u8,0x84u8,0x08u8,0xC8u8,0x00u8,0x00u8,0x00u8,
  0x48u8,0x0Fu8,0xB7u8,0x04u8,0x48u8,
  0x48u8,0x0Fu8,0xBEu8,0x04u8,0x08u8,
  0x48u8,0x0Fu8,0xBFu8,0x04u8,0x48u8,
  0x48u8,0x63u8,0x04u8,0x88u8,
  0x48u8,0x63u8,0x44u8,0x88u8,0x08u8
]

fn slen(s: *u8) -> u32 { let mut i : u32 = 0u32  while i < 8192u32 { if s[i as u64] == 126u8 { return i }  i = i + 1u32 }  return 0u32 }

fn main() -> u64 {
    let src : *u8 = "  .text\n  movzbq (%rax,%rcx,1), %rax\n  movzbq 8(%rax,%rcx,1), %rax\n  movzbq 200(%rax,%rcx,1), %rax\n  movzwq (%rax,%rcx,2), %rax\n  movsbq (%rax,%rcx,1), %rax\n  movswq (%rax,%rcx,2), %rax\n  movslq (%rax,%rcx,4), %rax\n  movslq 8(%rax,%rcx,4), %rax\n~" as *u8
    let n : u32 = slen(src)
    if sovparse_full(src, n) != 0i32 { return 10u64 }
    if sov_len() != 44u32 { return 13u64 }
    let mut i : u32 = 0u32
    while i < 44u32 { if sov_at(i) != (GOLD[i as u64] as u32) { return (14u64 + (i as u64)) }  i = i + 1u32 }
    return 99u64
}
