/* test_sib.iii  --  SIB-memory operands (base+index*scale).  Real cg_r3 array fn `A[3]=99; return A[3]`:
 *   movq %rdx, (%rax,%rcx,8)  = 48 89 14 c8   (store to base+index*8)
 *   movq (%rax,%rcx,8), %rax  = 48 8b 04 c8   (load)
 * plus two leaq L_A(%rip) -> .bss relocs.  Must reproduce gcc's 100 .text bytes + the 2 relocs exactly.
 *   11 reln / 12 relent / 13 len / 14+i byte i.  exit 99 = SIB encode + .bss reloc byte+reloc exact vs gcc.
 */
module sovtc_test_sib

extern @abi(c-msvc-x64) fn sovparse_full(ptr: *u8, len: u32) -> i32 from "sovparse.iii"
extern @abi(c-msvc-x64) fn sov_len() -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_at(i: u32) -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_reloc_n() -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_reloc_off(i: u32) -> u32 from "sovas.iii"
extern @abi(c-msvc-x64) fn sov_reloc_sec(i: u32) -> u32 from "sovas.iii"

var GOLD : [u8; 100] = [
  0x55u8,0x48u8,0x89u8,0xE5u8,0x48u8,0x81u8,0xECu8,0x00u8,0x04u8,0x00u8,0x00u8,0x48u8,0x8Du8,0x05u8,0x00u8,0x00u8,
  0x00u8,0x00u8,0x50u8,0x48u8,0xB8u8,0x03u8,0x00u8,0x00u8,0x00u8,0x00u8,0x00u8,0x00u8,0x00u8,0x50u8,0x48u8,0xB8u8,
  0x63u8,0x00u8,0x00u8,0x00u8,0x00u8,0x00u8,0x00u8,0x00u8,0x50u8,0x5Au8,0x59u8,0x58u8,0x48u8,0x89u8,0x14u8,0xC8u8,
  0x48u8,0x8Du8,0x05u8,0x00u8,0x00u8,0x00u8,0x00u8,0x50u8,0x48u8,0xB8u8,0x03u8,0x00u8,0x00u8,0x00u8,0x00u8,0x00u8,
  0x00u8,0x00u8,0x50u8,0x59u8,0x58u8,0x48u8,0x8Bu8,0x04u8,0xC8u8,0x50u8,0x58u8,0x48u8,0x89u8,0xECu8,0x5Du8,0xC3u8,
  0x48u8,0xC7u8,0xC0u8,0x00u8,0x00u8,0x00u8,0x00u8,0x50u8,0x48u8,0xC7u8,0xC0u8,0x00u8,0x00u8,0x00u8,0x00u8,0x48u8,
  0x89u8,0xECu8,0x5Du8,0xC3u8
]

fn slen(s: *u8) -> u32 { let mut i : u32 = 0u32  while i < 8192u32 { if s[i as u64] == 126u8 { return i }  i = i + 1u32 }  return 0u32 }

fn main() -> u64 {
    let src : *u8 = "  .section .bss\n  .global L_A\nL_A:\n  .zero 64\n  .text\n  .global main\nmain:\n  pushq %rbp\n  movq %rsp, %rbp\n  subq $1024, %rsp\n  leaq L_A(%rip), %rax\n  pushq %rax\n  movabsq $0x3, %rax\n  pushq %rax\n  movabsq $0x63, %rax\n  pushq %rax\n  popq %rdx\n  popq %rcx\n  popq %rax\n  movq %rdx, (%rax,%rcx,8)\n  leaq L_A(%rip), %rax\n  pushq %rax\n  movabsq $0x3, %rax\n  pushq %rax\n  popq %rcx\n  popq %rax\n  movq (%rax,%rcx,8), %rax\n  pushq %rax\n  popq %rax\n  movq %rbp, %rsp\n  popq %rbp\n  retq\n  movq $0, %rax\n  pushq %rax\n  movq $0, %rax\n  movq %rbp, %rsp\n  popq %rbp\n  retq\n~" as *u8
    let n : u32 = slen(src)
    if sovparse_full(src, n) != 0i32 { return 10u64 }
    if sov_reloc_n() != 2u32 { return 11u64 }
    if sov_reloc_off(0u32) != 0x0Eu32 { return 12u64 }
    if sov_reloc_sec(0u32) != 3u32 { return 12u64 }     /* .bss */
    if sov_reloc_off(1u32) != 0x33u32 { return 12u64 }
    if sov_reloc_sec(1u32) != 3u32 { return 12u64 }
    if sov_len() != 100u32 { return 13u64 }
    let mut i : u32 = 0u32
    while i < 100u32 { if sov_at(i) != (GOLD[i as u64] as u32) { return (14u64 + (i as u64)) }  i = i + 1u32 }
    return 99u64
}
