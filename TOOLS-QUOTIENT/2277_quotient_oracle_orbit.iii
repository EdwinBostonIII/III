/* 2277_quotient_oracle_orbit.iii -- WEAPON 1 made real: the QUOTIENT ORACLE as an O(1) theorem multiplier.
 *
 * CLAIM (path-forward Weapon 1): proving an exact identity for ONE orbit representative proves it, exactly and for
 * free, for the entire 2^m-1 remaining orbit -- via the Galois group action = REFLECT (c2/2274).
 *
 * THE CONCRETE ORBIT: in Q(sqrt A, sqrt B, sqrt C) (side-length-squared radicands of a triangle), the incenter is the
 * barycentric point (a:b:c) with a=sqrt A, b=sqrt B, c=sqrt C.  The three EXCENTERS are (-a:b:c),(a:-b:c),(a:b:-c).
 * Because the vertex coordinates are RATIONAL (Galois-fixed), applying the automorphism sigma_A: sqrt A |-> -sqrt A to
 * the incenter's field coordinates gives EXACTLY the excenter I_A -- the excenter IS the Galois conjugate of the
 * incenter.  So the whole in/excenter family is the orbit (Z/2)^3 / (global sign) = 4 points of ONE invariant.
 *
 * THE MULTIPLIER (proven, not asserted): sigma_g applied to the incenter is a pure SIGN FLIP of 4 of 8 field
 * components -- ZERO kf_mul, O(1).  Yet ARM 2 shows sigma_A(incenter) content-addresses IDENTICALLY to I_A built by a
 * genuinely INDEPENDENT construction (internal bisector from A  intersect  EXTERNAL bisector from B, a full Kramer
 * solve using kf_mul).  So the incenter's hard-won two-construction collapse (2329) transfers to the excenter for the
 * price of a sign flip.  Pay the exact (PosSLP-family) cost ONCE; the involution certifies the rest of the class.
 *
 * exit 99 = the orbit is generated by the group action AND a conjugate matches an independent construction.
 *   1/2 address build failed
 *   10 ARM1: the 4 in/excenters are not DISTINCT (the orbit is not size 4)
 *   20 ARM2: sigma_A(incenter) != I_A via the independent external-bisector solve (the free theorem is false)
 *   30 ARM3: a non-orbit point (centroid) collapsed into the orbit (false positive)
 *   8  the coincidence engine did not see exactly 5 distinct points (4 orbit + 1 control) */
module corpus_2277_quotient_oracle_orbit

extern @abi(c-msvc-x64) fn kf_radix(sa: i64, sb: i64, sc: i64) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_zero(p: u64) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_mul(out: u64, x: u64, y: u64) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn kf_point_addr(nx: u64, ny: u64, den: u64, out32: *u8) -> i32 from "kfield.iii"
extern @abi(c-msvc-x64) fn coin_reset() -> i32 from "coincidence.iii"
extern @abi(c-msvc-x64) fn coin_observe_concrete(addr: *u8, faculty: u32, result: u64) -> u8 from "coincidence.iii"
extern @abi(c-msvc-x64) fn coin_concrete_n() -> u32 from "coincidence.iii"

var INX : [i64; 8]   var INY : [i64; 8]   var IDEN : [i64; 8]
var CNX : [i64; 8]   var CNY : [i64; 8]   var CDEN : [i64; 8]
var DAX : [i64; 8]   var DAY : [i64; 8]   var DBX : [i64; 8]   var DBY : [i64; 8]
var SN  : [i64; 8]   var SD  : [i64; 8]   var NX2 : [i64; 8]   var NY2 : [i64; 8]
var T1  : [i64; 8]   var T2  : [i64; 8]   var T3  : [i64; 8]
var CENX: [i64; 8]   var CENY: [i64; 8]   var CEDEN:[i64; 8]
var AIN : [u8; 32]   var ACA : [u8; 32]   var ACB : [u8; 32]   var ACC : [u8; 32]
var AEXT: [u8; 32]   var ACENT: [u8; 32]

/* copy 8 field components. */
fn vcopy(dst: u64, src: u64) -> i32 {
    let d : *i64 = dst as *i64   let s : *i64 = src as *i64
    let mut i : u64 = 0u64
    while i < 8u64 { d[i] = s[i]   i = i + 1u64 }
    return 0i32
}

/* THE GROUP ACTION = REFLECT: sigma_g on a field vector negates every basis element whose mask includes g (O(1)). */
fn sigma_apply(p: u64, gbit: u64) -> i32 {
    let v : *i64 = p as *i64
    let mut i : u64 = 0u64
    while i < 8u64 {
        if (i & gbit) != 0u64 { v[i] = 0i64 - v[i] }
        i = i + 1u64
    }
    return 0i32
}

fn addr_eq(x: u64, y: u64) -> u32 {
    let px : *u8 = x as *u8   let py : *u8 = y as *u8
    let mut i : u64 = 0u64
    while i < 32u64 { if px[i] != py[i] { return 0u32 }   i = i + 1u64 }
    return 1u32
}

/* build a conjugate excenter address: copy the incenter field coords, apply sigma_g, canonicalize. NO kf_mul. */
fn conjugate_excenter(gbit: u64, out32: u64) -> i32 {
    vcopy((&CNX) as u64, (&INX) as u64)
    vcopy((&CNY) as u64, (&INY) as u64)
    vcopy((&CDEN) as u64, (&IDEN) as u64)
    sigma_apply((&CNX) as u64, gbit)
    sigma_apply((&CNY) as u64, gbit)
    sigma_apply((&CDEN) as u64, gbit)
    return kf_point_addr((&CNX) as u64, (&CNY) as u64, (&CDEN) as u64, out32 as *u8)
}

fn main() -> u64 {
    kf_radix(5i64, 10i64, 13i64)                            /* triangle (1,0),(4,2),(2,3): A=5,B=10,C=13 */

    /* the incenter barycentric (a:b:c), a=sqrtA(idx1) b=sqrtB(idx2) c=sqrtC(idx4). PAY THE EXACT COST ONCE. */
    kf_zero((&INX) as u64)   INX[1u64] = 1i64   INX[2u64] = 4i64   INX[4u64] = 2i64
    kf_zero((&INY) as u64)   INY[1u64] = 0i64   INY[2u64] = 2i64   INY[4u64] = 3i64
    kf_zero((&IDEN) as u64)  IDEN[1u64] = 1i64  IDEN[2u64] = 1i64  IDEN[4u64] = 1i64
    if kf_point_addr((&INX) as u64, (&INY) as u64, (&IDEN) as u64, (&AIN) as *u8) != 0i32 { return 1u64 }

    /* ===== ARM 1 -- GENERATE THE ORBIT FOR FREE: sigma_A, sigma_B, sigma_C on the incenter (O(1), no kf_mul). ===== */
    conjugate_excenter(1u64, (&ACA) as u64)                 /* I_A = sigma_A(incenter) */
    conjugate_excenter(2u64, (&ACB) as u64)                 /* I_B = sigma_B(incenter) */
    conjugate_excenter(4u64, (&ACC) as u64)                 /* I_C = sigma_C(incenter) */

    /* the 4 in/excenters must be DISTINCT -- the orbit has exactly 4 elements. */
    coin_reset()
    if coin_observe_concrete((&AIN) as *u8, 1u32, 0u64) != 0u8 { return 10u64 }
    if coin_observe_concrete((&ACA) as *u8, 1u32, 0u64) != 0u8 { return 10u64 }
    if coin_observe_concrete((&ACB) as *u8, 1u32, 0u64) != 0u8 { return 10u64 }
    if coin_observe_concrete((&ACC) as *u8, 1u32, 0u64) != 0u8 { return 10u64 }

    /* ===== ARM 2 -- THE FREE THEOREM IS REAL: sigma_A(incenter) == I_A via an INDEPENDENT external-bisector solve. ==== */
    /* internal bisector A (dir sqrtB*(B-A)+sqrtC*(C-A)) ∩ EXTERNAL bisector B (dir sqrtA*(A-B) - sqrtC*(C-B)). */
    kf_zero((&DAX) as u64)   DAX[2u64] = 3i64   DAX[4u64] = 1i64
    kf_zero((&DAY) as u64)   DAY[2u64] = 2i64   DAY[4u64] = 3i64
    kf_zero((&DBX) as u64)   DBX[1u64] = 0i64 - 3i64   DBX[4u64] = 2i64
    kf_zero((&DBY) as u64)   DBY[1u64] = 0i64 - 2i64   DBY[4u64] = 0i64 - 1i64
    let mut m : u64 = 0u64
    while m < 8u64 { SN[m] = 3i64 * DBY[m] - 2i64 * DBX[m]   m = m + 1u64 }
    kf_mul((&T1) as u64, (&DAX) as u64, (&DBY) as u64)
    kf_mul((&T2) as u64, (&DAY) as u64, (&DBX) as u64)
    m = 0u64   while m < 8u64 { SD[m] = T1[m] - T2[m]   m = m + 1u64 }
    kf_mul((&T3) as u64, (&SN) as u64, (&DAX) as u64)
    m = 0u64   while m < 8u64 { NX2[m] = 1i64 * SD[m] + T3[m]   m = m + 1u64 }
    kf_mul((&T3) as u64, (&SN) as u64, (&DAY) as u64)
    m = 0u64   while m < 8u64 { NY2[m] = 0i64 * SD[m] + T3[m]   m = m + 1u64 }
    if kf_point_addr((&NX2) as u64, (&NY2) as u64, (&SD) as u64, (&AEXT) as *u8) != 0i32 { return 2u64 }

    if addr_eq((&ACA) as u64, (&AEXT) as u64) != 1u32 { return 20u64 }   /* conjugate == independent solve: FREE THEOREM */

    /* ===== ARM 3 -- CONTROL: the centroid (rational, off-orbit) is NOT in the in/excenter orbit. ===== */
    kf_zero((&CENX) as u64)   CENX[0u64] = 1i64 + 4i64 + 2i64
    kf_zero((&CENY) as u64)   CENY[0u64] = 0i64 + 2i64 + 3i64
    kf_zero((&CEDEN) as u64)  CEDEN[0u64] = 3i64
    if kf_point_addr((&CENX) as u64, (&CENY) as u64, (&CEDEN) as u64, (&ACENT) as *u8) != 0i32 { return 1u64 }
    if coin_observe_concrete((&ACENT) as *u8, 1u32, 0u64) != 0u8 { return 30u64 }   /* distinct from all 4 orbit pts */

    if coin_concrete_n() != 5u32 { return 8u64 }            /* 4 orbit + 1 control = 5 distinct points */
    return 99u64
}
