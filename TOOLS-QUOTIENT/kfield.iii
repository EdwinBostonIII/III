/* STDLIB/iii/numera/kfield.iii -- the MULTIQUADRATIC FIELD K = Q(sqrt A, sqrt B, sqrt C).
 *
 * THE SOLVE for exact content-addressing of irrational geometry points. Every triangle center lives in K
 * (A,B,C = squared side lengths). K has degree <= 8 over Q with fixed basis indexed by a 3-bit MASK:
 *   mask m  <->  sqrt( prod_{bit i set in m} R_i )        R = (A,B,C)
 * A K-element is 8 integer coefficients (a common scalar denominator is carried separately by the point).
 *   MULTIPLY:  (e_i)(e_j) = ( prod_{bits in i&j} R ) * e_{i^j}     -- AND gives the rational factor, XOR the result
 *   CONJUGATE: the automorphism sqrt R_axis -> -sqrt R_axis  flips the sign of every mask with that bit set
 *   RATIONALIZE a denominator: multiply num & den by conj_A, conj_B, conj_C in turn -> after 3 the den is rational
 *   CANONICALIZE (degeneracy-robust): square-free-reduce each mask's radicand and COMBINE masks whose radicands
 *     share a square-free part (perfect squares fold into mask 0). This is the ONLY canonical form -- without it an
 *     isoceles/commensurable triangle would split one value across two masks and a real coincidence would be MISSED.
 *
 * SOUNDNESS/COMPLETENESS: general exact-real equality is undecidable (transcendental zero-test). Points in a FIXED
 * number field are decidable via this canonical form. So the content-address is SOUND ALWAYS (equal address => equal
 * value, never a false coincidence) and COMPLETE ON K (equal value => equal address, every real coincidence fires).
 * The general unsolvability IS the soundness guarantee; triangle centers live on the decidable island. No float, no ML. */
module numera_kfield

extern @abi(c-msvc-x64) fn sha256_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 from "sha256.iii"

var KR : [i64; 3]                    /* the radicands A,B,C */
var KTMP : [i64; 8]   var KCONJ : [i64; 8]
var SF_S : i64   var SF_D : i64
var KOC : [i64; 8]   var KOR : [i64; 8]      /* canonicalized (coeff, radicand) buckets for one coordinate */
var KOC2 : [i64; 8]  var KOR2 : [i64; 8]
var KPBUF : [u8; 272]                        /* address preimage: 2*(8 coeff + 8 rad) i64 + count + den */

fn kf_radix(sa: i64, sb: i64, sc: i64) -> i32 @export { KR[0] = sa   KR[1] = sb   KR[2] = sc   return 0i32 }

fn kf_zero(p: u64) -> i32 @export { let pp : *i64 = p as *i64   let mut m : u64 = 0u64   while m < 8u64 { pp[m] = 0i64   m = m + 1u64 }   return 0i32 }
fn kf_copy(dst: u64, src: u64) -> i32 { let d : *i64 = dst as *i64   let s : *i64 = src as *i64   let mut m : u64 = 0u64   while m < 8u64 { d[m] = s[m]   m = m + 1u64 }   return 0i32 }

fn kf_iabs(x: i64) -> i64 { if x < 0i64 { return 0i64 - x }   return x }
fn kf_igcd(x: i64, y: i64) -> i64 {
    let mut a : i64 = kf_iabs(x)   let mut b : i64 = kf_iabs(y)
    while b != 0i64 { let t : i64 = a % b   a = b   b = t }
    return a
}

fn kf_radicand(mask: u64) -> i64 {
    let mut r : i64 = 1i64
    if (mask & 1u64) != 0u64 { r = r * KR[0] }
    if (mask & 2u64) != 0u64 { r = r * KR[1] }
    if (mask & 4u64) != 0u64 { r = r * KR[2] }
    return r
}

/* out = x * y in K.  out MUST be distinct storage from x and y. */
fn kf_mul(out: u64, x: u64, y: u64) -> i32 @export {
    let po : *i64 = out as *i64   let px : *i64 = x as *i64   let py : *i64 = y as *i64
    kf_zero(out)
    let mut i : u64 = 0u64
    while i < 8u64 {
        if px[i] != 0i64 {
            let mut j : u64 = 0u64
            while j < 8u64 {
                if py[j] != 0i64 {
                    let inter : u64 = i & j
                    let mut f : i64 = 1i64
                    if (inter & 1u64) != 0u64 { f = f * KR[0] }
                    if (inter & 2u64) != 0u64 { f = f * KR[1] }
                    if (inter & 4u64) != 0u64 { f = f * KR[2] }
                    let mm : u64 = i ^ j
                    po[mm] = po[mm] + px[i] * py[j] * f
                }
                j = j + 1u64
            }
        }
        i = i + 1u64
    }
    return 0i32
}

fn kf_conj(out: u64, x: u64, axis: u32) -> i32 {
    let po : *i64 = out as *i64   let px : *i64 = x as *i64
    let bit : u64 = 1u64 << (axis as u64)
    let mut m : u64 = 0u64
    while m < 8u64 {
        if (m & bit) != 0u64 { po[m] = 0i64 - px[m] } else { po[m] = px[m] }
        m = m + 1u64
    }
    return 0i32
}

/* divide the point (nx,ny,den) by the common gcd of all their coefficients -- preserves nx/den, ny/den; bounds growth. */
fn kf_reduce3(nx: u64, ny: u64, den: u64) -> i32 {
    let px : *i64 = nx as *i64   let py : *i64 = ny as *i64   let pd : *i64 = den as *i64
    let mut g : i64 = 0i64
    let mut m : u64 = 0u64
    while m < 8u64 { g = kf_igcd(g, px[m])   g = kf_igcd(g, py[m])   g = kf_igcd(g, pd[m])   m = m + 1u64 }
    if g <= 1i64 { return 0i32 }
    m = 0u64
    while m < 8u64 { px[m] = px[m] / g   py[m] = py[m] / g   pd[m] = pd[m] / g   m = m + 1u64 }
    return 0i32
}

fn kf_rat_axis(nx: u64, ny: u64, den: u64, axis: u32) -> i32 {
    kf_conj((&KCONJ) as u64, den, axis)
    kf_mul((&KTMP) as u64, den, (&KCONJ) as u64)   kf_copy(den, (&KTMP) as u64)
    kf_mul((&KTMP) as u64, nx,  (&KCONJ) as u64)   kf_copy(nx,  (&KTMP) as u64)
    kf_mul((&KTMP) as u64, ny,  (&KCONJ) as u64)   kf_copy(ny,  (&KTMP) as u64)
    kf_reduce3(nx, ny, den)
    return 0i32
}
/* rationalize the point's denominator to a pure rational (mask 0); returns 1 if den became rational, 0 if not. */
fn kf_rationalize(nx: u64, ny: u64, den: u64) -> i32 {
    kf_rat_axis(nx, ny, den, 0u32)
    kf_rat_axis(nx, ny, den, 1u32)
    kf_rat_axis(nx, ny, den, 2u32)
    let pd : *i64 = den as *i64
    let mut m : u64 = 1u64
    while m < 8u64 { if pd[m] != 0i64 { return 0i32 }   m = m + 1u64 }
    return 1i32
}

fn kf_sqfree(n: i64) -> i32 {
    let mut d : i64 = n   let mut s : i64 = 1i64   let mut k : i64 = 2i64
    while k * k <= d {
        let kk : i64 = k * k
        let qd : i64 = d / kk
        if d - qd * kk == 0i64 { d = qd   s = s * k } else { k = k + 1i64 }
    }
    SF_S = s   SF_D = d
    return 0i32
}

/* degeneracy-robust canonical form of one K-coordinate v[8]: fold to buckets (coeff, square-free radicand),
 * combining masks with equal square-free part; insertion-sort by radicand into (oc,or); returns the term count. */
fn kf_canon_vec(v: u64, oc: u64, orad: u64) -> u64 {
    let pv : *i64 = v as *i64   let poc : *i64 = oc as *i64   let por : *i64 = orad as *i64
    let mut n : u64 = 0u64
    let mut mask : u64 = 0u64
    while mask < 8u64 {
        if pv[mask] != 0i64 {
            kf_sqfree(kf_radicand(mask))
            let coeff : i64 = pv[mask] * SF_S
            let d : i64 = SF_D
            let mut hit : u8 = 0u8   let mut fj : u64 = 0u64   let mut j : u64 = 0u64
            while j < n { if por[j] == d { fj = j   hit = 1u8 }   j = j + 1u64 }
            if hit == 1u8 { poc[fj] = poc[fj] + coeff } else { poc[n] = coeff   por[n] = d   n = n + 1u64 }
        }
        mask = mask + 1u64
    }
    /* drop any zeroed bucket, then insertion-sort by radicand */
    let mut w : u64 = 0u64   let mut r : u64 = 0u64
    while r < n { if poc[r] != 0i64 { poc[w] = poc[r]   por[w] = por[r]   w = w + 1u64 }   r = r + 1u64 }
    n = w
    let mut p : u64 = 1u64
    while p < n {
        let cv : i64 = poc[p]   let dv : i64 = por[p]
        let mut q : u64 = p   let mut go : u8 = 1u8
        while go == 1u8 {
            if q == 0u64 { go = 0u8 }
            if go == 1u8 { if por[q - 1u64] <= dv { go = 0u8 } }
            if go == 1u8 { poc[q] = poc[q - 1u64]   por[q] = por[q - 1u64]   q = q - 1u64 }
        }
        poc[q] = cv   por[q] = dv
        p = p + 1u64
    }
    return n
}

fn kf_put_i64(off: u64, v: i64) -> i32 {
    let u : u64 = v as u64
    let mut k : u64 = 0u64
    while k < 8u64 { KPBUF[off + k] = ((u >> (8u64 * k)) & 255u64) as u8   k = k + 1u64 }
    return 0i32
}

/* content-address the point (nx,ny,den): rationalize, canonicalize both coordinates (degeneracy-robust), reduce the
 * whole triple by gcd + fix sign(den)>0, and hash the canonical (coeff,radicand) lists + den. Returns 0 ok, 1 if the
 * denominator did not rationalize (a zero-divisor / off-field input -- refuse rather than emit a false address). */
fn kf_point_addr(nx: u64, ny: u64, den: u64, out32: *u8) -> i32 @export {
    if kf_rationalize(nx, ny, den) != 1i32 { return 1i32 }
    let nxn : u64 = kf_canon_vec(nx, (&KOC) as u64, (&KOR) as u64)
    let nyn : u64 = kf_canon_vec(ny, (&KOC2) as u64, (&KOR2) as u64)
    let pd : *i64 = den as *i64
    let mut d : i64 = pd[0]
    /* common gcd of all coeffs and d; then sign so d>0 */
    let mut g : i64 = kf_iabs(d)
    let mut m : u64 = 0u64
    while m < nxn { g = kf_igcd(g, KOC[m])   m = m + 1u64 }
    m = 0u64
    while m < nyn { g = kf_igcd(g, KOC2[m])   m = m + 1u64 }
    if g <= 0i64 { g = 1i64 }
    let mut sgn : i64 = 1i64
    if d < 0i64 { sgn = 0i64 - 1i64 }
    let gg : i64 = g * sgn
    m = 0u64   while m < nxn { KOC[m] = KOC[m] / gg   m = m + 1u64 }
    m = 0u64   while m < nyn { KOC2[m] = KOC2[m] / gg   m = m + 1u64 }
    d = d / gg
    /* pack: [nxn][ then nxn (coeff,rad) pairs ][nyn][ nyn pairs ][d]  into KPBUF, zero-padded region hashed fully */
    let mut z : u64 = 0u64   while z < 272u64 { KPBUF[z] = 0u8   z = z + 1u64 }
    kf_put_i64(0u64, nxn as i64)
    m = 0u64
    while m < nxn { kf_put_i64(8u64 + m * 16u64, KOC[m])   kf_put_i64(16u64 + m * 16u64, KOR[m])   m = m + 1u64 }
    kf_put_i64(136u64, nyn as i64)
    m = 0u64
    while m < nyn { kf_put_i64(144u64 + m * 16u64, KOC2[m])   kf_put_i64(152u64 + m * 16u64, KOR2[m])   m = m + 1u64 }
    kf_put_i64(264u64, d)
    sha256_oneshot((&KPBUF) as *u8, 272u64, out32)
    return 0i32
}

/* ── kf_sign: the GALOIS-TOWER sign decision — the theory made runnable. Decides sign(x) for x ∈ K EXACTLY, with NO
 * separation bound. Write x = p + q·√R (R = KR[level]; p,q in the subfield with bit `level` cleared): if sign(p) and
 * sign(q) agree it is that sign; if one is zero it is the other; if they differ it is sign(p)·sign(p²−q²R) — a value
 * one level down the tower ℚ(√A,√B,√C) ⊃ ℚ(√A,√B) ⊃ ℚ(√A) ⊃ ℚ. Depth 3, pure exact rational arithmetic, no float.
 * This closes "Σ√-sign OPEN" for the BOUNDED-rank (triangle) field; unbounded rank would blow the tower up 2^n (the
 * SOSR wall). Robust to un-squarefree radicands: √4 resolves to 2 through the recursion. ── */
var SGP : [i64; 24]   var SGQ : [i64; 24]   var SGP2 : [i64; 24]   var SGQ2 : [i64; 24]   var SGD : [i64; 24]

fn kf_split(x: u64, level: i32, pout: u64, qout: u64) -> i32 {
    let px : *i64 = x as *i64   let pp : *i64 = pout as *i64   let pq : *i64 = qout as *i64
    let bit : u64 = 1u64 << (level as u64)
    let mut m : u64 = 0u64
    while m < 8u64 { pp[m] = 0i64   pq[m] = 0i64   m = m + 1u64 }
    m = 0u64
    while m < 8u64 {
        if (m & bit) == 0u64 { pp[m] = px[m] } else { pq[m ^ bit] = px[m] }
        m = m + 1u64
    }
    return 0i32
}

fn kf_sign_rec(x: u64, level: i32) -> i32 {
    let px : *i64 = x as *i64
    if level < 0i32 {
        let v : i64 = px[0u64]                  /* bind first: inline `px[0] < 0` mis-evaluates as UNSIGNED (iii trap) */
        if v > 0i64 { return 1i32 }
        if v < 0i64 { return 0i32 - 1i32 }
        return 0i32
    }
    let off : u64 = (level as u64) * 8u64
    let pp : u64 = (&SGP as u64) + off * 8u64
    let qq : u64 = (&SGQ as u64) + off * 8u64
    kf_split(x, level, pp, qq)
    let sp : i32 = kf_sign_rec(pp, level - 1i32)
    let sq : i32 = kf_sign_rec(qq, level - 1i32)
    if sp == 0i32 { return sq }
    if sq == 0i32 { return sp }
    if sp == sq { return sp }
    let p2 : u64 = (&SGP2 as u64) + off * 8u64
    let q2 : u64 = (&SGQ2 as u64) + off * 8u64
    let dd : u64 = (&SGD as u64) + off * 8u64
    kf_mul(p2, pp, pp)
    kf_mul(q2, qq, qq)
    let r : i64 = KR[level as u64]
    let pp2 : *i64 = p2 as *i64   let pq2 : *i64 = q2 as *i64   let pdd : *i64 = dd as *i64
    let mut m : u64 = 0u64
    while m < 8u64 { pdd[m] = pp2[m] - r * pq2[m]   m = m + 1u64 }
    let sd : i32 = kf_sign_rec(dd, level - 1i32)
    return sp * sd
}

/* sign of x ∈ K = Q(√KR[0], √KR[1], √KR[2]): +1 / 0 / -1, exact. */
fn kf_sign(x: u64) -> i32 @export { return kf_sign_rec(x, 2i32) }

/* FIELD-EXIT DETECTOR (rational case): is sqrt(n) in K for a rational n>=0?  kfield is CLOSED under mul/add/rationalize
 * -- it never leaves K by itself. A construction leaves K only if it needs sqrt(a value). For a RATIONAL radicand,
 * sqrt(n) is in K iff sqfree(n) lies in K's SQUARE-CLASS GROUP, generated (in Q modulo squares) by the square-free
 * parts of KR[0..2]. Decided WITHOUT a root or a division: sqfree(n) times some subset-product of the generators is a
 * perfect square (its own square-free part is 1) for exactly the in-field radicands. Returns 1 = sqrt(n) in K (stays),
 * 0 = sqrt(n) not in K (the construction LEAVES the multiquadratic field -- flag it, do NOT hash it as if in K). The
 * GENERIC-K case (sqrt of a non-rational K-element, e.g. a distance between Sigma-sqrt points) is the tower-denesting
 * extension (kf_sqrt), documented but not built here. */
fn kf_rat_in_field(n: i64) -> i32 @export {
    let nn : i64 = n
    if nn < 0i64 { return 0i32 }
    if nn == 0i64 { return 1i32 }
    kf_sqfree(KR[0u64])   let g0 : i64 = SF_D
    kf_sqfree(KR[1u64])   let g1 : i64 = SF_D
    kf_sqfree(KR[2u64])   let g2 : i64 = SF_D
    kf_sqfree(nn)         let d : i64 = SF_D
    let mut mask : u64 = 0u64
    while mask < 8u64 {
        let mut prod : i64 = d
        if (mask & 1u64) != 0u64 { prod = prod * g0 }
        if (mask & 2u64) != 0u64 { prod = prod * g1 }
        if (mask & 4u64) != 0u64 { prod = prod * g2 }
        kf_sqfree(prod)
        if SF_D == 1i64 { return 1i32 }
        mask = mask + 1u64
    }
    return 0i32
}
