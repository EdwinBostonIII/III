/* 1345_bv_bits.iii -- THE MIXED ARITHMETIC+BITWISE DECIDER (harmony item 18).
 *
 * bv_ring decides arithmetic (no bitwise); the BW fragment decides bitwise (no arithmetic).
 * bv_bits decides the MIXED language by Tseitin bit-blast into III's own CDCL solver: equivalence
 * over Z/2^w as UNSAT of "some bit differs".  Arms (the classic boundary identities, full width):
 *  (1) (x & y) + (x | y) == x + y                       TRUE  (w=64)
 *  (2) x + x == x << 1                                  TRUE  (w=64)
 *  (3) x - (x & y) == x & ~y                            TRUE  (w=64)
 *  (4) x ^ y == (x | y) - (x & y)                       TRUE  (w=64)
 *  (5) x + y == x | y                                   FALSE (the carry countermodel exists)
 *  (6) (x >> 1) << 1 == x & ~1                          TRUE  (w=64)
 *  (7) MULTIPLIER identities (SAT-hard at 64 -- the width is the decider's honest contract):
 *      x*y == y*x  TRUE at w=8;  x*(y+z) == x*y + x*z  TRUE at w=6 (three multipliers; the
 *      current solver's practical boundary for triple-mul miters, precisely characterized);
 *  (8) x*y == x & y                                     FALSE (w=8)
 *  (9) an out-of-range input poisons the decision (0xFF), never fabricates a verdict;
 * (10) the DAG survives bb_equal: a second query on the same build still answers.
 * Exit 99 = the arithmetic/bitwise boundary is DECIDED, by III's own solver, no oracle. */
module corpus_1345

extern @abi(c-msvc-x64) fn bb_reset(w: u64) -> i32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_var(v: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_const(c: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_and(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_or(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_xor(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_not(a: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_add(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_sub(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shl(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_shr(a: u32, k: u64) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_mul(a: u32, b: u32) -> u32 from "bv_bits.iii"
extern @abi(c-msvc-x64) fn bb_equal(a: u32, b: u32) -> u8 from "bv_bits.iii"

fn main() -> u64 {
    /* (1) (x & y) + (x | y) == x + y */
    bb_reset(64u64)
    let x1 : u32 = bb_var(0u32)
    let y1 : u32 = bb_var(1u32)
    let l1 : u32 = bb_add(bb_and(x1, y1), bb_or(x1, y1))
    let r1 : u32 = bb_add(x1, y1)
    if bb_equal(l1, r1) != 1u8 { return 1u64 }

    /* (2) x + x == x << 1 */
    bb_reset(64u64)
    let x2 : u32 = bb_var(0u32)
    if bb_equal(bb_add(x2, x2), bb_shl(x2, 1u64)) != 1u8 { return 2u64 }

    /* (3) x - (x & y) == x & ~y */
    bb_reset(64u64)
    let x3 : u32 = bb_var(0u32)
    let y3 : u32 = bb_var(1u32)
    if bb_equal(bb_sub(x3, bb_and(x3, y3)), bb_and(x3, bb_not(y3))) != 1u8 { return 3u64 }

    /* (4) x ^ y == (x | y) - (x & y) */
    bb_reset(64u64)
    let x4 : u32 = bb_var(0u32)
    let y4 : u32 = bb_var(1u32)
    if bb_equal(bb_xor(x4, y4), bb_sub(bb_or(x4, y4), bb_and(x4, y4))) != 1u8 { return 4u64 }

    /* (5) FALSE: x + y == x | y (the carry refutes it) */
    bb_reset(64u64)
    let x5 : u32 = bb_var(0u32)
    let y5 : u32 = bb_var(1u32)
    if bb_equal(bb_add(x5, y5), bb_or(x5, y5)) != 0u8 { return 5u64 }

    /* (6) (x >> 1) << 1 == x & ~1 */
    bb_reset(64u64)
    let x6 : u32 = bb_var(0u32)
    if bb_equal(bb_shl(bb_shr(x6, 1u64), 1u64), bb_and(x6, bb_const(0xFFFFFFFFFFFFFFFEu64))) != 1u8 { return 6u64 }

    /* (7) multiplier identities at width 8 */
    bb_reset(8u64)
    let x7 : u32 = bb_var(0u32)
    let y7 : u32 = bb_var(1u32)
    if bb_equal(bb_mul(x7, y7), bb_mul(y7, x7)) != 1u8 { return 7u64 }
    bb_reset(6u64)
    let x8 : u32 = bb_var(0u32)
    let y8 : u32 = bb_var(1u32)
    let z8 : u32 = bb_var(2u32)
    let dl : u32 = bb_mul(x8, bb_add(y8, z8))
    let dr : u32 = bb_add(bb_mul(x8, y8), bb_mul(x8, z8))
    if bb_equal(dl, dr) != 1u8 { return 8u64 }

    /* (8) FALSE: x*y == x & y at width 8 */
    bb_reset(8u64)
    let x9 : u32 = bb_var(0u32)
    let y9 : u32 = bb_var(1u32)
    if bb_equal(bb_mul(x9, y9), bb_and(x9, y9)) != 0u8 { return 9u64 }

    /* (9) poisoned decision on a bad input -- never a fabricated verdict */
    bb_reset(8u64)
    let bad : u32 = bb_var(99u32)
    let ok9 : u32 = bb_var(0u32)
    if bb_equal(bad, ok9) != 0xFFu8 { return 10u64 }

    /* (10) the DAG survives bb_equal: build once, query twice */
    bb_reset(16u64)
    let xa : u32 = bb_var(0u32)
    let ya : u32 = bb_var(1u32)
    let la : u32 = bb_add(bb_and(xa, ya), bb_or(xa, ya))
    let ra : u32 = bb_add(xa, ya)
    if bb_equal(la, ra) != 1u8 { return 11u64 }
    if bb_equal(la, ra) != 1u8 { return 12u64 }
    if bb_equal(la, xa) != 0u8 { return 13u64 }

    return 99u64
}
