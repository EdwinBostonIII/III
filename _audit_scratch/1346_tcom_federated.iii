/* 1346_tcom_federated.iii -- THE PROOF-CARRYING FEDERATED COMMONS (harmony item 19).
 *
 * A peer ships (serialized goal, serialized proof) in the item-5 injective wire encoding;
 * tcom_receive deserializes BOTH into the LOCAL arena and re-runs the LOCAL kernel's admission
 * gate -- the peer's claim is RE-PROVEN, never trusted.  Arms:
 *  (1) ROUND-TRIP LAW -- serialize o deserialize == identity, byte-for-byte (so the address the
 *      peer published is exactly the address the local Commons re-derives);
 *  (2) END-TO-END FEDERATION -- a "sending node" builds + serializes refl : Id(Bool,true,true);
 *      the arena is WIPED (a genuinely fresh receiving node); tcom_receive admits (TCOM_OK) and
 *      the theorem is then citable by goal (the locally-rebuilt term names the same address);
 *  (3) ZERO-TRUST/FALSE-MATH -- a well-formed stream carrying refl(true) : Id(Bool,true,false)
 *      deserializes fine and is REFUSED by the kernel (E_UNPROVEN); never admitted;
 *  (4) MALFORMED WIRE -- a tampered tag byte, a truncated stream, and trailing garbage are all
 *      refused fail-closed (E_NULL), never half-built;
 *  (5) idempotent re-receive of the same true theorem (TCOM_OK, size unchanged).
 * Exit 99 = the Theorem DAG federates with zero trust: re-prove or refuse, one name per goal. */
module corpus_1346

extern @abi(c-msvc-x64) fn tcom_init() -> i32 from "theorem_commons.iii"
extern @abi(c-msvc-x64) fn tcom_receive(goal_bytes: u64, goal_len: u64, proof_bytes: u64, proof_len: u64) -> i32 from "theorem_commons.iii"
extern @abi(c-msvc-x64) fn tcom_cite_goal(goal: u32) -> i32 from "theorem_commons.iii"
extern @abi(c-msvc-x64) fn tcom_size() -> u64 from "theorem_commons.iii"
extern @abi(c-msvc-x64) fn tc_reset() -> u64 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_bool() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_true() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_false() -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_id(ty: u32, l: u32, r: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_refl(v: u32) -> u32 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_serialize(t: u32, out: *u8, cap: u64) -> u64 from "typecheck.iii"
extern @abi(c-msvc-x64) fn tc_deserialize(bytes: *u8, len: u64) -> u32 from "typecheck.iii"

var GW : [u8; 512]     /* the goal on the wire */
var PW : [u8; 512]     /* the proof on the wire */
var BW : [u8; 512]     /* the false goal on the wire */
var RT : [u8; 512]     /* round-trip re-serialization */

fn main() -> u64 {
    /* ---- the SENDING node ---- */
    tc_reset()
    let kb : u32 = tc_bool()
    let goal : u32 = tc_id(kb, tc_true(), tc_true())
    let prf  : u32 = tc_refl(tc_true())
    let badg : u32 = tc_id(kb, tc_true(), tc_false())
    let glen : u64 = tc_serialize(goal, (&GW as u64) as *u8, 512u64)
    let plen : u64 = tc_serialize(prf, (&PW as u64) as *u8, 512u64)
    let blen : u64 = tc_serialize(badg, (&BW as u64) as *u8, 512u64)
    if glen == 0xFFFFFFFFFFFFFFFFu64 { return 1u64 }
    if plen == 0xFFFFFFFFFFFFFFFFu64 { return 1u64 }
    if blen == 0xFFFFFFFFFFFFFFFFu64 { return 1u64 }

    /* ---- the RECEIVING node: a genuinely fresh arena ---- */
    tc_reset()
    tcom_init()

    /* (1) ROUND-TRIP LAW: deserialize then re-serialize, byte-identical */
    let g2 : u32 = tc_deserialize((&GW as u64) as *u8, glen)
    if g2 == 0u32 { return 2u64 }
    let rlen : u64 = tc_serialize(g2, (&RT as u64) as *u8, 512u64)
    if rlen != glen { return 3u64 }
    let mut i : u64 = 0u64
    while i < glen {
        if RT[i] != GW[i] { return 4u64 }
        i = i + 1u64
    }

    /* (2) END-TO-END: receive -> admitted -> citable by the locally-rebuilt goal */
    if tcom_receive((&GW as u64), glen, (&PW as u64), plen) != 0i32 { return 5u64 }
    if tcom_size() != 1u64 { return 6u64 }
    if tcom_cite_goal(g2) != 0i32 { return 7u64 }

    /* (3) ZERO-TRUST: well-formed wire, FALSE mathematics -> kernel refusal, not admission */
    if tcom_receive((&BW as u64), blen, (&PW as u64), plen) != -3i32 { return 8u64 }
    if tcom_size() != 1u64 { return 9u64 }

    /* (4) MALFORMED WIRE: tag tamper / truncation / trailing garbage -- all fail-closed */
    let save : u8 = GW[1u64]
    GW[1u64] = 0xEEu8                                       /* an unknown tag */
    if tcom_receive((&GW as u64), glen, (&PW as u64), plen) != -1i32 { return 10u64 }
    GW[1u64] = save
    if tcom_receive((&GW as u64), glen - 3u64, (&PW as u64), plen) != -1i32 { return 11u64 }
    if tcom_receive((&GW as u64), glen + 1u64, (&PW as u64), plen) != -1i32 { return 12u64 }
    if tcom_size() != 1u64 { return 13u64 }

    /* (5) idempotent re-receive */
    if tcom_receive((&GW as u64), glen, (&PW as u64), plen) != 0i32 { return 14u64 }
    if tcom_size() != 1u64 { return 15u64 }

    return 99u64
}
