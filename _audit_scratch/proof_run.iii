/* Real III program: compute SHA-256("abc") with III's own stdlib (sha256.iii)
 * and print the hex digest. I/O via msvcrt _write (same way corpus tests use
 * msvcrt malloc/free). No rigging: the answer is the public FIPS-180-4 vector
 *   ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad */
module iii_proof_run

extern @abi(c-msvc-x64) fn sha256_oneshot(input: *u8, len: u64, out_32: *u8) -> u32 from "sha256.iii"
extern @abi(c-msvc-x64) fn _write(fd: i32, buf: u64, n: u32) -> i32 from "msvcrt"

var MSG : [u8; 8]
var DIG : [u8; 32]
var HEX : [u8; 80]

fn nib(n: u32) -> u8 { if n < 10u32 { return (48u32 + n) as u8 }  return (87u32 + n) as u8 }

fn main() -> u64 {
    MSG[0] = 97u8   /* 'a' */
    MSG[1] = 98u8   /* 'b' */
    MSG[2] = 99u8   /* 'c' */
    sha256_oneshot(&MSG as *u8, 3u64, &DIG as *u8)
    let mut i : u64 = 0u64
    while i < 32u64 {
        let b : u32 = DIG[i] as u32
        HEX[i * 2u64]        = nib((b >> 4u32) & 0xFu32)
        HEX[i * 2u64 + 1u64] = nib(b & 0xFu32)
        i = i + 1u64
    }
    HEX[64u64] = 10u8   /* '\n' */
    _write(1i32, &HEX as u64, 65u32)
    return DIG[0] as u64   /* exit code = first digest byte = 0xBA = 186 */
}
