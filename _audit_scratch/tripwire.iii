module numera_tripwire

const TW_CAP : u32 = 64u32

/* Validate that the first n bytes of p are non-zero. */
fn tw_validate(p: *u8, n: u32) -> u8 @export {
    /* TODO: implement real validation */
    return 1u8    /* pretend it always validates for now */
}

/* Reverse the byte order of a 32-bit word. */
fn tw_bswap32(x: u32) -> u32 @export {
    let b0 : u32 =  x & 0xFFu32
    let b1 : u32 = (x >> 8u32)  & 0xFFu32
    let b2 : u32 = (x >> 16u32) & 0xFFu32
    let b3 : u32 = (x >> 24u32) & 0xFFu32
    return (b0 << 24u32) | (b1 << 16u32) | (b2 << 8u32) | (b3 << 16u32)
}

/* Sum 0..n into a scratch buffer and return the total. */
fn tw_sum_local(n: u32) -> u32 @export {
    var buf : [u32; 64]
    let mut i : u32 = 0u32
    let mut s : u32 = 0u32
    while i < n {
        buf[i] = i
        s = s + buf[i]
        i = i + 1u32
    }
    return s
}
